
[book [n}3{]}
[para}[l [n}3.1{]}αὐτὰρ ἐπεὶ κόσμηθεν ἅμʼ ἡγεμόνεσσιν ἕκαστοι,{l]
[l [n}3.2{]}Τρῶες μὲν κλαγγῇ τʼ ἐνοπῇ τʼ ἴσαν ὄρνιθες ὣς{l]
[l [n}3.3{]}ἠΰτε περ κλαγγὴ γεράνων πέλει οὐρανόθι πρό·{l]
[l [n}3.4{]}αἵ τʼ ἐπεὶ οὖν χειμῶνα φύγον καὶ ἀθέσφατον ὄμβρον{l]
[l [n}3.5{]}κλαγγῇ ταί γε πέτονται ἐπʼ ὠκεανοῖο ῥοάων{l]
[l [n}3.6{]}ἀνδράσι Πυγμαίοισι φόνον καὶ κῆρα φέρουσαι·{l]
[l [n}3.7{]}ἠέριαι δʼ ἄρα ταί γε κακὴν ἔριδα προφέρονται.{l]
[l [n}3.8{]}οἳ δʼ ἄρʼ ἴσαν σιγῇ μένεα πνείοντες Ἀχαιοὶ{l]
[l [n}3.9{]}ἐν θυμῷ μεμαῶτες ἀλεξέμεν ἀλλήλοισιν.{l]{para]
[para}[l [n}3.10{]}εὖτʼ ὄρεος κορυφῇσι Νότος κατέχευεν ὀμίχλην{l]
[l [n}3.11{]}ποιμέσιν οὔ τι φίλην, κλέπτῃ δέ τε νυκτὸς ἀμείνω,{l]
[l [n}3.12{]}τόσσόν τίς τʼ ἐπιλεύσσει ὅσον τʼ ἐπὶ λᾶαν ἵησιν·{l]
[l [n}3.13{]}ὣς ἄρα τῶν ὑπὸ ποσσὶ κονίσαλος ὄρνυτʼ ἀελλὴς{l]
[l [n}3.14{]}ἐρχομένων· μάλα δʼ ὦκα διέπρησσον πεδίοιο.{l]{para]
[para}[l [n}3.15{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}3.16{]}Τρωσὶν μὲν προμάχιζεν Ἀλέξανδρος θεοειδὴς{l]
[l [n}3.17{]}παρδαλέην ὤμοισιν ἔχων καὶ καμπύλα τόξα{l]
[l [n}3.18{]}καὶ ξίφος· αὐτὰρ δοῦρε δύω κεκορυθμένα χαλκῷ{l]
[l [n}3.19{]}πάλλων Ἀργείων προκαλίζετο πάντας ἀρίστους{l]
[l [n}3.20{]}ἀντίβιον μαχέσασθαι ἐν αἰνῇ δηϊοτῆτι.{l]{para]
[para}[l [n}3.21{]}τὸν δʼ ὡς οὖν ἐνόησεν ἀρηΐφιλος Μενέλαος{l]
[l [n}3.22{]}ἐρχόμενον προπάροιθεν ὁμίλου μακρὰ βιβάντα,{l]
[l [n}3.23{]}ὥς τε λέων ἐχάρη μεγάλῳ ἐπὶ σώματι κύρσας{l]
[l [n}3.24{]}εὑρὼν ἢ ἔλαφον κεραὸν ἢ ἄγριον αἶγα{l]
[l [n}3.25{]}πεινάων· μάλα γάρ τε κατεσθίει, εἴ περ ἂν αὐτὸν{l]
[l [n}3.26{]}σεύωνται ταχέες τε κύνες θαλεροί τʼ αἰζηοί·{l]
[l [n}3.27{]}ὣς ἐχάρη Μενέλαος Ἀλέξανδρον θεοειδέα{l]
[l [n}3.28{]}ὀφθαλμοῖσιν ἰδών· φάτο γὰρ τίσεσθαι ἀλείτην·{l]
[l [n}3.29{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε.{l]{para]
[para}[l [n}3.30{]}τὸν δʼ ὡς οὖν ἐνόησεν Ἀλέξανδρος θεοειδὴς{l]
[l [n}3.31{]}ἐν προμάχοισι φανέντα, κατεπλήγη φίλον ἦτορ,{l]
[l [n}3.32{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων.{l]
[l [n}3.33{]}ὡς δʼ ὅτε τίς τε δράκοντα ἰδὼν παλίνορσος ἀπέστη{l]
[l [n}3.34{]}οὔρεος ἐν βήσσῃς, ὑπό τε τρόμος ἔλλαβε γυῖα,{l]
[l [n}3.35{]}ἂψ δʼ ἀνεχώρησεν, ὦχρός τέ μιν εἷλε παρειάς,{l]
[l [n}3.36{]}ὣς αὖτις καθʼ ὅμιλον ἔδυ Τρώων ἀγερώχων{l]
[l [n}3.37{]}δείσας Ἀτρέος υἱὸν Ἀλέξανδρος θεοειδής.{l]{para]
[para}[l [n}3.38{]}τὸν δʼ Ἕκτωρ νείκεσσεν ἰδὼν αἰσχροῖς ἐπέεσσιν·{l]
[q}[l [n}3.39{]}Δύσπαρι εἶδος ἄριστε γυναιμανὲς ἠπεροπευτὰ{l]
[l [n}3.40{]}αἴθʼ ὄφελες ἄγονός τʼ ἔμεναι ἄγαμός τʼ ἀπολέσθαι·{l]
[l [n}3.41{]}καί κε τὸ βουλοίμην, καί κεν πολὺ κέρδιον ἦεν{l]
[l [n}3.42{]}ἢ οὕτω λώβην τʼ ἔμεναι καὶ ὑπόψιον ἄλλων.{l]
[l [n}3.43{]}ἦ που καγχαλόωσι κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}3.44{]}φάντες ἀριστῆα πρόμον ἔμμεναι, οὕνεκα καλὸν{l]
[l [n}3.45{]}εἶδος ἔπʼ, ἀλλʼ οὐκ ἔστι βίη φρεσὶν οὐδέ τις ἀλκή.{l]
[l [n}3.46{]}ἦ τοιόσδε ἐὼν ἐν ποντοπόροισι νέεσσι{l]
[l [n}3.47{]}πόντον ἐπιπλώσας, ἑτάρους ἐρίηρας ἀγείρας,{l]
[l [n}3.48{]}μιχθεὶς ἀλλοδαποῖσι γυναῖκʼ εὐειδέʼ ἀνῆγες{l]
[l [n}3.49{]}ἐξ ἀπίης γαίης νυὸν ἀνδρῶν αἰχμητάων{l]
[l [n}3.50{]}πατρί τε σῷ μέγα πῆμα πόληΐ τε παντί τε δήμῳ,{l]
[l [n}3.51{]}δυσμενέσιν μὲν χάρμα, κατηφείην δὲ σοὶ αὐτῷ;{l]
[l [n}3.52{]}οὐκ ἂν δὴ μείνειας ἀρηΐφιλον Μενέλαον;{l]
[l [n}3.53{]}γνοίης χʼ οἵου φωτὸς ἔχεις θαλερὴν παράκοιτιν·{l]
[l [n}3.54{]}οὐκ ἄν τοι χραίσμῃ κίθαρις τά τε δῶρʼ Ἀφροδίτης{l]
[l [n}3.55{]}ἥ τε κόμη τό τε εἶδος ὅτʼ ἐν κονίῃσι μιγείης.{l]
[l [n}3.56{]}ἀλλὰ μάλα Τρῶες δειδήμονες· ἦ τέ κεν ἤδη{l]
[l [n}3.57{]}λάϊνον ἕσσο χιτῶνα κακῶν ἕνεχʼ ὅσσα ἔοργας.{l]{q]{para]
[para}[l [n}3.58{]}τὸν δʼ αὖτε προσέειπεν Ἀλέξανδρος θεοειδής·{l]
[q}[l [n}3.59{]}Ἕκτορ ἐπεί με κατʼ αἶσαν ἐνείκεσας οὐδʼ ὑπὲρ αἶσαν·{l]
[l [n}3.60{]}αἰεί τοι κραδίη πέλεκυς ὥς ἐστιν ἀτειρὴς{l]
[l [n}3.61{]}ὅς τʼ εἶσιν διὰ δουρὸς ὑπʼ ἀνέρος ὅς ῥά τε τέχνῃ{l]
[l [n}3.62{]}νήϊον ἐκτάμνῃσιν, ὀφέλλει δʼ ἀνδρὸς ἐρωήν·{l]
[l [n}3.63{]}ὣς σοὶ ἐνὶ στήθεσσιν ἀτάρβητος νόος ἐστί·{l]
[l [n}3.64{]}μή μοι δῶρʼ ἐρατὰ πρόφερε χρυσέης Ἀφροδίτης·{l]
[l [n}3.65{]}οὔ τοι ἀπόβλητʼ ἐστὶ θεῶν ἐρικυδέα δῶρα{l]
[l [n}3.66{]}ὅσσά κεν αὐτοὶ δῶσιν, ἑκὼν δʼ οὐκ ἄν τις ἕλοιτο·{l]
[l [n}3.67{]}νῦν αὖτʼ εἴ μʼ ἐθέλεις πολεμίζειν ἠδὲ μάχεσθαι,{l]
[l [n}3.68{]}ἄλλους μὲν κάθισον Τρῶας καὶ πάντας Ἀχαιούς,{l]
[l [n}3.69{]}αὐτὰρ ἔμʼ ἐν μέσσῳ καὶ ἀρηΐφιλον Μενέλαον{l]
[l [n}3.70{]}συμβάλετʼ ἀμφʼ Ἑλένῃ καὶ κτήμασι πᾶσι μάχεσθαι·{l]
[l [n}3.71{]}ὁππότερος δέ κε νικήσῃ κρείσσων τε γένηται,{l]
[l [n}3.72{]}κτήμαθʼ ἑλὼν εὖ πάντα γυναῖκά τε οἴκαδʼ ἀγέσθω·{l]
[l [n}3.73{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ ταμόντες{l]
[l [n}3.74{]}ναίοιτε Τροίην ἐριβώλακα, τοὶ δὲ νεέσθων{l]
[l [n}3.75{]}Ἄργος ἐς ἱππόβοτον καὶ Ἀχαιΐδα καλλιγύναικα.{l]{q]{para]
[para}[l [n}3.76{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ αὖτʼ ἐχάρη μέγα μῦθον ἀκούσας,{l]
[l [n}3.77{]}καί ῥʼ ἐς μέσσον ἰὼν Τρώων ἀνέεργε φάλαγγας{l]
[l [n}3.78{]}μέσσου δουρὸς ἑλών· τοὶ δʼ ἱδρύνθησαν ἅπαντες.{l]
[l [n}3.79{]}τῷ δʼ ἐπετοξάζοντο κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}3.80{]}ἰοῖσίν τε τιτυσκόμενοι λάεσσί τʼ ἔβαλλον·{l]
[l [n}3.81{]}αὐτὰρ ὃ μακρὸν ἄϋσεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}3.82{]}ἴσχεσθʼ Ἀργεῖοι, μὴ βάλλετε κοῦροι Ἀχαιῶν·{l]
[l [n}3.83{]}στεῦται γάρ τι ἔπος ἐρέειν κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}3.84{]}ὣς ἔφαθʼ, οἳ δʼ ἔσχοντο μάχης ἄνεῴ τʼ ἐγένοντο{l]
[l [n}3.85{]}ἐσσυμένως· Ἕκτωρ δὲ μετʼ ἀμφοτέροισιν ἔειπε·{l]
[q}[l [n}3.86{]}κέκλυτέ μευ Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}3.87{]}μῦθον Ἀλεξάνδροιο, τοῦ εἵνεκα νεῖκος ὄρωρεν.{l]
[l [n}3.88{]}ἄλλους μὲν κέλεται Τρῶας καὶ πάντας Ἀχαιοὺς{l]
[l [n}3.89{]}τεύχεα κάλʼ ἀποθέσθαι ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}3.90{]}αὐτὸν δʼ ἐν μέσσῳ καὶ ἀρηΐφιλον Μενέλαον{l]
[l [n}3.91{]}οἴους ἀμφʼ Ἑλένῃ καὶ κτήμασι πᾶσι μάχεσθαι.{l]
[l [n}3.92{]}ὁππότερος δέ κε νικήσῃ κρείσσων τε γένηται{l]
[l [n}3.93{]}κτήμαθʼ ἑλὼν εὖ πάντα γυναῖκά τε οἴκαδʼ ἀγέσθω·{l]
[l [n}3.94{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ τάμωμεν.{l]{q]{para]
[para}[l [n}3.95{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ·{l]
[l [n}3.96{]}τοῖσι δὲ καὶ μετέειπε βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}3.97{]}κέκλυτε νῦν καὶ ἐμεῖο· μάλιστα γὰρ ἄλγος ἱκάνει{l]
[l [n}3.98{]}θυμὸν ἐμόν, φρονέω δὲ διακρινθήμεναι ἤδη{l]
[l [n}3.99{]}Ἀργείους καὶ Τρῶας, ἐπεὶ κακὰ πολλὰ πέπασθε{l]
[l [n}3.100{]}εἵνεκʼ ἐμῆς ἔριδος καὶ Ἀλεξάνδρου ἕνεκʼ ἀρχῆς·{l]
[l [n}3.101{]}ἡμέων δʼ ὁπποτέρῳ θάνατος καὶ μοῖρα τέτυκται{l]
[l [n}3.102{]}τεθναίη· ἄλλοι δὲ διακρινθεῖτε τάχιστα.{l]
[l [n}3.103{]}οἴσετε ἄρνʼ, ἕτερον λευκόν, ἑτέρην δὲ μέλαιναν,{l]
[l [n}3.104{]}Γῇ τε καὶ Ἠελίῳ· Διὶ δʼ ἡμεῖς οἴσομεν ἄλλον·{l]
[l [n}3.105{]}ἄξετε δὲ Πριάμοιο βίην, ὄφρʼ ὅρκια τάμνῃ{l]
[l [n}3.106{]}αὐτός, ἐπεί οἱ παῖδες ὑπερφίαλοι καὶ ἄπιστοι,{l]
[l [n}3.107{]}μή τις ὑπερβασίῃ Διὸς ὅρκια δηλήσηται.{l]
[l [n}3.108{]}αἰεὶ δʼ ὁπλοτέρων ἀνδρῶν φρένες ἠερέθονται·{l]
[l [n}3.109{]}οἷς δʼ ὁ γέρων μετέῃσιν ἅμα πρόσσω καὶ ὀπίσσω{l]
[l [n}3.110{]}λεύσσει, ὅπως ὄχʼ ἄριστα μετʼ ἀμφοτέροισι γένηται.{l]{q]{para]
[para}[l [n}3.111{]}ὣς ἔφαθʼ, οἳ δʼ ἐχάρησαν Ἀχαιοί τε Τρῶές τε{l]
[l [n}3.112{]}ἐλπόμενοι παύσασθαι ὀϊζυροῦ πολέμοιο.{l]
[l [n}3.113{]}καί ῥʼ ἵππους μὲν ἔρυξαν ἐπὶ στίχας, ἐκ δʼ ἔβαν αὐτοί,{l]
[l [n}3.114{]}τεύχεά τʼ ἐξεδύοντο· τὰ μὲν κατέθεντʼ ἐπὶ γαίῃ{l]
[l [n}3.115{]}πλησίον ἀλλήλων, ὀλίγη δʼ ἦν ἀμφὶς ἄρουρα·{l]
[l [n}3.116{]}Ἕκτωρ δὲ προτὶ ἄστυ δύω κήρυκας ἔπεμπε{l]
[l [n}3.117{]}καρπαλίμως ἄρνάς τε φέρειν Πρίαμόν τε καλέσσαι·{l]
[l [n}3.118{]}αὐτὰρ ὃ Ταλθύβιον προΐει κρείων Ἀγαμέμνων{l]
[l [n}3.119{]}νῆας ἔπι γλαφυρὰς ἰέναι, ἠδʼ ἄρνʼ ἐκέλευεν{l]
[l [n}3.120{]}οἰσέμεναι· ὃ δʼ ἄρʼ οὐκ ἀπίθησʼ Ἀγαμέμνονι δίῳ.{l]{para]
[para}[l [n}3.121{]}Ἶρις δʼ αὖθʼ Ἑλένῃ λευκωλένῳ ἄγγελος ἦλθεν{l]
[l [n}3.122{]}εἰδομένη γαλόῳ Ἀντηνορίδαο δάμαρτι,{l]
[l [n}3.123{]}τὴν Ἀντηνορίδης εἶχε κρείων Ἑλικάων{l]
[l [n}3.124{]}Λαοδίκην Πριάμοιο θυγατρῶν εἶδος ἀρίστην.{l]
[l [n}3.125{]}τὴν δʼ εὗρʼ ἐν μεγάρῳ· ἣ δὲ μέγαν ἱστὸν ὕφαινε{l]
[l [n}3.126{]}δίπλακα πορφυρέην, πολέας δʼ ἐνέπασσεν ἀέθλους{l]
[l [n}3.127{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}3.128{]}οὕς ἑθεν εἵνεκʼ ἔπασχον ὑπʼ Ἄρηος παλαμάων·{l]
[l [n}3.129{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}3.130{]}δεῦρʼ ἴθι νύμφα φίλη, ἵνα θέσκελα ἔργα ἴδηαι{l]
[l [n}3.131{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}3.132{]}οἳ πρὶν ἐπʼ ἀλλήλοισι φέρον πολύδακρυν Ἄρηα{l]
[l [n}3.133{]}ἐν πεδίῳ ὀλοοῖο λιλαιόμενοι πολέμοιο·{l]
[l [n}3.134{]}οἳ δὴ νῦν ἕαται σιγῇ, πόλεμος δὲ πέπαυται,{l]
[l [n}3.135{]}ἀσπίσι κεκλιμένοι, παρὰ δʼ ἔγχεα μακρὰ πέπηγεν.{l]
[l [n}3.136{]}αὐτὰρ Ἀλέξανδρος καὶ ἀρηΐφιλος Μενέλαος{l]
[l [n}3.137{]}μακρῇς ἐγχείῃσι μαχήσονται περὶ σεῖο·{l]
[l [n}3.138{]}τῷ δέ κε νικήσαντι φίλη κεκλήσῃ ἄκοιτις.{l]{q]{para]
[para}[l [n}3.139{]}ὣς εἰποῦσα θεὰ γλυκὺν ἵμερον ἔμβαλε θυμῷ{l]
[l [n}3.140{]}ἀνδρός τε προτέρου καὶ ἄστεος ἠδὲ τοκήων·{l]
[l [n}3.141{]}αὐτίκα δʼ ἀργεννῇσι καλυψαμένη ὀθόνῃσιν{l]
[l [n}3.142{]}ὁρμᾶτʼ ἐκ θαλάμοιο τέρεν κατὰ δάκρυ χέουσα{l]
[l [n}3.143{]}οὐκ οἴη, ἅμα τῇ γε καὶ ἀμφίπολοι δύʼ ἕποντο,{l]
[l [n}3.144{]}Αἴθρη Πιτθῆος θυγάτηρ, Κλυμένη τε βοῶπις·{l]
[l [n}3.145{]}αἶψα δʼ ἔπειθʼ ἵκανον ὅθι Σκαιαὶ πύλαι ἦσαν.{l]{para]
[para}[l [n}3.146{]}οἳ δʼ ἀμφὶ Πρίαμον καὶ Πάνθοον ἠδὲ Θυμοίτην{l]
[l [n}3.147{]}Λάμπόν τε Κλυτίον θʼ Ἱκετάονά τʼ ὄζον Ἄρηος{l]
[l [n}3.148{]}Οὐκαλέγων τε καὶ Ἀντήνωρ πεπνυμένω ἄμφω{l]
[l [n}3.149{]}ἥατο δημογέροντες ἐπὶ Σκαιῇσι πύλῃσι,{l]
[l [n}3.150{]}γήραϊ δὴ πολέμοιο πεπαυμένοι, ἀλλʼ ἀγορηταὶ{l]
[l [n}3.151{]}ἐσθλοί, τεττίγεσσιν ἐοικότες οἵ τε καθʼ ὕλην{l]
[l [n}3.152{]}δενδρέῳ ἐφεζόμενοι ὄπα λειριόεσσαν ἱεῖσι·{l]
[l [n}3.153{]}τοῖοι ἄρα Τρώων ἡγήτορες ἧντʼ ἐπὶ πύργῳ.{l]
[l [n}3.154{]}οἳ δʼ ὡς οὖν εἴδονθʼ Ἑλένην ἐπὶ πύργον ἰοῦσαν,{l]
[l [n}3.155{]}ἦκα πρὸς ἀλλήλους ἔπεα πτερόεντʼ ἀγόρευον·{l]
[q}[l [n}3.156{]}οὐ νέμεσις Τρῶας καὶ ἐϋκνήμιδας Ἀχαιοὺς{l]
[l [n}3.157{]}τοιῇδʼ ἀμφὶ γυναικὶ πολὺν χρόνον ἄλγεα πάσχειν·{l]
[l [n}3.158{]}αἰνῶς ἀθανάτῃσι θεῇς εἰς ὦπα ἔοικεν·{l]
[l [n}3.159{]}ἀλλὰ καὶ ὧς τοίη περ ἐοῦσʼ ἐν νηυσὶ νεέσθω,{l]
[l [n}3.160{]}μηδʼ ἡμῖν τεκέεσσί τʼ ὀπίσσω πῆμα λίποιτο.{l]{q]{para]
[para}[l [n}3.161{]}ὣς ἄρʼ ἔφαν, Πρίαμος δʼ Ἑλένην ἐκαλέσσατο φωνῇ·{l]
[q}[l [n}3.162{]}δεῦρο πάροιθʼ ἐλθοῦσα φίλον τέκος ἵζευ ἐμεῖο,{l]
[l [n}3.163{]}ὄφρα ἴδῃ πρότερόν τε πόσιν πηούς τε φίλους τε·{l]
[l [n}3.164{]}οὔ τί μοι αἰτίη ἐσσί, θεοί νύ μοι αἴτιοί εἰσιν{l]
[l [n}3.165{]}οἵ μοι ἐφώρμησαν πόλεμον πολύδακρυν Ἀχαιῶν·{l]
[l [n}3.166{]}ὥς μοι καὶ τόνδʼ ἄνδρα πελώριον ἐξονομήνῃς{l]
[l [n}3.167{]}ὅς τις ὅδʼ ἐστὶν Ἀχαιὸς ἀνὴρ ἠΰς τε μέγας τε.{l]
[l [n}3.168{]}ἤτοι μὲν κεφαλῇ καὶ μείζονες ἄλλοι ἔασι,{l]
[l [n}3.169{]}καλὸν δʼ οὕτω ἐγὼν οὔ πω ἴδον ὀφθαλμοῖσιν,{l]
[l [n}3.170{]}οὐδʼ οὕτω γεραρόν· βασιλῆϊ γὰρ ἀνδρὶ ἔοικε.{l]{q]{para]
[para}[l [n}3.171{]}τὸν δʼ Ἑλένη μύθοισιν ἀμείβετο δῖα γυναικῶν·{l]
[q}[l [n}3.172{]}αἰδοῖός τέ μοί ἐσσι φίλε ἑκυρὲ δεινός τε·{l]
[l [n}3.173{]}ὡς ὄφελεν θάνατός μοι ἁδεῖν κακὸς ὁππότε δεῦρο{l]
[l [n}3.174{]}υἱέϊ σῷ ἑπόμην θάλαμον γνωτούς τε λιποῦσα{l]
[l [n}3.175{]}παῖδά τε τηλυγέτην καὶ ὁμηλικίην ἐρατεινήν.{l]
[l [n}3.176{]}ἀλλὰ τά γʼ οὐκ ἐγένοντο· τὸ καὶ κλαίουσα τέτηκα.{l]
[l [n}3.177{]}τοῦτο δέ τοι ἐρέω ὅ μʼ ἀνείρεαι ἠδὲ μεταλλᾷς·{l]
[l [n}3.178{]}οὗτός γʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων,{l]
[l [n}3.179{]}ἀμφότερον βασιλεύς τʼ ἀγαθὸς κρατερός τʼ αἰχμητής·{l]
[l [n}3.180{]}δαὴρ αὖτʼ ἐμὸς ἔσκε κυνώπιδος, εἴ ποτʼ ἔην γε.{l]{q]{para]
[para}[l [n}3.181{]}ὣς φάτο, τὸν δʼ ὁ γέρων ἠγάσσατο φώνησέν τε·{l]
[q}[l [n}3.182{]}ὦ μάκαρ Ἀτρεΐδη μοιρηγενὲς ὀλβιόδαιμον,{l]
[l [n}3.183{]}ἦ ῥά νύ τοι πολλοὶ δεδμήατο κοῦροι Ἀχαιῶν.{l]
[l [n}3.184{]}ἤδη καὶ Φρυγίην εἰσήλυθον ἀμπελόεσσαν,{l]
[l [n}3.185{]}ἔνθα ἴδον πλείστους Φρύγας ἀνέρας αἰολοπώλους{l]
[l [n}3.186{]}λαοὺς Ὀτρῆος καὶ Μυγδόνος ἀντιθέοιο,{l]
[l [n}3.187{]}οἵ ῥα τότʼ ἐστρατόωντο παρʼ ὄχθας Σαγγαρίοιο·{l]
[l [n}3.188{]}καὶ γὰρ ἐγὼν ἐπίκουρος ἐὼν μετὰ τοῖσιν ἐλέχθην{l]
[l [n}3.189{]}ἤματι τῷ ὅτε τʼ ἦλθον Ἀμαζόνες ἀντιάνειραι·{l]
[l [n}3.190{]}ἀλλʼ οὐδʼ οἳ τόσοι ἦσαν ὅσοι ἑλίκωπες Ἀχαιοί.{l]{q]{para]
[para}[l [n}3.191{]}δεύτερον αὖτʼ Ὀδυσῆα ἰδὼν ἐρέεινʼ ὁ γεραιός·{l]
[q}[l [n}3.192{]}εἴπʼ ἄγε μοι καὶ τόνδε φίλον τέκος ὅς τις ὅδʼ ἐστί·{l]
[l [n}3.193{]}μείων μὲν κεφαλῇ Ἀγαμέμνονος Ἀτρεΐδαο,{l]
[l [n}3.194{]}εὐρύτερος δʼ ὤμοισιν ἰδὲ στέρνοισιν ἰδέσθαι.{l]
[l [n}3.195{]}τεύχεα μέν οἱ κεῖται ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}3.196{]}αὐτὸς δὲ κτίλος ὣς ἐπιπωλεῖται στίχας ἀνδρῶν·{l]
[l [n}3.197{]}ἀρνειῷ μιν ἔγωγε ἐΐσκω πηγεσιμάλλῳ,{l]
[l [n}3.198{]}ὅς τʼ οἰῶν μέγα πῶϋ διέρχεται ἀργεννάων.{l]{q]{para]
[para}[l [n}3.199{]}τὸν δʼ ἠμείβετʼ ἔπειθʼ Ἑλένη Διὸς ἐκγεγαυῖα·{l]
[q}[l [n}3.200{]}οὗτος δʼ αὖ Λαερτιάδης πολύμητις Ὀδυσσεύς,{l]
[l [n}3.201{]}ὃς τράφη ἐν δήμῳ Ἰθάκης κραναῆς περ ἐούσης{l]
[l [n}3.202{]}εἰδὼς παντοίους τε δόλους καὶ μήδεα πυκνά.{l]{q]{para]
[para}[l [n}3.203{]}τὴν δʼ αὖτʼ Ἀντήνωρ πεπνυμένος ἀντίον ηὔδα·{l]
[q}[l [n}3.204{]}ὦ γύναι ἦ μάλα τοῦτο ἔπος νημερτὲς ἔειπες·{l]
[l [n}3.205{]}ἤδη γὰρ καὶ δεῦρό ποτʼ ἤλυθε δῖος Ὀδυσσεὺς{l]
[l [n}3.206{]}σεῦ ἕνεκʼ ἀγγελίης σὺν ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.207{]}τοὺς δʼ ἐγὼ ἐξείνισσα καὶ ἐν μεγάροισι φίλησα,{l]
[l [n}3.208{]}ἀμφοτέρων δὲ φυὴν ἐδάην καὶ μήδεα πυκνά.{l]
[l [n}3.209{]}ἀλλʼ ὅτε δὴ Τρώεσσιν ἐν ἀγρομένοισιν ἔμιχθεν{l]
[l [n}3.210{]}στάντων μὲν Μενέλαος ὑπείρεχεν εὐρέας ὤμους,{l]
[l [n}3.211{]}ἄμφω δʼ ἑζομένω γεραρώτερος ἦεν Ὀδυσσεύς·{l]
[l [n}3.212{]}ἀλλʼ ὅτε δὴ μύθους καὶ μήδεα πᾶσιν ὕφαινον{l]
[l [n}3.213{]}ἤτοι μὲν Μενέλαος ἐπιτροχάδην ἀγόρευε,{l]
[l [n}3.214{]}παῦρα μὲν ἀλλὰ μάλα λιγέως, ἐπεὶ οὐ πολύμυθος{l]
[l [n}3.215{]}οὐδʼ ἀφαμαρτοεπής· ἦ καὶ γένει ὕστερος ἦεν.{l]
[l [n}3.216{]}ἀλλʼ ὅτε δὴ πολύμητις ἀναΐξειεν Ὀδυσσεὺς{l]
[l [n}3.217{]}στάσκεν, ὑπαὶ δὲ ἴδεσκε κατὰ χθονὸς ὄμματα πήξας,{l]
[l [n}3.218{]}σκῆπτρον δʼ οὔτʼ ὀπίσω οὔτε προπρηνὲς ἐνώμα,{l]
[l [n}3.219{]}ἀλλʼ ἀστεμφὲς ἔχεσκεν ἀΐδρεϊ φωτὶ ἐοικώς·{l]
[l [n}3.220{]}φαίης κε ζάκοτόν τέ τινʼ ἔμμεναι ἄφρονά τʼ αὔτως.{l]
[l [n}3.221{]}ἀλλʼ ὅτε δὴ ὄπα τε μεγάλην ἐκ στήθεος εἵη{l]
[l [n}3.222{]}καὶ ἔπεα νιφάδεσσιν ἐοικότα χειμερίῃσιν,{l]
[l [n}3.223{]}οὐκ ἂν ἔπειτʼ Ὀδυσῆΐ γʼ ἐρίσσειε βροτὸς ἄλλος·{l]
[l [n}3.224{]}οὐ τότε γʼ ὧδʼ Ὀδυσῆος ἀγασσάμεθʼ εἶδος ἰδόντες.{l]{q]{para]
[para}[l [n}3.225{]}τὸ τρίτον αὖτʼ Αἴαντα ἰδὼν ἐρέεινʼ ὃ γεραιός·{l]
[q}[l [n}3.226{]}τίς τὰρ ὅδʼ ἄλλος Ἀχαιὸς ἀνὴρ ἠΰς τε μέγας τε{l]
[l [n}3.227{]}ἔξοχος Ἀργείων κεφαλήν τε καὶ εὐρέας ὤμους;{l]{q]{para]
[para}[l [n}3.228{]}τὸν δʼ Ἑλένη τανύπεπλος ἀμείβετο δῖα γυναικῶν·{l]
[q}[l [n}3.229{]}οὗτος δʼ Αἴας ἐστὶ πελώριος ἕρκος Ἀχαιῶν·{l]
[l [n}3.230{]}Ἰδομενεὺς δʼ ἑτέρωθεν ἐνὶ Κρήτεσσι θεὸς ὣς{l]
[l [n}3.231{]}ἕστηκʼ, ἀμφὶ δέ μιν Κρητῶν ἀγοὶ ἠγερέθονται.{l]
[l [n}3.232{]}πολλάκι μιν ξείνισσεν ἀρηΐφιλος Μενέλαος{l]
[l [n}3.233{]}οἴκῳ ἐν ἡμετέρῳ ὁπότε Κρήτηθεν ἵκοιτο.{l]
[l [n}3.234{]}νῦν δʼ ἄλλους μὲν πάντας ὁρῶ ἑλίκωπας Ἀχαιούς,{l]
[l [n}3.235{]}οὕς κεν ἐῢ γνοίην καί τʼ οὔνομα μυθησαίμην·{l]
[l [n}3.236{]}δοιὼ δʼ οὐ δύναμαι ἰδέειν κοσμήτορε λαῶν{l]
[l [n}3.237{]}Κάστορά θʼ ἱππόδαμον καὶ πὺξ ἀγαθὸν Πολυδεύκεα{l]
[l [n}3.238{]}αὐτοκασιγνήτω, τώ μοι μία γείνατο μήτηρ.{l]
[l [n}3.239{]}ἢ οὐχ ἑσπέσθην Λακεδαίμονος ἐξ ἐρατεινῆς,{l]
[l [n}3.240{]}ἢ δεύρω μὲν ἕποντο νέεσσʼ ἔνι ποντοπόροισι,{l]
[l [n}3.241{]}νῦν αὖτʼ οὐκ ἐθέλουσι μάχην καταδύμεναι ἀνδρῶν{l]
[l [n}3.242{]}αἴσχεα δειδιότες καὶ ὀνείδεα πόλλʼ ἅ μοί ἐστιν.{l]{q]{para]
[para}[l [n}3.243{]}ὣς φάτο, τοὺς δʼ ἤδη κάτεχεν φυσίζοος αἶα{l]
[l [n}3.244{]}ἐν Λακεδαίμονι αὖθι φίλῃ ἐν πατρίδι γαίῃ.{l]{para]
[para}[l [n}3.245{]}κήρυκες δʼ ἀνὰ ἄστυ θεῶν φέρον ὅρκια πιστὰ{l]
[l [n}3.246{]}ἄρνε δύω καὶ οἶνον ἐΰφρονα καρπὸν ἀρούρης{l]
[l [n}3.247{]}ἀσκῷ ἐν αἰγείῳ· φέρε δὲ κρητῆρα φαεινὸν{l]
[l [n}3.248{]}κῆρυξ Ἰδαῖος ἠδὲ χρύσεια κύπελλα·{l]
[l [n}3.249{]}ὄτρυνεν δὲ γέροντα παριστάμενος ἐπέεσσιν·{l]
[q}[l [n}3.250{]}ὄρσεο Λαομεδοντιάδη, καλέουσιν ἄριστοι{l]
[l [n}3.251{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}3.252{]}ἐς πεδίον καταβῆναι ἵνʼ ὅρκια πιστὰ τάμητε·{l]
[l [n}3.253{]}αὐτὰρ Ἀλέξανδρος καὶ ἀρηΐφιλος Μενέλαος{l]
[l [n}3.254{]}μακρῇς ἐγχείῃσι μαχήσοντʼ ἀμφὶ γυναικί·{l]
[l [n}3.255{]}τῷ δέ κε νικήσαντι γυνὴ καὶ κτήμαθʼ ἕποιτο·{l]
[l [n}3.256{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ ταμόντες{l]
[l [n}3.257{]}ναίοιμεν Τροίην ἐριβώλακα, τοὶ δὲ νέονται{l]
[l [n}3.258{]}Ἄργος ἐς ἱππόβοτον καὶ Ἀχαιΐδα καλλιγύναικα.{l]{q]{para]
[para}[l [n}3.259{]}ὣς φάτο ῥίγησεν δʼ ὃ γέρων, ἐκέλευσε δʼ ἑταίρους{l]
[l [n}3.260{]}ἵππους ζευγνύμεναι· τοὶ δʼ ὀτραλέως ἐπίθοντο.{l]
[l [n}3.261{]}ἂν δʼ ἄρʼ ἔβη Πρίαμος, κατὰ δʼ ἡνία τεῖνεν ὀπίσσω·{l]
[l [n}3.262{]}πὰρ δέ οἱ Ἀντήνωρ περικαλλέα βήσετο δίφρον·{l]
[l [n}3.263{]}τὼ δὲ διὰ Σκαιῶν πεδίον δʼ ἔχον ὠκέας ἵππους.{l]{para]
[para}[l [n}3.264{]}ἀλλʼ ὅτε δή ῥʼ ἵκοντο μετὰ Τρῶας καὶ Ἀχαιούς,{l]
[l [n}3.265{]}ἐξ ἵππων ἀποβάντες ἐπὶ χθόνα πουλυβότειραν{l]
[l [n}3.266{]}ἐς μέσσον Τρώων καὶ Ἀχαιῶν ἐστιχόωντο.{l]
[l [n}3.267{]}ὄρνυτο δʼ αὐτίκʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}3.268{]}ἂν δʼ Ὀδυσεὺς πολύμητις· ἀτὰρ κήρυκες ἀγαυοὶ{l]
[l [n}3.269{]}ὅρκια πιστὰ θεῶν σύναγον, κρητῆρι δὲ οἶνον{l]
[l [n}3.270{]}μίσγον, ἀτὰρ βασιλεῦσιν ὕδωρ ἐπὶ χεῖρας ἔχευαν.{l]
[l [n}3.271{]}Ἀτρεΐδης δὲ ἐρυσσάμενος χείρεσσι μάχαιραν,{l]
[l [n}3.272{]}ἥ οἱ πὰρ ξίφεος μέγα κουλεόν αἰὲν ἄωρτο,{l]
[l [n}3.273{]}ἀρνῶν ἐκ κεφαλέων τάμνε τρίχας· αὐτὰρ ἔπειτα{l]
[l [n}3.274{]}κήρυκες Τρώων καὶ Ἀχαιῶν νεῖμαν ἀρίστοις.{l]
[l [n}3.275{]}τοῖσιν δʼ Ἀτρεΐδης μεγάλʼ εὔχετο χεῖρας ἀνασχών·{l]
[q}[l [n}3.276{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε,{l]
[l [n}3.277{]}Ἠέλιός θʼ, ὃς πάντʼ ἐφορᾷς καὶ πάντʼ ἐπακούεις,{l]
[l [n}3.278{]}καὶ ποταμοὶ καὶ γαῖα, καὶ οἳ ὑπένερθε καμόντας{l]
[l [n}3.279{]}ἀνθρώπους τίνυσθον ὅτις κʼ ἐπίορκον ὀμόσσῃ,{l]
[l [n}3.280{]}ὑμεῖς μάρτυροι ἔστε, φυλάσσετε δʼ ὅρκια πιστά·{l]
[l [n}3.281{]}εἰ μέν κεν Μενέλαον Ἀλέξανδρος καταπέφνῃ{l]
[l [n}3.282{]}αὐτὸς ἔπειθʼ Ἑλένην ἐχέτω καὶ κτήματα πάντα,{l]
[l [n}3.283{]}ἡμεῖς δʼ ἐν νήεσσι νεώμεθα ποντοπόροισιν·{l]
[l [n}3.284{]}εἰ δέ κʼ Ἀλέξανδρον κτείνῃ ξανθὸς Μενέλαος,{l]
[l [n}3.285{]}Τρῶας ἔπειθʼ Ἑλένην καὶ κτήματα πάντʼ ἀποδοῦναι,{l]
[l [n}3.286{]}τιμὴν δʼ Ἀργείοις ἀποτινέμεν ἥν τινʼ ἔοικεν,{l]
[l [n}3.287{]}ἥ τε καὶ ἐσσομένοισι μετʼ ἀνθρώποισι πέληται.{l]
[l [n}3.288{]}εἰ δʼ ἂν ἐμοὶ τιμὴν Πρίαμος Πριάμοιό τε παῖδες{l]
[l [n}3.289{]}τίνειν οὐκ ἐθέλωσιν Ἀλεξάνδροιο πεσόντος,{l]
[l [n}3.290{]}αὐτὰρ ἐγὼ καὶ ἔπειτα μαχήσομαι εἵνεκα ποινῆς{l]
[l [n}3.291{]}αὖθι μένων, ἧός κε τέλος πολέμοιο κιχείω.{l]{q]{para]
[para}[l [n}3.292{]}ἦ, καὶ ἀπὸ στομάχους ἀρνῶν τάμε νηλέϊ χαλκῷ·{l]
[l [n}3.293{]}καὶ τοὺς μὲν κατέθηκεν ἐπὶ χθονὸς ἀσπαίροντας{l]
[l [n}3.294{]}θυμοῦ δευομένους· ἀπὸ γὰρ μένος εἵλετο χαλκός.{l]
[l [n}3.295{]}οἶνον δʼ ἐκ κρητῆρος ἀφυσσόμενοι δεπάεσσιν{l]
[l [n}3.296{]}ἔκχεον, ἠδʼ εὔχοντο θεοῖς αἰειγενέτῃσιν.{l]
[l [n}3.297{]}ὧδε δέ τις εἴπεσκεν Ἀχαιῶν τε Τρώων τε·{l]
[q}[l [n}3.298{]}Ζεῦ κύδιστε μέγιστε καὶ ἀθάνατοι θεοὶ ἄλλοι{l]
[l [n}3.299{]}ὁππότεροι πρότεροι ὑπὲρ ὅρκια πημήνειαν{l]
[l [n}3.300{]}ὧδέ σφʼ ἐγκέφαλος χαμάδις ῥέοι ὡς ὅδε οἶνος{l]
[l [n}3.301{]}αὐτῶν καὶ τεκέων, ἄλοχοι δʼ ἄλλοισι δαμεῖεν.{l]{q]{para]
[para}[l [n}3.302{]}ὣς ἔφαν, οὐδʼ ἄρα πώ σφιν ἐπεκραίαινε Κρονίων.{l]
[l [n}3.303{]}τοῖσι δὲ Δαρδανίδης Πρίαμος μετὰ μῦθον ἔειπε·{l]
[q}[l [n}3.304{]}κέκλυτέ μευ Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοί·{l]
[l [n}3.305{]}ἤτοι ἐγὼν εἶμι προτὶ Ἴλιον ἠνεμόεσσαν{l]
[l [n}3.306{]}ἄψ, ἐπεὶ οὔ πω τλήσομʼ ἐν ὀφθαλμοῖσιν ὁρᾶσθαι{l]
[l [n}3.307{]}μαρνάμενον φίλον υἱὸν ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.308{]}Ζεὺς μέν που τό γε οἶδε καὶ ἀθάνατοι θεοὶ ἄλλοι{l]
[l [n}3.309{]}ὁπποτέρῳ θανάτοιο τέλος πεπρωμένον ἐστίν.{l]{q]{para]
[para}[l [n}3.310{]}ἦ ῥα καὶ ἐς δίφρον ἄρνας θέτο ἰσόθεος φώς,{l]
[l [n}3.311{]}ἂν δʼ ἄρʼ ἔβαινʼ αὐτός, κατὰ δʼ ἡνία τεῖνεν ὀπίσσω·{l]
[l [n}3.312{]}πὰρ δέ οἱ Ἀντήνωρ περικαλλέα βήσετο δίφρον.{l]
[l [n}3.313{]}τὼ μὲν ἄρʼ ἄψορροι προτὶ Ἴλιον ἀπονέοντο·{l]
[l [n}3.314{]}Ἕκτωρ δὲ Πριάμοιο πάϊς καὶ δῖος Ὀδυσσεὺς{l]
[l [n}3.315{]}χῶρον μὲν πρῶτον διεμέτρεον, αὐτὰρ ἔπειτα{l]
[l [n}3.316{]}κλήρους ἐν κυνέῃ χαλκήρεϊ πάλλον ἑλόντες,{l]
[l [n}3.317{]}ὁππότερος δὴ πρόσθεν ἀφείη χάλκεον ἔγχος.{l]
[l [n}3.318{]}λαοὶ δʼ ἠρήσαντο, θεοῖσι δὲ χεῖρας ἀνέσχον,{l]
[l [n}3.319{]}ὧδε δέ τις εἴπεσκεν Ἀχαιῶν τε Τρώων τε·{l]
[q}[l [n}3.320{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε{l]
[l [n}3.321{]}ὁππότερος τάδε ἔργα μετʼ ἀμφοτέροισιν ἔθηκε,{l]
[l [n}3.322{]}τὸν δὸς ἀποφθίμενον δῦναι δόμον Ἄϊδος εἴσω,{l]
[l [n}3.323{]}ἡμῖν δʼ αὖ φιλότητα καὶ ὅρκια πιστὰ γενέσθαι.{l]{q]{para]
[para}[l [n}3.324{]}ὣς ἄρʼ ἔφαν, πάλλεν δὲ μέγας κορυθαίολος Ἕκτωρ{l]
[l [n}3.325{]}ἂψ ὁρόων· Πάριος δὲ θοῶς ἐκ κλῆρος ὄρουσεν.{l]
[l [n}3.326{]}οἳ μὲν ἔπειθʼ ἵζοντο κατὰ στίχας, ἧχι ἑκάστῳ{l]
[l [n}3.327{]}ἵπποι ἀερσίποδες καὶ ποικίλα τεύχεʼ ἔκειτο·{l]
[l [n}3.328{]}αὐτὰρ ὅ γʼ ἀμφʼ ὤμοισιν ἐδύσετο τεύχεα καλὰ{l]
[l [n}3.329{]}δῖος Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο.{l]
[l [n}3.330{]}κνημῖδας μὲν πρῶτα περὶ κνήμῃσιν ἔθηκε{l]
[l [n}3.331{]}καλάς, ἀργυρέοισιν ἐπισφυρίοις ἀραρυίας·{l]
[l [n}3.332{]}δεύτερον αὖ θώρηκα περὶ στήθεσσιν ἔδυνεν{l]
[l [n}3.333{]}οἷο κασιγνήτοιο Λυκάονος· ἥρμοσε δʼ αὐτῷ.{l]
[l [n}3.334{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον{l]
[l [n}3.335{]}χάλκεον, αὐτὰρ ἔπειτα σάκος μέγα τε στιβαρόν τε·{l]
[l [n}3.336{]}κρατὶ δʼ ἐπʼ ἰφθίμῳ κυνέην εὔτυκτον ἔθηκεν{l]
[l [n}3.337{]}ἵππουριν· δεινὸν δὲ λόφος καθύπερθεν ἔνευεν·{l]
[l [n}3.338{]}εἵλετο δʼ ἄλκιμον ἔγχος, ὅ οἱ παλάμηφιν ἀρήρει.{l]
[l [n}3.339{]}ὣς δʼ αὔτως Μενέλαος ἀρήϊος ἔντεʼ ἔδυνεν.{l]{para]
[para}[l [n}3.340{]}οἳ δʼ ἐπεὶ οὖν ἑκάτερθεν ὁμίλου θωρήχθησαν,{l]
[l [n}3.341{]}ἐς μέσσον Τρώων καὶ Ἀχαιῶν ἐστιχόωντο{l]
[l [n}3.342{]}δεινὸν δερκόμενοι· θάμβος δʼ ἔχεν εἰσορόωντας{l]
[l [n}3.343{]}Τρῶάς θʼ ἱπποδάμους καὶ ἐϋκνήμιδας Ἀχαιούς.{l]
[l [n}3.344{]}καί ῥʼ ἐγγὺς στήτην διαμετρητῷ ἐνὶ χώρῳ{l]
[l [n}3.345{]}σείοντʼ ἐγχείας ἀλλήλοισιν κοτέοντε.{l]
[l [n}3.346{]}πρόσθε δʼ Ἀλέξανδρος προΐει δολιχόσκιον ἔγχος,{l]
[l [n}3.347{]}καὶ βάλεν Ἀτρεΐδαο κατʼ ἀσπίδα πάντοσε ἴσην,{l]
[l [n}3.348{]}οὐδʼ ἔρρηξεν χαλκός, ἀνεγνάμφθη δέ οἱ αἰχμὴ{l]
[l [n}3.349{]}ἀσπίδʼ ἐνὶ κρατερῇ· ὃ δὲ δεύτερον ὄρνυτο χαλκῷ{l]
[l [n}3.350{]}Ἀτρεΐδης Μενέλαος ἐπευξάμενος Διὶ πατρί·{l]
[q}[l [n}3.351{]}Ζεῦ ἄνα δὸς τίσασθαι ὅ με πρότερος κάκʼ ἔοργε{l]
[l [n}3.352{]}δῖον Ἀλέξανδρον, καὶ ἐμῇς ὑπὸ χερσὶ δάμασσον,{l]
[l [n}3.353{]}ὄφρα τις ἐρρίγῃσι καὶ ὀψιγόνων ἀνθρώπων{l]
[l [n}3.354{]}ξεινοδόκον κακὰ ῥέξαι, ὅ κεν φιλότητα παράσχῃ.{l]{q]{para]
[para}[l [n}3.355{]}ἦ ῥα καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος,{l]
[l [n}3.356{]}καὶ βάλε Πριαμίδαο κατʼ ἀσπίδα πάντοσε ἴσην·{l]
[l [n}3.357{]}διὰ μὲν ἀσπίδος ἦλθε φαεινῆς ὄβριμον ἔγχος,{l]
[l [n}3.358{]}καὶ διὰ θώρηκος πολυδαιδάλου ἠρήρειστο·{l]
[l [n}3.359{]}ἀντικρὺ δὲ παραὶ λαπάρην διάμησε χιτῶνα{l]
[l [n}3.360{]}ἔγχος· ὃ δʼ ἐκλίνθη καὶ ἀλεύατο κῆρα μέλαιναν.{l]
[l [n}3.361{]}Ἀτρεΐδης δὲ ἐρυσσάμενος ξίφος ἀργυρόηλον{l]
[l [n}3.362{]}πλῆξεν ἀνασχόμενος κόρυθος φάλον· ἀμφὶ δʼ ἄρʼ αὐτῷ{l]
[l [n}3.363{]}τριχθά τε καὶ τετραχθὰ διατρυφὲν ἔκπεσε χειρός.{l]
[l [n}3.364{]}Ἀτρεΐδης δʼ ᾤμωξεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}3.365{]}Ζεῦ πάτερ οὔ τις σεῖο θεῶν ὀλοώτερος ἄλλος·{l]
[l [n}3.366{]}ἦ τʼ ἐφάμην τίσασθαι Ἀλέξανδρον κακότητος·{l]
[l [n}3.367{]}νῦν δέ μοι ἐν χείρεσσιν ἄγη ξίφος, ἐκ δέ μοι ἔγχος{l]
[l [n}3.368{]}ἠΐχθη παλάμηφιν ἐτώσιον, οὐδʼ ἔβαλόν μιν.{l]{q]{para]
[para}[l [n}3.369{]}ἦ καὶ ἐπαΐξας κόρυθος λάβεν ἱπποδασείης,{l]
[l [n}3.370{]}ἕλκε δʼ ἐπιστρέψας μετʼ ἐϋκνήμιδας Ἀχαιούς·{l]
[l [n}3.371{]}ἄγχε δέ μιν πολύκεστος ἱμὰς ἁπαλὴν ὑπὸ δειρήν,{l]
[l [n}3.372{]}ὅς οἱ ὑπʼ ἀνθερεῶνος ὀχεὺς τέτατο τρυφαλείης.{l]
[l [n}3.373{]}καί νύ κεν εἴρυσσέν τε καὶ ἄσπετον ἤρατο κῦδος,{l]
[l [n}3.374{]}εἰ μὴ ἄρʼ ὀξὺ νόησε Διὸς θυγάτηρ Ἀφροδίτη,{l]
[l [n}3.375{]}ἥ οἱ ῥῆξεν ἱμάντα βοὸς ἶφι κταμένοιο·{l]
[l [n}3.376{]}κεινὴ δὲ τρυφάλεια ἅμʼ ἕσπετο χειρὶ παχείῃ.{l]
[l [n}3.377{]}τὴν μὲν ἔπειθʼ ἥρως μετʼ ἐϋκνήμιδας Ἀχαιοὺς{l]
[l [n}3.378{]}ῥῖψʼ ἐπιδινήσας, κόμισαν δʼ ἐρίηρες ἑταῖροι·{l]
[l [n}3.379{]}αὐτὰρ ὃ ἂψ ἐπόρουσε κατακτάμεναι μενεαίνων{l]
[l [n}3.380{]}ἔγχεϊ χαλκείῳ· τὸν δʼ ἐξήρπαξʼ Ἀφροδίτη{l]
[l [n}3.381{]}ῥεῖα μάλʼ ὥς τε θεός, ἐκάλυψε δʼ ἄρʼ ἠέρι πολλῇ,{l]
[l [n}3.382{]}κὰδ δʼ εἷσʼ ἐν θαλάμῳ εὐώδεϊ κηώεντι.{l]
[l [n}3.383{]}αὐτὴ δʼ αὖ Ἑλένην καλέουσʼ ἴε· τὴν δὲ κίχανε{l]
[l [n}3.384{]}πύργῳ ἐφʼ ὑψηλῷ, περὶ δὲ Τρῳαὶ ἅλις ἦσαν·{l]
[l [n}3.385{]}χειρὶ δὲ νεκταρέου ἑανοῦ ἐτίναξε λαβοῦσα,{l]
[l [n}3.386{]}γρηῒ δέ μιν ἐϊκυῖα παλαιγενέϊ προσέειπεν{l]
[l [n}3.387{]}εἰροκόμῳ, ἥ οἱ Λακεδαίμονι ναιετοώσῃ{l]
[l [n}3.388{]}ἤσκειν εἴρια καλά, μάλιστα δέ μιν φιλέεσκε·{l]
[l [n}3.389{]}τῇ μιν ἐεισαμένη προσεφώνεε δῖʼ Ἀφροδίτη·{l]
[q}[l [n}3.390{]}δεῦρʼ ἴθʼ· Ἀλέξανδρός σε καλεῖ οἶκον δὲ νέεσθαι.{l]
[l [n}3.391{]}κεῖνος ὅ γʼ ἐν θαλάμῳ καὶ δινωτοῖσι λέχεσσι{l]
[l [n}3.392{]}κάλλεΐ τε στίλβων καὶ εἵμασιν· οὐδέ κε φαίης{l]
[l [n}3.393{]}ἀνδρὶ μαχεσσάμενον τόν γʼ ἐλθεῖν, ἀλλὰ χορὸν δὲ{l]
[l [n}3.394{]}ἔρχεσθʼ, ἠὲ χοροῖο νέον λήγοντα καθίζειν.{l]{q]{para]
[para}[l [n}3.395{]}ὣς φάτο, τῇ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ὄρινε·{l]
[l [n}3.396{]}καί ῥʼ ὡς οὖν ἐνόησε θεᾶς περικαλλέα δειρὴν{l]
[l [n}3.397{]}στήθεά θʼ ἱμερόεντα καὶ ὄμματα μαρμαίροντα,{l]
[l [n}3.398{]}θάμβησέν τʼ ἄρʼ ἔπειτα ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}3.399{]}δαιμονίη, τί με ταῦτα λιλαίεαι ἠπεροπεύειν;{l]
[l [n}3.400{]}ἦ πῄ με προτέρω πολίων εὖ ναιομενάων{l]
[l [n}3.401{]}ἄξεις, ἢ Φρυγίης ἢ Μῃονίης ἐρατεινῆς,{l]
[l [n}3.402{]}εἴ τίς τοι καὶ κεῖθι φίλος μερόπων ἀνθρώπων·{l]
[l [n}3.403{]}οὕνεκα δὴ νῦν δῖον Ἀλέξανδρον Μενέλαος{l]
[l [n}3.404{]}νικήσας ἐθέλει στυγερὴν ἐμὲ οἴκαδʼ ἄγεσθαι,{l]
[l [n}3.405{]}τοὔνεκα δὴ νῦν δεῦρο δολοφρονέουσα παρέστης;{l]
[l [n}3.406{]}ἧσο παρʼ αὐτὸν ἰοῦσα, θεῶν δʼ ἀπόεικε κελεύθου,{l]
[l [n}3.407{]}μηδʼ ἔτι σοῖσι πόδεσσιν ὑποστρέψειας Ὄλυμπον,{l]
[l [n}3.408{]}ἀλλʼ αἰεὶ περὶ κεῖνον ὀΐζυε καί ἑ φύλασσε,{l]
[l [n}3.409{]}εἰς ὅ κέ σʼ ἢ ἄλοχον ποιήσεται ἢ ὅ γε δούλην.{l]
[l [n}3.410{]}κεῖσε δʼ ἐγὼν οὐκ εἶμι· νεμεσσητὸν δέ κεν εἴη·{l]
[l [n}3.411{]}κείνου πορσανέουσα λέχος· Τρῳαὶ δέ μʼ ὀπίσσω{l]
[l [n}3.412{]}πᾶσαι μωμήσονται· ἔχω δʼ ἄχεʼ ἄκριτα θυμῷ.{l]{q]{para]
[para}[l [n}3.413{]}τὴν δὲ χολωσαμένη προσεφώνεε δῖʼ Ἀφροδίτη·{l]
[q}[l [n}3.414{]}μή μʼ ἔρεθε σχετλίη, μὴ χωσαμένη σε μεθείω,{l]
[l [n}3.415{]}τὼς δέ σʼ ἀπεχθήρω ὡς νῦν ἔκπαγλʼ ἐφίλησα,{l]
[l [n}3.416{]}μέσσῳ δʼ ἀμφοτέρων μητίσομαι ἔχθεα λυγρὰ{l]
[l [n}3.417{]}Τρώων καὶ Δαναῶν, σὺ δέ κεν κακὸν οἶτον ὄληαι.{l]{q]{para]
[para}[l [n}3.418{]}ὣς ἔφατʼ, ἔδεισεν δʼ Ἑλένη Διὸς ἐκγεγαυῖα,{l]
[l [n}3.419{]}βῆ δὲ κατασχομένη ἑανῷ ἀργῆτι φαεινῷ{l]
[l [n}3.420{]}σιγῇ, πάσας δὲ Τρῳὰς λάθεν· ἦρχε δὲ δαίμων.{l]{para]
[para}[l [n}3.421{]}αἳ δʼ ὅτʼ Ἀλεξάνδροιο δόμον περικαλλέʼ ἵκοντο,{l]
[l [n}3.422{]}ἀμφίπολοι μὲν ἔπειτα θοῶς ἐπὶ ἔργα τράποντο,{l]
[l [n}3.423{]}ἣ δʼ εἰς ὑψόροφον θάλαμον κίε δῖα γυναικῶν.{l]
[l [n}3.424{]}τῇ δʼ ἄρα δίφρον ἑλοῦσα φιλομειδὴς Ἀφροδίτη{l]
[l [n}3.425{]}ἀντίʼ Ἀλεξάνδροιο θεὰ κατέθηκε φέρουσα·{l]
[l [n}3.426{]}ἔνθα κάθιζʼ Ἑλένη κούρη Διὸς αἰγιόχοιο{l]
[l [n}3.427{]}ὄσσε πάλιν κλίνασα, πόσιν δʼ ἠνίπαπε μύθῳ·{l]
[q}[l [n}3.428{]}ἤλυθες ἐκ πολέμου· ὡς ὤφελες αὐτόθʼ ὀλέσθαι{l]
[l [n}3.429{]}ἀνδρὶ δαμεὶς κρατερῷ, ὃς ἐμὸς πρότερος πόσις ἦεν.{l]
[l [n}3.430{]}ἦ μὲν δὴ πρίν γʼ εὔχεʼ ἀρηϊφίλου Μενελάου{l]
[l [n}3.431{]}σῇ τε βίῃ καὶ χερσὶ καὶ ἔγχεϊ φέρτερος εἶναι·{l]
[l [n}3.432{]}ἀλλʼ ἴθι νῦν προκάλεσσαι ἀρηΐφιλον Μενέλαον{l]
[l [n}3.433{]}ἐξαῦτις μαχέσασθαι ἐναντίον· ἀλλά σʼ ἔγωγε{l]
[l [n}3.434{]}παύεσθαι κέλομαι, μηδὲ ξανθῷ Μενελάῳ{l]
[l [n}3.435{]}ἀντίβιον πόλεμον πολεμίζειν ἠδὲ μάχεσθαι{l]
[l [n}3.436{]}ἀφραδέως, μή πως τάχʼ ὑπʼ αὐτοῦ δουρὶ δαμήῃς.{l]{q]{para]
[para}[l [n}3.437{]}τὴν δὲ Πάρις μύθοισιν ἀμειβόμενος προσέειπε·{l]
[q}[l [n}3.438{]}μή με γύναι χαλεποῖσιν ὀνείδεσι θυμὸν ἔνιπτε·{l]
[l [n}3.439{]}νῦν μὲν γὰρ Μενέλαος ἐνίκησεν σὺν Ἀθήνῃ,{l]
[l [n}3.440{]}κεῖνον δʼ αὖτις ἐγώ· πάρα γὰρ θεοί εἰσι καὶ ἡμῖν.{l]
[l [n}3.441{]}ἀλλʼ ἄγε δὴ φιλότητι τραπείομεν εὐνηθέντε·{l]
[l [n}3.442{]}οὐ γάρ πώ ποτέ μʼ ὧδέ γʼ ἔρως φρένας ἀμφεκάλυψεν,{l]
[l [n}3.443{]}οὐδʼ ὅτε σε πρῶτον Λακεδαίμονος ἐξ ἐρατεινῆς{l]
[l [n}3.444{]}ἔπλεον ἁρπάξας ἐν ποντοπόροισι νέεσσι,{l]
[l [n}3.445{]}νήσῳ δʼ ἐν Κραναῇ ἐμίγην φιλότητι καὶ εὐνῇ,{l]
[l [n}3.446{]}ὥς σεο νῦν ἔραμαι καί με γλυκὺς ἵμερος αἱρεῖ.{l]{q]{para]
[para}[l [n}3.447{]}ἦ ῥα, καὶ ἄρχε λέχος δὲ κιών· ἅμα δʼ εἵπετʼ ἄκοιτις.{l]{para]
[para}[l [n}3.448{]}τὼ μὲν ἄρʼ ἐν τρητοῖσι κατεύνασθεν λεχέεσσιν,{l]
[l [n}3.449{]}Ἀτρεΐδης δʼ ἀνʼ ὅμιλον ἐφοίτα θηρὶ ἐοικὼς{l]
[l [n}3.450{]}εἴ που ἐσαθρήσειεν Ἀλέξανδρον θεοειδέα.{l]
[l [n}3.451{]}ἀλλʼ οὔ τις δύνατο Τρώων κλειτῶν τʼ ἐπικούρων{l]
[l [n}3.452{]}δεῖξαι Ἀλέξανδρον τότʼ ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.453{]}οὐ μὲν γὰρ φιλότητί γʼ ἐκεύθανον εἴ τις ἴδοιτο·{l]
[l [n}3.454{]}ἶσον γάρ σφιν πᾶσιν ἀπήχθετο κηρὶ μελαίνῃ.{l]
[l [n}3.455{]}τοῖσι δὲ καὶ μετέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}3.456{]}κέκλυτέ μευ Τρῶες καὶ Δάρδανοι ἠδʼ ἐπίκουροι·{l]
[l [n}3.457{]}νίκη μὲν δὴ φαίνετʼ ἀρηϊφίλου Μενελάου,{l]
[l [n}3.458{]}ὑμεῖς δʼ Ἀργείην Ἑλένην καὶ κτήμαθʼ ἅμʼ αὐτῇ{l]
[l [n}3.459{]}ἔκδοτε, καὶ τιμὴν ἀποτινέμεν ἥν τινʼ ἔοικεν,{l]
[l [n}3.460{]}ἥ τε καὶ ἐσσομένοισι μετʼ ἀνθρώποισι πέληται.{l]{q]{para]
[para}[l [n}3.461{]}ὣς ἔφατʼ Ἀτρεΐδης, ἐπὶ δʼ ᾔνεον ἄλλοι Ἀχαιοί.{l]{para]
{book]