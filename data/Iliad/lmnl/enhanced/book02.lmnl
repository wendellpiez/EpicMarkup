
[book [n}2{]}
[para}[l [n}2.1{]}ἄλλοι μέν ῥα θεοί τε καὶ ἀνέρες ἱπποκορυσταὶ{l]
[l [n}2.2{]}εὗδον παννύχιοι, Δία δʼ οὐκ ἔχε νήδυμος ὕπνος,{l]
[l [n}2.3{]}ἀλλʼ ὅ γε μερμήριζε κατὰ φρένα ὡς Ἀχιλῆα{l]
[l [n}2.4{]}τιμήσῃ, ὀλέσῃ δὲ πολέας ἐπὶ νηυσὶν Ἀχαιῶν.{l]
[l [n}2.5{]}ἥδε δέ οἱ κατὰ θυμὸν ἀρίστη φαίνετο βουλή,{l]
[l [n}2.6{]}πέμψαι ἐπʼ Ἀτρεΐδῃ Ἀγαμέμνονι οὖλον ὄνειρον·{l]
[l [n}2.7{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}2.8{]}βάσκʼ ἴθι οὖλε ὄνειρε θοὰς ἐπὶ νῆας Ἀχαιῶν·{l]
[l [n}2.9{]}ἐλθὼν ἐς κλισίην Ἀγαμέμνονος Ἀτρεΐδαο{l]
[l [n}2.10{]}πάντα μάλʼ ἀτρεκέως ἀγορευέμεν ὡς ἐπιτέλλω·{l]
[l [n}2.11{]}θωρῆξαί ἑ κέλευε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.12{]}πανσυδίῃ· νῦν γάρ κεν ἕλοι πόλιν εὐρυάγυιαν{l]
[l [n}2.13{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.14{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.15{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται.{l]{q]{para]
[para}[l [n}2.16{]}ὣς φάτο, βῆ δʼ ἄρʼ ὄνειρος ἐπεὶ τὸν μῦθον ἄκουσε·{l]
[l [n}2.17{]}καρπαλίμως δʼ ἵκανε θοὰς ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}2.18{]}βῆ δʼ ἄρʼ ἐπʼ Ἀτρεΐδην Ἀγαμέμνονα· τὸν δὲ κίχανεν{l]
[l [n}2.19{]}εὕδοντʼ ἐν κλισίῃ, περὶ δʼ ἀμβρόσιος κέχυθʼ ὕπνος.{l]
[l [n}2.20{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς Νηληΐῳ υἷι ἐοικώς{l]
[l [n}2.21{]}Νέστορι, τόν ῥα μάλιστα γερόντων τῖʼ Ἀγαμέμνων·{l]
[l [n}2.22{]}τῷ μιν ἐεισάμενος προσεφώνεε θεῖος ὄνειρος·{l]
[q}[l [n}2.23{]}εὕδεις Ἀτρέος υἱὲ δαΐφρονος ἱπποδάμοιο·{l]
[l [n}2.24{]}οὐ χρὴ παννύχιον εὕδειν βουληφόρον ἄνδρα{l]
[l [n}2.25{]}ᾧ λαοί τʼ ἐπιτετράφαται καὶ τόσσα μέμηλε·{l]
[l [n}2.26{]}νῦν δʼ ἐμέθεν ξύνες ὦκα· Διὸς δέ τοι ἄγγελός εἰμι,{l]
[l [n}2.27{]}ὃς σεῦ ἄνευθεν ἐὼν μέγα κήδεται ἠδʼ ἐλεαίρει.{l]
[l [n}2.28{]}θωρῆξαί σε κέλευσε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.29{]}πανσυδίῃ· νῦν γάρ κεν ἕλοις πόλιν εὐρυάγυιαν{l]
[l [n}2.30{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.31{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.32{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται{l]
[l [n}2.33{]}ἐκ Διός· ἀλλὰ σὺ σῇσιν ἔχε φρεσί, μηδέ σε λήθη{l]
[l [n}2.34{]}αἱρείτω εὖτʼ ἄν σε μελίφρων ὕπνος ἀνήῃ.{l]{q]{para]
[para}[l [n}2.35{]}ὣς ἄρα φωνήσας ἀπεβήσετο, τὸν δὲ λίπʼ αὐτοῦ{l]
[l [n}2.36{]}τὰ φρονέοντʼ ἀνὰ θυμὸν ἅ ῥʼ οὐ τελέεσθαι ἔμελλον·{l]
[l [n}2.37{]}φῆ γὰρ ὅ γʼ αἱρήσειν Πριάμου πόλιν ἤματι κείνῳ{l]
[l [n}2.38{]}νήπιος, οὐδὲ τὰ ᾔδη ἅ ῥα Ζεὺς μήδετο ἔργα·{l]
[l [n}2.39{]}θήσειν γὰρ ἔτʼ ἔμελλεν ἐπʼ ἄλγεά τε στοναχάς τε{l]
[l [n}2.40{]}Τρωσί τε καὶ Δαναοῖσι διὰ κρατερὰς ὑσμίνας.{l]
[l [n}2.41{]}ἔγρετο δʼ ἐξ ὕπνου, θείη δέ μιν ἀμφέχυτʼ ὀμφή·{l]
[l [n}2.42{]}ἕζετο δʼ ὀρθωθείς, μαλακὸν δʼ ἔνδυνε χιτῶνα{l]
[l [n}2.43{]}καλὸν νηγάτεον, περὶ δὲ μέγα βάλλετο φᾶρος·{l]
[l [n}2.44{]}ποσσὶ δʼ ὑπὸ λιπαροῖσιν ἐδήσατο καλὰ πέδιλα,{l]
[l [n}2.45{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον·{l]
[l [n}2.46{]}εἵλετο δὲ σκῆπτρον πατρώϊον ἄφθιτον αἰεὶ{l]
[l [n}2.47{]}σὺν τῷ ἔβη κατὰ νῆας Ἀχαιῶν χαλκοχιτώνων·{l]{para]
[para}[l [n}2.48{]}ἠὼς μέν ῥα θεὰ προσεβήσετο μακρὸν Ὄλυμπον{l]
[l [n}2.49{]}Ζηνὶ φόως ἐρέουσα καὶ ἄλλοις ἀθανάτοισιν·{l]
[l [n}2.50{]}αὐτὰρ ὃ κηρύκεσσι λιγυφθόγγοισι κέλευσε{l]
[l [n}2.51{]}κηρύσσειν ἀγορὴν δὲ κάρη κομόωντας Ἀχαιούς·{l]
[l [n}2.52{]}οἳ μὲν ἐκήρυσσον, τοὶ δʼ ἠγείροντο μάλʼ ὦκα·{l]{para]
[para}[l [n}2.53{]}βουλὴν δὲ πρῶτον μεγαθύμων ἷζε γερόντων{l]
[l [n}2.54{]}Νεστορέῃ παρὰ νηῒ Πυλοιγενέος βασιλῆος·{l]
[l [n}2.55{]}τοὺς ὅ γε συγκαλέσας πυκινὴν ἀρτύνετο βουλήν·{l]
[q}[l [n}2.56{]}κλῦτε φίλοι· θεῖός μοι ἐνύπνιον ἦλθεν ὄνειρος{l]
[l [n}2.57{]}ἀμβροσίην διὰ νύκτα· μάλιστα δὲ Νέστορι δίῳ{l]
[l [n}2.58{]}εἶδός τε μέγεθός τε φυήν τʼ ἄγχιστα ἐῴκει·{l]
[l [n}2.59{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς καί με πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}2.60{]}εὕδεις Ἀτρέος υἱὲ δαΐφρονος ἱπποδάμοιο·{l]
[l [n}2.61{]}οὐ χρὴ παννύχιον εὕδειν βουληφόρον ἄνδρα,{l]
[l [n}2.62{]}ᾧ λαοί τʼ ἐπιτετράφαται καὶ τόσσα μέμηλε·{l]
[l [n}2.63{]}νῦν δʼ ἐμέθεν ξύνες ὦκα· Διὸς δέ τοι ἄγγελός εἰμι,{l]
[l [n}2.64{]}ὃς σεῦ ἄνευθεν ἐὼν μέγα κήδεται ἠδʼ ἐλεαίρει·{l]
[l [n}2.65{]}θωρῆξαί σε κέλευσε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.66{]}πανσυδίῃ· νῦν γάρ κεν ἕλοις πόλιν εὐρυάγυιαν{l]
[l [n}2.67{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.68{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.69{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται{l]
[l [n}2.70{]}ἐκ Διός· ἀλλὰ σὺ σῇσιν ἔχε φρεσίν·{q] ὣς ὃ μὲν εἰπὼν{l]
[l [n}2.71{]}ᾤχετʼ ἀποπτάμενος, ἐμὲ δὲ γλυκὺς ὕπνος ἀνῆκεν.{l]
[l [n}2.72{]}ἀλλʼ ἄγετʼ αἴ κέν πως θωρήξομεν υἷας Ἀχαιῶν·{l]
[l [n}2.73{]}πρῶτα δʼ ἐγὼν ἔπεσιν πειρήσομαι, ἣ θέμις ἐστί,{l]
[l [n}2.74{]}καὶ φεύγειν σὺν νηυσὶ πολυκλήϊσι κελεύσω·{l]
[l [n}2.75{]}ὑμεῖς δʼ ἄλλοθεν ἄλλος ἐρητύειν ἐπέεσσιν.{l]{q]{para]
[para}[l [n}2.76{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο, τοῖσι δʼ ἀνέστη{l]
[l [n}2.77{]}Νέστωρ, ὅς ῥα Πύλοιο ἄναξ ἦν ἠμαθόεντος,{l]
[l [n}2.78{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}2.79{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}2.80{]}εἰ μέν τις τὸν ὄνειρον Ἀχαιῶν ἄλλος ἔνισπε{l]
[l [n}2.81{]}ψεῦδός κεν φαῖμεν καὶ νοσφιζοίμεθα μᾶλλον·{l]
[l [n}2.82{]}νῦν δʼ ἴδεν ὃς μέγʼ ἄριστος Ἀχαιῶν εὔχεται εἶναι·{l]
[l [n}2.83{]}ἀλλʼ ἄγετʼ αἴ κέν πως θωρήξομεν υἷας Ἀχαιῶν.{l]{q]{para]
[para}[l [n}2.84{]}ὣς ἄρα φωνήσας βουλῆς ἐξῆρχε νέεσθαι,{l]
[l [n}2.85{]}οἳ δʼ ἐπανέστησαν πείθοντό τε ποιμένι λαῶν{l]
[l [n}2.86{]}σκηπτοῦχοι βασιλῆες· ἐπεσσεύοντο δὲ λαοί.{l]
[l [n}2.87{]}ἠΰτε ἔθνεα εἶσι μελισσάων ἁδινάων{l]
[l [n}2.88{]}πέτρης ἐκ γλαφυρῆς αἰεὶ νέον ἐρχομενάων,{l]
[l [n}2.89{]}βοτρυδὸν δὲ πέτονται ἐπʼ ἄνθεσιν εἰαρινοῖσιν·{l]
[l [n}2.90{]}αἳ μέν τʼ ἔνθα ἅλις πεποτήαται, αἳ δέ τε ἔνθα·{l]
[l [n}2.91{]}ὣς τῶν ἔθνεα πολλὰ νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.92{]}ἠϊόνος προπάροιθε βαθείης ἐστιχόωντο{l]
[l [n}2.93{]}ἰλαδὸν εἰς ἀγορήν· μετὰ δέ σφισιν ὄσσα δεδήει{l]
[l [n}2.94{]}ὀτρύνουσʼ ἰέναι Διὸς ἄγγελος· οἳ δʼ ἀγέροντο.{l]
[l [n}2.95{]}τετρήχει δʼ ἀγορή, ὑπὸ δὲ στεναχίζετο γαῖα{l]
[l [n}2.96{]}λαῶν ἱζόντων, ὅμαδος δʼ ἦν· ἐννέα δέ σφεας{l]
[l [n}2.97{]}κήρυκες βοόωντες ἐρήτυον, εἴ ποτʼ ἀϋτῆς{l]
[l [n}2.98{]}σχοίατʼ, ἀκούσειαν δὲ διοτρεφέων βασιλήων.{l]
[l [n}2.99{]}σπουδῇ δʼ ἕζετο λαός, ἐρήτυθεν δὲ καθʼ ἕδρας{l]
[l [n}2.100{]}παυσάμενοι κλαγγῆς· ἀνὰ δὲ κρείων Ἀγαμέμνων{l]
[l [n}2.101{]}ἔστη σκῆπτρον ἔχων τὸ μὲν Ἥφαιστος κάμε τεύχων.{l]
[l [n}2.102{]}Ἥφαιστος μὲν δῶκε Διὶ Κρονίωνι ἄνακτι,{l]
[l [n}2.103{]}αὐτὰρ ἄρα Ζεὺς δῶκε διακτόρῳ ἀργεϊφόντῃ·{l]
[l [n}2.104{]}Ἑρμείας δὲ ἄναξ δῶκεν Πέλοπι πληξίππῳ,{l]
[l [n}2.105{]}αὐτὰρ ὃ αὖτε Πέλοψ δῶκʼ Ἀτρέϊ ποιμένι λαῶν,{l]
[l [n}2.106{]}Ἀτρεὺς δὲ θνῄσκων ἔλιπεν πολύαρνι Θυέστῃ,{l]
[l [n}2.107{]}αὐτὰρ ὃ αὖτε Θυέστʼ Ἀγαμέμνονι λεῖπε φορῆναι,{l]
[l [n}2.108{]}πολλῇσιν νήσοισι καὶ Ἄργεϊ παντὶ ἀνάσσειν.{l]
[l [n}2.109{]}τῷ ὅ γʼ ἐρεισάμενος ἔπεʼ Ἀργείοισι μετηύδα·{l]
[q}[l [n}2.110{]}ὦ φίλοι ἥρωες Δαναοὶ θεράποντες Ἄρηος{l]
[l [n}2.111{]}Ζεύς με μέγα Κρονίδης ἄτῃ ἐνέδησε βαρείῃ,{l]
[l [n}2.112{]}σχέτλιος, ὃς πρὶν μέν μοι ὑπέσχετο καὶ κατένευσεν{l]
[l [n}2.113{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι,{l]
[l [n}2.114{]}νῦν δὲ κακὴν ἀπάτην βουλεύσατο, καί με κελεύει{l]
[l [n}2.115{]}δυσκλέα Ἄργος ἱκέσθαι, ἐπεὶ πολὺν ὤλεσα λαόν.{l]
[l [n}2.116{]}οὕτω που Διὶ μέλλει ὑπερμενέϊ φίλον εἶναι,{l]
[l [n}2.117{]}ὃς δὴ πολλάων πολίων κατέλυσε κάρηνα{l]
[l [n}2.118{]}ἠδʼ ἔτι καὶ λύσει· τοῦ γὰρ κράτος ἐστὶ μέγιστον.{l]
[l [n}2.119{]}αἰσχρὸν γὰρ τόδε γʼ ἐστὶ καὶ ἐσσομένοισι πυθέσθαι{l]
[l [n}2.120{]}μὰψ οὕτω τοιόνδε τοσόνδε τε λαὸν Ἀχαιῶν{l]
[l [n}2.121{]}ἄπρηκτον πόλεμον πολεμίζειν ἠδὲ μάχεσθαι{l]
[l [n}2.122{]}ἀνδράσι παυροτέροισι, τέλος δʼ οὔ πώ τι πέφανται·{l]
[l [n}2.123{]}εἴ περ γάρ κʼ ἐθέλοιμεν Ἀχαιοί τε Τρῶές τε{l]
[l [n}2.124{]}ὅρκια πιστὰ ταμόντες ἀριθμηθήμεναι ἄμφω,{l]
[l [n}2.125{]}Τρῶας μὲν λέξασθαι ἐφέστιοι ὅσσοι ἔασιν,{l]
[l [n}2.126{]}ἡμεῖς δʼ ἐς δεκάδας διακοσμηθεῖμεν Ἀχαιοί,{l]
[l [n}2.127{]}Τρώων δʼ ἄνδρα ἕκαστοι ἑλοίμεθα οἰνοχοεύειν,{l]
[l [n}2.128{]}πολλαί κεν δεκάδες δευοίατο οἰνοχόοιο.{l]
[l [n}2.129{]}τόσσον ἐγώ φημι πλέας ἔμμεναι υἷας Ἀχαιῶν{l]
[l [n}2.130{]}Τρώων, οἳ ναίουσι κατὰ πτόλιν· ἀλλʼ ἐπίκουροι{l]
[l [n}2.131{]}πολλέων ἐκ πολίων ἐγχέσπαλοι ἄνδρες ἔασιν,{l]
[l [n}2.132{]}οἵ με μέγα πλάζουσι καὶ οὐκ εἰῶσʼ ἐθέλοντα{l]
[l [n}2.133{]}Ἰλίου ἐκπέρσαι εὖ ναιόμενον πτολίεθρον.{l]
[l [n}2.134{]}ἐννέα δὴ βεβάασι Διὸς μεγάλου ἐνιαυτοί,{l]
[l [n}2.135{]}καὶ δὴ δοῦρα σέσηπε νεῶν καὶ σπάρτα λέλυνται·{l]
[l [n}2.136{]}αἳ δέ που ἡμέτεραί τʼ ἄλοχοι καὶ νήπια τέκνα{l]
[l [n}2.137{]}εἵατʼ ἐνὶ μεγάροις ποτιδέγμεναι· ἄμμι δὲ ἔργον{l]
[l [n}2.138{]}αὔτως ἀκράαντον οὗ εἵνεκα δεῦρʼ ἱκόμεσθα.{l]
[l [n}2.139{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}2.140{]}φεύγωμεν σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν·{l]
[l [n}2.141{]}οὐ γὰρ ἔτι Τροίην αἱρήσομεν εὐρυάγυιαν.{l]{q]{para]
[para}[l [n}2.142{]}ὣς φάτο, τοῖσι δὲ θυμὸν ἐνὶ στήθεσσιν ὄρινε{l]
[l [n}2.143{]}πᾶσι μετὰ πληθὺν ὅσοι οὐ βουλῆς ἐπάκουσαν·{l]
[l [n}2.144{]}κινήθη δʼ ἀγορὴ φὴ κύματα μακρὰ θαλάσσης{l]
[l [n}2.145{]}πόντου Ἰκαρίοιο, τὰ μέν τʼ Εὖρός τε Νότος τε{l]
[l [n}2.146{]}ὤρορʼ ἐπαΐξας πατρὸς Διὸς ἐκ νεφελάων.{l]
[l [n}2.147{]}ὡς δʼ ὅτε κινήσῃ Ζέφυρος βαθὺ λήϊον ἐλθὼν{l]
[l [n}2.148{]}λάβρος ἐπαιγίζων, ἐπί τʼ ἠμύει ἀσταχύεσσιν,{l]
[l [n}2.149{]}ὣς τῶν πᾶσʼ ἀγορὴ κινήθη· τοὶ δʼ ἀλαλητῷ{l]
[l [n}2.150{]}νῆας ἔπʼ ἐσσεύοντο, ποδῶν δʼ ὑπένερθε κονίη{l]
[l [n}2.151{]}ἵστατʼ ἀειρομένη· τοὶ δʼ ἀλλήλοισι κέλευον{l]
[l [n}2.152{]}ἅπτεσθαι νηῶν ἠδʼ ἑλκέμεν εἰς ἅλα δῖαν,{l]
[l [n}2.153{]}οὐρούς τʼ ἐξεκάθαιρον· ἀϋτὴ δʼ οὐρανὸν ἷκεν{l]
[l [n}2.154{]}οἴκαδε ἱεμένων· ὑπὸ δʼ ᾕρεον ἕρματα νηῶν.{l]{para]
[para}[l [n}2.155{]}ἔνθά κεν Ἀργείοισιν ὑπέρμορα νόστος ἐτύχθη{l]
[l [n}2.156{]}εἰ μὴ Ἀθηναίην Ἥρη πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}2.157{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος Ἀτρυτώνη,{l]
[l [n}2.158{]}οὕτω δὴ οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}2.159{]}Ἀργεῖοι φεύξονται ἐπʼ εὐρέα νῶτα θαλάσσης,{l]
[l [n}2.160{]}κὰδ δέ κεν εὐχωλὴν Πριάμῳ καὶ Τρωσὶ λίποιεν{l]
[l [n}2.161{]}Ἀργείην Ἑλένην, ἧς εἵνεκα πολλοὶ Ἀχαιῶν{l]
[l [n}2.162{]}ἐν Τροίῃ ἀπόλοντο φίλης ἀπὸ πατρίδος αἴης·{l]
[l [n}2.163{]}ἀλλʼ ἴθι νῦν κατὰ λαὸν Ἀχαιῶν χαλκοχιτώνων·{l]
[l [n}2.164{]}σοῖς ἀγανοῖς ἐπέεσσιν ἐρήτυε φῶτα ἕκαστον,{l]
[l [n}2.165{]}μηδὲ ἔα νῆας ἅλα δʼ ἑλκέμεν ἀμφιελίσσας.{l]{q]{para]
[para}[l [n}2.166{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ γλαυκῶπις Ἀθήνη,{l]
[l [n}2.167{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων ἀΐξασα·{l]
[l [n}2.168{]}καρπαλίμως δʼ ἵκανε θοὰς ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}2.169{]}εὗρεν ἔπειτʼ Ὀδυσῆα Διὶ μῆτιν ἀτάλαντον{l]
[l [n}2.170{]}ἑσταότʼ· οὐδʼ ὅ γε νηὸς ἐϋσσέλμοιο μελαίνης{l]
[l [n}2.171{]}ἅπτετʼ, ἐπεί μιν ἄχος κραδίην καὶ θυμὸν ἵκανεν·{l]
[l [n}2.172{]}ἀγχοῦ δʼ ἱσταμένη προσέφη γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}2.173{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ,{l]
[l [n}2.174{]}οὕτω δὴ οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}2.175{]}φεύξεσθʼ ἐν νήεσσι πολυκλήϊσι πεσόντες,{l]
[l [n}2.176{]}κὰδ δέ κεν εὐχωλὴν Πριάμῳ καὶ Τρωσὶ λίποιτε{l]
[l [n}2.177{]}Ἀργείην Ἑλένην, ἧς εἵνεκα πολλοὶ Ἀχαιῶν{l]
[l [n}2.178{]}ἐν Τροίῃ ἀπόλοντο φίλης ἀπὸ πατρίδος αἴης;{l]
[l [n}2.179{]}ἀλλʼ ἴθι νῦν κατὰ λαὸν Ἀχαιῶν, μηδʼ ἔτʼ ἐρώει,{l]
[l [n}2.180{]}σοῖς δʼ ἀγανοῖς ἐπέεσσιν ἐρήτυε φῶτα ἕκαστον,{l]
[l [n}2.181{]}μηδὲ ἔα νῆας ἅλα δʼ ἑλκέμεν ἀμφιελίσσας.{l]{q]{para]
[para}[l [n}2.182{]}ὣς φάθʼ, ὃ δὲ ξυνέηκε θεᾶς ὄπα φωνησάσης,{l]
[l [n}2.183{]}βῆ δὲ θέειν, ἀπὸ δὲ χλαῖναν βάλε· τὴν δὲ κόμισσε{l]
[l [n}2.184{]}κῆρυξ Εὐρυβάτης Ἰθακήσιος ὅς οἱ ὀπήδει·{l]
[l [n}2.185{]}αὐτὸς δʼ Ἀτρεΐδεω Ἀγαμέμνονος ἀντίος ἐλθὼν{l]
[l [n}2.186{]}δέξατό οἱ σκῆπτρον πατρώϊον ἄφθιτον αἰεί·{l]
[l [n}2.187{]}σὺν τῷ ἔβη κατὰ νῆας Ἀχαιῶν χαλκοχιτώνων.{l]{para]
[para}[l [n}2.188{]}ὅν τινα μὲν βασιλῆα καὶ ἔξοχον ἄνδρα κιχείη{l]
[l [n}2.189{]}τὸν δʼ ἀγανοῖς ἐπέεσσιν ἐρητύσασκε παραστάς·{l]
[q}[l [n}2.190{]}δαιμόνιʼ οὔ σε ἔοικε κακὸν ὣς δειδίσσεσθαι,{l]
[l [n}2.191{]}ἀλλʼ αὐτός τε κάθησο καὶ ἄλλους ἵδρυε λαούς·{l]
[l [n}2.192{]}οὐ γάρ πω σάφα οἶσθʼ οἷος νόος Ἀτρεΐωνος·{l]
[l [n}2.193{]}νῦν μὲν πειρᾶται, τάχα δʼ ἴψεται υἷας Ἀχαιῶν.{l]
[l [n}2.194{]}ἐν βουλῇ δʼ οὐ πάντες ἀκούσαμεν οἷον ἔειπε.{l]
[l [n}2.195{]}μή τι χολωσάμενος ῥέξῃ κακὸν υἷας Ἀχαιῶν·{l]
[l [n}2.196{]}θυμὸς δὲ μέγας ἐστὶ διοτρεφέων βασιλήων,{l]
[l [n}2.197{]}τιμὴ δʼ ἐκ Διός ἐστι, φιλεῖ δέ ἑ μητίετα Ζεύς.{l]{q]{para]
[para}[l [n}2.198{]}ὃν δʼ αὖ δήμου τʼ ἄνδρα ἴδοι βοόωντά τʼ ἐφεύροι,{l]
[l [n}2.199{]}τὸν σκήπτρῳ ἐλάσασκεν ὁμοκλήσασκέ τε μύθῳ·{l]
[q}[l [n}2.200{]}δαιμόνιʼ ἀτρέμας ἧσο καὶ ἄλλων μῦθον ἄκουε,{l]
[l [n}2.201{]}οἳ σέο φέρτεροί εἰσι, σὺ δʼ ἀπτόλεμος καὶ ἄναλκις{l]
[l [n}2.202{]}οὔτέ ποτʼ ἐν πολέμῳ ἐναρίθμιος οὔτʼ ἐνὶ βουλῇ·{l]
[l [n}2.203{]}οὐ μέν πως πάντες βασιλεύσομεν ἐνθάδʼ Ἀχαιοί·{l]
[l [n}2.204{]}οὐκ ἀγαθὸν πολυκοιρανίη· εἷς κοίρανος ἔστω,{l]
[l [n}2.205{]}εἷς βασιλεύς, ᾧ δῶκε Κρόνου πάϊς ἀγκυλομήτεω{l]
[l [n}2.206{]}σκῆπτρόν τʼ ἠδὲ θέμιστας, ἵνά σφισι βουλεύῃσι.{l]{q]{para]
[para}[l [n}2.207{]}ὣς ὅ γε κοιρανέων δίεπε στρατόν· οἳ δʼ ἀγορὴν δὲ{l]
[l [n}2.208{]}αὖτις ἐπεσσεύοντο νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.209{]}ἠχῇ, ὡς ὅτε κῦμα πολυφλοίσβοιο θαλάσσης{l]
[l [n}2.210{]}αἰγιαλῷ μεγάλῳ βρέμεται, σμαραγεῖ δέ τε πόντος.{l]{para]
[para}[l [n}2.211{]}ἄλλοι μέν ῥʼ ἕζοντο, ἐρήτυθεν δὲ καθʼ ἕδρας·{l]
[l [n}2.212{]}Θερσίτης δʼ ἔτι μοῦνος ἀμετροεπὴς ἐκολῴα,{l]
[l [n}2.213{]}ὃς ἔπεα φρεσὶν ᾗσιν ἄκοσμά τε πολλά τε ᾔδη{l]
[l [n}2.214{]}μάψ, ἀτὰρ οὐ κατὰ κόσμον, ἐριζέμεναι βασιλεῦσιν,{l]
[l [n}2.215{]}ἀλλʼ ὅ τι οἱ εἴσαιτο γελοίϊον Ἀργείοισιν{l]
[l [n}2.216{]}ἔμμεναι· αἴσχιστος δὲ ἀνὴρ ὑπὸ Ἴλιον ἦλθε·{l]
[l [n}2.217{]}φολκὸς ἔην, χωλὸς δʼ ἕτερον πόδα· τὼ δέ οἱ ὤμω{l]
[l [n}2.218{]}κυρτὼ ἐπὶ στῆθος συνοχωκότε· αὐτὰρ ὕπερθε{l]
[l [n}2.219{]}φοξὸς ἔην κεφαλήν, ψεδνὴ δʼ ἐπενήνοθε λάχνη.{l]
[l [n}2.220{]}ἔχθιστος δʼ Ἀχιλῆϊ μάλιστʼ ἦν ἠδʼ Ὀδυσῆϊ·{l]
[l [n}2.221{]}τὼ γὰρ νεικείεσκε· τότʼ αὖτʼ Ἀγαμέμνονι δίῳ{l]
[l [n}2.222{]}ὀξέα κεκλήγων λέγʼ ὀνείδεα· τῷ δʼ ἄρʼ Ἀχαιοὶ{l]
[l [n}2.223{]}ἐκπάγλως κοτέοντο νεμέσσηθέν τʼ ἐνὶ θυμῷ.{l]
[l [n}2.224{]}αὐτὰρ ὃ μακρὰ βοῶν Ἀγαμέμνονα νείκεε μύθῳ·{l]
[q}[l [n}2.225{]}Ἀτρεΐδη τέο δʼ αὖτʼ ἐπιμέμφεαι ἠδὲ χατίζεις;{l]
[l [n}2.226{]}πλεῖαί τοι χαλκοῦ κλισίαι, πολλαὶ δὲ γυναῖκες{l]
[l [n}2.227{]}εἰσὶν ἐνὶ κλισίῃς ἐξαίρετοι, ἅς τοι Ἀχαιοὶ{l]
[l [n}2.228{]}πρωτίστῳ δίδομεν εὖτʼ ἂν πτολίεθρον ἕλωμεν.{l]
[l [n}2.229{]}ἦ ἔτι καὶ χρυσοῦ ἐπιδεύεαι, ὅν κέ τις οἴσει{l]
[l [n}2.230{]}Τρώων ἱπποδάμων ἐξ Ἰλίου υἷος ἄποινα,{l]
[l [n}2.231{]}ὅν κεν ἐγὼ δήσας ἀγάγω ἢ ἄλλος Ἀχαιῶν,{l]
[l [n}2.232{]}ἠὲ γυναῖκα νέην, ἵνα μίσγεαι ἐν φιλότητι,{l]
[l [n}2.233{]}ἥν τʼ αὐτὸς ἀπονόσφι κατίσχεαι; οὐ μὲν ἔοικεν{l]
[l [n}2.234{]}ἀρχὸν ἐόντα κακῶν ἐπιβασκέμεν υἷας Ἀχαιῶν.{l]
[l [n}2.235{]}ὦ πέπονες κάκʼ ἐλέγχεʼ Ἀχαιΐδες οὐκέτʼ Ἀχαιοὶ{l]
[l [n}2.236{]}οἴκαδέ περ σὺν νηυσὶ νεώμεθα, τόνδε δʼ ἐῶμεν{l]
[l [n}2.237{]}αὐτοῦ ἐνὶ Τροίῃ γέρα πεσσέμεν, ὄφρα ἴδηται{l]
[l [n}2.238{]}ἤ ῥά τί οἱ χἠμεῖς προσαμύνομεν ἦε καὶ οὐκί·{l]
[l [n}2.239{]}ὃς καὶ νῦν Ἀχιλῆα ἕο μέγʼ ἀμείνονα φῶτα{l]
[l [n}2.240{]}ἠτίμησεν· ἑλὼν γὰρ ἔχει γέρας αὐτὸς ἀπούρας.{l]
[l [n}2.241{]}ἀλλὰ μάλʼ οὐκ Ἀχιλῆϊ χόλος φρεσίν, ἀλλὰ μεθήμων·{l]
[l [n}2.242{]}ἦ γὰρ ἂν Ἀτρεΐδη νῦν ὕστατα λωβήσαιο·{l]{q]{para]
[para}[l [n}2.243{]}ὣς φάτο νεικείων Ἀγαμέμνονα ποιμένα λαῶν,{l]
[l [n}2.244{]}Θερσίτης· τῷ δʼ ὦκα παρίστατο δῖος Ὀδυσσεύς,{l]
[l [n}2.245{]}καί μιν ὑπόδρα ἰδὼν χαλεπῷ ἠνίπαπε μύθῳ·{l]
[q}[l [n}2.246{]}Θερσῖτʼ ἀκριτόμυθε, λιγύς περ ἐὼν ἀγορητής,{l]
[l [n}2.247{]}ἴσχεο, μηδʼ ἔθελʼ οἶος ἐριζέμεναι βασιλεῦσιν·{l]
[l [n}2.248{]}οὐ γὰρ ἐγὼ σέο φημὶ χερειότερον βροτὸν ἄλλον{l]
[l [n}2.249{]}ἔμμεναι, ὅσσοι ἅμʼ Ἀτρεΐδῃς ὑπὸ Ἴλιον ἦλθον.{l]
[l [n}2.250{]}τὼ οὐκ ἂν βασιλῆας ἀνὰ στόμʼ ἔχων ἀγορεύοις,{l]
[l [n}2.251{]}καί σφιν ὀνείδεά τε προφέροις, νόστόν τε φυλάσσοις.{l]
[l [n}2.252{]}οὐδέ τί πω σάφα ἴδμεν ὅπως ἔσται τάδε ἔργα,{l]
[l [n}2.253{]}ἢ εὖ ἦε κακῶς νοστήσομεν υἷες Ἀχαιῶν.{l]
[l [n}2.254{]}τὼ νῦν Ἀτρεΐδῃ Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}2.255{]}ἧσαι ὀνειδίζων, ὅτι οἱ μάλα πολλὰ διδοῦσιν{l]
[l [n}2.256{]}ἥρωες Δαναοί· σὺ δὲ κερτομέων ἀγορεύεις.{l]
[l [n}2.257{]}ἀλλʼ ἔκ τοι ἐρέω, τὸ δὲ καὶ τετελεσμένον ἔσται·{l]
[l [n}2.258{]}εἴ κʼ ἔτι σʼ ἀφραίνοντα κιχήσομαι ὥς νύ περ ὧδε,{l]
[l [n}2.259{]}μηκέτʼ ἔπειτʼ Ὀδυσῆϊ κάρη ὤμοισιν ἐπείη,{l]
[l [n}2.260{]}μηδʼ ἔτι Τηλεμάχοιο πατὴρ κεκλημένος εἴην,{l]
[l [n}2.261{]}εἰ μὴ ἐγώ σε λαβὼν ἀπὸ μὲν φίλα εἵματα δύσω,{l]
[l [n}2.262{]}χλαῖνάν τʼ ἠδὲ χιτῶνα, τά τʼ αἰδῶ ἀμφικαλύπτει,{l]
[l [n}2.263{]}αὐτὸν δὲ κλαίοντα θοὰς ἐπὶ νῆας ἀφήσω{l]
[l [n}2.264{]}πεπλήγων ἀγορῆθεν ἀεικέσσι πληγῇσιν.{l]{q]{para]
[para}[l [n}2.265{]}ὣς ἄρʼ ἔφη, σκήπτρῳ δὲ μετάφρενον ἠδὲ καὶ ὤμω{l]
[l [n}2.266{]}πλῆξεν· ὃ δʼ ἰδνώθη, θαλερὸν δέ οἱ ἔκπεσε δάκρυ·{l]
[l [n}2.267{]}σμῶδιξ δʼ αἱματόεσσα μεταφρένου ἐξυπανέστη{l]
[l [n}2.268{]}σκήπτρου ὕπο χρυσέου· ὃ δʼ ἄρʼ ἕζετο τάρβησέν τε,{l]
[l [n}2.269{]}ἀλγήσας δʼ ἀχρεῖον ἰδὼν ἀπομόρξατο δάκρυ.{l]
[l [n}2.270{]}οἳ δὲ καὶ ἀχνύμενοί περ ἐπʼ αὐτῷ ἡδὺ γέλασσαν·{l]
[l [n}2.271{]}ὧδε δέ τις εἴπεσκεν ἰδὼν ἐς πλησίον ἄλλον·{l]
[q}[l [n}2.272{]}ὢ πόποι ἦ δὴ μυρίʼ Ὀδυσσεὺς ἐσθλὰ ἔοργε{l]
[l [n}2.273{]}βουλάς τʼ ἐξάρχων ἀγαθὰς πόλεμόν τε κορύσσων·{l]
[l [n}2.274{]}νῦν δὲ τόδε μέγʼ ἄριστον ἐν Ἀργείοισιν ἔρεξεν,{l]
[l [n}2.275{]}ὃς τὸν λωβητῆρα ἐπεσβόλον ἔσχʼ ἀγοράων.{l]
[l [n}2.276{]}οὔ θήν μιν πάλιν αὖτις ἀνήσει θυμὸς ἀγήνωρ{l]
[l [n}2.277{]}νεικείειν βασιλῆας ὀνειδείοις ἐπέεσσιν.{l]{q]{para]
[para}[l [n}2.278{]}ὣς φάσαν ἣ πληθύς· ἀνὰ δʼ ὃ πτολίπορθος Ὀδυσσεὺς{l]
[l [n}2.279{]}ἔστη σκῆπτρον ἔχων· παρὰ δὲ γλαυκῶπις Ἀθήνη{l]
[l [n}2.280{]}εἰδομένη κήρυκι σιωπᾶν λαὸν ἀνώγει,{l]
[l [n}2.281{]}ὡς ἅμα θʼ οἳ πρῶτοί τε καὶ ὕστατοι υἷες Ἀχαιῶν{l]
[l [n}2.282{]}μῦθον ἀκούσειαν καὶ ἐπιφρασσαίατο βουλήν·{l]
[l [n}2.283{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}2.284{]}Ἀτρεΐδη νῦν δή σε ἄναξ ἐθέλουσιν Ἀχαιοὶ{l]
[l [n}2.285{]}πᾶσιν ἐλέγχιστον θέμεναι μερόπεσσι βροτοῖσιν,{l]
[l [n}2.286{]}οὐδέ τοι ἐκτελέουσιν ὑπόσχεσιν ἥν περ ὑπέσταν{l]
[l [n}2.287{]}ἐνθάδʼ ἔτι στείχοντες ἀπʼ Ἄργεος ἱπποβότοιο{l]
[l [n}2.288{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι.{l]
[l [n}2.289{]}ὥς τε γὰρ ἢ παῖδες νεαροὶ χῆραί τε γυναῖκες{l]
[l [n}2.290{]}ἀλλήλοισιν ὀδύρονται οἶκον δὲ νέεσθαι.{l]
[l [n}2.291{]}ἦ μὴν καὶ πόνος ἐστὶν ἀνιηθέντα νέεσθαι·{l]
[l [n}2.292{]}καὶ γάρ τίς θʼ ἕνα μῆνα μένων ἀπὸ ἧς ἀλόχοιο{l]
[l [n}2.293{]}ἀσχαλάᾳ σὺν νηῒ πολυζύγῳ, ὅν περ ἄελλαι{l]
[l [n}2.294{]}χειμέριαι εἰλέωσιν ὀρινομένη τε θάλασσα·{l]
[l [n}2.295{]}ἡμῖν δʼ εἴνατός ἐστι περιτροπέων ἐνιαυτὸς{l]
[l [n}2.296{]}ἐνθάδε μιμνόντεσσι· τὼ οὐ νεμεσίζομʼ Ἀχαιοὺς{l]
[l [n}2.297{]}ἀσχαλάαν παρὰ νηυσὶ κορωνίσιν· ἀλλὰ καὶ ἔμπης{l]
[l [n}2.298{]}αἰσχρόν τοι δηρόν τε μένειν κενεόν τε νέεσθαι.{l]
[l [n}2.299{]}τλῆτε φίλοι, καὶ μείνατʼ ἐπὶ χρόνον ὄφρα δαῶμεν{l]
[l [n}2.300{]}ἢ ἐτεὸν Κάλχας μαντεύεται ἦε καὶ οὐκί.{l]
[l [n}2.301{]}εὖ γὰρ δὴ τόδε ἴδμεν ἐνὶ φρεσίν, ἐστὲ δὲ πάντες{l]
[l [n}2.302{]}μάρτυροι, οὓς μὴ κῆρες ἔβαν θανάτοιο φέρουσαι·{l]
[l [n}2.303{]}χθιζά τε καὶ πρωΐζʼ ὅτʼ ἐς Αὐλίδα νῆες Ἀχαιῶν{l]
[l [n}2.304{]}ἠγερέθοντο κακὰ Πριάμῳ καὶ Τρωσὶ φέρουσαι,{l]
[l [n}2.305{]}ἡμεῖς δʼ ἀμφὶ περὶ κρήνην ἱεροὺς κατὰ βωμοὺς{l]
[l [n}2.306{]}ἕρδομεν ἀθανάτοισι τεληέσσας ἑκατόμβας{l]
[l [n}2.307{]}καλῇ ὑπὸ πλατανίστῳ ὅθεν ῥέεν ἀγλαὸν ὕδωρ·{l]
[l [n}2.308{]}ἔνθʼ ἐφάνη μέγα σῆμα· δράκων ἐπὶ νῶτα δαφοινὸς{l]
[l [n}2.309{]}σμερδαλέος, τόν ῥʼ αὐτὸς Ὀλύμπιος ἧκε φόως δέ,{l]
[l [n}2.310{]}βωμοῦ ὑπαΐξας πρός ῥα πλατάνιστον ὄρουσεν.{l]
[l [n}2.311{]}ἔνθα δʼ ἔσαν στρουθοῖο νεοσσοί, νήπια τέκνα,{l]
[l [n}2.312{]}ὄζῳ ἐπʼ ἀκροτάτῳ πετάλοις ὑποπεπτηῶτες{l]
[l [n}2.313{]}ὀκτώ, ἀτὰρ μήτηρ ἐνάτη ἦν ἣ τέκε τέκνα·{l]
[l [n}2.314{]}ἔνθʼ ὅ γε τοὺς ἐλεεινὰ κατήσθιε τετριγῶτας·{l]
[l [n}2.315{]}μήτηρ δʼ ἀμφεποτᾶτο ὀδυρομένη φίλα τέκνα·{l]
[l [n}2.316{]}τὴν δʼ ἐλελιξάμενος πτέρυγος λάβεν ἀμφιαχυῖαν.{l]
[l [n}2.317{]}αὐτὰρ ἐπεὶ κατὰ τέκνα φάγε στρουθοῖο καὶ αὐτήν,{l]
[l [n}2.318{]}τὸν μὲν ἀρίζηλον θῆκεν θεὸς ὅς περ ἔφηνε·{l]
[l [n}2.319{]}λᾶαν γάρ μιν ἔθηκε Κρόνου πάϊς ἀγκυλομήτεω·{l]
[l [n}2.320{]}ἡμεῖς δʼ ἑσταότες θαυμάζομεν οἷον ἐτύχθη.{l]
[l [n}2.321{]}ὡς οὖν δεινὰ πέλωρα θεῶν εἰσῆλθʼ ἑκατόμβας,{l]
[l [n}2.322{]}Κάλχας δʼ αὐτίκʼ ἔπειτα θεοπροπέων ἀγόρευε·{l]
[q}[l [n}2.323{]}τίπτʼ ἄνεῳ ἐγένεσθε κάρη κομόωντες Ἀχαιοί;{l]
[l [n}2.324{]}ἡμῖν μὲν τόδʼ ἔφηνε τέρας μέγα μητίετα Ζεὺς{l]
[l [n}2.325{]}ὄψιμον ὀψιτέλεστον, ὅου κλέος οὔ ποτʼ ὀλεῖται.{l]
[l [n}2.326{]}ὡς οὗτος κατὰ τέκνα φάγε στρουθοῖο καὶ αὐτὴν{l]
[l [n}2.327{]}ὀκτώ, ἀτὰρ μήτηρ ἐνάτη ἦν ἣ τέκε τέκνα,{l]
[l [n}2.328{]}ὣς ἡμεῖς τοσσαῦτʼ ἔτεα πτολεμίξομεν αὖθι,{l]
[l [n}2.329{]}τῷ δεκάτῳ δὲ πόλιν αἱρήσομεν εὐρυάγυιαν.{l]{q][l [n}2.330{]}κεῖνος τὼς ἀγόρευε· τὰ δὴ νῦν πάντα τελεῖται.{l]
[l [n}2.331{]}ἀλλʼ ἄγε μίμνετε πάντες ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}2.332{]}αὐτοῦ εἰς ὅ κεν ἄστυ μέγα Πριάμοιο ἕλωμεν.{l]{q]{para]
[para}[l [n}2.333{]}ὣς ἔφατʼ, Ἀργεῖοι δὲ μέγʼ ἴαχον, ἀμφὶ δὲ νῆες{l]
[l [n}2.334{]}σμερδαλέον κονάβησαν ἀϋσάντων ὑπʼ Ἀχαιῶν,{l]
[l [n}2.335{]}μῦθον ἐπαινήσαντες Ὀδυσσῆος θείοιο·{l]
[l [n}2.336{]}τοῖσι δὲ καὶ μετέειπε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}2.337{]}ὦ πόποι ἦ δὴ παισὶν ἐοικότες ἀγοράασθε{l]
[l [n}2.338{]}νηπιάχοις οἷς οὔ τι μέλει πολεμήϊα ἔργα.{l]
[l [n}2.339{]}πῇ δὴ συνθεσίαι τε καὶ ὅρκια βήσεται ἥμιν;{l]
[l [n}2.340{]}ἐν πυρὶ δὴ βουλαί τε γενοίατο μήδεά τʼ ἀνδρῶν{l]
[l [n}2.341{]}σπονδαί τʼ ἄκρητοι καὶ δεξιαί, ᾗς ἐπέπιθμεν·{l]
[l [n}2.342{]}αὔτως γὰρ ἐπέεσσʼ ἐριδαίνομεν, οὐδέ τι μῆχος{l]
[l [n}2.343{]}εὑρέμεναι δυνάμεσθα, πολὺν χρόνον ἐνθάδʼ ἐόντες.{l]
[l [n}2.344{]}Ἀτρεΐδη σὺ δʼ ἔθʼ ὡς πρὶν ἔχων ἀστεμφέα βουλὴν{l]
[l [n}2.345{]}ἄρχευʼ Ἀργείοισι κατὰ κρατερὰς ὑσμίνας,{l]
[l [n}2.346{]}τούσδε δʼ ἔα φθινύθειν ἕνα καὶ δύο, τοί κεν Ἀχαιῶν{l]
[l [n}2.347{]}νόσφιν βουλεύωσʼ· ἄνυσις δʼ οὐκ ἔσσεται αὐτῶν·{l]
[l [n}2.348{]}πρὶν Ἄργος δʼ ἰέναι πρὶν καὶ Διὸς αἰγιόχοιο{l]
[l [n}2.349{]}γνώμεναι εἴ τε ψεῦδος ὑπόσχεσις εἴ τε καὶ οὐκί.{l]
[l [n}2.350{]}φημὶ γὰρ οὖν κατανεῦσαι ὑπερμενέα Κρονίωνα{l]
[l [n}2.351{]}ἤματι τῷ ὅτε νηυσὶν ἐν ὠκυπόροισιν ἔβαινον{l]
[l [n}2.352{]}Ἀργεῖοι Τρώεσσι φόνον καὶ κῆρα φέροντες{l]
[l [n}2.353{]}ἀστράπτων ἐπιδέξιʼ ἐναίσιμα σήματα φαίνων.{l]
[l [n}2.354{]}τὼ μή τις πρὶν ἐπειγέσθω οἶκον δὲ νέεσθαι{l]
[l [n}2.355{]}πρίν τινα πὰρ Τρώων ἀλόχῳ κατακοιμηθῆναι,{l]
[l [n}2.356{]}τίσασθαι δʼ Ἑλένης ὁρμήματά τε στοναχάς τε.{l]
[l [n}2.357{]}εἰ δέ τις ἐκπάγλως ἐθέλει οἶκον δὲ νέεσθαι{l]
[l [n}2.358{]}ἁπτέσθω ἧς νηὸς ἐϋσσέλμοιο μελαίνης,{l]
[l [n}2.359{]}ὄφρα πρόσθʼ ἄλλων θάνατον καὶ πότμον ἐπίσπῃ.{l]
[l [n}2.360{]}ἀλλὰ ἄναξ αὐτός τʼ εὖ μήδεο πείθεό τʼ ἄλλῳ·{l]
[l [n}2.361{]}οὔ τοι ἀπόβλητον ἔπος ἔσσεται ὅττί κεν εἴπω·{l]
[l [n}2.362{]}κρῖνʼ ἄνδρας κατὰ φῦλα κατὰ φρήτρας Ἀγάμεμνον,{l]
[l [n}2.363{]}ὡς φρήτρη φρήτρηφιν ἀρήγῃ, φῦλα δὲ φύλοις.{l]
[l [n}2.364{]}εἰ δέ κεν ὣς ἕρξῃς καί τοι πείθωνται Ἀχαιοί,{l]
[l [n}2.365{]}γνώσῃ ἔπειθʼ ὅς θʼ ἡγεμόνων κακὸς ὅς τέ νυ λαῶν{l]
[l [n}2.366{]}ἠδʼ ὅς κʼ ἐσθλὸς ἔῃσι· κατὰ σφέας γὰρ μαχέονται.{l]
[l [n}2.367{]}γνώσεαι δʼ εἰ καὶ θεσπεσίῃ πόλιν οὐκ ἀλαπάξεις,{l]
[l [n}2.368{]}ἦ ἀνδρῶν κακότητι καὶ ἀφραδίῃ πολέμοιο.{l]{q]{para]
[para}[l [n}2.369{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}2.370{]}ἦ μὰν αὖτʼ ἀγορῇ νικᾷς γέρον υἷας Ἀχαιῶν.{l]
[l [n}2.371{]}αἲ γὰρ Ζεῦ τε πάτερ καὶ Ἀθηναίη καὶ Ἄπολλον{l]
[l [n}2.372{]}τοιοῦτοι δέκα μοι συμφράδμονες εἶεν Ἀχαιῶν·{l]
[l [n}2.373{]}τώ κε τάχʼ ἠμύσειε πόλις Πριάμοιο ἄνακτος{l]
[l [n}2.374{]}χερσὶν ὑφʼ ἡμετέρῃσιν ἁλοῦσά τε περθομένη τε.{l]
[l [n}2.375{]}ἀλλά μοι αἰγίοχος Κρονίδης Ζεὺς ἄλγεʼ ἔδωκεν,{l]
[l [n}2.376{]}ὅς με μετʼ ἀπρήκτους ἔριδας καὶ νείκεα βάλλει.{l]
[l [n}2.377{]}καὶ γὰρ ἐγὼν Ἀχιλεύς τε μαχεσσάμεθʼ εἵνεκα κούρης{l]
[l [n}2.378{]}ἀντιβίοις ἐπέεσσιν, ἐγὼ δʼ ἦρχον χαλεπαίνων·{l]
[l [n}2.379{]}εἰ δέ ποτʼ ἔς γε μίαν βουλεύσομεν, οὐκέτʼ ἔπειτα{l]
[l [n}2.380{]}Τρωσὶν ἀνάβλησις κακοῦ ἔσσεται οὐδʼ ἠβαιόν.{l]
[l [n}2.381{]}νῦν δʼ ἔρχεσθʼ ἐπὶ δεῖπνον ἵνα ξυνάγωμεν Ἄρηα.{l]
[l [n}2.382{]}εὖ μέν τις δόρυ θηξάσθω, εὖ δʼ ἀσπίδα θέσθω,{l]
[l [n}2.383{]}εὖ δέ τις ἵπποισιν δεῖπνον δότω ὠκυπόδεσσιν,{l]
[l [n}2.384{]}εὖ δέ τις ἅρματος ἀμφὶς ἰδὼν πολέμοιο μεδέσθω,{l]
[l [n}2.385{]}ὥς κε πανημέριοι στυγερῷ κρινώμεθʼ Ἄρηϊ.{l]
[l [n}2.386{]}οὐ γὰρ παυσωλή γε μετέσσεται οὐδʼ ἠβαιὸν{l]
[l [n}2.387{]}εἰ μὴ νὺξ ἐλθοῦσα διακρινέει μένος ἀνδρῶν.{l]
[l [n}2.388{]}ἱδρώσει μέν τευ τελαμὼν ἀμφὶ στήθεσφιν{l]
[l [n}2.389{]}ἀσπίδος ἀμφιβρότης, περὶ δʼ ἔγχεϊ χεῖρα καμεῖται·{l]
[l [n}2.390{]}ἱδρώσει δέ τευ ἵππος ἐΰξοον ἅρμα τιταίνων.{l]
[l [n}2.391{]}ὃν δέ κʼ ἐγὼν ἀπάνευθε μάχης ἐθέλοντα νοήσω{l]
[l [n}2.392{]}μιμνάζειν παρὰ νηυσὶ κορωνίσιν, οὔ οἱ ἔπειτα{l]
[l [n}2.393{]}ἄρκιον ἐσσεῖται φυγέειν κύνας ἠδʼ οἰωνούς.{l]{q]{para]
[para}[l [n}2.394{]}ὣς ἔφατʼ, Ἀργεῖοι δὲ μέγʼ ἴαχον ὡς ὅτε κῦμα{l]
[l [n}2.395{]}ἀκτῇ ἐφʼ ὑψηλῇ, ὅτε κινήσῃ Νότος ἐλθών,{l]
[l [n}2.396{]}προβλῆτι σκοπέλῳ· τὸν δʼ οὔ ποτε κύματα λείπει{l]
[l [n}2.397{]}παντοίων ἀνέμων, ὅτʼ ἂν ἔνθʼ ἢ ἔνθα γένωνται.{l]
[l [n}2.398{]}ἀνστάντες δʼ ὀρέοντο κεδασθέντες κατὰ νῆας,{l]
[l [n}2.399{]}κάπνισσάν τε κατὰ κλισίας, καὶ δεῖπνον ἕλοντο.{l]
[l [n}2.400{]}ἄλλος δʼ ἄλλῳ ἔρεζε θεῶν αἰειγενετάων{l]
[l [n}2.401{]}εὐχόμενος θάνατόν τε φυγεῖν καὶ μῶλον Ἄρηος.{l]
[l [n}2.402{]}αὐτὰρ ὃ βοῦν ἱέρευσε ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}2.403{]}πίονα πενταέτηρον ὑπερμενέϊ Κρονίωνι,{l]
[l [n}2.404{]}κίκλησκεν δὲ γέροντας ἀριστῆας Παναχαιῶν,{l]
[l [n}2.405{]}Νέστορα μὲν πρώτιστα καὶ Ἰδομενῆα ἄνακτα,{l]
[l [n}2.406{]}αὐτὰρ ἔπειτʼ Αἴαντε δύω καὶ Τυδέος υἱόν,{l]
[l [n}2.407{]}ἕκτον δʼ αὖτʼ Ὀδυσῆα Διὶ μῆτιν ἀτάλαντον.{l]
[l [n}2.408{]}αὐτόματος δέ οἱ ἦλθε βοὴν ἀγαθὸς Μενέλαος·{l]
[l [n}2.409{]}ᾔδεε γὰρ κατὰ θυμὸν ἀδελφεὸν ὡς ἐπονεῖτο.{l]
[l [n}2.410{]}βοῦν δὲ περιστήσαντο καὶ οὐλοχύτας ἀνέλοντο·{l]
[l [n}2.411{]}τοῖσιν δʼ εὐχόμενος μετέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}2.412{]}Ζεῦ κύδιστε μέγιστε κελαινεφὲς αἰθέρι ναίων{l]
[l [n}2.413{]}μὴ πρὶν ἐπʼ ἠέλιον δῦναι καὶ ἐπὶ κνέφας ἐλθεῖν{l]
[l [n}2.414{]}πρίν με κατὰ πρηνὲς βαλέειν Πριάμοιο μέλαθρον{l]
[l [n}2.415{]}αἰθαλόεν, πρῆσαι δὲ πυρὸς δηΐοιο θύρετρα,{l]
[l [n}2.416{]}Ἑκτόρεον δὲ χιτῶνα περὶ στήθεσσι δαΐξαι{l]
[l [n}2.417{]}χαλκῷ ῥωγαλέον· πολέες δʼ ἀμφʼ αὐτὸν ἑταῖροι{l]
[l [n}2.418{]}πρηνέες ἐν κονίῃσιν ὀδὰξ λαζοίατο γαῖαν.{l]{q]{para]
[para}[l [n}2.419{]}ὣς ἔφατʼ, οὐδʼ ἄρα πώ οἱ ἐπεκραίαινε Κρονίων,{l]
[l [n}2.420{]}ἀλλʼ ὅ γε δέκτο μὲν ἱρά, πόνον δʼ ἀμέγαρτον ὄφελλεν.{l]
[l [n}2.421{]}αὐτὰρ ἐπεί ῥʼ εὔξαντο καὶ οὐλοχύτας προβάλοντο,{l]
[l [n}2.422{]}αὐέρυσαν μὲν πρῶτα καὶ ἔσφαξαν καὶ ἔδειραν,{l]
[l [n}2.423{]}μηρούς τʼ ἐξέταμον κατά τε κνίσῃ ἐκάλυψαν{l]
[l [n}2.424{]}δίπτυχα ποιήσαντες, ἐπʼ αὐτῶν δʼ ὠμοθέτησαν.{l]
[l [n}2.425{]}καὶ τὰ μὲν ἂρ σχίζῃσιν ἀφύλλοισιν κατέκαιον,{l]
[l [n}2.426{]}σπλάγχνα δʼ ἄρʼ ἀμπείραντες ὑπείρεχον Ἡφαίστοιο.{l]
[l [n}2.427{]}αὐτὰρ ἐπεὶ κατὰ μῆρε κάη καὶ σπλάγχνα πάσαντο,{l]
[l [n}2.428{]}μίστυλλόν τʼ ἄρα τἆλλα καὶ ἀμφʼ ὀβελοῖσιν ἔπειραν,{l]
[l [n}2.429{]}ὤπτησάν τε περιφραδέως, ἐρύσαντό τε πάντα.{l]
[l [n}2.430{]}αὐτὰρ ἐπεὶ παύσαντο πόνου τετύκοντό τε δαῖτα{l]
[l [n}2.431{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης.{l]
[l [n}2.432{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}2.433{]}τοῖς ἄρα μύθων ἦρχε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}2.434{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον,{l]
[l [n}2.435{]}μηκέτι νῦν δήθʼ αὖθι λεγώμεθα, μηδʼ ἔτι δηρὸν{l]
[l [n}2.436{]}ἀμβαλλώμεθα ἔργον ὃ δὴ θεὸς ἐγγυαλίζει.{l]
[l [n}2.437{]}ἀλλʼ ἄγε κήρυκες μὲν Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}2.438{]}λαὸν κηρύσσοντες ἀγειρόντων κατὰ νῆας,{l]
[l [n}2.439{]}ἡμεῖς δʼ ἀθρόοι ὧδε κατὰ στρατὸν εὐρὺν Ἀχαιῶν{l]
[l [n}2.440{]}ἴομεν ὄφρα κε θᾶσσον ἐγείρομεν ὀξὺν Ἄρηα.{l]{q]{para]
[para}[l [n}2.441{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησεν ἄναξ ἀνδρῶν Ἀγαμέμνων.{l]
[l [n}2.442{]}αὐτίκα κηρύκεσσι λιγυφθόγγοισι κέλευσε{l]
[l [n}2.443{]}κηρύσσειν πόλεμον δὲ κάρη κομόωντας Ἀχαιούς·{l]
[l [n}2.444{]}οἳ μὲν ἐκήρυσσον, τοὶ δʼ ἠγείροντο μάλʼ ὦκα.{l]
[l [n}2.445{]}οἳ δʼ ἀμφʼ Ἀτρεΐωνα διοτρεφέες βασιλῆες{l]
[l [n}2.446{]}θῦνον κρίνοντες, μετὰ δὲ γλαυκῶπις Ἀθήνη{l]
[l [n}2.447{]}αἰγίδʼ ἔχουσʼ ἐρίτιμον ἀγήρων ἀθανάτην τε,{l]
[l [n}2.448{]}τῆς ἑκατὸν θύσανοι παγχρύσεοι ἠερέθονται,{l]
[l [n}2.449{]}πάντες ἐϋπλεκέες, ἑκατόμβοιος δὲ ἕκαστος·{l]
[l [n}2.450{]}σὺν τῇ παιφάσσουσα διέσσυτο λαὸν Ἀχαιῶν{l]
[l [n}2.451{]}ὀτρύνουσʼ ἰέναι· ἐν δὲ σθένος ὦρσεν ἑκάστῳ{l]
[l [n}2.452{]}καρδίῃ ἄλληκτον πολεμίζειν ἠδὲ μάχεσθαι.{l]
[l [n}2.453{]}τοῖσι δʼ ἄφαρ πόλεμος γλυκίων γένετʼ ἠὲ νέεσθαι{l]
[l [n}2.454{]}ἐν νηυσὶ γλαφυρῇσι φίλην ἐς πατρίδα γαῖαν.{l]{para]
[para}[l [n}2.455{]}ἠΰτε πῦρ ἀΐδηλον ἐπιφλέγει ἄσπετον ὕλην{l]
[l [n}2.456{]}οὔρεος ἐν κορυφῇς, ἕκαθεν δέ τε φαίνεται αὐγή,{l]
[l [n}2.457{]}ὣς τῶν ἐρχομένων ἀπὸ χαλκοῦ θεσπεσίοιο{l]
[l [n}2.458{]}αἴγλη παμφανόωσα διʼ αἰθέρος οὐρανὸν ἷκε.{l]{para]
[para}[l [n}2.459{]}τῶν δʼ ὥς τʼ ὀρνίθων πετεηνῶν ἔθνεα πολλὰ{l]
[l [n}2.460{]}χηνῶν ἢ γεράνων ἢ κύκνων δουλιχοδείρων{l]
[l [n}2.461{]}Ἀσίω ἐν λειμῶνι Καϋστρίου ἀμφὶ ῥέεθρα{l]
[l [n}2.462{]}ἔνθα καὶ ἔνθα ποτῶνται ἀγαλλόμενα πτερύγεσσι{l]
[l [n}2.463{]}κλαγγηδὸν προκαθιζόντων, σμαραγεῖ δέ τε λειμών,{l]
[l [n}2.464{]}ὣς τῶν ἔθνεα πολλὰ νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.465{]}ἐς πεδίον προχέοντο Σκαμάνδριον· αὐτὰρ ὑπὸ χθὼν{l]
[l [n}2.466{]}σμερδαλέον κονάβιζε ποδῶν αὐτῶν τε καὶ ἵππων.{l]
[l [n}2.467{]}ἔσταν δʼ ἐν λειμῶνι Σκαμανδρίῳ ἀνθεμόεντι{l]
[l [n}2.468{]}μυρίοι, ὅσσά τε φύλλα καὶ ἄνθεα γίγνεται ὥρῃ.{l]{para]
[para}[l [n}2.469{]}ἠΰτε μυιάων ἁδινάων ἔθνεα πολλὰ{l]
[l [n}2.470{]}αἵ τε κατὰ σταθμὸν ποιμνήϊον ἠλάσκουσιν{l]
[l [n}2.471{]}ὥρῃ ἐν εἰαρινῇ ὅτε τε γλάγος ἄγγεα δεύει,{l]
[l [n}2.472{]}τόσσοι ἐπὶ Τρώεσσι κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}2.473{]}ἐν πεδίῳ ἵσταντο διαρραῖσαι μεμαῶτες.{l]{para]
[para}[l [n}2.474{]}τοὺς δʼ ὥς τʼ αἰπόλια πλατέʼ αἰγῶν αἰπόλοι ἄνδρες{l]
[l [n}2.475{]}ῥεῖα διακρίνωσιν ἐπεί κε νομῷ μιγέωσιν,{l]
[l [n}2.476{]}ὣς τοὺς ἡγεμόνες διεκόσμεον ἔνθα καὶ ἔνθα{l]
[l [n}2.477{]}ὑσμίνην δʼ ἰέναι, μετὰ δὲ κρείων Ἀγαμέμνων{l]
[l [n}2.478{]}ὄμματα καὶ κεφαλὴν ἴκελος Διὶ τερπικεραύνῳ,{l]
[l [n}2.479{]}Ἄρεϊ δὲ ζώνην, στέρνον δὲ Ποσειδάωνι.{l]
[l [n}2.480{]}ἠΰτε βοῦς ἀγέληφι μέγʼ ἔξοχος ἔπλετο πάντων{l]
[l [n}2.481{]}ταῦρος· ὃ γάρ τε βόεσσι μεταπρέπει ἀγρομένῃσι·{l]
[l [n}2.482{]}τοῖον ἄρʼ Ἀτρεΐδην θῆκε Ζεὺς ἤματι κείνῳ{l]
[l [n}2.483{]}ἐκπρεπέʼ ἐν πολλοῖσι καὶ ἔξοχον ἡρώεσσιν.{l]{para]
[para}[l [n}2.484{]}ἔσπετε νῦν μοι Μοῦσαι Ὀλύμπια δώματʼ ἔχουσαι·{l]
[l [n}2.485{]}ὑμεῖς γὰρ θεαί ἐστε πάρεστέ τε ἴστέ τε πάντα,{l]
[l [n}2.486{]}ἡμεῖς δὲ κλέος οἶον ἀκούομεν οὐδέ τι ἴδμεν·{l]
[l [n}2.487{]}οἵ τινες ἡγεμόνες Δαναῶν καὶ κοίρανοι ἦσαν·{l]
[l [n}2.488{]}πληθὺν δʼ οὐκ ἂν ἐγὼ μυθήσομαι οὐδʼ ὀνομήνω,{l]
[l [n}2.489{]}οὐδʼ εἴ μοι δέκα μὲν γλῶσσαι, δέκα δὲ στόματʼ εἶεν,{l]
[l [n}2.490{]}φωνὴ δʼ ἄρρηκτος, χάλκεον δέ μοι ἦτορ ἐνείη,{l]
[l [n}2.491{]}εἰ μὴ Ὀλυμπιάδες Μοῦσαι Διὸς αἰγιόχοιο{l]
[l [n}2.492{]}θυγατέρες μνησαίαθʼ ὅσοι ὑπὸ Ἴλιον ἦλθον·{l]
[l [n}2.493{]}ἀρχοὺς αὖ νηῶν ἐρέω νῆάς τε προπάσας.{l]{para]
[para}[l [n}2.494{]}Βοιωτῶν μὲν Πηνέλεως καὶ Λήϊτος ἦρχον{l]
[l [n}2.495{]}Ἀρκεσίλαός τε Προθοήνωρ τε Κλονίος τε,{l]
[l [n}2.496{]}οἵ θʼ Ὑρίην ἐνέμοντο καὶ Αὐλίδα πετρήεσσαν{l]
[l [n}2.497{]}Σχοῖνόν τε Σκῶλόν τε πολύκνημόν τʼ Ἐτεωνόν,{l]
[l [n}2.498{]}Θέσπειαν Γραῖάν τε καὶ εὐρύχορον Μυκαλησσόν,{l]
[l [n}2.499{]}οἵ τʼ ἀμφʼ Ἅρμʼ ἐνέμοντο καὶ Εἰλέσιον καὶ Ἐρυθράς,{l]
[l [n}2.500{]}οἵ τʼ Ἐλεῶνʼ εἶχον ἠδʼ Ὕλην καὶ Πετεῶνα,{l]
[l [n}2.501{]}Ὠκαλέην Μεδεῶνά τʼ ἐϋκτίμενον πτολίεθρον,{l]
[l [n}2.502{]}Κώπας Εὔτρησίν τε πολυτρήρωνά τε Θίσβην,{l]
[l [n}2.503{]}οἵ τε Κορώνειαν καὶ ποιήενθʼ Ἁλίαρτον,{l]
[l [n}2.504{]}οἵ τε Πλάταιαν ἔχον ἠδʼ οἳ Γλισᾶντʼ ἐνέμοντο,{l]
[l [n}2.505{]}οἵ θʼ Ὑποθήβας εἶχον ἐϋκτίμενον πτολίεθρον,{l]
[l [n}2.506{]}Ὀγχηστόν θʼ ἱερὸν Ποσιδήϊον ἀγλαὸν ἄλσος,{l]
[l [n}2.507{]}οἵ τε πολυστάφυλον Ἄρνην ἔχον, οἵ τε Μίδειαν{l]
[l [n}2.508{]}Νῖσάν τε ζαθέην Ἀνθηδόνα τʼ ἐσχατόωσαν·{l]
[l [n}2.509{]}τῶν μὲν πεντήκοντα νέες κίον, ἐν δὲ ἑκάστῃ{l]
[l [n}2.510{]}κοῦροι Βοιωτῶν ἑκατὸν καὶ εἴκοσι βαῖνον.{l]{para]
[para}[l [n}2.511{]}οἳ δʼ Ἀσπληδόνα ναῖον ἰδʼ Ὀρχομενὸν Μινύειον,{l]
[l [n}2.512{]}τῶν ἦρχʼ Ἀσκάλαφος καὶ Ἰάλμενος υἷες Ἄρηος{l]
[l [n}2.513{]}οὓς τέκεν Ἀστυόχη δόμῳ Ἄκτορος Ἀζεΐδαο,{l]
[l [n}2.514{]}παρθένος αἰδοίη ὑπερώϊον εἰσαναβᾶσα{l]
[l [n}2.515{]}Ἄρηϊ κρατερῷ· ὃ δέ οἱ παρελέξατο λάθρῃ·{l]
[l [n}2.516{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.517{]}αὐτὰρ Φωκήων Σχεδίος καὶ Ἐπίστροφος ἦρχον{l]
[l [n}2.518{]}υἷες Ἰφίτου μεγαθύμου Ναυβολίδαο,{l]
[l [n}2.519{]}οἳ Κυπάρισσον ἔχον Πυθῶνά τε πετρήεσσαν{l]
[l [n}2.520{]}Κρῖσάν τε ζαθέην καὶ Δαυλίδα καὶ Πανοπῆα,{l]
[l [n}2.521{]}οἵ τʼ Ἀνεμώρειαν καὶ Ὑάμπολιν ἀμφενέμοντο,{l]
[l [n}2.522{]}οἵ τʼ ἄρα πὰρ ποταμὸν Κηφισὸν δῖον ἔναιον,{l]
[l [n}2.523{]}οἵ τε Λίλαιαν ἔχον πηγῇς ἔπι Κηφισοῖο·{l]
[l [n}2.524{]}τοῖς δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]
[l [n}2.525{]}οἳ μὲν Φωκήων στίχας ἵστασαν ἀμφιέποντες,{l]
[l [n}2.526{]}Βοιωτῶν δʼ ἔμπλην ἐπʼ ἀριστερὰ θωρήσσοντο.{l]{para]
[para}[l [n}2.527{]}Λοκρῶν δʼ ἡγεμόνευεν Ὀϊλῆος ταχὺς Αἴας{l]
[l [n}2.528{]}μείων, οὔ τι τόσος γε ὅσος Τελαμώνιος Αἴας{l]
[l [n}2.529{]}ἀλλὰ πολὺ μείων· ὀλίγος μὲν ἔην λινοθώρηξ,{l]
[l [n}2.530{]}ἐγχείῃ δʼ ἐκέκαστο Πανέλληνας καὶ Ἀχαιούς·{l]
[l [n}2.531{]}οἳ Κῦνόν τʼ ἐνέμοντʼ Ὀπόεντά τε Καλλίαρόν τε{l]
[l [n}2.532{]}Βῆσσάν τε Σκάρφην τε καὶ Αὐγειὰς ἐρατεινὰς{l]
[l [n}2.533{]}Τάρφην τε Θρόνιον τε Βοαγρίου ἀμφὶ ῥέεθρα·{l]
[l [n}2.534{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο{l]
[l [n}2.535{]}Λοκρῶν, οἳ ναίουσι πέρην ἱερῆς Εὐβοίης.{l]{para]
[para}[l [n}2.536{]}οἳ δʼ Εὔβοιαν ἔχον μένεα πνείοντες Ἄβαντες{l]
[l [n}2.537{]}Χαλκίδα τʼ Εἰρέτριάν τε πολυστάφυλόν θʼ Ἱστίαιαν{l]
[l [n}2.538{]}Κήρινθόν τʼ ἔφαλον Δίου τʼ αἰπὺ πτολίεθρον,{l]
[l [n}2.539{]}οἵ τε Κάρυστον ἔχον ἠδʼ οἳ Στύρα ναιετάασκον,{l]
[l [n}2.540{]}τῶν αὖθʼ ἡγεμόνευʼ Ἐλεφήνωρ ὄζος Ἄρηος{l]
[l [n}2.541{]}Χαλκωδοντιάδης μεγαθύμων ἀρχὸς Ἀβάντων.{l]
[l [n}2.542{]}τῷ δʼ ἅμʼ Ἄβαντες ἕποντο θοοὶ ὄπιθεν κομόωντες{l]
[l [n}2.543{]}αἰχμηταὶ μεμαῶτες ὀρεκτῇσιν μελίῃσι{l]
[l [n}2.544{]}θώρηκας ῥήξειν δηΐων ἀμφὶ στήθεσσι·{l]
[l [n}2.545{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.546{]}οἳ δʼ ἄρʼ Ἀθήνας εἶχον ἐϋκτίμενον πτολίεθρον{l]
[l [n}2.547{]}δῆμον Ἐρεχθῆος μεγαλήτορος, ὅν ποτʼ Ἀθήνη{l]
[l [n}2.548{]}θρέψε Διὸς θυγάτηρ, τέκε δὲ ζείδωρος ἄρουρα,{l]
[l [n}2.549{]}κὰδ δʼ ἐν Ἀθήνῃς εἷσεν ἑῷ ἐν πίονι νηῷ·{l]
[l [n}2.550{]}ἔνθα δέ μιν ταύροισι καὶ ἀρνειοῖς ἱλάονται{l]
[l [n}2.551{]}κοῦροι Ἀθηναίων περιτελλομένων ἐνιαυτῶν·{l]
[l [n}2.552{]}τῶν αὖθʼ ἡγεμόνευʼ υἱὸς Πετεῶο Μενεσθεύς.{l]
[l [n}2.553{]}τῷ δʼ οὔ πώ τις ὁμοῖος ἐπιχθόνιος γένετʼ ἀνὴρ{l]
[l [n}2.554{]}κοσμῆσαι ἵππους τε καὶ ἀνέρας ἀσπιδιώτας·{l]
[l [n}2.555{]}Νέστωρ οἶος ἔριζεν· ὃ γὰρ προγενέστερος ἦεν·{l]
[l [n}2.556{]}τῷ δʼ ἅμα πεντήκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.557{]}Αἴας δʼ ἐκ Σαλαμῖνος ἄγεν δυοκαίδεκα νῆας,{l]
[l [n}2.558{]}στῆσε δʼ ἄγων ἵνʼ Ἀθηναίων ἵσταντο φάλαγγες.{l]{para]
[para}[l [n}2.559{]}οἳ δʼ Ἄργός τʼ εἶχον Τίρυνθά τε τειχιόεσσαν{l]
[l [n}2.560{]}Ἑρμιόνην Ἀσίνην τε, βαθὺν κατὰ κόλπον ἐχούσας,{l]
[l [n}2.561{]}Τροιζῆνʼ Ἠϊόνας τε καὶ ἀμπελόεντʼ Ἐπίδαυρον,{l]
[l [n}2.562{]}οἵ τʼ ἔχον Αἴγιναν Μάσητά τε κοῦροι Ἀχαιῶν,{l]
[l [n}2.563{]}τῶν αὖθʼ ἡγεμόνευε βοὴν ἀγαθὸς Διομήδης{l]
[l [n}2.564{]}καὶ Σθένελος, Καπανῆος ἀγακλειτοῦ φίλος υἱός·{l]
[l [n}2.565{]}τοῖσι δʼ ἅμʼ Εὐρύαλος τρίτατος κίεν ἰσόθεος φὼς{l]
[l [n}2.566{]}Μηκιστέος υἱὸς Ταλαϊονίδαο ἄνακτος·{l]
[l [n}2.567{]}συμπάντων δʼ ἡγεῖτο βοὴν ἀγαθὸς Διομήδης·{l]
[l [n}2.568{]}τοῖσι δʼ ἅμʼ ὀγδώκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.569{]}οἳ δὲ Μυκήνας εἶχον ἐϋκτίμενον πτολίεθρον{l]
[l [n}2.570{]}ἀφνειόν τε Κόρινθον ἐϋκτιμένας τε Κλεωνάς,{l]
[l [n}2.571{]}Ὀρνειάς τʼ ἐνέμοντο Ἀραιθυρέην τʼ ἐρατεινὴν{l]
[l [n}2.572{]}καὶ Σικυῶνʼ, ὅθʼ ἄρʼ Ἄδρηστος πρῶτʼ ἐμβασίλευεν,{l]
[l [n}2.573{]}οἵ θʼ Ὑπερησίην τε καὶ αἰπεινὴν Γονόεσσαν{l]
[l [n}2.574{]}Πελλήνην τʼ εἶχον ἠδʼ Αἴγιον ἀμφενέμοντο{l]
[l [n}2.575{]}Αἰγιαλόν τʼ ἀνὰ πάντα καὶ ἀμφʼ Ἑλίκην εὐρεῖαν,{l]
[l [n}2.576{]}τῶν ἑκατὸν νηῶν ἦρχε κρείων Ἀγαμέμνων{l]
[l [n}2.577{]}Ἀτρεΐδης· ἅμα τῷ γε πολὺ πλεῖστοι καὶ ἄριστοι{l]
[l [n}2.578{]}λαοὶ ἕποντʼ· ἐν δʼ αὐτὸς ἐδύσετο νώροπα χαλκὸν{l]
[l [n}2.579{]}κυδιόων, πᾶσιν δὲ μετέπρεπεν ἡρώεσσιν{l]
[l [n}2.580{]}οὕνεκʼ ἄριστος ἔην πολὺ δὲ πλείστους ἄγε λαούς.{l]{para]
[para}[l [n}2.581{]}οἳ δʼ εἶχον κοίλην Λακεδαίμονα κητώεσσαν,{l]
[l [n}2.582{]}Φᾶρίν τε Σπάρτην τε πολυτρήρωνά τε Μέσσην,{l]
[l [n}2.583{]}Βρυσειάς τʼ ἐνέμοντο καὶ Αὐγειὰς ἐρατεινάς,{l]
[l [n}2.584{]}οἵ τʼ ἄρʼ Ἀμύκλας εἶχον Ἕλος τʼ ἔφαλον πτολίεθρον,{l]
[l [n}2.585{]}οἵ τε Λάαν εἶχον ἠδʼ Οἴτυλον ἀμφενέμοντο,{l]
[l [n}2.586{]}τῶν οἱ ἀδελφεὸς ἦρχε βοὴν ἀγαθὸς Μενέλαος{l]
[l [n}2.587{]}ἑξήκοντα νεῶν· ἀπάτερθε δὲ θωρήσσοντο·{l]
[l [n}2.588{]}ἐν δʼ αὐτὸς κίεν ᾗσι προθυμίῃσι πεποιθὼς{l]
[l [n}2.589{]}ὀτρύνων πόλεμον δέ· μάλιστα δὲ ἵετο θυμῷ{l]
[l [n}2.590{]}τίσασθαι Ἑλένης ὁρμήματά τε στοναχάς τε.{l]{para]
[para}[l [n}2.591{]}οἳ δὲ Πύλον τʼ ἐνέμοντο καὶ Ἀρήνην ἐρατεινὴν{l]
[l [n}2.592{]}καὶ Θρύον Ἀλφειοῖο πόρον καὶ ἐΰκτιτον Αἰπὺ{l]
[l [n}2.593{]}καὶ Κυπαρισσήεντα καὶ Ἀμφιγένειαν ἔναιον{l]
[l [n}2.594{]}καὶ Πτελεὸν καὶ Ἕλος καὶ Δώριον, ἔνθά τε Μοῦσαι{l]
[l [n}2.595{]}ἀντόμεναι Θάμυριν τὸν Θρήϊκα παῦσαν ἀοιδῆς{l]
[l [n}2.596{]}Οἰχαλίηθεν ἰόντα παρʼ Εὐρύτου Οἰχαλιῆος·{l]
[l [n}2.597{]}στεῦτο γὰρ εὐχόμενος νικησέμεν εἴ περ ἂν αὐταὶ{l]
[l [n}2.598{]}Μοῦσαι ἀείδοιεν κοῦραι Διὸς αἰγιόχοιο·{l]
[l [n}2.599{]}αἳ δὲ χολωσάμεναι πηρὸν θέσαν, αὐτὰρ ἀοιδὴν{l]
[l [n}2.600{]}θεσπεσίην ἀφέλοντο καὶ ἐκλέλαθον κιθαριστύν·{l]
[l [n}2.601{]}τῶν αὖθʼ ἡγεμόνευε Γερήνιος ἱππότα Νέστωρ·{l]
[l [n}2.602{]}τῷ δʼ ἐνενήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.603{]}οἳ δʼ ἔχον Ἀρκαδίην ὑπὸ Κυλλήνης ὄρος αἰπὺ{l]
[l [n}2.604{]}Αἰπύτιον παρὰ τύμβον ἵνʼ ἀνέρες ἀγχιμαχηταί,{l]
[l [n}2.605{]}οἳ Φενεόν τʼ ἐνέμοντο καὶ Ὀρχομενὸν πολύμηλον{l]
[l [n}2.606{]}Ῥίπην τε Στρατίην τε καὶ ἠνεμόεσσαν Ἐνίσπην{l]
[l [n}2.607{]}καὶ Τεγέην εἶχον καὶ Μαντινέην ἐρατεινὴν{l]
[l [n}2.608{]}Στύμφηλόν τʼ εἶχον καὶ Παρρασίην ἐνέμοντο,{l]
[l [n}2.609{]}τῶν ἦρχʼ Ἀγκαίοιο πάϊς κρείων Ἀγαπήνωρ{l]
[l [n}2.610{]}ἑξήκοντα νεῶν· πολέες δʼ ἐν νηῒ ἑκάστῃ{l]
[l [n}2.611{]}Ἀρκάδες ἄνδρες ἔβαινον ἐπιστάμενοι πολεμίζειν.{l]
[l [n}2.612{]}αὐτὸς γάρ σφιν δῶκεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}2.613{]}νῆας ἐϋσσέλμους περάαν ἐπὶ οἴνοπα πόντον{l]
[l [n}2.614{]}Ἀτρεΐδης, ἐπεὶ οὔ σφι θαλάσσια ἔργα μεμήλει.{l]{para]
[para}[l [n}2.615{]}οἳ δʼ ἄρα Βουπράσιόν τε καὶ Ἤλιδα δῖαν ἔναιον{l]
[l [n}2.616{]}ὅσσον ἐφʼ Ὑρμίνη καὶ Μύρσινος ἐσχατόωσα{l]
[l [n}2.617{]}πέτρη τʼ Ὠλενίη καὶ Ἀλήσιον ἐντὸς ἐέργει,{l]
[l [n}2.618{]}τῶν αὖ τέσσαρες ἀρχοὶ ἔσαν, δέκα δʼ ἀνδρὶ ἑκάστῳ{l]
[l [n}2.619{]}νῆες ἕποντο θοαί, πολέες δʼ ἔμβαινον Ἐπειοί.{l]
[l [n}2.620{]}τῶν μὲν ἄρʼ Ἀμφίμαχος καὶ Θάλπιος ἡγησάσθην{l]
[l [n}2.621{]}υἷες ὃ μὲν Κτεάτου, ὃ δʼ ἄρʼ Εὐρύτου, Ἀκτορίωνε·{l]
[l [n}2.622{]}τῶν δʼ Ἀμαρυγκεΐδης ἦρχε κρατερὸς Διώρης·{l]
[l [n}2.623{]}τῶν δὲ τετάρτων ἦρχε Πολύξεινος θεοειδὴς{l]
[l [n}2.624{]}υἱὸς Ἀγασθένεος Αὐγηϊάδαο ἄνακτος.{l]{para]
[para}[l [n}2.625{]}οἳ δʼ ἐκ Δουλιχίοιο Ἐχινάων θʼ ἱεράων{l]
[l [n}2.626{]}νήσων, αἳ ναίουσι πέρην ἁλὸς Ἤλιδος ἄντα,{l]
[l [n}2.627{]}τῶν αὖθʼ ἡγεμόνευε Μέγης ἀτάλαντος Ἄρηϊ{l]
[l [n}2.628{]}Φυλεΐδης, ὃν τίκτε Διῒ φίλος ἱππότα Φυλεύς,{l]
[l [n}2.629{]}ὅς ποτε Δουλίχιον δʼ ἀπενάσσατο πατρὶ χολωθείς·{l]
[l [n}2.630{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.631{]}αὐτὰρ Ὀδυσσεὺς ἦγε Κεφαλλῆνας μεγαθύμους,{l]
[l [n}2.632{]}οἵ ῥʼ Ἰθάκην εἶχον καὶ Νήριτον εἰνοσίφυλλον{l]
[l [n}2.633{]}καὶ Κροκύλειʼ ἐνέμοντο καὶ Αἰγίλιπα τρηχεῖαν,{l]
[l [n}2.634{]}οἵ τε Ζάκυνθον ἔχον ἠδʼ οἳ Σάμον ἀμφενέμοντο,{l]
[l [n}2.635{]}οἵ τʼ ἤπειρον ἔχον ἠδʼ ἀντιπέραιʼ ἐνέμοντο·{l]
[l [n}2.636{]}τῶν μὲν Ὀδυσσεὺς ἦρχε Διὶ μῆτιν ἀτάλαντος·{l]
[l [n}2.637{]}τῷ δʼ ἅμα νῆες ἕποντο δυώδεκα μιλτοπάρῃοι.{l]{para]
[para}[l [n}2.638{]}Αἰτωλῶν δʼ ἡγεῖτο Θόας Ἀνδραίμονος υἱός,{l]
[l [n}2.639{]}οἳ Πλευρῶνʼ ἐνέμοντο καὶ Ὤλενον ἠδὲ Πυλήνην{l]
[l [n}2.640{]}Χαλκίδα τʼ ἀγχίαλον Καλυδῶνά τε πετρήεσσαν·{l]
[l [n}2.641{]}οὐ γὰρ ἔτʼ Οἰνῆος μεγαλήτορος υἱέες ἦσαν,{l]
[l [n}2.642{]}οὐδʼ ἄρʼ ἔτʼ αὐτὸς ἔην, θάνε δὲ ξανθὸς Μελέαγρος·{l]
[l [n}2.643{]}τῷ δʼ ἐπὶ πάντʼ ἐτέταλτο ἀνασσέμεν Αἰτωλοῖσι·{l]
[l [n}2.644{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.645{]}Κρητῶν δʼ Ἰδομενεὺς δουρὶ κλυτὸς ἡγεμόνευεν,{l]
[l [n}2.646{]}οἳ Κνωσόν τʼ εἶχον Γόρτυνά τε τειχιόεσσαν,{l]
[l [n}2.647{]}Λύκτον Μίλητόν τε καὶ ἀργινόεντα Λύκαστον{l]
[l [n}2.648{]}Φαιστόν τε Ῥύτιόν τε, πόλεις εὖ ναιετοώσας,{l]
[l [n}2.649{]}ἄλλοι θʼ οἳ Κρήτην ἑκατόμπολιν ἀμφενέμοντο.{l]
[l [n}2.650{]}τῶν μὲν ἄρʼ Ἰδομενεὺς δουρὶ κλυτὸς ἡγεμόνευε{l]
[l [n}2.651{]}Μηριόνης τʼ ἀτάλαντος Ἐνυαλίῳ ἀνδρειφόντῃ·{l]
[l [n}2.652{]}τοῖσι δʼ ἅμʼ ὀγδώκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.653{]}Τληπόλεμος δʼ Ἡρακλεΐδης ἠΰς τε μέγας τε{l]
[l [n}2.654{]}ἐκ Ῥόδου ἐννέα νῆας ἄγεν Ῥοδίων ἀγερώχων,{l]
[l [n}2.655{]}οἳ Ῥόδον ἀμφενέμοντο διὰ τρίχα κοσμηθέντες{l]
[l [n}2.656{]}Λίνδον Ἰηλυσόν τε καὶ ἀργινόεντα Κάμειρον.{l]
[l [n}2.657{]}τῶν μὲν Τληπόλεμος δουρὶ κλυτὸς ἡγεμόνευεν,{l]
[l [n}2.658{]}ὃν τέκεν Ἀστυόχεια βίῃ Ἡρακληείῃ,{l]
[l [n}2.659{]}τὴν ἄγετʼ ἐξ Ἐφύρης ποταμοῦ ἄπο Σελλήεντος{l]
[l [n}2.660{]}πέρσας ἄστεα πολλὰ διοτρεφέων αἰζηῶν.{l]
[l [n}2.661{]}Τληπόλεμος δʼ ἐπεὶ οὖν τράφʼ ἐνὶ μεγάρῳ εὐπήκτῳ,{l]
[l [n}2.662{]}αὐτίκα πατρὸς ἑοῖο φίλον μήτρωα κατέκτα{l]
[l [n}2.663{]}ἤδη γηράσκοντα Λικύμνιον ὄζον Ἄρηος·{l]
[l [n}2.664{]}αἶψα δὲ νῆας ἔπηξε, πολὺν δʼ ὅ γε λαὸν ἀγείρας{l]
[l [n}2.665{]}βῆ φεύγων ἐπὶ πόντον· ἀπείλησαν γάρ οἱ ἄλλοι{l]
[l [n}2.666{]}υἱέες υἱωνοί τε βίης Ἡρακληείης.{l]
[l [n}2.667{]}αὐτὰρ ὅ γʼ ἐς Ῥόδον ἷξεν ἀλώμενος ἄλγεα πάσχων·{l]
[l [n}2.668{]}τριχθὰ δὲ ᾤκηθεν καταφυλαδόν, ἠδὲ φίληθεν{l]
[l [n}2.669{]}ἐκ Διός, ὅς τε θεοῖσι καὶ ἀνθρώποισιν ἀνάσσει,{l]
[l [n}2.670{]}καί σφιν θεσπέσιον πλοῦτον κατέχευε Κρονίων.{l]{para]
[para}[l [n}2.671{]}Νιρεὺς αὖ Σύμηθεν ἄγε τρεῖς νῆας ἐΐσας{l]
[l [n}2.672{]}Νιρεὺς Ἀγλαΐης υἱὸς Χαρόποιό τʼ ἄνακτος{l]
[l [n}2.673{]}Νιρεύς, ὃς κάλλιστος ἀνὴρ ὑπὸ Ἴλιον ἦλθε{l]
[l [n}2.674{]}τῶν ἄλλων Δαναῶν μετʼ ἀμύμονα Πηλεΐωνα·{l]
[l [n}2.675{]}ἀλλʼ ἀλαπαδνὸς ἔην, παῦρος δέ οἱ εἵπετο λαός.{l]{para]
[para}[l [n}2.676{]}οἳ δʼ ἄρα Νίσυρόν τʼ εἶχον Κράπαθόν τε Κάσον τε{l]
[l [n}2.677{]}καὶ Κῶν Εὐρυπύλοιο πόλιν νήσους τε Καλύδνας,{l]
[l [n}2.678{]}τῶν αὖ Φείδιππός τε καὶ Ἄντιφος ἡγησάσθην{l]
[l [n}2.679{]}Θεσσαλοῦ υἷε δύω Ἡρακλεΐδαο ἄνακτος·{l]
[l [n}2.680{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.681{]}νῦν αὖ τοὺς ὅσσοι τὸ Πελασγικὸν Ἄργος ἔναιον,{l]
[l [n}2.682{]}οἵ τʼ Ἄλον οἵ τʼ Ἀλόπην οἵ τε Τρηχῖνα νέμοντο,{l]
[l [n}2.683{]}οἵ τʼ εἶχον Φθίην ἠδʼ Ἑλλάδα καλλιγύναικα,{l]
[l [n}2.684{]}Μυρμιδόνες δὲ καλεῦντο καὶ Ἕλληνες καὶ Ἀχαιοί,{l]
[l [n}2.685{]}τῶν αὖ πεντήκοντα νεῶν ἦν ἀρχὸς Ἀχιλλεύς.{l]
[l [n}2.686{]}ἀλλʼ οἵ γʼ οὐ πολέμοιο δυσηχέος ἐμνώοντο·{l]
[l [n}2.687{]}οὐ γὰρ ἔην ὅς τίς σφιν ἐπὶ στίχας ἡγήσαιτο·{l]
[l [n}2.688{]}κεῖτο γὰρ ἐν νήεσσι ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}2.689{]}κούρης χωόμενος Βρισηΐδος ἠϋκόμοιο,{l]
[l [n}2.690{]}τὴν ἐκ Λυρνησσοῦ ἐξείλετο πολλὰ μογήσας{l]
[l [n}2.691{]}Λυρνησσὸν διαπορθήσας καὶ τείχεα Θήβης,{l]
[l [n}2.692{]}κὰδ δὲ Μύνητʼ ἔβαλεν καὶ Ἐπίστροφον ἐγχεσιμώρους,{l]
[l [n}2.693{]}υἱέας Εὐηνοῖο Σεληπιάδαο ἄνακτος·{l]
[l [n}2.694{]}τῆς ὅ γε κεῖτʼ ἀχέων, τάχα δʼ ἀνστήσεσθαι ἔμελλεν.{l]{para]
[para}[l [n}2.695{]}οἳ δʼ εἶχον Φυλάκην καὶ Πύρασον ἀνθεμόεντα{l]
[l [n}2.696{]}Δήμητρος τέμενος, Ἴτωνά τε μητέρα μήλων,{l]
[l [n}2.697{]}ἀγχίαλόν τʼ Ἀντρῶνα ἰδὲ Πτελεὸν λεχεποίην,{l]
[l [n}2.698{]}τῶν αὖ Πρωτεσίλαος ἀρήϊος ἡγεμόνευε{l]
[l [n}2.699{]}ζωὸς ἐών· τότε δʼ ἤδη ἔχεν κάτα γαῖα μέλαινα.{l]
[l [n}2.700{]}τοῦ δὲ καὶ ἀμφιδρυφὴς ἄλοχος Φυλάκῃ ἐλέλειπτο{l]
[l [n}2.701{]}καὶ δόμος ἡμιτελής· τὸν δʼ ἔκτανε Δάρδανος ἀνὴρ{l]
[l [n}2.702{]}νηὸς ἀποθρῴσκοντα πολὺ πρώτιστον Ἀχαιῶν.{l]
[l [n}2.703{]}οὐδὲ μὲν οὐδʼ οἳ ἄναρχοι ἔσαν, πόθεόν γε μὲν ἀρχόν·{l]
[l [n}2.704{]}ἀλλά σφεας κόσμησε Ποδάρκης ὄζος Ἄρηος{l]
[l [n}2.705{]}Ἰφίκλου υἱὸς πολυμήλου Φυλακίδαο{l]
[l [n}2.706{]}αὐτοκασίγνητος μεγαθύμου Πρωτεσιλάου{l]
[l [n}2.707{]}ὁπλότερος γενεῇ· ὁ δʼ ἅμα πρότερος καὶ ἀρείων{l]
[l [n}2.708{]}ἥρως Πρωτεσίλαος ἀρήϊος· οὐδέ τι λαοὶ{l]
[l [n}2.709{]}δεύονθʼ ἡγεμόνος, πόθεόν γε μὲν ἐσθλὸν ἐόντα·{l]
[l [n}2.710{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.711{]}οἳ δὲ Φερὰς ἐνέμοντο παραὶ Βοιβηΐδα λίμνην{l]
[l [n}2.712{]}Βοίβην καὶ Γλαφύρας καὶ ἐϋκτιμένην Ἰαωλκόν,{l]
[l [n}2.713{]}τῶν ἦρχʼ Ἀδμήτοιο φίλος πάϊς ἕνδεκα νηῶν{l]
[l [n}2.714{]}Εὔμηλος, τὸν ὑπʼ Ἀδμήτῳ τέκε δῖα γυναικῶν{l]
[l [n}2.715{]}Ἄλκηστις Πελίαο θυγατρῶν εἶδος ἀρίστη.{l]{para]
[para}[l [n}2.716{]}οἳ δʼ ἄρα Μηθώνην καὶ Θαυμακίην ἐνέμοντο{l]
[l [n}2.717{]}καὶ Μελίβοιαν ἔχον καὶ Ὀλιζῶνα τρηχεῖαν,{l]
[l [n}2.718{]}τῶν δὲ Φιλοκτήτης ἦρχεν τόξων ἐῢ εἰδὼς{l]
[l [n}2.719{]}ἑπτὰ νεῶν· ἐρέται δʼ ἐν ἑκάστῃ πεντήκοντα{l]
[l [n}2.720{]}ἐμβέβασαν τόξων εὖ εἰδότες ἶφι μάχεσθαι.{l]
[l [n}2.721{]}ἀλλʼ ὃ μὲν ἐν νήσῳ κεῖτο κρατέρʼ ἄλγεα πάσχων{l]
[l [n}2.722{]}Λήμνῳ ἐν ἠγαθέῃ, ὅθι μιν λίπον υἷες Ἀχαιῶν{l]
[l [n}2.723{]}ἕλκεϊ μοχθίζοντα κακῷ ὀλοόφρονος ὕδρου·{l]
[l [n}2.724{]}ἔνθʼ ὅ γε κεῖτʼ ἀχέων· τάχα δὲ μνήσεσθαι ἔμελλον{l]
[l [n}2.725{]}Ἀργεῖοι παρὰ νηυσὶ Φιλοκτήταο ἄνακτος.{l]
[l [n}2.726{]}οὐδὲ μὲν οὐδʼ οἳ ἄναρχοι ἔσαν, πόθεόν γε μὲν ἀρχόν·{l]
[l [n}2.727{]}ἀλλὰ Μέδων κόσμησεν Ὀϊλῆος νόθος υἱός,{l]
[l [n}2.728{]}τόν ῥʼ ἔτεκεν Ῥήνη ὑπʼ Ὀϊλῆϊ πτολιπόρθῳ.{l]{para]
[para}[l [n}2.729{]}οἳ δʼ εἶχον Τρίκκην καὶ Ἰθώμην κλωμακόεσσαν,{l]
[l [n}2.730{]}οἵ τʼ ἔχον Οἰχαλίην πόλιν Εὐρύτου Οἰχαλιῆος,{l]
[l [n}2.731{]}τῶν αὖθʼ ἡγείσθην Ἀσκληπιοῦ δύο παῖδε{l]
[l [n}2.732{]}ἰητῆρʼ ἀγαθὼ Ποδαλείριος ἠδὲ Μαχάων·{l]
[l [n}2.733{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.734{]}οἳ δʼ ἔχον Ὀρμένιον, οἵ τε κρήνην Ὑπέρειαν,{l]
[l [n}2.735{]}οἵ τʼ ἔχον Ἀστέριον Τιτάνοιό τε λευκὰ κάρηνα,{l]
[l [n}2.736{]}τῶν ἦρχʼ Εὐρύπυλος Εὐαίμονος ἀγλαὸς υἱός·{l]
[l [n}2.737{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.738{]}οἳ δʼ Ἄργισσαν ἔχον καὶ Γυρτώνην ἐνέμοντο,{l]
[l [n}2.739{]}Ὄρθην Ἠλώνην τε πόλιν τʼ Ὀλοοσσόνα λευκήν,{l]
[l [n}2.740{]}τῶν αὖθʼ ἡγεμόνευε μενεπτόλεμος Πολυποίτης{l]
[l [n}2.741{]}υἱὸς Πειριθόοιο τὸν ἀθάνατος τέκετο Ζεύς·{l]
[l [n}2.742{]}τόν ῥʼ ὑπὸ Πειριθόῳ τέκετο κλυτὸς Ἱπποδάμεια{l]
[l [n}2.743{]}ἤματι τῷ ὅτε Φῆρας ἐτίσατο λαχνήεντας,{l]
[l [n}2.744{]}τοὺς δʼ ἐκ Πηλίου ὦσε καὶ Αἰθίκεσσι πέλασσεν·{l]
[l [n}2.745{]}οὐκ οἶος, ἅμα τῷ γε Λεοντεὺς ὄζος Ἄρηος{l]
[l [n}2.746{]}υἱὸς ὑπερθύμοιο Κορώνου Καινεΐδαο·{l]
[l [n}2.747{]}τοῖς δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.748{]}Γουνεὺς δʼ ἐκ Κύφου ἦγε δύω καὶ εἴκοσι νῆας·{l]
[l [n}2.749{]}τῷ δʼ Ἐνιῆνες ἕποντο μενεπτόλεμοί τε Περαιβοὶ{l]
[l [n}2.750{]}οἳ περὶ Δωδώνην δυσχείμερον οἰκίʼ ἔθεντο,{l]
[l [n}2.751{]}οἵ τʼ ἀμφʼ ἱμερτὸν Τιταρησσὸν ἔργα νέμοντο{l]
[l [n}2.752{]}ὅς ῥʼ ἐς Πηνειὸν προΐει καλλίρροον ὕδωρ,{l]
[l [n}2.753{]}οὐδʼ ὅ γε Πηνειῷ συμμίσγεται ἀργυροδίνῃ,{l]
[l [n}2.754{]}ἀλλά τέ μιν καθύπερθεν ἐπιρρέει ἠΰτʼ ἔλαιον·{l]
[l [n}2.755{]}ὅρκου γὰρ δεινοῦ Στυγὸς ὕδατός ἐστιν ἀπορρώξ.{l]{para]
[para}[l [n}2.756{]}Μαγνήτων δʼ ἦρχε Πρόθοος Τενθρηδόνος υἱός,{l]
[l [n}2.757{]}οἳ περὶ Πηνειὸν καὶ Πήλιον εἰνοσίφυλλον{l]
[l [n}2.758{]}ναίεσκον· τῶν μὲν Πρόθοος θοὸς ἡγεμόνευε,{l]
[l [n}2.759{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.760{]}οὗτοι ἄρʼ ἡγεμόνες Δαναῶν καὶ κοίρανοι ἦσαν·{l]
[l [n}2.761{]}τίς τὰρ τῶν ὄχʼ ἄριστος ἔην σύ μοι ἔννεπε Μοῦσα{l]
[l [n}2.762{]}αὐτῶν ἠδʼ ἵππων, οἳ ἅμʼ Ἀτρεΐδῃσιν ἕποντο.{l]{para]
[para}[l [n}2.763{]}ἵπποι μὲν μέγʼ ἄρισται ἔσαν Φηρητιάδαο,{l]
[l [n}2.764{]}τὰς Εὔμηλος ἔλαυνε ποδώκεας ὄρνιθας ὣς{l]
[l [n}2.765{]}ὄτριχας οἰέτεας σταφύλῇ ἐπὶ νῶτον ἐΐσας·{l]
[l [n}2.766{]}τὰς ἐν Πηρείῃ θρέψʼ ἀργυρότοξος Ἀπόλλων{l]
[l [n}2.767{]}ἄμφω θηλείας, φόβον Ἄρηος φορεούσας.{l]
[l [n}2.768{]}ἀνδρῶν αὖ μέγʼ ἄριστος ἔην Τελαμώνιος Αἴας{l]
[l [n}2.769{]}ὄφρʼ Ἀχιλεὺς μήνιεν· ὃ γὰρ πολὺ φέρτατος ἦεν,{l]
[l [n}2.770{]}ἵπποι θʼ οἳ φορέεσκον ἀμύμονα Πηλεΐωνα.{l]
[l [n}2.771{]}ἀλλʼ ὃ μὲν ἐν νήεσσι κορωνίσι ποντοπόροισι{l]
[l [n}2.772{]}κεῖτʼ ἀπομηνίσας Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}2.773{]}Ἀτρεΐδῃ· λαοὶ δὲ παρὰ ῥηγμῖνι θαλάσσης{l]
[l [n}2.774{]}δίσκοισιν τέρποντο καὶ αἰγανέῃσιν ἱέντες{l]
[l [n}2.775{]}τόξοισίν θʼ· ἵπποι δὲ παρʼ ἅρμασιν οἷσιν ἕκαστος{l]
[l [n}2.776{]}λωτὸν ἐρεπτόμενοι ἐλεόθρεπτόν τε σέλινον{l]
[l [n}2.777{]}ἕστασαν· ἅρματα δʼ εὖ πεπυκασμένα κεῖτο ἀνάκτων{l]
[l [n}2.778{]}ἐν κλισίῃς· οἳ δʼ ἀρχὸν ἀρηΐφιλον ποθέοντες{l]
[l [n}2.779{]}φοίτων ἔνθα καὶ ἔνθα κατὰ στρατὸν οὐδὲ μάχοντο.{l]{para]
[para}[l [n}2.780{]}οἳ δʼ ἄρʼ ἴσαν ὡς εἴ τε πυρὶ χθὼν πᾶσα νέμοιτο·{l]
[l [n}2.781{]}γαῖα δʼ ὑπεστενάχιζε Διὶ ὣς τερπικεραύνῳ{l]
[l [n}2.782{]}χωομένῳ ὅτε τʼ ἀμφὶ Τυφωέϊ γαῖαν ἱμάσσῃ{l]
[l [n}2.783{]}εἰν Ἀρίμοις, ὅθι φασὶ Τυφωέος ἔμμεναι εὐνάς·{l]
[l [n}2.784{]}ὣς ἄρα τῶν ὑπὸ ποσσὶ μέγα στεναχίζετο γαῖα{l]
[l [n}2.785{]}ἐρχομένων· μάλα δʼ ὦκα διέπρησσον πεδίοιο.{l]{para]
[para}[l [n}2.786{]}Τρωσὶν δʼ ἄγγελος ἦλθε ποδήνεμος ὠκέα Ἶρις{l]
[l [n}2.787{]}πὰρ Διὸς αἰγιόχοιο σὺν ἀγγελίῃ ἀλεγεινῇ·{l]
[l [n}2.788{]}οἳ δʼ ἀγορὰς ἀγόρευον ἐπὶ Πριάμοιο θύρῃσι{l]
[l [n}2.789{]}πάντες ὁμηγερέες ἠμὲν νέοι ἠδὲ γέροντες·{l]
[l [n}2.790{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[l [n}2.791{]}εἴσατο δὲ φθογγὴν υἷϊ Πριάμοιο Πολίτῃ,{l]
[l [n}2.792{]}ὃς Τρώων σκοπὸς ἷζε ποδωκείῃσι πεποιθὼς{l]
[l [n}2.793{]}τύμβῳ ἐπʼ ἀκροτάτῳ Αἰσυήταο γέροντος,{l]
[l [n}2.794{]}δέγμενος ὁππότε ναῦφιν ἀφορμηθεῖεν Ἀχαιοί·{l]
[l [n}2.795{]}τῷ μιν ἐεισαμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}2.796{]}ὦ γέρον αἰεί τοι μῦθοι φίλοι ἄκριτοί εἰσιν,{l]
[l [n}2.797{]}ὥς ποτʼ ἐπʼ εἰρήνης· πόλεμος δʼ ἀλίαστος ὄρωρεν.{l]
[l [n}2.798{]}ἤδη μὲν μάλα πολλὰ μάχας εἰσήλυθον ἀνδρῶν,{l]
[l [n}2.799{]}ἀλλʼ οὔ πω τοιόνδε τοσόνδέ τε λαὸν ὄπωπα·{l]
[l [n}2.800{]}λίην γὰρ φύλλοισιν ἐοικότες ἢ ψαμάθοισιν{l]
[l [n}2.801{]}ἔρχονται πεδίοιο μαχησόμενοι προτὶ ἄστυ.{l]
[l [n}2.802{]}Ἕκτορ σοὶ δὲ μάλιστʼ ἐπιτέλλομαι, ὧδε δὲ ῥέξαι·{l]
[l [n}2.803{]}πολλοὶ γὰρ κατὰ ἄστυ μέγα Πριάμου ἐπίκουροι,{l]
[l [n}2.804{]}ἄλλη δʼ ἄλλων γλῶσσα πολυσπερέων ἀνθρώπων·{l]
[l [n}2.805{]}τοῖσιν ἕκαστος ἀνὴρ σημαινέτω οἷσί περ ἄρχει,{l]
[l [n}2.806{]}τῶν δʼ ἐξηγείσθω κοσμησάμενος πολιήτας.{l]{q]{para]
[para}[l [n}2.807{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ οὔ τι θεᾶς ἔπος ἠγνοίησεν,{l]
[l [n}2.808{]}αἶψα δʼ ἔλυσʼ ἀγορήν· ἐπὶ τεύχεα δʼ ἐσσεύοντο·{l]
[l [n}2.809{]}πᾶσαι δʼ ὠΐγνυντο πύλαι, ἐκ δʼ ἔσσυτο λαὸς{l]
[l [n}2.810{]}πεζοί θʼ ἱππῆές τε· πολὺς δʼ ὀρυμαγδὸς ὀρώρει.{l]{para]
[para}[l [n}2.811{]}ἔστι δέ τις προπάροιθε πόλιος αἰπεῖα κολώνη{l]
[l [n}2.812{]}ἐν πεδίῳ ἀπάνευθε περίδρομος ἔνθα καὶ ἔνθα,{l]
[l [n}2.813{]}τὴν ἤτοι ἄνδρες Βατίειαν κικλήσκουσιν,{l]
[l [n}2.814{]}ἀθάνατοι δέ τε σῆμα πολυσκάρθμοιο Μυρίνης·{l]
[l [n}2.815{]}ἔνθα τότε Τρῶές τε διέκριθεν ἠδʼ ἐπίκουροι.{l]{para]
[para}[l [n}2.816{]}Τρωσὶ μὲν ἡγεμόνευε μέγας κορυθαίολος Ἕκτωρ{l]
[l [n}2.817{]}Πριαμίδης· ἅμα τῷ γε πολὺ πλεῖστοι καὶ ἄριστοι{l]
[l [n}2.818{]}λαοὶ θωρήσσοντο μεμαότες ἐγχείῃσι.{l]{para]
[para}[l [n}2.819{]}Δαρδανίων αὖτʼ ἦρχεν ἐῢς πάϊς Ἀγχίσαο{l]
[l [n}2.820{]}Αἰνείας, τὸν ὑπʼ Ἀγχίσῃ τέκε δῖʼ Ἀφροδίτη{l]
[l [n}2.821{]}Ἴδης ἐν κνημοῖσι θεὰ βροτῷ εὐνηθεῖσα,{l]
[l [n}2.822{]}οὐκ οἶος, ἅμα τῷ γε δύω Ἀντήνορος υἷε{l]
[l [n}2.823{]}Ἀρχέλοχός τʼ Ἀκάμας τε μάχης εὖ εἰδότε πάσης.{l]{para]
[para}[l [n}2.824{]}οἳ δὲ Ζέλειαν ἔναιον ὑπαὶ πόδα νείατον Ἴδης{l]
[l [n}2.825{]}ἀφνειοὶ πίνοντες ὕδωρ μέλαν Αἰσήποιο{l]
[l [n}2.826{]}Τρῶες, τῶν αὖτʼ ἦρχε Λυκάονος ἀγλαὸς υἱὸς{l]
[l [n}2.827{]}Πάνδαρος, ᾧ καὶ τόξον Ἀπόλλων αὐτὸς ἔδωκεν.{l]{para]
[para}[l [n}2.828{]}οἳ δʼ Ἀδρήστειάν τʼ εἶχον καὶ δῆμον Ἀπαισοῦ{l]
[l [n}2.829{]}καὶ Πιτύειαν ἔχον καὶ Τηρείης ὄρος αἰπύ,{l]
[l [n}2.830{]}τῶν ἦρχʼ Ἄδρηστός τε καὶ Ἄμφιος λινοθώρηξ{l]
[l [n}2.831{]}υἷε δύω Μέροπος Περκωσίου, ὃς περὶ πάντων{l]
[l [n}2.832{]}ᾔδεε μαντοσύνας, οὐδὲ οὓς παῖδας ἔασκε{l]
[l [n}2.833{]}στείχειν ἐς πόλεμον φθισήνορα· τὼ δέ οἱ οὔ τι{l]
[l [n}2.834{]}πειθέσθην· κῆρες γὰρ ἄγον μέλανος θανάτοιο.{l]{para]
[para}[l [n}2.835{]}οἳ δʼ ἄρα Περκώτην καὶ Πράκτιον ἀμφενέμοντο{l]
[l [n}2.836{]}καὶ Σηστὸν καὶ Ἄβυδον ἔχον καὶ δῖαν Ἀρίσβην,{l]
[l [n}2.837{]}τῶν αὖθʼ Ὑρτακίδης ἦρχʼ Ἄσιος ὄρχαμος ἀνδρῶν,{l]
[l [n}2.838{]}Ἄσιος Ὑρτακίδης ὃν Ἀρίσβηθεν φέρον ἵπποι{l]
[l [n}2.839{]}αἴθωνες μεγάλοι ποταμοῦ ἄπο Σελλήεντος.{l]{para]
[para}[l [n}2.840{]}Ἱππόθοος δʼ ἄγε φῦλα Πελασγῶν ἐγχεσιμώρων{l]
[l [n}2.841{]}τῶν οἳ Λάρισαν ἐριβώλακα ναιετάασκον·{l]
[l [n}2.842{]}τῶν ἦρχʼ Ἱππόθοός τε Πύλαιός τʼ ὄζος Ἄρηος,{l]
[l [n}2.843{]}υἷε δύω Λήθοιο Πελασγοῦ Τευταμίδαο.{l]{para]
[para}[l [n}2.844{]}αὐτὰρ Θρήϊκας ἦγʼ Ἀκάμας καὶ Πείροος ἥρως{l]
[l [n}2.845{]}ὅσσους Ἑλλήσποντος ἀγάρροος ἐντὸς ἐέργει.{l]{para]
[para}[l [n}2.846{]}Εὔφημος δʼ ἀρχὸς Κικόνων ἦν αἰχμητάων{l]
[l [n}2.847{]}υἱὸς Τροιζήνοιο διοτρεφέος Κεάδαο.{l]{para]
[para}[l [n}2.848{]}αὐτὰρ Πυραίχμης ἄγε Παίονας ἀγκυλοτόξους{l]
[l [n}2.849{]}τηλόθεν ἐξ Ἀμυδῶνος ἀπʼ Ἀξιοῦ εὐρὺ ῥέοντος,{l]
[l [n}2.850{]}Ἀξιοῦ οὗ κάλλιστον ὕδωρ ἐπικίδναται αἶαν.{l]{para]
[para}[l [n}2.851{]}Παφλαγόνων δʼ ἡγεῖτο Πυλαιμένεος λάσιον κῆρ{l]
[l [n}2.852{]}ἐξ Ἐνετῶν, ὅθεν ἡμιόνων γένος ἀγροτεράων,{l]
[l [n}2.853{]}οἵ ῥα Κύτωρον ἔχον καὶ Σήσαμον ἀμφενέμοντο{l]
[l [n}2.854{]}ἀμφί τε Παρθένιον ποταμὸν κλυτὰ δώματʼ ἔναιον{l]
[l [n}2.855{]}Κρῶμνάν τʼ Αἰγιαλόν τε καὶ ὑψηλοὺς Ἐρυθίνους.{l]{para]
[para}[l [n}2.856{]}αὐτὰρ Ἁλιζώνων Ὀδίος καὶ Ἐπίστροφος ἦρχον{l]
[l [n}2.857{]}τηλόθεν ἐξ Ἀλύβης, ὅθεν ἀργύρου ἐστὶ γενέθλη.{l]{para]
[para}[l [n}2.858{]}Μυσῶν δὲ Χρόμις ἦρχε καὶ Ἔννομος οἰωνιστής·{l]
[l [n}2.859{]}ἀλλʼ οὐκ οἰωνοῖσιν ἐρύσατο κῆρα μέλαιναν,{l]
[l [n}2.860{]}ἀλλʼ ἐδάμη ὑπὸ χερσὶ ποδώκεος Αἰακίδαο{l]
[l [n}2.861{]}ἐν ποταμῷ, ὅθι περ Τρῶας κεράϊζε καὶ ἄλλους.{l]{para]
[para}[l [n}2.862{]}Φόρκυς αὖ Φρύγας ἦγε καὶ Ἀσκάνιος θεοειδὴς{l]
[l [n}2.863{]}τῆλʼ ἐξ Ἀσκανίης· μέμασαν δʼ ὑσμῖνι μάχεσθαι.{l]{para]
[para}[l [n}2.864{]}Μῄοσιν αὖ Μέσθλης τε καὶ Ἄντιφος ἡγησάσθην{l]
[l [n}2.865{]}υἷε Ταλαιμένεος τὼ Γυγαίη τέκε λίμνη,{l]
[l [n}2.866{]}οἳ καὶ Μῄονας ἦγον ὑπὸ Τμώλῳ γεγαῶτας.{l]{para]
[para}[l [n}2.867{]}Νάστης αὖ Καρῶν ἡγήσατο βαρβαροφώνων,{l]
[l [n}2.868{]}οἳ Μίλητον ἔχον Φθιρῶν τʼ ὄρος ἀκριτόφυλλον{l]
[l [n}2.869{]}Μαιάνδρου τε ῥοὰς Μυκάλης τʼ αἰπεινὰ κάρηνα·{l]
[l [n}2.870{]}τῶν μὲν ἄρʼ Ἀμφίμαχος καὶ Νάστης ἡγησάσθην,{l]
[l [n}2.871{]}Νάστης Ἀμφίμαχός τε Νομίονος ἀγλαὰ τέκνα,{l]
[l [n}2.872{]}ὃς καὶ χρυσὸν ἔχων πόλεμον δʼ ἴεν ἠΰτε κούρη{l]
[l [n}2.873{]}νήπιος, οὐδέ τί οἱ τό γʼ ἐπήρκεσε λυγρὸν ὄλεθρον,{l]
[l [n}2.874{]}ἀλλʼ ἐδάμη ὑπὸ χερσὶ ποδώκεος Αἰακίδαο{l]
[l [n}2.875{]}ἐν ποταμῷ, χρυσὸν δʼ Ἀχιλεὺς ἐκόμισσε δαΐφρων.{l]{para]
[para}[l [n}2.876{]}Σαρπηδὼν δʼ ἦρχεν Λυκίων καὶ Γλαῦκος ἀμύμων{l]
[l [n}2.877{]}τηλόθεν ἐκ Λυκίης, Ξάνθου ἄπο δινήεντος.{l]{para]
{book]