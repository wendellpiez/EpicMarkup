[book [n}1{]}
[para}[l [n}1.1{]}μῆνιν ἄειδε θεὰ Πηληϊάδεω Ἀχιλῆος{l]
[l [n}1.2{]}οὐλομένην, ἣ μυρίʼ Ἀχαιοῖς ἄλγεʼ ἔθηκε,{l]
[l [n}1.3{]}πολλὰς δʼ ἰφθίμους ψυχὰς Ἄϊδι προΐαψεν{l]
[l [n}1.4{]}ἡρώων, αὐτοὺς δὲ ἑλώρια τεῦχε κύνεσσιν{l]
[l [n}1.5{]}οἰωνοῖσί τε πᾶσι, Διὸς δʼ ἐτελείετο βουλή,{l]
[l [n}1.6{]}ἐξ οὗ δὴ τὰ πρῶτα διαστήτην ἐρίσαντε{l]
[l [n}1.7{]}Ἀτρεΐδης τε ἄναξ ἀνδρῶν καὶ δῖος Ἀχιλλεύς.{l]{para]
[para}[l [n}1.8{]}τίς τʼ ἄρ σφωε θεῶν ἔριδι ξυνέηκε μάχεσθαι;{l]
[l [n}1.9{]}Λητοῦς καὶ Διὸς υἱός· ὃ γὰρ βασιλῆϊ χολωθεὶς{l]
[l [n}1.10{]}νοῦσον ἀνὰ στρατὸν ὄρσε κακήν, ὀλέκοντο δὲ λαοί,{l]
[l [n}1.11{]}οὕνεκα τὸν Χρύσην ἠτίμασεν ἀρητῆρα{l]
[l [n}1.12{]}Ἀτρεΐδης· ὃ γὰρ ἦλθε θοὰς ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}1.13{]}λυσόμενός τε θύγατρα φέρων τʼ ἀπερείσιʼ ἄποινα,{l]
[l [n}1.14{]}στέμματʼ ἔχων ἐν χερσὶν ἑκηβόλου Ἀπόλλωνος{l]
[l [n}1.15{]}χρυσέῳ ἀνὰ σκήπτρῳ, καὶ λίσσετο πάντας Ἀχαιούς,{l]
[l [n}1.16{]}Ἀτρεΐδα δὲ μάλιστα δύω, κοσμήτορε λαῶν·{l]
[q}[l [n}1.17{]}Ἀτρεΐδαι τε καὶ ἄλλοι ἐϋκνήμιδες Ἀχαιοί,{l]
[l [n}1.18{]}ὑμῖν μὲν θεοὶ δοῖεν Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}1.19{]}ἐκπέρσαι Πριάμοιο πόλιν, εὖ δʼ οἴκαδʼ ἱκέσθαι·{l]
[l [n}1.20{]}παῖδα δʼ ἐμοὶ λύσαιτε φίλην, τὰ δʼ ἄποινα δέχεσθαι,{l]
[l [n}1.21{]}ἁζόμενοι Διὸς υἱὸν ἑκηβόλον Ἀπόλλωνα.{l]{q]{para]
[para}[l [n}1.22{]}ἔνθʼ ἄλλοι μὲν πάντες ἐπευφήμησαν Ἀχαιοὶ{l]
[l [n}1.23{]}αἰδεῖσθαί θʼ ἱερῆα καὶ ἀγλαὰ δέχθαι ἄποινα·{l]
[l [n}1.24{]}ἀλλʼ οὐκ Ἀτρεΐδῃ Ἀγαμέμνονι ἥνδανε θυμῷ,{l]
[l [n}1.25{]}ἀλλὰ κακῶς ἀφίει, κρατερὸν δʼ ἐπὶ μῦθον ἔτελλε·{l]
[q}[l [n}1.26{]}μή σε γέρον κοίλῃσιν ἐγὼ παρὰ νηυσὶ κιχείω{l]
[l [n}1.27{]}ἢ νῦν δηθύνοντʼ ἢ ὕστερον αὖτις ἰόντα,{l]
[l [n}1.28{]}μή νύ τοι οὐ χραίσμῃ σκῆπτρον καὶ στέμμα θεοῖο·{l]
[l [n}1.29{]}τὴν δʼ ἐγὼ οὐ λύσω· πρίν μιν καὶ γῆρας ἔπεισιν{l]
[l [n}1.30{]}ἡμετέρῳ ἐνὶ οἴκῳ ἐν Ἄργεϊ τηλόθι πάτρης{l]
[l [n}1.31{]}ἱστὸν ἐποιχομένην καὶ ἐμὸν λέχος ἀντιόωσαν·{l]
[l [n}1.32{]}ἀλλʼ ἴθι μή μʼ ἐρέθιζε σαώτερος ὥς κε νέηαι.{l]{q]{para]
[para}[l [n}1.33{]}ὣς ἔφατʼ, ἔδεισεν δʼ ὃ γέρων καὶ ἐπείθετο μύθῳ·{l]
[l [n}1.34{]}βῆ δʼ ἀκέων παρὰ θῖνα πολυφλοίσβοιο θαλάσσης·{l]
[l [n}1.35{]}πολλὰ δʼ ἔπειτʼ ἀπάνευθε κιὼν ἠρᾶθʼ ὁ γεραιὸς{l]
[l [n}1.36{]}Ἀπόλλωνι ἄνακτι, τὸν ἠΰκομος τέκε Λητώ·{l]
[q}[l [n}1.37{]}κλῦθί μευ ἀργυρότοξʼ, ὃς Χρύσην ἀμφιβέβηκας{l]
[l [n}1.38{]}Κίλλαν τε ζαθέην Τενέδοιό τε ἶφι ἀνάσσεις,{l]
[l [n}1.39{]}Σμινθεῦ εἴ ποτέ τοι χαρίεντʼ ἐπὶ νηὸν ἔρεψα,{l]
[l [n}1.40{]}ἢ εἰ δή ποτέ τοι κατὰ πίονα μηρίʼ ἔκηα{l]
[l [n}1.41{]}ταύρων ἠδʼ αἰγῶν, τὸ δέ μοι κρήηνον ἐέλδωρ·{l]
[l [n}1.42{]}τίσειαν Δαναοὶ ἐμὰ δάκρυα σοῖσι βέλεσσιν.{l]{q]{para]
[para}[l [n}1.43{]}ὣς ἔφατʼ εὐχόμενος, τοῦ δʼ ἔκλυε Φοῖβος Ἀπόλλων,{l]
[l [n}1.44{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων χωόμενος κῆρ,{l]
[l [n}1.45{]}τόξʼ ὤμοισιν ἔχων ἀμφηρεφέα τε φαρέτρην·{l]
[l [n}1.46{]}ἔκλαγξαν δʼ ἄρʼ ὀϊστοὶ ἐπʼ ὤμων χωομένοιο,{l]
[l [n}1.47{]}αὐτοῦ κινηθέντος· ὃ δʼ ἤϊε νυκτὶ ἐοικώς.{l]
[l [n}1.48{]}ἕζετʼ ἔπειτʼ ἀπάνευθε νεῶν, μετὰ δʼ ἰὸν ἕηκε·{l]
[l [n}1.49{]}δεινὴ δὲ κλαγγὴ γένετʼ ἀργυρέοιο βιοῖο·{l]
[l [n}1.50{]}οὐρῆας μὲν πρῶτον ἐπῴχετο καὶ κύνας ἀργούς,{l]
[l [n}1.51{]}αὐτὰρ ἔπειτʼ αὐτοῖσι βέλος ἐχεπευκὲς ἐφιεὶς{l]
[l [n}1.52{]}βάλλʼ· αἰεὶ δὲ πυραὶ νεκύων καίοντο θαμειαί.{l]{para]
[para}[l [n}1.53{]}ἐννῆμαρ μὲν ἀνὰ στρατὸν ᾤχετο κῆλα θεοῖο,{l]
[l [n}1.54{]}τῇ δεκάτῃ δʼ ἀγορὴν δὲ καλέσσατο λαὸν Ἀχιλλεύς·{l]
[l [n}1.55{]}τῷ γὰρ ἐπὶ φρεσὶ θῆκε θεὰ λευκώλενος Ἥρη·{l]
[l [n}1.56{]}κήδετο γὰρ Δαναῶν, ὅτι ῥα θνήσκοντας ὁρᾶτο.{l]
[l [n}1.57{]}οἳ δʼ ἐπεὶ οὖν ἤγερθεν ὁμηγερέες τε γένοντο,{l]
[l [n}1.58{]}τοῖσι δʼ ἀνιστάμενος μετέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}1.59{]}Ἀτρεΐδη νῦν ἄμμε παλιμπλαγχθέντας ὀΐω{l]
[l [n}1.60{]}ἂψ ἀπονοστήσειν, εἴ κεν θάνατόν γε φύγοιμεν,{l]
[l [n}1.61{]}εἰ δὴ ὁμοῦ πόλεμός τε δαμᾷ καὶ λοιμὸς Ἀχαιούς·{l]
[l [n}1.62{]}ἀλλʼ ἄγε δή τινα μάντιν ἐρείομεν ἢ ἱερῆα{l]
[l [n}1.63{]}ἢ καὶ ὀνειροπόλον, καὶ γάρ τʼ ὄναρ ἐκ Διός ἐστιν,{l]
[l [n}1.64{]}ὅς κʼ εἴποι ὅ τι τόσσον ἐχώσατο Φοῖβος Ἀπόλλων,{l]
[l [n}1.65{]}εἴτʼ ἄρʼ ὅ γʼ εὐχωλῆς ἐπιμέμφεται ἠδʼ ἑκατόμβης,{l]
[l [n}1.66{]}αἴ κέν πως ἀρνῶν κνίσης αἰγῶν τε τελείων{l]
[l [n}1.67{]}βούλεται ἀντιάσας ἡμῖν ἀπὸ λοιγὸν ἀμῦναι.{l]{q]{para]
[para}[l [n}1.68{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο· τοῖσι δʼ ἀνέστη{l]
[l [n}1.69{]}Κάλχας Θεστορίδης οἰωνοπόλων ὄχʼ ἄριστος,{l]
[l [n}1.70{]}ὃς ᾔδη τά τʼ ἐόντα τά τʼ ἐσσόμενα πρό τʼ ἐόντα,{l]
[l [n}1.71{]}καὶ νήεσσʼ ἡγήσατʼ Ἀχαιῶν Ἴλιον εἴσω{l]
[l [n}1.72{]}ἣν διὰ μαντοσύνην, τήν οἱ πόρε Φοῖβος Ἀπόλλων·{l]
[l [n}1.73{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}1.74{]}ὦ Ἀχιλεῦ κέλεαί με Διῒ φίλε μυθήσασθαι{l]
[l [n}1.75{]}μῆνιν Ἀπόλλωνος ἑκατηβελέταο ἄνακτος·{l]
[l [n}1.76{]}τοὶ γὰρ ἐγὼν ἐρέω· σὺ δὲ σύνθεο καί μοι ὄμοσσον{l]
[l [n}1.77{]}ἦ μέν μοι πρόφρων ἔπεσιν καὶ χερσὶν ἀρήξειν·{l]
[l [n}1.78{]}ἦ γὰρ ὀΐομαι ἄνδρα χολωσέμεν, ὃς μέγα πάντων{l]
[l [n}1.79{]}Ἀργείων κρατέει καί οἱ πείθονται Ἀχαιοί·{l]
[l [n}1.80{]}κρείσσων γὰρ βασιλεὺς ὅτε χώσεται ἀνδρὶ χέρηϊ·{l]
[l [n}1.81{]}εἴ περ γάρ τε χόλον γε καὶ αὐτῆμαρ καταπέψῃ,{l]
[l [n}1.82{]}ἀλλά τε καὶ μετόπισθεν ἔχει κότον, ὄφρα τελέσσῃ,{l]
[l [n}1.83{]}ἐν στήθεσσιν ἑοῖσι· σὺ δὲ φράσαι εἴ με σαώσεις.{l]{q]{para]
[para}[l [n}1.84{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}1.85{]}θαρσήσας μάλα εἰπὲ θεοπρόπιον ὅ τι οἶσθα·{l]
[l [n}1.86{]}οὐ μὰ γὰρ Ἀπόλλωνα Διῒ φίλον, ᾧ τε σὺ Κάλχαν{l]
[l [n}1.87{]}εὐχόμενος Δαναοῖσι θεοπροπίας ἀναφαίνεις,{l]
[l [n}1.88{]}οὔ τις ἐμεῦ ζῶντος καὶ ἐπὶ χθονὶ δερκομένοιο{l]
[l [n}1.89{]}σοὶ κοίλῃς παρὰ νηυσί βαρείας χεῖρας ἐποίσει{l]
[l [n}1.90{]}συμπάντων Δαναῶν, οὐδʼ ἢν Ἀγαμέμνονα εἴπῃς,{l]
[l [n}1.91{]}ὃς νῦν πολλὸν ἄριστος Ἀχαιῶν εὔχεται εἶναι.{l]{q]{para]
[para}[l [n}1.92{]}καὶ τότε δὴ θάρσησε καὶ ηὔδα μάντις ἀμύμων·{l]
[q}[l [n}1.93{]}οὔ τʼ ἄρ ὅ γʼ εὐχωλῆς ἐπιμέμφεται οὐδʼ ἑκατόμβης,{l]
[l [n}1.94{]}ἀλλʼ ἕνεκʼ ἀρητῆρος ὃν ἠτίμησʼ Ἀγαμέμνων,{l]
[l [n}1.95{]}οὐδʼ ἀπέλυσε θύγατρα καὶ οὐκ ἀπεδέξατʼ ἄποινα,{l]
[l [n}1.96{]}τοὔνεκʼ ἄρʼ ἄλγεʼ ἔδωκεν ἑκηβόλος ἠδʼ ἔτι δώσει·{l]
[l [n}1.97{]}οὐδʼ ὅ γε πρὶν Δαναοῖσιν ἀεικέα λοιγὸν ἀπώσει{l]
[l [n}1.98{]}πρίν γʼ ἀπὸ πατρὶ φίλῳ δόμεναι ἑλικώπιδα κούρην{l]
[l [n}1.99{]}ἀπριάτην ἀνάποινον, ἄγειν θʼ ἱερὴν ἑκατόμβην{l]
[l [n}1.100{]}ἐς Χρύσην· τότε κέν μιν ἱλασσάμενοι πεπίθοιμεν.{l]{q]{para]
[para}[l [n}1.101{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο· τοῖσι δʼ ἀνέστη{l]
[l [n}1.102{]}ἥρως Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}1.103{]}ἀχνύμενος· μένεος δὲ μέγα φρένες ἀμφιμέλαιναι{l]
[l [n}1.104{]}πίμπλαντʼ, ὄσσε δέ οἱ πυρὶ λαμπετόωντι ἐΐκτην·{l]
[l [n}1.105{]}Κάλχαντα πρώτιστα κάκʼ ὀσσόμενος προσέειπε·{l]
[q}[l [n}1.106{]}μάντι κακῶν οὐ πώ ποτέ μοι τὸ κρήγυον εἶπας·{l]
[l [n}1.107{]}αἰεί τοι τὰ κάκʼ ἐστὶ φίλα φρεσὶ μαντεύεσθαι,{l]
[l [n}1.108{]}ἐσθλὸν δʼ οὔτέ τί πω εἶπας ἔπος οὔτʼ ἐτέλεσσας·{l]
[l [n}1.109{]}καὶ νῦν ἐν Δαναοῖσι θεοπροπέων ἀγορεύεις{l]
[l [n}1.110{]}ὡς δὴ τοῦδʼ ἕνεκά σφιν ἑκηβόλος ἄλγεα τεύχει,{l]
[l [n}1.111{]}οὕνεκʼ ἐγὼ κούρης Χρυσηΐδος ἀγλάʼ ἄποινα{l]
[l [n}1.112{]}οὐκ ἔθελον δέξασθαι, ἐπεὶ πολὺ βούλομαι αὐτὴν{l]
[l [n}1.113{]}οἴκοι ἔχειν· καὶ γάρ ῥα Κλυταιμνήστρης προβέβουλα{l]
[l [n}1.114{]}κουριδίης ἀλόχου, ἐπεὶ οὔ ἑθέν ἐστι χερείων,{l]
[l [n}1.115{]}οὐ δέμας οὐδὲ φυήν, οὔτʼ ἂρ φρένας οὔτέ τι ἔργα.{l]
[l [n}1.116{]}ἀλλὰ καὶ ὧς ἐθέλω δόμεναι πάλιν εἰ τό γʼ ἄμεινον·{l]
[l [n}1.117{]}βούλομʼ ἐγὼ λαὸν σῶν ἔμμεναι ἢ ἀπολέσθαι·{l]
[l [n}1.118{]}αὐτὰρ ἐμοὶ γέρας αὐτίχʼ ἑτοιμάσατʼ ὄφρα μὴ οἶος{l]
[l [n}1.119{]}Ἀργείων ἀγέραστος ἔω, ἐπεὶ οὐδὲ ἔοικε·{l]
[l [n}1.120{]}λεύσσετε γὰρ τό γε πάντες ὅ μοι γέρας ἔρχεται ἄλλῃ.{l]{q]{para]
[para}[l [n}1.121{]}τὸν δʼ ἠμείβετʼ ἔπειτα ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}1.122{]}Ἀτρεΐδη κύδιστε φιλοκτεανώτατε πάντων,{l]
[l [n}1.123{]}πῶς γάρ τοι δώσουσι γέρας μεγάθυμοι Ἀχαιοί;{l]
[l [n}1.124{]}οὐδέ τί που ἴδμεν ξυνήϊα κείμενα πολλά·{l]
[l [n}1.125{]}ἀλλὰ τὰ μὲν πολίων ἐξεπράθομεν, τὰ δέδασται,{l]
[l [n}1.126{]}λαοὺς δʼ οὐκ ἐπέοικε παλίλλογα ταῦτʼ ἐπαγείρειν.{l]
[l [n}1.127{]}ἀλλὰ σὺ μὲν νῦν τήνδε θεῷ πρόες· αὐτὰρ Ἀχαιοὶ{l]
[l [n}1.128{]}τριπλῇ τετραπλῇ τʼ ἀποτείσομεν, αἴ κέ ποθι Ζεὺς{l]
[l [n}1.129{]}δῷσι πόλιν Τροίην εὐτείχεον ἐξαλαπάξαι.{l]{q]{para]
[para}[l [n}1.130{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}1.131{]}μὴ δʼ οὕτως ἀγαθός περ ἐὼν θεοείκελʼ Ἀχιλλεῦ{l]
[l [n}1.132{]}κλέπτε νόῳ, ἐπεὶ οὐ παρελεύσεαι οὐδέ με πείσεις.{l]
[l [n}1.133{]}ἦ ἐθέλεις ὄφρʼ αὐτὸς ἔχῃς γέρας, αὐτὰρ ἔμʼ αὔτως{l]
[l [n}1.134{]}ἧσθαι δευόμενον, κέλεαι δέ με τήνδʼ ἀποδοῦναι;{l]
[l [n}1.135{]}ἀλλʼ εἰ μὲν δώσουσι γέρας μεγάθυμοι Ἀχαιοὶ{l]
[l [n}1.136{]}ἄρσαντες κατὰ θυμὸν ὅπως ἀντάξιον ἔσται·{l]
[l [n}1.137{]}εἰ δέ κε μὴ δώωσιν ἐγὼ δέ κεν αὐτὸς ἕλωμαι{l]
[l [n}1.138{]}ἢ τεὸν ἢ Αἴαντος ἰὼν γέρας, ἢ Ὀδυσῆος{l]
[l [n}1.139{]}ἄξω ἑλών· ὃ δέ κεν κεχολώσεται ὅν κεν ἵκωμαι.{l]
[l [n}1.140{]}ἀλλʼ ἤτοι μὲν ταῦτα μεταφρασόμεσθα καὶ αὖτις,{l]
[l [n}1.141{]}νῦν δʼ ἄγε νῆα μέλαιναν ἐρύσσομεν εἰς ἅλα δῖαν,{l]
[l [n}1.142{]}ἐν δʼ ἐρέτας ἐπιτηδὲς ἀγείρομεν, ἐς δʼ ἑκατόμβην{l]
[l [n}1.143{]}θείομεν, ἂν δʼ αὐτὴν Χρυσηΐδα καλλιπάρῃον{l]
[l [n}1.144{]}βήσομεν· εἷς δέ τις ἀρχὸς ἀνὴρ βουληφόρος ἔστω,{l]
[l [n}1.145{]}ἢ Αἴας ἢ Ἰδομενεὺς ἢ δῖος Ὀδυσσεὺς{l]
[l [n}1.146{]}ἠὲ σὺ Πηλεΐδη πάντων ἐκπαγλότατʼ ἀνδρῶν,{l]
[l [n}1.147{]}ὄφρʼ ἥμιν ἑκάεργον ἱλάσσεαι ἱερὰ ῥέξας.{l]{q]{para]
[para}[l [n}1.148{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}1.149{]}ὤ μοι ἀναιδείην ἐπιειμένε κερδαλεόφρον{l]
[l [n}1.150{]}πῶς τίς τοι πρόφρων ἔπεσιν πείθηται Ἀχαιῶν{l]
[l [n}1.151{]}ἢ ὁδὸν ἐλθέμεναι ἢ ἀνδράσιν ἶφι μάχεσθαι;{l]
[l [n}1.152{]}οὐ γὰρ ἐγὼ Τρώων ἕνεκʼ ἤλυθον αἰχμητάων{l]
[l [n}1.153{]}δεῦρο μαχησόμενος, ἐπεὶ οὔ τί μοι αἴτιοί εἰσιν·{l]
[l [n}1.154{]}οὐ γὰρ πώποτʼ ἐμὰς βοῦς ἤλασαν οὐδὲ μὲν ἵππους,{l]
[l [n}1.155{]}οὐδέ ποτʼ ἐν Φθίῃ ἐριβώλακι βωτιανείρῃ{l]
[l [n}1.156{]}καρπὸν ἐδηλήσαντʼ, ἐπεὶ ἦ μάλα πολλὰ μεταξὺ{l]
[l [n}1.157{]}οὔρεά τε σκιόεντα θάλασσά τε ἠχήεσσα·{l]
[l [n}1.158{]}ἀλλὰ σοὶ ὦ μέγʼ ἀναιδὲς ἅμʼ ἑσπόμεθʼ ὄφρα σὺ χαίρῃς,{l]
[l [n}1.159{]}τιμὴν ἀρνύμενοι Μενελάῳ σοί τε κυνῶπα{l]
[l [n}1.160{]}πρὸς Τρώων· τῶν οὔ τι μετατρέπῃ οὐδʼ ἀλεγίζεις·{l]
[l [n}1.161{]}καὶ δή μοι γέρας αὐτὸς ἀφαιρήσεσθαι ἀπειλεῖς,{l]
[l [n}1.162{]}ᾧ ἔπι πολλὰ μόγησα, δόσαν δέ μοι υἷες Ἀχαιῶν.{l]
[l [n}1.163{]}οὐ μὲν σοί ποτε ἶσον ἔχω γέρας ὁππότʼ Ἀχαιοὶ{l]
[l [n}1.164{]}Τρώων ἐκπέρσωσʼ εὖ ναιόμενον πτολίεθρον·{l]
[l [n}1.165{]}ἀλλὰ τὸ μὲν πλεῖον πολυάϊκος πολέμοιο{l]
[l [n}1.166{]}χεῖρες ἐμαὶ διέπουσʼ· ἀτὰρ ἤν ποτε δασμὸς ἵκηται,{l]
[l [n}1.167{]}σοὶ τὸ γέρας πολὺ μεῖζον, ἐγὼ δʼ ὀλίγον τε φίλον τε{l]
[l [n}1.168{]}ἔρχομʼ ἔχων ἐπὶ νῆας, ἐπεί κε κάμω πολεμίζων.{l]
[l [n}1.169{]}νῦν δʼ εἶμι Φθίην δʼ, ἐπεὶ ἦ πολὺ φέρτερόν ἐστιν{l]
[l [n}1.170{]}οἴκαδʼ ἴμεν σὺν νηυσὶ κορωνίσιν, οὐδέ σʼ ὀΐω{l]
[l [n}1.171{]}ἐνθάδʼ ἄτιμος ἐὼν ἄφενος καὶ πλοῦτον ἀφύξειν.{l]{q]{para]
[para}[l [n}1.172{]}τὸν δʼ ἠμείβετʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}1.173{]}φεῦγε μάλʼ εἴ τοι θυμὸς ἐπέσσυται, οὐδέ σʼ ἔγωγε{l]
[l [n}1.174{]}λίσσομαι εἵνεκʼ ἐμεῖο μένειν· πάρʼ ἔμοιγε καὶ ἄλλοι{l]
[l [n}1.175{]}οἵ κέ με τιμήσουσι, μάλιστα δὲ μητίετα Ζεύς.{l]
[l [n}1.176{]}ἔχθιστος δέ μοί ἐσσι διοτρεφέων βασιλήων·{l]
[l [n}1.177{]}αἰεὶ γάρ τοι ἔρις τε φίλη πόλεμοί τε μάχαι τε·{l]
[l [n}1.178{]}εἰ μάλα καρτερός ἐσσι, θεός που σοὶ τό γʼ ἔδωκεν·{l]
[l [n}1.179{]}οἴκαδʼ ἰὼν σὺν νηυσί τε σῇς καὶ σοῖς ἑτάροισι{l]
[l [n}1.180{]}Μυρμιδόνεσσιν ἄνασσε, σέθεν δʼ ἐγὼ οὐκ ἀλεγίζω,{l]
[l [n}1.181{]}οὐδʼ ὄθομαι κοτέοντος· ἀπειλήσω δέ τοι ὧδε·{l]
[l [n}1.182{]}ὡς ἔμʼ ἀφαιρεῖται Χρυσηΐδα Φοῖβος Ἀπόλλων,{l]
[l [n}1.183{]}τὴν μὲν ἐγὼ σὺν νηΐ τʼ ἐμῇ καὶ ἐμοῖς ἑτάροισι{l]
[l [n}1.184{]}πέμψω, ἐγὼ δέ κʼ ἄγω Βρισηΐδα καλλιπάρῃον{l]
[l [n}1.185{]}αὐτὸς ἰὼν κλισίην δὲ τὸ σὸν γέρας ὄφρʼ ἐῢ εἰδῇς{l]
[l [n}1.186{]}ὅσσον φέρτερός εἰμι σέθεν, στυγέῃ δὲ καὶ ἄλλος{l]
[l [n}1.187{]}ἶσον ἐμοὶ φάσθαι καὶ ὁμοιωθήμεναι ἄντην.{l]{q]{para]
[para}[l [n}1.188{]}ὣς φάτο· Πηλεΐωνι δʼ ἄχος γένετʼ, ἐν δέ οἱ ἦτορ{l]
[l [n}1.189{]}στήθεσσιν λασίοισι διάνδιχα μερμήριξεν,{l]
[l [n}1.190{]}ἢ ὅ γε φάσγανον ὀξὺ ἐρυσσάμενος παρὰ μηροῦ{l]
[l [n}1.191{]}τοὺς μὲν ἀναστήσειεν, ὃ δʼ Ἀτρεΐδην ἐναρίζοι,{l]
[l [n}1.192{]}ἦε χόλον παύσειεν ἐρητύσειέ τε θυμόν.{l]
[l [n}1.193{]}ἧος ὃ ταῦθʼ ὥρμαινε κατὰ φρένα καὶ κατὰ θυμόν,{l]
[l [n}1.194{]}ἕλκετο δʼ ἐκ κολεοῖο μέγα ξίφος, ἦλθε δʼ Ἀθήνη{l]
[l [n}1.195{]}οὐρανόθεν· πρὸ γὰρ ἧκε θεὰ λευκώλενος Ἥρη{l]
[l [n}1.196{]}ἄμφω ὁμῶς θυμῷ φιλέουσά τε κηδομένη τε·{l]
[l [n}1.197{]}στῆ δʼ ὄπιθεν, ξανθῆς δὲ κόμης ἕλε Πηλεΐωνα{l]
[l [n}1.198{]}οἴῳ φαινομένη· τῶν δʼ ἄλλων οὔ τις ὁρᾶτο·{l]
[l [n}1.199{]}θάμβησεν δʼ Ἀχιλεύς, μετὰ δʼ ἐτράπετʼ, αὐτίκα δʼ ἔγνω{l]
[l [n}1.200{]}Παλλάδʼ Ἀθηναίην· δεινὼ δέ οἱ ὄσσε φάανθεν·{l]
[l [n}1.201{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}1.202{]}τίπτʼ αὖτʼ αἰγιόχοιο Διὸς τέκος εἰλήλουθας;{l]
[l [n}1.203{]}ἦ ἵνα ὕβριν ἴδῃ Ἀγαμέμνονος Ἀτρεΐδαο;{l]
[l [n}1.204{]}ἀλλʼ ἔκ τοι ἐρέω, τὸ δὲ καὶ τελέεσθαι ὀΐω·{l]
[l [n}1.205{]}ᾗς ὑπεροπλίῃσι τάχʼ ἄν ποτε θυμὸν ὀλέσσῃ.{l]{q]{para]
[para}[l [n}1.206{]}τὸν δʼ αὖτε προσέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}1.207{]}ἦλθον ἐγὼ παύσουσα τὸ σὸν μένος, αἴ κε πίθηαι,{l]
[l [n}1.208{]}οὐρανόθεν· πρὸ δέ μʼ ἧκε θεὰ λευκώλενος Ἥρη{l]
[l [n}1.209{]}ἄμφω ὁμῶς θυμῷ φιλέουσά τε κηδομένη τε·{l]
[l [n}1.210{]}ἀλλʼ ἄγε λῆγʼ ἔριδος, μηδὲ ξίφος ἕλκεο χειρί·{l]
[l [n}1.211{]}ἀλλʼ ἤτοι ἔπεσιν μὲν ὀνείδισον ὡς ἔσεταί περ·{l]
[l [n}1.212{]}ὧδε γὰρ ἐξερέω, τὸ δὲ καὶ τετελεσμένον ἔσται·{l]
[l [n}1.213{]}καί ποτέ τοι τρὶς τόσσα παρέσσεται ἀγλαὰ δῶρα{l]
[l [n}1.214{]}ὕβριος εἵνεκα τῆσδε· σὺ δʼ ἴσχεο, πείθεο δʼ ἡμῖν.{l]{q]{para]
[para}[l [n}1.215{]}τὴν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}1.216{]}χρὴ μὲν σφωΐτερόν γε θεὰ ἔπος εἰρύσσασθαι{l]
[l [n}1.217{]}καὶ μάλα περ θυμῷ κεχολωμένον· ὧς γὰρ ἄμεινον·{l]
[l [n}1.218{]}ὅς κε θεοῖς ἐπιπείθηται μάλα τʼ ἔκλυον αὐτοῦ.{l]{q]{para]
[para}[l [n}1.219{]}ἦ καὶ ἐπʼ ἀργυρέῃ κώπῃ σχέθε χεῖρα βαρεῖαν,{l]
[l [n}1.220{]}ἂψ δʼ ἐς κουλεὸν ὦσε μέγα ξίφος, οὐδʼ ἀπίθησε{l]
[l [n}1.221{]}μύθῳ Ἀθηναίης· ἣ δʼ Οὔλυμπον δὲ βεβήκει{l]
[l [n}1.222{]}δώματʼ ἐς αἰγιόχοιο Διὸς μετὰ δαίμονας ἄλλους.{l]{para]
[para}[l [n}1.223{]}Πηλεΐδης δʼ ἐξαῦτις ἀταρτηροῖς ἐπέεσσιν{l]
[l [n}1.224{]}Ἀτρεΐδην προσέειπε, καὶ οὔ πω λῆγε χόλοιο·{l]
[q}[l [n}1.225{]}οἰνοβαρές, κυνὸς ὄμματʼ ἔχων, κραδίην δʼ ἐλάφοιο,{l]
[l [n}1.226{]}οὔτέ ποτʼ ἐς πόλεμον ἅμα λαῷ θωρηχθῆναι{l]
[l [n}1.227{]}οὔτε λόχον δʼ ἰέναι σὺν ἀριστήεσσιν Ἀχαιῶν{l]
[l [n}1.228{]}τέτληκας θυμῷ· τὸ δέ τοι κὴρ εἴδεται εἶναι.{l]
[l [n}1.229{]}ἦ πολὺ λώϊόν ἐστι κατὰ στρατὸν εὐρὺν Ἀχαιῶν{l]
[l [n}1.230{]}δῶρʼ ἀποαιρεῖσθαι ὅς τις σέθεν ἀντίον εἴπῃ·{l]
[l [n}1.231{]}δημοβόρος βασιλεὺς ἐπεὶ οὐτιδανοῖσιν ἀνάσσεις·{l]
[l [n}1.232{]}ἦ γὰρ ἂν Ἀτρεΐδη νῦν ὕστατα λωβήσαιο.{l]
[l [n}1.233{]}ἀλλʼ ἔκ τοι ἐρέω καὶ ἐπὶ μέγαν ὅρκον ὀμοῦμαι·{l]
[l [n}1.234{]}ναὶ μὰ τόδε σκῆπτρον, τὸ μὲν οὔ ποτε φύλλα καὶ ὄζους{l]
[l [n}1.235{]}φύσει, ἐπεὶ δὴ πρῶτα τομὴν ἐν ὄρεσσι λέλοιπεν,{l]
[l [n}1.236{]}οὐδʼ ἀναθηλήσει· περὶ γάρ ῥά ἑ χαλκὸς ἔλεψε{l]
[l [n}1.237{]}φύλλά τε καὶ φλοιόν· νῦν αὖτέ μιν υἷες Ἀχαιῶν{l]
[l [n}1.238{]}ἐν παλάμῃς φορέουσι δικασπόλοι, οἵ τε θέμιστας{l]
[l [n}1.239{]}πρὸς Διὸς εἰρύαται· ὃ δέ τοι μέγας ἔσσεται ὅρκος·{l]
[l [n}1.240{]}ἦ ποτʼ Ἀχιλλῆος ποθὴ ἵξεται υἷας Ἀχαιῶν{l]
[l [n}1.241{]}σύμπαντας· τότε δʼ οὔ τι δυνήσεαι ἀχνύμενός περ{l]
[l [n}1.242{]}χραισμεῖν, εὖτʼ ἂν πολλοὶ ὑφʼ Ἕκτορος ἀνδροφόνοιο{l]
[l [n}1.243{]}θνήσκοντες πίπτωσι· σὺ δʼ ἔνδοθι θυμὸν ἀμύξεις{l]
[l [n}1.244{]}χωόμενος ὅ τʼ ἄριστον Ἀχαιῶν οὐδὲν ἔτισας.{l]{q]{para]
[para}[l [n}1.245{]}ὣς φάτο Πηλεΐδης, ποτὶ δὲ σκῆπτρον βάλε γαίῃ{l]
[l [n}1.246{]}χρυσείοις ἥλοισι πεπαρμένον, ἕζετο δʼ αὐτός·{l]
[l [n}1.247{]}Ἀτρεΐδης δʼ ἑτέρωθεν ἐμήνιε· τοῖσι δὲ Νέστωρ{l]
[l [n}1.248{]}ἡδυεπὴς ἀνόρουσε λιγὺς Πυλίων ἀγορητής,{l]
[l [n}1.249{]}τοῦ καὶ ἀπὸ γλώσσης μέλιτος γλυκίων ῥέεν αὐδή·{l]
[l [n}1.250{]}τῷ δʼ ἤδη δύο μὲν γενεαὶ μερόπων ἀνθρώπων{l]
[l [n}1.251{]}ἐφθίαθʼ, οἵ οἱ πρόσθεν ἅμα τράφεν ἠδʼ ἐγένοντο{l]
[l [n}1.252{]}ἐν Πύλῳ ἠγαθέῃ, μετὰ δὲ τριτάτοισιν ἄνασσεν·{l]
[l [n}1.253{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}1.254{]}ὦ πόποι ἦ μέγα πένθος Ἀχαιΐδα γαῖαν ἱκάνει·{l]
[l [n}1.255{]}ἦ κεν γηθήσαι Πρίαμος Πριάμοιό τε παῖδες{l]
[l [n}1.256{]}ἄλλοι τε Τρῶες μέγα κεν κεχαροίατο θυμῷ{l]
[l [n}1.257{]}εἰ σφῶϊν τάδε πάντα πυθοίατο μαρναμένοιϊν,{l]
[l [n}1.258{]}οἳ περὶ μὲν βουλὴν Δαναῶν, περὶ δʼ ἐστὲ μάχεσθαι.{l]
[l [n}1.259{]}ἀλλὰ πίθεσθʼ· ἄμφω δὲ νεωτέρω ἐστὸν ἐμεῖο·{l]
[l [n}1.260{]}ἤδη γάρ ποτʼ ἐγὼ καὶ ἀρείοσιν ἠέ περ ὑμῖν{l]
[l [n}1.261{]}ἀνδράσιν ὡμίλησα, καὶ οὔ ποτέ μʼ οἵ γʼ ἀθέριζον.{l]
[l [n}1.262{]}οὐ γάρ πω τοίους ἴδον ἀνέρας οὐδὲ ἴδωμαι,{l]
[l [n}1.263{]}οἷον Πειρίθοόν τε Δρύαντά τε ποιμένα λαῶν{l]
[l [n}1.264{]}Καινέα τʼ Ἐξάδιόν τε καὶ ἀντίθεον Πολύφημον{l]
[l [n}1.265{]}Θησέα τʼ Αἰγεΐδην, ἐπιείκελον ἀθανάτοισιν·{l]
[l [n}1.266{]}κάρτιστοι δὴ κεῖνοι ἐπιχθονίων τράφεν ἀνδρῶν·{l]
[l [n}1.267{]}κάρτιστοι μὲν ἔσαν καὶ καρτίστοις ἐμάχοντο{l]
[l [n}1.268{]}φηρσὶν ὀρεσκῴοισι καὶ ἐκπάγλως ἀπόλεσσαν.{l]
[l [n}1.269{]}καὶ μὲν τοῖσιν ἐγὼ μεθομίλεον ἐκ Πύλου ἐλθὼν{l]
[l [n}1.270{]}τηλόθεν ἐξ ἀπίης γαίης· καλέσαντο γὰρ αὐτοί·{l]
[l [n}1.271{]}καὶ μαχόμην κατʼ ἔμʼ αὐτὸν ἐγώ· κείνοισι δʼ ἂν οὔ τις{l]
[l [n}1.272{]}τῶν οἳ νῦν βροτοί εἰσιν ἐπιχθόνιοι μαχέοιτο·{l]
[l [n}1.273{]}καὶ μέν μευ βουλέων ξύνιεν πείθοντό τε μύθῳ·{l]
[l [n}1.274{]}ἀλλὰ πίθεσθε καὶ ὔμμες, ἐπεὶ πείθεσθαι ἄμεινον·{l]
[l [n}1.275{]}μήτε σὺ τόνδʼ ἀγαθός περ ἐὼν ἀποαίρεο κούρην,{l]
[l [n}1.276{]}ἀλλʼ ἔα ὥς οἱ πρῶτα δόσαν γέρας υἷες Ἀχαιῶν·{l]
[l [n}1.277{]}μήτε σὺ Πηλείδη ἔθελʼ ἐριζέμεναι βασιλῆϊ{l]
[l [n}1.278{]}ἀντιβίην, ἐπεὶ οὔ ποθʼ ὁμοίης ἔμμορε τιμῆς{l]
[l [n}1.279{]}σκηπτοῦχος βασιλεύς, ᾧ τε Ζεὺς κῦδος ἔδωκεν.{l]
[l [n}1.280{]}εἰ δὲ σὺ καρτερός ἐσσι θεὰ δέ σε γείνατο μήτηρ,{l]
[l [n}1.281{]}ἀλλʼ ὅ γε φέρτερός ἐστιν ἐπεὶ πλεόνεσσιν ἀνάσσει.{l]
[l [n}1.282{]}Ἀτρεΐδη σὺ δὲ παῦε τεὸν μένος· αὐτὰρ ἔγωγε{l]
[l [n}1.283{]}λίσσομʼ Ἀχιλλῆϊ μεθέμεν χόλον, ὃς μέγα πᾶσιν{l]
[l [n}1.284{]}ἕρκος Ἀχαιοῖσιν πέλεται πολέμοιο κακοῖο.{l]{q]{para]
[para}[l [n}1.285{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}1.286{]}ναὶ δὴ ταῦτά γε πάντα γέρον κατὰ μοῖραν ἔειπες·{l]
[l [n}1.287{]}ἀλλʼ ὅδʼ ἀνὴρ ἐθέλει περὶ πάντων ἔμμεναι ἄλλων,{l]
[l [n}1.288{]}πάντων μὲν κρατέειν ἐθέλει, πάντεσσι δʼ ἀνάσσειν,{l]
[l [n}1.289{]}πᾶσι δὲ σημαίνειν, ἅ τινʼ οὐ πείσεσθαι ὀΐω·{l]
[l [n}1.290{]}εἰ δέ μιν αἰχμητὴν ἔθεσαν θεοὶ αἰὲν ἐόντες{l]
[l [n}1.291{]}τοὔνεκά οἱ προθέουσιν ὀνείδεα μυθήσασθαι;{l]{q]{para]
[para}[l [n}1.292{]}τὸν δʼ ἄρʼ ὑποβλήδην ἠμείβετο δῖος Ἀχιλλεύς·{l]
[q}[l [n}1.293{]}ἦ γάρ κεν δειλός τε καὶ οὐτιδανὸς καλεοίμην{l]
[l [n}1.294{]}εἰ δὴ σοὶ πᾶν ἔργον ὑπείξομαι ὅττί κεν εἴπῃς·{l]
[l [n}1.295{]}ἄλλοισιν δὴ ταῦτʼ ἐπιτέλλεο, μὴ γὰρ ἔμοιγε{l]
[l [n}1.296{]}σήμαινʼ· οὐ γὰρ ἔγωγʼ ἔτι σοὶ πείσεσθαι ὀΐω.{l]
[l [n}1.297{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσι·{l]
[l [n}1.298{]}χερσὶ μὲν οὔ τοι ἔγωγε μαχήσομαι εἵνεκα κούρης{l]
[l [n}1.299{]}οὔτε σοὶ οὔτέ τῳ ἄλλῳ, ἐπεί μʼ ἀφέλεσθέ γε δόντες·{l]
[l [n}1.300{]}τῶν δʼ ἄλλων ἅ μοί ἐστι θοῇ παρὰ νηῒ μελαίνῃ{l]
[l [n}1.301{]}τῶν οὐκ ἄν τι φέροις ἀνελὼν ἀέκοντος ἐμεῖο·{l]
[l [n}1.302{]}εἰ δʼ ἄγε μὴν πείρησαι ἵνα γνώωσι καὶ οἵδε·{l]
[l [n}1.303{]}αἶψά τοι αἷμα κελαινὸν ἐρωήσει περὶ δουρί.{l]{q]{para]
[para}[l [n}1.304{]}ὣς τώ γʼ ἀντιβίοισι μαχεσσαμένω ἐπέεσσιν{l]
[l [n}1.305{]}ἀνστήτην, λῦσαν δʼ ἀγορὴν παρὰ νηυσὶν Ἀχαιῶν·{l]
[l [n}1.306{]}Πηλεΐδης μὲν ἐπὶ κλισίας καὶ νῆας ἐΐσας{l]
[l [n}1.307{]}ἤϊε σύν τε Μενοιτιάδῃ καὶ οἷς ἑτάροισιν·{l]
[l [n}1.308{]}Ἀτρεΐδης δʼ ἄρα νῆα θοὴν ἅλα δὲ προέρυσσεν,{l]
[l [n}1.309{]}ἐν δʼ ἐρέτας ἔκρινεν ἐείκοσιν, ἐς δʼ ἑκατόμβην{l]
[l [n}1.310{]}βῆσε θεῷ, ἀνὰ δὲ Χρυσηΐδα καλλιπάρῃον{l]
[l [n}1.311{]}εἷσεν ἄγων· ἐν δʼ ἀρχὸς ἔβη πολύμητις Ὀδυσσεύς.{l]{para]
[para}[l [n}1.312{]}οἳ μὲν ἔπειτʼ ἀναβάντες ἐπέπλεον ὑγρὰ κέλευθα,{l]
[l [n}1.313{]}λαοὺς δʼ Ἀτρεΐδης ἀπολυμαίνεσθαι ἄνωγεν·{l]
[l [n}1.314{]}οἳ δʼ ἀπελυμαίνοντο καὶ εἰς ἅλα λύματα βάλλον,{l]
[l [n}1.315{]}ἕρδον δʼ Ἀπόλλωνι τεληέσσας ἑκατόμβας{l]
[l [n}1.316{]}ταύρων ἠδʼ αἰγῶν παρὰ θῖνʼ ἁλὸς ἀτρυγέτοιο·{l]
[l [n}1.317{]}κνίση δʼ οὐρανὸν ἷκεν ἑλισσομένη περὶ καπνῷ.{l]{para]
[para}[l [n}1.318{]}ὣς οἳ μὲν τὰ πένοντο κατὰ στρατόν· οὐδʼ Ἀγαμέμνων{l]
[l [n}1.319{]}λῆγʼ ἔριδος τὴν πρῶτον ἐπηπείλησʼ Ἀχιλῆϊ,{l]
[l [n}1.320{]}ἀλλʼ ὅ γε Ταλθύβιόν τε καὶ Εὐρυβάτην προσέειπε,{l]
[l [n}1.321{]}τώ οἱ ἔσαν κήρυκε καὶ ὀτρηρὼ θεράποντε·{l]
[q}[l [n}1.322{]}ἔρχεσθον κλισίην Πηληϊάδεω Ἀχιλῆος·{l]
[l [n}1.323{]}χειρὸς ἑλόντʼ ἀγέμεν Βρισηΐδα καλλιπάρῃον·{l]
[l [n}1.324{]}εἰ δέ κε μὴ δώῃσιν ἐγὼ δέ κεν αὐτὸς ἕλωμαι{l]
[l [n}1.325{]}ἐλθὼν σὺν πλεόνεσσι· τό οἱ καὶ ῥίγιον ἔσται.{l]{q]{para]
[para}[l [n}1.326{]}ὣς εἰπὼν προΐει, κρατερὸν δʼ ἐπὶ μῦθον ἔτελλε·{l]
[l [n}1.327{]}τὼ δʼ ἀέκοντε βάτην παρὰ θῖνʼ ἁλὸς ἀτρυγέτοιο,{l]
[l [n}1.328{]}Μυρμιδόνων δʼ ἐπί τε κλισίας καὶ νῆας ἱκέσθην,{l]
[l [n}1.329{]}τὸν δʼ εὗρον παρά τε κλισίῃ καὶ νηῒ μελαίνῃ{l]
[l [n}1.330{]}ἥμενον· οὐδʼ ἄρα τώ γε ἰδὼν γήθησεν Ἀχιλλεύς.{l]
[l [n}1.331{]}τὼ μὲν ταρβήσαντε καὶ αἰδομένω βασιλῆα{l]
[l [n}1.332{]}στήτην, οὐδέ τί μιν προσεφώνεον οὐδʼ ἐρέοντο·{l]
[l [n}1.333{]}αὐτὰρ ὃ ἔγνω ᾗσιν ἐνὶ φρεσὶ φώνησέν τε·{l]
[q}[l [n}1.334{]}χαίρετε κήρυκες Διὸς ἄγγελοι ἠδὲ καὶ ἀνδρῶν,{l]
[l [n}1.335{]}ἆσσον ἴτʼ· οὔ τί μοι ὔμμες ἐπαίτιοι ἀλλʼ Ἀγαμέμνων,{l]
[l [n}1.336{]}ὃ σφῶϊ προΐει Βρισηΐδος εἵνεκα κούρης.{l]
[l [n}1.337{]}ἀλλʼ ἄγε διογενὲς Πατρόκλεες ἔξαγε κούρην{l]
[l [n}1.338{]}καί σφωϊν δὸς ἄγειν· τὼ δʼ αὐτὼ μάρτυροι ἔστων{l]
[l [n}1.339{]}πρός τε θεῶν μακάρων πρός τε θνητῶν ἀνθρώπων{l]
[l [n}1.340{]}καὶ πρὸς τοῦ βασιλῆος ἀπηνέος εἴ ποτε δʼ αὖτε{l]
[l [n}1.341{]}χρειὼ ἐμεῖο γένηται ἀεικέα λοιγὸν ἀμῦναι{l]
[l [n}1.342{]}τοῖς ἄλλοις· ἦ γὰρ ὅ γʼ ὀλοιῇσι φρεσὶ θύει,{l]
[l [n}1.343{]}οὐδέ τι οἶδε νοῆσαι ἅμα πρόσσω καὶ ὀπίσσω,{l]
[l [n}1.344{]}ὅππως οἱ παρὰ νηυσὶ σόοι μαχέοιντο Ἀχαιοί.{l]{q]{para]
[para}[l [n}1.345{]}ὣς φάτο, Πάτροκλος δὲ φίλῳ ἐπεπείθεθʼ ἑταίρῳ,{l]
[l [n}1.346{]}ἐκ δʼ ἄγαγε κλισίης Βρισηΐδα καλλιπάρῃον,{l]
[l [n}1.347{]}δῶκε δʼ ἄγειν· τὼ δʼ αὖτις ἴτην παρὰ νῆας Ἀχαιῶν·{l]
[l [n}1.348{]}ἣ δʼ ἀέκουσʼ ἅμα τοῖσι γυνὴ κίεν· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}1.349{]}δακρύσας ἑτάρων ἄφαρ ἕζετο νόσφι λιασθείς,{l]
[l [n}1.350{]}θῖνʼ ἔφʼ ἁλὸς πολιῆς, ὁρόων ἐπʼ ἀπείρονα πόντον·{l]
[l [n}1.351{]}πολλὰ δὲ μητρὶ φίλῃ ἠρήσατο χεῖρας ὀρεγνύς·{l]
[q}[l [n}1.352{]}μῆτερ ἐπεί μʼ ἔτεκές γε μινυνθάδιόν περ ἐόντα,{l]
[l [n}1.353{]}τιμήν πέρ μοι ὄφελλεν Ὀλύμπιος ἐγγυαλίξαι{l]
[l [n}1.354{]}Ζεὺς ὑψιβρεμέτης· νῦν δʼ οὐδέ με τυτθὸν ἔτισεν·{l]
[l [n}1.355{]}ἦ γάρ μʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}1.356{]}ἠτίμησεν· ἑλὼν γὰρ ἔχει γέρας αὐτὸς ἀπούρας.{l]{q]{para]
[para}[l [n}1.357{]}ὣς φάτο δάκρυ χέων, τοῦ δʼ ἔκλυε πότνια μήτηρ{l]
[l [n}1.358{]}ἡμένη ἐν βένθεσσιν ἁλὸς παρὰ πατρὶ γέροντι·{l]
[l [n}1.359{]}καρπαλίμως δʼ ἀνέδυ πολιῆς ἁλὸς ἠΰτʼ ὀμίχλη,{l]
[l [n}1.360{]}καί ῥα πάροιθʼ αὐτοῖο καθέζετο δάκρυ χέοντος,{l]
[l [n}1.361{]}χειρί τέ μιν κατέρεξεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}1.362{]}τέκνον τί κλαίεις; τί δέ σε φρένας ἵκετο πένθος;{l]
[l [n}1.363{]}ἐξαύδα, μὴ κεῦθε νόῳ, ἵνα εἴδομεν ἄμφω.{l]{q]{para]
[para}[l [n}1.364{]}τὴν δὲ βαρὺ στενάχων προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}1.365{]}οἶσθα· τί ἤ τοι ταῦτα ἰδυίῃ πάντʼ ἀγορεύω;{l]
[l [n}1.366{]}ᾠχόμεθʼ ἐς Θήβην ἱερὴν πόλιν Ἠετίωνος,{l]
[l [n}1.367{]}τὴν δὲ διεπράθομέν τε καὶ ἤγομεν ἐνθάδε πάντα·{l]
[l [n}1.368{]}καὶ τὰ μὲν εὖ δάσσαντο μετὰ σφίσιν υἷες Ἀχαιῶν,{l]
[l [n}1.369{]}ἐκ δʼ ἕλον Ἀτρεΐδῃ Χρυσηΐδα καλλιπάρῃον.{l]
[l [n}1.370{]}Χρύσης δʼ αὖθʼ ἱερεὺς ἑκατηβόλου Ἀπόλλωνος{l]
[l [n}1.371{]}ἦλθε θοὰς ἐπὶ νῆας Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}1.372{]}λυσόμενός τε θύγατρα φέρων τʼ ἀπερείσιʼ ἄποινα,{l]
[l [n}1.373{]}στέμματʼ ἔχων ἐν χερσὶν ἑκηβόλου Ἀπόλλωνος{l]
[l [n}1.374{]}χρυσέῳ ἀνὰ σκήπτρῳ, καὶ λίσσετο πάντας Ἀχαιούς,{l]
[l [n}1.375{]}Ἀτρεΐδα δὲ μάλιστα δύω κοσμήτορε λαῶν.{l]
[l [n}1.376{]}ἔνθʼ ἄλλοι μὲν πάντες ἐπευφήμησαν Ἀχαιοὶ{l]
[l [n}1.377{]}αἰδεῖσθαί θʼ ἱερῆα καὶ ἀγλαὰ δέχθαι ἄποινα·{l]
[l [n}1.378{]}ἀλλʼ οὐκ Ἀτρεΐδῃ Ἀγαμέμνονι ἥνδανε θυμῷ,{l]
[l [n}1.379{]}ἀλλὰ κακῶς ἀφίει, κρατερὸν δʼ ἐπὶ μῦθον ἔτελλε·{l]
[l [n}1.380{]}χωόμενος δʼ ὁ γέρων πάλιν ᾤχετο· τοῖο δʼ Ἀπόλλων{l]
[l [n}1.381{]}εὐξαμένου ἤκουσεν, ἐπεὶ μάλα οἱ φίλος ἦεν,{l]
[l [n}1.382{]}ἧκε δʼ ἐπʼ Ἀργείοισι κακὸν βέλος· οἳ δέ νυ λαοὶ{l]
[l [n}1.383{]}θνῇσκον ἐπασσύτεροι, τὰ δʼ ἐπῴχετο κῆλα θεοῖο{l]
[l [n}1.384{]}πάντῃ ἀνὰ στρατὸν εὐρὺν Ἀχαιῶν· ἄμμι δὲ μάντις{l]
[l [n}1.385{]}εὖ εἰδὼς ἀγόρευε θεοπροπίας ἑκάτοιο.{l]
[l [n}1.386{]}αὐτίκʼ ἐγὼ πρῶτος κελόμην θεὸν ἱλάσκεσθαι·{l]
[l [n}1.387{]}Ἀτρεΐωνα δʼ ἔπειτα χόλος λάβεν, αἶψα δʼ ἀναστὰς{l]
[l [n}1.388{]}ἠπείλησεν μῦθον ὃ δὴ τετελεσμένος ἐστί·{l]
[l [n}1.389{]}τὴν μὲν γὰρ σὺν νηῒ θοῇ ἑλίκωπες Ἀχαιοὶ{l]
[l [n}1.390{]}ἐς Χρύσην πέμπουσιν, ἄγουσι δὲ δῶρα ἄνακτι·{l]
[l [n}1.391{]}τὴν δὲ νέον κλισίηθεν ἔβαν κήρυκες ἄγοντες{l]
[l [n}1.392{]}κούρην Βρισῆος τήν μοι δόσαν υἷες Ἀχαιῶν.{l]
[l [n}1.393{]}ἀλλὰ σὺ εἰ δύνασαί γε περίσχεο παιδὸς ἑῆος·{l]
[l [n}1.394{]}ἐλθοῦσʼ Οὔλυμπον δὲ Δία λίσαι, εἴ ποτε δή τι{l]
[l [n}1.395{]}ἢ ἔπει ὤνησας κραδίην Διὸς ἠὲ καὶ ἔργῳ.{l]
[l [n}1.396{]}πολλάκι γάρ σεο πατρὸς ἐνὶ μεγάροισιν ἄκουσα{l]
[l [n}1.397{]}εὐχομένης ὅτʼ ἔφησθα κελαινεφέϊ Κρονίωνι{l]
[l [n}1.398{]}οἴη ἐν ἀθανάτοισιν ἀεικέα λοιγὸν ἀμῦναι,{l]
[l [n}1.399{]}ὁππότε μιν ξυνδῆσαι Ὀλύμπιοι ἤθελον ἄλλοι{l]
[l [n}1.400{]}Ἥρη τʼ ἠδὲ Ποσειδάων καὶ Παλλὰς Ἀθήνη·{l]
[l [n}1.401{]}ἀλλὰ σὺ τόν γʼ ἐλθοῦσα θεὰ ὑπελύσαο δεσμῶν,{l]
[l [n}1.402{]}ὦχʼ ἑκατόγχειρον καλέσασʼ ἐς μακρὸν Ὄλυμπον,{l]
[l [n}1.403{]}ὃν Βριάρεων καλέουσι θεοί, ἄνδρες δέ τε πάντες{l]
[l [n}1.404{]}Αἰγαίωνʼ, ὃ γὰρ αὖτε βίην οὗ πατρὸς ἀμείνων·{l]
[l [n}1.405{]}ὅς ῥα παρὰ Κρονίωνι καθέζετο κύδεϊ γαίων·{l]
[l [n}1.406{]}τὸν καὶ ὑπέδεισαν μάκαρες θεοὶ οὐδʼ ἔτʼ ἔδησαν.{l]
[l [n}1.407{]}τῶν νῦν μιν μνήσασα παρέζεο καὶ λαβὲ γούνων{l]
[l [n}1.408{]}αἴ κέν πως ἐθέλῃσιν ἐπὶ Τρώεσσιν ἀρῆξαι,{l]
[l [n}1.409{]}τοὺς δὲ κατὰ πρύμνας τε καὶ ἀμφʼ ἅλα ἔλσαι Ἀχαιοὺς{l]
[l [n}1.410{]}κτεινομένους, ἵνα πάντες ἐπαύρωνται βασιλῆος,{l]
[l [n}1.411{]}γνῷ δὲ καὶ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}1.412{]}ἣν ἄτην ὅ τʼ ἄριστον Ἀχαιῶν οὐδὲν ἔτισεν.{l]{q]{para]
[para}[l [n}1.413{]}τὸν δʼ ἠμείβετʼ ἔπειτα Θέτις κατὰ δάκρυ χέουσα·{l]
[q}[l [n}1.414{]}ὤ μοι τέκνον ἐμόν, τί νύ σʼ ἔτρεφον αἰνὰ τεκοῦσα;{l]
[l [n}1.415{]}αἴθʼ ὄφελες παρὰ νηυσὶν ἀδάκρυτος καὶ ἀπήμων{l]
[l [n}1.416{]}ἧσθαι, ἐπεί νύ τοι αἶσα μίνυνθά περ οὔ τι μάλα δήν·{l]
[l [n}1.417{]}νῦν δʼ ἅμα τʼ ὠκύμορος καὶ ὀϊζυρὸς περὶ πάντων{l]
[l [n}1.418{]}ἔπλεο· τώ σε κακῇ αἴσῃ τέκον ἐν μεγάροισι.{l]
[l [n}1.419{]}τοῦτο δέ τοι ἐρέουσα ἔπος Διὶ τερπικεραύνῳ{l]
[l [n}1.420{]}εἶμʼ αὐτὴ πρὸς Ὄλυμπον ἀγάννιφον αἴ κε πίθηται.{l]
[l [n}1.421{]}ἀλλὰ σὺ μὲν νῦν νηυσὶ παρήμενος ὠκυπόροισι{l]
[l [n}1.422{]}μήνιʼ Ἀχαιοῖσιν, πολέμου δʼ ἀποπαύεο πάμπαν·{l]
[l [n}1.423{]}Ζεὺς γὰρ ἐς Ὠκεανὸν μετʼ ἀμύμονας Αἰθιοπῆας{l]
[l [n}1.424{]}χθιζὸς ἔβη κατὰ δαῖτα, θεοὶ δʼ ἅμα πάντες ἕποντο·{l]
[l [n}1.425{]}δωδεκάτῃ δέ τοι αὖτις ἐλεύσεται Οὔλυμπον δέ,{l]
[l [n}1.426{]}καὶ τότʼ ἔπειτά τοι εἶμι Διὸς ποτὶ χαλκοβατὲς δῶ,{l]
[l [n}1.427{]}καί μιν γουνάσομαι καί μιν πείσεσθαι ὀΐω.{l]{q]{para]
[para}[l [n}1.428{]}ὣς ἄρα φωνήσασʼ ἀπεβήσετο, τὸν δὲ λίπʼ αὐτοῦ{l]
[l [n}1.429{]}χωόμενον κατὰ θυμὸν ἐϋζώνοιο γυναικὸς{l]
[l [n}1.430{]}τήν ῥα βίῃ ἀέκοντος ἀπηύρων· αὐτὰρ Ὀδυσσεὺς{l]
[l [n}1.431{]}ἐς Χρύσην ἵκανεν ἄγων ἱερὴν ἑκατόμβην.{l]
[l [n}1.432{]}οἳ δʼ ὅτε δὴ λιμένος πολυβενθέος ἐντὸς ἵκοντο{l]
[l [n}1.433{]}ἱστία μὲν στείλαντο, θέσαν δʼ ἐν νηῒ μελαίνῃ,{l]
[l [n}1.434{]}ἱστὸν δʼ ἱστοδόκῃ πέλασαν προτόνοισιν ὑφέντες{l]
[l [n}1.435{]}καρπαλίμως, τὴν δʼ εἰς ὅρμον προέρεσσαν ἐρετμοῖς.{l]
[l [n}1.436{]}ἐκ δʼ εὐνὰς ἔβαλον, κατὰ δὲ πρυμνήσιʼ ἔδησαν·{l]
[l [n}1.437{]}ἐκ δὲ καὶ αὐτοὶ βαῖνον ἐπὶ ῥηγμῖνι θαλάσσης,{l]
[l [n}1.438{]}ἐκ δʼ ἑκατόμβην βῆσαν ἑκηβόλῳ Ἀπόλλωνι·{l]
[l [n}1.439{]}ἐκ δὲ Χρυσηῒς νηὸς βῆ ποντοπόροιο.{l]
[l [n}1.440{]}τὴν μὲν ἔπειτʼ ἐπὶ βωμὸν ἄγων πολύμητις Ὀδυσσεὺς{l]
[l [n}1.441{]}πατρὶ φίλῳ ἐν χερσὶ τίθει καί μιν προσέειπεν·{l]
[q}[l [n}1.442{]}ὦ Χρύση, πρό μʼ ἔπεμψεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}1.443{]}παῖδά τε σοὶ ἀγέμεν, Φοίβῳ θʼ ἱερὴν ἑκατόμβην{l]
[l [n}1.444{]}ῥέξαι ὑπὲρ Δαναῶν ὄφρʼ ἱλασόμεσθα ἄνακτα,{l]
[l [n}1.445{]}ὃς νῦν Ἀργείοισι πολύστονα κήδεʼ ἐφῆκεν.{l]{q]{para]
[para}[l [n}1.446{]}ὣς εἰπὼν ἐν χερσὶ τίθει, ὃ δὲ δέξατο χαίρων{l]
[l [n}1.447{]}παῖδα φίλην· τοὶ δʼ ὦκα θεῷ ἱερὴν ἑκατόμβην{l]
[l [n}1.448{]}ἑξείης ἔστησαν ἐΰδμητον περὶ βωμόν,{l]
[l [n}1.449{]}χερνίψαντο δʼ ἔπειτα καὶ οὐλοχύτας ἀνέλοντο.{l]
[l [n}1.450{]}τοῖσιν δὲ Χρύσης μεγάλʼ εὔχετο χεῖρας ἀνασχών·{l]
[q}[l [n}1.451{]}κλῦθί μευ ἀργυρότοξʼ, ὃς Χρύσην ἀμφιβέβηκας{l]
[l [n}1.452{]}Κίλλαν τε ζαθέην Τενέδοιό τε ἶφι ἀνάσσεις·{l]
[l [n}1.453{]}ἦ μὲν δή ποτʼ ἐμεῦ πάρος ἔκλυες εὐξαμένοιο,{l]
[l [n}1.454{]}τίμησας μὲν ἐμέ, μέγα δʼ ἴψαο λαὸν Ἀχαιῶν·{l]
[l [n}1.455{]}ἠδʼ ἔτι καὶ νῦν μοι τόδʼ ἐπικρήηνον ἐέλδωρ·{l]
[l [n}1.456{]}ἤδη νῦν Δαναοῖσιν ἀεικέα λοιγὸν ἄμυνον.{l]{q]{para]
[para}[l [n}1.457{]}ὣς ἔφατʼ εὐχόμενος, τοῦ δʼ ἔκλυε Φοῖβος Ἀπόλλων.{l]
[l [n}1.458{]}αὐτὰρ ἐπεί ῥʼ εὔξαντο καὶ οὐλοχύτας προβάλοντο,{l]
[l [n}1.459{]}αὐέρυσαν μὲν πρῶτα καὶ ἔσφαξαν καὶ ἔδειραν,{l]
[l [n}1.460{]}μηρούς τʼ ἐξέταμον κατά τε κνίσῃ ἐκάλυψαν{l]
[l [n}1.461{]}δίπτυχα ποιήσαντες, ἐπʼ αὐτῶν δʼ ὠμοθέτησαν·{l]
[l [n}1.462{]}καῖε δʼ ἐπὶ σχίζῃς ὁ γέρων, ἐπὶ δʼ αἴθοπα οἶνον{l]
[l [n}1.463{]}λεῖβε· νέοι δὲ παρʼ αὐτὸν ἔχον πεμπώβολα χερσίν.{l]
[l [n}1.464{]}αὐτὰρ ἐπεὶ κατὰ μῆρε κάη καὶ σπλάγχνα πάσαντο,{l]
[l [n}1.465{]}μίστυλλόν τʼ ἄρα τἆλλα καὶ ἀμφʼ ὀβελοῖσιν ἔπειραν,{l]
[l [n}1.466{]}ὤπτησάν τε περιφραδέως, ἐρύσαντό τε πάντα.{l]
[l [n}1.467{]}αὐτὰρ ἐπεὶ παύσαντο πόνου τετύκοντό τε δαῖτα{l]
[l [n}1.468{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης.{l]
[l [n}1.469{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}1.470{]}κοῦροι μὲν κρητῆρας ἐπεστέψαντο ποτοῖο,{l]
[l [n}1.471{]}νώμησαν δʼ ἄρα πᾶσιν ἐπαρξάμενοι δεπάεσσιν·{l]
[l [n}1.472{]}οἳ δὲ πανημέριοι μολπῇ θεὸν ἱλάσκοντο{l]
[l [n}1.473{]}καλὸν ἀείδοντες παιήονα κοῦροι Ἀχαιῶν{l]
[l [n}1.474{]}μέλποντες ἑκάεργον· ὃ δὲ φρένα τέρπετʼ ἀκούων.{l]{para]
[para}[l [n}1.475{]}ἦμος δʼ ἠέλιος κατέδυ καὶ ἐπὶ κνέφας ἦλθε,{l]
[l [n}1.476{]}δὴ τότε κοιμήσαντο παρὰ πρυμνήσια νηός·{l]
[l [n}1.477{]}ἦμος δʼ ἠριγένεια φάνη ῥοδοδάκτυλος Ἠώς,{l]
[l [n}1.478{]}καὶ τότʼ ἔπειτʼ ἀνάγοντο μετὰ στρατὸν εὐρὺν Ἀχαιῶν·{l]
[l [n}1.479{]}τοῖσιν δʼ ἴκμενον οὖρον ἵει ἑκάεργος Ἀπόλλων·{l]
[l [n}1.480{]}οἳ δʼ ἱστὸν στήσαντʼ ἀνά θʼ ἱστία λευκὰ πέτασσαν,{l]
[l [n}1.481{]}ἐν δʼ ἄνεμος πρῆσεν μέσον ἱστίον, ἀμφὶ δὲ κῦμα{l]
[l [n}1.482{]}στείρῃ πορφύρεον μεγάλʼ ἴαχε νηὸς ἰούσης·{l]
[l [n}1.483{]}ἣ δʼ ἔθεεν κατὰ κῦμα διαπρήσσουσα κέλευθον.{l]
[l [n}1.484{]}αὐτὰρ ἐπεί ῥʼ ἵκοντο κατὰ στρατὸν εὐρὺν Ἀχαιῶν,{l]
[l [n}1.485{]}νῆα μὲν οἵ γε μέλαιναν ἐπʼ ἠπείροιο ἔρυσσαν{l]
[l [n}1.486{]}ὑψοῦ ἐπὶ ψαμάθοις, ὑπὸ δʼ ἕρματα μακρὰ τάνυσσαν·{l]
[l [n}1.487{]}αὐτοὶ δʼ ἐσκίδναντο κατὰ κλισίας τε νέας τε.{l]{para]
[para}[l [n}1.488{]}αὐτὰρ ὃ μήνιε νηυσὶ παρήμενος ὠκυπόροισι{l]
[l [n}1.489{]}διογενὴς Πηλῆος υἱὸς πόδας ὠκὺς Ἀχιλλεύς·{l]
[l [n}1.490{]}οὔτέ ποτʼ εἰς ἀγορὴν πωλέσκετο κυδιάνειραν{l]
[l [n}1.491{]}οὔτέ ποτʼ ἐς πόλεμον, ἀλλὰ φθινύθεσκε φίλον κῆρ{l]
[l [n}1.492{]}αὖθι μένων, ποθέεσκε δʼ ἀϋτήν τε πτόλεμόν τε.{l]{para]
[para}[l [n}1.493{]}ἀλλʼ ὅτε δή ῥʼ ἐκ τοῖο δυωδεκάτη γένετʼ ἠώς,{l]
[l [n}1.494{]}καὶ τότε δὴ πρὸς Ὄλυμπον ἴσαν θεοὶ αἰὲν ἐόντες{l]
[l [n}1.495{]}πάντες ἅμα, Ζεὺς δʼ ἦρχε· Θέτις δʼ οὐ λήθετʼ ἐφετμέων{l]
[l [n}1.496{]}παιδὸς ἑοῦ, ἀλλʼ ἥ γʼ ἀνεδύσετο κῦμα θαλάσσης.{l]
[l [n}1.497{]}ἠερίη δʼ ἀνέβη μέγαν οὐρανὸν Οὔλυμπόν τε.{l]
[l [n}1.498{]}εὗρεν δʼ εὐρύοπα Κρονίδην ἄτερ ἥμενον ἄλλων{l]
[l [n}1.499{]}ἀκροτάτῃ κορυφῇ πολυδειράδος Οὐλύμποιο·{l]
[l [n}1.500{]}καί ῥα πάροιθʼ αὐτοῖο καθέζετο, καὶ λάβε γούνων{l]
[l [n}1.501{]}σκαιῇ, δεξιτερῇ δʼ ἄρʼ ὑπʼ ἀνθερεῶνος ἑλοῦσα{l]
[l [n}1.502{]}λισσομένη προσέειπε Δία Κρονίωνα ἄνακτα·{l]
[q}[l [n}1.503{]}Ζεῦ πάτερ εἴ ποτε δή σε μετʼ ἀθανάτοισιν ὄνησα{l]
[l [n}1.504{]}ἢ ἔπει ἢ ἔργῳ, τόδε μοι κρήηνον ἐέλδωρ·{l]
[l [n}1.505{]}τίμησόν μοι υἱὸν ὃς ὠκυμορώτατος ἄλλων{l]
[l [n}1.506{]}ἔπλετʼ· ἀτάρ μιν νῦν γε ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}1.507{]}ἠτίμησεν· ἑλὼν γὰρ ἔχει γέρας αὐτὸς ἀπούρας.{l]
[l [n}1.508{]}ἀλλὰ σύ πέρ μιν τῖσον Ὀλύμπιε μητίετα Ζεῦ·{l]
[l [n}1.509{]}τόφρα δʼ ἐπὶ Τρώεσσι τίθει κράτος ὄφρʼ ἂν Ἀχαιοὶ{l]
[l [n}1.510{]}υἱὸν ἐμὸν τίσωσιν ὀφέλλωσίν τέ ἑ τιμῇ.{l]{q]{para]
[para}[l [n}1.511{]}ὣς φάτο· τὴν δʼ οὔ τι προσέφη νεφεληγερέτα Ζεύς,{l]
[l [n}1.512{]}ἀλλʼ ἀκέων δὴν ἧστο· Θέτις δʼ ὡς ἥψατο γούνων{l]
[l [n}1.513{]}ὣς ἔχετʼ ἐμπεφυυῖα, καὶ εἴρετο δεύτερον αὖτις·{l]
[q}[l [n}1.514{]}νημερτὲς μὲν δή μοι ὑπόσχεο καὶ κατάνευσον{l]
[l [n}1.515{]}ἢ ἀπόειπʼ, ἐπεὶ οὔ τοι ἔπι δέος, ὄφρʼ ἐῢ εἰδέω{l]
[l [n}1.516{]}ὅσσον ἐγὼ μετὰ πᾶσιν ἀτιμοτάτη θεός εἰμι.{l]{q]{para]
[para}[l [n}1.517{]}τὴν δὲ μέγʼ ὀχθήσας προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}1.518{]}ἦ δὴ λοίγια ἔργʼ ὅ τέ μʼ ἐχθοδοπῆσαι ἐφήσεις{l]
[l [n}1.519{]}Ἥρῃ ὅτʼ ἄν μʼ ἐρέθῃσιν ὀνειδείοις ἐπέεσσιν·{l]
[l [n}1.520{]}ἣ δὲ καὶ αὔτως μʼ αἰεὶ ἐν ἀθανάτοισι θεοῖσι{l]
[l [n}1.521{]}νεικεῖ, καί τέ μέ φησι μάχῃ Τρώεσσιν ἀρήγειν.{l]
[l [n}1.522{]}ἀλλὰ σὺ μὲν νῦν αὖτις ἀπόστιχε μή τι νοήσῃ{l]
[l [n}1.523{]}Ἥρη· ἐμοὶ δέ κε ταῦτα μελήσεται ὄφρα τελέσσω·{l]
[l [n}1.524{]}εἰ δʼ ἄγε τοι κεφαλῇ κατανεύσομαι ὄφρα πεποίθῃς·{l]
[l [n}1.525{]}τοῦτο γὰρ ἐξ ἐμέθεν γε μετʼ ἀθανάτοισι μέγιστον{l]
[l [n}1.526{]}τέκμωρ· οὐ γὰρ ἐμὸν παλινάγρετον οὐδʼ ἀπατηλὸν{l]
[l [n}1.527{]}οὐδʼ ἀτελεύτητον ὅ τί κεν κεφαλῇ κατανεύσω.{l]{q]{para]
[para}[l [n}1.528{]}ἦ καὶ κυανέῃσιν ἐπʼ ὀφρύσι νεῦσε Κρονίων·{l]
[l [n}1.529{]}ἀμβρόσιαι δʼ ἄρα χαῖται ἐπερρώσαντο ἄνακτος{l]
[l [n}1.530{]}κρατὸς ἀπʼ ἀθανάτοιο· μέγαν δʼ ἐλέλιξεν Ὄλυμπον.{l]{para]
[para}[l [n}1.531{]}τώ γʼ ὣς βουλεύσαντε διέτμαγεν· ἣ μὲν ἔπειτα{l]
[l [n}1.532{]}εἰς ἅλα ἆλτο βαθεῖαν ἀπʼ αἰγλήεντος Ὀλύμπου,{l]
[l [n}1.533{]}Ζεὺς δὲ ἑὸν πρὸς δῶμα· θεοὶ δʼ ἅμα πάντες ἀνέσταν{l]
[l [n}1.534{]}ἐξ ἑδέων σφοῦ πατρὸς ἐναντίον· οὐδέ τις ἔτλη{l]
[l [n}1.535{]}μεῖναι ἐπερχόμενον, ἀλλʼ ἀντίοι ἔσταν ἅπαντες.{l]
[l [n}1.536{]}ὣς ὃ μὲν ἔνθα καθέζετʼ ἐπὶ θρόνου· οὐδέ μιν Ἥρη{l]
[l [n}1.537{]}ἠγνοίησεν ἰδοῦσʼ ὅτι οἱ συμφράσσατο βουλὰς{l]
[l [n}1.538{]}ἀργυρόπεζα Θέτις θυγάτηρ ἁλίοιο γέροντος.{l]
[l [n}1.539{]}αὐτίκα κερτομίοισι Δία Κρονίωνα προσηύδα·{l]
[q}[l [n}1.540{]}τίς δʼ αὖ τοι δολομῆτα θεῶν συμφράσσατο βουλάς;{l]
[l [n}1.541{]}αἰεί τοι φίλον ἐστὶν ἐμεῦ ἀπὸ νόσφιν ἐόντα{l]
[l [n}1.542{]}κρυπτάδια φρονέοντα δικαζέμεν· οὐδέ τί πώ μοι{l]
[l [n}1.543{]}πρόφρων τέτληκας εἰπεῖν ἔπος ὅττι νοήσῃς.{l]{q]{para]
[para}[l [n}1.544{]}τὴν δʼ ἠμείβετʼ ἔπειτα πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[q}[l [n}1.545{]}Ἥρη μὴ δὴ πάντας ἐμοὺς ἐπιέλπεο μύθους{l]
[l [n}1.546{]}εἰδήσειν· χαλεποί τοι ἔσοντʼ ἀλόχῳ περ ἐούσῃ·{l]
[l [n}1.547{]}ἀλλʼ ὃν μέν κʼ ἐπιεικὲς ἀκουέμεν οὔ τις ἔπειτα{l]
[l [n}1.548{]}οὔτε θεῶν πρότερος τὸν εἴσεται οὔτʼ ἀνθρώπων·{l]
[l [n}1.549{]}ὃν δέ κʼ ἐγὼν ἀπάνευθε θεῶν ἐθέλωμι νοῆσαι{l]
[l [n}1.550{]}μή τι σὺ ταῦτα ἕκαστα διείρεο μηδὲ μετάλλα.{l]{q]{para]
[para}[l [n}1.551{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοῶπις πότνια Ἥρη·{l]
[q}[l [n}1.552{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες;{l]
[l [n}1.553{]}καὶ λίην σε πάρος γʼ οὔτʼ εἴρομαι οὔτε μεταλλῶ,{l]
[l [n}1.554{]}ἀλλὰ μάλʼ εὔκηλος τὰ φράζεαι ἅσσʼ ἐθέλῃσθα.{l]
[l [n}1.555{]}νῦν δʼ αἰνῶς δείδοικα κατὰ φρένα μή σε παρείπῃ{l]
[l [n}1.556{]}ἀργυρόπεζα Θέτις θυγάτηρ ἁλίοιο γέροντος·{l]
[l [n}1.557{]}ἠερίη γὰρ σοί γε παρέζετο καὶ λάβε γούνων·{l]
[l [n}1.558{]}τῇ σʼ ὀΐω κατανεῦσαι ἐτήτυμον ὡς Ἀχιλῆα{l]
[l [n}1.559{]}τιμήσῃς, ὀλέσῃς δὲ πολέας ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}1.560{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}1.561{]}δαιμονίη αἰεὶ μὲν ὀΐεαι οὐδέ σε λήθω·{l]
[l [n}1.562{]}πρῆξαι δʼ ἔμπης οὔ τι δυνήσεαι, ἀλλʼ ἀπὸ θυμοῦ{l]
[l [n}1.563{]}μᾶλλον ἐμοὶ ἔσεαι· τὸ δέ τοι καὶ ῥίγιον ἔσται.{l]
[l [n}1.564{]}εἰ δʼ οὕτω τοῦτʼ ἐστὶν ἐμοὶ μέλλει φίλον εἶναι·{l]
[l [n}1.565{]}ἀλλʼ ἀκέουσα κάθησο, ἐμῷ δʼ ἐπιπείθεο μύθῳ,{l]
[l [n}1.566{]}μή νύ τοι οὐ χραίσμωσιν ὅσοι θεοί εἰσʼ ἐν Ὀλύμπῳ{l]
[l [n}1.567{]}ἆσσον ἰόνθʼ, ὅτε κέν τοι ἀάπτους χεῖρας ἐφείω.{l]{q]{para]
[para}[l [n}1.568{]}ὣς ἔφατʼ ἔδεισεν δὲ βοῶπις πότνια Ἥρη,{l]
[l [n}1.569{]}καί ῥʼ ἀκέουσα καθῆστο ἐπιγνάμψασα φίλον κῆρ·{l]
[l [n}1.570{]}ὄχθησαν δʼ ἀνὰ δῶμα Διὸς θεοὶ Οὐρανίωνες·{l]
[l [n}1.571{]}τοῖσιν δʼ Ἥφαιστος κλυτοτέχνης ἦρχʼ ἀγορεύειν{l]
[l [n}1.572{]}μητρὶ φίλῃ ἐπίηρα φέρων λευκωλένῳ Ἥρῃ·{l]
[q}[l [n}1.573{]}ἦ δὴ λοίγια ἔργα τάδʼ ἔσσεται οὐδʼ ἔτʼ ἀνεκτά,{l]
[l [n}1.574{]}εἰ δὴ σφὼ ἕνεκα θνητῶν ἐριδαίνετον ὧδε,{l]
[l [n}1.575{]}ἐν δὲ θεοῖσι κολῳὸν ἐλαύνετον· οὐδέ τι δαιτὸς{l]
[l [n}1.576{]}ἐσθλῆς ἔσσεται ἦδος, ἐπεὶ τὰ χερείονα νικᾷ.{l]
[l [n}1.577{]}μητρὶ δʼ ἐγὼ παράφημι καὶ αὐτῇ περ νοεούσῃ{l]
[l [n}1.578{]}πατρὶ φίλῳ ἐπίηρα φέρειν Διί, ὄφρα μὴ αὖτε{l]
[l [n}1.579{]}νεικείῃσι πατήρ, σὺν δʼ ἡμῖν δαῖτα ταράξῃ.{l]
[l [n}1.580{]}εἴ περ γάρ κʼ ἐθέλῃσιν Ὀλύμπιος ἀστεροπητὴς{l]
[l [n}1.581{]}ἐξ ἑδέων στυφελίξαι· ὃ γὰρ πολὺ φέρτατός ἐστιν.{l]
[l [n}1.582{]}ἀλλὰ σὺ τὸν ἐπέεσσι καθάπτεσθαι μαλακοῖσιν·{l]
[l [n}1.583{]}αὐτίκʼ ἔπειθʼ ἵλαος Ὀλύμπιος ἔσσεται ἡμῖν.{l]{q]{para]
[para}[l [n}1.584{]}ὣς ἄρʼ ἔφη καὶ ἀναΐξας δέπας ἀμφικύπελλον{l]
[l [n}1.585{]}μητρὶ φίλῃ ἐν χειρὶ τίθει καί μιν προσέειπε·{l]
[q}[l [n}1.586{]}τέτλαθι μῆτερ ἐμή, καὶ ἀνάσχεο κηδομένη περ,{l]
[l [n}1.587{]}μή σε φίλην περ ἐοῦσαν ἐν ὀφθαλμοῖσιν ἴδωμαι{l]
[l [n}1.588{]}θεινομένην, τότε δʼ οὔ τι δυνήσομαι ἀχνύμενός περ{l]
[l [n}1.589{]}χραισμεῖν· ἀργαλέος γὰρ Ὀλύμπιος ἀντιφέρεσθαι·{l]
[l [n}1.590{]}ἤδη γάρ με καὶ ἄλλοτʼ ἀλεξέμεναι μεμαῶτα{l]
[l [n}1.591{]}ῥῖψε ποδὸς τεταγὼν ἀπὸ βηλοῦ θεσπεσίοιο,{l]
[l [n}1.592{]}πᾶν δʼ ἦμαρ φερόμην, ἅμα δʼ ἠελίῳ καταδύντι{l]
[l [n}1.593{]}κάππεσον ἐν Λήμνῳ, ὀλίγος δʼ ἔτι θυμὸς ἐνῆεν·{l]
[l [n}1.594{]}ἔνθά με Σίντιες ἄνδρες ἄφαρ κομίσαντο πεσόντα.{l]{q]{para]
[para}[l [n}1.595{]}ὣς φάτο, μείδησεν δὲ θεὰ λευκώλενος Ἥρη,{l]
[l [n}1.596{]}μειδήσασα δὲ παιδὸς ἐδέξατο χειρὶ κύπελλον·{l]
[l [n}1.597{]}αὐτὰρ ὃ τοῖς ἄλλοισι θεοῖς ἐνδέξια πᾶσιν{l]
[l [n}1.598{]}οἰνοχόει γλυκὺ νέκταρ ἀπὸ κρητῆρος ἀφύσσων·{l]
[l [n}1.599{]}ἄσβεστος δʼ ἄρʼ ἐνῶρτο γέλως μακάρεσσι θεοῖσιν{l]
[l [n}1.600{]}ὡς ἴδον Ἥφαιστον διὰ δώματα ποιπνύοντα.{l]{para]
[para}[l [n}1.601{]}ὣς τότε μὲν πρόπαν ἦμαρ ἐς ἠέλιον καταδύντα{l]
[l [n}1.602{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης,{l]
[l [n}1.603{]}οὐ μὲν φόρμιγγος περικαλλέος ἣν ἔχʼ Ἀπόλλων,{l]
[l [n}1.604{]}Μουσάων θʼ αἳ ἄειδον ἀμειβόμεναι ὀπὶ καλῇ.{l]{para]
[para}[l [n}1.605{]}αὐτὰρ ἐπεὶ κατέδυ λαμπρὸν φάος ἠελίοιο,{l]
[l [n}1.606{]}οἳ μὲν κακκείοντες ἔβαν οἶκον δὲ ἕκαστος,{l]
[l [n}1.607{]}ἧχι ἑκάστῳ δῶμα περικλυτὸς ἀμφιγυήεις{l]
[l [n}1.608{]}Ἥφαιστος ποίησεν ἰδυίῃσι πραπίδεσσι·{l]
[l [n}1.609{]}Ζεὺς δὲ πρὸς ὃν λέχος ἤϊʼ Ὀλύμπιος ἀστεροπητής,{l]
[l [n}1.610{]}ἔνθα πάρος κοιμᾶθʼ ὅτε μιν γλυκὺς ὕπνος ἱκάνοι·{l]
[l [n}1.611{]}ἔνθα καθεῦδʼ ἀναβάς, παρὰ δὲ χρυσόθρονος Ἥρη.{l]{para]
{book]
[book [n}2{]}
[para}[l [n}2.1{]}ἄλλοι μέν ῥα θεοί τε καὶ ἀνέρες ἱπποκορυσταὶ{l]
[l [n}2.2{]}εὗδον παννύχιοι, Δία δʼ οὐκ ἔχε νήδυμος ὕπνος,{l]
[l [n}2.3{]}ἀλλʼ ὅ γε μερμήριζε κατὰ φρένα ὡς Ἀχιλῆα{l]
[l [n}2.4{]}τιμήσῃ, ὀλέσῃ δὲ πολέας ἐπὶ νηυσὶν Ἀχαιῶν.{l]
[l [n}2.5{]}ἥδε δέ οἱ κατὰ θυμὸν ἀρίστη φαίνετο βουλή,{l]
[l [n}2.6{]}πέμψαι ἐπʼ Ἀτρεΐδῃ Ἀγαμέμνονι οὖλον ὄνειρον·{l]
[l [n}2.7{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}2.8{]}βάσκʼ ἴθι οὖλε ὄνειρε θοὰς ἐπὶ νῆας Ἀχαιῶν·{l]
[l [n}2.9{]}ἐλθὼν ἐς κλισίην Ἀγαμέμνονος Ἀτρεΐδαο{l]
[l [n}2.10{]}πάντα μάλʼ ἀτρεκέως ἀγορευέμεν ὡς ἐπιτέλλω·{l]
[l [n}2.11{]}θωρῆξαί ἑ κέλευε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.12{]}πανσυδίῃ· νῦν γάρ κεν ἕλοι πόλιν εὐρυάγυιαν{l]
[l [n}2.13{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.14{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.15{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται.{l]{q]{para]
[para}[l [n}2.16{]}ὣς φάτο, βῆ δʼ ἄρʼ ὄνειρος ἐπεὶ τὸν μῦθον ἄκουσε·{l]
[l [n}2.17{]}καρπαλίμως δʼ ἵκανε θοὰς ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}2.18{]}βῆ δʼ ἄρʼ ἐπʼ Ἀτρεΐδην Ἀγαμέμνονα· τὸν δὲ κίχανεν{l]
[l [n}2.19{]}εὕδοντʼ ἐν κλισίῃ, περὶ δʼ ἀμβρόσιος κέχυθʼ ὕπνος.{l]
[l [n}2.20{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς Νηληΐῳ υἷι ἐοικώς{l]
[l [n}2.21{]}Νέστορι, τόν ῥα μάλιστα γερόντων τῖʼ Ἀγαμέμνων·{l]
[l [n}2.22{]}τῷ μιν ἐεισάμενος προσεφώνεε θεῖος ὄνειρος·{l]
[q}[l [n}2.23{]}εὕδεις Ἀτρέος υἱὲ δαΐφρονος ἱπποδάμοιο·{l]
[l [n}2.24{]}οὐ χρὴ παννύχιον εὕδειν βουληφόρον ἄνδρα{l]
[l [n}2.25{]}ᾧ λαοί τʼ ἐπιτετράφαται καὶ τόσσα μέμηλε·{l]
[l [n}2.26{]}νῦν δʼ ἐμέθεν ξύνες ὦκα· Διὸς δέ τοι ἄγγελός εἰμι,{l]
[l [n}2.27{]}ὃς σεῦ ἄνευθεν ἐὼν μέγα κήδεται ἠδʼ ἐλεαίρει.{l]
[l [n}2.28{]}θωρῆξαί σε κέλευσε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.29{]}πανσυδίῃ· νῦν γάρ κεν ἕλοις πόλιν εὐρυάγυιαν{l]
[l [n}2.30{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.31{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.32{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται{l]
[l [n}2.33{]}ἐκ Διός· ἀλλὰ σὺ σῇσιν ἔχε φρεσί, μηδέ σε λήθη{l]
[l [n}2.34{]}αἱρείτω εὖτʼ ἄν σε μελίφρων ὕπνος ἀνήῃ.{l]{q]{para]
[para}[l [n}2.35{]}ὣς ἄρα φωνήσας ἀπεβήσετο, τὸν δὲ λίπʼ αὐτοῦ{l]
[l [n}2.36{]}τὰ φρονέοντʼ ἀνὰ θυμὸν ἅ ῥʼ οὐ τελέεσθαι ἔμελλον·{l]
[l [n}2.37{]}φῆ γὰρ ὅ γʼ αἱρήσειν Πριάμου πόλιν ἤματι κείνῳ{l]
[l [n}2.38{]}νήπιος, οὐδὲ τὰ ᾔδη ἅ ῥα Ζεὺς μήδετο ἔργα·{l]
[l [n}2.39{]}θήσειν γὰρ ἔτʼ ἔμελλεν ἐπʼ ἄλγεά τε στοναχάς τε{l]
[l [n}2.40{]}Τρωσί τε καὶ Δαναοῖσι διὰ κρατερὰς ὑσμίνας.{l]
[l [n}2.41{]}ἔγρετο δʼ ἐξ ὕπνου, θείη δέ μιν ἀμφέχυτʼ ὀμφή·{l]
[l [n}2.42{]}ἕζετο δʼ ὀρθωθείς, μαλακὸν δʼ ἔνδυνε χιτῶνα{l]
[l [n}2.43{]}καλὸν νηγάτεον, περὶ δὲ μέγα βάλλετο φᾶρος·{l]
[l [n}2.44{]}ποσσὶ δʼ ὑπὸ λιπαροῖσιν ἐδήσατο καλὰ πέδιλα,{l]
[l [n}2.45{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον·{l]
[l [n}2.46{]}εἵλετο δὲ σκῆπτρον πατρώϊον ἄφθιτον αἰεὶ{l]
[l [n}2.47{]}σὺν τῷ ἔβη κατὰ νῆας Ἀχαιῶν χαλκοχιτώνων·{l]{para]
[para}[l [n}2.48{]}ἠὼς μέν ῥα θεὰ προσεβήσετο μακρὸν Ὄλυμπον{l]
[l [n}2.49{]}Ζηνὶ φόως ἐρέουσα καὶ ἄλλοις ἀθανάτοισιν·{l]
[l [n}2.50{]}αὐτὰρ ὃ κηρύκεσσι λιγυφθόγγοισι κέλευσε{l]
[l [n}2.51{]}κηρύσσειν ἀγορὴν δὲ κάρη κομόωντας Ἀχαιούς·{l]
[l [n}2.52{]}οἳ μὲν ἐκήρυσσον, τοὶ δʼ ἠγείροντο μάλʼ ὦκα·{l]{para]
[para}[l [n}2.53{]}βουλὴν δὲ πρῶτον μεγαθύμων ἷζε γερόντων{l]
[l [n}2.54{]}Νεστορέῃ παρὰ νηῒ Πυλοιγενέος βασιλῆος·{l]
[l [n}2.55{]}τοὺς ὅ γε συγκαλέσας πυκινὴν ἀρτύνετο βουλήν·{l]
[q}[l [n}2.56{]}κλῦτε φίλοι· θεῖός μοι ἐνύπνιον ἦλθεν ὄνειρος{l]
[l [n}2.57{]}ἀμβροσίην διὰ νύκτα· μάλιστα δὲ Νέστορι δίῳ{l]
[l [n}2.58{]}εἶδός τε μέγεθός τε φυήν τʼ ἄγχιστα ἐῴκει·{l]
[l [n}2.59{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς καί με πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}2.60{]}εὕδεις Ἀτρέος υἱὲ δαΐφρονος ἱπποδάμοιο·{l]
[l [n}2.61{]}οὐ χρὴ παννύχιον εὕδειν βουληφόρον ἄνδρα,{l]
[l [n}2.62{]}ᾧ λαοί τʼ ἐπιτετράφαται καὶ τόσσα μέμηλε·{l]
[l [n}2.63{]}νῦν δʼ ἐμέθεν ξύνες ὦκα· Διὸς δέ τοι ἄγγελός εἰμι,{l]
[l [n}2.64{]}ὃς σεῦ ἄνευθεν ἐὼν μέγα κήδεται ἠδʼ ἐλεαίρει·{l]
[l [n}2.65{]}θωρῆξαί σε κέλευσε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}2.66{]}πανσυδίῃ· νῦν γάρ κεν ἕλοις πόλιν εὐρυάγυιαν{l]
[l [n}2.67{]}Τρώων· οὐ γὰρ ἔτʼ ἀμφὶς Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}2.68{]}ἀθάνατοι φράζονται· ἐπέγναμψεν γὰρ ἅπαντας{l]
[l [n}2.69{]}Ἥρη λισσομένη, Τρώεσσι δὲ κήδεʼ ἐφῆπται{l]
[l [n}2.70{]}ἐκ Διός· ἀλλὰ σὺ σῇσιν ἔχε φρεσίν·{q] ὣς ὃ μὲν εἰπὼν{l]
[l [n}2.71{]}ᾤχετʼ ἀποπτάμενος, ἐμὲ δὲ γλυκὺς ὕπνος ἀνῆκεν.{l]
[l [n}2.72{]}ἀλλʼ ἄγετʼ αἴ κέν πως θωρήξομεν υἷας Ἀχαιῶν·{l]
[l [n}2.73{]}πρῶτα δʼ ἐγὼν ἔπεσιν πειρήσομαι, ἣ θέμις ἐστί,{l]
[l [n}2.74{]}καὶ φεύγειν σὺν νηυσὶ πολυκλήϊσι κελεύσω·{l]
[l [n}2.75{]}ὑμεῖς δʼ ἄλλοθεν ἄλλος ἐρητύειν ἐπέεσσιν.{l]{q]{para]
[para}[l [n}2.76{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο, τοῖσι δʼ ἀνέστη{l]
[l [n}2.77{]}Νέστωρ, ὅς ῥα Πύλοιο ἄναξ ἦν ἠμαθόεντος,{l]
[l [n}2.78{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}2.79{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}2.80{]}εἰ μέν τις τὸν ὄνειρον Ἀχαιῶν ἄλλος ἔνισπε{l]
[l [n}2.81{]}ψεῦδός κεν φαῖμεν καὶ νοσφιζοίμεθα μᾶλλον·{l]
[l [n}2.82{]}νῦν δʼ ἴδεν ὃς μέγʼ ἄριστος Ἀχαιῶν εὔχεται εἶναι·{l]
[l [n}2.83{]}ἀλλʼ ἄγετʼ αἴ κέν πως θωρήξομεν υἷας Ἀχαιῶν.{l]{q]{para]
[para}[l [n}2.84{]}ὣς ἄρα φωνήσας βουλῆς ἐξῆρχε νέεσθαι,{l]
[l [n}2.85{]}οἳ δʼ ἐπανέστησαν πείθοντό τε ποιμένι λαῶν{l]
[l [n}2.86{]}σκηπτοῦχοι βασιλῆες· ἐπεσσεύοντο δὲ λαοί.{l]
[l [n}2.87{]}ἠΰτε ἔθνεα εἶσι μελισσάων ἁδινάων{l]
[l [n}2.88{]}πέτρης ἐκ γλαφυρῆς αἰεὶ νέον ἐρχομενάων,{l]
[l [n}2.89{]}βοτρυδὸν δὲ πέτονται ἐπʼ ἄνθεσιν εἰαρινοῖσιν·{l]
[l [n}2.90{]}αἳ μέν τʼ ἔνθα ἅλις πεποτήαται, αἳ δέ τε ἔνθα·{l]
[l [n}2.91{]}ὣς τῶν ἔθνεα πολλὰ νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.92{]}ἠϊόνος προπάροιθε βαθείης ἐστιχόωντο{l]
[l [n}2.93{]}ἰλαδὸν εἰς ἀγορήν· μετὰ δέ σφισιν ὄσσα δεδήει{l]
[l [n}2.94{]}ὀτρύνουσʼ ἰέναι Διὸς ἄγγελος· οἳ δʼ ἀγέροντο.{l]
[l [n}2.95{]}τετρήχει δʼ ἀγορή, ὑπὸ δὲ στεναχίζετο γαῖα{l]
[l [n}2.96{]}λαῶν ἱζόντων, ὅμαδος δʼ ἦν· ἐννέα δέ σφεας{l]
[l [n}2.97{]}κήρυκες βοόωντες ἐρήτυον, εἴ ποτʼ ἀϋτῆς{l]
[l [n}2.98{]}σχοίατʼ, ἀκούσειαν δὲ διοτρεφέων βασιλήων.{l]
[l [n}2.99{]}σπουδῇ δʼ ἕζετο λαός, ἐρήτυθεν δὲ καθʼ ἕδρας{l]
[l [n}2.100{]}παυσάμενοι κλαγγῆς· ἀνὰ δὲ κρείων Ἀγαμέμνων{l]
[l [n}2.101{]}ἔστη σκῆπτρον ἔχων τὸ μὲν Ἥφαιστος κάμε τεύχων.{l]
[l [n}2.102{]}Ἥφαιστος μὲν δῶκε Διὶ Κρονίωνι ἄνακτι,{l]
[l [n}2.103{]}αὐτὰρ ἄρα Ζεὺς δῶκε διακτόρῳ ἀργεϊφόντῃ·{l]
[l [n}2.104{]}Ἑρμείας δὲ ἄναξ δῶκεν Πέλοπι πληξίππῳ,{l]
[l [n}2.105{]}αὐτὰρ ὃ αὖτε Πέλοψ δῶκʼ Ἀτρέϊ ποιμένι λαῶν,{l]
[l [n}2.106{]}Ἀτρεὺς δὲ θνῄσκων ἔλιπεν πολύαρνι Θυέστῃ,{l]
[l [n}2.107{]}αὐτὰρ ὃ αὖτε Θυέστʼ Ἀγαμέμνονι λεῖπε φορῆναι,{l]
[l [n}2.108{]}πολλῇσιν νήσοισι καὶ Ἄργεϊ παντὶ ἀνάσσειν.{l]
[l [n}2.109{]}τῷ ὅ γʼ ἐρεισάμενος ἔπεʼ Ἀργείοισι μετηύδα·{l]
[q}[l [n}2.110{]}ὦ φίλοι ἥρωες Δαναοὶ θεράποντες Ἄρηος{l]
[l [n}2.111{]}Ζεύς με μέγα Κρονίδης ἄτῃ ἐνέδησε βαρείῃ,{l]
[l [n}2.112{]}σχέτλιος, ὃς πρὶν μέν μοι ὑπέσχετο καὶ κατένευσεν{l]
[l [n}2.113{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι,{l]
[l [n}2.114{]}νῦν δὲ κακὴν ἀπάτην βουλεύσατο, καί με κελεύει{l]
[l [n}2.115{]}δυσκλέα Ἄργος ἱκέσθαι, ἐπεὶ πολὺν ὤλεσα λαόν.{l]
[l [n}2.116{]}οὕτω που Διὶ μέλλει ὑπερμενέϊ φίλον εἶναι,{l]
[l [n}2.117{]}ὃς δὴ πολλάων πολίων κατέλυσε κάρηνα{l]
[l [n}2.118{]}ἠδʼ ἔτι καὶ λύσει· τοῦ γὰρ κράτος ἐστὶ μέγιστον.{l]
[l [n}2.119{]}αἰσχρὸν γὰρ τόδε γʼ ἐστὶ καὶ ἐσσομένοισι πυθέσθαι{l]
[l [n}2.120{]}μὰψ οὕτω τοιόνδε τοσόνδε τε λαὸν Ἀχαιῶν{l]
[l [n}2.121{]}ἄπρηκτον πόλεμον πολεμίζειν ἠδὲ μάχεσθαι{l]
[l [n}2.122{]}ἀνδράσι παυροτέροισι, τέλος δʼ οὔ πώ τι πέφανται·{l]
[l [n}2.123{]}εἴ περ γάρ κʼ ἐθέλοιμεν Ἀχαιοί τε Τρῶές τε{l]
[l [n}2.124{]}ὅρκια πιστὰ ταμόντες ἀριθμηθήμεναι ἄμφω,{l]
[l [n}2.125{]}Τρῶας μὲν λέξασθαι ἐφέστιοι ὅσσοι ἔασιν,{l]
[l [n}2.126{]}ἡμεῖς δʼ ἐς δεκάδας διακοσμηθεῖμεν Ἀχαιοί,{l]
[l [n}2.127{]}Τρώων δʼ ἄνδρα ἕκαστοι ἑλοίμεθα οἰνοχοεύειν,{l]
[l [n}2.128{]}πολλαί κεν δεκάδες δευοίατο οἰνοχόοιο.{l]
[l [n}2.129{]}τόσσον ἐγώ φημι πλέας ἔμμεναι υἷας Ἀχαιῶν{l]
[l [n}2.130{]}Τρώων, οἳ ναίουσι κατὰ πτόλιν· ἀλλʼ ἐπίκουροι{l]
[l [n}2.131{]}πολλέων ἐκ πολίων ἐγχέσπαλοι ἄνδρες ἔασιν,{l]
[l [n}2.132{]}οἵ με μέγα πλάζουσι καὶ οὐκ εἰῶσʼ ἐθέλοντα{l]
[l [n}2.133{]}Ἰλίου ἐκπέρσαι εὖ ναιόμενον πτολίεθρον.{l]
[l [n}2.134{]}ἐννέα δὴ βεβάασι Διὸς μεγάλου ἐνιαυτοί,{l]
[l [n}2.135{]}καὶ δὴ δοῦρα σέσηπε νεῶν καὶ σπάρτα λέλυνται·{l]
[l [n}2.136{]}αἳ δέ που ἡμέτεραί τʼ ἄλοχοι καὶ νήπια τέκνα{l]
[l [n}2.137{]}εἵατʼ ἐνὶ μεγάροις ποτιδέγμεναι· ἄμμι δὲ ἔργον{l]
[l [n}2.138{]}αὔτως ἀκράαντον οὗ εἵνεκα δεῦρʼ ἱκόμεσθα.{l]
[l [n}2.139{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}2.140{]}φεύγωμεν σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν·{l]
[l [n}2.141{]}οὐ γὰρ ἔτι Τροίην αἱρήσομεν εὐρυάγυιαν.{l]{q]{para]
[para}[l [n}2.142{]}ὣς φάτο, τοῖσι δὲ θυμὸν ἐνὶ στήθεσσιν ὄρινε{l]
[l [n}2.143{]}πᾶσι μετὰ πληθὺν ὅσοι οὐ βουλῆς ἐπάκουσαν·{l]
[l [n}2.144{]}κινήθη δʼ ἀγορὴ φὴ κύματα μακρὰ θαλάσσης{l]
[l [n}2.145{]}πόντου Ἰκαρίοιο, τὰ μέν τʼ Εὖρός τε Νότος τε{l]
[l [n}2.146{]}ὤρορʼ ἐπαΐξας πατρὸς Διὸς ἐκ νεφελάων.{l]
[l [n}2.147{]}ὡς δʼ ὅτε κινήσῃ Ζέφυρος βαθὺ λήϊον ἐλθὼν{l]
[l [n}2.148{]}λάβρος ἐπαιγίζων, ἐπί τʼ ἠμύει ἀσταχύεσσιν,{l]
[l [n}2.149{]}ὣς τῶν πᾶσʼ ἀγορὴ κινήθη· τοὶ δʼ ἀλαλητῷ{l]
[l [n}2.150{]}νῆας ἔπʼ ἐσσεύοντο, ποδῶν δʼ ὑπένερθε κονίη{l]
[l [n}2.151{]}ἵστατʼ ἀειρομένη· τοὶ δʼ ἀλλήλοισι κέλευον{l]
[l [n}2.152{]}ἅπτεσθαι νηῶν ἠδʼ ἑλκέμεν εἰς ἅλα δῖαν,{l]
[l [n}2.153{]}οὐρούς τʼ ἐξεκάθαιρον· ἀϋτὴ δʼ οὐρανὸν ἷκεν{l]
[l [n}2.154{]}οἴκαδε ἱεμένων· ὑπὸ δʼ ᾕρεον ἕρματα νηῶν.{l]{para]
[para}[l [n}2.155{]}ἔνθά κεν Ἀργείοισιν ὑπέρμορα νόστος ἐτύχθη{l]
[l [n}2.156{]}εἰ μὴ Ἀθηναίην Ἥρη πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}2.157{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος Ἀτρυτώνη,{l]
[l [n}2.158{]}οὕτω δὴ οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}2.159{]}Ἀργεῖοι φεύξονται ἐπʼ εὐρέα νῶτα θαλάσσης,{l]
[l [n}2.160{]}κὰδ δέ κεν εὐχωλὴν Πριάμῳ καὶ Τρωσὶ λίποιεν{l]
[l [n}2.161{]}Ἀργείην Ἑλένην, ἧς εἵνεκα πολλοὶ Ἀχαιῶν{l]
[l [n}2.162{]}ἐν Τροίῃ ἀπόλοντο φίλης ἀπὸ πατρίδος αἴης·{l]
[l [n}2.163{]}ἀλλʼ ἴθι νῦν κατὰ λαὸν Ἀχαιῶν χαλκοχιτώνων·{l]
[l [n}2.164{]}σοῖς ἀγανοῖς ἐπέεσσιν ἐρήτυε φῶτα ἕκαστον,{l]
[l [n}2.165{]}μηδὲ ἔα νῆας ἅλα δʼ ἑλκέμεν ἀμφιελίσσας.{l]{q]{para]
[para}[l [n}2.166{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ γλαυκῶπις Ἀθήνη,{l]
[l [n}2.167{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων ἀΐξασα·{l]
[l [n}2.168{]}καρπαλίμως δʼ ἵκανε θοὰς ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}2.169{]}εὗρεν ἔπειτʼ Ὀδυσῆα Διὶ μῆτιν ἀτάλαντον{l]
[l [n}2.170{]}ἑσταότʼ· οὐδʼ ὅ γε νηὸς ἐϋσσέλμοιο μελαίνης{l]
[l [n}2.171{]}ἅπτετʼ, ἐπεί μιν ἄχος κραδίην καὶ θυμὸν ἵκανεν·{l]
[l [n}2.172{]}ἀγχοῦ δʼ ἱσταμένη προσέφη γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}2.173{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ,{l]
[l [n}2.174{]}οὕτω δὴ οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}2.175{]}φεύξεσθʼ ἐν νήεσσι πολυκλήϊσι πεσόντες,{l]
[l [n}2.176{]}κὰδ δέ κεν εὐχωλὴν Πριάμῳ καὶ Τρωσὶ λίποιτε{l]
[l [n}2.177{]}Ἀργείην Ἑλένην, ἧς εἵνεκα πολλοὶ Ἀχαιῶν{l]
[l [n}2.178{]}ἐν Τροίῃ ἀπόλοντο φίλης ἀπὸ πατρίδος αἴης;{l]
[l [n}2.179{]}ἀλλʼ ἴθι νῦν κατὰ λαὸν Ἀχαιῶν, μηδʼ ἔτʼ ἐρώει,{l]
[l [n}2.180{]}σοῖς δʼ ἀγανοῖς ἐπέεσσιν ἐρήτυε φῶτα ἕκαστον,{l]
[l [n}2.181{]}μηδὲ ἔα νῆας ἅλα δʼ ἑλκέμεν ἀμφιελίσσας.{l]{q]{para]
[para}[l [n}2.182{]}ὣς φάθʼ, ὃ δὲ ξυνέηκε θεᾶς ὄπα φωνησάσης,{l]
[l [n}2.183{]}βῆ δὲ θέειν, ἀπὸ δὲ χλαῖναν βάλε· τὴν δὲ κόμισσε{l]
[l [n}2.184{]}κῆρυξ Εὐρυβάτης Ἰθακήσιος ὅς οἱ ὀπήδει·{l]
[l [n}2.185{]}αὐτὸς δʼ Ἀτρεΐδεω Ἀγαμέμνονος ἀντίος ἐλθὼν{l]
[l [n}2.186{]}δέξατό οἱ σκῆπτρον πατρώϊον ἄφθιτον αἰεί·{l]
[l [n}2.187{]}σὺν τῷ ἔβη κατὰ νῆας Ἀχαιῶν χαλκοχιτώνων.{l]{para]
[para}[l [n}2.188{]}ὅν τινα μὲν βασιλῆα καὶ ἔξοχον ἄνδρα κιχείη{l]
[l [n}2.189{]}τὸν δʼ ἀγανοῖς ἐπέεσσιν ἐρητύσασκε παραστάς·{l]
[q}[l [n}2.190{]}δαιμόνιʼ οὔ σε ἔοικε κακὸν ὣς δειδίσσεσθαι,{l]
[l [n}2.191{]}ἀλλʼ αὐτός τε κάθησο καὶ ἄλλους ἵδρυε λαούς·{l]
[l [n}2.192{]}οὐ γάρ πω σάφα οἶσθʼ οἷος νόος Ἀτρεΐωνος·{l]
[l [n}2.193{]}νῦν μὲν πειρᾶται, τάχα δʼ ἴψεται υἷας Ἀχαιῶν.{l]
[l [n}2.194{]}ἐν βουλῇ δʼ οὐ πάντες ἀκούσαμεν οἷον ἔειπε.{l]
[l [n}2.195{]}μή τι χολωσάμενος ῥέξῃ κακὸν υἷας Ἀχαιῶν·{l]
[l [n}2.196{]}θυμὸς δὲ μέγας ἐστὶ διοτρεφέων βασιλήων,{l]
[l [n}2.197{]}τιμὴ δʼ ἐκ Διός ἐστι, φιλεῖ δέ ἑ μητίετα Ζεύς.{l]{q]{para]
[para}[l [n}2.198{]}ὃν δʼ αὖ δήμου τʼ ἄνδρα ἴδοι βοόωντά τʼ ἐφεύροι,{l]
[l [n}2.199{]}τὸν σκήπτρῳ ἐλάσασκεν ὁμοκλήσασκέ τε μύθῳ·{l]
[q}[l [n}2.200{]}δαιμόνιʼ ἀτρέμας ἧσο καὶ ἄλλων μῦθον ἄκουε,{l]
[l [n}2.201{]}οἳ σέο φέρτεροί εἰσι, σὺ δʼ ἀπτόλεμος καὶ ἄναλκις{l]
[l [n}2.202{]}οὔτέ ποτʼ ἐν πολέμῳ ἐναρίθμιος οὔτʼ ἐνὶ βουλῇ·{l]
[l [n}2.203{]}οὐ μέν πως πάντες βασιλεύσομεν ἐνθάδʼ Ἀχαιοί·{l]
[l [n}2.204{]}οὐκ ἀγαθὸν πολυκοιρανίη· εἷς κοίρανος ἔστω,{l]
[l [n}2.205{]}εἷς βασιλεύς, ᾧ δῶκε Κρόνου πάϊς ἀγκυλομήτεω{l]
[l [n}2.206{]}σκῆπτρόν τʼ ἠδὲ θέμιστας, ἵνά σφισι βουλεύῃσι.{l]{q]{para]
[para}[l [n}2.207{]}ὣς ὅ γε κοιρανέων δίεπε στρατόν· οἳ δʼ ἀγορὴν δὲ{l]
[l [n}2.208{]}αὖτις ἐπεσσεύοντο νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.209{]}ἠχῇ, ὡς ὅτε κῦμα πολυφλοίσβοιο θαλάσσης{l]
[l [n}2.210{]}αἰγιαλῷ μεγάλῳ βρέμεται, σμαραγεῖ δέ τε πόντος.{l]{para]
[para}[l [n}2.211{]}ἄλλοι μέν ῥʼ ἕζοντο, ἐρήτυθεν δὲ καθʼ ἕδρας·{l]
[l [n}2.212{]}Θερσίτης δʼ ἔτι μοῦνος ἀμετροεπὴς ἐκολῴα,{l]
[l [n}2.213{]}ὃς ἔπεα φρεσὶν ᾗσιν ἄκοσμά τε πολλά τε ᾔδη{l]
[l [n}2.214{]}μάψ, ἀτὰρ οὐ κατὰ κόσμον, ἐριζέμεναι βασιλεῦσιν,{l]
[l [n}2.215{]}ἀλλʼ ὅ τι οἱ εἴσαιτο γελοίϊον Ἀργείοισιν{l]
[l [n}2.216{]}ἔμμεναι· αἴσχιστος δὲ ἀνὴρ ὑπὸ Ἴλιον ἦλθε·{l]
[l [n}2.217{]}φολκὸς ἔην, χωλὸς δʼ ἕτερον πόδα· τὼ δέ οἱ ὤμω{l]
[l [n}2.218{]}κυρτὼ ἐπὶ στῆθος συνοχωκότε· αὐτὰρ ὕπερθε{l]
[l [n}2.219{]}φοξὸς ἔην κεφαλήν, ψεδνὴ δʼ ἐπενήνοθε λάχνη.{l]
[l [n}2.220{]}ἔχθιστος δʼ Ἀχιλῆϊ μάλιστʼ ἦν ἠδʼ Ὀδυσῆϊ·{l]
[l [n}2.221{]}τὼ γὰρ νεικείεσκε· τότʼ αὖτʼ Ἀγαμέμνονι δίῳ{l]
[l [n}2.222{]}ὀξέα κεκλήγων λέγʼ ὀνείδεα· τῷ δʼ ἄρʼ Ἀχαιοὶ{l]
[l [n}2.223{]}ἐκπάγλως κοτέοντο νεμέσσηθέν τʼ ἐνὶ θυμῷ.{l]
[l [n}2.224{]}αὐτὰρ ὃ μακρὰ βοῶν Ἀγαμέμνονα νείκεε μύθῳ·{l]
[q}[l [n}2.225{]}Ἀτρεΐδη τέο δʼ αὖτʼ ἐπιμέμφεαι ἠδὲ χατίζεις;{l]
[l [n}2.226{]}πλεῖαί τοι χαλκοῦ κλισίαι, πολλαὶ δὲ γυναῖκες{l]
[l [n}2.227{]}εἰσὶν ἐνὶ κλισίῃς ἐξαίρετοι, ἅς τοι Ἀχαιοὶ{l]
[l [n}2.228{]}πρωτίστῳ δίδομεν εὖτʼ ἂν πτολίεθρον ἕλωμεν.{l]
[l [n}2.229{]}ἦ ἔτι καὶ χρυσοῦ ἐπιδεύεαι, ὅν κέ τις οἴσει{l]
[l [n}2.230{]}Τρώων ἱπποδάμων ἐξ Ἰλίου υἷος ἄποινα,{l]
[l [n}2.231{]}ὅν κεν ἐγὼ δήσας ἀγάγω ἢ ἄλλος Ἀχαιῶν,{l]
[l [n}2.232{]}ἠὲ γυναῖκα νέην, ἵνα μίσγεαι ἐν φιλότητι,{l]
[l [n}2.233{]}ἥν τʼ αὐτὸς ἀπονόσφι κατίσχεαι; οὐ μὲν ἔοικεν{l]
[l [n}2.234{]}ἀρχὸν ἐόντα κακῶν ἐπιβασκέμεν υἷας Ἀχαιῶν.{l]
[l [n}2.235{]}ὦ πέπονες κάκʼ ἐλέγχεʼ Ἀχαιΐδες οὐκέτʼ Ἀχαιοὶ{l]
[l [n}2.236{]}οἴκαδέ περ σὺν νηυσὶ νεώμεθα, τόνδε δʼ ἐῶμεν{l]
[l [n}2.237{]}αὐτοῦ ἐνὶ Τροίῃ γέρα πεσσέμεν, ὄφρα ἴδηται{l]
[l [n}2.238{]}ἤ ῥά τί οἱ χἠμεῖς προσαμύνομεν ἦε καὶ οὐκί·{l]
[l [n}2.239{]}ὃς καὶ νῦν Ἀχιλῆα ἕο μέγʼ ἀμείνονα φῶτα{l]
[l [n}2.240{]}ἠτίμησεν· ἑλὼν γὰρ ἔχει γέρας αὐτὸς ἀπούρας.{l]
[l [n}2.241{]}ἀλλὰ μάλʼ οὐκ Ἀχιλῆϊ χόλος φρεσίν, ἀλλὰ μεθήμων·{l]
[l [n}2.242{]}ἦ γὰρ ἂν Ἀτρεΐδη νῦν ὕστατα λωβήσαιο·{l]{q]{para]
[para}[l [n}2.243{]}ὣς φάτο νεικείων Ἀγαμέμνονα ποιμένα λαῶν,{l]
[l [n}2.244{]}Θερσίτης· τῷ δʼ ὦκα παρίστατο δῖος Ὀδυσσεύς,{l]
[l [n}2.245{]}καί μιν ὑπόδρα ἰδὼν χαλεπῷ ἠνίπαπε μύθῳ·{l]
[q}[l [n}2.246{]}Θερσῖτʼ ἀκριτόμυθε, λιγύς περ ἐὼν ἀγορητής,{l]
[l [n}2.247{]}ἴσχεο, μηδʼ ἔθελʼ οἶος ἐριζέμεναι βασιλεῦσιν·{l]
[l [n}2.248{]}οὐ γὰρ ἐγὼ σέο φημὶ χερειότερον βροτὸν ἄλλον{l]
[l [n}2.249{]}ἔμμεναι, ὅσσοι ἅμʼ Ἀτρεΐδῃς ὑπὸ Ἴλιον ἦλθον.{l]
[l [n}2.250{]}τὼ οὐκ ἂν βασιλῆας ἀνὰ στόμʼ ἔχων ἀγορεύοις,{l]
[l [n}2.251{]}καί σφιν ὀνείδεά τε προφέροις, νόστόν τε φυλάσσοις.{l]
[l [n}2.252{]}οὐδέ τί πω σάφα ἴδμεν ὅπως ἔσται τάδε ἔργα,{l]
[l [n}2.253{]}ἢ εὖ ἦε κακῶς νοστήσομεν υἷες Ἀχαιῶν.{l]
[l [n}2.254{]}τὼ νῦν Ἀτρεΐδῃ Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}2.255{]}ἧσαι ὀνειδίζων, ὅτι οἱ μάλα πολλὰ διδοῦσιν{l]
[l [n}2.256{]}ἥρωες Δαναοί· σὺ δὲ κερτομέων ἀγορεύεις.{l]
[l [n}2.257{]}ἀλλʼ ἔκ τοι ἐρέω, τὸ δὲ καὶ τετελεσμένον ἔσται·{l]
[l [n}2.258{]}εἴ κʼ ἔτι σʼ ἀφραίνοντα κιχήσομαι ὥς νύ περ ὧδε,{l]
[l [n}2.259{]}μηκέτʼ ἔπειτʼ Ὀδυσῆϊ κάρη ὤμοισιν ἐπείη,{l]
[l [n}2.260{]}μηδʼ ἔτι Τηλεμάχοιο πατὴρ κεκλημένος εἴην,{l]
[l [n}2.261{]}εἰ μὴ ἐγώ σε λαβὼν ἀπὸ μὲν φίλα εἵματα δύσω,{l]
[l [n}2.262{]}χλαῖνάν τʼ ἠδὲ χιτῶνα, τά τʼ αἰδῶ ἀμφικαλύπτει,{l]
[l [n}2.263{]}αὐτὸν δὲ κλαίοντα θοὰς ἐπὶ νῆας ἀφήσω{l]
[l [n}2.264{]}πεπλήγων ἀγορῆθεν ἀεικέσσι πληγῇσιν.{l]{q]{para]
[para}[l [n}2.265{]}ὣς ἄρʼ ἔφη, σκήπτρῳ δὲ μετάφρενον ἠδὲ καὶ ὤμω{l]
[l [n}2.266{]}πλῆξεν· ὃ δʼ ἰδνώθη, θαλερὸν δέ οἱ ἔκπεσε δάκρυ·{l]
[l [n}2.267{]}σμῶδιξ δʼ αἱματόεσσα μεταφρένου ἐξυπανέστη{l]
[l [n}2.268{]}σκήπτρου ὕπο χρυσέου· ὃ δʼ ἄρʼ ἕζετο τάρβησέν τε,{l]
[l [n}2.269{]}ἀλγήσας δʼ ἀχρεῖον ἰδὼν ἀπομόρξατο δάκρυ.{l]
[l [n}2.270{]}οἳ δὲ καὶ ἀχνύμενοί περ ἐπʼ αὐτῷ ἡδὺ γέλασσαν·{l]
[l [n}2.271{]}ὧδε δέ τις εἴπεσκεν ἰδὼν ἐς πλησίον ἄλλον·{l]
[q}[l [n}2.272{]}ὢ πόποι ἦ δὴ μυρίʼ Ὀδυσσεὺς ἐσθλὰ ἔοργε{l]
[l [n}2.273{]}βουλάς τʼ ἐξάρχων ἀγαθὰς πόλεμόν τε κορύσσων·{l]
[l [n}2.274{]}νῦν δὲ τόδε μέγʼ ἄριστον ἐν Ἀργείοισιν ἔρεξεν,{l]
[l [n}2.275{]}ὃς τὸν λωβητῆρα ἐπεσβόλον ἔσχʼ ἀγοράων.{l]
[l [n}2.276{]}οὔ θήν μιν πάλιν αὖτις ἀνήσει θυμὸς ἀγήνωρ{l]
[l [n}2.277{]}νεικείειν βασιλῆας ὀνειδείοις ἐπέεσσιν.{l]{q]{para]
[para}[l [n}2.278{]}ὣς φάσαν ἣ πληθύς· ἀνὰ δʼ ὃ πτολίπορθος Ὀδυσσεὺς{l]
[l [n}2.279{]}ἔστη σκῆπτρον ἔχων· παρὰ δὲ γλαυκῶπις Ἀθήνη{l]
[l [n}2.280{]}εἰδομένη κήρυκι σιωπᾶν λαὸν ἀνώγει,{l]
[l [n}2.281{]}ὡς ἅμα θʼ οἳ πρῶτοί τε καὶ ὕστατοι υἷες Ἀχαιῶν{l]
[l [n}2.282{]}μῦθον ἀκούσειαν καὶ ἐπιφρασσαίατο βουλήν·{l]
[l [n}2.283{]}ὅ σφιν ἐὺ φρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}2.284{]}Ἀτρεΐδη νῦν δή σε ἄναξ ἐθέλουσιν Ἀχαιοὶ{l]
[l [n}2.285{]}πᾶσιν ἐλέγχιστον θέμεναι μερόπεσσι βροτοῖσιν,{l]
[l [n}2.286{]}οὐδέ τοι ἐκτελέουσιν ὑπόσχεσιν ἥν περ ὑπέσταν{l]
[l [n}2.287{]}ἐνθάδʼ ἔτι στείχοντες ἀπʼ Ἄργεος ἱπποβότοιο{l]
[l [n}2.288{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι.{l]
[l [n}2.289{]}ὥς τε γὰρ ἢ παῖδες νεαροὶ χῆραί τε γυναῖκες{l]
[l [n}2.290{]}ἀλλήλοισιν ὀδύρονται οἶκον δὲ νέεσθαι.{l]
[l [n}2.291{]}ἦ μὴν καὶ πόνος ἐστὶν ἀνιηθέντα νέεσθαι·{l]
[l [n}2.292{]}καὶ γάρ τίς θʼ ἕνα μῆνα μένων ἀπὸ ἧς ἀλόχοιο{l]
[l [n}2.293{]}ἀσχαλάᾳ σὺν νηῒ πολυζύγῳ, ὅν περ ἄελλαι{l]
[l [n}2.294{]}χειμέριαι εἰλέωσιν ὀρινομένη τε θάλασσα·{l]
[l [n}2.295{]}ἡμῖν δʼ εἴνατός ἐστι περιτροπέων ἐνιαυτὸς{l]
[l [n}2.296{]}ἐνθάδε μιμνόντεσσι· τὼ οὐ νεμεσίζομʼ Ἀχαιοὺς{l]
[l [n}2.297{]}ἀσχαλάαν παρὰ νηυσὶ κορωνίσιν· ἀλλὰ καὶ ἔμπης{l]
[l [n}2.298{]}αἰσχρόν τοι δηρόν τε μένειν κενεόν τε νέεσθαι.{l]
[l [n}2.299{]}τλῆτε φίλοι, καὶ μείνατʼ ἐπὶ χρόνον ὄφρα δαῶμεν{l]
[l [n}2.300{]}ἢ ἐτεὸν Κάλχας μαντεύεται ἦε καὶ οὐκί.{l]
[l [n}2.301{]}εὖ γὰρ δὴ τόδε ἴδμεν ἐνὶ φρεσίν, ἐστὲ δὲ πάντες{l]
[l [n}2.302{]}μάρτυροι, οὓς μὴ κῆρες ἔβαν θανάτοιο φέρουσαι·{l]
[l [n}2.303{]}χθιζά τε καὶ πρωΐζʼ ὅτʼ ἐς Αὐλίδα νῆες Ἀχαιῶν{l]
[l [n}2.304{]}ἠγερέθοντο κακὰ Πριάμῳ καὶ Τρωσὶ φέρουσαι,{l]
[l [n}2.305{]}ἡμεῖς δʼ ἀμφὶ περὶ κρήνην ἱεροὺς κατὰ βωμοὺς{l]
[l [n}2.306{]}ἕρδομεν ἀθανάτοισι τεληέσσας ἑκατόμβας{l]
[l [n}2.307{]}καλῇ ὑπὸ πλατανίστῳ ὅθεν ῥέεν ἀγλαὸν ὕδωρ·{l]
[l [n}2.308{]}ἔνθʼ ἐφάνη μέγα σῆμα· δράκων ἐπὶ νῶτα δαφοινὸς{l]
[l [n}2.309{]}σμερδαλέος, τόν ῥʼ αὐτὸς Ὀλύμπιος ἧκε φόως δέ,{l]
[l [n}2.310{]}βωμοῦ ὑπαΐξας πρός ῥα πλατάνιστον ὄρουσεν.{l]
[l [n}2.311{]}ἔνθα δʼ ἔσαν στρουθοῖο νεοσσοί, νήπια τέκνα,{l]
[l [n}2.312{]}ὄζῳ ἐπʼ ἀκροτάτῳ πετάλοις ὑποπεπτηῶτες{l]
[l [n}2.313{]}ὀκτώ, ἀτὰρ μήτηρ ἐνάτη ἦν ἣ τέκε τέκνα·{l]
[l [n}2.314{]}ἔνθʼ ὅ γε τοὺς ἐλεεινὰ κατήσθιε τετριγῶτας·{l]
[l [n}2.315{]}μήτηρ δʼ ἀμφεποτᾶτο ὀδυρομένη φίλα τέκνα·{l]
[l [n}2.316{]}τὴν δʼ ἐλελιξάμενος πτέρυγος λάβεν ἀμφιαχυῖαν.{l]
[l [n}2.317{]}αὐτὰρ ἐπεὶ κατὰ τέκνα φάγε στρουθοῖο καὶ αὐτήν,{l]
[l [n}2.318{]}τὸν μὲν ἀρίζηλον θῆκεν θεὸς ὅς περ ἔφηνε·{l]
[l [n}2.319{]}λᾶαν γάρ μιν ἔθηκε Κρόνου πάϊς ἀγκυλομήτεω·{l]
[l [n}2.320{]}ἡμεῖς δʼ ἑσταότες θαυμάζομεν οἷον ἐτύχθη.{l]
[l [n}2.321{]}ὡς οὖν δεινὰ πέλωρα θεῶν εἰσῆλθʼ ἑκατόμβας,{l]
[l [n}2.322{]}Κάλχας δʼ αὐτίκʼ ἔπειτα θεοπροπέων ἀγόρευε·{l]
[q}[l [n}2.323{]}τίπτʼ ἄνεῳ ἐγένεσθε κάρη κομόωντες Ἀχαιοί;{l]
[l [n}2.324{]}ἡμῖν μὲν τόδʼ ἔφηνε τέρας μέγα μητίετα Ζεὺς{l]
[l [n}2.325{]}ὄψιμον ὀψιτέλεστον, ὅου κλέος οὔ ποτʼ ὀλεῖται.{l]
[l [n}2.326{]}ὡς οὗτος κατὰ τέκνα φάγε στρουθοῖο καὶ αὐτὴν{l]
[l [n}2.327{]}ὀκτώ, ἀτὰρ μήτηρ ἐνάτη ἦν ἣ τέκε τέκνα,{l]
[l [n}2.328{]}ὣς ἡμεῖς τοσσαῦτʼ ἔτεα πτολεμίξομεν αὖθι,{l]
[l [n}2.329{]}τῷ δεκάτῳ δὲ πόλιν αἱρήσομεν εὐρυάγυιαν.{l]{q][l [n}2.330{]}κεῖνος τὼς ἀγόρευε· τὰ δὴ νῦν πάντα τελεῖται.{l]
[l [n}2.331{]}ἀλλʼ ἄγε μίμνετε πάντες ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}2.332{]}αὐτοῦ εἰς ὅ κεν ἄστυ μέγα Πριάμοιο ἕλωμεν.{l]{q]{para]
[para}[l [n}2.333{]}ὣς ἔφατʼ, Ἀργεῖοι δὲ μέγʼ ἴαχον, ἀμφὶ δὲ νῆες{l]
[l [n}2.334{]}σμερδαλέον κονάβησαν ἀϋσάντων ὑπʼ Ἀχαιῶν,{l]
[l [n}2.335{]}μῦθον ἐπαινήσαντες Ὀδυσσῆος θείοιο·{l]
[l [n}2.336{]}τοῖσι δὲ καὶ μετέειπε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}2.337{]}ὦ πόποι ἦ δὴ παισὶν ἐοικότες ἀγοράασθε{l]
[l [n}2.338{]}νηπιάχοις οἷς οὔ τι μέλει πολεμήϊα ἔργα.{l]
[l [n}2.339{]}πῇ δὴ συνθεσίαι τε καὶ ὅρκια βήσεται ἥμιν;{l]
[l [n}2.340{]}ἐν πυρὶ δὴ βουλαί τε γενοίατο μήδεά τʼ ἀνδρῶν{l]
[l [n}2.341{]}σπονδαί τʼ ἄκρητοι καὶ δεξιαί, ᾗς ἐπέπιθμεν·{l]
[l [n}2.342{]}αὔτως γὰρ ἐπέεσσʼ ἐριδαίνομεν, οὐδέ τι μῆχος{l]
[l [n}2.343{]}εὑρέμεναι δυνάμεσθα, πολὺν χρόνον ἐνθάδʼ ἐόντες.{l]
[l [n}2.344{]}Ἀτρεΐδη σὺ δʼ ἔθʼ ὡς πρὶν ἔχων ἀστεμφέα βουλὴν{l]
[l [n}2.345{]}ἄρχευʼ Ἀργείοισι κατὰ κρατερὰς ὑσμίνας,{l]
[l [n}2.346{]}τούσδε δʼ ἔα φθινύθειν ἕνα καὶ δύο, τοί κεν Ἀχαιῶν{l]
[l [n}2.347{]}νόσφιν βουλεύωσʼ· ἄνυσις δʼ οὐκ ἔσσεται αὐτῶν·{l]
[l [n}2.348{]}πρὶν Ἄργος δʼ ἰέναι πρὶν καὶ Διὸς αἰγιόχοιο{l]
[l [n}2.349{]}γνώμεναι εἴ τε ψεῦδος ὑπόσχεσις εἴ τε καὶ οὐκί.{l]
[l [n}2.350{]}φημὶ γὰρ οὖν κατανεῦσαι ὑπερμενέα Κρονίωνα{l]
[l [n}2.351{]}ἤματι τῷ ὅτε νηυσὶν ἐν ὠκυπόροισιν ἔβαινον{l]
[l [n}2.352{]}Ἀργεῖοι Τρώεσσι φόνον καὶ κῆρα φέροντες{l]
[l [n}2.353{]}ἀστράπτων ἐπιδέξιʼ ἐναίσιμα σήματα φαίνων.{l]
[l [n}2.354{]}τὼ μή τις πρὶν ἐπειγέσθω οἶκον δὲ νέεσθαι{l]
[l [n}2.355{]}πρίν τινα πὰρ Τρώων ἀλόχῳ κατακοιμηθῆναι,{l]
[l [n}2.356{]}τίσασθαι δʼ Ἑλένης ὁρμήματά τε στοναχάς τε.{l]
[l [n}2.357{]}εἰ δέ τις ἐκπάγλως ἐθέλει οἶκον δὲ νέεσθαι{l]
[l [n}2.358{]}ἁπτέσθω ἧς νηὸς ἐϋσσέλμοιο μελαίνης,{l]
[l [n}2.359{]}ὄφρα πρόσθʼ ἄλλων θάνατον καὶ πότμον ἐπίσπῃ.{l]
[l [n}2.360{]}ἀλλὰ ἄναξ αὐτός τʼ εὖ μήδεο πείθεό τʼ ἄλλῳ·{l]
[l [n}2.361{]}οὔ τοι ἀπόβλητον ἔπος ἔσσεται ὅττί κεν εἴπω·{l]
[l [n}2.362{]}κρῖνʼ ἄνδρας κατὰ φῦλα κατὰ φρήτρας Ἀγάμεμνον,{l]
[l [n}2.363{]}ὡς φρήτρη φρήτρηφιν ἀρήγῃ, φῦλα δὲ φύλοις.{l]
[l [n}2.364{]}εἰ δέ κεν ὣς ἕρξῃς καί τοι πείθωνται Ἀχαιοί,{l]
[l [n}2.365{]}γνώσῃ ἔπειθʼ ὅς θʼ ἡγεμόνων κακὸς ὅς τέ νυ λαῶν{l]
[l [n}2.366{]}ἠδʼ ὅς κʼ ἐσθλὸς ἔῃσι· κατὰ σφέας γὰρ μαχέονται.{l]
[l [n}2.367{]}γνώσεαι δʼ εἰ καὶ θεσπεσίῃ πόλιν οὐκ ἀλαπάξεις,{l]
[l [n}2.368{]}ἦ ἀνδρῶν κακότητι καὶ ἀφραδίῃ πολέμοιο.{l]{q]{para]
[para}[l [n}2.369{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}2.370{]}ἦ μὰν αὖτʼ ἀγορῇ νικᾷς γέρον υἷας Ἀχαιῶν.{l]
[l [n}2.371{]}αἲ γὰρ Ζεῦ τε πάτερ καὶ Ἀθηναίη καὶ Ἄπολλον{l]
[l [n}2.372{]}τοιοῦτοι δέκα μοι συμφράδμονες εἶεν Ἀχαιῶν·{l]
[l [n}2.373{]}τώ κε τάχʼ ἠμύσειε πόλις Πριάμοιο ἄνακτος{l]
[l [n}2.374{]}χερσὶν ὑφʼ ἡμετέρῃσιν ἁλοῦσά τε περθομένη τε.{l]
[l [n}2.375{]}ἀλλά μοι αἰγίοχος Κρονίδης Ζεὺς ἄλγεʼ ἔδωκεν,{l]
[l [n}2.376{]}ὅς με μετʼ ἀπρήκτους ἔριδας καὶ νείκεα βάλλει.{l]
[l [n}2.377{]}καὶ γὰρ ἐγὼν Ἀχιλεύς τε μαχεσσάμεθʼ εἵνεκα κούρης{l]
[l [n}2.378{]}ἀντιβίοις ἐπέεσσιν, ἐγὼ δʼ ἦρχον χαλεπαίνων·{l]
[l [n}2.379{]}εἰ δέ ποτʼ ἔς γε μίαν βουλεύσομεν, οὐκέτʼ ἔπειτα{l]
[l [n}2.380{]}Τρωσὶν ἀνάβλησις κακοῦ ἔσσεται οὐδʼ ἠβαιόν.{l]
[l [n}2.381{]}νῦν δʼ ἔρχεσθʼ ἐπὶ δεῖπνον ἵνα ξυνάγωμεν Ἄρηα.{l]
[l [n}2.382{]}εὖ μέν τις δόρυ θηξάσθω, εὖ δʼ ἀσπίδα θέσθω,{l]
[l [n}2.383{]}εὖ δέ τις ἵπποισιν δεῖπνον δότω ὠκυπόδεσσιν,{l]
[l [n}2.384{]}εὖ δέ τις ἅρματος ἀμφὶς ἰδὼν πολέμοιο μεδέσθω,{l]
[l [n}2.385{]}ὥς κε πανημέριοι στυγερῷ κρινώμεθʼ Ἄρηϊ.{l]
[l [n}2.386{]}οὐ γὰρ παυσωλή γε μετέσσεται οὐδʼ ἠβαιὸν{l]
[l [n}2.387{]}εἰ μὴ νὺξ ἐλθοῦσα διακρινέει μένος ἀνδρῶν.{l]
[l [n}2.388{]}ἱδρώσει μέν τευ τελαμὼν ἀμφὶ στήθεσφιν{l]
[l [n}2.389{]}ἀσπίδος ἀμφιβρότης, περὶ δʼ ἔγχεϊ χεῖρα καμεῖται·{l]
[l [n}2.390{]}ἱδρώσει δέ τευ ἵππος ἐΰξοον ἅρμα τιταίνων.{l]
[l [n}2.391{]}ὃν δέ κʼ ἐγὼν ἀπάνευθε μάχης ἐθέλοντα νοήσω{l]
[l [n}2.392{]}μιμνάζειν παρὰ νηυσὶ κορωνίσιν, οὔ οἱ ἔπειτα{l]
[l [n}2.393{]}ἄρκιον ἐσσεῖται φυγέειν κύνας ἠδʼ οἰωνούς.{l]{q]{para]
[para}[l [n}2.394{]}ὣς ἔφατʼ, Ἀργεῖοι δὲ μέγʼ ἴαχον ὡς ὅτε κῦμα{l]
[l [n}2.395{]}ἀκτῇ ἐφʼ ὑψηλῇ, ὅτε κινήσῃ Νότος ἐλθών,{l]
[l [n}2.396{]}προβλῆτι σκοπέλῳ· τὸν δʼ οὔ ποτε κύματα λείπει{l]
[l [n}2.397{]}παντοίων ἀνέμων, ὅτʼ ἂν ἔνθʼ ἢ ἔνθα γένωνται.{l]
[l [n}2.398{]}ἀνστάντες δʼ ὀρέοντο κεδασθέντες κατὰ νῆας,{l]
[l [n}2.399{]}κάπνισσάν τε κατὰ κλισίας, καὶ δεῖπνον ἕλοντο.{l]
[l [n}2.400{]}ἄλλος δʼ ἄλλῳ ἔρεζε θεῶν αἰειγενετάων{l]
[l [n}2.401{]}εὐχόμενος θάνατόν τε φυγεῖν καὶ μῶλον Ἄρηος.{l]
[l [n}2.402{]}αὐτὰρ ὃ βοῦν ἱέρευσε ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}2.403{]}πίονα πενταέτηρον ὑπερμενέϊ Κρονίωνι,{l]
[l [n}2.404{]}κίκλησκεν δὲ γέροντας ἀριστῆας Παναχαιῶν,{l]
[l [n}2.405{]}Νέστορα μὲν πρώτιστα καὶ Ἰδομενῆα ἄνακτα,{l]
[l [n}2.406{]}αὐτὰρ ἔπειτʼ Αἴαντε δύω καὶ Τυδέος υἱόν,{l]
[l [n}2.407{]}ἕκτον δʼ αὖτʼ Ὀδυσῆα Διὶ μῆτιν ἀτάλαντον.{l]
[l [n}2.408{]}αὐτόματος δέ οἱ ἦλθε βοὴν ἀγαθὸς Μενέλαος·{l]
[l [n}2.409{]}ᾔδεε γὰρ κατὰ θυμὸν ἀδελφεὸν ὡς ἐπονεῖτο.{l]
[l [n}2.410{]}βοῦν δὲ περιστήσαντο καὶ οὐλοχύτας ἀνέλοντο·{l]
[l [n}2.411{]}τοῖσιν δʼ εὐχόμενος μετέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}2.412{]}Ζεῦ κύδιστε μέγιστε κελαινεφὲς αἰθέρι ναίων{l]
[l [n}2.413{]}μὴ πρὶν ἐπʼ ἠέλιον δῦναι καὶ ἐπὶ κνέφας ἐλθεῖν{l]
[l [n}2.414{]}πρίν με κατὰ πρηνὲς βαλέειν Πριάμοιο μέλαθρον{l]
[l [n}2.415{]}αἰθαλόεν, πρῆσαι δὲ πυρὸς δηΐοιο θύρετρα,{l]
[l [n}2.416{]}Ἑκτόρεον δὲ χιτῶνα περὶ στήθεσσι δαΐξαι{l]
[l [n}2.417{]}χαλκῷ ῥωγαλέον· πολέες δʼ ἀμφʼ αὐτὸν ἑταῖροι{l]
[l [n}2.418{]}πρηνέες ἐν κονίῃσιν ὀδὰξ λαζοίατο γαῖαν.{l]{q]{para]
[para}[l [n}2.419{]}ὣς ἔφατʼ, οὐδʼ ἄρα πώ οἱ ἐπεκραίαινε Κρονίων,{l]
[l [n}2.420{]}ἀλλʼ ὅ γε δέκτο μὲν ἱρά, πόνον δʼ ἀμέγαρτον ὄφελλεν.{l]
[l [n}2.421{]}αὐτὰρ ἐπεί ῥʼ εὔξαντο καὶ οὐλοχύτας προβάλοντο,{l]
[l [n}2.422{]}αὐέρυσαν μὲν πρῶτα καὶ ἔσφαξαν καὶ ἔδειραν,{l]
[l [n}2.423{]}μηρούς τʼ ἐξέταμον κατά τε κνίσῃ ἐκάλυψαν{l]
[l [n}2.424{]}δίπτυχα ποιήσαντες, ἐπʼ αὐτῶν δʼ ὠμοθέτησαν.{l]
[l [n}2.425{]}καὶ τὰ μὲν ἂρ σχίζῃσιν ἀφύλλοισιν κατέκαιον,{l]
[l [n}2.426{]}σπλάγχνα δʼ ἄρʼ ἀμπείραντες ὑπείρεχον Ἡφαίστοιο.{l]
[l [n}2.427{]}αὐτὰρ ἐπεὶ κατὰ μῆρε κάη καὶ σπλάγχνα πάσαντο,{l]
[l [n}2.428{]}μίστυλλόν τʼ ἄρα τἆλλα καὶ ἀμφʼ ὀβελοῖσιν ἔπειραν,{l]
[l [n}2.429{]}ὤπτησάν τε περιφραδέως, ἐρύσαντό τε πάντα.{l]
[l [n}2.430{]}αὐτὰρ ἐπεὶ παύσαντο πόνου τετύκοντό τε δαῖτα{l]
[l [n}2.431{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης.{l]
[l [n}2.432{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}2.433{]}τοῖς ἄρα μύθων ἦρχε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}2.434{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον,{l]
[l [n}2.435{]}μηκέτι νῦν δήθʼ αὖθι λεγώμεθα, μηδʼ ἔτι δηρὸν{l]
[l [n}2.436{]}ἀμβαλλώμεθα ἔργον ὃ δὴ θεὸς ἐγγυαλίζει.{l]
[l [n}2.437{]}ἀλλʼ ἄγε κήρυκες μὲν Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}2.438{]}λαὸν κηρύσσοντες ἀγειρόντων κατὰ νῆας,{l]
[l [n}2.439{]}ἡμεῖς δʼ ἀθρόοι ὧδε κατὰ στρατὸν εὐρὺν Ἀχαιῶν{l]
[l [n}2.440{]}ἴομεν ὄφρα κε θᾶσσον ἐγείρομεν ὀξὺν Ἄρηα.{l]{q]{para]
[para}[l [n}2.441{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησεν ἄναξ ἀνδρῶν Ἀγαμέμνων.{l]
[l [n}2.442{]}αὐτίκα κηρύκεσσι λιγυφθόγγοισι κέλευσε{l]
[l [n}2.443{]}κηρύσσειν πόλεμον δὲ κάρη κομόωντας Ἀχαιούς·{l]
[l [n}2.444{]}οἳ μὲν ἐκήρυσσον, τοὶ δʼ ἠγείροντο μάλʼ ὦκα.{l]
[l [n}2.445{]}οἳ δʼ ἀμφʼ Ἀτρεΐωνα διοτρεφέες βασιλῆες{l]
[l [n}2.446{]}θῦνον κρίνοντες, μετὰ δὲ γλαυκῶπις Ἀθήνη{l]
[l [n}2.447{]}αἰγίδʼ ἔχουσʼ ἐρίτιμον ἀγήρων ἀθανάτην τε,{l]
[l [n}2.448{]}τῆς ἑκατὸν θύσανοι παγχρύσεοι ἠερέθονται,{l]
[l [n}2.449{]}πάντες ἐϋπλεκέες, ἑκατόμβοιος δὲ ἕκαστος·{l]
[l [n}2.450{]}σὺν τῇ παιφάσσουσα διέσσυτο λαὸν Ἀχαιῶν{l]
[l [n}2.451{]}ὀτρύνουσʼ ἰέναι· ἐν δὲ σθένος ὦρσεν ἑκάστῳ{l]
[l [n}2.452{]}καρδίῃ ἄλληκτον πολεμίζειν ἠδὲ μάχεσθαι.{l]
[l [n}2.453{]}τοῖσι δʼ ἄφαρ πόλεμος γλυκίων γένετʼ ἠὲ νέεσθαι{l]
[l [n}2.454{]}ἐν νηυσὶ γλαφυρῇσι φίλην ἐς πατρίδα γαῖαν.{l]{para]
[para}[l [n}2.455{]}ἠΰτε πῦρ ἀΐδηλον ἐπιφλέγει ἄσπετον ὕλην{l]
[l [n}2.456{]}οὔρεος ἐν κορυφῇς, ἕκαθεν δέ τε φαίνεται αὐγή,{l]
[l [n}2.457{]}ὣς τῶν ἐρχομένων ἀπὸ χαλκοῦ θεσπεσίοιο{l]
[l [n}2.458{]}αἴγλη παμφανόωσα διʼ αἰθέρος οὐρανὸν ἷκε.{l]{para]
[para}[l [n}2.459{]}τῶν δʼ ὥς τʼ ὀρνίθων πετεηνῶν ἔθνεα πολλὰ{l]
[l [n}2.460{]}χηνῶν ἢ γεράνων ἢ κύκνων δουλιχοδείρων{l]
[l [n}2.461{]}Ἀσίω ἐν λειμῶνι Καϋστρίου ἀμφὶ ῥέεθρα{l]
[l [n}2.462{]}ἔνθα καὶ ἔνθα ποτῶνται ἀγαλλόμενα πτερύγεσσι{l]
[l [n}2.463{]}κλαγγηδὸν προκαθιζόντων, σμαραγεῖ δέ τε λειμών,{l]
[l [n}2.464{]}ὣς τῶν ἔθνεα πολλὰ νεῶν ἄπο καὶ κλισιάων{l]
[l [n}2.465{]}ἐς πεδίον προχέοντο Σκαμάνδριον· αὐτὰρ ὑπὸ χθὼν{l]
[l [n}2.466{]}σμερδαλέον κονάβιζε ποδῶν αὐτῶν τε καὶ ἵππων.{l]
[l [n}2.467{]}ἔσταν δʼ ἐν λειμῶνι Σκαμανδρίῳ ἀνθεμόεντι{l]
[l [n}2.468{]}μυρίοι, ὅσσά τε φύλλα καὶ ἄνθεα γίγνεται ὥρῃ.{l]{para]
[para}[l [n}2.469{]}ἠΰτε μυιάων ἁδινάων ἔθνεα πολλὰ{l]
[l [n}2.470{]}αἵ τε κατὰ σταθμὸν ποιμνήϊον ἠλάσκουσιν{l]
[l [n}2.471{]}ὥρῃ ἐν εἰαρινῇ ὅτε τε γλάγος ἄγγεα δεύει,{l]
[l [n}2.472{]}τόσσοι ἐπὶ Τρώεσσι κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}2.473{]}ἐν πεδίῳ ἵσταντο διαρραῖσαι μεμαῶτες.{l]{para]
[para}[l [n}2.474{]}τοὺς δʼ ὥς τʼ αἰπόλια πλατέʼ αἰγῶν αἰπόλοι ἄνδρες{l]
[l [n}2.475{]}ῥεῖα διακρίνωσιν ἐπεί κε νομῷ μιγέωσιν,{l]
[l [n}2.476{]}ὣς τοὺς ἡγεμόνες διεκόσμεον ἔνθα καὶ ἔνθα{l]
[l [n}2.477{]}ὑσμίνην δʼ ἰέναι, μετὰ δὲ κρείων Ἀγαμέμνων{l]
[l [n}2.478{]}ὄμματα καὶ κεφαλὴν ἴκελος Διὶ τερπικεραύνῳ,{l]
[l [n}2.479{]}Ἄρεϊ δὲ ζώνην, στέρνον δὲ Ποσειδάωνι.{l]
[l [n}2.480{]}ἠΰτε βοῦς ἀγέληφι μέγʼ ἔξοχος ἔπλετο πάντων{l]
[l [n}2.481{]}ταῦρος· ὃ γάρ τε βόεσσι μεταπρέπει ἀγρομένῃσι·{l]
[l [n}2.482{]}τοῖον ἄρʼ Ἀτρεΐδην θῆκε Ζεὺς ἤματι κείνῳ{l]
[l [n}2.483{]}ἐκπρεπέʼ ἐν πολλοῖσι καὶ ἔξοχον ἡρώεσσιν.{l]{para]
[para}[l [n}2.484{]}ἔσπετε νῦν μοι Μοῦσαι Ὀλύμπια δώματʼ ἔχουσαι·{l]
[l [n}2.485{]}ὑμεῖς γὰρ θεαί ἐστε πάρεστέ τε ἴστέ τε πάντα,{l]
[l [n}2.486{]}ἡμεῖς δὲ κλέος οἶον ἀκούομεν οὐδέ τι ἴδμεν·{l]
[l [n}2.487{]}οἵ τινες ἡγεμόνες Δαναῶν καὶ κοίρανοι ἦσαν·{l]
[l [n}2.488{]}πληθὺν δʼ οὐκ ἂν ἐγὼ μυθήσομαι οὐδʼ ὀνομήνω,{l]
[l [n}2.489{]}οὐδʼ εἴ μοι δέκα μὲν γλῶσσαι, δέκα δὲ στόματʼ εἶεν,{l]
[l [n}2.490{]}φωνὴ δʼ ἄρρηκτος, χάλκεον δέ μοι ἦτορ ἐνείη,{l]
[l [n}2.491{]}εἰ μὴ Ὀλυμπιάδες Μοῦσαι Διὸς αἰγιόχοιο{l]
[l [n}2.492{]}θυγατέρες μνησαίαθʼ ὅσοι ὑπὸ Ἴλιον ἦλθον·{l]
[l [n}2.493{]}ἀρχοὺς αὖ νηῶν ἐρέω νῆάς τε προπάσας.{l]{para]
[para}[l [n}2.494{]}Βοιωτῶν μὲν Πηνέλεως καὶ Λήϊτος ἦρχον{l]
[l [n}2.495{]}Ἀρκεσίλαός τε Προθοήνωρ τε Κλονίος τε,{l]
[l [n}2.496{]}οἵ θʼ Ὑρίην ἐνέμοντο καὶ Αὐλίδα πετρήεσσαν{l]
[l [n}2.497{]}Σχοῖνόν τε Σκῶλόν τε πολύκνημόν τʼ Ἐτεωνόν,{l]
[l [n}2.498{]}Θέσπειαν Γραῖάν τε καὶ εὐρύχορον Μυκαλησσόν,{l]
[l [n}2.499{]}οἵ τʼ ἀμφʼ Ἅρμʼ ἐνέμοντο καὶ Εἰλέσιον καὶ Ἐρυθράς,{l]
[l [n}2.500{]}οἵ τʼ Ἐλεῶνʼ εἶχον ἠδʼ Ὕλην καὶ Πετεῶνα,{l]
[l [n}2.501{]}Ὠκαλέην Μεδεῶνά τʼ ἐϋκτίμενον πτολίεθρον,{l]
[l [n}2.502{]}Κώπας Εὔτρησίν τε πολυτρήρωνά τε Θίσβην,{l]
[l [n}2.503{]}οἵ τε Κορώνειαν καὶ ποιήενθʼ Ἁλίαρτον,{l]
[l [n}2.504{]}οἵ τε Πλάταιαν ἔχον ἠδʼ οἳ Γλισᾶντʼ ἐνέμοντο,{l]
[l [n}2.505{]}οἵ θʼ Ὑποθήβας εἶχον ἐϋκτίμενον πτολίεθρον,{l]
[l [n}2.506{]}Ὀγχηστόν θʼ ἱερὸν Ποσιδήϊον ἀγλαὸν ἄλσος,{l]
[l [n}2.507{]}οἵ τε πολυστάφυλον Ἄρνην ἔχον, οἵ τε Μίδειαν{l]
[l [n}2.508{]}Νῖσάν τε ζαθέην Ἀνθηδόνα τʼ ἐσχατόωσαν·{l]
[l [n}2.509{]}τῶν μὲν πεντήκοντα νέες κίον, ἐν δὲ ἑκάστῃ{l]
[l [n}2.510{]}κοῦροι Βοιωτῶν ἑκατὸν καὶ εἴκοσι βαῖνον.{l]{para]
[para}[l [n}2.511{]}οἳ δʼ Ἀσπληδόνα ναῖον ἰδʼ Ὀρχομενὸν Μινύειον,{l]
[l [n}2.512{]}τῶν ἦρχʼ Ἀσκάλαφος καὶ Ἰάλμενος υἷες Ἄρηος{l]
[l [n}2.513{]}οὓς τέκεν Ἀστυόχη δόμῳ Ἄκτορος Ἀζεΐδαο,{l]
[l [n}2.514{]}παρθένος αἰδοίη ὑπερώϊον εἰσαναβᾶσα{l]
[l [n}2.515{]}Ἄρηϊ κρατερῷ· ὃ δέ οἱ παρελέξατο λάθρῃ·{l]
[l [n}2.516{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.517{]}αὐτὰρ Φωκήων Σχεδίος καὶ Ἐπίστροφος ἦρχον{l]
[l [n}2.518{]}υἷες Ἰφίτου μεγαθύμου Ναυβολίδαο,{l]
[l [n}2.519{]}οἳ Κυπάρισσον ἔχον Πυθῶνά τε πετρήεσσαν{l]
[l [n}2.520{]}Κρῖσάν τε ζαθέην καὶ Δαυλίδα καὶ Πανοπῆα,{l]
[l [n}2.521{]}οἵ τʼ Ἀνεμώρειαν καὶ Ὑάμπολιν ἀμφενέμοντο,{l]
[l [n}2.522{]}οἵ τʼ ἄρα πὰρ ποταμὸν Κηφισὸν δῖον ἔναιον,{l]
[l [n}2.523{]}οἵ τε Λίλαιαν ἔχον πηγῇς ἔπι Κηφισοῖο·{l]
[l [n}2.524{]}τοῖς δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]
[l [n}2.525{]}οἳ μὲν Φωκήων στίχας ἵστασαν ἀμφιέποντες,{l]
[l [n}2.526{]}Βοιωτῶν δʼ ἔμπλην ἐπʼ ἀριστερὰ θωρήσσοντο.{l]{para]
[para}[l [n}2.527{]}Λοκρῶν δʼ ἡγεμόνευεν Ὀϊλῆος ταχὺς Αἴας{l]
[l [n}2.528{]}μείων, οὔ τι τόσος γε ὅσος Τελαμώνιος Αἴας{l]
[l [n}2.529{]}ἀλλὰ πολὺ μείων· ὀλίγος μὲν ἔην λινοθώρηξ,{l]
[l [n}2.530{]}ἐγχείῃ δʼ ἐκέκαστο Πανέλληνας καὶ Ἀχαιούς·{l]
[l [n}2.531{]}οἳ Κῦνόν τʼ ἐνέμοντʼ Ὀπόεντά τε Καλλίαρόν τε{l]
[l [n}2.532{]}Βῆσσάν τε Σκάρφην τε καὶ Αὐγειὰς ἐρατεινὰς{l]
[l [n}2.533{]}Τάρφην τε Θρόνιον τε Βοαγρίου ἀμφὶ ῥέεθρα·{l]
[l [n}2.534{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο{l]
[l [n}2.535{]}Λοκρῶν, οἳ ναίουσι πέρην ἱερῆς Εὐβοίης.{l]{para]
[para}[l [n}2.536{]}οἳ δʼ Εὔβοιαν ἔχον μένεα πνείοντες Ἄβαντες{l]
[l [n}2.537{]}Χαλκίδα τʼ Εἰρέτριάν τε πολυστάφυλόν θʼ Ἱστίαιαν{l]
[l [n}2.538{]}Κήρινθόν τʼ ἔφαλον Δίου τʼ αἰπὺ πτολίεθρον,{l]
[l [n}2.539{]}οἵ τε Κάρυστον ἔχον ἠδʼ οἳ Στύρα ναιετάασκον,{l]
[l [n}2.540{]}τῶν αὖθʼ ἡγεμόνευʼ Ἐλεφήνωρ ὄζος Ἄρηος{l]
[l [n}2.541{]}Χαλκωδοντιάδης μεγαθύμων ἀρχὸς Ἀβάντων.{l]
[l [n}2.542{]}τῷ δʼ ἅμʼ Ἄβαντες ἕποντο θοοὶ ὄπιθεν κομόωντες{l]
[l [n}2.543{]}αἰχμηταὶ μεμαῶτες ὀρεκτῇσιν μελίῃσι{l]
[l [n}2.544{]}θώρηκας ῥήξειν δηΐων ἀμφὶ στήθεσσι·{l]
[l [n}2.545{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.546{]}οἳ δʼ ἄρʼ Ἀθήνας εἶχον ἐϋκτίμενον πτολίεθρον{l]
[l [n}2.547{]}δῆμον Ἐρεχθῆος μεγαλήτορος, ὅν ποτʼ Ἀθήνη{l]
[l [n}2.548{]}θρέψε Διὸς θυγάτηρ, τέκε δὲ ζείδωρος ἄρουρα,{l]
[l [n}2.549{]}κὰδ δʼ ἐν Ἀθήνῃς εἷσεν ἑῷ ἐν πίονι νηῷ·{l]
[l [n}2.550{]}ἔνθα δέ μιν ταύροισι καὶ ἀρνειοῖς ἱλάονται{l]
[l [n}2.551{]}κοῦροι Ἀθηναίων περιτελλομένων ἐνιαυτῶν·{l]
[l [n}2.552{]}τῶν αὖθʼ ἡγεμόνευʼ υἱὸς Πετεῶο Μενεσθεύς.{l]
[l [n}2.553{]}τῷ δʼ οὔ πώ τις ὁμοῖος ἐπιχθόνιος γένετʼ ἀνὴρ{l]
[l [n}2.554{]}κοσμῆσαι ἵππους τε καὶ ἀνέρας ἀσπιδιώτας·{l]
[l [n}2.555{]}Νέστωρ οἶος ἔριζεν· ὃ γὰρ προγενέστερος ἦεν·{l]
[l [n}2.556{]}τῷ δʼ ἅμα πεντήκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.557{]}Αἴας δʼ ἐκ Σαλαμῖνος ἄγεν δυοκαίδεκα νῆας,{l]
[l [n}2.558{]}στῆσε δʼ ἄγων ἵνʼ Ἀθηναίων ἵσταντο φάλαγγες.{l]{para]
[para}[l [n}2.559{]}οἳ δʼ Ἄργός τʼ εἶχον Τίρυνθά τε τειχιόεσσαν{l]
[l [n}2.560{]}Ἑρμιόνην Ἀσίνην τε, βαθὺν κατὰ κόλπον ἐχούσας,{l]
[l [n}2.561{]}Τροιζῆνʼ Ἠϊόνας τε καὶ ἀμπελόεντʼ Ἐπίδαυρον,{l]
[l [n}2.562{]}οἵ τʼ ἔχον Αἴγιναν Μάσητά τε κοῦροι Ἀχαιῶν,{l]
[l [n}2.563{]}τῶν αὖθʼ ἡγεμόνευε βοὴν ἀγαθὸς Διομήδης{l]
[l [n}2.564{]}καὶ Σθένελος, Καπανῆος ἀγακλειτοῦ φίλος υἱός·{l]
[l [n}2.565{]}τοῖσι δʼ ἅμʼ Εὐρύαλος τρίτατος κίεν ἰσόθεος φὼς{l]
[l [n}2.566{]}Μηκιστέος υἱὸς Ταλαϊονίδαο ἄνακτος·{l]
[l [n}2.567{]}συμπάντων δʼ ἡγεῖτο βοὴν ἀγαθὸς Διομήδης·{l]
[l [n}2.568{]}τοῖσι δʼ ἅμʼ ὀγδώκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.569{]}οἳ δὲ Μυκήνας εἶχον ἐϋκτίμενον πτολίεθρον{l]
[l [n}2.570{]}ἀφνειόν τε Κόρινθον ἐϋκτιμένας τε Κλεωνάς,{l]
[l [n}2.571{]}Ὀρνειάς τʼ ἐνέμοντο Ἀραιθυρέην τʼ ἐρατεινὴν{l]
[l [n}2.572{]}καὶ Σικυῶνʼ, ὅθʼ ἄρʼ Ἄδρηστος πρῶτʼ ἐμβασίλευεν,{l]
[l [n}2.573{]}οἵ θʼ Ὑπερησίην τε καὶ αἰπεινὴν Γονόεσσαν{l]
[l [n}2.574{]}Πελλήνην τʼ εἶχον ἠδʼ Αἴγιον ἀμφενέμοντο{l]
[l [n}2.575{]}Αἰγιαλόν τʼ ἀνὰ πάντα καὶ ἀμφʼ Ἑλίκην εὐρεῖαν,{l]
[l [n}2.576{]}τῶν ἑκατὸν νηῶν ἦρχε κρείων Ἀγαμέμνων{l]
[l [n}2.577{]}Ἀτρεΐδης· ἅμα τῷ γε πολὺ πλεῖστοι καὶ ἄριστοι{l]
[l [n}2.578{]}λαοὶ ἕποντʼ· ἐν δʼ αὐτὸς ἐδύσετο νώροπα χαλκὸν{l]
[l [n}2.579{]}κυδιόων, πᾶσιν δὲ μετέπρεπεν ἡρώεσσιν{l]
[l [n}2.580{]}οὕνεκʼ ἄριστος ἔην πολὺ δὲ πλείστους ἄγε λαούς.{l]{para]
[para}[l [n}2.581{]}οἳ δʼ εἶχον κοίλην Λακεδαίμονα κητώεσσαν,{l]
[l [n}2.582{]}Φᾶρίν τε Σπάρτην τε πολυτρήρωνά τε Μέσσην,{l]
[l [n}2.583{]}Βρυσειάς τʼ ἐνέμοντο καὶ Αὐγειὰς ἐρατεινάς,{l]
[l [n}2.584{]}οἵ τʼ ἄρʼ Ἀμύκλας εἶχον Ἕλος τʼ ἔφαλον πτολίεθρον,{l]
[l [n}2.585{]}οἵ τε Λάαν εἶχον ἠδʼ Οἴτυλον ἀμφενέμοντο,{l]
[l [n}2.586{]}τῶν οἱ ἀδελφεὸς ἦρχε βοὴν ἀγαθὸς Μενέλαος{l]
[l [n}2.587{]}ἑξήκοντα νεῶν· ἀπάτερθε δὲ θωρήσσοντο·{l]
[l [n}2.588{]}ἐν δʼ αὐτὸς κίεν ᾗσι προθυμίῃσι πεποιθὼς{l]
[l [n}2.589{]}ὀτρύνων πόλεμον δέ· μάλιστα δὲ ἵετο θυμῷ{l]
[l [n}2.590{]}τίσασθαι Ἑλένης ὁρμήματά τε στοναχάς τε.{l]{para]
[para}[l [n}2.591{]}οἳ δὲ Πύλον τʼ ἐνέμοντο καὶ Ἀρήνην ἐρατεινὴν{l]
[l [n}2.592{]}καὶ Θρύον Ἀλφειοῖο πόρον καὶ ἐΰκτιτον Αἰπὺ{l]
[l [n}2.593{]}καὶ Κυπαρισσήεντα καὶ Ἀμφιγένειαν ἔναιον{l]
[l [n}2.594{]}καὶ Πτελεὸν καὶ Ἕλος καὶ Δώριον, ἔνθά τε Μοῦσαι{l]
[l [n}2.595{]}ἀντόμεναι Θάμυριν τὸν Θρήϊκα παῦσαν ἀοιδῆς{l]
[l [n}2.596{]}Οἰχαλίηθεν ἰόντα παρʼ Εὐρύτου Οἰχαλιῆος·{l]
[l [n}2.597{]}στεῦτο γὰρ εὐχόμενος νικησέμεν εἴ περ ἂν αὐταὶ{l]
[l [n}2.598{]}Μοῦσαι ἀείδοιεν κοῦραι Διὸς αἰγιόχοιο·{l]
[l [n}2.599{]}αἳ δὲ χολωσάμεναι πηρὸν θέσαν, αὐτὰρ ἀοιδὴν{l]
[l [n}2.600{]}θεσπεσίην ἀφέλοντο καὶ ἐκλέλαθον κιθαριστύν·{l]
[l [n}2.601{]}τῶν αὖθʼ ἡγεμόνευε Γερήνιος ἱππότα Νέστωρ·{l]
[l [n}2.602{]}τῷ δʼ ἐνενήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.603{]}οἳ δʼ ἔχον Ἀρκαδίην ὑπὸ Κυλλήνης ὄρος αἰπὺ{l]
[l [n}2.604{]}Αἰπύτιον παρὰ τύμβον ἵνʼ ἀνέρες ἀγχιμαχηταί,{l]
[l [n}2.605{]}οἳ Φενεόν τʼ ἐνέμοντο καὶ Ὀρχομενὸν πολύμηλον{l]
[l [n}2.606{]}Ῥίπην τε Στρατίην τε καὶ ἠνεμόεσσαν Ἐνίσπην{l]
[l [n}2.607{]}καὶ Τεγέην εἶχον καὶ Μαντινέην ἐρατεινὴν{l]
[l [n}2.608{]}Στύμφηλόν τʼ εἶχον καὶ Παρρασίην ἐνέμοντο,{l]
[l [n}2.609{]}τῶν ἦρχʼ Ἀγκαίοιο πάϊς κρείων Ἀγαπήνωρ{l]
[l [n}2.610{]}ἑξήκοντα νεῶν· πολέες δʼ ἐν νηῒ ἑκάστῃ{l]
[l [n}2.611{]}Ἀρκάδες ἄνδρες ἔβαινον ἐπιστάμενοι πολεμίζειν.{l]
[l [n}2.612{]}αὐτὸς γάρ σφιν δῶκεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}2.613{]}νῆας ἐϋσσέλμους περάαν ἐπὶ οἴνοπα πόντον{l]
[l [n}2.614{]}Ἀτρεΐδης, ἐπεὶ οὔ σφι θαλάσσια ἔργα μεμήλει.{l]{para]
[para}[l [n}2.615{]}οἳ δʼ ἄρα Βουπράσιόν τε καὶ Ἤλιδα δῖαν ἔναιον{l]
[l [n}2.616{]}ὅσσον ἐφʼ Ὑρμίνη καὶ Μύρσινος ἐσχατόωσα{l]
[l [n}2.617{]}πέτρη τʼ Ὠλενίη καὶ Ἀλήσιον ἐντὸς ἐέργει,{l]
[l [n}2.618{]}τῶν αὖ τέσσαρες ἀρχοὶ ἔσαν, δέκα δʼ ἀνδρὶ ἑκάστῳ{l]
[l [n}2.619{]}νῆες ἕποντο θοαί, πολέες δʼ ἔμβαινον Ἐπειοί.{l]
[l [n}2.620{]}τῶν μὲν ἄρʼ Ἀμφίμαχος καὶ Θάλπιος ἡγησάσθην{l]
[l [n}2.621{]}υἷες ὃ μὲν Κτεάτου, ὃ δʼ ἄρʼ Εὐρύτου, Ἀκτορίωνε·{l]
[l [n}2.622{]}τῶν δʼ Ἀμαρυγκεΐδης ἦρχε κρατερὸς Διώρης·{l]
[l [n}2.623{]}τῶν δὲ τετάρτων ἦρχε Πολύξεινος θεοειδὴς{l]
[l [n}2.624{]}υἱὸς Ἀγασθένεος Αὐγηϊάδαο ἄνακτος.{l]{para]
[para}[l [n}2.625{]}οἳ δʼ ἐκ Δουλιχίοιο Ἐχινάων θʼ ἱεράων{l]
[l [n}2.626{]}νήσων, αἳ ναίουσι πέρην ἁλὸς Ἤλιδος ἄντα,{l]
[l [n}2.627{]}τῶν αὖθʼ ἡγεμόνευε Μέγης ἀτάλαντος Ἄρηϊ{l]
[l [n}2.628{]}Φυλεΐδης, ὃν τίκτε Διῒ φίλος ἱππότα Φυλεύς,{l]
[l [n}2.629{]}ὅς ποτε Δουλίχιον δʼ ἀπενάσσατο πατρὶ χολωθείς·{l]
[l [n}2.630{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.631{]}αὐτὰρ Ὀδυσσεὺς ἦγε Κεφαλλῆνας μεγαθύμους,{l]
[l [n}2.632{]}οἵ ῥʼ Ἰθάκην εἶχον καὶ Νήριτον εἰνοσίφυλλον{l]
[l [n}2.633{]}καὶ Κροκύλειʼ ἐνέμοντο καὶ Αἰγίλιπα τρηχεῖαν,{l]
[l [n}2.634{]}οἵ τε Ζάκυνθον ἔχον ἠδʼ οἳ Σάμον ἀμφενέμοντο,{l]
[l [n}2.635{]}οἵ τʼ ἤπειρον ἔχον ἠδʼ ἀντιπέραιʼ ἐνέμοντο·{l]
[l [n}2.636{]}τῶν μὲν Ὀδυσσεὺς ἦρχε Διὶ μῆτιν ἀτάλαντος·{l]
[l [n}2.637{]}τῷ δʼ ἅμα νῆες ἕποντο δυώδεκα μιλτοπάρῃοι.{l]{para]
[para}[l [n}2.638{]}Αἰτωλῶν δʼ ἡγεῖτο Θόας Ἀνδραίμονος υἱός,{l]
[l [n}2.639{]}οἳ Πλευρῶνʼ ἐνέμοντο καὶ Ὤλενον ἠδὲ Πυλήνην{l]
[l [n}2.640{]}Χαλκίδα τʼ ἀγχίαλον Καλυδῶνά τε πετρήεσσαν·{l]
[l [n}2.641{]}οὐ γὰρ ἔτʼ Οἰνῆος μεγαλήτορος υἱέες ἦσαν,{l]
[l [n}2.642{]}οὐδʼ ἄρʼ ἔτʼ αὐτὸς ἔην, θάνε δὲ ξανθὸς Μελέαγρος·{l]
[l [n}2.643{]}τῷ δʼ ἐπὶ πάντʼ ἐτέταλτο ἀνασσέμεν Αἰτωλοῖσι·{l]
[l [n}2.644{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.645{]}Κρητῶν δʼ Ἰδομενεὺς δουρὶ κλυτὸς ἡγεμόνευεν,{l]
[l [n}2.646{]}οἳ Κνωσόν τʼ εἶχον Γόρτυνά τε τειχιόεσσαν,{l]
[l [n}2.647{]}Λύκτον Μίλητόν τε καὶ ἀργινόεντα Λύκαστον{l]
[l [n}2.648{]}Φαιστόν τε Ῥύτιόν τε, πόλεις εὖ ναιετοώσας,{l]
[l [n}2.649{]}ἄλλοι θʼ οἳ Κρήτην ἑκατόμπολιν ἀμφενέμοντο.{l]
[l [n}2.650{]}τῶν μὲν ἄρʼ Ἰδομενεὺς δουρὶ κλυτὸς ἡγεμόνευε{l]
[l [n}2.651{]}Μηριόνης τʼ ἀτάλαντος Ἐνυαλίῳ ἀνδρειφόντῃ·{l]
[l [n}2.652{]}τοῖσι δʼ ἅμʼ ὀγδώκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.653{]}Τληπόλεμος δʼ Ἡρακλεΐδης ἠΰς τε μέγας τε{l]
[l [n}2.654{]}ἐκ Ῥόδου ἐννέα νῆας ἄγεν Ῥοδίων ἀγερώχων,{l]
[l [n}2.655{]}οἳ Ῥόδον ἀμφενέμοντο διὰ τρίχα κοσμηθέντες{l]
[l [n}2.656{]}Λίνδον Ἰηλυσόν τε καὶ ἀργινόεντα Κάμειρον.{l]
[l [n}2.657{]}τῶν μὲν Τληπόλεμος δουρὶ κλυτὸς ἡγεμόνευεν,{l]
[l [n}2.658{]}ὃν τέκεν Ἀστυόχεια βίῃ Ἡρακληείῃ,{l]
[l [n}2.659{]}τὴν ἄγετʼ ἐξ Ἐφύρης ποταμοῦ ἄπο Σελλήεντος{l]
[l [n}2.660{]}πέρσας ἄστεα πολλὰ διοτρεφέων αἰζηῶν.{l]
[l [n}2.661{]}Τληπόλεμος δʼ ἐπεὶ οὖν τράφʼ ἐνὶ μεγάρῳ εὐπήκτῳ,{l]
[l [n}2.662{]}αὐτίκα πατρὸς ἑοῖο φίλον μήτρωα κατέκτα{l]
[l [n}2.663{]}ἤδη γηράσκοντα Λικύμνιον ὄζον Ἄρηος·{l]
[l [n}2.664{]}αἶψα δὲ νῆας ἔπηξε, πολὺν δʼ ὅ γε λαὸν ἀγείρας{l]
[l [n}2.665{]}βῆ φεύγων ἐπὶ πόντον· ἀπείλησαν γάρ οἱ ἄλλοι{l]
[l [n}2.666{]}υἱέες υἱωνοί τε βίης Ἡρακληείης.{l]
[l [n}2.667{]}αὐτὰρ ὅ γʼ ἐς Ῥόδον ἷξεν ἀλώμενος ἄλγεα πάσχων·{l]
[l [n}2.668{]}τριχθὰ δὲ ᾤκηθεν καταφυλαδόν, ἠδὲ φίληθεν{l]
[l [n}2.669{]}ἐκ Διός, ὅς τε θεοῖσι καὶ ἀνθρώποισιν ἀνάσσει,{l]
[l [n}2.670{]}καί σφιν θεσπέσιον πλοῦτον κατέχευε Κρονίων.{l]{para]
[para}[l [n}2.671{]}Νιρεὺς αὖ Σύμηθεν ἄγε τρεῖς νῆας ἐΐσας{l]
[l [n}2.672{]}Νιρεὺς Ἀγλαΐης υἱὸς Χαρόποιό τʼ ἄνακτος{l]
[l [n}2.673{]}Νιρεύς, ὃς κάλλιστος ἀνὴρ ὑπὸ Ἴλιον ἦλθε{l]
[l [n}2.674{]}τῶν ἄλλων Δαναῶν μετʼ ἀμύμονα Πηλεΐωνα·{l]
[l [n}2.675{]}ἀλλʼ ἀλαπαδνὸς ἔην, παῦρος δέ οἱ εἵπετο λαός.{l]{para]
[para}[l [n}2.676{]}οἳ δʼ ἄρα Νίσυρόν τʼ εἶχον Κράπαθόν τε Κάσον τε{l]
[l [n}2.677{]}καὶ Κῶν Εὐρυπύλοιο πόλιν νήσους τε Καλύδνας,{l]
[l [n}2.678{]}τῶν αὖ Φείδιππός τε καὶ Ἄντιφος ἡγησάσθην{l]
[l [n}2.679{]}Θεσσαλοῦ υἷε δύω Ἡρακλεΐδαο ἄνακτος·{l]
[l [n}2.680{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.681{]}νῦν αὖ τοὺς ὅσσοι τὸ Πελασγικὸν Ἄργος ἔναιον,{l]
[l [n}2.682{]}οἵ τʼ Ἄλον οἵ τʼ Ἀλόπην οἵ τε Τρηχῖνα νέμοντο,{l]
[l [n}2.683{]}οἵ τʼ εἶχον Φθίην ἠδʼ Ἑλλάδα καλλιγύναικα,{l]
[l [n}2.684{]}Μυρμιδόνες δὲ καλεῦντο καὶ Ἕλληνες καὶ Ἀχαιοί,{l]
[l [n}2.685{]}τῶν αὖ πεντήκοντα νεῶν ἦν ἀρχὸς Ἀχιλλεύς.{l]
[l [n}2.686{]}ἀλλʼ οἵ γʼ οὐ πολέμοιο δυσηχέος ἐμνώοντο·{l]
[l [n}2.687{]}οὐ γὰρ ἔην ὅς τίς σφιν ἐπὶ στίχας ἡγήσαιτο·{l]
[l [n}2.688{]}κεῖτο γὰρ ἐν νήεσσι ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}2.689{]}κούρης χωόμενος Βρισηΐδος ἠϋκόμοιο,{l]
[l [n}2.690{]}τὴν ἐκ Λυρνησσοῦ ἐξείλετο πολλὰ μογήσας{l]
[l [n}2.691{]}Λυρνησσὸν διαπορθήσας καὶ τείχεα Θήβης,{l]
[l [n}2.692{]}κὰδ δὲ Μύνητʼ ἔβαλεν καὶ Ἐπίστροφον ἐγχεσιμώρους,{l]
[l [n}2.693{]}υἱέας Εὐηνοῖο Σεληπιάδαο ἄνακτος·{l]
[l [n}2.694{]}τῆς ὅ γε κεῖτʼ ἀχέων, τάχα δʼ ἀνστήσεσθαι ἔμελλεν.{l]{para]
[para}[l [n}2.695{]}οἳ δʼ εἶχον Φυλάκην καὶ Πύρασον ἀνθεμόεντα{l]
[l [n}2.696{]}Δήμητρος τέμενος, Ἴτωνά τε μητέρα μήλων,{l]
[l [n}2.697{]}ἀγχίαλόν τʼ Ἀντρῶνα ἰδὲ Πτελεὸν λεχεποίην,{l]
[l [n}2.698{]}τῶν αὖ Πρωτεσίλαος ἀρήϊος ἡγεμόνευε{l]
[l [n}2.699{]}ζωὸς ἐών· τότε δʼ ἤδη ἔχεν κάτα γαῖα μέλαινα.{l]
[l [n}2.700{]}τοῦ δὲ καὶ ἀμφιδρυφὴς ἄλοχος Φυλάκῃ ἐλέλειπτο{l]
[l [n}2.701{]}καὶ δόμος ἡμιτελής· τὸν δʼ ἔκτανε Δάρδανος ἀνὴρ{l]
[l [n}2.702{]}νηὸς ἀποθρῴσκοντα πολὺ πρώτιστον Ἀχαιῶν.{l]
[l [n}2.703{]}οὐδὲ μὲν οὐδʼ οἳ ἄναρχοι ἔσαν, πόθεόν γε μὲν ἀρχόν·{l]
[l [n}2.704{]}ἀλλά σφεας κόσμησε Ποδάρκης ὄζος Ἄρηος{l]
[l [n}2.705{]}Ἰφίκλου υἱὸς πολυμήλου Φυλακίδαο{l]
[l [n}2.706{]}αὐτοκασίγνητος μεγαθύμου Πρωτεσιλάου{l]
[l [n}2.707{]}ὁπλότερος γενεῇ· ὁ δʼ ἅμα πρότερος καὶ ἀρείων{l]
[l [n}2.708{]}ἥρως Πρωτεσίλαος ἀρήϊος· οὐδέ τι λαοὶ{l]
[l [n}2.709{]}δεύονθʼ ἡγεμόνος, πόθεόν γε μὲν ἐσθλὸν ἐόντα·{l]
[l [n}2.710{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.711{]}οἳ δὲ Φερὰς ἐνέμοντο παραὶ Βοιβηΐδα λίμνην{l]
[l [n}2.712{]}Βοίβην καὶ Γλαφύρας καὶ ἐϋκτιμένην Ἰαωλκόν,{l]
[l [n}2.713{]}τῶν ἦρχʼ Ἀδμήτοιο φίλος πάϊς ἕνδεκα νηῶν{l]
[l [n}2.714{]}Εὔμηλος, τὸν ὑπʼ Ἀδμήτῳ τέκε δῖα γυναικῶν{l]
[l [n}2.715{]}Ἄλκηστις Πελίαο θυγατρῶν εἶδος ἀρίστη.{l]{para]
[para}[l [n}2.716{]}οἳ δʼ ἄρα Μηθώνην καὶ Θαυμακίην ἐνέμοντο{l]
[l [n}2.717{]}καὶ Μελίβοιαν ἔχον καὶ Ὀλιζῶνα τρηχεῖαν,{l]
[l [n}2.718{]}τῶν δὲ Φιλοκτήτης ἦρχεν τόξων ἐῢ εἰδὼς{l]
[l [n}2.719{]}ἑπτὰ νεῶν· ἐρέται δʼ ἐν ἑκάστῃ πεντήκοντα{l]
[l [n}2.720{]}ἐμβέβασαν τόξων εὖ εἰδότες ἶφι μάχεσθαι.{l]
[l [n}2.721{]}ἀλλʼ ὃ μὲν ἐν νήσῳ κεῖτο κρατέρʼ ἄλγεα πάσχων{l]
[l [n}2.722{]}Λήμνῳ ἐν ἠγαθέῃ, ὅθι μιν λίπον υἷες Ἀχαιῶν{l]
[l [n}2.723{]}ἕλκεϊ μοχθίζοντα κακῷ ὀλοόφρονος ὕδρου·{l]
[l [n}2.724{]}ἔνθʼ ὅ γε κεῖτʼ ἀχέων· τάχα δὲ μνήσεσθαι ἔμελλον{l]
[l [n}2.725{]}Ἀργεῖοι παρὰ νηυσὶ Φιλοκτήταο ἄνακτος.{l]
[l [n}2.726{]}οὐδὲ μὲν οὐδʼ οἳ ἄναρχοι ἔσαν, πόθεόν γε μὲν ἀρχόν·{l]
[l [n}2.727{]}ἀλλὰ Μέδων κόσμησεν Ὀϊλῆος νόθος υἱός,{l]
[l [n}2.728{]}τόν ῥʼ ἔτεκεν Ῥήνη ὑπʼ Ὀϊλῆϊ πτολιπόρθῳ.{l]{para]
[para}[l [n}2.729{]}οἳ δʼ εἶχον Τρίκκην καὶ Ἰθώμην κλωμακόεσσαν,{l]
[l [n}2.730{]}οἵ τʼ ἔχον Οἰχαλίην πόλιν Εὐρύτου Οἰχαλιῆος,{l]
[l [n}2.731{]}τῶν αὖθʼ ἡγείσθην Ἀσκληπιοῦ δύο παῖδε{l]
[l [n}2.732{]}ἰητῆρʼ ἀγαθὼ Ποδαλείριος ἠδὲ Μαχάων·{l]
[l [n}2.733{]}τοῖς δὲ τριήκοντα γλαφυραὶ νέες ἐστιχόωντο.{l]{para]
[para}[l [n}2.734{]}οἳ δʼ ἔχον Ὀρμένιον, οἵ τε κρήνην Ὑπέρειαν,{l]
[l [n}2.735{]}οἵ τʼ ἔχον Ἀστέριον Τιτάνοιό τε λευκὰ κάρηνα,{l]
[l [n}2.736{]}τῶν ἦρχʼ Εὐρύπυλος Εὐαίμονος ἀγλαὸς υἱός·{l]
[l [n}2.737{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.738{]}οἳ δʼ Ἄργισσαν ἔχον καὶ Γυρτώνην ἐνέμοντο,{l]
[l [n}2.739{]}Ὄρθην Ἠλώνην τε πόλιν τʼ Ὀλοοσσόνα λευκήν,{l]
[l [n}2.740{]}τῶν αὖθʼ ἡγεμόνευε μενεπτόλεμος Πολυποίτης{l]
[l [n}2.741{]}υἱὸς Πειριθόοιο τὸν ἀθάνατος τέκετο Ζεύς·{l]
[l [n}2.742{]}τόν ῥʼ ὑπὸ Πειριθόῳ τέκετο κλυτὸς Ἱπποδάμεια{l]
[l [n}2.743{]}ἤματι τῷ ὅτε Φῆρας ἐτίσατο λαχνήεντας,{l]
[l [n}2.744{]}τοὺς δʼ ἐκ Πηλίου ὦσε καὶ Αἰθίκεσσι πέλασσεν·{l]
[l [n}2.745{]}οὐκ οἶος, ἅμα τῷ γε Λεοντεὺς ὄζος Ἄρηος{l]
[l [n}2.746{]}υἱὸς ὑπερθύμοιο Κορώνου Καινεΐδαο·{l]
[l [n}2.747{]}τοῖς δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.748{]}Γουνεὺς δʼ ἐκ Κύφου ἦγε δύω καὶ εἴκοσι νῆας·{l]
[l [n}2.749{]}τῷ δʼ Ἐνιῆνες ἕποντο μενεπτόλεμοί τε Περαιβοὶ{l]
[l [n}2.750{]}οἳ περὶ Δωδώνην δυσχείμερον οἰκίʼ ἔθεντο,{l]
[l [n}2.751{]}οἵ τʼ ἀμφʼ ἱμερτὸν Τιταρησσὸν ἔργα νέμοντο{l]
[l [n}2.752{]}ὅς ῥʼ ἐς Πηνειὸν προΐει καλλίρροον ὕδωρ,{l]
[l [n}2.753{]}οὐδʼ ὅ γε Πηνειῷ συμμίσγεται ἀργυροδίνῃ,{l]
[l [n}2.754{]}ἀλλά τέ μιν καθύπερθεν ἐπιρρέει ἠΰτʼ ἔλαιον·{l]
[l [n}2.755{]}ὅρκου γὰρ δεινοῦ Στυγὸς ὕδατός ἐστιν ἀπορρώξ.{l]{para]
[para}[l [n}2.756{]}Μαγνήτων δʼ ἦρχε Πρόθοος Τενθρηδόνος υἱός,{l]
[l [n}2.757{]}οἳ περὶ Πηνειὸν καὶ Πήλιον εἰνοσίφυλλον{l]
[l [n}2.758{]}ναίεσκον· τῶν μὲν Πρόθοος θοὸς ἡγεμόνευε,{l]
[l [n}2.759{]}τῷ δʼ ἅμα τεσσαράκοντα μέλαιναι νῆες ἕποντο.{l]{para]
[para}[l [n}2.760{]}οὗτοι ἄρʼ ἡγεμόνες Δαναῶν καὶ κοίρανοι ἦσαν·{l]
[l [n}2.761{]}τίς τὰρ τῶν ὄχʼ ἄριστος ἔην σύ μοι ἔννεπε Μοῦσα{l]
[l [n}2.762{]}αὐτῶν ἠδʼ ἵππων, οἳ ἅμʼ Ἀτρεΐδῃσιν ἕποντο.{l]{para]
[para}[l [n}2.763{]}ἵπποι μὲν μέγʼ ἄρισται ἔσαν Φηρητιάδαο,{l]
[l [n}2.764{]}τὰς Εὔμηλος ἔλαυνε ποδώκεας ὄρνιθας ὣς{l]
[l [n}2.765{]}ὄτριχας οἰέτεας σταφύλῇ ἐπὶ νῶτον ἐΐσας·{l]
[l [n}2.766{]}τὰς ἐν Πηρείῃ θρέψʼ ἀργυρότοξος Ἀπόλλων{l]
[l [n}2.767{]}ἄμφω θηλείας, φόβον Ἄρηος φορεούσας.{l]
[l [n}2.768{]}ἀνδρῶν αὖ μέγʼ ἄριστος ἔην Τελαμώνιος Αἴας{l]
[l [n}2.769{]}ὄφρʼ Ἀχιλεὺς μήνιεν· ὃ γὰρ πολὺ φέρτατος ἦεν,{l]
[l [n}2.770{]}ἵπποι θʼ οἳ φορέεσκον ἀμύμονα Πηλεΐωνα.{l]
[l [n}2.771{]}ἀλλʼ ὃ μὲν ἐν νήεσσι κορωνίσι ποντοπόροισι{l]
[l [n}2.772{]}κεῖτʼ ἀπομηνίσας Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}2.773{]}Ἀτρεΐδῃ· λαοὶ δὲ παρὰ ῥηγμῖνι θαλάσσης{l]
[l [n}2.774{]}δίσκοισιν τέρποντο καὶ αἰγανέῃσιν ἱέντες{l]
[l [n}2.775{]}τόξοισίν θʼ· ἵπποι δὲ παρʼ ἅρμασιν οἷσιν ἕκαστος{l]
[l [n}2.776{]}λωτὸν ἐρεπτόμενοι ἐλεόθρεπτόν τε σέλινον{l]
[l [n}2.777{]}ἕστασαν· ἅρματα δʼ εὖ πεπυκασμένα κεῖτο ἀνάκτων{l]
[l [n}2.778{]}ἐν κλισίῃς· οἳ δʼ ἀρχὸν ἀρηΐφιλον ποθέοντες{l]
[l [n}2.779{]}φοίτων ἔνθα καὶ ἔνθα κατὰ στρατὸν οὐδὲ μάχοντο.{l]{para]
[para}[l [n}2.780{]}οἳ δʼ ἄρʼ ἴσαν ὡς εἴ τε πυρὶ χθὼν πᾶσα νέμοιτο·{l]
[l [n}2.781{]}γαῖα δʼ ὑπεστενάχιζε Διὶ ὣς τερπικεραύνῳ{l]
[l [n}2.782{]}χωομένῳ ὅτε τʼ ἀμφὶ Τυφωέϊ γαῖαν ἱμάσσῃ{l]
[l [n}2.783{]}εἰν Ἀρίμοις, ὅθι φασὶ Τυφωέος ἔμμεναι εὐνάς·{l]
[l [n}2.784{]}ὣς ἄρα τῶν ὑπὸ ποσσὶ μέγα στεναχίζετο γαῖα{l]
[l [n}2.785{]}ἐρχομένων· μάλα δʼ ὦκα διέπρησσον πεδίοιο.{l]{para]
[para}[l [n}2.786{]}Τρωσὶν δʼ ἄγγελος ἦλθε ποδήνεμος ὠκέα Ἶρις{l]
[l [n}2.787{]}πὰρ Διὸς αἰγιόχοιο σὺν ἀγγελίῃ ἀλεγεινῇ·{l]
[l [n}2.788{]}οἳ δʼ ἀγορὰς ἀγόρευον ἐπὶ Πριάμοιο θύρῃσι{l]
[l [n}2.789{]}πάντες ὁμηγερέες ἠμὲν νέοι ἠδὲ γέροντες·{l]
[l [n}2.790{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[l [n}2.791{]}εἴσατο δὲ φθογγὴν υἷϊ Πριάμοιο Πολίτῃ,{l]
[l [n}2.792{]}ὃς Τρώων σκοπὸς ἷζε ποδωκείῃσι πεποιθὼς{l]
[l [n}2.793{]}τύμβῳ ἐπʼ ἀκροτάτῳ Αἰσυήταο γέροντος,{l]
[l [n}2.794{]}δέγμενος ὁππότε ναῦφιν ἀφορμηθεῖεν Ἀχαιοί·{l]
[l [n}2.795{]}τῷ μιν ἐεισαμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}2.796{]}ὦ γέρον αἰεί τοι μῦθοι φίλοι ἄκριτοί εἰσιν,{l]
[l [n}2.797{]}ὥς ποτʼ ἐπʼ εἰρήνης· πόλεμος δʼ ἀλίαστος ὄρωρεν.{l]
[l [n}2.798{]}ἤδη μὲν μάλα πολλὰ μάχας εἰσήλυθον ἀνδρῶν,{l]
[l [n}2.799{]}ἀλλʼ οὔ πω τοιόνδε τοσόνδέ τε λαὸν ὄπωπα·{l]
[l [n}2.800{]}λίην γὰρ φύλλοισιν ἐοικότες ἢ ψαμάθοισιν{l]
[l [n}2.801{]}ἔρχονται πεδίοιο μαχησόμενοι προτὶ ἄστυ.{l]
[l [n}2.802{]}Ἕκτορ σοὶ δὲ μάλιστʼ ἐπιτέλλομαι, ὧδε δὲ ῥέξαι·{l]
[l [n}2.803{]}πολλοὶ γὰρ κατὰ ἄστυ μέγα Πριάμου ἐπίκουροι,{l]
[l [n}2.804{]}ἄλλη δʼ ἄλλων γλῶσσα πολυσπερέων ἀνθρώπων·{l]
[l [n}2.805{]}τοῖσιν ἕκαστος ἀνὴρ σημαινέτω οἷσί περ ἄρχει,{l]
[l [n}2.806{]}τῶν δʼ ἐξηγείσθω κοσμησάμενος πολιήτας.{l]{q]{para]
[para}[l [n}2.807{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ οὔ τι θεᾶς ἔπος ἠγνοίησεν,{l]
[l [n}2.808{]}αἶψα δʼ ἔλυσʼ ἀγορήν· ἐπὶ τεύχεα δʼ ἐσσεύοντο·{l]
[l [n}2.809{]}πᾶσαι δʼ ὠΐγνυντο πύλαι, ἐκ δʼ ἔσσυτο λαὸς{l]
[l [n}2.810{]}πεζοί θʼ ἱππῆές τε· πολὺς δʼ ὀρυμαγδὸς ὀρώρει.{l]{para]
[para}[l [n}2.811{]}ἔστι δέ τις προπάροιθε πόλιος αἰπεῖα κολώνη{l]
[l [n}2.812{]}ἐν πεδίῳ ἀπάνευθε περίδρομος ἔνθα καὶ ἔνθα,{l]
[l [n}2.813{]}τὴν ἤτοι ἄνδρες Βατίειαν κικλήσκουσιν,{l]
[l [n}2.814{]}ἀθάνατοι δέ τε σῆμα πολυσκάρθμοιο Μυρίνης·{l]
[l [n}2.815{]}ἔνθα τότε Τρῶές τε διέκριθεν ἠδʼ ἐπίκουροι.{l]{para]
[para}[l [n}2.816{]}Τρωσὶ μὲν ἡγεμόνευε μέγας κορυθαίολος Ἕκτωρ{l]
[l [n}2.817{]}Πριαμίδης· ἅμα τῷ γε πολὺ πλεῖστοι καὶ ἄριστοι{l]
[l [n}2.818{]}λαοὶ θωρήσσοντο μεμαότες ἐγχείῃσι.{l]{para]
[para}[l [n}2.819{]}Δαρδανίων αὖτʼ ἦρχεν ἐῢς πάϊς Ἀγχίσαο{l]
[l [n}2.820{]}Αἰνείας, τὸν ὑπʼ Ἀγχίσῃ τέκε δῖʼ Ἀφροδίτη{l]
[l [n}2.821{]}Ἴδης ἐν κνημοῖσι θεὰ βροτῷ εὐνηθεῖσα,{l]
[l [n}2.822{]}οὐκ οἶος, ἅμα τῷ γε δύω Ἀντήνορος υἷε{l]
[l [n}2.823{]}Ἀρχέλοχός τʼ Ἀκάμας τε μάχης εὖ εἰδότε πάσης.{l]{para]
[para}[l [n}2.824{]}οἳ δὲ Ζέλειαν ἔναιον ὑπαὶ πόδα νείατον Ἴδης{l]
[l [n}2.825{]}ἀφνειοὶ πίνοντες ὕδωρ μέλαν Αἰσήποιο{l]
[l [n}2.826{]}Τρῶες, τῶν αὖτʼ ἦρχε Λυκάονος ἀγλαὸς υἱὸς{l]
[l [n}2.827{]}Πάνδαρος, ᾧ καὶ τόξον Ἀπόλλων αὐτὸς ἔδωκεν.{l]{para]
[para}[l [n}2.828{]}οἳ δʼ Ἀδρήστειάν τʼ εἶχον καὶ δῆμον Ἀπαισοῦ{l]
[l [n}2.829{]}καὶ Πιτύειαν ἔχον καὶ Τηρείης ὄρος αἰπύ,{l]
[l [n}2.830{]}τῶν ἦρχʼ Ἄδρηστός τε καὶ Ἄμφιος λινοθώρηξ{l]
[l [n}2.831{]}υἷε δύω Μέροπος Περκωσίου, ὃς περὶ πάντων{l]
[l [n}2.832{]}ᾔδεε μαντοσύνας, οὐδὲ οὓς παῖδας ἔασκε{l]
[l [n}2.833{]}στείχειν ἐς πόλεμον φθισήνορα· τὼ δέ οἱ οὔ τι{l]
[l [n}2.834{]}πειθέσθην· κῆρες γὰρ ἄγον μέλανος θανάτοιο.{l]{para]
[para}[l [n}2.835{]}οἳ δʼ ἄρα Περκώτην καὶ Πράκτιον ἀμφενέμοντο{l]
[l [n}2.836{]}καὶ Σηστὸν καὶ Ἄβυδον ἔχον καὶ δῖαν Ἀρίσβην,{l]
[l [n}2.837{]}τῶν αὖθʼ Ὑρτακίδης ἦρχʼ Ἄσιος ὄρχαμος ἀνδρῶν,{l]
[l [n}2.838{]}Ἄσιος Ὑρτακίδης ὃν Ἀρίσβηθεν φέρον ἵπποι{l]
[l [n}2.839{]}αἴθωνες μεγάλοι ποταμοῦ ἄπο Σελλήεντος.{l]{para]
[para}[l [n}2.840{]}Ἱππόθοος δʼ ἄγε φῦλα Πελασγῶν ἐγχεσιμώρων{l]
[l [n}2.841{]}τῶν οἳ Λάρισαν ἐριβώλακα ναιετάασκον·{l]
[l [n}2.842{]}τῶν ἦρχʼ Ἱππόθοός τε Πύλαιός τʼ ὄζος Ἄρηος,{l]
[l [n}2.843{]}υἷε δύω Λήθοιο Πελασγοῦ Τευταμίδαο.{l]{para]
[para}[l [n}2.844{]}αὐτὰρ Θρήϊκας ἦγʼ Ἀκάμας καὶ Πείροος ἥρως{l]
[l [n}2.845{]}ὅσσους Ἑλλήσποντος ἀγάρροος ἐντὸς ἐέργει.{l]{para]
[para}[l [n}2.846{]}Εὔφημος δʼ ἀρχὸς Κικόνων ἦν αἰχμητάων{l]
[l [n}2.847{]}υἱὸς Τροιζήνοιο διοτρεφέος Κεάδαο.{l]{para]
[para}[l [n}2.848{]}αὐτὰρ Πυραίχμης ἄγε Παίονας ἀγκυλοτόξους{l]
[l [n}2.849{]}τηλόθεν ἐξ Ἀμυδῶνος ἀπʼ Ἀξιοῦ εὐρὺ ῥέοντος,{l]
[l [n}2.850{]}Ἀξιοῦ οὗ κάλλιστον ὕδωρ ἐπικίδναται αἶαν.{l]{para]
[para}[l [n}2.851{]}Παφλαγόνων δʼ ἡγεῖτο Πυλαιμένεος λάσιον κῆρ{l]
[l [n}2.852{]}ἐξ Ἐνετῶν, ὅθεν ἡμιόνων γένος ἀγροτεράων,{l]
[l [n}2.853{]}οἵ ῥα Κύτωρον ἔχον καὶ Σήσαμον ἀμφενέμοντο{l]
[l [n}2.854{]}ἀμφί τε Παρθένιον ποταμὸν κλυτὰ δώματʼ ἔναιον{l]
[l [n}2.855{]}Κρῶμνάν τʼ Αἰγιαλόν τε καὶ ὑψηλοὺς Ἐρυθίνους.{l]{para]
[para}[l [n}2.856{]}αὐτὰρ Ἁλιζώνων Ὀδίος καὶ Ἐπίστροφος ἦρχον{l]
[l [n}2.857{]}τηλόθεν ἐξ Ἀλύβης, ὅθεν ἀργύρου ἐστὶ γενέθλη.{l]{para]
[para}[l [n}2.858{]}Μυσῶν δὲ Χρόμις ἦρχε καὶ Ἔννομος οἰωνιστής·{l]
[l [n}2.859{]}ἀλλʼ οὐκ οἰωνοῖσιν ἐρύσατο κῆρα μέλαιναν,{l]
[l [n}2.860{]}ἀλλʼ ἐδάμη ὑπὸ χερσὶ ποδώκεος Αἰακίδαο{l]
[l [n}2.861{]}ἐν ποταμῷ, ὅθι περ Τρῶας κεράϊζε καὶ ἄλλους.{l]{para]
[para}[l [n}2.862{]}Φόρκυς αὖ Φρύγας ἦγε καὶ Ἀσκάνιος θεοειδὴς{l]
[l [n}2.863{]}τῆλʼ ἐξ Ἀσκανίης· μέμασαν δʼ ὑσμῖνι μάχεσθαι.{l]{para]
[para}[l [n}2.864{]}Μῄοσιν αὖ Μέσθλης τε καὶ Ἄντιφος ἡγησάσθην{l]
[l [n}2.865{]}υἷε Ταλαιμένεος τὼ Γυγαίη τέκε λίμνη,{l]
[l [n}2.866{]}οἳ καὶ Μῄονας ἦγον ὑπὸ Τμώλῳ γεγαῶτας.{l]{para]
[para}[l [n}2.867{]}Νάστης αὖ Καρῶν ἡγήσατο βαρβαροφώνων,{l]
[l [n}2.868{]}οἳ Μίλητον ἔχον Φθιρῶν τʼ ὄρος ἀκριτόφυλλον{l]
[l [n}2.869{]}Μαιάνδρου τε ῥοὰς Μυκάλης τʼ αἰπεινὰ κάρηνα·{l]
[l [n}2.870{]}τῶν μὲν ἄρʼ Ἀμφίμαχος καὶ Νάστης ἡγησάσθην,{l]
[l [n}2.871{]}Νάστης Ἀμφίμαχός τε Νομίονος ἀγλαὰ τέκνα,{l]
[l [n}2.872{]}ὃς καὶ χρυσὸν ἔχων πόλεμον δʼ ἴεν ἠΰτε κούρη{l]
[l [n}2.873{]}νήπιος, οὐδέ τί οἱ τό γʼ ἐπήρκεσε λυγρὸν ὄλεθρον,{l]
[l [n}2.874{]}ἀλλʼ ἐδάμη ὑπὸ χερσὶ ποδώκεος Αἰακίδαο{l]
[l [n}2.875{]}ἐν ποταμῷ, χρυσὸν δʼ Ἀχιλεὺς ἐκόμισσε δαΐφρων.{l]{para]
[para}[l [n}2.876{]}Σαρπηδὼν δʼ ἦρχεν Λυκίων καὶ Γλαῦκος ἀμύμων{l]
[l [n}2.877{]}τηλόθεν ἐκ Λυκίης, Ξάνθου ἄπο δινήεντος.{l]{para]
{book]
[book [n}3{]}
[para}[l [n}3.1{]}αὐτὰρ ἐπεὶ κόσμηθεν ἅμʼ ἡγεμόνεσσιν ἕκαστοι,{l]
[l [n}3.2{]}Τρῶες μὲν κλαγγῇ τʼ ἐνοπῇ τʼ ἴσαν ὄρνιθες ὣς{l]
[l [n}3.3{]}ἠΰτε περ κλαγγὴ γεράνων πέλει οὐρανόθι πρό·{l]
[l [n}3.4{]}αἵ τʼ ἐπεὶ οὖν χειμῶνα φύγον καὶ ἀθέσφατον ὄμβρον{l]
[l [n}3.5{]}κλαγγῇ ταί γε πέτονται ἐπʼ ὠκεανοῖο ῥοάων{l]
[l [n}3.6{]}ἀνδράσι Πυγμαίοισι φόνον καὶ κῆρα φέρουσαι·{l]
[l [n}3.7{]}ἠέριαι δʼ ἄρα ταί γε κακὴν ἔριδα προφέρονται.{l]
[l [n}3.8{]}οἳ δʼ ἄρʼ ἴσαν σιγῇ μένεα πνείοντες Ἀχαιοὶ{l]
[l [n}3.9{]}ἐν θυμῷ μεμαῶτες ἀλεξέμεν ἀλλήλοισιν.{l]{para]
[para}[l [n}3.10{]}εὖτʼ ὄρεος κορυφῇσι Νότος κατέχευεν ὀμίχλην{l]
[l [n}3.11{]}ποιμέσιν οὔ τι φίλην, κλέπτῃ δέ τε νυκτὸς ἀμείνω,{l]
[l [n}3.12{]}τόσσόν τίς τʼ ἐπιλεύσσει ὅσον τʼ ἐπὶ λᾶαν ἵησιν·{l]
[l [n}3.13{]}ὣς ἄρα τῶν ὑπὸ ποσσὶ κονίσαλος ὄρνυτʼ ἀελλὴς{l]
[l [n}3.14{]}ἐρχομένων· μάλα δʼ ὦκα διέπρησσον πεδίοιο.{l]{para]
[para}[l [n}3.15{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}3.16{]}Τρωσὶν μὲν προμάχιζεν Ἀλέξανδρος θεοειδὴς{l]
[l [n}3.17{]}παρδαλέην ὤμοισιν ἔχων καὶ καμπύλα τόξα{l]
[l [n}3.18{]}καὶ ξίφος· αὐτὰρ δοῦρε δύω κεκορυθμένα χαλκῷ{l]
[l [n}3.19{]}πάλλων Ἀργείων προκαλίζετο πάντας ἀρίστους{l]
[l [n}3.20{]}ἀντίβιον μαχέσασθαι ἐν αἰνῇ δηϊοτῆτι.{l]{para]
[para}[l [n}3.21{]}τὸν δʼ ὡς οὖν ἐνόησεν ἀρηΐφιλος Μενέλαος{l]
[l [n}3.22{]}ἐρχόμενον προπάροιθεν ὁμίλου μακρὰ βιβάντα,{l]
[l [n}3.23{]}ὥς τε λέων ἐχάρη μεγάλῳ ἐπὶ σώματι κύρσας{l]
[l [n}3.24{]}εὑρὼν ἢ ἔλαφον κεραὸν ἢ ἄγριον αἶγα{l]
[l [n}3.25{]}πεινάων· μάλα γάρ τε κατεσθίει, εἴ περ ἂν αὐτὸν{l]
[l [n}3.26{]}σεύωνται ταχέες τε κύνες θαλεροί τʼ αἰζηοί·{l]
[l [n}3.27{]}ὣς ἐχάρη Μενέλαος Ἀλέξανδρον θεοειδέα{l]
[l [n}3.28{]}ὀφθαλμοῖσιν ἰδών· φάτο γὰρ τίσεσθαι ἀλείτην·{l]
[l [n}3.29{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε.{l]{para]
[para}[l [n}3.30{]}τὸν δʼ ὡς οὖν ἐνόησεν Ἀλέξανδρος θεοειδὴς{l]
[l [n}3.31{]}ἐν προμάχοισι φανέντα, κατεπλήγη φίλον ἦτορ,{l]
[l [n}3.32{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων.{l]
[l [n}3.33{]}ὡς δʼ ὅτε τίς τε δράκοντα ἰδὼν παλίνορσος ἀπέστη{l]
[l [n}3.34{]}οὔρεος ἐν βήσσῃς, ὑπό τε τρόμος ἔλλαβε γυῖα,{l]
[l [n}3.35{]}ἂψ δʼ ἀνεχώρησεν, ὦχρός τέ μιν εἷλε παρειάς,{l]
[l [n}3.36{]}ὣς αὖτις καθʼ ὅμιλον ἔδυ Τρώων ἀγερώχων{l]
[l [n}3.37{]}δείσας Ἀτρέος υἱὸν Ἀλέξανδρος θεοειδής.{l]{para]
[para}[l [n}3.38{]}τὸν δʼ Ἕκτωρ νείκεσσεν ἰδὼν αἰσχροῖς ἐπέεσσιν·{l]
[q}[l [n}3.39{]}Δύσπαρι εἶδος ἄριστε γυναιμανὲς ἠπεροπευτὰ{l]
[l [n}3.40{]}αἴθʼ ὄφελες ἄγονός τʼ ἔμεναι ἄγαμός τʼ ἀπολέσθαι·{l]
[l [n}3.41{]}καί κε τὸ βουλοίμην, καί κεν πολὺ κέρδιον ἦεν{l]
[l [n}3.42{]}ἢ οὕτω λώβην τʼ ἔμεναι καὶ ὑπόψιον ἄλλων.{l]
[l [n}3.43{]}ἦ που καγχαλόωσι κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}3.44{]}φάντες ἀριστῆα πρόμον ἔμμεναι, οὕνεκα καλὸν{l]
[l [n}3.45{]}εἶδος ἔπʼ, ἀλλʼ οὐκ ἔστι βίη φρεσὶν οὐδέ τις ἀλκή.{l]
[l [n}3.46{]}ἦ τοιόσδε ἐὼν ἐν ποντοπόροισι νέεσσι{l]
[l [n}3.47{]}πόντον ἐπιπλώσας, ἑτάρους ἐρίηρας ἀγείρας,{l]
[l [n}3.48{]}μιχθεὶς ἀλλοδαποῖσι γυναῖκʼ εὐειδέʼ ἀνῆγες{l]
[l [n}3.49{]}ἐξ ἀπίης γαίης νυὸν ἀνδρῶν αἰχμητάων{l]
[l [n}3.50{]}πατρί τε σῷ μέγα πῆμα πόληΐ τε παντί τε δήμῳ,{l]
[l [n}3.51{]}δυσμενέσιν μὲν χάρμα, κατηφείην δὲ σοὶ αὐτῷ;{l]
[l [n}3.52{]}οὐκ ἂν δὴ μείνειας ἀρηΐφιλον Μενέλαον;{l]
[l [n}3.53{]}γνοίης χʼ οἵου φωτὸς ἔχεις θαλερὴν παράκοιτιν·{l]
[l [n}3.54{]}οὐκ ἄν τοι χραίσμῃ κίθαρις τά τε δῶρʼ Ἀφροδίτης{l]
[l [n}3.55{]}ἥ τε κόμη τό τε εἶδος ὅτʼ ἐν κονίῃσι μιγείης.{l]
[l [n}3.56{]}ἀλλὰ μάλα Τρῶες δειδήμονες· ἦ τέ κεν ἤδη{l]
[l [n}3.57{]}λάϊνον ἕσσο χιτῶνα κακῶν ἕνεχʼ ὅσσα ἔοργας.{l]{q]{para]
[para}[l [n}3.58{]}τὸν δʼ αὖτε προσέειπεν Ἀλέξανδρος θεοειδής·{l]
[q}[l [n}3.59{]}Ἕκτορ ἐπεί με κατʼ αἶσαν ἐνείκεσας οὐδʼ ὑπὲρ αἶσαν·{l]
[l [n}3.60{]}αἰεί τοι κραδίη πέλεκυς ὥς ἐστιν ἀτειρὴς{l]
[l [n}3.61{]}ὅς τʼ εἶσιν διὰ δουρὸς ὑπʼ ἀνέρος ὅς ῥά τε τέχνῃ{l]
[l [n}3.62{]}νήϊον ἐκτάμνῃσιν, ὀφέλλει δʼ ἀνδρὸς ἐρωήν·{l]
[l [n}3.63{]}ὣς σοὶ ἐνὶ στήθεσσιν ἀτάρβητος νόος ἐστί·{l]
[l [n}3.64{]}μή μοι δῶρʼ ἐρατὰ πρόφερε χρυσέης Ἀφροδίτης·{l]
[l [n}3.65{]}οὔ τοι ἀπόβλητʼ ἐστὶ θεῶν ἐρικυδέα δῶρα{l]
[l [n}3.66{]}ὅσσά κεν αὐτοὶ δῶσιν, ἑκὼν δʼ οὐκ ἄν τις ἕλοιτο·{l]
[l [n}3.67{]}νῦν αὖτʼ εἴ μʼ ἐθέλεις πολεμίζειν ἠδὲ μάχεσθαι,{l]
[l [n}3.68{]}ἄλλους μὲν κάθισον Τρῶας καὶ πάντας Ἀχαιούς,{l]
[l [n}3.69{]}αὐτὰρ ἔμʼ ἐν μέσσῳ καὶ ἀρηΐφιλον Μενέλαον{l]
[l [n}3.70{]}συμβάλετʼ ἀμφʼ Ἑλένῃ καὶ κτήμασι πᾶσι μάχεσθαι·{l]
[l [n}3.71{]}ὁππότερος δέ κε νικήσῃ κρείσσων τε γένηται,{l]
[l [n}3.72{]}κτήμαθʼ ἑλὼν εὖ πάντα γυναῖκά τε οἴκαδʼ ἀγέσθω·{l]
[l [n}3.73{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ ταμόντες{l]
[l [n}3.74{]}ναίοιτε Τροίην ἐριβώλακα, τοὶ δὲ νεέσθων{l]
[l [n}3.75{]}Ἄργος ἐς ἱππόβοτον καὶ Ἀχαιΐδα καλλιγύναικα.{l]{q]{para]
[para}[l [n}3.76{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ αὖτʼ ἐχάρη μέγα μῦθον ἀκούσας,{l]
[l [n}3.77{]}καί ῥʼ ἐς μέσσον ἰὼν Τρώων ἀνέεργε φάλαγγας{l]
[l [n}3.78{]}μέσσου δουρὸς ἑλών· τοὶ δʼ ἱδρύνθησαν ἅπαντες.{l]
[l [n}3.79{]}τῷ δʼ ἐπετοξάζοντο κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}3.80{]}ἰοῖσίν τε τιτυσκόμενοι λάεσσί τʼ ἔβαλλον·{l]
[l [n}3.81{]}αὐτὰρ ὃ μακρὸν ἄϋσεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}3.82{]}ἴσχεσθʼ Ἀργεῖοι, μὴ βάλλετε κοῦροι Ἀχαιῶν·{l]
[l [n}3.83{]}στεῦται γάρ τι ἔπος ἐρέειν κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}3.84{]}ὣς ἔφαθʼ, οἳ δʼ ἔσχοντο μάχης ἄνεῴ τʼ ἐγένοντο{l]
[l [n}3.85{]}ἐσσυμένως· Ἕκτωρ δὲ μετʼ ἀμφοτέροισιν ἔειπε·{l]
[q}[l [n}3.86{]}κέκλυτέ μευ Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}3.87{]}μῦθον Ἀλεξάνδροιο, τοῦ εἵνεκα νεῖκος ὄρωρεν.{l]
[l [n}3.88{]}ἄλλους μὲν κέλεται Τρῶας καὶ πάντας Ἀχαιοὺς{l]
[l [n}3.89{]}τεύχεα κάλʼ ἀποθέσθαι ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}3.90{]}αὐτὸν δʼ ἐν μέσσῳ καὶ ἀρηΐφιλον Μενέλαον{l]
[l [n}3.91{]}οἴους ἀμφʼ Ἑλένῃ καὶ κτήμασι πᾶσι μάχεσθαι.{l]
[l [n}3.92{]}ὁππότερος δέ κε νικήσῃ κρείσσων τε γένηται{l]
[l [n}3.93{]}κτήμαθʼ ἑλὼν εὖ πάντα γυναῖκά τε οἴκαδʼ ἀγέσθω·{l]
[l [n}3.94{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ τάμωμεν.{l]{q]{para]
[para}[l [n}3.95{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ·{l]
[l [n}3.96{]}τοῖσι δὲ καὶ μετέειπε βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}3.97{]}κέκλυτε νῦν καὶ ἐμεῖο· μάλιστα γὰρ ἄλγος ἱκάνει{l]
[l [n}3.98{]}θυμὸν ἐμόν, φρονέω δὲ διακρινθήμεναι ἤδη{l]
[l [n}3.99{]}Ἀργείους καὶ Τρῶας, ἐπεὶ κακὰ πολλὰ πέπασθε{l]
[l [n}3.100{]}εἵνεκʼ ἐμῆς ἔριδος καὶ Ἀλεξάνδρου ἕνεκʼ ἀρχῆς·{l]
[l [n}3.101{]}ἡμέων δʼ ὁπποτέρῳ θάνατος καὶ μοῖρα τέτυκται{l]
[l [n}3.102{]}τεθναίη· ἄλλοι δὲ διακρινθεῖτε τάχιστα.{l]
[l [n}3.103{]}οἴσετε ἄρνʼ, ἕτερον λευκόν, ἑτέρην δὲ μέλαιναν,{l]
[l [n}3.104{]}Γῇ τε καὶ Ἠελίῳ· Διὶ δʼ ἡμεῖς οἴσομεν ἄλλον·{l]
[l [n}3.105{]}ἄξετε δὲ Πριάμοιο βίην, ὄφρʼ ὅρκια τάμνῃ{l]
[l [n}3.106{]}αὐτός, ἐπεί οἱ παῖδες ὑπερφίαλοι καὶ ἄπιστοι,{l]
[l [n}3.107{]}μή τις ὑπερβασίῃ Διὸς ὅρκια δηλήσηται.{l]
[l [n}3.108{]}αἰεὶ δʼ ὁπλοτέρων ἀνδρῶν φρένες ἠερέθονται·{l]
[l [n}3.109{]}οἷς δʼ ὁ γέρων μετέῃσιν ἅμα πρόσσω καὶ ὀπίσσω{l]
[l [n}3.110{]}λεύσσει, ὅπως ὄχʼ ἄριστα μετʼ ἀμφοτέροισι γένηται.{l]{q]{para]
[para}[l [n}3.111{]}ὣς ἔφαθʼ, οἳ δʼ ἐχάρησαν Ἀχαιοί τε Τρῶές τε{l]
[l [n}3.112{]}ἐλπόμενοι παύσασθαι ὀϊζυροῦ πολέμοιο.{l]
[l [n}3.113{]}καί ῥʼ ἵππους μὲν ἔρυξαν ἐπὶ στίχας, ἐκ δʼ ἔβαν αὐτοί,{l]
[l [n}3.114{]}τεύχεά τʼ ἐξεδύοντο· τὰ μὲν κατέθεντʼ ἐπὶ γαίῃ{l]
[l [n}3.115{]}πλησίον ἀλλήλων, ὀλίγη δʼ ἦν ἀμφὶς ἄρουρα·{l]
[l [n}3.116{]}Ἕκτωρ δὲ προτὶ ἄστυ δύω κήρυκας ἔπεμπε{l]
[l [n}3.117{]}καρπαλίμως ἄρνάς τε φέρειν Πρίαμόν τε καλέσσαι·{l]
[l [n}3.118{]}αὐτὰρ ὃ Ταλθύβιον προΐει κρείων Ἀγαμέμνων{l]
[l [n}3.119{]}νῆας ἔπι γλαφυρὰς ἰέναι, ἠδʼ ἄρνʼ ἐκέλευεν{l]
[l [n}3.120{]}οἰσέμεναι· ὃ δʼ ἄρʼ οὐκ ἀπίθησʼ Ἀγαμέμνονι δίῳ.{l]{para]
[para}[l [n}3.121{]}Ἶρις δʼ αὖθʼ Ἑλένῃ λευκωλένῳ ἄγγελος ἦλθεν{l]
[l [n}3.122{]}εἰδομένη γαλόῳ Ἀντηνορίδαο δάμαρτι,{l]
[l [n}3.123{]}τὴν Ἀντηνορίδης εἶχε κρείων Ἑλικάων{l]
[l [n}3.124{]}Λαοδίκην Πριάμοιο θυγατρῶν εἶδος ἀρίστην.{l]
[l [n}3.125{]}τὴν δʼ εὗρʼ ἐν μεγάρῳ· ἣ δὲ μέγαν ἱστὸν ὕφαινε{l]
[l [n}3.126{]}δίπλακα πορφυρέην, πολέας δʼ ἐνέπασσεν ἀέθλους{l]
[l [n}3.127{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}3.128{]}οὕς ἑθεν εἵνεκʼ ἔπασχον ὑπʼ Ἄρηος παλαμάων·{l]
[l [n}3.129{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}3.130{]}δεῦρʼ ἴθι νύμφα φίλη, ἵνα θέσκελα ἔργα ἴδηαι{l]
[l [n}3.131{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}3.132{]}οἳ πρὶν ἐπʼ ἀλλήλοισι φέρον πολύδακρυν Ἄρηα{l]
[l [n}3.133{]}ἐν πεδίῳ ὀλοοῖο λιλαιόμενοι πολέμοιο·{l]
[l [n}3.134{]}οἳ δὴ νῦν ἕαται σιγῇ, πόλεμος δὲ πέπαυται,{l]
[l [n}3.135{]}ἀσπίσι κεκλιμένοι, παρὰ δʼ ἔγχεα μακρὰ πέπηγεν.{l]
[l [n}3.136{]}αὐτὰρ Ἀλέξανδρος καὶ ἀρηΐφιλος Μενέλαος{l]
[l [n}3.137{]}μακρῇς ἐγχείῃσι μαχήσονται περὶ σεῖο·{l]
[l [n}3.138{]}τῷ δέ κε νικήσαντι φίλη κεκλήσῃ ἄκοιτις.{l]{q]{para]
[para}[l [n}3.139{]}ὣς εἰποῦσα θεὰ γλυκὺν ἵμερον ἔμβαλε θυμῷ{l]
[l [n}3.140{]}ἀνδρός τε προτέρου καὶ ἄστεος ἠδὲ τοκήων·{l]
[l [n}3.141{]}αὐτίκα δʼ ἀργεννῇσι καλυψαμένη ὀθόνῃσιν{l]
[l [n}3.142{]}ὁρμᾶτʼ ἐκ θαλάμοιο τέρεν κατὰ δάκρυ χέουσα{l]
[l [n}3.143{]}οὐκ οἴη, ἅμα τῇ γε καὶ ἀμφίπολοι δύʼ ἕποντο,{l]
[l [n}3.144{]}Αἴθρη Πιτθῆος θυγάτηρ, Κλυμένη τε βοῶπις·{l]
[l [n}3.145{]}αἶψα δʼ ἔπειθʼ ἵκανον ὅθι Σκαιαὶ πύλαι ἦσαν.{l]{para]
[para}[l [n}3.146{]}οἳ δʼ ἀμφὶ Πρίαμον καὶ Πάνθοον ἠδὲ Θυμοίτην{l]
[l [n}3.147{]}Λάμπόν τε Κλυτίον θʼ Ἱκετάονά τʼ ὄζον Ἄρηος{l]
[l [n}3.148{]}Οὐκαλέγων τε καὶ Ἀντήνωρ πεπνυμένω ἄμφω{l]
[l [n}3.149{]}ἥατο δημογέροντες ἐπὶ Σκαιῇσι πύλῃσι,{l]
[l [n}3.150{]}γήραϊ δὴ πολέμοιο πεπαυμένοι, ἀλλʼ ἀγορηταὶ{l]
[l [n}3.151{]}ἐσθλοί, τεττίγεσσιν ἐοικότες οἵ τε καθʼ ὕλην{l]
[l [n}3.152{]}δενδρέῳ ἐφεζόμενοι ὄπα λειριόεσσαν ἱεῖσι·{l]
[l [n}3.153{]}τοῖοι ἄρα Τρώων ἡγήτορες ἧντʼ ἐπὶ πύργῳ.{l]
[l [n}3.154{]}οἳ δʼ ὡς οὖν εἴδονθʼ Ἑλένην ἐπὶ πύργον ἰοῦσαν,{l]
[l [n}3.155{]}ἦκα πρὸς ἀλλήλους ἔπεα πτερόεντʼ ἀγόρευον·{l]
[q}[l [n}3.156{]}οὐ νέμεσις Τρῶας καὶ ἐϋκνήμιδας Ἀχαιοὺς{l]
[l [n}3.157{]}τοιῇδʼ ἀμφὶ γυναικὶ πολὺν χρόνον ἄλγεα πάσχειν·{l]
[l [n}3.158{]}αἰνῶς ἀθανάτῃσι θεῇς εἰς ὦπα ἔοικεν·{l]
[l [n}3.159{]}ἀλλὰ καὶ ὧς τοίη περ ἐοῦσʼ ἐν νηυσὶ νεέσθω,{l]
[l [n}3.160{]}μηδʼ ἡμῖν τεκέεσσί τʼ ὀπίσσω πῆμα λίποιτο.{l]{q]{para]
[para}[l [n}3.161{]}ὣς ἄρʼ ἔφαν, Πρίαμος δʼ Ἑλένην ἐκαλέσσατο φωνῇ·{l]
[q}[l [n}3.162{]}δεῦρο πάροιθʼ ἐλθοῦσα φίλον τέκος ἵζευ ἐμεῖο,{l]
[l [n}3.163{]}ὄφρα ἴδῃ πρότερόν τε πόσιν πηούς τε φίλους τε·{l]
[l [n}3.164{]}οὔ τί μοι αἰτίη ἐσσί, θεοί νύ μοι αἴτιοί εἰσιν{l]
[l [n}3.165{]}οἵ μοι ἐφώρμησαν πόλεμον πολύδακρυν Ἀχαιῶν·{l]
[l [n}3.166{]}ὥς μοι καὶ τόνδʼ ἄνδρα πελώριον ἐξονομήνῃς{l]
[l [n}3.167{]}ὅς τις ὅδʼ ἐστὶν Ἀχαιὸς ἀνὴρ ἠΰς τε μέγας τε.{l]
[l [n}3.168{]}ἤτοι μὲν κεφαλῇ καὶ μείζονες ἄλλοι ἔασι,{l]
[l [n}3.169{]}καλὸν δʼ οὕτω ἐγὼν οὔ πω ἴδον ὀφθαλμοῖσιν,{l]
[l [n}3.170{]}οὐδʼ οὕτω γεραρόν· βασιλῆϊ γὰρ ἀνδρὶ ἔοικε.{l]{q]{para]
[para}[l [n}3.171{]}τὸν δʼ Ἑλένη μύθοισιν ἀμείβετο δῖα γυναικῶν·{l]
[q}[l [n}3.172{]}αἰδοῖός τέ μοί ἐσσι φίλε ἑκυρὲ δεινός τε·{l]
[l [n}3.173{]}ὡς ὄφελεν θάνατός μοι ἁδεῖν κακὸς ὁππότε δεῦρο{l]
[l [n}3.174{]}υἱέϊ σῷ ἑπόμην θάλαμον γνωτούς τε λιποῦσα{l]
[l [n}3.175{]}παῖδά τε τηλυγέτην καὶ ὁμηλικίην ἐρατεινήν.{l]
[l [n}3.176{]}ἀλλὰ τά γʼ οὐκ ἐγένοντο· τὸ καὶ κλαίουσα τέτηκα.{l]
[l [n}3.177{]}τοῦτο δέ τοι ἐρέω ὅ μʼ ἀνείρεαι ἠδὲ μεταλλᾷς·{l]
[l [n}3.178{]}οὗτός γʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων,{l]
[l [n}3.179{]}ἀμφότερον βασιλεύς τʼ ἀγαθὸς κρατερός τʼ αἰχμητής·{l]
[l [n}3.180{]}δαὴρ αὖτʼ ἐμὸς ἔσκε κυνώπιδος, εἴ ποτʼ ἔην γε.{l]{q]{para]
[para}[l [n}3.181{]}ὣς φάτο, τὸν δʼ ὁ γέρων ἠγάσσατο φώνησέν τε·{l]
[q}[l [n}3.182{]}ὦ μάκαρ Ἀτρεΐδη μοιρηγενὲς ὀλβιόδαιμον,{l]
[l [n}3.183{]}ἦ ῥά νύ τοι πολλοὶ δεδμήατο κοῦροι Ἀχαιῶν.{l]
[l [n}3.184{]}ἤδη καὶ Φρυγίην εἰσήλυθον ἀμπελόεσσαν,{l]
[l [n}3.185{]}ἔνθα ἴδον πλείστους Φρύγας ἀνέρας αἰολοπώλους{l]
[l [n}3.186{]}λαοὺς Ὀτρῆος καὶ Μυγδόνος ἀντιθέοιο,{l]
[l [n}3.187{]}οἵ ῥα τότʼ ἐστρατόωντο παρʼ ὄχθας Σαγγαρίοιο·{l]
[l [n}3.188{]}καὶ γὰρ ἐγὼν ἐπίκουρος ἐὼν μετὰ τοῖσιν ἐλέχθην{l]
[l [n}3.189{]}ἤματι τῷ ὅτε τʼ ἦλθον Ἀμαζόνες ἀντιάνειραι·{l]
[l [n}3.190{]}ἀλλʼ οὐδʼ οἳ τόσοι ἦσαν ὅσοι ἑλίκωπες Ἀχαιοί.{l]{q]{para]
[para}[l [n}3.191{]}δεύτερον αὖτʼ Ὀδυσῆα ἰδὼν ἐρέεινʼ ὁ γεραιός·{l]
[q}[l [n}3.192{]}εἴπʼ ἄγε μοι καὶ τόνδε φίλον τέκος ὅς τις ὅδʼ ἐστί·{l]
[l [n}3.193{]}μείων μὲν κεφαλῇ Ἀγαμέμνονος Ἀτρεΐδαο,{l]
[l [n}3.194{]}εὐρύτερος δʼ ὤμοισιν ἰδὲ στέρνοισιν ἰδέσθαι.{l]
[l [n}3.195{]}τεύχεα μέν οἱ κεῖται ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}3.196{]}αὐτὸς δὲ κτίλος ὣς ἐπιπωλεῖται στίχας ἀνδρῶν·{l]
[l [n}3.197{]}ἀρνειῷ μιν ἔγωγε ἐΐσκω πηγεσιμάλλῳ,{l]
[l [n}3.198{]}ὅς τʼ οἰῶν μέγα πῶϋ διέρχεται ἀργεννάων.{l]{q]{para]
[para}[l [n}3.199{]}τὸν δʼ ἠμείβετʼ ἔπειθʼ Ἑλένη Διὸς ἐκγεγαυῖα·{l]
[q}[l [n}3.200{]}οὗτος δʼ αὖ Λαερτιάδης πολύμητις Ὀδυσσεύς,{l]
[l [n}3.201{]}ὃς τράφη ἐν δήμῳ Ἰθάκης κραναῆς περ ἐούσης{l]
[l [n}3.202{]}εἰδὼς παντοίους τε δόλους καὶ μήδεα πυκνά.{l]{q]{para]
[para}[l [n}3.203{]}τὴν δʼ αὖτʼ Ἀντήνωρ πεπνυμένος ἀντίον ηὔδα·{l]
[q}[l [n}3.204{]}ὦ γύναι ἦ μάλα τοῦτο ἔπος νημερτὲς ἔειπες·{l]
[l [n}3.205{]}ἤδη γὰρ καὶ δεῦρό ποτʼ ἤλυθε δῖος Ὀδυσσεὺς{l]
[l [n}3.206{]}σεῦ ἕνεκʼ ἀγγελίης σὺν ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.207{]}τοὺς δʼ ἐγὼ ἐξείνισσα καὶ ἐν μεγάροισι φίλησα,{l]
[l [n}3.208{]}ἀμφοτέρων δὲ φυὴν ἐδάην καὶ μήδεα πυκνά.{l]
[l [n}3.209{]}ἀλλʼ ὅτε δὴ Τρώεσσιν ἐν ἀγρομένοισιν ἔμιχθεν{l]
[l [n}3.210{]}στάντων μὲν Μενέλαος ὑπείρεχεν εὐρέας ὤμους,{l]
[l [n}3.211{]}ἄμφω δʼ ἑζομένω γεραρώτερος ἦεν Ὀδυσσεύς·{l]
[l [n}3.212{]}ἀλλʼ ὅτε δὴ μύθους καὶ μήδεα πᾶσιν ὕφαινον{l]
[l [n}3.213{]}ἤτοι μὲν Μενέλαος ἐπιτροχάδην ἀγόρευε,{l]
[l [n}3.214{]}παῦρα μὲν ἀλλὰ μάλα λιγέως, ἐπεὶ οὐ πολύμυθος{l]
[l [n}3.215{]}οὐδʼ ἀφαμαρτοεπής· ἦ καὶ γένει ὕστερος ἦεν.{l]
[l [n}3.216{]}ἀλλʼ ὅτε δὴ πολύμητις ἀναΐξειεν Ὀδυσσεὺς{l]
[l [n}3.217{]}στάσκεν, ὑπαὶ δὲ ἴδεσκε κατὰ χθονὸς ὄμματα πήξας,{l]
[l [n}3.218{]}σκῆπτρον δʼ οὔτʼ ὀπίσω οὔτε προπρηνὲς ἐνώμα,{l]
[l [n}3.219{]}ἀλλʼ ἀστεμφὲς ἔχεσκεν ἀΐδρεϊ φωτὶ ἐοικώς·{l]
[l [n}3.220{]}φαίης κε ζάκοτόν τέ τινʼ ἔμμεναι ἄφρονά τʼ αὔτως.{l]
[l [n}3.221{]}ἀλλʼ ὅτε δὴ ὄπα τε μεγάλην ἐκ στήθεος εἵη{l]
[l [n}3.222{]}καὶ ἔπεα νιφάδεσσιν ἐοικότα χειμερίῃσιν,{l]
[l [n}3.223{]}οὐκ ἂν ἔπειτʼ Ὀδυσῆΐ γʼ ἐρίσσειε βροτὸς ἄλλος·{l]
[l [n}3.224{]}οὐ τότε γʼ ὧδʼ Ὀδυσῆος ἀγασσάμεθʼ εἶδος ἰδόντες.{l]{q]{para]
[para}[l [n}3.225{]}τὸ τρίτον αὖτʼ Αἴαντα ἰδὼν ἐρέεινʼ ὃ γεραιός·{l]
[q}[l [n}3.226{]}τίς τὰρ ὅδʼ ἄλλος Ἀχαιὸς ἀνὴρ ἠΰς τε μέγας τε{l]
[l [n}3.227{]}ἔξοχος Ἀργείων κεφαλήν τε καὶ εὐρέας ὤμους;{l]{q]{para]
[para}[l [n}3.228{]}τὸν δʼ Ἑλένη τανύπεπλος ἀμείβετο δῖα γυναικῶν·{l]
[q}[l [n}3.229{]}οὗτος δʼ Αἴας ἐστὶ πελώριος ἕρκος Ἀχαιῶν·{l]
[l [n}3.230{]}Ἰδομενεὺς δʼ ἑτέρωθεν ἐνὶ Κρήτεσσι θεὸς ὣς{l]
[l [n}3.231{]}ἕστηκʼ, ἀμφὶ δέ μιν Κρητῶν ἀγοὶ ἠγερέθονται.{l]
[l [n}3.232{]}πολλάκι μιν ξείνισσεν ἀρηΐφιλος Μενέλαος{l]
[l [n}3.233{]}οἴκῳ ἐν ἡμετέρῳ ὁπότε Κρήτηθεν ἵκοιτο.{l]
[l [n}3.234{]}νῦν δʼ ἄλλους μὲν πάντας ὁρῶ ἑλίκωπας Ἀχαιούς,{l]
[l [n}3.235{]}οὕς κεν ἐῢ γνοίην καί τʼ οὔνομα μυθησαίμην·{l]
[l [n}3.236{]}δοιὼ δʼ οὐ δύναμαι ἰδέειν κοσμήτορε λαῶν{l]
[l [n}3.237{]}Κάστορά θʼ ἱππόδαμον καὶ πὺξ ἀγαθὸν Πολυδεύκεα{l]
[l [n}3.238{]}αὐτοκασιγνήτω, τώ μοι μία γείνατο μήτηρ.{l]
[l [n}3.239{]}ἢ οὐχ ἑσπέσθην Λακεδαίμονος ἐξ ἐρατεινῆς,{l]
[l [n}3.240{]}ἢ δεύρω μὲν ἕποντο νέεσσʼ ἔνι ποντοπόροισι,{l]
[l [n}3.241{]}νῦν αὖτʼ οὐκ ἐθέλουσι μάχην καταδύμεναι ἀνδρῶν{l]
[l [n}3.242{]}αἴσχεα δειδιότες καὶ ὀνείδεα πόλλʼ ἅ μοί ἐστιν.{l]{q]{para]
[para}[l [n}3.243{]}ὣς φάτο, τοὺς δʼ ἤδη κάτεχεν φυσίζοος αἶα{l]
[l [n}3.244{]}ἐν Λακεδαίμονι αὖθι φίλῃ ἐν πατρίδι γαίῃ.{l]{para]
[para}[l [n}3.245{]}κήρυκες δʼ ἀνὰ ἄστυ θεῶν φέρον ὅρκια πιστὰ{l]
[l [n}3.246{]}ἄρνε δύω καὶ οἶνον ἐΰφρονα καρπὸν ἀρούρης{l]
[l [n}3.247{]}ἀσκῷ ἐν αἰγείῳ· φέρε δὲ κρητῆρα φαεινὸν{l]
[l [n}3.248{]}κῆρυξ Ἰδαῖος ἠδὲ χρύσεια κύπελλα·{l]
[l [n}3.249{]}ὄτρυνεν δὲ γέροντα παριστάμενος ἐπέεσσιν·{l]
[q}[l [n}3.250{]}ὄρσεο Λαομεδοντιάδη, καλέουσιν ἄριστοι{l]
[l [n}3.251{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}3.252{]}ἐς πεδίον καταβῆναι ἵνʼ ὅρκια πιστὰ τάμητε·{l]
[l [n}3.253{]}αὐτὰρ Ἀλέξανδρος καὶ ἀρηΐφιλος Μενέλαος{l]
[l [n}3.254{]}μακρῇς ἐγχείῃσι μαχήσοντʼ ἀμφὶ γυναικί·{l]
[l [n}3.255{]}τῷ δέ κε νικήσαντι γυνὴ καὶ κτήμαθʼ ἕποιτο·{l]
[l [n}3.256{]}οἳ δʼ ἄλλοι φιλότητα καὶ ὅρκια πιστὰ ταμόντες{l]
[l [n}3.257{]}ναίοιμεν Τροίην ἐριβώλακα, τοὶ δὲ νέονται{l]
[l [n}3.258{]}Ἄργος ἐς ἱππόβοτον καὶ Ἀχαιΐδα καλλιγύναικα.{l]{q]{para]
[para}[l [n}3.259{]}ὣς φάτο ῥίγησεν δʼ ὃ γέρων, ἐκέλευσε δʼ ἑταίρους{l]
[l [n}3.260{]}ἵππους ζευγνύμεναι· τοὶ δʼ ὀτραλέως ἐπίθοντο.{l]
[l [n}3.261{]}ἂν δʼ ἄρʼ ἔβη Πρίαμος, κατὰ δʼ ἡνία τεῖνεν ὀπίσσω·{l]
[l [n}3.262{]}πὰρ δέ οἱ Ἀντήνωρ περικαλλέα βήσετο δίφρον·{l]
[l [n}3.263{]}τὼ δὲ διὰ Σκαιῶν πεδίον δʼ ἔχον ὠκέας ἵππους.{l]{para]
[para}[l [n}3.264{]}ἀλλʼ ὅτε δή ῥʼ ἵκοντο μετὰ Τρῶας καὶ Ἀχαιούς,{l]
[l [n}3.265{]}ἐξ ἵππων ἀποβάντες ἐπὶ χθόνα πουλυβότειραν{l]
[l [n}3.266{]}ἐς μέσσον Τρώων καὶ Ἀχαιῶν ἐστιχόωντο.{l]
[l [n}3.267{]}ὄρνυτο δʼ αὐτίκʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}3.268{]}ἂν δʼ Ὀδυσεὺς πολύμητις· ἀτὰρ κήρυκες ἀγαυοὶ{l]
[l [n}3.269{]}ὅρκια πιστὰ θεῶν σύναγον, κρητῆρι δὲ οἶνον{l]
[l [n}3.270{]}μίσγον, ἀτὰρ βασιλεῦσιν ὕδωρ ἐπὶ χεῖρας ἔχευαν.{l]
[l [n}3.271{]}Ἀτρεΐδης δὲ ἐρυσσάμενος χείρεσσι μάχαιραν,{l]
[l [n}3.272{]}ἥ οἱ πὰρ ξίφεος μέγα κουλεόν αἰὲν ἄωρτο,{l]
[l [n}3.273{]}ἀρνῶν ἐκ κεφαλέων τάμνε τρίχας· αὐτὰρ ἔπειτα{l]
[l [n}3.274{]}κήρυκες Τρώων καὶ Ἀχαιῶν νεῖμαν ἀρίστοις.{l]
[l [n}3.275{]}τοῖσιν δʼ Ἀτρεΐδης μεγάλʼ εὔχετο χεῖρας ἀνασχών·{l]
[q}[l [n}3.276{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε,{l]
[l [n}3.277{]}Ἠέλιός θʼ, ὃς πάντʼ ἐφορᾷς καὶ πάντʼ ἐπακούεις,{l]
[l [n}3.278{]}καὶ ποταμοὶ καὶ γαῖα, καὶ οἳ ὑπένερθε καμόντας{l]
[l [n}3.279{]}ἀνθρώπους τίνυσθον ὅτις κʼ ἐπίορκον ὀμόσσῃ,{l]
[l [n}3.280{]}ὑμεῖς μάρτυροι ἔστε, φυλάσσετε δʼ ὅρκια πιστά·{l]
[l [n}3.281{]}εἰ μέν κεν Μενέλαον Ἀλέξανδρος καταπέφνῃ{l]
[l [n}3.282{]}αὐτὸς ἔπειθʼ Ἑλένην ἐχέτω καὶ κτήματα πάντα,{l]
[l [n}3.283{]}ἡμεῖς δʼ ἐν νήεσσι νεώμεθα ποντοπόροισιν·{l]
[l [n}3.284{]}εἰ δέ κʼ Ἀλέξανδρον κτείνῃ ξανθὸς Μενέλαος,{l]
[l [n}3.285{]}Τρῶας ἔπειθʼ Ἑλένην καὶ κτήματα πάντʼ ἀποδοῦναι,{l]
[l [n}3.286{]}τιμὴν δʼ Ἀργείοις ἀποτινέμεν ἥν τινʼ ἔοικεν,{l]
[l [n}3.287{]}ἥ τε καὶ ἐσσομένοισι μετʼ ἀνθρώποισι πέληται.{l]
[l [n}3.288{]}εἰ δʼ ἂν ἐμοὶ τιμὴν Πρίαμος Πριάμοιό τε παῖδες{l]
[l [n}3.289{]}τίνειν οὐκ ἐθέλωσιν Ἀλεξάνδροιο πεσόντος,{l]
[l [n}3.290{]}αὐτὰρ ἐγὼ καὶ ἔπειτα μαχήσομαι εἵνεκα ποινῆς{l]
[l [n}3.291{]}αὖθι μένων, ἧός κε τέλος πολέμοιο κιχείω.{l]{q]{para]
[para}[l [n}3.292{]}ἦ, καὶ ἀπὸ στομάχους ἀρνῶν τάμε νηλέϊ χαλκῷ·{l]
[l [n}3.293{]}καὶ τοὺς μὲν κατέθηκεν ἐπὶ χθονὸς ἀσπαίροντας{l]
[l [n}3.294{]}θυμοῦ δευομένους· ἀπὸ γὰρ μένος εἵλετο χαλκός.{l]
[l [n}3.295{]}οἶνον δʼ ἐκ κρητῆρος ἀφυσσόμενοι δεπάεσσιν{l]
[l [n}3.296{]}ἔκχεον, ἠδʼ εὔχοντο θεοῖς αἰειγενέτῃσιν.{l]
[l [n}3.297{]}ὧδε δέ τις εἴπεσκεν Ἀχαιῶν τε Τρώων τε·{l]
[q}[l [n}3.298{]}Ζεῦ κύδιστε μέγιστε καὶ ἀθάνατοι θεοὶ ἄλλοι{l]
[l [n}3.299{]}ὁππότεροι πρότεροι ὑπὲρ ὅρκια πημήνειαν{l]
[l [n}3.300{]}ὧδέ σφʼ ἐγκέφαλος χαμάδις ῥέοι ὡς ὅδε οἶνος{l]
[l [n}3.301{]}αὐτῶν καὶ τεκέων, ἄλοχοι δʼ ἄλλοισι δαμεῖεν.{l]{q]{para]
[para}[l [n}3.302{]}ὣς ἔφαν, οὐδʼ ἄρα πώ σφιν ἐπεκραίαινε Κρονίων.{l]
[l [n}3.303{]}τοῖσι δὲ Δαρδανίδης Πρίαμος μετὰ μῦθον ἔειπε·{l]
[q}[l [n}3.304{]}κέκλυτέ μευ Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοί·{l]
[l [n}3.305{]}ἤτοι ἐγὼν εἶμι προτὶ Ἴλιον ἠνεμόεσσαν{l]
[l [n}3.306{]}ἄψ, ἐπεὶ οὔ πω τλήσομʼ ἐν ὀφθαλμοῖσιν ὁρᾶσθαι{l]
[l [n}3.307{]}μαρνάμενον φίλον υἱὸν ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.308{]}Ζεὺς μέν που τό γε οἶδε καὶ ἀθάνατοι θεοὶ ἄλλοι{l]
[l [n}3.309{]}ὁπποτέρῳ θανάτοιο τέλος πεπρωμένον ἐστίν.{l]{q]{para]
[para}[l [n}3.310{]}ἦ ῥα καὶ ἐς δίφρον ἄρνας θέτο ἰσόθεος φώς,{l]
[l [n}3.311{]}ἂν δʼ ἄρʼ ἔβαινʼ αὐτός, κατὰ δʼ ἡνία τεῖνεν ὀπίσσω·{l]
[l [n}3.312{]}πὰρ δέ οἱ Ἀντήνωρ περικαλλέα βήσετο δίφρον.{l]
[l [n}3.313{]}τὼ μὲν ἄρʼ ἄψορροι προτὶ Ἴλιον ἀπονέοντο·{l]
[l [n}3.314{]}Ἕκτωρ δὲ Πριάμοιο πάϊς καὶ δῖος Ὀδυσσεὺς{l]
[l [n}3.315{]}χῶρον μὲν πρῶτον διεμέτρεον, αὐτὰρ ἔπειτα{l]
[l [n}3.316{]}κλήρους ἐν κυνέῃ χαλκήρεϊ πάλλον ἑλόντες,{l]
[l [n}3.317{]}ὁππότερος δὴ πρόσθεν ἀφείη χάλκεον ἔγχος.{l]
[l [n}3.318{]}λαοὶ δʼ ἠρήσαντο, θεοῖσι δὲ χεῖρας ἀνέσχον,{l]
[l [n}3.319{]}ὧδε δέ τις εἴπεσκεν Ἀχαιῶν τε Τρώων τε·{l]
[q}[l [n}3.320{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε{l]
[l [n}3.321{]}ὁππότερος τάδε ἔργα μετʼ ἀμφοτέροισιν ἔθηκε,{l]
[l [n}3.322{]}τὸν δὸς ἀποφθίμενον δῦναι δόμον Ἄϊδος εἴσω,{l]
[l [n}3.323{]}ἡμῖν δʼ αὖ φιλότητα καὶ ὅρκια πιστὰ γενέσθαι.{l]{q]{para]
[para}[l [n}3.324{]}ὣς ἄρʼ ἔφαν, πάλλεν δὲ μέγας κορυθαίολος Ἕκτωρ{l]
[l [n}3.325{]}ἂψ ὁρόων· Πάριος δὲ θοῶς ἐκ κλῆρος ὄρουσεν.{l]
[l [n}3.326{]}οἳ μὲν ἔπειθʼ ἵζοντο κατὰ στίχας, ἧχι ἑκάστῳ{l]
[l [n}3.327{]}ἵπποι ἀερσίποδες καὶ ποικίλα τεύχεʼ ἔκειτο·{l]
[l [n}3.328{]}αὐτὰρ ὅ γʼ ἀμφʼ ὤμοισιν ἐδύσετο τεύχεα καλὰ{l]
[l [n}3.329{]}δῖος Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο.{l]
[l [n}3.330{]}κνημῖδας μὲν πρῶτα περὶ κνήμῃσιν ἔθηκε{l]
[l [n}3.331{]}καλάς, ἀργυρέοισιν ἐπισφυρίοις ἀραρυίας·{l]
[l [n}3.332{]}δεύτερον αὖ θώρηκα περὶ στήθεσσιν ἔδυνεν{l]
[l [n}3.333{]}οἷο κασιγνήτοιο Λυκάονος· ἥρμοσε δʼ αὐτῷ.{l]
[l [n}3.334{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον{l]
[l [n}3.335{]}χάλκεον, αὐτὰρ ἔπειτα σάκος μέγα τε στιβαρόν τε·{l]
[l [n}3.336{]}κρατὶ δʼ ἐπʼ ἰφθίμῳ κυνέην εὔτυκτον ἔθηκεν{l]
[l [n}3.337{]}ἵππουριν· δεινὸν δὲ λόφος καθύπερθεν ἔνευεν·{l]
[l [n}3.338{]}εἵλετο δʼ ἄλκιμον ἔγχος, ὅ οἱ παλάμηφιν ἀρήρει.{l]
[l [n}3.339{]}ὣς δʼ αὔτως Μενέλαος ἀρήϊος ἔντεʼ ἔδυνεν.{l]{para]
[para}[l [n}3.340{]}οἳ δʼ ἐπεὶ οὖν ἑκάτερθεν ὁμίλου θωρήχθησαν,{l]
[l [n}3.341{]}ἐς μέσσον Τρώων καὶ Ἀχαιῶν ἐστιχόωντο{l]
[l [n}3.342{]}δεινὸν δερκόμενοι· θάμβος δʼ ἔχεν εἰσορόωντας{l]
[l [n}3.343{]}Τρῶάς θʼ ἱπποδάμους καὶ ἐϋκνήμιδας Ἀχαιούς.{l]
[l [n}3.344{]}καί ῥʼ ἐγγὺς στήτην διαμετρητῷ ἐνὶ χώρῳ{l]
[l [n}3.345{]}σείοντʼ ἐγχείας ἀλλήλοισιν κοτέοντε.{l]
[l [n}3.346{]}πρόσθε δʼ Ἀλέξανδρος προΐει δολιχόσκιον ἔγχος,{l]
[l [n}3.347{]}καὶ βάλεν Ἀτρεΐδαο κατʼ ἀσπίδα πάντοσε ἴσην,{l]
[l [n}3.348{]}οὐδʼ ἔρρηξεν χαλκός, ἀνεγνάμφθη δέ οἱ αἰχμὴ{l]
[l [n}3.349{]}ἀσπίδʼ ἐνὶ κρατερῇ· ὃ δὲ δεύτερον ὄρνυτο χαλκῷ{l]
[l [n}3.350{]}Ἀτρεΐδης Μενέλαος ἐπευξάμενος Διὶ πατρί·{l]
[q}[l [n}3.351{]}Ζεῦ ἄνα δὸς τίσασθαι ὅ με πρότερος κάκʼ ἔοργε{l]
[l [n}3.352{]}δῖον Ἀλέξανδρον, καὶ ἐμῇς ὑπὸ χερσὶ δάμασσον,{l]
[l [n}3.353{]}ὄφρα τις ἐρρίγῃσι καὶ ὀψιγόνων ἀνθρώπων{l]
[l [n}3.354{]}ξεινοδόκον κακὰ ῥέξαι, ὅ κεν φιλότητα παράσχῃ.{l]{q]{para]
[para}[l [n}3.355{]}ἦ ῥα καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος,{l]
[l [n}3.356{]}καὶ βάλε Πριαμίδαο κατʼ ἀσπίδα πάντοσε ἴσην·{l]
[l [n}3.357{]}διὰ μὲν ἀσπίδος ἦλθε φαεινῆς ὄβριμον ἔγχος,{l]
[l [n}3.358{]}καὶ διὰ θώρηκος πολυδαιδάλου ἠρήρειστο·{l]
[l [n}3.359{]}ἀντικρὺ δὲ παραὶ λαπάρην διάμησε χιτῶνα{l]
[l [n}3.360{]}ἔγχος· ὃ δʼ ἐκλίνθη καὶ ἀλεύατο κῆρα μέλαιναν.{l]
[l [n}3.361{]}Ἀτρεΐδης δὲ ἐρυσσάμενος ξίφος ἀργυρόηλον{l]
[l [n}3.362{]}πλῆξεν ἀνασχόμενος κόρυθος φάλον· ἀμφὶ δʼ ἄρʼ αὐτῷ{l]
[l [n}3.363{]}τριχθά τε καὶ τετραχθὰ διατρυφὲν ἔκπεσε χειρός.{l]
[l [n}3.364{]}Ἀτρεΐδης δʼ ᾤμωξεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}3.365{]}Ζεῦ πάτερ οὔ τις σεῖο θεῶν ὀλοώτερος ἄλλος·{l]
[l [n}3.366{]}ἦ τʼ ἐφάμην τίσασθαι Ἀλέξανδρον κακότητος·{l]
[l [n}3.367{]}νῦν δέ μοι ἐν χείρεσσιν ἄγη ξίφος, ἐκ δέ μοι ἔγχος{l]
[l [n}3.368{]}ἠΐχθη παλάμηφιν ἐτώσιον, οὐδʼ ἔβαλόν μιν.{l]{q]{para]
[para}[l [n}3.369{]}ἦ καὶ ἐπαΐξας κόρυθος λάβεν ἱπποδασείης,{l]
[l [n}3.370{]}ἕλκε δʼ ἐπιστρέψας μετʼ ἐϋκνήμιδας Ἀχαιούς·{l]
[l [n}3.371{]}ἄγχε δέ μιν πολύκεστος ἱμὰς ἁπαλὴν ὑπὸ δειρήν,{l]
[l [n}3.372{]}ὅς οἱ ὑπʼ ἀνθερεῶνος ὀχεὺς τέτατο τρυφαλείης.{l]
[l [n}3.373{]}καί νύ κεν εἴρυσσέν τε καὶ ἄσπετον ἤρατο κῦδος,{l]
[l [n}3.374{]}εἰ μὴ ἄρʼ ὀξὺ νόησε Διὸς θυγάτηρ Ἀφροδίτη,{l]
[l [n}3.375{]}ἥ οἱ ῥῆξεν ἱμάντα βοὸς ἶφι κταμένοιο·{l]
[l [n}3.376{]}κεινὴ δὲ τρυφάλεια ἅμʼ ἕσπετο χειρὶ παχείῃ.{l]
[l [n}3.377{]}τὴν μὲν ἔπειθʼ ἥρως μετʼ ἐϋκνήμιδας Ἀχαιοὺς{l]
[l [n}3.378{]}ῥῖψʼ ἐπιδινήσας, κόμισαν δʼ ἐρίηρες ἑταῖροι·{l]
[l [n}3.379{]}αὐτὰρ ὃ ἂψ ἐπόρουσε κατακτάμεναι μενεαίνων{l]
[l [n}3.380{]}ἔγχεϊ χαλκείῳ· τὸν δʼ ἐξήρπαξʼ Ἀφροδίτη{l]
[l [n}3.381{]}ῥεῖα μάλʼ ὥς τε θεός, ἐκάλυψε δʼ ἄρʼ ἠέρι πολλῇ,{l]
[l [n}3.382{]}κὰδ δʼ εἷσʼ ἐν θαλάμῳ εὐώδεϊ κηώεντι.{l]
[l [n}3.383{]}αὐτὴ δʼ αὖ Ἑλένην καλέουσʼ ἴε· τὴν δὲ κίχανε{l]
[l [n}3.384{]}πύργῳ ἐφʼ ὑψηλῷ, περὶ δὲ Τρῳαὶ ἅλις ἦσαν·{l]
[l [n}3.385{]}χειρὶ δὲ νεκταρέου ἑανοῦ ἐτίναξε λαβοῦσα,{l]
[l [n}3.386{]}γρηῒ δέ μιν ἐϊκυῖα παλαιγενέϊ προσέειπεν{l]
[l [n}3.387{]}εἰροκόμῳ, ἥ οἱ Λακεδαίμονι ναιετοώσῃ{l]
[l [n}3.388{]}ἤσκειν εἴρια καλά, μάλιστα δέ μιν φιλέεσκε·{l]
[l [n}3.389{]}τῇ μιν ἐεισαμένη προσεφώνεε δῖʼ Ἀφροδίτη·{l]
[q}[l [n}3.390{]}δεῦρʼ ἴθʼ· Ἀλέξανδρός σε καλεῖ οἶκον δὲ νέεσθαι.{l]
[l [n}3.391{]}κεῖνος ὅ γʼ ἐν θαλάμῳ καὶ δινωτοῖσι λέχεσσι{l]
[l [n}3.392{]}κάλλεΐ τε στίλβων καὶ εἵμασιν· οὐδέ κε φαίης{l]
[l [n}3.393{]}ἀνδρὶ μαχεσσάμενον τόν γʼ ἐλθεῖν, ἀλλὰ χορὸν δὲ{l]
[l [n}3.394{]}ἔρχεσθʼ, ἠὲ χοροῖο νέον λήγοντα καθίζειν.{l]{q]{para]
[para}[l [n}3.395{]}ὣς φάτο, τῇ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ὄρινε·{l]
[l [n}3.396{]}καί ῥʼ ὡς οὖν ἐνόησε θεᾶς περικαλλέα δειρὴν{l]
[l [n}3.397{]}στήθεά θʼ ἱμερόεντα καὶ ὄμματα μαρμαίροντα,{l]
[l [n}3.398{]}θάμβησέν τʼ ἄρʼ ἔπειτα ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}3.399{]}δαιμονίη, τί με ταῦτα λιλαίεαι ἠπεροπεύειν;{l]
[l [n}3.400{]}ἦ πῄ με προτέρω πολίων εὖ ναιομενάων{l]
[l [n}3.401{]}ἄξεις, ἢ Φρυγίης ἢ Μῃονίης ἐρατεινῆς,{l]
[l [n}3.402{]}εἴ τίς τοι καὶ κεῖθι φίλος μερόπων ἀνθρώπων·{l]
[l [n}3.403{]}οὕνεκα δὴ νῦν δῖον Ἀλέξανδρον Μενέλαος{l]
[l [n}3.404{]}νικήσας ἐθέλει στυγερὴν ἐμὲ οἴκαδʼ ἄγεσθαι,{l]
[l [n}3.405{]}τοὔνεκα δὴ νῦν δεῦρο δολοφρονέουσα παρέστης;{l]
[l [n}3.406{]}ἧσο παρʼ αὐτὸν ἰοῦσα, θεῶν δʼ ἀπόεικε κελεύθου,{l]
[l [n}3.407{]}μηδʼ ἔτι σοῖσι πόδεσσιν ὑποστρέψειας Ὄλυμπον,{l]
[l [n}3.408{]}ἀλλʼ αἰεὶ περὶ κεῖνον ὀΐζυε καί ἑ φύλασσε,{l]
[l [n}3.409{]}εἰς ὅ κέ σʼ ἢ ἄλοχον ποιήσεται ἢ ὅ γε δούλην.{l]
[l [n}3.410{]}κεῖσε δʼ ἐγὼν οὐκ εἶμι· νεμεσσητὸν δέ κεν εἴη·{l]
[l [n}3.411{]}κείνου πορσανέουσα λέχος· Τρῳαὶ δέ μʼ ὀπίσσω{l]
[l [n}3.412{]}πᾶσαι μωμήσονται· ἔχω δʼ ἄχεʼ ἄκριτα θυμῷ.{l]{q]{para]
[para}[l [n}3.413{]}τὴν δὲ χολωσαμένη προσεφώνεε δῖʼ Ἀφροδίτη·{l]
[q}[l [n}3.414{]}μή μʼ ἔρεθε σχετλίη, μὴ χωσαμένη σε μεθείω,{l]
[l [n}3.415{]}τὼς δέ σʼ ἀπεχθήρω ὡς νῦν ἔκπαγλʼ ἐφίλησα,{l]
[l [n}3.416{]}μέσσῳ δʼ ἀμφοτέρων μητίσομαι ἔχθεα λυγρὰ{l]
[l [n}3.417{]}Τρώων καὶ Δαναῶν, σὺ δέ κεν κακὸν οἶτον ὄληαι.{l]{q]{para]
[para}[l [n}3.418{]}ὣς ἔφατʼ, ἔδεισεν δʼ Ἑλένη Διὸς ἐκγεγαυῖα,{l]
[l [n}3.419{]}βῆ δὲ κατασχομένη ἑανῷ ἀργῆτι φαεινῷ{l]
[l [n}3.420{]}σιγῇ, πάσας δὲ Τρῳὰς λάθεν· ἦρχε δὲ δαίμων.{l]{para]
[para}[l [n}3.421{]}αἳ δʼ ὅτʼ Ἀλεξάνδροιο δόμον περικαλλέʼ ἵκοντο,{l]
[l [n}3.422{]}ἀμφίπολοι μὲν ἔπειτα θοῶς ἐπὶ ἔργα τράποντο,{l]
[l [n}3.423{]}ἣ δʼ εἰς ὑψόροφον θάλαμον κίε δῖα γυναικῶν.{l]
[l [n}3.424{]}τῇ δʼ ἄρα δίφρον ἑλοῦσα φιλομειδὴς Ἀφροδίτη{l]
[l [n}3.425{]}ἀντίʼ Ἀλεξάνδροιο θεὰ κατέθηκε φέρουσα·{l]
[l [n}3.426{]}ἔνθα κάθιζʼ Ἑλένη κούρη Διὸς αἰγιόχοιο{l]
[l [n}3.427{]}ὄσσε πάλιν κλίνασα, πόσιν δʼ ἠνίπαπε μύθῳ·{l]
[q}[l [n}3.428{]}ἤλυθες ἐκ πολέμου· ὡς ὤφελες αὐτόθʼ ὀλέσθαι{l]
[l [n}3.429{]}ἀνδρὶ δαμεὶς κρατερῷ, ὃς ἐμὸς πρότερος πόσις ἦεν.{l]
[l [n}3.430{]}ἦ μὲν δὴ πρίν γʼ εὔχεʼ ἀρηϊφίλου Μενελάου{l]
[l [n}3.431{]}σῇ τε βίῃ καὶ χερσὶ καὶ ἔγχεϊ φέρτερος εἶναι·{l]
[l [n}3.432{]}ἀλλʼ ἴθι νῦν προκάλεσσαι ἀρηΐφιλον Μενέλαον{l]
[l [n}3.433{]}ἐξαῦτις μαχέσασθαι ἐναντίον· ἀλλά σʼ ἔγωγε{l]
[l [n}3.434{]}παύεσθαι κέλομαι, μηδὲ ξανθῷ Μενελάῳ{l]
[l [n}3.435{]}ἀντίβιον πόλεμον πολεμίζειν ἠδὲ μάχεσθαι{l]
[l [n}3.436{]}ἀφραδέως, μή πως τάχʼ ὑπʼ αὐτοῦ δουρὶ δαμήῃς.{l]{q]{para]
[para}[l [n}3.437{]}τὴν δὲ Πάρις μύθοισιν ἀμειβόμενος προσέειπε·{l]
[q}[l [n}3.438{]}μή με γύναι χαλεποῖσιν ὀνείδεσι θυμὸν ἔνιπτε·{l]
[l [n}3.439{]}νῦν μὲν γὰρ Μενέλαος ἐνίκησεν σὺν Ἀθήνῃ,{l]
[l [n}3.440{]}κεῖνον δʼ αὖτις ἐγώ· πάρα γὰρ θεοί εἰσι καὶ ἡμῖν.{l]
[l [n}3.441{]}ἀλλʼ ἄγε δὴ φιλότητι τραπείομεν εὐνηθέντε·{l]
[l [n}3.442{]}οὐ γάρ πώ ποτέ μʼ ὧδέ γʼ ἔρως φρένας ἀμφεκάλυψεν,{l]
[l [n}3.443{]}οὐδʼ ὅτε σε πρῶτον Λακεδαίμονος ἐξ ἐρατεινῆς{l]
[l [n}3.444{]}ἔπλεον ἁρπάξας ἐν ποντοπόροισι νέεσσι,{l]
[l [n}3.445{]}νήσῳ δʼ ἐν Κραναῇ ἐμίγην φιλότητι καὶ εὐνῇ,{l]
[l [n}3.446{]}ὥς σεο νῦν ἔραμαι καί με γλυκὺς ἵμερος αἱρεῖ.{l]{q]{para]
[para}[l [n}3.447{]}ἦ ῥα, καὶ ἄρχε λέχος δὲ κιών· ἅμα δʼ εἵπετʼ ἄκοιτις.{l]{para]
[para}[l [n}3.448{]}τὼ μὲν ἄρʼ ἐν τρητοῖσι κατεύνασθεν λεχέεσσιν,{l]
[l [n}3.449{]}Ἀτρεΐδης δʼ ἀνʼ ὅμιλον ἐφοίτα θηρὶ ἐοικὼς{l]
[l [n}3.450{]}εἴ που ἐσαθρήσειεν Ἀλέξανδρον θεοειδέα.{l]
[l [n}3.451{]}ἀλλʼ οὔ τις δύνατο Τρώων κλειτῶν τʼ ἐπικούρων{l]
[l [n}3.452{]}δεῖξαι Ἀλέξανδρον τότʼ ἀρηϊφίλῳ Μενελάῳ·{l]
[l [n}3.453{]}οὐ μὲν γὰρ φιλότητί γʼ ἐκεύθανον εἴ τις ἴδοιτο·{l]
[l [n}3.454{]}ἶσον γάρ σφιν πᾶσιν ἀπήχθετο κηρὶ μελαίνῃ.{l]
[l [n}3.455{]}τοῖσι δὲ καὶ μετέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}3.456{]}κέκλυτέ μευ Τρῶες καὶ Δάρδανοι ἠδʼ ἐπίκουροι·{l]
[l [n}3.457{]}νίκη μὲν δὴ φαίνετʼ ἀρηϊφίλου Μενελάου,{l]
[l [n}3.458{]}ὑμεῖς δʼ Ἀργείην Ἑλένην καὶ κτήμαθʼ ἅμʼ αὐτῇ{l]
[l [n}3.459{]}ἔκδοτε, καὶ τιμὴν ἀποτινέμεν ἥν τινʼ ἔοικεν,{l]
[l [n}3.460{]}ἥ τε καὶ ἐσσομένοισι μετʼ ἀνθρώποισι πέληται.{l]{q]{para]
[para}[l [n}3.461{]}ὣς ἔφατʼ Ἀτρεΐδης, ἐπὶ δʼ ᾔνεον ἄλλοι Ἀχαιοί.{l]{para]
{book]
[book [n}4{]}
[para}[l [n}4.1{]}οἳ δὲ θεοὶ πὰρ Ζηνὶ καθήμενοι ἠγορόωντο{l]
[l [n}4.2{]}χρυσέῳ ἐν δαπέδῳ, μετὰ δέ σφισι πότνια Ἥβη{l]
[l [n}4.3{]}νέκταρ ἐοινοχόει· τοὶ δὲ χρυσέοις δεπάεσσι{l]
[l [n}4.4{]}δειδέχατʼ ἀλλήλους, Τρώων πόλιν εἰσορόωντες·{l]
[l [n}4.5{]}αὐτίκʼ ἐπειρᾶτο Κρονίδης ἐρεθιζέμεν Ἥρην{l]
[l [n}4.6{]}κερτομίοις ἐπέεσσι παραβλήδην ἀγορεύων·{l]
[q}[l [n}4.7{]}δοιαὶ μὲν Μενελάῳ ἀρηγόνες εἰσὶ θεάων{l]
[l [n}4.8{]}Ἥρη τʼ Ἀργείη καὶ Ἀλαλκομενηῒς Ἀθήνη.{l]
[l [n}4.9{]}ἀλλʼ ἤτοι ταὶ νόσφι καθήμεναι εἰσορόωσαι{l]
[l [n}4.10{]}τέρπεσθον· τῷ δʼ αὖτε φιλομειδὴς Ἀφροδίτη{l]
[l [n}4.11{]}αἰεὶ παρμέμβλωκε καὶ αὐτοῦ κῆρας ἀμύνει·{l]
[l [n}4.12{]}καὶ νῦν ἐξεσάωσεν ὀϊόμενον θανέεσθαι.{l]
[l [n}4.13{]}ἀλλʼ ἤτοι νίκη μὲν ἀρηϊφίλου Μενελάου·{l]
[l [n}4.14{]}ἡμεῖς δὲ φραζώμεθʼ ὅπως ἔσται τάδε ἔργα,{l]
[l [n}4.15{]}ἤ ῥʼ αὖτις πόλεμόν τε κακὸν καὶ φύλοπιν αἰνὴν{l]
[l [n}4.16{]}ὄρσομεν, ἦ φιλότητα μετʼ ἀμφοτέροισι βάλωμεν.{l]
[l [n}4.17{]}εἰ δʼ αὖ πως τόδε πᾶσι φίλον καὶ ἡδὺ γένοιτο,{l]
[l [n}4.18{]}ἤτοι μὲν οἰκέοιτο πόλις Πριάμοιο ἄνακτος,{l]
[l [n}4.19{]}αὖτις δʼ Ἀργείην Ἑλένην Μενέλαος ἄγοιτο.{l]{q]{para]
[para}[l [n}4.20{]}ὣς ἔφαθʼ, αἳ δʼ ἐπέμυξαν Ἀθηναίη τε καὶ Ἥρη·{l]
[l [n}4.21{]}πλησίαι αἵ γʼ ἥσθην, κακὰ δὲ Τρώεσσι μεδέσθην.{l]
[l [n}4.22{]}ἤτοι Ἀθηναίη ἀκέων ἦν οὐδέ τι εἶπε{l]
[l [n}4.23{]}σκυζομένη Διὶ πατρί, χόλος δέ μιν ἄγριος ᾕρει·{l]
[l [n}4.24{]}Ἥρῃ δʼ οὐκ ἔχαδε στῆθος χόλον, ἀλλὰ προσηύδα·{l]
[q}[l [n}4.25{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες·{l]
[l [n}4.26{]}πῶς ἐθέλεις ἅλιον θεῖναι πόνον ἠδʼ ἀτέλεστον,{l]
[l [n}4.27{]}ἱδρῶ θʼ ὃν ἵδρωσα μόγῳ, καμέτην δέ μοι ἵπποι{l]
[l [n}4.28{]}λαὸν ἀγειρούσῃ, Πριάμῳ κακὰ τοῖό τε παισίν.{l]
[l [n}4.29{]}ἕρδʼ· ἀτὰρ οὔ τοι πάντες ἐπαινέομεν θεοὶ ἄλλοι.{l]{q]{para]
[para}[l [n}4.30{]}τὴν δὲ μέγʼ ὀχθήσας προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}4.31{]}δαιμονίη τί νύ σε Πρίαμος Πριάμοιό τε παῖδες{l]
[l [n}4.32{]}τόσσα κακὰ ῥέζουσιν, ὅ τʼ ἀσπερχὲς μενεαίνεις{l]
[l [n}4.33{]}Ἰλίου ἐξαλαπάξαι ἐϋκτίμενον πτολίεθρον;{l]
[l [n}4.34{]}εἰ δὲ σύ γʼ εἰσελθοῦσα πύλας καὶ τείχεα μακρὰ{l]
[l [n}4.35{]}ὠμὸν βεβρώθοις Πρίαμον Πριάμοιό τε παῖδας{l]
[l [n}4.36{]}ἄλλους τε Τρῶας, τότε κεν χόλον ἐξακέσαιο.{l]
[l [n}4.37{]}ἕρξον ὅπως ἐθέλεις· μὴ τοῦτό γε νεῖκος ὀπίσσω{l]
[l [n}4.38{]}σοὶ καὶ ἐμοὶ μέγʼ ἔρισμα μετʼ ἀμφοτέροισι γένηται.{l]
[l [n}4.39{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσιν·{l]
[l [n}4.40{]}ὁππότε κεν καὶ ἐγὼ μεμαὼς πόλιν ἐξαλαπάξαι{l]
[l [n}4.41{]}τὴν ἐθέλω ὅθι τοι φίλοι ἀνέρες ἐγγεγάασι,{l]
[l [n}4.42{]}μή τι διατρίβειν τὸν ἐμὸν χόλον, ἀλλά μʼ ἐᾶσαι·{l]
[l [n}4.43{]}καὶ γὰρ ἐγὼ σοὶ δῶκα ἑκὼν ἀέκοντί γε θυμῷ·{l]
[l [n}4.44{]}αἳ γὰρ ὑπʼ ἠελίῳ τε καὶ οὐρανῷ ἀστερόεντι{l]
[l [n}4.45{]}ναιετάουσι πόληες ἐπιχθονίων ἀνθρώπων,{l]
[l [n}4.46{]}τάων μοι περὶ κῆρι τιέσκετο Ἴλιος ἱρὴ{l]
[l [n}4.47{]}καὶ Πρίαμος καὶ λαὸς ἐϋμμελίω Πριάμοιο.{l]
[l [n}4.48{]}οὐ γάρ μοί ποτε βωμὸς ἐδεύετο δαιτὸς ἐΐσης{l]
[l [n}4.49{]}λοιβῆς τε κνίσης τε· τὸ γὰρ λάχομεν γέρας ἡμεῖς.{l]{q]{para]
[para}[l [n}4.50{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοῶπις πότνια Ἥρη·{l]
[q}[l [n}4.51{]}ἤτοι ἐμοὶ τρεῖς μὲν πολὺ φίλταταί εἰσι πόληες{l]
[l [n}4.52{]}Ἄργός τε Σπάρτη τε καὶ εὐρυάγυια Μυκήνη·{l]
[l [n}4.53{]}τὰς διαπέρσαι ὅτʼ ἄν τοι ἀπέχθωνται περὶ κῆρι·{l]
[l [n}4.54{]}τάων οὔ τοι ἐγὼ πρόσθʼ ἵσταμαι οὐδὲ μεγαίρω.{l]
[l [n}4.55{]}εἴ περ γὰρ φθονέω τε καὶ οὐκ εἰῶ διαπέρσαι,{l]
[l [n}4.56{]}οὐκ ἀνύω φθονέουσʼ ἐπεὶ ἦ πολὺ φέρτερός ἐσσι.{l]
[l [n}4.57{]}ἀλλὰ χρὴ καὶ ἐμὸν θέμεναι πόνον οὐκ ἀτέλεστον·{l]
[l [n}4.58{]}καὶ γὰρ ἐγὼ θεός εἰμι, γένος δέ μοι ἔνθεν ὅθεν σοί,{l]
[l [n}4.59{]}καί με πρεσβυτάτην τέκετο Κρόνος ἀγκυλομήτης,{l]
[l [n}4.60{]}ἀμφότερον γενεῇ τε καὶ οὕνεκα σὴ παράκοιτις{l]
[l [n}4.61{]}κέκλημαι, σὺ δὲ πᾶσι μετʼ ἀθανάτοισιν ἀνάσσεις.{l]
[l [n}4.62{]}ἀλλʼ ἤτοι μὲν ταῦθʼ ὑποείξομεν ἀλλήλοισι,{l]
[l [n}4.63{]}σοὶ μὲν ἐγώ, σὺ δʼ ἐμοί· ἐπὶ δʼ ἕψονται θεοὶ ἄλλοι{l]
[l [n}4.64{]}ἀθάνατοι· σὺ δὲ θᾶσσον Ἀθηναίῃ ἐπιτεῖλαι{l]
[l [n}4.65{]}ἐλθεῖν ἐς Τρώων καὶ Ἀχαιῶν φύλοπιν αἰνήν,{l]
[l [n}4.66{]}πειρᾶν δʼ ὥς κε Τρῶες ὑπερκύδαντας Ἀχαιοὺς{l]
[l [n}4.67{]}ἄρξωσι πρότεροι ὑπὲρ ὅρκια δηλήσασθαι.{l]{q]{para]
[para}[l [n}4.68{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[l [n}4.69{]}αὐτίκʼ Ἀθηναίην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.70{]}αἶψα μάλʼ ἐς στρατὸν ἐλθὲ μετὰ Τρῶας καὶ Ἀχαιούς,{l]
[l [n}4.71{]}πειρᾶν δʼ ὥς κε Τρῶες ὑπερκύδαντας Ἀχαιοὺς{l]
[l [n}4.72{]}ἄρξωσι πρότεροι ὑπὲρ ὅρκια δηλήσασθαι.{l]{q]{para]
[para}[l [n}4.73{]}ὣς εἰπὼν ὄτρυνε πάρος μεμαυῖαν Ἀθήνην,{l]
[l [n}4.74{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων ἀΐξασα.{l]
[l [n}4.75{]}οἷον δʼ ἀστέρα ἧκε Κρόνου πάϊς ἀγκυλομήτεω{l]
[l [n}4.76{]}ἢ ναύτῃσι τέρας ἠὲ στρατῷ εὐρέϊ λαῶν{l]
[l [n}4.77{]}λαμπρόν· τοῦ δέ τε πολλοὶ ἀπὸ σπινθῆρες ἵενται·{l]
[l [n}4.78{]}τῷ ἐϊκυῖʼ ἤϊξεν ἐπὶ χθόνα Παλλὰς Ἀθήνη,{l]
[l [n}4.79{]}κὰδ δʼ ἔθορʼ ἐς μέσσον· θάμβος δʼ ἔχεν εἰσορόωντας{l]
[l [n}4.80{]}Τρῶάς θʼ ἱπποδάμους καὶ ἐϋκνήμιδας Ἀχαιούς·{l]
[l [n}4.81{]}ὧδε δέ τις εἴπεσκεν ἰδὼν ἐς πλησίον ἄλλον·{l]
[q}[l [n}4.82{]}ἦ ῥʼ αὖτις πόλεμός τε κακὸς καὶ φύλοπις αἰνὴ{l]
[l [n}4.83{]}ἔσσεται, ἢ φιλότητα μετʼ ἀμφοτέροισι τίθησι{l]
[l [n}4.84{]}Ζεύς, ὅς τʼ ἀνθρώπων ταμίης πολέμοιο τέτυκται.{l]{q]{para]
[para}[l [n}4.85{]}ὣς ἄρα τις εἴπεσκεν Ἀχαιῶν τε Τρώων τε.{l]
[l [n}4.86{]}ἣ δʼ ἀνδρὶ ἰκέλη Τρώων κατεδύσεθʼ ὅμιλον{l]
[l [n}4.87{]}Λαοδόκῳ Ἀντηνορίδῃ κρατερῷ αἰχμητῇ,{l]
[l [n}4.88{]}Πάνδαρον ἀντίθεον διζημένη εἴ που ἐφεύροι.{l]
[l [n}4.89{]}εὗρε Λυκάονος υἱὸν ἀμύμονά τε κρατερόν τε{l]
[l [n}4.90{]}ἑσταότʼ· ἀμφὶ δέ μιν κρατεραὶ στίχες ἀσπιστάων{l]
[l [n}4.91{]}λαῶν, οἵ οἱ ἕποντο ἀπʼ Αἰσήποιο ῥοάων·{l]
[l [n}4.92{]}ἀγχοῦ δʼ ἱσταμένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.93{]}ἦ ῥά νύ μοί τι πίθοιο Λυκάονος υἱὲ δαΐφρον.{l]
[l [n}4.94{]}τλαίης κεν Μενελάῳ ἐπιπροέμεν ταχὺν ἰόν,{l]
[l [n}4.95{]}πᾶσι δέ κε Τρώεσσι χάριν καὶ κῦδος ἄροιο,{l]
[l [n}4.96{]}ἐκ πάντων δὲ μάλιστα Ἀλεξάνδρῳ βασιλῆϊ.{l]
[l [n}4.97{]}τοῦ κεν δὴ πάμπρωτα παρʼ ἀγλαὰ δῶρα φέροιο,{l]
[l [n}4.98{]}αἴ κεν ἴδῃ Μενέλαον ἀρήϊον Ἀτρέος υἱὸν{l]
[l [n}4.99{]}σῷ βέλεϊ δμηθέντα πυρῆς ἐπιβάντʼ ἀλεγεινῆς.{l]
[l [n}4.100{]}ἀλλʼ ἄγʼ ὀΐστευσον Μενελάου κυδαλίμοιο,{l]
[l [n}4.101{]}εὔχεο δʼ Ἀπόλλωνι Λυκηγενέϊ κλυτοτόξῳ{l]
[l [n}4.102{]}ἀρνῶν πρωτογόνων ῥέξειν κλειτὴν ἑκατόμβην{l]
[l [n}4.103{]}οἴκαδε νοστήσας ἱερῆς εἰς ἄστυ Ζελείης.{l]{q]{para]
[para}[l [n}4.104{]}ὣς φάτʼ Ἀθηναίη, τῷ δὲ φρένας ἄφρονι πεῖθεν·{l]
[l [n}4.105{]}αὐτίκʼ ἐσύλα τόξον ἐΰξοον ἰξάλου αἰγὸς{l]
[l [n}4.106{]}ἀγρίου, ὅν ῥά ποτʼ αὐτὸς ὑπὸ στέρνοιο τυχήσας{l]
[l [n}4.107{]}πέτρης ἐκβαίνοντα δεδεγμένος ἐν προδοκῇσι{l]
[l [n}4.108{]}βεβλήκει πρὸς στῆθος· ὃ δʼ ὕπτιος ἔμπεσε πέτρῃ.{l]
[l [n}4.109{]}τοῦ κέρα ἐκ κεφαλῆς ἑκκαιδεκάδωρα πεφύκει·{l]
[l [n}4.110{]}καὶ τὰ μὲν ἀσκήσας κεραοξόος ἤραρε τέκτων,{l]
[l [n}4.111{]}πᾶν δʼ εὖ λειήνας χρυσέην ἐπέθηκε κορώνην.{l]
[l [n}4.112{]}καὶ τὸ μὲν εὖ κατέθηκε τανυσσάμενος ποτὶ γαίῃ{l]
[l [n}4.113{]}ἀγκλίνας· πρόσθεν δὲ σάκεα σχέθον ἐσθλοὶ ἑταῖροι{l]
[l [n}4.114{]}μὴ πρὶν ἀναΐξειαν ἀρήϊοι υἷες Ἀχαιῶν{l]
[l [n}4.115{]}πρὶν βλῆσθαι Μενέλαον ἀρήϊον Ἀτρέος υἱόν.{l]
[l [n}4.116{]}αὐτὰρ ὁ σύλα πῶμα φαρέτρης, ἐκ δʼ ἕλετʼ ἰὸν{l]
[l [n}4.117{]}ἀβλῆτα πτερόεντα μελαινέων ἕρμʼ ὀδυνάων·{l]
[l [n}4.118{]}αἶψα δʼ ἐπὶ νευρῇ κατεκόσμει πικρὸν ὀϊστόν,{l]
[l [n}4.119{]}εὔχετο δʼ Ἀπόλλωνι Λυκηγενέϊ κλυτοτόξῳ{l]
[l [n}4.120{]}ἀρνῶν πρωτογόνων ῥέξειν κλειτὴν ἑκατόμβην{l]
[l [n}4.121{]}οἴκαδε νοστήσας ἱερῆς εἰς ἄστυ Ζελείης.{l]
[l [n}4.122{]}ἕλκε δʼ ὁμοῦ γλυφίδας τε λαβὼν καὶ νεῦρα βόεια·{l]
[l [n}4.123{]}νευρὴν μὲν μαζῷ πέλασεν, τόξῳ δὲ σίδηρον.{l]
[l [n}4.124{]}αὐτὰρ ἐπεὶ δὴ κυκλοτερὲς μέγα τόξον ἔτεινε,{l]
[l [n}4.125{]}λίγξε βιός, νευρὴ δὲ μέγʼ ἴαχεν, ἆλτο δʼ ὀϊστὸς{l]
[l [n}4.126{]}ὀξυβελὴς καθʼ ὅμιλον ἐπιπτέσθαι μενεαίνων.{l]{para]
[para}[l [n}4.127{]}οὐδὲ σέθεν Μενέλαε θεοὶ μάκαρες λελάθοντο{l]
[l [n}4.128{]}ἀθάνατοι, πρώτη δὲ Διὸς θυγάτηρ ἀγελείη,{l]
[l [n}4.129{]}ἥ τοι πρόσθε στᾶσα βέλος ἐχεπευκὲς ἄμυνεν.{l]
[l [n}4.130{]}ἣ δὲ τόσον μὲν ἔεργεν ἀπὸ χροὸς ὡς ὅτε μήτηρ{l]
[l [n}4.131{]}παιδὸς ἐέργῃ μυῖαν ὅθʼ ἡδέϊ λέξεται ὕπνῳ,{l]
[l [n}4.132{]}αὐτὴ δʼ αὖτʼ ἴθυνεν ὅθι ζωστῆρος ὀχῆες{l]
[l [n}4.133{]}χρύσειοι σύνεχον καὶ διπλόος ἤντετο θώρηξ.{l]
[l [n}4.134{]}ἐν δʼ ἔπεσε ζωστῆρι ἀρηρότι πικρὸς ὀϊστός·{l]
[l [n}4.135{]}διὰ μὲν ἂρ ζωστῆρος ἐλήλατο δαιδαλέοιο,{l]
[l [n}4.136{]}καὶ διὰ θώρηκος πολυδαιδάλου ἠρήρειστο{l]
[l [n}4.137{]}μίτρης θʼ, ἣν ἐφόρει ἔρυμα χροὸς ἕρκος ἀκόντων,{l]
[l [n}4.138{]}ἥ οἱ πλεῖστον ἔρυτο· διὰ πρὸ δὲ εἴσατο καὶ τῆς.{l]
[l [n}4.139{]}ἀκρότατον δʼ ἄρʼ ὀϊστὸς ἐπέγραψε χρόα φωτός·{l]
[l [n}4.140{]}αὐτίκα δʼ ἔρρεεν αἷμα κελαινεφὲς ἐξ ὠτειλῆς.{l]{para]
[para}[l [n}4.141{]}ὡς δʼ ὅτε τίς τʼ ἐλέφαντα γυνὴ φοίνικι μιήνῃ{l]
[l [n}4.142{]}Μῃονὶς ἠὲ Κάειρα παρήϊον ἔμμεναι ἵππων·{l]
[l [n}4.143{]}κεῖται δʼ ἐν θαλάμῳ, πολέες τέ μιν ἠρήσαντο{l]
[l [n}4.144{]}ἱππῆες φορέειν· βασιλῆϊ δὲ κεῖται ἄγαλμα,{l]
[l [n}4.145{]}ἀμφότερον κόσμός θʼ ἵππῳ ἐλατῆρί τε κῦδος·{l]
[l [n}4.146{]}τοῖοί τοι Μενέλαε μιάνθην αἵματι μηροὶ{l]
[l [n}4.147{]}εὐφυέες κνῆμαί τε ἰδὲ σφυρὰ κάλʼ ὑπένερθε.{l]{para]
[para}[l [n}4.148{]}ῥίγησεν δʼ ἄρʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}4.149{]}ὡς εἶδεν μέλαν αἷμα καταρρέον ἐξ ὠτειλῆς·{l]
[l [n}4.150{]}ῥίγησεν δὲ καὶ αὐτὸς ἀρηΐφιλος Μενέλαος.{l]
[l [n}4.151{]}ὡς δὲ ἴδεν νεῦρόν τε καὶ ὄγκους ἐκτὸς ἐόντας{l]
[l [n}4.152{]}ἄψορρόν οἱ θυμὸς ἐνὶ στήθεσσιν ἀγέρθη.{l]
[l [n}4.153{]}τοῖς δὲ βαρὺ στενάχων μετέφη κρείων Ἀγαμέμνων{l]
[l [n}4.154{]}χειρὸς ἔχων Μενέλαον, ἐπεστενάχοντο δʼ ἑταῖροι·{l]
[q}[l [n}4.155{]}φίλε κασίγνητε θάνατόν νύ τοι ὅρκιʼ ἔταμνον{l]
[l [n}4.156{]}οἶον προστήσας πρὸ Ἀχαιῶν Τρωσὶ μάχεσθαι,{l]
[l [n}4.157{]}ὥς σʼ ἔβαλον Τρῶες, κατὰ δʼ ὅρκια πιστὰ πάτησαν.{l]
[l [n}4.158{]}οὐ μέν πως ἅλιον πέλει ὅρκιον αἷμά τε ἀρνῶν{l]
[l [n}4.159{]}σπονδαί τʼ ἄκρητοι καὶ δεξιαὶ ᾗς ἐπέπιθμεν.{l]
[l [n}4.160{]}εἴ περ γάρ τε καὶ αὐτίκʼ Ὀλύμπιος οὐκ ἐτέλεσσεν,{l]
[l [n}4.161{]}ἔκ τε καὶ ὀψὲ τελεῖ, σύν τε μεγάλῳ ἀπέτισαν{l]
[l [n}4.162{]}σὺν σφῇσιν κεφαλῇσι γυναιξί τε καὶ τεκέεσσιν.{l]
[l [n}4.163{]}εὖ γὰρ ἐγὼ τόδε οἶδα κατὰ φρένα καὶ κατὰ θυμόν·{l]
[l [n}4.164{]}ἔσσεται ἦμαρ ὅτʼ ἄν ποτʼ ὀλώλῃ Ἴλιος ἱρὴ{l]
[l [n}4.165{]}καὶ Πρίαμος καὶ λαὸς ἐϋμμελίω Πριάμοιο,{l]
[l [n}4.166{]}Ζεὺς δέ σφι Κρονίδης ὑψίζυγος αἰθέρι ναίων{l]
[l [n}4.167{]}αὐτὸς ἐπισσείῃσιν ἐρεμνὴν αἰγίδα πᾶσι{l]
[l [n}4.168{]}τῆσδʼ ἀπάτης κοτέων· τὰ μὲν ἔσσεται οὐκ ἀτέλεστα·{l]
[l [n}4.169{]}ἀλλά μοι αἰνὸν ἄχος σέθεν ἔσσεται ὦ Μενέλαε{l]
[l [n}4.170{]}αἴ κε θάνῃς καὶ πότμον ἀναπλήσῃς βιότοιο.{l]
[l [n}4.171{]}καί κεν ἐλέγχιστος πολυδίψιον Ἄργος ἱκοίμην·{l]
[l [n}4.172{]}αὐτίκα γὰρ μνήσονται Ἀχαιοὶ πατρίδος αἴης·{l]
[l [n}4.173{]}κὰδ δέ κεν εὐχωλὴν Πριάμῳ καὶ Τρωσὶ λίποιμεν{l]
[l [n}4.174{]}Ἀργείην Ἑλένην· σέο δʼ ὀστέα πύσει ἄρουρα{l]
[l [n}4.175{]}κειμένου ἐν Τροίῃ ἀτελευτήτῳ ἐπὶ ἔργῳ.{l]
[l [n}4.176{]}καί κέ τις ὧδʼ ἐρέει Τρώων ὑπερηνορεόντων{l]
[l [n}4.177{]}τύμβῳ ἐπιθρῴσκων Μενελάου κυδαλίμοιο·{l]
[q}[l [n}4.178{]}αἴθʼ οὕτως ἐπὶ πᾶσι χόλον τελέσειʼ Ἀγαμέμνων,{l]
[l [n}4.179{]}ὡς καὶ νῦν ἅλιον στρατὸν ἤγαγεν ἐνθάδʼ Ἀχαιῶν,{l]
[l [n}4.180{]}καὶ δὴ ἔβη οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}4.181{]}σὺν κεινῇσιν νηυσὶ λιπὼν ἀγαθὸν Μενέλαον.{l]{q][l [n}4.182{]}ὥς ποτέ τις ἐρέει· τότε μοι χάνοι εὐρεῖα χθών.{l]{q]{para]
[para}[l [n}4.183{]}τὸν δʼ ἐπιθαρσύνων προσέφη ξανθὸς Μενέλαος·{l]
[q}[l [n}4.184{]}θάρσει, μηδέ τί πω δειδίσσεο λαὸν Ἀχαιῶν·{l]
[l [n}4.185{]}οὐκ ἐν καιρίῳ ὀξὺ πάγη βέλος, ἀλλὰ πάροιθεν{l]
[l [n}4.186{]}εἰρύσατο ζωστήρ τε παναίολος ἠδʼ ὑπένερθε{l]
[l [n}4.187{]}ζῶμά τε καὶ μίτρη, τὴν χαλκῆες κάμον ἄνδρες.{l]{q]{para]
[para}[l [n}4.188{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}4.189{]}αἲ γὰρ δὴ οὕτως εἴη φίλος ὦ Μενέλαε·{l]
[l [n}4.190{]}ἕλκος δʼ ἰητὴρ ἐπιμάσσεται ἠδʼ ἐπιθήσει{l]
[l [n}4.191{]}φάρμαχʼ ἅ κεν παύσῃσι μελαινάων ὀδυνάων.{l]{q]{para]
[para}[l [n}4.192{]}ἦ καὶ Ταλθύβιον θεῖον κήρυκα προσηύδα·{l]
[q}[l [n}4.193{]}Ταλθύβιʼ ὅττι τάχιστα Μαχάονα δεῦρο κάλεσσον{l]
[l [n}4.194{]}φῶτʼ Ἀσκληπιοῦ υἱὸν ἀμύμονος ἰητῆρος,{l]
[l [n}4.195{]}ὄφρα ἴδῃ Μενέλαον ἀρήϊον Ἀτρέος υἱόν,{l]
[l [n}4.196{]}ὅν τις ὀϊστεύσας ἔβαλεν τόξων ἐῢ εἰδὼς{l]
[l [n}4.197{]}Τρώων ἢ Λυκίων, τῷ μὲν κλέος, ἄμμι δὲ πένθος.{l]{q]{para]
[para}[l [n}4.198{]}ὣς ἔφατʼ, οὐδʼ ἄρα οἱ κῆρυξ ἀπίθησεν ἀκούσας,{l]
[l [n}4.199{]}βῆ δʼ ἰέναι κατὰ λαὸν Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}4.200{]}παπταίνων ἥρωα Μαχάονα· τὸν δὲ νόησεν{l]
[l [n}4.201{]}ἑσταότʼ· ἀμφὶ δέ μιν κρατεραὶ στίχες ἀσπιστάων{l]
[l [n}4.202{]}λαῶν, οἵ οἱ ἕποντο Τρίκης ἐξ ἱπποβότοιο.{l]
[l [n}4.203{]}ἀγχοῦ δʼ ἱστάμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.204{]}ὄρσʼ Ἀσκληπιάδη, καλέει κρείων Ἀγαμέμνων,{l]
[l [n}4.205{]}ὄφρα ἴδῃς Μενέλαον ἀρήϊον ἀρχὸν Ἀχαιῶν,{l]
[l [n}4.206{]}ὅν τις ὀϊστεύσας ἔβαλεν τόξων ἐῢ εἰδὼς{l]
[l [n}4.207{]}Τρώων ἢ Λυκίων, τῷ μὲν κλέος, ἄμμι δὲ πένθος.{l]{q]{para]
[para}[l [n}4.208{]}ὣς φάτο, τῷ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ὄρινε·{l]
[l [n}4.209{]}βὰν δʼ ἰέναι καθʼ ὅμιλον ἀνὰ στρατὸν εὐρὺν Ἀχαιῶν.{l]
[l [n}4.210{]}ἀλλʼ ὅτε δή ῥʼ ἵκανον ὅθι ξανθὸς Μενέλαος{l]
[l [n}4.211{]}βλήμενος ἦν, περὶ δʼ αὐτὸν ἀγηγέραθʼ ὅσσοι ἄριστοι{l]
[l [n}4.212{]}κυκλόσʼ, ὃ δʼ ἐν μέσσοισι παρίστατο ἰσόθεος φώς,{l]
[l [n}4.213{]}αὐτίκα δʼ ἐκ ζωστῆρος ἀρηρότος ἕλκεν ὀϊστόν·{l]
[l [n}4.214{]}τοῦ δʼ ἐξελκομένοιο πάλιν ἄγεν ὀξέες ὄγκοι.{l]
[l [n}4.215{]}λῦσε δέ οἱ ζωστῆρα παναίολον ἠδʼ ὑπένερθε{l]
[l [n}4.216{]}ζῶμά τε καὶ μίτρην, τὴν χαλκῆες κάμον ἄνδρες.{l]
[l [n}4.217{]}αὐτὰρ ἐπεὶ ἴδεν ἕλκος ὅθʼ ἔμπεσε πικρὸς ὀϊστός,{l]
[l [n}4.218{]}αἷμʼ ἐκμυζήσας ἐπʼ ἄρʼ ἤπια φάρμακα εἰδὼς{l]
[l [n}4.219{]}πάσσε, τά οἵ ποτε πατρὶ φίλα φρονέων πόρε Χείρων.{l]{para]
[para}[l [n}4.220{]}ὄφρα τοὶ ἀμφεπένοντο βοὴν ἀγαθὸν Μενέλαον,{l]
[l [n}4.221{]}τόφρα δʼ ἐπὶ Τρώων στίχες ἤλυθον ἀσπιστάων·{l]
[l [n}4.222{]}οἳ δʼ αὖτις κατὰ τεύχεʼ ἔδυν, μνήσαντο δὲ χάρμης.{l]{para]
[para}[l [n}4.223{]}ἔνθʼ οὐκ ἂν βρίζοντα ἴδοις Ἀγαμέμνονα δῖον{l]
[l [n}4.224{]}οὐδὲ καταπτώσσοντʼ οὐδʼ οὐκ ἐθέλοντα μάχεσθαι,{l]
[l [n}4.225{]}ἀλλὰ μάλα σπεύδοντα μάχην ἐς κυδιάνειραν.{l]
[l [n}4.226{]}ἵππους μὲν γὰρ ἔασε καὶ ἅρματα ποικίλα χαλκῷ·{l]
[l [n}4.227{]}καὶ τοὺς μὲν θεράπων ἀπάνευθʼ ἔχε φυσιόωντας{l]
[l [n}4.228{]}Εὐρυμέδων υἱὸς Πτολεμαίου Πειραΐδαο·{l]
[l [n}4.229{]}τῷ μάλα πόλλʼ ἐπέτελλε παρισχέμεν ὁππότε κέν μιν{l]
[l [n}4.230{]}γυῖα λάβῃ κάματος πολέας διὰ κοιρανέοντα·{l]
[l [n}4.231{]}αὐτὰρ ὃ πεζὸς ἐὼν ἐπεπωλεῖτο στίχας ἀνδρῶν·{l]
[l [n}4.232{]}καί ῥʼ οὓς μὲν σπεύδοντας ἴδοι Δαναῶν ταχυπώλων,{l]
[l [n}4.233{]}τοὺς μάλα θαρσύνεσκε παριστάμενος ἐπέεσσιν·{l]
[q}[l [n}4.234{]}Ἀργεῖοι μή πώ τι μεθίετε θούριδος ἀλκῆς·{l]
[l [n}4.235{]}οὐ γὰρ ἐπὶ ψευδέσσι πατὴρ Ζεὺς ἔσσετʼ ἀρωγός,{l]
[l [n}4.236{]}ἀλλʼ οἵ περ πρότεροι ὑπὲρ ὅρκια δηλήσαντο{l]
[l [n}4.237{]}τῶν ἤτοι αὐτῶν τέρενα χρόα γῦπες ἔδονται,{l]
[l [n}4.238{]}ἡμεῖς αὖτʼ ἀλόχους τε φίλας καὶ νήπια τέκνα{l]
[l [n}4.239{]}ἄξομεν ἐν νήεσσιν, ἐπὴν πτολίεθρον ἕλωμεν.{l]{q]{para]
[para}[l [n}4.240{]}οὕς τινας αὖ μεθιέντας ἴδοι στυγεροῦ πολέμοιο,{l]
[l [n}4.241{]}τοὺς μάλα νεικείεσκε χολωτοῖσιν ἐπέεσσιν·{l]
[q}
[para}[l [n}4.242{]}Ἀργεῖοι ἰόμωροι ἐλεγχέες οὔ νυ σέβεσθε;{l]
[l [n}4.243{]}τίφθʼ οὕτως ἔστητε τεθηπότες ἠΰτε νεβροί,{l]
[l [n}4.244{]}αἵ τʼ ἐπεὶ οὖν ἔκαμον πολέος πεδίοιο θέουσαι{l]
[l [n}4.245{]}ἑστᾶσʼ, οὐδʼ ἄρα τίς σφι μετὰ φρεσὶ γίγνεται ἀλκή·{l]
[l [n}4.246{]}ὣς ὑμεῖς ἔστητε τεθηπότες οὐδὲ μάχεσθε.{l]
[l [n}4.247{]}ἦ μένετε Τρῶας σχεδὸν ἐλθέμεν ἔνθά τε νῆες{l]
[l [n}4.248{]}εἰρύατʼ εὔπρυμνοι πολιῆς ἐπὶ θινὶ θαλάσσης,{l]
[l [n}4.249{]}ὄφρα ἴδητʼ αἴ κʼ ὔμμιν ὑπέρσχῃ χεῖρα Κρονίων;{l]{q]{para]
[para}[l [n}4.250{]}ὣς ὅ γε κοιρανέων ἐπεπωλεῖτο στίχας ἀνδρῶν·{l]
[l [n}4.251{]}ἦλθε δʼ ἐπὶ Κρήτεσσι κιὼν ἀνὰ οὐλαμὸν ἀνδρῶν.{l]
[l [n}4.252{]}οἳ δʼ ἀμφʼ Ἰδομενῆα δαΐφρονα θωρήσσοντο·{l]
[l [n}4.253{]}Ἰδομενεὺς μὲν ἐνὶ προμάχοις συῒ εἴκελος ἀλκήν,{l]
[l [n}4.254{]}Μηριόνης δʼ ἄρα οἱ πυμάτας ὄτρυνε φάλαγγας.{l]
[l [n}4.255{]}τοὺς δὲ ἰδὼν γήθησεν ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}4.256{]}αὐτίκα δʼ Ἰδομενῆα προσηύδα μειλιχίοισιν·{l]
[q}[l [n}4.257{]}Ἰδομενεῦ περὶ μέν σε τίω Δαναῶν ταχυπώλων{l]
[l [n}4.258{]}ἠμὲν ἐνὶ πτολέμῳ ἠδʼ ἀλλοίῳ ἐπὶ ἔργῳ{l]
[l [n}4.259{]}ἠδʼ ἐν δαίθʼ, ὅτε πέρ τε γερούσιον αἴθοπα οἶνον{l]
[l [n}4.260{]}Ἀργείων οἳ ἄριστοι ἐνὶ κρητῆρι κέρωνται.{l]
[l [n}4.261{]}εἴ περ γάρ τʼ ἄλλοι γε κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}4.262{]}δαιτρὸν πίνωσιν, σὸν δὲ πλεῖον δέπας αἰεὶ{l]
[l [n}4.263{]}ἕστηχʼ, ὥς περ ἐμοί, πιέειν ὅτε θυμὸς ἀνώγοι.{l]
[l [n}4.264{]}ἀλλʼ ὄρσευ πόλεμον δʼ οἷος πάρος εὔχεαι εἶναι.{l]{q]{para]
[para}[l [n}4.265{]}τὸν δʼ αὖτʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}4.266{]}Ἀτρεΐδη μάλα μέν τοι ἐγὼν ἐρίηρος ἑταῖρος{l]
[l [n}4.267{]}ἔσσομαι, ὡς τὸ πρῶτον ὑπέστην καὶ κατένευσα·{l]
[l [n}4.268{]}ἀλλʼ ἄλλους ὄτρυνε κάρη κομόωντας Ἀχαιοὺς{l]
[l [n}4.269{]}ὄφρα τάχιστα μαχώμεθʼ, ἐπεὶ σύν γʼ ὅρκιʼ ἔχευαν{l]
[l [n}4.270{]}Τρῶες· τοῖσιν δʼ αὖ θάνατος καὶ κήδεʼ ὀπίσσω{l]
[l [n}4.271{]}ἔσσετʼ ἐπεὶ πρότεροι ὑπὲρ ὅρκια δηλήσαντο.{l]{q]{para]
[para}[l [n}4.272{]}ὣς ἔφατʼ, Ἀτρεΐδης δὲ παρῴχετο γηθόσυνος κῆρ·{l]
[l [n}4.273{]}ἦλθε δʼ ἐπʼ Αἰάντεσσι κιὼν ἀνὰ οὐλαμὸν ἀνδρῶν·{l]
[l [n}4.274{]}τὼ δὲ κορυσσέσθην, ἅμα δὲ νέφος εἵπετο πεζῶν.{l]
[l [n}4.275{]}ὡς δʼ ὅτʼ ἀπὸ σκοπιῆς εἶδεν νέφος αἰπόλος ἀνὴρ{l]
[l [n}4.276{]}ἐρχόμενον κατὰ πόντον ὑπὸ Ζεφύροιο ἰωῆς·{l]
[l [n}4.277{]}τῷ δέ τʼ ἄνευθεν ἐόντι μελάντερον ἠΰτε πίσσα{l]
[l [n}4.278{]}φαίνετʼ ἰὸν κατὰ πόντον, ἄγει δέ τε λαίλαπα πολλήν,{l]
[l [n}4.279{]}ῥίγησέν τε ἰδών, ὑπό τε σπέος ἤλασε μῆλα·{l]
[l [n}4.280{]}τοῖαι ἅμʼ Αἰάντεσσι διοτρεφέων αἰζηῶν{l]
[l [n}4.281{]}δήϊον ἐς πόλεμον πυκιναὶ κίνυντο φάλαγγες{l]
[l [n}4.282{]}κυάνεαι, σάκεσίν τε καὶ ἔγχεσι πεφρικυῖαι.{l]
[l [n}4.283{]}καὶ τοὺς μὲν γήθησεν ἰδὼν κρείων Ἀγαμέμνων,{l]
[l [n}4.284{]}καί σφεας φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.285{]}Αἴαντʼ Ἀργείων ἡγήτορε χαλκοχιτώνων,{l]
[l [n}4.286{]}σφῶϊ μέν· οὐ γὰρ ἔοικʼ ὀτρυνέμεν· οὔ τι κελεύω·{l]
[l [n}4.287{]}αὐτὼ γὰρ μάλα λαὸν ἀνώγετον ἶφι μάχεσθαι.{l]
[l [n}4.288{]}αἲ γὰρ Ζεῦ τε πάτερ καὶ Ἀθηναίη καὶ Ἄπολλον{l]
[l [n}4.289{]}τοῖος πᾶσιν θυμὸς ἐνὶ στήθεσσι γένοιτο·{l]
[l [n}4.290{]}τώ κε τάχʼ ἠμύσειε πόλις Πριάμοιο ἄνακτος{l]
[l [n}4.291{]}χερσὶν ὑφʼ ἡμετέρῃσιν ἁλοῦσά τε περθομένη τε.{l]{q]{para]
[para}[l [n}4.292{]}ὣς εἰπὼν τοὺς μὲν λίπεν αὐτοῦ, βῆ δὲ μετʼ ἄλλους·{l]
[l [n}4.293{]}ἔνθʼ ὅ γε Νέστορʼ ἔτετμε λιγὺν Πυλίων ἀγορητὴν{l]
[l [n}4.294{]}οὓς ἑτάρους στέλλοντα καὶ ὀτρύνοντα μάχεσθαι{l]
[l [n}4.295{]}ἀμφὶ μέγαν Πελάγοντα Ἀλάστορά τε Χρομίον τε{l]
[l [n}4.296{]}Αἵμονά τε κρείοντα Βίαντά τε ποιμένα λαῶν·{l]
[l [n}4.297{]}ἱππῆας μὲν πρῶτα σὺν ἵπποισιν καὶ ὄχεσφι,{l]
[l [n}4.298{]}πεζοὺς δʼ ἐξόπιθε στῆσεν πολέας τε καὶ ἐσθλοὺς{l]
[l [n}4.299{]}ἕρκος ἔμεν πολέμοιο· κακοὺς δʼ ἐς μέσσον ἔλασσεν,{l]
[l [n}4.300{]}ὄφρα καὶ οὐκ ἐθέλων τις ἀναγκαίῃ πολεμίζοι.{l]
[l [n}4.301{]}ἱππεῦσιν μὲν πρῶτʼ ἐπετέλλετο· τοὺς γὰρ ἀνώγει{l]
[l [n}4.302{]}σφοὺς ἵππους ἐχέμεν μηδὲ κλονέεσθαι ὁμίλῳ·{l]
[q}[l [n}4.303{]}μηδέ τις ἱπποσύνῃ τε καὶ ἠνορέηφι πεποιθὼς{l]
[l [n}4.304{]}οἶος πρόσθʼ ἄλλων μεμάτω Τρώεσσι μάχεσθαι,{l]
[l [n}4.305{]}μηδʼ ἀναχωρείτω· ἀλαπαδνότεροι γὰρ ἔσεσθε.{l]
[l [n}4.306{]}ὃς δέ κʼ ἀνὴρ ἀπὸ ὧν ὀχέων ἕτερʼ ἅρμαθʼ ἵκηται{l]
[l [n}4.307{]}ἔγχει ὀρεξάσθω, ἐπεὶ ἦ πολὺ φέρτερον οὕτω.{l]
[l [n}4.308{]}ὧδε καὶ οἱ πρότεροι πόλεας καὶ τείχεʼ ἐπόρθεον{l]
[l [n}4.309{]}τόνδε νόον καὶ θυμὸν ἐνὶ στήθεσσιν ἔχοντες.{l]{q]{para]
[para}[l [n}4.310{]}ὣς ὃ γέρων ὄτρυνε πάλαι πολέμων ἐῢ εἰδώς·{l]
[l [n}4.311{]}καὶ τὸν μὲν γήθησεν ἰδὼν κρείων Ἀγαμέμνων,{l]
[l [n}4.312{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.313{]}ὦ γέρον εἴθʼ ὡς θυμὸς ἐνὶ στήθεσσι φίλοισιν{l]
[l [n}4.314{]}ὥς τοι γούναθʼ ἕποιτο, βίη δέ τοι ἔμπεδος εἴη·{l]
[l [n}4.315{]}ἀλλά σε γῆρας τείρει ὁμοίϊον· ὡς ὄφελέν τις{l]
[l [n}4.316{]}ἀνδρῶν ἄλλος ἔχειν, σὺ δὲ κουροτέροισι μετεῖναι.{l]{q]{para]
[para}[l [n}4.317{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}4.318{]}Ἀτρεΐδη μάλα μέν τοι ἐγὼν ἐθέλοιμι καὶ αὐτὸς{l]
[l [n}4.319{]}ὣς ἔμεν ὡς ὅτε δῖον Ἐρευθαλίωνα κατέκταν.{l]
[l [n}4.320{]}ἀλλʼ οὔ πως ἅμα πάντα θεοὶ δόσαν ἀνθρώποισιν·{l]
[l [n}4.321{]}εἰ τότε κοῦρος ἔα νῦν αὖτέ με γῆρας ὀπάζει.{l]
[l [n}4.322{]}ἀλλὰ καὶ ὧς ἱππεῦσι μετέσσομαι ἠδὲ κελεύσω{l]
[l [n}4.323{]}βουλῇ καὶ μύθοισι· τὸ γὰρ γέρας ἐστὶ γερόντων.{l]
[l [n}4.324{]}αἰχμὰς δʼ αἰχμάσσουσι νεώτεροι, οἵ περ ἐμεῖο{l]
[l [n}4.325{]}ὁπλότεροι γεγάασι πεποίθασίν τε βίηφιν.{l]{q]{para]
[para}[l [n}4.326{]}ὣς ἔφατʼ, Ἀτρεΐδης δὲ παρῴχετο γηθόσυνος κῆρ.{l]
[l [n}4.327{]}εὗρʼ υἱὸν Πετεῶο Μενεσθῆα πλήξιππον{l]
[l [n}4.328{]}ἑσταότʼ· ἀμφὶ δʼ Ἀθηναῖοι μήστωρες ἀϋτῆς·{l]
[l [n}4.329{]}αὐτὰρ ὃ πλησίον ἑστήκει πολύμητις Ὀδυσσεύς,{l]
[l [n}4.330{]}πὰρ δὲ Κεφαλλήνων ἀμφὶ στίχες οὐκ ἀλαπαδναὶ{l]
[l [n}4.331{]}ἕστασαν· οὐ γάρ πώ σφιν ἀκούετο λαὸς ἀϋτῆς,{l]
[l [n}4.332{]}ἀλλὰ νέον συνορινόμεναι κίνυντο φάλαγγες{l]
[l [n}4.333{]}Τρώων ἱπποδάμων καὶ Ἀχαιῶν· οἳ δὲ μένοντες{l]
[l [n}4.334{]}ἕστασαν ὁππότε πύργος Ἀχαιῶν ἄλλος ἐπελθὼν{l]
[l [n}4.335{]}Τρώων ὁρμήσειε καὶ ἄρξειαν πολέμοιο.{l]
[l [n}4.336{]}τοὺς δὲ ἰδὼν νείκεσσεν ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}4.337{]}καί σφεας φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.338{]}ὦ υἱὲ Πετεῶο διοτρεφέος βασιλῆος,{l]
[l [n}4.339{]}καὶ σὺ κακοῖσι δόλοισι κεκασμένε κερδαλεόφρον{l]
[l [n}4.340{]}τίπτε καταπτώσσοντες ἀφέστατε, μίμνετε δʼ ἄλλους;{l]
[l [n}4.341{]}σφῶϊν μέν τʼ ἐπέοικε μετὰ πρώτοισιν ἐόντας{l]
[l [n}4.342{]}ἑστάμεν ἠδὲ μάχης καυστείρης ἀντιβολῆσαι·{l]
[l [n}4.343{]}πρώτω γὰρ καὶ δαιτὸς ἀκουάζεσθον ἐμεῖο,{l]
[l [n}4.344{]}ὁππότε δαῖτα γέρουσιν ἐφοπλίζωμεν Ἀχαιοί.{l]
[l [n}4.345{]}ἔνθα φίλʼ ὀπταλέα κρέα ἔδμεναι ἠδὲ κύπελλα{l]
[l [n}4.346{]}οἴνου πινέμεναι μελιηδέος ὄφρʼ ἐθέλητον·{l]
[l [n}4.347{]}νῦν δὲ φίλως χʼ ὁρόῳτε καὶ εἰ δέκα πύργοι Ἀχαιῶν{l]
[l [n}4.348{]}ὑμείων προπάροιθε μαχοίατο νηλέϊ χαλκῷ.{l]{q]{para]
[para}[l [n}4.349{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}4.350{]}Ἀτρεΐδη ποῖόν σε ἔπος φύγεν ἕρκος ὀδόντων;{l]
[l [n}4.351{]}πῶς δὴ φῂς πολέμοιο μεθιέμεν ὁππότʼ Ἀχαιοὶ{l]
[l [n}4.352{]}Τρωσὶν ἐφʼ ἱπποδάμοισιν ἐγείρομεν ὀξὺν Ἄρηα;{l]
[l [n}4.353{]}ὄψεαι αἴ κʼ ἐθέλῃσθα καὶ αἴ κέν τοι τὰ μεμήλῃ{l]
[l [n}4.354{]}Τηλεμάχοιο φίλον πατέρα προμάχοισι μιγέντα{l]
[l [n}4.355{]}Τρώων ἱπποδάμων· σὺ δὲ ταῦτʼ ἀνεμώλια βάζεις.{l]{q]{para]
[para}[l [n}4.356{]}τὸν δʼ ἐπιμειδήσας προσέφη κρείων Ἀγαμέμνων{l]
[l [n}4.357{]}ὡς γνῶ χωομένοιο· πάλιν δʼ ὅ γε λάζετο μῦθον·{l]
[q}[l [n}4.358{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}4.359{]}οὔτέ σε νεικείω περιώσιον οὔτε κελεύω·{l]
[l [n}4.360{]}οἶδα γὰρ ὥς τοι θυμὸς ἐνὶ στήθεσσι φίλοισιν{l]
[l [n}4.361{]}ἤπια δήνεα οἶδε· τὰ γὰρ φρονέεις ἅ τʼ ἐγώ περ.{l]
[l [n}4.362{]}ἀλλʼ ἴθι ταῦτα δʼ ὄπισθεν ἀρεσσόμεθʼ εἴ τι κακὸν νῦν{l]
[l [n}4.363{]}εἴρηται, τὰ δὲ πάντα θεοὶ μεταμώνια θεῖεν.{l]{q]{para]
[para}[l [n}4.364{]}ὣς εἰπὼν τοὺς μὲν λίπεν αὐτοῦ, βῆ δὲ μετʼ ἄλλους.{l]
[l [n}4.365{]}εὗρε δὲ Τυδέος υἱὸν ὑπέρθυμον Διομήδεα{l]
[l [n}4.366{]}ἑσταότʼ ἔν θʼ ἵπποισι καὶ ἅρμασι κολλητοῖσι·{l]
[l [n}4.367{]}πὰρ δέ οἱ ἑστήκει Σθένελος Καπανήϊος υἱός.{l]
[l [n}4.368{]}καὶ τὸν μὲν νείκεσσεν ἰδὼν κρείων Ἀγαμέμνων,{l]
[l [n}4.369{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}4.370{]}ὤ μοι Τυδέος υἱὲ δαΐφρονος ἱπποδάμοιο{l]
[l [n}4.371{]}τί πτώσσεις, τί δʼ ὀπιπεύεις πολέμοιο γεφύρας;{l]
[l [n}4.372{]}οὐ μὲν Τυδέϊ γʼ ὧδε φίλον πτωσκαζέμεν ἦεν,{l]
[l [n}4.373{]}ἀλλὰ πολὺ πρὸ φίλων ἑτάρων δηΐοισι μάχεσθαι,{l]
[l [n}4.374{]}ὡς φάσαν οἵ μιν ἴδοντο πονεύμενον· οὐ γὰρ ἔγωγε{l]
[l [n}4.375{]}ἤντησʼ οὐδὲ ἴδον· περὶ δʼ ἄλλων φασὶ γενέσθαι.{l]
[l [n}4.376{]}ἤτοι μὲν γὰρ ἄτερ πολέμου εἰσῆλθε Μυκήνας{l]
[l [n}4.377{]}ξεῖνος ἅμʼ ἀντιθέῳ Πολυνείκεϊ λαὸν ἀγείρων·{l]
[l [n}4.378{]}οἳ δὲ τότʼ ἐστρατόωνθʼ ἱερὰ πρὸς τείχεα Θήβης,{l]
[l [n}4.379{]}καί ῥα μάλα λίσσοντο δόμεν κλειτοὺς ἐπικούρους·{l]
[l [n}4.380{]}οἳ δʼ ἔθελον δόμεναι καὶ ἐπῄνεον ὡς ἐκέλευον·{l]
[l [n}4.381{]}ἀλλὰ Ζεὺς ἔτρεψε παραίσια σήματα φαίνων.{l]
[l [n}4.382{]}οἳ δʼ ἐπεὶ οὖν ᾤχοντο ἰδὲ πρὸ ὁδοῦ ἐγένοντο,{l]
[l [n}4.383{]}Ἀσωπὸν δʼ ἵκοντο βαθύσχοινον λεχεποίην,{l]
[l [n}4.384{]}ἔνθʼ αὖτʼ ἀγγελίην ἐπὶ Τυδῆ στεῖλαν Ἀχαιοί.{l]
[l [n}4.385{]}αὐτὰρ ὃ βῆ, πολέας δὲ κιχήσατο Καδμεΐωνας{l]
[l [n}4.386{]}δαινυμένους κατὰ δῶμα βίης Ἐτεοκληείης.{l]
[l [n}4.387{]}ἔνθʼ οὐδὲ ξεῖνός περ ἐὼν ἱππηλάτα Τυδεὺς{l]
[l [n}4.388{]}τάρβει, μοῦνος ἐὼν πολέσιν μετὰ Καδμείοισιν,{l]
[l [n}4.389{]}ἀλλʼ ὅ γʼ ἀεθλεύειν προκαλίζετο, πάντα δʼ ἐνίκα{l]
[l [n}4.390{]}ῥηϊδίως· τοίη οἱ ἐπίρροθος ἦεν Ἀθήνη.{l]
[l [n}4.391{]}οἳ δὲ χολωσάμενοι Καδμεῖοι κέντορες ἵππων{l]
[l [n}4.392{]}ἂψ ἄρʼ ἀνερχομένῳ πυκινὸν λόχον εἷσαν ἄγοντες{l]
[l [n}4.393{]}κούρους πεντήκοντα· δύω δʼ ἡγήτορες ἦσαν,{l]
[l [n}4.394{]}Μαίων Αἱμονίδης ἐπιείκελος ἀθανάτοισιν,{l]
[l [n}4.395{]}υἱός τʼ Αὐτοφόνοιο μενεπτόλεμος Πολυφόντης.{l]
[l [n}4.396{]}Τυδεὺς μὲν καὶ τοῖσιν ἀεικέα πότμον ἐφῆκε·{l]
[l [n}4.397{]}πάντας ἔπεφνʼ, ἕνα δʼ οἶον ἵει οἶκον δὲ νέεσθαι·{l]
[l [n}4.398{]}Μαίονʼ ἄρα προέηκε θεῶν τεράεσσι πιθήσας.{l]
[l [n}4.399{]}τοῖος ἔην Τυδεὺς Αἰτώλιος· ἀλλὰ τὸν υἱὸν{l]
[l [n}4.400{]}γείνατο εἷο χέρεια μάχῃ, ἀγορῇ δέ τʼ ἀμείνω.{l]{q]{para]
[para}[l [n}4.401{]}ὣς φάτο, τὸν δʼ οὔ τι προσέφη κρατερὸς Διομήδης{l]
[l [n}4.402{]}αἰδεσθεὶς βασιλῆος ἐνιπὴν αἰδοίοιο·{l]
[l [n}4.403{]}τὸν δʼ υἱὸς Καπανῆος ἀμείψατο κυδαλίμοιο·{l]
[q}[l [n}4.404{]}Ἀτρεΐδη μὴ ψεύδεʼ ἐπιστάμενος σάφα εἰπεῖν·{l]
[l [n}4.405{]}ἡμεῖς τοι πατέρων μέγʼ ἀμείνονες εὐχόμεθʼ εἶναι·{l]
[l [n}4.406{]}ἡμεῖς καὶ Θήβης ἕδος εἵλομεν ἑπταπύλοιο{l]
[l [n}4.407{]}παυρότερον λαὸν ἀγαγόνθʼ ὑπὸ τεῖχος ἄρειον,{l]
[l [n}4.408{]}πειθόμενοι τεράεσσι θεῶν καὶ Ζηνὸς ἀρωγῇ·{l]
[l [n}4.409{]}κεῖνοι δὲ σφετέρῃσιν ἀτασθαλίῃσιν ὄλοντο·{l]
[l [n}4.410{]}τὼ μή μοι πατέρας ποθʼ ὁμοίῃ ἔνθεο τιμῇ.{l]{q]{para]
[para}[l [n}4.411{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}4.412{]}τέττα, σιωπῇ ἧσο, ἐμῷ δʼ ἐπιπείθεο μύθῳ·{l]
[l [n}4.413{]}οὐ γὰρ ἐγὼ νεμεσῶ Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}4.414{]}ὀτρύνοντι μάχεσθαι ἐϋκνήμιδας Ἀχαιούς·{l]
[l [n}4.415{]}τούτῳ μὲν γὰρ κῦδος ἅμʼ ἕψεται εἴ κεν Ἀχαιοὶ{l]
[l [n}4.416{]}Τρῶας δῃώσωσιν ἕλωσί τε Ἴλιον ἱρήν,{l]
[l [n}4.417{]}τούτῳ δʼ αὖ μέγα πένθος Ἀχαιῶν δῃωθέντων.{l]
[l [n}4.418{]}ἀλλʼ ἄγε δὴ καὶ νῶϊ μεδώμεθα θούριδος ἀλκῆς.{l]{q]{para]
[para}[l [n}4.419{]}ἦ ῥα καὶ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε·{l]
[l [n}4.420{]}δεινὸν δʼ ἔβραχε χαλκὸς ἐπὶ στήθεσσιν ἄνακτος{l]
[l [n}4.421{]}ὀρνυμένου· ὑπό κεν ταλασίφρονά περ δέος εἷλεν.{l]{para]
[para}[l [n}4.422{]}ὡς δʼ ὅτʼ ἐν αἰγιαλῷ πολυηχέϊ κῦμα θαλάσσης{l]
[l [n}4.423{]}ὄρνυτʼ ἐπασσύτερον Ζεφύρου ὕπο κινήσαντος·{l]
[l [n}4.424{]}πόντῳ μέν τε πρῶτα κορύσσεται, αὐτὰρ ἔπειτα{l]
[l [n}4.425{]}χέρσῳ ῥηγνύμενον μεγάλα βρέμει, ἀμφὶ δέ τʼ ἄκρας{l]
[l [n}4.426{]}κυρτὸν ἐὸν κορυφοῦται, ἀποπτύει δʼ ἁλὸς ἄχνην·{l]
[l [n}4.427{]}ὣς τότʼ ἐπασσύτεραι Δαναῶν κίνυντο φάλαγγες{l]
[l [n}4.428{]}νωλεμέως πόλεμον δέ· κέλευε δὲ οἷσιν ἕκαστος{l]
[l [n}4.429{]}ἡγεμόνων· οἳ δʼ ἄλλοι ἀκὴν ἴσαν, οὐδέ κε φαίης{l]
[l [n}4.430{]}τόσσον λαὸν ἕπεσθαι ἔχοντʼ ἐν στήθεσιν αὐδήν,{l]
[l [n}4.431{]}σιγῇ δειδιότες σημάντορας· ἀμφὶ δὲ πᾶσι{l]
[l [n}4.432{]}τεύχεα ποικίλʼ ἔλαμπε, τὰ εἱμένοι ἐστιχόωντο.{l]
[l [n}4.433{]}Τρῶες δʼ, ὥς τʼ ὄϊες πολυπάμονος ἀνδρὸς ἐν αὐλῇ{l]
[l [n}4.434{]}μυρίαι ἑστήκασιν ἀμελγόμεναι γάλα λευκὸν{l]
[l [n}4.435{]}ἀζηχὲς μεμακυῖαι ἀκούουσαι ὄπα ἀρνῶν,{l]
[l [n}4.436{]}ὣς Τρώων ἀλαλητὸς ἀνὰ στρατὸν εὐρὺν ὀρώρει·{l]
[l [n}4.437{]}οὐ γὰρ πάντων ἦεν ὁμὸς θρόος οὐδʼ ἴα γῆρυς,{l]
[l [n}4.438{]}ἀλλὰ γλῶσσα μέμικτο, πολύκλητοι δʼ ἔσαν ἄνδρες.{l]
[l [n}4.439{]}ὄρσε δὲ τοὺς μὲν Ἄρης, τοὺς δὲ γλαυκῶπις Ἀθήνη{l]
[l [n}4.440{]}Δεῖμός τʼ ἠδὲ Φόβος καὶ Ἔρις ἄμοτον μεμαυῖα,{l]
[l [n}4.441{]}Ἄρεος ἀνδροφόνοιο κασιγνήτη ἑτάρη τε,{l]
[l [n}4.442{]}ἥ τʼ ὀλίγη μὲν πρῶτα κορύσσεται, αὐτὰρ ἔπειτα{l]
[l [n}4.443{]}οὐρανῷ ἐστήριξε κάρη καὶ ἐπὶ χθονὶ βαίνει·{l]
[l [n}4.444{]}ἥ σφιν καὶ τότε νεῖκος ὁμοίϊον ἔμβαλε μέσσῳ{l]
[l [n}4.445{]}ἐρχομένη καθʼ ὅμιλον ὀφέλλουσα στόνον ἀνδρῶν.{l]{para]
[para}[l [n}4.446{]}οἳ δʼ ὅτε δή ῥʼ ἐς χῶρον ἕνα ξυνιόντες ἵκοντο,{l]
[l [n}4.447{]}σύν ῥʼ ἔβαλον ῥινούς, σὺν δʼ ἔγχεα καὶ μένεʼ ἀνδρῶν{l]
[l [n}4.448{]}χαλκεοθωρήκων· ἀτὰρ ἀσπίδες ὀμφαλόεσσαι{l]
[l [n}4.449{]}ἔπληντʼ ἀλλήλῃσι, πολὺς δʼ ὀρυμαγδὸς ὀρώρει.{l]
[l [n}4.450{]}ἔνθα δʼ ἅμʼ οἰμωγή τε καὶ εὐχωλὴ πέλεν ἀνδρῶν{l]
[l [n}4.451{]}ὀλλύντων τε καὶ ὀλλυμένων, ῥέε δʼ αἵματι γαῖα.{l]
[l [n}4.452{]}ὡς δʼ ὅτε χείμαρροι ποταμοὶ κατʼ ὄρεσφι ῥέοντες{l]
[l [n}4.453{]}ἐς μισγάγκειαν συμβάλλετον ὄβριμον ὕδωρ{l]
[l [n}4.454{]}κρουνῶν ἐκ μεγάλων κοίλης ἔντοσθε χαράδρης,{l]
[l [n}4.455{]}τῶν δέ τε τηλόσε δοῦπον ἐν οὔρεσιν ἔκλυε ποιμήν·{l]
[l [n}4.456{]}ὣς τῶν μισγομένων γένετο ἰαχή τε πόνος τε.{l]{para]
[para}[l [n}4.457{]}πρῶτος δʼ Ἀντίλοχος Τρώων ἕλεν ἄνδρα κορυστὴν{l]
[l [n}4.458{]}ἐσθλὸν ἐνὶ προμάχοισι Θαλυσιάδην Ἐχέπωλον·{l]
[l [n}4.459{]}τόν ῥʼ ἔβαλε πρῶτος κόρυθος φάλον ἱπποδασείης,{l]
[l [n}4.460{]}ἐν δὲ μετώπῳ πῆξε, πέρησε δʼ ἄρʼ ὀστέον εἴσω{l]
[l [n}4.461{]}αἰχμὴ χαλκείη· τὸν δὲ σκότος ὄσσε κάλυψεν,{l]
[l [n}4.462{]}ἤριπε δʼ ὡς ὅτε πύργος ἐνὶ κρατερῇ ὑσμίνῃ.{l]
[l [n}4.463{]}τὸν δὲ πεσόντα ποδῶν ἔλαβε κρείων Ἐλεφήνωρ{l]
[l [n}4.464{]}Χαλκωδοντιάδης μεγαθύμων ἀρχὸς Ἀβάντων,{l]
[l [n}4.465{]}ἕλκε δʼ ὑπʼ ἐκ βελέων, λελιημένος ὄφρα τάχιστα{l]
[l [n}4.466{]}τεύχεα συλήσειε· μίνυνθα δέ οἱ γένεθʼ ὁρμή.{l]
[l [n}4.467{]}νεκρὸν γὰρ ἐρύοντα ἰδὼν μεγάθυμος Ἀγήνωρ{l]
[l [n}4.468{]}πλευρά, τά οἱ κύψαντι παρʼ ἀσπίδος ἐξεφαάνθη,{l]
[l [n}4.469{]}οὔτησε ξυστῷ χαλκήρεϊ, λῦσε δὲ γυῖα.{l]
[l [n}4.470{]}ὣς τὸν μὲν λίπε θυμός, ἐπʼ αὐτῷ δʼ ἔργον ἐτύχθη{l]
[l [n}4.471{]}ἀργαλέον Τρώων καὶ Ἀχαιῶν· οἳ δὲ λύκοι ὣς{l]
[l [n}4.472{]}ἀλλήλοις ἐπόρουσαν, ἀνὴρ δʼ ἄνδρʼ ἐδνοπάλιζεν.{l]{para]
[para}[l [n}4.473{]}ἔνθʼ ἔβαλʼ Ἀνθεμίωνος υἱὸν Τελαμώνιος Αἴας{l]
[l [n}4.474{]}ἠΐθεον θαλερὸν Σιμοείσιον, ὅν ποτε μήτηρ{l]
[l [n}4.475{]}Ἴδηθεν κατιοῦσα παρʼ ὄχθῃσιν Σιμόεντος{l]
[l [n}4.476{]}γείνατʼ, ἐπεί ῥα τοκεῦσιν ἅμʼ ἕσπετο μῆλα ἰδέσθαι·{l]
[l [n}4.477{]}τοὔνεκά μιν κάλεον Σιμοείσιον· οὐδὲ τοκεῦσι{l]
[l [n}4.478{]}θρέπτρα φίλοις ἀπέδωκε, μινυνθάδιος δέ οἱ αἰὼν{l]
[l [n}4.479{]}ἔπλεθʼ ὑπʼ Αἴαντος μεγαθύμου δουρὶ δαμέντι.{l]
[l [n}4.480{]}πρῶτον γάρ μιν ἰόντα βάλε στῆθος παρὰ μαζὸν{l]
[l [n}4.481{]}δεξιόν· ἀντικρὺ δὲ διʼ ὤμου χάλκεον ἔγχος{l]
[l [n}4.482{]}ἦλθεν· ὁ δʼ ἐν κονίῃσι χαμαὶ πέσεν αἴγειρος ὣς{l]
[l [n}4.483{]}ἥ ῥά τʼ ἐν εἱαμενῇ ἕλεος μεγάλοιο πεφύκει{l]
[l [n}4.484{]}λείη, ἀτάρ τέ οἱ ὄζοι ἐπʼ ἀκροτάτῃ πεφύασι·{l]
[l [n}4.485{]}τὴν μέν θʼ ἁρματοπηγὸς ἀνὴρ αἴθωνι σιδήρῳ{l]
[l [n}4.486{]}ἐξέταμʼ, ὄφρα ἴτυν κάμψῃ περικαλλέϊ δίφρῳ·{l]
[l [n}4.487{]}ἣ μέν τʼ ἀζομένη κεῖται ποταμοῖο παρʼ ὄχθας.{l]
[l [n}4.488{]}τοῖον ἄρʼ Ἀνθεμίδην Σιμοείσιον ἐξενάριξεν{l]
[l [n}4.489{]}Αἴας διογενής· τοῦ δʼ Ἄντιφος αἰολοθώρηξ{l]
[l [n}4.490{]}Πριαμίδης καθʼ ὅμιλον ἀκόντισεν ὀξέϊ δουρί.{l]
[l [n}4.491{]}τοῦ μὲν ἅμαρθʼ, ὃ δὲ Λεῦκον Ὀδυσσέος ἐσθλὸν ἑταῖρον{l]
[l [n}4.492{]}βεβλήκει βουβῶνα, νέκυν ἑτέρωσʼ ἐρύοντα·{l]
[l [n}4.493{]}ἤριπε δʼ ἀμφʼ αὐτῷ, νεκρὸς δέ οἱ ἔκπεσε χειρός.{l]
[l [n}4.494{]}τοῦ δʼ Ὀδυσεὺς μάλα θυμὸν ἀποκταμένοιο χολώθη,{l]
[l [n}4.495{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ,{l]
[l [n}4.496{]}στῆ δὲ μάλʼ ἐγγὺς ἰὼν καὶ ἀκόντισε δουρὶ φαεινῷ{l]
[l [n}4.497{]}ἀμφὶ ἓ παπτήνας· ὑπὸ δὲ Τρῶες κεκάδοντο{l]
[l [n}4.498{]}ἀνδρὸς ἀκοντίσσαντος· ὃ δʼ οὐχ ἅλιον βέλος ἧκεν,{l]
[l [n}4.499{]}ἀλλʼ υἱὸν Πριάμοιο νόθον βάλε Δημοκόωντα{l]
[l [n}4.500{]}ὅς οἱ Ἀβυδόθεν ἦλθε παρʼ ἵππων ὠκειάων.{l]
[l [n}4.501{]}τόν ῥʼ Ὀδυσεὺς ἑτάροιο χολωσάμενος βάλε δουρὶ{l]
[l [n}4.502{]}κόρσην· ἣ δʼ ἑτέροιο διὰ κροτάφοιο πέρησεν{l]
[l [n}4.503{]}αἰχμὴ χαλκείη· τὸν δὲ σκότος ὄσσε κάλυψε,{l]
[l [n}4.504{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]
[l [n}4.505{]}χώρησαν δʼ ὑπό τε πρόμαχοι καὶ φαίδιμος Ἕκτωρ·{l]
[l [n}4.506{]}Ἀργεῖοι δὲ μέγα ἴαχον, ἐρύσαντο δὲ νεκρούς,{l]
[l [n}4.507{]}ἴθυσαν δὲ πολὺ προτέρω· νεμέσησε δʼ Ἀπόλλων{l]
[l [n}4.508{]}Περγάμου ἐκκατιδών, Τρώεσσι δὲ κέκλετʼ ἀΰσας·{l]
[q}[l [n}4.509{]}ὄρνυσθʼ ἱππόδαμοι Τρῶες μηδʼ εἴκετε χάρμης{l]
[l [n}4.510{]}Ἀργείοις, ἐπεὶ οὔ σφι λίθος χρὼς οὐδὲ σίδηρος{l]
[l [n}4.511{]}χαλκὸν ἀνασχέσθαι ταμεσίχροα βαλλομένοισιν·{l]
[l [n}4.512{]}οὐ μὰν οὐδʼ Ἀχιλεὺς Θέτιδος πάϊς ἠϋκόμοιο{l]
[l [n}4.513{]}μάρναται, ἀλλʼ ἐπὶ νηυσὶ χόλον θυμαλγέα πέσσει.{l]{q]{para]
[para}[l [n}4.514{]}ὣς φάτʼ ἀπὸ πτόλιος δεινὸς θεός· αὐτὰρ Ἀχαιοὺς{l]
[l [n}4.515{]}ὦρσε Διὸς θυγάτηρ κυδίστη Τριτογένεια{l]
[l [n}4.516{]}ἐρχομένη καθʼ ὅμιλον, ὅθι μεθιέντας ἴδοιτο.{l]{para]
[para}[l [n}4.517{]}ἔνθʼ Ἀμαρυγκείδην Διώρεα μοῖρα πέδησε·{l]
[l [n}4.518{]}χερμαδίῳ γὰρ βλῆτο παρὰ σφυρὸν ὀκριόεντι{l]
[l [n}4.519{]}κνήμην δεξιτερήν· βάλε δὲ Θρῃκῶν ἀγὸς ἀνδρῶν{l]
[l [n}4.520{]}Πείρως Ἰμβρασίδης ὃς ἄρʼ Αἰνόθεν εἰληλούθει.{l]
[l [n}4.521{]}ἀμφοτέρω δὲ τένοντε καὶ ὀστέα λᾶας ἀναιδὴς{l]
[l [n}4.522{]}ἄχρις ἀπηλοίησεν· ὃ δʼ ὕπτιος ἐν κονίῃσι{l]
[l [n}4.523{]}κάππεσεν ἄμφω χεῖρε φίλοις ἑτάροισι πετάσσας{l]
[l [n}4.524{]}θυμὸν ἀποπνείων· ὃ δʼ ἐπέδραμεν ὅς ῥʼ ἔβαλέν περ{l]
[l [n}4.525{]}Πείροος, οὖτα δὲ δουρὶ παρʼ ὀμφαλόν· ἐκ δʼ ἄρα πᾶσαι{l]
[l [n}4.526{]}χύντο χαμαὶ χολάδες, τὸν δὲ σκότος ὄσσε κάλυψε.{l]{para]
[para}[l [n}4.527{]}τὸν δὲ Θόας Αἰτωλὸς ἀπεσσύμενον βάλε δουρὶ{l]
[l [n}4.528{]}στέρνον ὑπὲρ μαζοῖο, πάγη δʼ ἐν πνεύμονι χαλκός·{l]
[l [n}4.529{]}ἀγχίμολον δέ οἱ ἦλθε Θόας, ἐκ δʼ ὄβριμον ἔγχος{l]
[l [n}4.530{]}ἐσπάσατο στέρνοιο, ἐρύσσατο δὲ ξίφος ὀξύ,{l]
[l [n}4.531{]}τῷ ὅ γε γαστέρα τύψε μέσην, ἐκ δʼ αἴνυτο θυμόν.{l]
[l [n}4.532{]}τεύχεα δʼ οὐκ ἀπέδυσε· περίστησαν γὰρ ἑταῖροι{l]
[l [n}4.533{]}Θρήϊκες ἀκρόκομοι δολίχʼ ἔγχεα χερσὶν ἔχοντες,{l]
[l [n}4.534{]}οἵ ἑ μέγαν περ ἐόντα καὶ ἴφθιμον καὶ ἀγαυὸν{l]
[l [n}4.535{]}ὦσαν ἀπὸ σφείων· ὃ δὲ χασσάμενος πελεμίχθη.{l]
[l [n}4.536{]}ὣς τώ γʼ ἐν κονίῃσι παρʼ ἀλλήλοισι τετάσθην,{l]
[l [n}4.537{]}ἤτοι ὃ μὲν Θρῃκῶν, ὃ δʼ Ἐπειῶν χαλκοχιτώνων{l]
[l [n}4.538{]}ἡγεμόνες· πολλοὶ δὲ περὶ κτείνοντο καὶ ἄλλοι.{l]{para]
[para}[l [n}4.539{]}ἔνθά κεν οὐκέτι ἔργον ἀνὴρ ὀνόσαιτο μετελθών,{l]
[l [n}4.540{]}ὅς τις ἔτʼ ἄβλητος καὶ ἀνούτατος ὀξέϊ χαλκῷ{l]
[l [n}4.541{]}δινεύοι κατὰ μέσσον, ἄγοι δέ ἑ Παλλὰς Ἀθήνη{l]
[l [n}4.542{]}χειρὸς ἑλοῦσʼ, αὐτὰρ βελέων ἀπερύκοι ἐρωήν·{l]
[l [n}4.543{]}πολλοὶ γὰρ Τρώων καὶ Ἀχαιῶν ἤματι κείνῳ{l]
[l [n}4.544{]}πρηνέες ἐν κονίῃσι παρʼ ἀλλήλοισι τέταντο.{l]{para]
{book]
[book [n}5{]}
[para}[l [n}5.1{]}ἔνθʼ αὖ Τυδεΐδῃ Διομήδεϊ Παλλὰς Ἀθήνη{l]
[l [n}5.2{]}δῶκε μένος καὶ θάρσος, ἵνʼ ἔκδηλος μετὰ πᾶσιν{l]
[l [n}5.3{]}Ἀργείοισι γένοιτο ἰδὲ κλέος ἐσθλὸν ἄροιτο·{l]
[l [n}5.4{]}δαῖέ οἱ ἐκ κόρυθός τε καὶ ἀσπίδος ἀκάματον πῦρ{l]
[l [n}5.5{]}ἀστέρʼ ὀπωρινῷ ἐναλίγκιον, ὅς τε μάλιστα{l]
[l [n}5.6{]}λαμπρὸν παμφαίνῃσι λελουμένος ὠκεανοῖο·{l]
[l [n}5.7{]}τοῖόν οἱ πῦρ δαῖεν ἀπὸ κρατός τε καὶ ὤμων,{l]
[l [n}5.8{]}ὦρσε δέ μιν κατὰ μέσσον ὅθι πλεῖστοι κλονέοντο.{l]{para]
[para}[l [n}5.9{]}ἦν δέ τις ἐν Τρώεσσι Δάρης ἀφνειὸς ἀμύμων{l]
[l [n}5.10{]}ἱρεὺς Ἡφαίστοιο· δύω δέ οἱ υἱέες ἤστην{l]
[l [n}5.11{]}Φηγεὺς Ἰδαῖός τε μάχης εὖ εἰδότε πάσης.{l]
[l [n}5.12{]}τώ οἱ ἀποκρινθέντε ἐναντίω ὁρμηθήτην·{l]
[l [n}5.13{]}τὼ μὲν ἀφʼ ἵπποιιν, ὃ δʼ ἀπὸ χθονὸς ὄρνυτο πεζός.{l]
[l [n}5.14{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες{l]
[l [n}5.15{]}Φηγεύς ῥα πρότερος προΐει δολιχόσκιον ἔγχος·{l]
[l [n}5.16{]}Τυδεΐδεω δʼ ὑπὲρ ὦμον ἀριστερὸν ἤλυθʼ ἀκωκὴ{l]
[l [n}5.17{]}ἔγχεος, οὐδʼ ἔβαλʼ αὐτόν· ὃ δʼ ὕστερος ὄρνυτο χαλκῷ{l]
[l [n}5.18{]}Τυδεΐδης· τοῦ δʼ οὐχ ἅλιον βέλος ἔκφυγε χειρός,{l]
[l [n}5.19{]}ἀλλʼ ἔβαλε στῆθος μεταμάζιον, ὦσε δʼ ἀφʼ ἵππων.{l]
[l [n}5.20{]}Ἰδαῖος δʼ ἀπόρουσε λιπὼν περικαλλέα δίφρον,{l]
[l [n}5.21{]}οὐδʼ ἔτλη περιβῆναι ἀδελφειοῦ κταμένοιο·{l]
[l [n}5.22{]}οὐδὲ γὰρ οὐδέ κεν αὐτὸς ὑπέκφυγε κῆρα μέλαιναν,{l]
[l [n}5.23{]}ἀλλʼ Ἥφαιστος ἔρυτο, σάωσε δὲ νυκτὶ καλύψας,{l]
[l [n}5.24{]}ὡς δή οἱ μὴ πάγχυ γέρων ἀκαχήμενος εἴη.{l]
[l [n}5.25{]}ἵππους δʼ ἐξελάσας μεγαθύμου Τυδέος υἱὸς{l]
[l [n}5.26{]}δῶκεν ἑταίροισιν κατάγειν κοίλας ἐπὶ νῆας.{l]
[l [n}5.27{]}Τρῶες δὲ μεγάθυμοι ἐπεὶ ἴδον υἷε Δάρητος{l]
[l [n}5.28{]}τὸν μὲν ἀλευάμενον, τὸν δὲ κτάμενον παρʼ ὄχεσφι,{l]
[l [n}5.29{]}πᾶσιν ὀρίνθη θυμός· ἀτὰρ γλαυκῶπις Ἀθήνη{l]
[l [n}5.30{]}χειρὸς ἑλοῦσʼ ἐπέεσσι προσηύδα θοῦρον Ἄρηα·{l]
[q}[l [n}5.31{]}Ἆρες Ἄρες βροτολοιγὲ μιαιφόνε τειχεσιπλῆτα{l]
[l [n}5.32{]}οὐκ ἂν δὴ Τρῶας μὲν ἐάσαιμεν καὶ Ἀχαιοὺς{l]
[l [n}5.33{]}μάρνασθʼ, ὁπποτέροισι πατὴρ Ζεὺς κῦδος ὀρέξῃ,{l]
[l [n}5.34{]}νῶϊ δὲ χαζώμεσθα, Διὸς δʼ ἀλεώμεθα μῆνιν;{l]{q]{para]
[para}[l [n}5.35{]}ὣς εἰποῦσα μάχης ἐξήγαγε θοῦρον Ἄρηα·{l]
[l [n}5.36{]}τὸν μὲν ἔπειτα καθεῖσεν ἐπʼ ἠϊόεντι Σκαμάνδρῳ,{l]
[l [n}5.37{]}Τρῶας δʼ ἔκλιναν Δαναοί· ἕλε δʼ ἄνδρα ἕκαστος{l]
[l [n}5.38{]}ἡγεμόνων· πρῶτος δὲ ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}5.39{]}ἀρχὸν Ἁλιζώνων Ὀδίον μέγαν ἔκβαλε δίφρου·{l]
[l [n}5.40{]}πρώτῳ γὰρ στρεφθέντι μεταφρένῳ ἐν δόρυ πῆξεν{l]
[l [n}5.41{]}ὤμων μεσσηγύς, διὰ δὲ στήθεσφιν ἔλασσε,{l]
[l [n}5.42{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]{para]
[para}[l [n}5.43{]}Ἰδομενεὺς δʼ ἄρα Φαῖστον ἐνήρατο Μῄονος υἱὸν{l]
[l [n}5.44{]}Βώρου, ὃς ἐκ Τάρνης ἐριβώλακος εἰληλούθει.{l]
[l [n}5.45{]}τὸν μὲν ἄρʼ Ἰδομενεὺς δουρικλυτὸς ἔγχεϊ μακρῷ{l]
[l [n}5.46{]}νύξʼ ἵππων ἐπιβησόμενον κατὰ δεξιὸν ὦμον·{l]
[l [n}5.47{]}ἤριπε δʼ ἐξ ὀχέων, στυγερὸς δʼ ἄρα μιν σκότος εἷλε.{l]{para]
[para}[l [n}5.48{]}τὸν μὲν ἄρʼ Ἰδομενῆος ἐσύλευον θεράποντες·{l]
[l [n}5.49{]}υἱὸν δὲ Στροφίοιο Σκαμάνδριον αἵμονα θήρης{l]
[l [n}5.50{]}Ἀτρεΐδης Μενέλαος ἕλʼ ἔγχεϊ ὀξυόεντι{l]
[l [n}5.51{]}ἐσθλὸν θηρητῆρα· δίδαξε γὰρ Ἄρτεμις αὐτὴ{l]
[l [n}5.52{]}βάλλειν ἄγρια πάντα, τά τε τρέφει οὔρεσιν ὕλη·{l]
[l [n}5.53{]}ἀλλʼ οὔ οἱ τότε γε χραῖσμʼ Ἄρτεμις ἰοχέαιρα,{l]
[l [n}5.54{]}οὐδὲ ἑκηβολίαι ᾗσιν τὸ πρίν γε κέκαστο·{l]
[l [n}5.55{]}ἀλλά μιν Ἀτρεΐδης δουρικλειτὸς Μενέλαος{l]
[l [n}5.56{]}πρόσθεν ἕθεν φεύγοντα μετάφρενον οὔτασε δουρὶ{l]
[l [n}5.57{]}ὤμων μεσσηγύς, διὰ δὲ στήθεσφιν ἔλασσεν,{l]
[l [n}5.58{]}ἤριπε δὲ πρηνής, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]{para]
[para}[l [n}5.59{]}Μηριόνης δὲ Φέρεκλον ἐνήρατο, τέκτονος υἱὸν{l]
[l [n}5.60{]}Ἁρμονίδεω, ὃς χερσὶν ἐπίστατο δαίδαλα πάντα{l]
[l [n}5.61{]}τεύχειν· ἔξοχα γάρ μιν ἐφίλατο Παλλὰς Ἀθήνη·{l]
[l [n}5.62{]}ὃς καὶ Ἀλεξάνδρῳ τεκτήνατο νῆας ἐΐσας{l]
[l [n}5.63{]}ἀρχεκάκους, αἳ πᾶσι κακὸν Τρώεσσι γένοντο{l]
[l [n}5.64{]}οἷ τʼ αὐτῷ, ἐπεὶ οὔ τι θεῶν ἐκ θέσφατα ᾔδη.{l]
[l [n}5.65{]}τὸν μὲν Μηριόνης ὅτε δὴ κατέμαρπτε διώκων{l]
[l [n}5.66{]}βεβλήκει γλουτὸν κατὰ δεξιόν· ἣ δὲ διαπρὸ{l]
[l [n}5.67{]}ἀντικρὺ κατὰ κύστιν ὑπʼ ὀστέον ἤλυθʼ ἀκωκή·{l]
[l [n}5.68{]}γνὺξ δʼ ἔριπʼ οἰμώξας, θάνατος δέ μιν ἀμφεκάλυψε.{l]{para]
[para}[l [n}5.69{]}Πήδαιον δʼ ἄρʼ ἔπεφνε Μέγης Ἀντήνορος υἱὸν{l]
[l [n}5.70{]}ὅς ῥα νόθος μὲν ἔην, πύκα δʼ ἔτρεφε δῖα Θεανὼ{l]
[l [n}5.71{]}ἶσα φίλοισι τέκεσσι χαριζομένη πόσεϊ ᾧ.{l]
[l [n}5.72{]}τὸν μὲν Φυλεΐδης δουρὶ κλυτὸς ἐγγύθεν ἐλθὼν{l]
[l [n}5.73{]}βεβλήκει κεφαλῆς κατὰ ἰνίον ὀξέϊ δουρί·{l]
[l [n}5.74{]}ἀντικρὺ δʼ ἀνʼ ὀδόντας ὑπὸ γλῶσσαν τάμε χαλκός·{l]
[l [n}5.75{]}ἤριπε δʼ ἐν κονίῃ, ψυχρὸν δʼ ἕλε χαλκὸν ὀδοῦσιν.{l]{para]
[para}[l [n}5.76{]}Εὐρύπυλος δʼ Εὐαιμονίδης Ὑψήνορα δῖον{l]
[l [n}5.77{]}υἱὸν ὑπερθύμου Δολοπίονος, ὅς ῥα Σκαμάνδρου{l]
[l [n}5.78{]}ἀρητὴρ ἐτέτυκτο, θεὸς δʼ ὣς τίετο δήμῳ,{l]
[l [n}5.79{]}τὸν μὲν ἄρʼ Εὐρύπυλος, Εὐαίμονος ἀγλαὸς υἱός,{l]
[l [n}5.80{]}πρόσθεν ἕθεν φεύγοντα μεταδρομάδην ἔλασʼ ὦμον{l]
[l [n}5.81{]}φασγάνῳ ἀΐξας, ἀπὸ δʼ ἔξεσε χεῖρα βαρεῖαν·{l]
[l [n}5.82{]}αἱματόεσσα δὲ χεὶρ πεδίῳ πέσε· τὸν δὲ κατʼ ὄσσε{l]
[l [n}5.83{]}ἔλλαβε πορφύρεος θάνατος καὶ μοῖρα κραταιή.{l]{para]
[para}[l [n}5.84{]}ὣς οἳ μὲν πονέοντο κατὰ κρατερὴν ὑσμίνην·{l]
[l [n}5.85{]}Τυδεΐδην δʼ οὐκ ἂν γνοίης ποτέροισι μετείη{l]
[l [n}5.86{]}ἠὲ μετὰ Τρώεσσιν ὁμιλέοι ἦ μετʼ Ἀχαιοῖς.{l]
[l [n}5.87{]}θῦνε γὰρ ἂμ πεδίον ποταμῷ πλήθοντι ἐοικὼς{l]
[l [n}5.88{]}χειμάρρῳ, ὅς τʼ ὦκα ῥέων ἐκέδασσε γεφύρας·{l]
[l [n}5.89{]}τὸν δʼ οὔτʼ ἄρ τε γέφυραι ἐεργμέναι ἰσχανόωσιν,{l]
[l [n}5.90{]}οὔτʼ ἄρα ἕρκεα ἴσχει ἀλωάων ἐριθηλέων{l]
[l [n}5.91{]}ἐλθόντʼ ἐξαπίνης ὅτʼ ἐπιβρίσῃ Διὸς ὄμβρος·{l]
[l [n}5.92{]}πολλὰ δʼ ὑπʼ αὐτοῦ ἔργα κατήριπε κάλʼ αἰζηῶν·{l]
[l [n}5.93{]}ὣς ὑπὸ Τυδεΐδῃ πυκιναὶ κλονέοντο φάλαγγες{l]
[l [n}5.94{]}Τρώων, οὐδʼ ἄρα μιν μίμνον πολέες περ ἐόντες.{l]{para]
[para}[l [n}5.95{]}τὸν δʼ ὡς οὖν ἐνόησε Λυκάονος ἀγλαὸς υἱὸς{l]
[l [n}5.96{]}θύνοντʼ ἂμ πεδίον πρὸ ἕθεν κλονέοντα φάλαγγας,{l]
[l [n}5.97{]}αἶψʼ ἐπὶ Τυδεΐδῃ ἐτιταίνετο καμπύλα τόξα,{l]
[l [n}5.98{]}καὶ βάλʼ ἐπαΐσσοντα τυχὼν κατὰ δεξιὸν ὦμον{l]
[l [n}5.99{]}θώρηκος γύαλον· διὰ δʼ ἔπτατο πικρὸς ὀϊστός,{l]
[l [n}5.100{]}ἀντικρὺ δὲ διέσχε, παλάσσετο δʼ αἵματι θώρηξ.{l]
[l [n}5.101{]}τῷ δʼ ἐπὶ μακρὸν ἄϋσε Λυκάονος ἀγλαὸς υἱός·{l]
[q}[l [n}5.102{]}ὄρνυσθε Τρῶες μεγάθυμοι κέντορες ἵππων·{l]
[l [n}5.103{]}βέβληται γὰρ ἄριστος Ἀχαιῶν, οὐδέ ἕ φημι{l]
[l [n}5.104{]}δήθʼ ἀνσχήσεσθαι κρατερὸν βέλος, εἰ ἐτεόν με{l]
[l [n}5.105{]}ὦρσεν ἄναξ Διὸς υἱὸς ἀπορνύμενον Λυκίηθεν.{l]{q]{para]
[para}[l [n}5.106{]}ὣς ἔφατʼ εὐχόμενος· τὸν δʼ οὐ βέλος ὠκὺ δάμασσεν,{l]
[l [n}5.107{]}ἀλλʼ ἀναχωρήσας πρόσθʼ ἵπποιιν καὶ ὄχεσφιν{l]
[l [n}5.108{]}ἔστη, καὶ Σθένελον προσέφη Καπανήϊον υἱόν·{l]
[q}[l [n}5.109{]}ὄρσο πέπον Καπανηϊάδη, καταβήσεο δίφρου,{l]
[l [n}5.110{]}ὄφρά μοι ἐξ ὤμοιο ἐρύσσῃς πικρὸν ὀϊστόν.{l]{q]{para]
[para}[l [n}5.111{]}ὣς ἄρʼ ἔφη, Σθένελος δὲ καθʼ ἵππων ἆλτο χαμᾶζε,{l]
[l [n}5.112{]}πὰρ δὲ στὰς βέλος ὠκὺ διαμπερὲς ἐξέρυσʼ ὤμου·{l]
[l [n}5.113{]}αἷμα δʼ ἀνηκόντιζε διὰ στρεπτοῖο χιτῶνος.{l]
[l [n}5.114{]}δὴ τότʼ ἔπειτʼ ἠρᾶτο βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}5.115{]}κλῦθί μευ αἰγιόχοιο Διὸς τέκος Ἀτρυτώνη,{l]
[l [n}5.116{]}εἴ ποτέ μοι καὶ πατρὶ φίλα φρονέουσα παρέστης{l]
[l [n}5.117{]}δηΐῳ ἐν πολέμῳ, νῦν αὖτʼ ἐμὲ φῖλαι Ἀθήνη·{l]
[l [n}5.118{]}δὸς δέ τέ μʼ ἄνδρα ἑλεῖν καὶ ἐς ὁρμὴν ἔγχεος ἐλθεῖν{l]
[l [n}5.119{]}ὅς μʼ ἔβαλε φθάμενος καὶ ἐπεύχεται, οὐδέ μέ φησι{l]
[l [n}5.120{]}δηρὸν ἔτʼ ὄψεσθαι λαμπρὸν φάος ἠελίοιο.{l]{q]{para]
[para}[l [n}5.121{]}ὣς ἔφατʼ εὐχόμενος· τοῦ δʼ ἔκλυε Παλλὰς Ἀθήνη,{l]
[l [n}5.122{]}γυῖα δʼ ἔθηκεν ἐλαφρά, πόδας καὶ χεῖρας ὕπερθεν·{l]
[l [n}5.123{]}ἀγχοῦ δʼ ἱσταμένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}5.124{]}θαρσῶν νῦν Διόμηδες ἐπὶ Τρώεσσι μάχεσθαι·{l]
[l [n}5.125{]}ἐν γάρ τοι στήθεσσι μένος πατρώϊον ἧκα{l]
[l [n}5.126{]}ἄτρομον, οἷον ἔχεσκε σακέσπαλος ἱππότα Τυδεύς·{l]
[l [n}5.127{]}ἀχλὺν δʼ αὖ τοι ἀπʼ ὀφθαλμῶν ἕλον ἣ πρὶν ἐπῆεν,{l]
[l [n}5.128{]}ὄφρʼ εὖ γιγνώσκῃς ἠμὲν θεὸν ἠδὲ καὶ ἄνδρα.{l]
[l [n}5.129{]}τὼ νῦν αἴ κε θεὸς πειρώμενος ἐνθάδʼ ἵκηται{l]
[l [n}5.130{]}μή τι σύ γʼ ἀθανάτοισι θεοῖς ἀντικρὺ μάχεσθαι{l]
[l [n}5.131{]}τοῖς ἄλλοις· ἀτὰρ εἴ κε Διὸς θυγάτηρ Ἀφροδίτη{l]
[l [n}5.132{]}ἔλθῃσʼ ἐς πόλεμον, τήν γʼ οὐτάμεν ὀξέϊ χαλκῷ.{l]{q]{para]
[para}[l [n}5.133{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπέβη γλαυκῶπις Ἀθήνη,{l]
[l [n}5.134{]}Τυδεΐδης δʼ ἐξαῦτις ἰὼν προμάχοισιν ἐμίχθη{l]
[l [n}5.135{]}καὶ πρίν περ θυμῷ μεμαὼς Τρώεσσι μάχεσθαι·{l]
[l [n}5.136{]}δὴ τότε μιν τρὶς τόσσον ἕλεν μένος ὥς τε λέοντα{l]
[l [n}5.137{]}ὅν ῥά τε ποιμὴν ἀγρῷ ἐπʼ εἰροπόκοις ὀΐεσσι{l]
[l [n}5.138{]}χραύσῃ μέν τʼ αὐλῆς ὑπεράλμενον οὐδὲ δαμάσσῃ·{l]
[l [n}5.139{]}τοῦ μέν τε σθένος ὦρσεν, ἔπειτα δέ τʼ οὐ προσαμύνει,{l]
[l [n}5.140{]}ἀλλὰ κατὰ σταθμοὺς δύεται, τὰ δʼ ἐρῆμα φοβεῖται·{l]
[l [n}5.141{]}αἳ μέν τʼ ἀγχιστῖναι ἐπʼ ἀλλήλῃσι κέχυνται,{l]
[l [n}5.142{]}αὐτὰρ ὃ ἐμμεμαὼς βαθέης ἐξάλλεται αὐλῆς·{l]
[l [n}5.143{]}ὣς μεμαὼς Τρώεσσι μίγη κρατερὸς Διομήδης.{l]{para]
[para}[l [n}5.144{]}ἔνθʼ ἕλεν Ἀστύνοον καὶ Ὑπείρονα ποιμένα λαῶν,{l]
[l [n}5.145{]}τὸν μὲν ὑπὲρ μαζοῖο βαλὼν χαλκήρεϊ δουρί,{l]
[l [n}5.146{]}τὸν δʼ ἕτερον ξίφεϊ μεγάλῳ κληῗδα παρʼ ὦμον{l]
[l [n}5.147{]}πλῆξʼ, ἀπὸ δʼ αὐχένος ὦμον ἐέργαθεν ἠδʼ ἀπὸ νώτου.{l]
[l [n}5.148{]}τοὺς μὲν ἔασʼ, ὃ δʼ Ἄβαντα μετῴχετο καὶ Πολύειδον{l]
[l [n}5.149{]}υἱέας Εὐρυδάμαντος ὀνειροπόλοιο γέροντος·{l]
[l [n}5.150{]}τοῖς οὐκ ἐρχομένοις ὃ γέρων ἐκρίνατʼ ὀνείρους,{l]
[l [n}5.151{]}ἀλλά σφεας κρατερὸς Διομήδης ἐξενάριξε·{l]
[l [n}5.152{]}βῆ δὲ μετὰ Ξάνθόν τε Θόωνά τε Φαίνοπος υἷε{l]
[l [n}5.153{]}ἄμφω τηλυγέτω· ὃ δὲ τείρετο γήραϊ λυγρῷ,{l]
[l [n}5.154{]}υἱὸν δʼ οὐ τέκετʼ ἄλλον ἐπὶ κτεάτεσσι λιπέσθαι.{l]
[l [n}5.155{]}ἔνθʼ ὅ γε τοὺς ἐνάριζε, φίλον δʼ ἐξαίνυτο θυμὸν{l]
[l [n}5.156{]}ἀμφοτέρω, πατέρι δὲ γόον καὶ κήδεα λυγρὰ{l]
[l [n}5.157{]}λεῖπʼ, ἐπεὶ οὐ ζώοντε μάχης ἐκνοστήσαντε{l]
[l [n}5.158{]}δέξατο· χηρωσταὶ δὲ διὰ κτῆσιν δατέοντο.{l]{para]
[para}[l [n}5.159{]}ἔνθʼ υἷας Πριάμοιο δύω λάβε Δαρδανίδαο{l]
[l [n}5.160{]}εἰν ἑνὶ δίφρῳ ἐόντας Ἐχέμμονά τε Χρομίον τε.{l]
[l [n}5.161{]}ὡς δὲ λέων ἐν βουσὶ θορὼν ἐξ αὐχένα ἄξῃ{l]
[l [n}5.162{]}πόρτιος ἠὲ βοὸς ξύλοχον κάτα βοσκομενάων,{l]
[l [n}5.163{]}ὣς τοὺς ἀμφοτέρους ἐξ ἵππων Τυδέος υἱὸς{l]
[l [n}5.164{]}βῆσε κακῶς ἀέκοντας, ἔπειτα δὲ τεύχεʼ ἐσύλα·{l]
[l [n}5.165{]}ἵππους δʼ οἷς ἑτάροισι δίδου μετὰ νῆας ἐλαύνειν.{l]{para]
[para}[l [n}5.166{]}τὸν δʼ ἴδεν Αἰνείας ἀλαπάζοντα στίχας ἀνδρῶν,{l]
[l [n}5.167{]}βῆ δʼ ἴμεν ἄν τε μάχην καὶ ἀνὰ κλόνον ἐγχειάων{l]
[l [n}5.168{]}Πάνδαρον ἀντίθεον διζήμενος εἴ που ἐφεύροι·{l]
[l [n}5.169{]}εὗρε Λυκάονος υἱὸν ἀμύμονά τε κρατερόν τε,{l]
[l [n}5.170{]}στῆ δὲ πρόσθʼ αὐτοῖο ἔπος τέ μιν ἀντίον ηὔδα·{l]
[q}[l [n}5.171{]}Πάνδαρε ποῦ τοι τόξον ἰδὲ πτερόεντες ὀϊστοὶ{l]
[l [n}5.172{]}καὶ κλέος; ᾧ οὔ τίς τοι ἐρίζεται ἐνθάδε γʼ ἀνήρ,{l]
[l [n}5.173{]}οὐδέ τις ἐν Λυκίῃ σέο γʼ εὔχεται εἶναι ἀμείνων.{l]
[l [n}5.174{]}ἀλλʼ ἄγε τῷδʼ ἔφες ἀνδρὶ βέλος Διὶ χεῖρας ἀνασχὼν{l]
[l [n}5.175{]}ὅς τις ὅδε κρατέει καὶ δὴ κακὰ πολλὰ ἔοργε{l]
[l [n}5.176{]}Τρῶας, ἐπεὶ πολλῶν τε καὶ ἐσθλῶν γούνατʼ ἔλυσεν·{l]
[l [n}5.177{]}εἰ μή τις θεός ἐστι κοτεσσάμενος Τρώεσσιν{l]
[l [n}5.178{]}ἱρῶν μηνίσας· χαλεπὴ δὲ θεοῦ ἔπι μῆνις.{l]{q]{para]
[para}[l [n}5.179{]}τὸν δʼ αὖτε προσέειπε Λυκάονος ἀγλαὸς υἱός·{l]
[q}[l [n}5.180{]}Αἰνεία Τρώων βουληφόρε χαλκοχιτώνων{l]
[l [n}5.181{]}Τυδεΐδῃ μιν ἔγωγε δαΐφρονι πάντα ἐΐσκω,{l]
[l [n}5.182{]}ἀσπίδι γιγνώσκων αὐλώπιδί τε τρυφαλείῃ,{l]
[l [n}5.183{]}ἵππους τʼ εἰσορόων· σάφα δʼ οὐκ οἶδʼ εἰ θεός ἐστιν.{l]
[l [n}5.184{]}εἰ δʼ ὅ γʼ ἀνὴρ ὅν φημι δαΐφρων Τυδέος υἱὸς{l]
[l [n}5.185{]}οὐχ ὅ γʼ ἄνευθε θεοῦ τάδε μαίνεται, ἀλλά τις ἄγχι{l]
[l [n}5.186{]}ἕστηκʼ ἀθανάτων νεφέλῃ εἰλυμένος ὤμους,{l]
[l [n}5.187{]}ὃς τούτου βέλος ὠκὺ κιχήμενον ἔτραπεν ἄλλῃ.{l]
[l [n}5.188{]}ἤδη γάρ οἱ ἐφῆκα βέλος, καί μιν βάλον ὦμον{l]
[l [n}5.189{]}δεξιὸν ἀντικρὺ διὰ θώρηκος γυάλοιο·{l]
[l [n}5.190{]}καί μιν ἔγωγʼ ἐφάμην Ἀϊδωνῆϊ προϊάψειν,{l]
[l [n}5.191{]}ἔμπης δʼ οὐκ ἐδάμασσα· θεός νύ τίς ἐστι κοτήεις.{l]
[l [n}5.192{]}ἵπποι δʼ οὐ παρέασι καὶ ἅρματα τῶν κʼ ἐπιβαίην·{l]
[l [n}5.193{]}ἀλλά που ἐν μεγάροισι Λυκάονος ἕνδεκα δίφροι{l]
[l [n}5.194{]}καλοὶ πρωτοπαγεῖς νεοτευχέες· ἀμφὶ δὲ πέπλοι{l]
[l [n}5.195{]}πέπτανται· παρὰ δέ σφιν ἑκάστῳ δίζυγες ἵπποι{l]
[l [n}5.196{]}ἑστᾶσι κρῖ λευκὸν ἐρεπτόμενοι καὶ ὀλύρας.{l]
[l [n}5.197{]}ἦ μέν μοι μάλα πολλὰ γέρων αἰχμητὰ Λυκάων{l]
[l [n}5.198{]}ἐρχομένῳ ἐπέτελλε δόμοις ἔνι ποιητοῖσιν·{l]
[l [n}5.199{]}ἵπποισίν μʼ ἐκέλευε καὶ ἅρμασιν ἐμβεβαῶτα{l]
[l [n}5.200{]}ἀρχεύειν Τρώεσσι κατὰ κρατερὰς ὑσμίνας·{l]
[l [n}5.201{]}ἀλλʼ ἐγὼ οὐ πιθόμην· ἦ τʼ ἂν πολὺ κέρδιον ἦεν·{l]
[l [n}5.202{]}ἵππων φειδόμενος, μή μοι δευοίατο φορβῆς{l]
[l [n}5.203{]}ἀνδρῶν εἰλομένων εἰωθότες ἔδμεναι ἄδην.{l]
[l [n}5.204{]}ὣς λίπον, αὐτὰρ πεζὸς ἐς Ἴλιον εἰλήλουθα{l]
[l [n}5.205{]}τόξοισιν πίσυνος· τὰ δέ μʼ οὐκ ἄρʼ ἔμελλον ὀνήσειν.{l]
[l [n}5.206{]}ἤδη γὰρ δοιοῖσιν ἀριστήεσσιν ἐφῆκα{l]
[l [n}5.207{]}Τυδεΐδῃ τε καὶ Ἀτρεΐδῃ, ἐκ δʼ ἀμφοτέροιιν{l]
[l [n}5.208{]}ἀτρεκὲς αἷμʼ ἔσσευα βαλών, ἤγειρα δὲ μᾶλλον.{l]
[l [n}5.209{]}τώ ῥα κακῇ αἴσῃ ἀπὸ πασσάλου ἀγκύλα τόξα{l]
[l [n}5.210{]}ἤματι τῷ ἑλόμην ὅτε Ἴλιον εἰς ἐρατεινὴν{l]
[l [n}5.211{]}ἡγεόμην Τρώεσσι φέρων χάριν Ἕκτορι δίῳ.{l]
[l [n}5.212{]}εἰ δέ κε νοστήσω καὶ ἐσόψομαι ὀφθαλμοῖσι{l]
[l [n}5.213{]}πατρίδʼ ἐμὴν ἄλοχόν τε καὶ ὑψερεφὲς μέγα δῶμα,{l]
[l [n}5.214{]}αὐτίκʼ ἔπειτʼ ἀπʼ ἐμεῖο κάρη τάμοι ἀλλότριος φὼς{l]
[l [n}5.215{]}εἰ μὴ ἐγὼ τάδε τόξα φαεινῷ ἐν πυρὶ θείην{l]
[l [n}5.216{]}χερσὶ διακλάσσας· ἀνεμώλια γάρ μοι ὀπηδεῖ.{l]{q]{para]
[para}[l [n}5.217{]}τὸν δʼ αὖτʼ Αἰνείας Τρώων ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}5.218{]}μὴ δʼ οὕτως ἀγόρευε· πάρος δʼ οὐκ ἔσσεται ἄλλως,{l]
[l [n}5.219{]}πρίν γʼ ἐπὶ νὼ τῷδʼ ἀνδρὶ σὺν ἵπποισιν καὶ ὄχεσφιν{l]
[l [n}5.220{]}ἀντιβίην ἐλθόντε σὺν ἔντεσι πειρηθῆναι.{l]
[l [n}5.221{]}ἀλλʼ ἄγʼ ἐμῶν ὀχέων ἐπιβήσεο, ὄφρα ἴδηαι{l]
[l [n}5.222{]}οἷοι Τρώϊοι ἵπποι ἐπιστάμενοι πεδίοιο{l]
[l [n}5.223{]}κραιπνὰ μάλʼ ἔνθα καὶ ἔνθα διωκέμεν ἠδὲ φέβεσθαι·{l]
[l [n}5.224{]}τὼ καὶ νῶϊ πόλιν δὲ σαώσετον, εἴ περ ἂν αὖτε{l]
[l [n}5.225{]}Ζεὺς ἐπὶ Τυδεΐδῃ Διομήδεϊ κῦδος ὀρέξῃ.{l]
[l [n}5.226{]}ἀλλʼ ἄγε νῦν μάστιγα καὶ ἡνία σιγαλόεντα{l]
[l [n}5.227{]}δέξαι, ἐγὼ δʼ ἵππων ἀποβήσομαι ὄφρα μάχωμαι·{l]
[l [n}5.228{]}ἠὲ σὺ τόνδε δέδεξο, μελήσουσιν δʼ ἐμοὶ ἵπποι.{l]{q]{para]
[para}[l [n}5.229{]}τὸν δʼ αὖτε προσέειπε Λυκάονος ἀγλαὸς υἱός·{l]
[q}[l [n}5.230{]}Αἰνεία σὺ μὲν αὐτὸς ἔχʼ ἡνία καὶ τεὼ ἵππω·{l]
[l [n}5.231{]}μᾶλλον ὑφʼ ἡνιόχῳ εἰωθότι καμπύλον ἅρμα{l]
[l [n}5.232{]}οἴσετον, εἴ περ ἂν αὖτε φεβώμεθα Τυδέος υἱόν·{l]
[l [n}5.233{]}μὴ τὼ μὲν δείσαντε ματήσετον, οὐδʼ ἐθέλητον{l]
[l [n}5.234{]}ἐκφερέμεν πολέμοιο τεὸν φθόγγον ποθέοντε,{l]
[l [n}5.235{]}νῶϊ δʼ ἐπαΐξας μεγαθύμου Τυδέος υἱὸς{l]
[l [n}5.236{]}αὐτώ τε κτείνῃ καὶ ἐλάσσῃ μώνυχας ἵππους.{l]
[l [n}5.237{]}ἀλλὰ σύ γʼ αὐτὸς ἔλαυνε τέʼ ἅρματα καὶ τεὼ ἵππω,{l]
[l [n}5.238{]}τὸν δὲ δʼ ἐγὼν ἐπιόντα δεδέξομαι ὀξέϊ δουρί.{l]{q]{para]
[para}[l [n}5.239{]}ὣς ἄρα φωνήσαντες ἐς ἅρματα ποικίλα βάντες{l]
[l [n}5.240{]}ἐμμεμαῶτʼ ἐπὶ Τυδεΐδῃ ἔχον ὠκέας ἵππους.{l]
[l [n}5.241{]}τοὺς δὲ ἴδε Σθένελος Καπανήϊος ἀγλαὸς υἱός,{l]
[l [n}5.242{]}αἶψα δὲ Τυδεΐδην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}5.243{]}Τυδεΐδη Διόμηδες ἐμῷ κεχαρισμένε θυμῷ,{l]
[l [n}5.244{]}ἄνδρʼ ὁρόω κρατερὼ ἐπὶ σοὶ μεμαῶτε μάχεσθαι{l]
[l [n}5.245{]}ἶνʼ ἀπέλεθρον ἔχοντας· ὃ μὲν τόξων ἐῢ εἰδὼς{l]
[l [n}5.246{]}Πάνδαρος, υἱὸς δʼ αὖτε Λυκάονος εὔχεται εἶναι·{l]
[l [n}5.247{]}Αἰνείας δʼ υἱὸς μὲν ἀμύμονος Ἀγχίσαο{l]
[l [n}5.248{]}εὔχεται ἐκγεγάμεν, μήτηρ δέ οἵ ἐστʼ Ἀφροδίτη.{l]
[l [n}5.249{]}ἀλλʼ ἄγε δὴ χαζώμεθʼ ἐφʼ ἵππων, μηδέ μοι οὕτω{l]
[l [n}5.250{]}θῦνε διὰ προμάχων, μή πως φίλον ἦτορ ὀλέσσῃς.{l]{q]{para]
[para}[l [n}5.251{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}5.252{]}μή τι φόβον δʼ ἀγόρευʼ, ἐπεὶ οὐδὲ σὲ πεισέμεν οἴω.{l]
[l [n}5.253{]}οὐ γάρ μοι γενναῖον ἀλυσκάζοντι μάχεσθαι{l]
[l [n}5.254{]}οὐδὲ καταπτώσσειν· ἔτι μοι μένος ἔμπεδόν ἐστιν·{l]
[l [n}5.255{]}ὀκνείω δʼ ἵππων ἐπιβαινέμεν, ἀλλὰ καὶ αὔτως{l]
[l [n}5.256{]}ἀντίον εἶμʼ αὐτῶν· τρεῖν μʼ οὐκ ἐᾷ Παλλὰς Ἀθήνη.{l]
[l [n}5.257{]}τούτω δʼ οὐ πάλιν αὖτις ἀποίσετον ὠκέες ἵπποι{l]
[l [n}5.258{]}ἄμφω ἀφʼ ἡμείων, εἴ γʼ οὖν ἕτερός γε φύγῃσιν.{l]
[l [n}5.259{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσιν·{l]
[l [n}5.260{]}αἴ κέν μοι πολύβουλος Ἀθήνη κῦδος ὀρέξῃ{l]
[l [n}5.261{]}ἀμφοτέρω κτεῖναι, σὺ δὲ τούσδε μὲν ὠκέας ἵππους{l]
[l [n}5.262{]}αὐτοῦ ἐρυκακέειν ἐξ ἄντυγος ἡνία τείνας,{l]
[l [n}5.263{]}Αἰνείαο δʼ ἐπαΐξαι μεμνημένος ἵππων,{l]
[l [n}5.264{]}ἐκ δʼ ἐλάσαι Τρώων μετʼ ἐϋκνήμιδας Ἀχαιούς.{l]
[l [n}5.265{]}τῆς γάρ τοι γενεῆς ἧς Τρωΐ περ εὐρύοπα Ζεὺς{l]
[l [n}5.266{]}δῶχʼ υἷος ποινὴν Γανυμήδεος, οὕνεκʼ ἄριστοι{l]
[l [n}5.267{]}ἵππων ὅσσοι ἔασιν ὑπʼ ἠῶ τʼ ἠέλιόν τε,{l]
[l [n}5.268{]}τῆς γενεῆς ἔκλεψεν ἄναξ ἀνδρῶν Ἀγχίσης{l]
[l [n}5.269{]}λάθρῃ Λαομέδοντος ὑποσχὼν θήλεας ἵππους·{l]
[l [n}5.270{]}τῶν οἱ ἓξ ἐγένοντο ἐνὶ μεγάροισι γενέθλη.{l]
[l [n}5.271{]}τοὺς μὲν τέσσαρας αὐτὸς ἔχων ἀτίταλλʼ ἐπὶ φάτνῃ,{l]
[l [n}5.272{]}τὼ δὲ δύʼ Αἰνείᾳ δῶκεν μήστωρε φόβοιο.{l]
[l [n}5.273{]}εἰ τούτω κε λάβοιμεν, ἀροίμεθά κε κλέος ἐσθλόν.{l]{q]{para]
[para}[l [n}5.274{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον,{l]
[l [n}5.275{]}τὼ δὲ τάχʼ ἐγγύθεν ἦλθον ἐλαύνοντʼ ὠκέας ἵππους.{l]
[l [n}5.276{]}τὸν πρότερος προσέειπε Λυκάονος ἀγλαὸς υἱός·{l]
[q}[l [n}5.277{]}καρτερόθυμε δαΐφρον ἀγαυοῦ Τυδέος υἱὲ{l]
[l [n}5.278{]}ἦ μάλα σʼ οὐ βέλος ὠκὺ δαμάσσατο πικρὸς ὀϊστός·{l]
[l [n}5.279{]}νῦν αὖτʼ ἐγχείῃ πειρήσομαι αἴ κε τύχωμι.{l]{q]{para]
[para}[l [n}5.280{]}ἦ ῥα καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος{l]
[l [n}5.281{]}καὶ βάλε Τυδεΐδαο κατʼ ἀσπίδα· τῆς δὲ διὰ πρὸ{l]
[l [n}5.282{]}αἰχμὴ χαλκείη πταμένη θώρηκι πελάσθη·{l]
[l [n}5.283{]}τῷ δʼ ἐπὶ μακρὸν ἄϋσε Λυκάονος ἀγλαὸς υἱός·{l]
[q}[l [n}5.284{]}βέβληαι κενεῶνα διαμπερές, οὐδέ σʼ ὀΐω{l]
[l [n}5.285{]}δηρὸν ἔτʼ ἀνσχήσεσθαι· ἐμοὶ δὲ μέγʼ εὖχος ἔδωκας.{l]{q]{para]
[para}[l [n}5.286{]}τὸν δʼ οὐ ταρβήσας προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}5.287{]}ἤμβροτες οὐδʼ ἔτυχες· ἀτὰρ οὐ μὲν σφῶΐ γʼ ὀΐω{l]
[l [n}5.288{]}πρίν γʼ ἀποπαύσεσθαι πρίν γʼ ἢ ἕτερόν γε πεσόντα{l]
[l [n}5.289{]}αἵματος ἆσαι Ἄρηα, ταλαύρινον πολεμιστήν.{l]{q]{para]
[para}[l [n}5.290{]}ὣς φάμενος προέηκε· βέλος δʼ ἴθυνεν Ἀθήνη{l]
[l [n}5.291{]}ῥῖνα παρʼ ὀφθαλμόν, λευκοὺς δʼ ἐπέρησεν ὀδόντας.{l]
[l [n}5.292{]}τοῦ δʼ ἀπὸ μὲν γλῶσσαν πρυμνὴν τάμε χαλκὸς ἀτειρής,{l]
[l [n}5.293{]}αἰχμὴ δʼ ἐξελύθη παρὰ νείατον ἀνθερεῶνα·{l]
[l [n}5.294{]}ἤριπε δʼ ἐξ ὀχέων, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ{l]
[l [n}5.295{]}αἰόλα παμφανόωντα, παρέτρεσσαν δέ οἱ ἵπποι{l]
[l [n}5.296{]}ὠκύποδες· τοῦ δʼ αὖθι λύθη ψυχή τε μένος τε.{l]{para]
[para}[l [n}5.297{]}Αἰνείας δʼ ἀπόρουσε σὺν ἀσπίδι δουρί τε μακρῷ{l]
[l [n}5.298{]}δείσας μή πώς οἱ ἐρυσαίατο νεκρὸν Ἀχαιοί.{l]
[l [n}5.299{]}ἀμφὶ δʼ ἄρʼ αὐτῷ βαῖνε λέων ὣς ἀλκὶ πεποιθώς,{l]
[l [n}5.300{]}πρόσθε δέ οἱ δόρυ τʼ ἔσχε καὶ ἀσπίδα πάντοσʼ ἐΐσην,{l]
[l [n}5.301{]}τὸν κτάμεναι μεμαὼς ὅς τις τοῦ γʼ ἀντίος ἔλθοι{l]
[l [n}5.302{]}σμερδαλέα ἰάχων· ὃ δὲ χερμάδιον λάβε χειρὶ{l]
[l [n}5.303{]}Τυδεΐδης μέγα ἔργον ὃ οὐ δύο γʼ ἄνδρε φέροιεν,{l]
[l [n}5.304{]}οἷοι νῦν βροτοί εἰσʼ· ὃ δέ μιν ῥέα πάλλε καὶ οἶος.{l]
[l [n}5.305{]}τῷ βάλεν Αἰνείαο κατʼ ἰσχίον ἔνθά τε μηρὸς{l]
[l [n}5.306{]}ἰσχίῳ ἐνστρέφεται, κοτύλην δέ τέ μιν καλέουσι·{l]
[l [n}5.307{]}θλάσσε δέ οἱ κοτύλην, πρὸς δʼ ἄμφω ῥῆξε τένοντε·{l]
[l [n}5.308{]}ὦσε δʼ ἀπὸ ῥινὸν τρηχὺς λίθος· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}5.309{]}ἔστη γνὺξ ἐριπὼν καὶ ἐρείσατο χειρὶ παχείῃ{l]
[l [n}5.310{]}γαίης· ἀμφὶ δὲ ὄσσε κελαινὴ νὺξ ἐκάλυψε.{l]{para]
[para}[l [n}5.311{]}καί νύ κεν ἔνθʼ ἀπόλοιτο ἄναξ ἀνδρῶν Αἰνείας,{l]
[l [n}5.312{]}εἰ μὴ ἄρʼ ὀξὺ νόησε Διὸς θυγάτηρ Ἀφροδίτη{l]
[l [n}5.313{]}μήτηρ, ἥ μιν ὑπʼ Ἀγχίσῃ τέκε βουκολέοντι·{l]
[l [n}5.314{]}ἀμφὶ δʼ ἑὸν φίλον υἱὸν ἐχεύατο πήχεε λευκώ,{l]
[l [n}5.315{]}πρόσθε δέ οἱ πέπλοιο φαεινοῦ πτύγμα κάλυψεν{l]
[l [n}5.316{]}ἕρκος ἔμεν βελέων, μή τις Δαναῶν ταχυπώλων{l]
[l [n}5.317{]}χαλκὸν ἐνὶ στήθεσσι βαλὼν ἐκ θυμὸν ἕλοιτο.{l]{para]
[para}[l [n}5.318{]}ἣ μὲν ἑὸν φίλον υἱὸν ὑπεξέφερεν πολέμοιο·{l]
[l [n}5.319{]}οὐδʼ υἱὸς Καπανῆος ἐλήθετο συνθεσιάων{l]
[l [n}5.320{]}τάων ἃς ἐπέτελλε βοὴν ἀγαθὸς Διομήδης,{l]
[l [n}5.321{]}ἀλλʼ ὅ γε τοὺς μὲν ἑοὺς ἠρύκακε μώνυχας ἵππους{l]
[l [n}5.322{]}νόσφιν ἀπὸ φλοίσβου ἐξ ἄντυγος ἡνία τείνας,{l]
[l [n}5.323{]}Αἰνείαο δʼ ἐπαΐξας καλλίτριχας ἵππους{l]
[l [n}5.324{]}ἐξέλασε Τρώων μετʼ ἐϋκνήμιδας Ἀχαιούς.{l]
[l [n}5.325{]}δῶκε δὲ Δηϊπύλῳ ἑτάρῳ φίλῳ, ὃν περὶ πάσης{l]
[l [n}5.326{]}τῖεν ὁμηλικίης ὅτι οἱ φρεσὶν ἄρτια ᾔδη,{l]
[l [n}5.327{]}νηυσὶν ἔπι γλαφυρῇσιν ἐλαυνέμεν· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}5.328{]}ὧν ἵππων ἐπιβὰς ἔλαβʼ ἡνία σιγαλόεντα,{l]
[l [n}5.329{]}αἶψα δὲ Τυδεΐδην μέθεπε κρατερώνυχας ἵππους{l]
[l [n}5.330{]}ἐμμεμαώς· ὃ δὲ Κύπριν ἐπῴχετο νηλέϊ χαλκῷ{l]
[l [n}5.331{]}γιγνώσκων ὅ τʼ ἄναλκις ἔην θεός, οὐδὲ θεάων{l]
[l [n}5.332{]}τάων αἵ τʼ ἀνδρῶν πόλεμον κάτα κοιρανέουσιν,{l]
[l [n}5.333{]}οὔτʼ ἄρʼ Ἀθηναίη οὔτε πτολίπορθος Ἐνυώ.{l]
[l [n}5.334{]}ἀλλʼ ὅτε δή ῥʼ ἐκίχανε πολὺν καθʼ ὅμιλον ὀπάζων,{l]
[l [n}5.335{]}ἔνθʼ ἐπορεξάμενος μεγαθύμου Τυδέος υἱὸς{l]
[l [n}5.336{]}ἄκρην οὔτασε χεῖρα μετάλμενος ὀξέϊ δουρὶ{l]
[l [n}5.337{]}ἀβληχρήν· εἶθαρ δὲ δόρυ χροὸς ἀντετόρησεν{l]
[l [n}5.338{]}ἀμβροσίου διὰ πέπλου, ὅν οἱ Χάριτες κάμον αὐταί,{l]
[l [n}5.339{]}πρυμνὸν ὕπερ θέναρος· ῥέε δʼ ἄμβροτον αἷμα θεοῖο{l]
[l [n}5.340{]}ἰχώρ, οἷός πέρ τε ῥέει μακάρεσσι θεοῖσιν·{l]
[l [n}5.341{]}οὐ γὰρ σῖτον ἔδουσʼ, οὐ πίνουσʼ αἴθοπα οἶνον,{l]
[l [n}5.342{]}τοὔνεκʼ ἀναίμονές εἰσι καὶ ἀθάνατοι καλέονται.{l]
[l [n}5.343{]}ἣ δὲ μέγα ἰάχουσα ἀπὸ ἕο κάββαλεν υἱόν·{l]
[l [n}5.344{]}καὶ τὸν μὲν μετὰ χερσὶν ἐρύσατο Φοῖβος Ἀπόλλων{l]
[l [n}5.345{]}κυανέῃ νεφέλῃ, μή τις Δαναῶν ταχυπώλων{l]
[l [n}5.346{]}χαλκὸν ἐνὶ στήθεσσι βαλὼν ἐκ θυμὸν ἕλοιτο·{l]
[l [n}5.347{]}τῇ δʼ ἐπὶ μακρὸν ἄϋσε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}5.348{]}εἶκε Διὸς θύγατερ πολέμου καὶ δηϊοτῆτος·{l]
[l [n}5.349{]}ἦ οὐχ ἅλις ὅττι γυναῖκας ἀνάλκιδας ἠπεροπεύεις;{l]
[l [n}5.350{]}εἰ δὲ σύ γʼ ἐς πόλεμον πωλήσεαι, ἦ τέ σʼ ὀΐω{l]
[l [n}5.351{]}ῥιγήσειν πόλεμόν γε καὶ εἴ χʼ ἑτέρωθι πύθηαι.{l]{q]{para]
[para}[l [n}5.352{]}ὣς ἔφαθʼ, ἣ δʼ ἀλύουσʼ ἀπεβήσετο, τείρετο δʼ αἰνῶς·{l]
[l [n}5.353{]}τὴν μὲν ἄρʼ Ἶρις ἑλοῦσα ποδήνεμος ἔξαγʼ ὁμίλου{l]
[l [n}5.354{]}ἀχθομένην ὀδύνῃσι, μελαίνετο δὲ χρόα καλόν.{l]
[l [n}5.355{]}εὗρεν ἔπειτα μάχης ἐπʼ ἀριστερὰ θοῦρον Ἄρηα{l]
[l [n}5.356{]}ἥμενον· ἠέρι δʼ ἔγχος ἐκέκλιτο καὶ ταχέʼ ἵππω·{l]
[l [n}5.357{]}ἣ δὲ γνὺξ ἐριποῦσα κασιγνήτοιο φίλοιο{l]
[l [n}5.358{]}πολλὰ λισσομένη χρυσάμπυκας ᾔτεεν ἵππους·{l]
[q}[l [n}5.359{]}φίλε κασίγνητε κόμισαί τέ με δός τέ μοι ἵππους,{l]
[l [n}5.360{]}ὄφρʼ ἐς Ὄλυμπον ἵκωμαι ἵνʼ ἀθανάτων ἕδος ἐστί.{l]
[l [n}5.361{]}λίην ἄχθομαι ἕλκος ὅ με βροτὸς οὔτασεν ἀνὴρ{l]
[l [n}5.362{]}Τυδεΐδης, ὃς νῦν γε καὶ ἂν Διὶ πατρὶ μάχοιτο.{l]{q]{para]
[para}[l [n}5.363{]}ὣς φάτο, τῇ δʼ ἄρʼ Ἄρης δῶκε χρυσάμπυκας ἵππους·{l]
[l [n}5.364{]}ἣ δʼ ἐς δίφρον ἔβαινεν ἀκηχεμένη φίλον ἦτορ,{l]
[l [n}5.365{]}πὰρ δέ οἱ Ἶρις ἔβαινε καὶ ἡνία λάζετο χερσί,{l]
[l [n}5.366{]}μάστιξεν δʼ ἐλάαν, τὼ δʼ οὐκ ἀέκοντε πετέσθην.{l]
[l [n}5.367{]}αἶψα δʼ ἔπειθʼ ἵκοντο θεῶν ἕδος αἰπὺν Ὄλυμπον·{l]
[l [n}5.368{]}ἔνθʼ ἵππους ἔστησε ποδήνεμος ὠκέα Ἶρις{l]
[l [n}5.369{]}λύσασʼ ἐξ ὀχέων, παρὰ δʼ ἀμβρόσιον βάλεν εἶδαρ·{l]
[l [n}5.370{]}ἣ δʼ ἐν γούνασι πῖπτε Διώνης δῖʼ Ἀφροδίτη{l]
[l [n}5.371{]}μητρὸς ἑῆς· ἣ δʼ ἀγκὰς ἐλάζετο θυγατέρα ἥν,{l]
[l [n}5.372{]}χειρί τέ μιν κατέρεξεν ἔπος τʼ ἔφατʼ ἐκ τʼ ὀνόμαζε·{l]
[q}[l [n}5.373{]}τίς νύ σε τοιάδʼ ἔρεξε φίλον τέκος Οὐρανιώνων{l]
[l [n}5.374{]}μαψιδίως, ὡς εἴ τι κακὸν ῥέζουσαν ἐνωπῇ;{l]{q]{para]
[para}[l [n}5.375{]}τὴν δʼ ἠμείβετʼ ἔπειτα φιλομμειδὴς Ἀφροδίτη·{l]
[q}[l [n}5.376{]}οὖτά με Τυδέος υἱὸς ὑπέρθυμος Διομήδης,{l]
[l [n}5.377{]}οὕνεκʼ ἐγὼ φίλον υἱὸν ὑπεξέφερον πολέμοιο{l]
[l [n}5.378{]}Αἰνείαν, ὃς ἐμοὶ πάντων πολὺ φίλτατός ἐστιν.{l]
[l [n}5.379{]}οὐ γὰρ ἔτι Τρώων καὶ Ἀχαιῶν φύλοπις αἰνή,{l]
[l [n}5.380{]}ἀλλʼ ἤδη Δαναοί γε καὶ ἀθανάτοισι μάχονται.{l]{q]{para]
[para}[l [n}5.381{]}τὴν δʼ ἠμείβετʼ ἔπειτα Διώνη, δῖα θεάων·{l]
[q}[l [n}5.382{]}τέτλαθι τέκνον ἐμόν, καὶ ἀνάσχεο κηδομένη περ·{l]
[l [n}5.383{]}πολλοὶ γὰρ δὴ τλῆμεν Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}5.384{]}ἐξ ἀνδρῶν χαλέπʼ ἄλγεʼ ἐπʼ ἀλλήλοισι τιθέντες.{l]
[l [n}5.385{]}τλῆ μὲν Ἄρης ὅτε μιν Ὦτος κρατερός τʼ Ἐφιάλτης{l]
[l [n}5.386{]}παῖδες Ἀλωῆος, δῆσαν κρατερῷ ἐνὶ δεσμῷ·{l]
[l [n}5.387{]}χαλκέῳ δʼ ἐν κεράμῳ δέδετο τρισκαίδεκα μῆνας·{l]
[l [n}5.388{]}καί νύ κεν ἔνθʼ ἀπόλοιτο Ἄρης ἆτος πολέμοιο,{l]
[l [n}5.389{]}εἰ μὴ μητρυιὴ περικαλλὴς Ἠερίβοια{l]
[l [n}5.390{]}Ἑρμέᾳ ἐξήγγειλεν· ὃ δʼ ἐξέκλεψεν Ἄρηα{l]
[l [n}5.391{]}ἤδη τειρόμενον, χαλεπὸς δέ ἑ δεσμὸς ἐδάμνα.{l]
[l [n}5.392{]}τλῆ δʼ Ἥρη, ὅτε μιν κρατερὸς πάϊς Ἀμφιτρύωνος{l]
[l [n}5.393{]}δεξιτερὸν κατὰ μαζὸν ὀϊστῷ τριγλώχινι{l]
[l [n}5.394{]}βεβλήκει· τότε καί μιν ἀνήκεστον λάβεν ἄλγος.{l]
[l [n}5.395{]}τλῆ δʼ Ἀΐδης ἐν τοῖσι πελώριος ὠκὺν ὀϊστόν,{l]
[l [n}5.396{]}εὖτέ μιν ωὐτὸς ἀνὴρ υἱὸς Διὸς αἰγιόχοιο{l]
[l [n}5.397{]}ἐν Πύλῳ ἐν νεκύεσσι βαλὼν ὀδύνῃσιν ἔδωκεν·{l]
[l [n}5.398{]}αὐτὰρ ὃ βῆ πρὸς δῶμα Διὸς καὶ μακρὸν Ὄλυμπον{l]
[l [n}5.399{]}κῆρ ἀχέων ὀδύνῃσι πεπαρμένος· αὐτὰρ ὀϊστὸς{l]
[l [n}5.400{]}ὤμῳ ἔνι στιβαρῷ ἠλήλατο, κῆδε δὲ θυμόν.{l]
[l [n}5.401{]}τῷ δʼ ἐπὶ Παιήων ὀδυνήφατα φάρμακα πάσσων{l]
[l [n}5.402{]}ἠκέσατʼ· οὐ μὲν γάρ τι καταθνητός γε τέτυκτο.{l]
[l [n}5.403{]}σχέτλιος ὀβριμοεργὸς ὃς οὐκ ὄθετʼ αἴσυλα ῥέζων,{l]
[l [n}5.404{]}ὃς τόξοισιν ἔκηδε θεοὺς οἳ Ὄλυμπον ἔχουσι.{l]
[l [n}5.405{]}σοὶ δʼ ἐπὶ τοῦτον ἀνῆκε θεὰ γλαυκῶπις Ἀθήνη·{l]
[l [n}5.406{]}νήπιος, οὐδὲ τὸ οἶδε κατὰ φρένα Τυδέος υἱὸς{l]
[l [n}5.407{]}ὅττι μάλʼ οὐ δηναιὸς ὃς ἀθανάτοισι μάχηται,{l]
[l [n}5.408{]}οὐδέ τί μιν παῖδες ποτὶ γούνασι παππάζουσιν{l]
[l [n}5.409{]}ἐλθόντʼ ἐκ πολέμοιο καὶ αἰνῆς δηϊοτῆτος.{l]
[l [n}5.410{]}τὼ νῦν Τυδεΐδης, εἰ καὶ μάλα καρτερός ἐστι,{l]
[l [n}5.411{]}φραζέσθω μή τίς οἱ ἀμείνων σεῖο μάχηται,{l]
[l [n}5.412{]}μὴ δὴν Αἰγιάλεια περίφρων Ἀδρηστίνη{l]
[l [n}5.413{]}ἐξ ὕπνου γοόωσα φίλους οἰκῆας ἐγείρῃ{l]
[l [n}5.414{]}κουρίδιον ποθέουσα πόσιν τὸν ἄριστον Ἀχαιῶν{l]
[l [n}5.415{]}ἰφθίμη ἄλοχος Διομήδεος ἱπποδάμοιο.{l]{q]{para]
[para}[l [n}5.416{]}ἦ ῥα καὶ ἀμφοτέρῃσιν ἀπʼ ἰχῶ χειρὸς ὀμόργνυ·{l]
[l [n}5.417{]}ἄλθετο χείρ, ὀδύναι δὲ κατηπιόωντο βαρεῖαι.{l]
[l [n}5.418{]}αἳ δʼ αὖτʼ εἰσορόωσαι Ἀθηναίη τε καὶ Ἥρη{l]
[l [n}5.419{]}κερτομίοις ἐπέεσσι Δία Κρονίδην ἐρέθιζον.{l]
[l [n}5.420{]}τοῖσι δὲ μύθων ἦρχε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}5.421{]}Ζεῦ πάτερ ἦ ῥά τί μοι κεχολώσεαι ὅττι κεν εἴπω;{l]
[l [n}5.422{]}ἦ μάλα δή τινα Κύπρις Ἀχαιϊάδων ἀνιεῖσα{l]
[l [n}5.423{]}Τρωσὶν ἅμα σπέσθαι, τοὺς νῦν ἔκπαγλα φίλησε,{l]
[l [n}5.424{]}τῶν τινα καρρέζουσα Ἀχαιϊάδων ἐϋπέπλων{l]
[l [n}5.425{]}πρὸς χρυσῇ περόνῃ καταμύξατο χεῖρα ἀραιήν.{l]{q]{para]
[para}[l [n}5.426{]}ὣς φάτο, μείδησεν δὲ πατὴρ ἀνδρῶν τε θεῶν τε,{l]
[l [n}5.427{]}καί ῥα καλεσσάμενος προσέφη χρυσῆν Ἀφροδίτην·{l]
[q}[l [n}5.428{]}οὔ τοι τέκνον ἐμὸν δέδοται πολεμήϊα ἔργα,{l]
[l [n}5.429{]}ἀλλὰ σύ γʼ ἱμερόεντα μετέρχεο ἔργα γάμοιο,{l]
[l [n}5.430{]}ταῦτα δʼ Ἄρηϊ θοῷ καὶ Ἀθήνῃ πάντα μελήσει.{l]{q]{para]
[para}[l [n}5.431{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον,{l]
[l [n}5.432{]}Αἰνείᾳ δʼ ἐπόρουσε βοὴν ἀγαθὸς Διομήδης,{l]
[l [n}5.433{]}γιγνώσκων ὅ οἱ αὐτὸς ὑπείρεχε χεῖρας Ἀπόλλων·{l]
[l [n}5.434{]}ἀλλʼ ὅ γʼ ἄρʼ οὐδὲ θεὸν μέγαν ἅζετο, ἵετο δʼ αἰεὶ{l]
[l [n}5.435{]}Αἰνείαν κτεῖναι καὶ ἀπὸ κλυτὰ τεύχεα δῦσαι.{l]
[l [n}5.436{]}τρὶς μὲν ἔπειτʼ ἐπόρουσε κατακτάμεναι μενεαίνων,{l]
[l [n}5.437{]}τρὶς δέ οἱ ἐστυφέλιξε φαεινὴν ἀσπίδʼ Ἀπόλλων·{l]
[l [n}5.438{]}ἀλλʼ ὅτε δὴ τὸ τέταρτον ἐπέσσυτο δαίμονι ἶσος,{l]
[l [n}5.439{]}δεινὰ δʼ ὁμοκλήσας προσέφη ἑκάεργος Ἀπόλλων·{l]
[q}[l [n}5.440{]}φράζεο Τυδεΐδη καὶ χάζεο, μηδὲ θεοῖσιν{l]
[l [n}5.441{]}ἶσʼ ἔθελε φρονέειν, ἐπεὶ οὔ ποτε φῦλον ὁμοῖον{l]
[l [n}5.442{]}ἀθανάτων τε θεῶν χαμαὶ ἐρχομένων τʼ ἀνθρώπων.{l]{q]{para]
[para}[l [n}5.443{]}ὣς φάτο, Τυδεΐδης δʼ ἀνεχάζετο τυτθὸν ὀπίσσω{l]
[l [n}5.444{]}μῆνιν ἀλευάμενος ἑκατηβόλου Ἀπόλλωνος.{l]
[l [n}5.445{]}Αἰνείαν δʼ ἀπάτερθεν ὁμίλου θῆκεν Ἀπόλλων{l]
[l [n}5.446{]}Περγάμῳ εἰν ἱερῇ, ὅθι οἱ νηός γε τέτυκτο.{l]
[l [n}5.447{]}ἤτοι τὸν Λητώ τε καὶ Ἄρτεμις ἰοχέαιρα{l]
[l [n}5.448{]}ἐν μεγάλῳ ἀδύτῳ ἀκέοντό τε κύδαινόν τε·{l]
[l [n}5.449{]}αὐτὰρ ὃ εἴδωλον τεῦξʼ ἀργυρότοξος Ἀπόλλων{l]
[l [n}5.450{]}αὐτῷ τʼ Αἰνείᾳ ἴκελον καὶ τεύχεσι τοῖον,{l]
[l [n}5.451{]}ἀμφὶ δʼ ἄρʼ εἰδώλῳ Τρῶες καὶ δῖοι Ἀχαιοὶ{l]
[l [n}5.452{]}δῄουν ἀλλήλων ἀμφὶ στήθεσσι βοείας{l]
[l [n}5.453{]}ἀσπίδας εὐκύκλους λαισήϊά τε πτερόεντα.{l]
[l [n}5.454{]}δὴ τότε θοῦρον Ἄρηα προσηύδα Φοῖβος Ἀπόλλων·{l]
[q}[l [n}5.455{]}Ἆρες Ἄρες βροτολοιγὲ μιαιφόνε τειχεσιπλῆτα,{l]
[l [n}5.456{]}οὐκ ἂν δὴ τόνδʼ ἄνδρα μάχης ἐρύσαιο μετελθὼν{l]
[l [n}5.457{]}Τυδεΐδην, ὃς νῦν γε καὶ ἂν Διὶ πατρὶ μάχοιτο;{l]
[l [n}5.458{]}Κύπριδα μὲν πρῶτα σχεδὸν οὔτασε χεῖρʼ ἐπὶ καρπῷ,{l]
[l [n}5.459{]}αὐτὰρ ἔπειτʼ αὐτῷ μοι ἐπέσσυτο δαίμονι ἶσος.{l]{q]{para]
[para}[l [n}5.460{]}ὣς εἰπὼν αὐτὸς μὲν ἐφέζετο Περγάμῳ ἄκρῃ,{l]
[l [n}5.461{]}Τρῳὰς δὲ στίχας οὖλος Ἄρης ὄτρυνε μετελθὼν{l]
[l [n}5.462{]}εἰδόμενος Ἀκάμαντι θοῷ ἡγήτορι Θρῃκῶν·{l]
[l [n}5.463{]}υἱάσι δὲ Πριάμοιο διοτρεφέεσσι κέλευεν·{l]
[q}[l [n}5.464{]}ὦ υἱεῖς Πριάμοιο διοτρεφέος βασιλῆος{l]
[l [n}5.465{]}ἐς τί ἔτι κτείνεσθαι ἐάσετε λαὸν Ἀχαιοῖς;{l]
[l [n}5.466{]}ἦ εἰς ὅ κεν ἀμφὶ πύλῃς εὖ ποιητῇσι μάχωνται;{l]
[l [n}5.467{]}κεῖται ἀνὴρ ὃν ἶσον ἐτίομεν Ἕκτορι δίῳ{l]
[l [n}5.468{]}Αἰνείας υἱὸς μεγαλήτορος Ἀγχίσαο·{l]
[l [n}5.469{]}ἀλλʼ ἄγετʼ ἐκ φλοίσβοιο σαώσομεν ἐσθλὸν ἑταῖρον.{l]{q]{para]
[para}[l [n}5.470{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}5.471{]}ἔνθʼ αὖ Σαρπηδὼν μάλα νείκεσεν Ἕκτορα δῖον·{l]
[q}[l [n}5.472{]}Ἕκτορ πῇ δή τοι μένος οἴχεται ὃ πρὶν ἔχεσκες;{l]
[l [n}5.473{]}φῆς που ἄτερ λαῶν πόλιν ἑξέμεν ἠδʼ ἐπικούρων{l]
[l [n}5.474{]}οἶος σὺν γαμβροῖσι κασιγνήτοισί τε σοῖσι.{l]
[l [n}5.475{]}τῶν νῦν οὔ τινʼ ἐγὼ ἰδέειν δύναμʼ οὐδὲ νοῆσαι,{l]
[l [n}5.476{]}ἀλλὰ καταπτώσσουσι κύνες ὣς ἀμφὶ λέοντα·{l]
[l [n}5.477{]}ἡμεῖς δὲ μαχόμεσθʼ οἵ πέρ τʼ ἐπίκουροι ἔνειμεν.{l]
[l [n}5.478{]}καὶ γὰρ ἐγὼν ἐπίκουρος ἐὼν μάλα τηλόθεν ἥκω·{l]
[l [n}5.479{]}τηλοῦ γὰρ Λυκίη Ξάνθῳ ἔπι δινήεντι,{l]
[l [n}5.480{]}ἔνθʼ ἄλοχόν τε φίλην ἔλιπον καὶ νήπιον υἱόν,{l]
[l [n}5.481{]}κὰδ δὲ κτήματα πολλά, τὰ ἔλδεται ὅς κʼ ἐπιδευής.{l]
[l [n}5.482{]}ἀλλὰ καὶ ὧς Λυκίους ὀτρύνω καὶ μέμονʼ αὐτὸς{l]
[l [n}5.483{]}ἀνδρὶ μαχήσασθαι· ἀτὰρ οὔ τί μοι ἐνθάδε τοῖον{l]
[l [n}5.484{]}οἷόν κʼ ἠὲ φέροιεν Ἀχαιοὶ ἤ κεν ἄγοιεν·{l]
[l [n}5.485{]}τύνη δʼ ἕστηκας, ἀτὰρ οὐδʼ ἄλλοισι κελεύεις{l]
[l [n}5.486{]}λαοῖσιν μενέμεν καὶ ἀμυνέμεναι ὤρεσσι.{l]
[l [n}5.487{]}μή πως ὡς ἀψῖσι λίνου ἁλόντε πανάγρου{l]
[l [n}5.488{]}ἀνδράσι δυσμενέεσσιν ἕλωρ καὶ κύρμα γένησθε·{l]
[l [n}5.489{]}οἳ δὲ τάχʼ ἐκπέρσουσʼ εὖ ναιομένην πόλιν ὑμήν.{l]
[l [n}5.490{]}σοὶ δὲ χρὴ τάδε πάντα μέλειν νύκτάς τε καὶ ἦμαρ{l]
[l [n}5.491{]}ἀρχοὺς λισσομένῳ τηλεκλειτῶν ἐπικούρων{l]
[l [n}5.492{]}νωλεμέως ἐχέμεν, κρατερὴν δʼ ἀποθέσθαι ἐνιπήν.{l]{q]{para]
[para}[l [n}5.493{]}ὣς φάτο Σαρπηδών, δάκε δὲ φρένας Ἕκτορι μῦθος·{l]
[l [n}5.494{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε,{l]
[l [n}5.495{]}πάλλων δʼ ὀξέα δοῦρα κατὰ στρατὸν ᾤχετο πάντῃ{l]
[l [n}5.496{]}ὀτρύνων μαχέσασθαι, ἔγειρε δὲ φύλοπιν αἰνήν.{l]
[l [n}5.497{]}οἳ δʼ ἐλελίχθησαν καὶ ἐναντίοι ἔσταν Ἀχαιῶν·{l]
[l [n}5.498{]}Ἀργεῖοι δʼ ὑπέμειναν ἀολλέες οὐδὲ φόβηθεν.{l]
[l [n}5.499{]}ὡς δʼ ἄνεμος ἄχνας φορέει ἱερὰς κατʼ ἀλωὰς{l]
[l [n}5.500{]}ἀνδρῶν λικμώντων, ὅτε τε ξανθὴ Δημήτηρ{l]
[l [n}5.501{]}κρίνῃ ἐπειγομένων ἀνέμων καρπόν τε καὶ ἄχνας,{l]
[l [n}5.502{]}αἳ δʼ ὑπολευκαίνονται ἀχυρμιαί· ὣς τότʼ Ἀχαιοὶ{l]
[l [n}5.503{]}λευκοὶ ὕπερθε γένοντο κονισάλῳ, ὅν ῥα διʼ αὐτῶν{l]
[l [n}5.504{]}οὐρανὸν ἐς πολύχαλκον ἐπέπληγον πόδες ἵππων{l]
[l [n}5.505{]}ἂψ ἐπιμισγομένων· ὑπὸ δʼ ἔστρεφον ἡνιοχῆες.{l]
[l [n}5.506{]}οἳ δὲ μένος χειρῶν ἰθὺς φέρον· ἀμφὶ δὲ νύκτα{l]
[l [n}5.507{]}θοῦρος Ἄρης ἐκάλυψε μάχῃ Τρώεσσιν ἀρήγων{l]
[l [n}5.508{]}πάντοσʼ ἐποιχόμενος· τοῦ δʼ ἐκραίαινεν ἐφετμὰς{l]
[l [n}5.509{]}Φοίβου Ἀπόλλωνος χρυσαόρου, ὅς μιν ἀνώγει{l]
[l [n}5.510{]}Τρωσὶν θυμὸν ἐγεῖραι, ἐπεὶ ἴδε Παλλάδʼ Ἀθήνην{l]
[l [n}5.511{]}οἰχομένην· ἣ γάρ ῥα πέλεν Δαναοῖσιν ἀρηγών.{l]
[l [n}5.512{]}αὐτὸς δʼ Αἰνείαν μάλα πίονος ἐξ ἀδύτοιο{l]
[l [n}5.513{]}ἧκε, καὶ ἐν στήθεσσι μένος βάλε ποιμένι λαῶν.{l]
[l [n}5.514{]}Αἰνείας δʼ ἑτάροισι μεθίστατο· τοὶ δὲ χάρησαν,{l]
[l [n}5.515{]}ὡς εἶδον ζωόν τε καὶ ἀρτεμέα προσιόντα{l]
[l [n}5.516{]}καὶ μένος ἐσθλὸν ἔχοντα· μετάλλησάν γε μὲν οὔ τι.{l]
[l [n}5.517{]}οὐ γὰρ ἔα πόνος ἄλλος, ὃν ἀργυρότοξος ἔγειρεν{l]
[l [n}5.518{]}Ἄρης τε βροτολοιγὸς Ἔρις τʼ ἄμοτον μεμαυῖα.{l]{para]
[para}[l [n}5.519{]}τοὺς δʼ Αἴαντε δύω καὶ Ὀδυσσεὺς καὶ Διομήδης{l]
[l [n}5.520{]}ὄτρυνον Δαναοὺς πολεμιζέμεν· οἳ δὲ καὶ αὐτοὶ{l]
[l [n}5.521{]}οὔτε βίας Τρώων ὑπεδείδισαν οὔτε ἰωκάς,{l]
[l [n}5.522{]}ἀλλʼ ἔμενον νεφέλῃσιν ἐοικότες ἅς τε Κρονίων{l]
[l [n}5.523{]}νηνεμίης ἔστησεν ἐπʼ ἀκροπόλοισιν ὄρεσσιν{l]
[l [n}5.524{]}ἀτρέμας, ὄφρʼ εὕδῃσι μένος Βορέαο καὶ ἄλλων{l]
[l [n}5.525{]}ζαχρειῶν ἀνέμων, οἵ τε νέφεα σκιόεντα{l]
[l [n}5.526{]}πνοιῇσιν λιγυρῇσι διασκιδνᾶσιν ἀέντες·{l]
[l [n}5.527{]}ὣς Δαναοὶ Τρῶας μένον ἔμπεδον οὐδὲ φέβοντο.{l]
[l [n}5.528{]}Ἀτρεΐδης δʼ ἀνʼ ὅμιλον ἐφοίτα πολλὰ κελεύων·{l]
[q}[l [n}5.529{]}ὦ φίλοι ἀνέρες ἔστε καὶ ἄλκιμον ἦτορ ἕλεσθε,{l]
[l [n}5.530{]}ἀλλήλους τʼ αἰδεῖσθε κατὰ κρατερὰς ὑσμίνας·{l]
[l [n}5.531{]}αἰδομένων ἀνδρῶν πλέονες σόοι ἠὲ πέφανται·{l]
[l [n}5.532{]}φευγόντων δʼ οὔτʼ ἂρ κλέος ὄρνυται οὔτε τις ἀλκή.{l]{q]{para]
[para}[l [n}5.533{]}ἦ καὶ ἀκόντισε δουρὶ θοῶς, βάλε δὲ πρόμον ἄνδρα{l]
[l [n}5.534{]}Αἰνείω ἕταρον μεγαθύμου Δηϊκόωντα{l]
[l [n}5.535{]}Περγασίδην, ὃν Τρῶες ὁμῶς Πριάμοιο τέκεσσι{l]
[l [n}5.536{]}τῖον, ἐπεὶ θοὸς ἔσκε μετὰ πρώτοισι μάχεσθαι.{l]
[l [n}5.537{]}τόν ῥα κατʼ ἀσπίδα δουρὶ βάλε κρείων Ἀγαμέμνων·{l]
[l [n}5.538{]}ἣ δʼ οὐκ ἔγχος ἔρυτο, διὰ πρὸ δὲ εἴσατο χαλκός,{l]
[l [n}5.539{]}νειαίρῃ δʼ ἐν γαστρὶ διὰ ζωστῆρος ἔλασσε·{l]
[l [n}5.540{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]{para]
[para}[l [n}5.541{]}ἔνθʼ αὖτʼ Αἰνείας Δαναῶν ἕλεν ἄνδρας ἀρίστους{l]
[l [n}5.542{]}υἷε Διοκλῆος Κρήθωνά τε Ὀρσίλοχόν τε,{l]
[l [n}5.543{]}τῶν ῥα πατὴρ μὲν ἔναιεν ἐϋκτιμένῃ ἐνὶ Φηρῇ{l]
[l [n}5.544{]}ἀφνειὸς βιότοιο, γένος δʼ ἦν ἐκ ποταμοῖο{l]
[l [n}5.545{]}Ἀλφειοῦ, ὅς τʼ εὐρὺ ῥέει Πυλίων διὰ γαίης,{l]
[l [n}5.546{]}ὃς τέκετʼ Ὀρτίλοχον πολέεσσʼ ἄνδρεσσιν ἄνακτα·{l]
[l [n}5.547{]}Ὀρτίλοχος δʼ ἄρʼ ἔτικτε Διοκλῆα μεγάθυμον,{l]
[l [n}5.548{]}ἐκ δὲ Διοκλῆος διδυμάονε παῖδε γενέσθην,{l]
[l [n}5.549{]}Κρήθων Ὀρσίλοχός τε μάχης εὖ εἰδότε πάσης.{l]
[l [n}5.550{]}τὼ μὲν ἄρʼ ἡβήσαντε μελαινάων ἐπὶ νηῶν{l]
[l [n}5.551{]}Ἴλιον εἰς εὔπωλον ἅμʼ Ἀργείοισιν ἑπέσθην,{l]
[l [n}5.552{]}τιμὴν Ἀτρεΐδῃς Ἀγαμέμνονι καὶ Μενελάῳ{l]
[l [n}5.553{]}ἀρνυμένω· τὼ δʼ αὖθι τέλος θανάτοιο κάλυψεν.{l]
[l [n}5.554{]}οἵω τώ γε λέοντε δύω ὄρεος κορυφῇσιν{l]
[l [n}5.555{]}ἐτραφέτην ὑπὸ μητρὶ βαθείης τάρφεσιν ὕλης·{l]
[l [n}5.556{]}τὼ μὲν ἄρʼ ἁρπάζοντε βόας καὶ ἴφια μῆλα{l]
[l [n}5.557{]}σταθμοὺς ἀνθρώπων κεραΐζετον, ὄφρα καὶ αὐτὼ{l]
[l [n}5.558{]}ἀνδρῶν ἐν παλάμῃσι κατέκταθεν ὀξέϊ χαλκῷ·{l]
[l [n}5.559{]}τοίω τὼ χείρεσσιν ὑπʼ Αἰνείαο δαμέντε{l]
[l [n}5.560{]}καππεσέτην, ἐλάτῃσιν ἐοικότες ὑψηλῇσι.{l]{para]
[para}[l [n}5.561{]}τὼ δὲ πεσόντʼ ἐλέησεν ἀρηΐφιλος Μενέλαος,{l]
[l [n}5.562{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ{l]
[l [n}5.563{]}σείων ἐγχείην· τοῦ δʼ ὄτρυνεν μένος Ἄρης,{l]
[l [n}5.564{]}τὰ φρονέων ἵνα χερσὶν ὑπʼ Αἰνείαο δαμείη.{l]
[l [n}5.565{]}τὸν δʼ ἴδεν Ἀντίλοχος μεγαθύμου Νέστορος υἱός,{l]
[l [n}5.566{]}βῆ δὲ διὰ προμάχων· περὶ γὰρ δίε ποιμένι λαῶν{l]
[l [n}5.567{]}μή τι πάθοι, μέγα δέ σφας ἀποσφήλειε πόνοιο.{l]
[l [n}5.568{]}τὼ μὲν δὴ χεῖράς τε καὶ ἔγχεα ὀξυόεντα{l]
[l [n}5.569{]}ἀντίον ἀλλήλων ἐχέτην μεμαῶτε μάχεσθαι·{l]
[l [n}5.570{]}Ἀντίλοχος δὲ μάλʼ ἄγχι παρίστατο ποιμένι λαῶν.{l]
[l [n}5.571{]}Αἰνείας δʼ οὐ μεῖνε θοός περ ἐὼν πολεμιστὴς{l]
[l [n}5.572{]}ὡς εἶδεν δύο φῶτε παρʼ ἀλλήλοισι μένοντε.{l]
[l [n}5.573{]}οἳ δʼ ἐπεὶ οὖν νεκροὺς ἔρυσαν μετὰ λαὸν Ἀχαιῶν,{l]
[l [n}5.574{]}τὼ μὲν ἄρα δειλὼ βαλέτην ἐν χερσὶν ἑταίρων,{l]
[l [n}5.575{]}αὐτὼ δὲ στρεφθέντε μετὰ πρώτοισι μαχέσθην.{l]{para]
[para}[l [n}5.576{]}ἔνθα Πυλαιμένεα ἑλέτην ἀτάλαντον Ἄρηϊ{l]
[l [n}5.577{]}ἀρχὸν Παφλαγόνων μεγαθύμων ἀσπιστάων.{l]
[l [n}5.578{]}τὸν μὲν ἄρʼ Ἀτρεΐδης δουρικλειτὸς Μενέλαος{l]
[l [n}5.579{]}ἑσταότʼ ἔγχεϊ νύξε κατὰ κληῗδα τυχήσας·{l]
[l [n}5.580{]}Ἀντίλοχος δὲ Μύδωνα βάλʼ ἡνίοχον θεράποντα{l]
[l [n}5.581{]}ἐσθλὸν Ἀτυμνιάδην· ὃ δʼ ὑπέστρεφε μώνυχας ἵππους·{l]
[l [n}5.582{]}χερμαδίῳ ἀγκῶνα τυχὼν μέσον· ἐκ δʼ ἄρα χειρῶν{l]
[l [n}5.583{]}ἡνία λεύκʼ ἐλέφαντι χαμαὶ πέσον ἐν κονίῃσιν.{l]
[l [n}5.584{]}Ἀντίλοχος δʼ ἄρʼ ἐπαΐξας ξίφει ἤλασε κόρσην·{l]
[l [n}5.585{]}αὐτὰρ ὅ γʼ ἀσθμαίνων εὐεργέος ἔκπεσε δίφρου{l]
[l [n}5.586{]}κύμβαχος ἐν κονίῃσιν ἐπὶ βρεχμόν τε καὶ ὤμους.{l]
[l [n}5.587{]}δηθὰ μάλʼ ἑστήκει· τύχε γάρ ῥʼ ἀμάθοιο βαθείης·{l]
[l [n}5.588{]}ὄφρʼ ἵππω πλήξαντε χαμαὶ βάλον ἐν κονίῃσι·{l]
[l [n}5.589{]}τοὺς ἵμασʼ Ἀντίλοχος, μετὰ δὲ στρατὸν ἤλασʼ Ἀχαιῶν.{l]{para]
[para}[l [n}5.590{]}τοὺς δʼ Ἕκτωρ ἐνόησε κατὰ στίχας, ὦρτο δʼ ἐπʼ αὐτοὺς{l]
[l [n}5.591{]}κεκλήγων· ἅμα δὲ Τρώων εἵποντο φάλαγγες{l]
[l [n}5.592{]}καρτεραί· ἦρχε δʼ ἄρα σφιν Ἄρης καὶ πότνιʼ Ἐνυώ,{l]
[l [n}5.593{]}ἣ μὲν ἔχουσα Κυδοιμὸν ἀναιδέα δηϊοτῆτος,{l]
[l [n}5.594{]}Ἄρης δʼ ἐν παλάμῃσι πελώριον ἔγχος ἐνώμα,{l]
[l [n}5.595{]}φοίτα δʼ ἄλλοτε μὲν πρόσθʼ Ἕκτορος, ἄλλοτʼ ὄπισθε.{l]{para]
[para}[l [n}5.596{]}τὸν δὲ ἰδὼν ῥίγησε βοὴν ἀγαθὸς Διομήδης·{l]
[l [n}5.597{]}ὡς δʼ ὅτʼ ἀνὴρ ἀπάλαμνος ἰὼν πολέος πεδίοιο{l]
[l [n}5.598{]}στήῃ ἐπʼ ὠκυρόῳ ποταμῷ ἅλα δὲ προρέοντι{l]
[l [n}5.599{]}ἀφρῷ μορμύροντα ἰδών, ἀνά τʼ ἔδραμʼ ὀπίσσω,{l]
[l [n}5.600{]}ὣς τότε Τυδεΐδης ἀνεχάζετο, εἶπέ τε λαῷ·{l]
[q}[l [n}5.601{]}ὦ φίλοι οἷον δὴ θαυμάζομεν Ἕκτορα δῖον{l]
[l [n}5.602{]}αἰχμητήν τʼ ἔμεναι καὶ θαρσαλέον πολεμιστήν·{l]
[l [n}5.603{]}τῷ δʼ αἰεὶ πάρα εἷς γε θεῶν, ὃς λοιγὸν ἀμύνει·{l]
[l [n}5.604{]}καὶ νῦν οἱ πάρα κεῖνος Ἄρης βροτῷ ἀνδρὶ ἐοικώς.{l]
[l [n}5.605{]}ἀλλὰ πρὸς Τρῶας τετραμμένοι αἰὲν ὀπίσσω{l]
[l [n}5.606{]}εἴκετε, μηδὲ θεοῖς μενεαινέμεν ἶφι μάχεσθαι.{l]{q]{para]
[para}[l [n}5.607{]}ὣς ἄρʼ ἔφη, Τρῶες δὲ μάλα σχεδὸν ἤλυθον αὐτῶν.{l]
[l [n}5.608{]}ἔνθʼ Ἕκτωρ δύο φῶτε κατέκτανεν εἰδότε χάρμης{l]
[l [n}5.609{]}εἰν ἑνὶ δίφρῳ ἐόντε, Μενέσθην Ἀγχίαλόν τε.{l]
[l [n}5.610{]}τὼ δὲ πεσόντʼ ἐλέησε μέγας Τελαμώνιος Αἴας·{l]
[l [n}5.611{]}στῆ δὲ μάλʼ ἐγγὺς ἰών, καὶ ἀκόντισε δουρὶ φαεινῷ,{l]
[l [n}5.612{]}καὶ βάλεν Ἄμφιον Σελάγου υἱόν, ὅς ῥʼ ἐνὶ Παισῷ{l]
[l [n}5.613{]}ναῖε πολυκτήμων πολυλήϊος· ἀλλά ἑ μοῖρα{l]
[l [n}5.614{]}ἦγʼ ἐπικουρήσοντα μετὰ Πρίαμόν τε καὶ υἷας.{l]
[l [n}5.615{]}τόν ῥα κατὰ ζωστῆρα βάλεν Τελαμώνιος Αἴας,{l]
[l [n}5.616{]}νειαίρῃ δʼ ἐν γαστρὶ πάγη δολιχόσκιον ἔγχος,{l]
[l [n}5.617{]}δούπησεν δὲ πεσών· ὃ δʼ ἐπέδραμε φαίδιμος Αἴας{l]
[l [n}5.618{]}τεύχεα συλήσων· Τρῶες δʼ ἐπὶ δούρατʼ ἔχευαν{l]
[l [n}5.619{]}ὀξέα παμφανόωντα· σάκος δʼ ἀνεδέξατο πολλά.{l]
[l [n}5.620{]}αὐτὰρ ὃ λὰξ προσβὰς ἐκ νεκροῦ χάλκεον ἔγχος{l]
[l [n}5.621{]}ἐσπάσατʼ· οὐδʼ ἄρʼ ἔτʼ ἄλλα δυνήσατο τεύχεα καλὰ{l]
[l [n}5.622{]}ὤμοιιν ἀφελέσθαι· ἐπείγετο γὰρ βελέεσσι.{l]
[l [n}5.623{]}δεῖσε δʼ ὅ γʼ ἀμφίβασιν κρατερὴν Τρώων ἀγερώχων,{l]
[l [n}5.624{]}οἳ πολλοί τε καὶ ἐσθλοὶ ἐφέστασαν ἔγχεʼ ἔχοντες,{l]
[l [n}5.625{]}οἵ ἑ μέγαν περ ἐόντα καὶ ἴφθιμον καὶ ἀγαυὸν{l]
[l [n}5.626{]}ὦσαν ἀπὸ σφείων· ὃ δὲ χασσάμενος πελεμίχθη.{l]{para]
[para}[l [n}5.627{]}ὣς οἳ μὲν πονέοντο κατὰ κρατερὴν ὑσμίνην·{l]
[l [n}5.628{]}Τληπόλεμον δʼ Ἡρακλεΐδην ἠΰν τε μέγαν τε{l]
[l [n}5.629{]}ὦρσεν ἐπʼ ἀντιθέῳ Σαρπηδόνι μοῖρα κραταιή.{l]
[l [n}5.630{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες{l]
[l [n}5.631{]}υἱός θʼ υἱωνός τε Διὸς νεφεληγερέταο,{l]
[l [n}5.632{]}τὸν καὶ Τληπόλεμος πρότερος πρὸς μῦθον ἔειπε·{l]
[q}[l [n}5.633{]}Σαρπῆδον Λυκίων βουληφόρε, τίς τοι ἀνάγκη{l]
[l [n}5.634{]}πτώσσειν ἐνθάδʼ ἐόντι μάχης ἀδαήμονι φωτί;{l]
[l [n}5.635{]}ψευδόμενοι δέ σέ φασι Διὸς γόνον αἰγιόχοιο{l]
[l [n}5.636{]}εἶναι, ἐπεὶ πολλὸν κείνων ἐπιδεύεαι ἀνδρῶν{l]
[l [n}5.637{]}οἳ Διὸς ἐξεγένοντο ἐπὶ προτέρων ἀνθρώπων·{l]
[l [n}5.638{]}ἀλλʼ οἷόν τινά φασι βίην Ἡρακληείην{l]
[l [n}5.639{]}εἶναι, ἐμὸν πατέρα θρασυμέμνονα θυμολέοντα·{l]
[l [n}5.640{]}ὅς ποτε δεῦρʼ ἐλθὼν ἕνεχʼ ἵππων Λαομέδοντος{l]
[l [n}5.641{]}ἓξ οἴῃς σὺν νηυσὶ καὶ ἀνδράσι παυροτέροισιν{l]
[l [n}5.642{]}Ἰλίου ἐξαλάπαξε πόλιν, χήρωσε δʼ ἀγυιάς·{l]
[l [n}5.643{]}σοὶ δὲ κακὸς μὲν θυμός, ἀποφθινύθουσι δὲ λαοί.{l]
[l [n}5.644{]}οὐδέ τί σε Τρώεσσιν ὀΐομαι ἄλκαρ ἔσεσθαι{l]
[l [n}5.645{]}ἐλθόντʼ ἐκ Λυκίης, οὐδʼ εἰ μάλα καρτερός ἐσσι,{l]
[l [n}5.646{]}ἀλλʼ ὑπʼ ἐμοὶ δμηθέντα πύλας Ἀΐδαο περήσειν.{l]{q]{para]
[para}[l [n}5.647{]}τὸν δʼ αὖ Σαρπηδὼν Λυκίων ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}5.648{]}Τληπόλεμʼ ἤτοι κεῖνος ἀπώλεσεν Ἴλιον ἱρὴν{l]
[l [n}5.649{]}ἀνέρος ἀφραδίῃσιν ἀγαυοῦ Λαομέδοντος,{l]
[l [n}5.650{]}ὅς ῥά μιν εὖ ἕρξαντα κακῷ ἠνίπαπε μύθῳ,{l]
[l [n}5.651{]}οὐδʼ ἀπέδωχʼ ἵππους, ὧν εἵνεκα τηλόθεν ἦλθε.{l]
[l [n}5.652{]}σοὶ δʼ ἐγὼ ἐνθάδε φημὶ φόνον καὶ κῆρα μέλαιναν{l]
[l [n}5.653{]}ἐξ ἐμέθεν τεύξεσθαι, ἐμῷ δʼ ὑπὸ δουρὶ δαμέντα{l]
[l [n}5.654{]}εὖχος ἐμοὶ δώσειν, ψυχὴν δʼ Ἄϊδι κλυτοπώλῳ.{l]{q]{para]
[para}[l [n}5.655{]}ὣς φάτο Σαρπηδών, ὃ δʼ ἀνέσχετο μείλινον ἔγχος{l]
[l [n}5.656{]}Τληπόλεμος· καὶ τῶν μὲν ἁμαρτῇ δούρατα μακρὰ{l]
[l [n}5.657{]}ἐκ χειρῶν ἤϊξαν· ὃ μὲν βάλεν αὐχένα μέσσον{l]
[l [n}5.658{]}Σαρπηδών, αἰχμὴ δὲ διαμπερὲς ἦλθʼ ἀλεγεινή·{l]
[l [n}5.659{]}τὸν δὲ κατʼ ὀφθαλμῶν ἐρεβεννὴ νὺξ ἐκάλυψε.{l]
[l [n}5.660{]}Τληπόλεμος δʼ ἄρα μηρὸν ἀριστερὸν ἔγχεϊ μακρῷ{l]
[l [n}5.661{]}βεβλήκειν, αἰχμὴ δὲ διέσσυτο μαιμώωσα{l]
[l [n}5.662{]}ὀστέω ἐγχριμφθεῖσα, πατὴρ δʼ ἔτι λοιγὸν ἄμυνεν.{l]{para]
[para}[l [n}5.663{]}οἳ μὲν ἄρʼ ἀντίθεον Σαρπηδόνα δῖοι ἑταῖροι{l]
[l [n}5.664{]}ἐξέφερον πολέμοιο· βάρυνε δέ μιν δόρυ μακρὸν{l]
[l [n}5.665{]}ἑλκόμενον· τὸ μὲν οὔ τις ἐπεφράσατʼ οὐδὲ νόησε{l]
[l [n}5.666{]}μηροῦ ἐξερύσαι δόρυ μείλινον ὄφρʼ ἐπιβαίη{l]
[l [n}5.667{]}σπευδόντων· τοῖον γὰρ ἔχον πόνον ἀμφιέποντες.{l]{para]
[para}[l [n}5.668{]}Τληπόλεμον δʼ ἑτέρωθεν ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}5.669{]}ἐξέφερον πολέμοιο· νόησε δὲ δῖος Ὀδυσσεὺς{l]
[l [n}5.670{]}τλήμονα θυμὸν ἔχων, μαίμησε δέ οἱ φίλον ἦτορ·{l]
[l [n}5.671{]}μερμήριξε δʼ ἔπειτα κατὰ φρένα καὶ κατὰ θυμὸν{l]
[l [n}5.672{]}ἢ προτέρω Διὸς υἱὸν ἐριγδούποιο διώκοι,{l]
[l [n}5.673{]}ἦ ὅ γε τῶν πλεόνων Λυκίων ἀπὸ θυμὸν ἕλοιτο.{l]
[l [n}5.674{]}οὐδʼ ἄρʼ Ὀδυσσῆϊ μεγαλήτορι μόρσιμον ἦεν{l]
[l [n}5.675{]}ἴφθιμον Διὸς υἱὸν ἀποκτάμεν ὀξέϊ χαλκῷ·{l]
[l [n}5.676{]}τώ ῥα κατὰ πληθὺν Λυκίων τράπε θυμὸν Ἀθήνη.{l]
[l [n}5.677{]}ἔνθʼ ὅ γε Κοίρανον εἷλεν Ἀλάστορά τε Χρομίον τε{l]
[l [n}5.678{]}Ἄλκανδρόν θʼ Ἅλιόν τε Νοήμονά τε Πρύτανίν τε.{l]
[l [n}5.679{]}καί νύ κʼ ἔτι πλέονας Λυκίων κτάνε δῖος Ὀδυσσεὺς{l]
[l [n}5.680{]}εἰ μὴ ἄρʼ ὀξὺ νόησε μέγας κορυθαίολος Ἕκτωρ·{l]
[l [n}5.681{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ{l]
[l [n}5.682{]}δεῖμα φέρων Δαναοῖσι· χάρη δʼ ἄρα οἱ προσιόντι{l]
[l [n}5.683{]}Σαρπηδὼν Διὸς υἱός, ἔπος δʼ ὀλοφυδνὸν ἔειπε·{l]
[q}[l [n}5.684{]}Πριαμίδη, μὴ δή με ἕλωρ Δαναοῖσιν ἐάσῃς{l]
[l [n}5.685{]}κεῖσθαι, ἀλλʼ ἐπάμυνον· ἔπειτά με καὶ λίποι αἰὼν{l]
[l [n}5.686{]}ἐν πόλει ὑμετέρῃ, ἐπεὶ οὐκ ἄρʼ ἔμελλον ἔγωγε{l]
[l [n}5.687{]}νοστήσας οἶκον δὲ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}5.688{]}εὐφρανέειν ἄλοχόν τε φίλην καὶ νήπιον υἱόν.{l]{q]{para]
[para}[l [n}5.689{]}ὣς φάτο, τὸν δʼ οὔ τι προσέφη κορυθαίολος Ἕκτωρ,{l]
[l [n}5.690{]}ἀλλὰ παρήϊξεν λελιημένος ὄφρα τάχιστα{l]
[l [n}5.691{]}ὤσαιτʼ Ἀργείους, πολέων δʼ ἀπὸ θυμὸν ἕλοιτο.{l]
[l [n}5.692{]}οἳ μὲν ἄρʼ ἀντίθεον Σαρπηδόνα δῖοι ἑταῖροι{l]
[l [n}5.693{]}εἷσαν ὑπʼ αἰγιόχοιο Διὸς περικαλλέϊ φηγῷ·{l]
[l [n}5.694{]}ἐκ δʼ ἄρα οἱ μηροῦ δόρυ μείλινον ὦσε θύραζε{l]
[l [n}5.695{]}ἴφθιμος Πελάγων, ὅς οἱ φίλος ἦεν ἑταῖρος.{l]
[l [n}5.696{]}τὸν δʼ ἔλιπε ψυχή, κατὰ δʼ ὀφθαλμῶν κέχυτʼ ἀχλύς·{l]
[l [n}5.697{]}αὖτις δʼ ἐμπνύνθη, περὶ δὲ πνοιὴ Βορέαο{l]
[l [n}5.698{]}ζώγρει ἐπιπνείουσα κακῶς κεκαφηότα θυμόν.{l]{para]
[para}[l [n}5.699{]}Ἀργεῖοι δʼ ὑπʼ Ἄρηϊ καὶ Ἕκτορι χαλκοκορυστῇ{l]
[l [n}5.700{]}οὔτε ποτὲ προτρέποντο μελαινάων ἐπὶ νηῶν{l]
[l [n}5.701{]}οὔτε ποτʼ ἀντεφέροντο μάχῃ, ἀλλʼ αἰὲν ὀπίσσω{l]
[l [n}5.702{]}χάζονθʼ, ὡς ἐπύθοντο μετὰ Τρώεσσιν Ἄρηα.{l]{para]
[para}[l [n}5.703{]}ἔνθα τίνα πρῶτον τίνα δʼ ὕστατον ἐξενάριξαν{l]
[l [n}5.704{]}Ἕκτωρ τε Πριάμοιο πάϊς καὶ χάλκεος Ἄρης;{l]
[l [n}5.705{]}ἀντίθεον Τεύθραντʼ, ἐπὶ δὲ πλήξιππον Ὀρέστην,{l]
[l [n}5.706{]}Τρῆχόν τʼ αἰχμητὴν Αἰτώλιον Οἰνόμαόν τε,{l]
[l [n}5.707{]}Οἰνοπίδην θʼ Ἕλενον καὶ Ὀρέσβιον αἰολομίτρην,{l]
[l [n}5.708{]}ὅς ῥʼ ἐν Ὕλῃ ναίεσκε μέγα πλούτοιο μεμηλώς,{l]
[l [n}5.709{]}λίμνῃ κεκλιμένος Κηφισίδι· πὰρ δέ οἱ ἄλλοι{l]
[l [n}5.710{]}ναῖον Βοιωτοὶ μάλα πίονα δῆμον ἔχοντες.{l]{para]
[para}[l [n}5.711{]}τοὺς δʼ ὡς οὖν ἐνόησε θεὰ λευκώλενος Ἥρη{l]
[l [n}5.712{]}Ἀργείους ὀλέκοντας ἐνὶ κρατερῇ ὑσμίνῃ,{l]
[l [n}5.713{]}αὐτίκʼ Ἀθηναίην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}5.714{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος Ἀτρυτώνη,{l]
[l [n}5.715{]}ἦ ῥʼ ἅλιον τὸν μῦθον ὑπέστημεν Μενελάῳ{l]
[l [n}5.716{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι,{l]
[l [n}5.717{]}εἰ οὕτω μαίνεσθαι ἐάσομεν οὖλον Ἄρηα.{l]
[l [n}5.718{]}ἀλλʼ ἄγε δὴ καὶ νῶϊ μεδώμεθα θούριδος ἀλκῆς.{l]{q]{para]
[para}[l [n}5.719{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ γλαυκῶπις Ἀθήνη.{l]
[l [n}5.720{]}ἣ μὲν ἐποιχομένη χρυσάμπυκας ἔντυεν ἵππους{l]
[l [n}5.721{]}Ἥρη πρέσβα θεὰ θυγάτηρ μεγάλοιο Κρόνοιο·{l]
[l [n}5.722{]}Ἥβη δʼ ἀμφʼ ὀχέεσσι θοῶς βάλε καμπύλα κύκλα{l]
[l [n}5.723{]}χάλκεα ὀκτάκνημα σιδηρέῳ ἄξονι ἀμφίς.{l]
[l [n}5.724{]}τῶν ἤτοι χρυσέη ἴτυς ἄφθιτος, αὐτὰρ ὕπερθε{l]
[l [n}5.725{]}χάλκεʼ ἐπίσσωτρα προσαρηρότα, θαῦμα ἰδέσθαι·{l]
[l [n}5.726{]}πλῆμναι δʼ ἀργύρου εἰσὶ περίδρομοι ἀμφοτέρωθεν·{l]
[l [n}5.727{]}δίφρος δὲ χρυσέοισι καὶ ἀργυρέοισιν ἱμᾶσιν{l]
[l [n}5.728{]}ἐντέταται, δοιαὶ δὲ περίδρομοι ἄντυγές εἰσι.{l]
[l [n}5.729{]}τοῦ δʼ ἐξ ἀργύρεος ῥυμὸς πέλεν· αὐτὰρ ἐπʼ ἄκρῳ{l]
[l [n}5.730{]}δῆσε χρύσειον καλὸν ζυγόν, ἐν δὲ λέπαδνα{l]
[l [n}5.731{]}κάλʼ ἔβαλε χρύσειʼ· ὑπὸ δὲ ζυγὸν ἤγαγεν Ἥρη{l]
[l [n}5.732{]}ἵππους ὠκύποδας, μεμαυῖʼ ἔριδος καὶ ἀϋτῆς.{l]{para]
[para}[l [n}5.733{]}αὐτὰρ Ἀθηναίη κούρη Διὸς αἰγιόχοιο{l]
[l [n}5.734{]}πέπλον μὲν κατέχευεν ἑανὸν πατρὸς ἐπʼ οὔδει{l]
[l [n}5.735{]}ποικίλον, ὅν ῥʼ αὐτὴ ποιήσατο καὶ κάμε χερσίν·{l]
[l [n}5.736{]}ἣ δὲ χιτῶνʼ ἐνδῦσα Διὸς νεφεληγερέταο{l]
[l [n}5.737{]}τεύχεσιν ἐς πόλεμον θωρήσσετο δακρυόεντα.{l]
[l [n}5.738{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετʼ αἰγίδα θυσσανόεσσαν{l]
[l [n}5.739{]}δεινήν, ἣν περὶ μὲν πάντῃ Φόβος ἐστεφάνωται,{l]
[l [n}5.740{]}ἐν δʼ Ἔρις, ἐν δʼ Ἀλκή, ἐν δὲ κρυόεσσα Ἰωκή,{l]
[l [n}5.741{]}ἐν δέ τε Γοργείη κεφαλὴ δεινοῖο πελώρου{l]
[l [n}5.742{]}δεινή τε σμερδνή τε, Διὸς τέρας αἰγιόχοιο.{l]
[l [n}5.743{]}κρατὶ δʼ ἐπʼ ἀμφίφαλον κυνέην θέτο τετραφάληρον{l]
[l [n}5.744{]}χρυσείην, ἑκατὸν πολίων πρυλέεσσʼ ἀραρυῖαν·{l]
[l [n}5.745{]}ἐς δʼ ὄχεα φλόγεα ποσὶ βήσετο, λάζετο δʼ ἔγχος{l]
[l [n}5.746{]}βριθὺ μέγα στιβαρόν, τῷ δάμνησι στίχας ἀνδρῶν{l]
[l [n}5.747{]}ἡρώων, οἷσίν τε κοτέσσεται ὀβριμοπάτρη.{l]
[l [n}5.748{]}Ἥρη δὲ μάστιγι θοῶς ἐπεμαίετʼ ἄρʼ ἵππους·{l]
[l [n}5.749{]}αὐτόμαται δὲ πύλαι μύκον οὐρανοῦ ἃς ἔχον Ὧραι,{l]
[l [n}5.750{]}τῇς ἐπιτέτραπται μέγας οὐρανὸς Οὔλυμπός τε{l]
[l [n}5.751{]}ἠμὲν ἀνακλῖναι πυκινὸν νέφος ἠδʼ ἐπιθεῖναι.{l]
[l [n}5.752{]}τῇ ῥα διʼ αὐτάων κεντρηνεκέας ἔχον ἵππους·{l]
[l [n}5.753{]}εὗρον δὲ Κρονίωνα θεῶν ἄτερ ἥμενον ἄλλων{l]
[l [n}5.754{]}ἀκροτάτῃ κορυφῇ πολυδειράδος Οὐλύμποιο.{l]
[l [n}5.755{]}ἔνθʼ ἵππους στήσασα θεὰ λευκώλενος Ἥρη{l]
[l [n}5.756{]}Ζῆνʼ ὕπατον Κρονίδην ἐξείρετο καὶ προσέειπε·{l]
[q}[l [n}5.757{]}Ζεῦ πάτερ οὐ νεμεσίζῃ Ἄρῃ τάδε καρτερὰ ἔργα{l]
[l [n}5.758{]}ὁσσάτιόν τε καὶ οἷον ἀπώλεσε λαὸν Ἀχαιῶν{l]
[l [n}5.759{]}μὰψ ἀτὰρ οὐ κατὰ κόσμον ἐμοὶ δʼ ἄχος, οἳ δὲ ἕκηλοι{l]
[l [n}5.760{]}τέρπονται Κύπρίς τε καὶ ἀργυρότοξος Ἀπόλλων{l]
[l [n}5.761{]}ἄφρονα τοῦτον ἀνέντες, ὃς οὔ τινα οἶδε θέμιστα;{l]
[l [n}5.762{]}Ζεῦ πάτερ ἦ ῥά τί μοι κεχολώσεαι, αἴ κεν Ἄρηα{l]
[l [n}5.763{]}λυγρῶς πεπληγυῖα μάχης ἐξαποδίωμαι;{l]{q]{para]
[para}[l [n}5.764{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}5.765{]}ἄγρει μάν οἱ ἔπορσον Ἀθηναίην ἀγελείην,{l]
[l [n}5.766{]}ἥ ἑ μάλιστʼ εἴωθε κακῇς ὀδύνῃσι πελάζειν.{l]{q]{para]
[para}[l [n}5.767{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ λευκώλενος Ἥρη,{l]
[l [n}5.768{]}μάστιξεν δʼ ἵππους· τὼ δʼ οὐκ ἀέκοντε πετέσθην{l]
[l [n}5.769{]}μεσσηγὺς γαίης τε καὶ οὐρανοῦ ἀστερόεντος.{l]
[l [n}5.770{]}ὅσσον δʼ ἠεροειδὲς ἀνὴρ ἴδεν ὀφθαλμοῖσιν{l]
[l [n}5.771{]}ἥμενος ἐν σκοπιῇ, λεύσσων ἐπὶ οἴνοπα πόντον,{l]
[l [n}5.772{]}τόσσον ἐπιθρῴσκουσι θεῶν ὑψηχέες ἵπποι.{l]
[l [n}5.773{]}ἀλλʼ ὅτε δὴ Τροίην ἷξον ποταμώ τε ῥέοντε,{l]
[l [n}5.774{]}ἧχι ῥοὰς Σιμόεις συμβάλλετον ἠδὲ Σκάμανδρος,{l]
[l [n}5.775{]}ἔνθʼ ἵππους ἔστησε θεὰ λευκώλενος Ἥρη{l]
[l [n}5.776{]}λύσασʼ ἐξ ὀχέων, περὶ δʼ ἠέρα πουλὺν ἔχευε·{l]
[l [n}5.777{]}τοῖσιν δʼ ἀμβροσίην Σιμόεις ἀνέτειλε νέμεσθαι.{l]{para]
[para}[l [n}5.778{]}αἳ δὲ βάτην τρήρωσι πελειάσιν ἴθμαθʼ ὁμοῖαι{l]
[l [n}5.779{]}ἀνδράσιν Ἀργείοισιν ἀλεξέμεναι μεμαυῖαι·{l]
[l [n}5.780{]}ἀλλʼ ὅτε δή ῥʼ ἵκανον ὅθι πλεῖστοι καὶ ἄριστοι{l]
[l [n}5.781{]}ἕστασαν ἀμφὶ βίην Διομήδεος ἱπποδάμοιο{l]
[l [n}5.782{]}εἰλόμενοι λείουσιν ἐοικότες ὠμοφάγοισιν{l]
[l [n}5.783{]}ἢ συσὶ κάπροισιν, τῶν τε σθένος οὐκ ἀλαπαδνόν,{l]
[l [n}5.784{]}ἔνθα στᾶσʼ ἤϋσε θεὰ λευκώλενος Ἥρη{l]
[l [n}5.785{]}Στέντορι εἰσαμένη μεγαλήτορι χαλκεοφώνῳ,{l]
[l [n}5.786{]}ὃς τόσον αὐδήσασχʼ ὅσον ἄλλοι πεντήκοντα·{l]
[q}[l [n}5.787{]}αἰδὼς Ἀργεῖοι κάκʼ ἐλέγχεα εἶδος ἀγητοί·{l]
[l [n}5.788{]}ὄφρα μὲν ἐς πόλεμον πωλέσκετο δῖος Ἀχιλλεύς,{l]
[l [n}5.789{]}οὐδέ ποτε Τρῶες πρὸ πυλάων Δαρδανιάων{l]
[l [n}5.790{]}οἴχνεσκον· κείνου γὰρ ἐδείδισαν ὄβριμον ἔγχος·{l]
[l [n}5.791{]}νῦν δὲ ἑκὰς πόλιος κοίλῃς ἐπὶ νηυσὶ μάχονται.{l]{q]{para]
[para}[l [n}5.792{]}ὣς εἰποῦσʼ ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}5.793{]}Τυδεΐδῃ δʼ ἐπόρουσε θεὰ γλαυκῶπις Ἀθήνη·{l]
[l [n}5.794{]}εὗρε δὲ τόν γε ἄνακτα παρʼ ἵπποισιν καὶ ὄχεσφιν{l]
[l [n}5.795{]}ἕλκος ἀναψύχοντα τό μιν βάλε Πάνδαρος ἰῷ.{l]
[l [n}5.796{]}ἱδρὼς γάρ μιν ἔτειρεν ὑπὸ πλατέος τελαμῶνος{l]
[l [n}5.797{]}ἀσπίδος εὐκύκλου· τῷ τείρετο, κάμνε δὲ χεῖρα,{l]
[l [n}5.798{]}ἂν δʼ ἴσχων τελαμῶνα κελαινεφὲς αἷμʼ ἀπομόργνυ.{l]
[l [n}5.799{]}ἱππείου δὲ θεὰ ζυγοῦ ἥψατο φώνησέν τε·{l]
[q}[l [n}5.800{]}ἦ ὀλίγον οἷ παῖδα ἐοικότα γείνατο Τυδεύς.{l]
[l [n}5.801{]}Τυδεύς τοι μικρὸς μὲν ἔην δέμας, ἀλλὰ μαχητής·{l]
[l [n}5.802{]}καί ῥʼ ὅτε πέρ μιν ἐγὼ πολεμίζειν οὐκ εἴασκον{l]
[l [n}5.803{]}οὐδʼ ἐκπαιφάσσειν, ὅτε τʼ ἤλυθε νόσφιν Ἀχαιῶν{l]
[l [n}5.804{]}ἄγγελος ἐς Θήβας πολέας μετὰ Καδμείωνας·{l]
[l [n}5.805{]}δαίνυσθαί μιν ἄνωγον ἐνὶ μεγάροισιν ἕκηλον·{l]
[l [n}5.806{]}αὐτὰρ ὃ θυμὸν ἔχων ὃν καρτερὸν ὡς τὸ πάρος περ{l]
[l [n}5.807{]}κούρους Καδμείων προκαλίζετο, πάντα δʼ ἐνίκα{l]
[l [n}5.808{]}ῥηϊδίως· τοίη οἱ ἐγὼν ἐπιτάρροθος ἦα.{l]
[l [n}5.809{]}σοὶ δʼ ἤτοι μὲν ἐγὼ παρά θʼ ἵσταμαι ἠδὲ φυλάσσω,{l]
[l [n}5.810{]}καί σε προφρονέως κέλομαι Τρώεσσι μάχεσθαι·{l]
[l [n}5.811{]}ἀλλά σευ ἢ κάματος πολυᾶϊξ γυῖα δέδυκεν{l]
[l [n}5.812{]}ἤ νύ σέ που δέος ἴσχει ἀκήριον· οὐ σύ γʼ ἔπειτα{l]
[l [n}5.813{]}Τυδέος ἔκγονός ἐσσι δαΐφρονος Οἰνεΐδαο.{l]{q]{para]
[para}[l [n}5.814{]}τὴν δʼ ἀπαμειβόμενος προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}5.815{]}γιγνώσκω σε θεὰ θύγατερ Διὸς αἰγιόχοιο·{l]
[l [n}5.816{]}τώ τοι προφρονέως ἐρέω ἔπος οὐδʼ ἐπικεύσω.{l]
[l [n}5.817{]}οὔτέ τί με δέος ἴσχει ἀκήριον οὔτέ τις ὄκνος,{l]
[l [n}5.818{]}ἀλλʼ ἔτι σέων μέμνημαι ἐφετμέων ἃς ἐπέτειλας·{l]
[l [n}5.819{]}οὔ μʼ εἴας μακάρεσσι θεοῖς ἀντικρὺ μάχεσθαι{l]
[l [n}5.820{]}τοῖς ἄλλοις· ἀτὰρ εἴ κε Διὸς θυγάτηρ Ἀφροδίτη{l]
[l [n}5.821{]}ἔλθῃσʼ ἐς πόλεμον, τήν γʼ οὐτάμεν ὀξέϊ χαλκῷ.{l]
[l [n}5.822{]}τοὔνεκα νῦν αὐτός τʼ ἀναχάζομαι ἠδὲ καὶ ἄλλους{l]
[l [n}5.823{]}Ἀργείους ἐκέλευσα ἀλήμεναι ἐνθάδε πάντας·{l]
[l [n}5.824{]}γιγνώσκω γὰρ Ἄρηα μάχην ἀνὰ κοιρανέοντα.{l]{q]{para]
[para}[l [n}5.825{]}τὸν δʼ ἠμείβετʼ ἔπειτα θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}5.826{]}Τυδεΐδη Διόμηδες ἐμῷ κεχαρισμένε θυμῷ{l]
[l [n}5.827{]}μήτε σύ γʼ Ἄρηα τό γε δείδιθι μήτε τινʼ ἄλλον{l]
[l [n}5.828{]}ἀθανάτων, τοίη τοι ἐγὼν ἐπιτάρροθός εἰμι·{l]
[l [n}5.829{]}ἀλλʼ ἄγʼ ἐπʼ Ἄρηϊ πρώτῳ ἔχε μώνυχας ἵππους,{l]
[l [n}5.830{]}τύψον δὲ σχεδίην μηδʼ ἅζεο θοῦρον Ἄρηα{l]
[l [n}5.831{]}τοῦτον μαινόμενον, τυκτὸν κακόν, ἀλλοπρόσαλλον,{l]
[l [n}5.832{]}ὃς πρῴην μὲν ἐμοί τε καὶ Ἥρῃ στεῦτʼ ἀγορεύων{l]
[l [n}5.833{]}Τρωσὶ μαχήσεσθαι, ἀτὰρ Ἀργείοισιν ἀρήξειν,{l]
[l [n}5.834{]}νῦν δὲ μετὰ Τρώεσσιν ὁμιλεῖ, τῶν δὲ λέλασται.{l]{q]{para]
[para}[l [n}5.835{]}ὣς φαμένη Σθένελον μὲν ἀφʼ ἵππων ὦσε χαμᾶζε,{l]
[l [n}5.836{]}χειρὶ πάλιν ἐρύσασʼ, ὃ δʼ ἄρʼ ἐμμαπέως ἀπόρουσεν·{l]
[l [n}5.837{]}ἣ δʼ ἐς δίφρον ἔβαινε παραὶ Διομήδεα δῖον{l]
[l [n}5.838{]}ἐμμεμαυῖα θεά· μέγα δʼ ἔβραχε φήγινος ἄξων{l]
[l [n}5.839{]}βριθοσύνῃ· δεινὴν γὰρ ἄγεν θεὸν ἄνδρά τʼ ἄριστον.{l]
[l [n}5.840{]}λάζετο δὲ μάστιγα καὶ ἡνία Παλλὰς Ἀθήνη·{l]
[l [n}5.841{]}αὐτίκʼ ἐπʼ Ἄρηϊ πρώτῳ ἔχε μώνυχας ἵππους.{l]
[l [n}5.842{]}ἤτοι ὃ μὲν Περίφαντα πελώριον ἐξενάριζεν{l]
[l [n}5.843{]}Αἰτωλῶν ὄχʼ ἄριστον Ὀχησίου ἀγλαὸν υἱόν·{l]
[l [n}5.844{]}τὸν μὲν Ἄρης ἐνάριζε μιαιφόνος· αὐτὰρ Ἀθήνη{l]
[l [n}5.845{]}δῦνʼ Ἄϊδος κυνέην, μή μιν ἴδοι ὄβριμος Ἄρης.{l]{para]
[para}[l [n}5.846{]}ὡς δὲ ἴδε βροτολοιγὸς Ἄρης Διομήδεα δῖον,{l]
[l [n}5.847{]}ἤτοι ὃ μὲν Περίφαντα πελώριον αὐτόθʼ ἔασε{l]
[l [n}5.848{]}κεῖσθαι ὅθι πρῶτον κτείνων ἐξαίνυτο θυμόν,{l]
[l [n}5.849{]}αὐτὰρ ὃ βῆ ῥʼ ἰθὺς Διομήδεος ἱπποδάμοιο.{l]
[l [n}5.850{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}5.851{]}πρόσθεν Ἄρης ὠρέξαθʼ ὑπὲρ ζυγὸν ἡνία θʼ ἵππων{l]
[l [n}5.852{]}ἔγχεϊ χαλκείῳ μεμαὼς ἀπὸ θυμὸν ἑλέσθαι·{l]
[l [n}5.853{]}καὶ τό γε χειρὶ λαβοῦσα θεὰ γλαυκῶπις Ἀθήνη{l]
[l [n}5.854{]}ὦσεν ὑπὲκ δίφροιο ἐτώσιον ἀϊχθῆναι.{l]
[l [n}5.855{]}δεύτερος αὖθʼ ὡρμᾶτο βοὴν ἀγαθὸς Διομήδης{l]
[l [n}5.856{]}ἔγχεϊ χαλκείῳ· ἐπέρεισε δὲ Παλλὰς Ἀθήνη{l]
[l [n}5.857{]}νείατον ἐς κενεῶνα ὅθι ζωννύσκετο μίτρῃ·{l]
[l [n}5.858{]}τῇ ῥά μιν οὖτα τυχών, διὰ δὲ χρόα καλὸν ἔδαψεν,{l]
[l [n}5.859{]}ἐκ δὲ δόρυ σπάσεν αὖτις· ὃ δʼ ἔβραχε χάλκεος Ἄρης{l]
[l [n}5.860{]}ὅσσόν τʼ ἐννεάχιλοι ἐπίαχον ἢ δεκάχιλοι{l]
[l [n}5.861{]}ἀνέρες ἐν πολέμῳ ἔριδα ξυνάγοντες Ἄρηος.{l]
[l [n}5.862{]}τοὺς δʼ ἄρʼ ὑπὸ τρόμος εἷλεν Ἀχαιούς τε Τρῶάς τε{l]
[l [n}5.863{]}δείσαντας· τόσον ἔβραχʼ Ἄρης ἆτος πολέμοιο.{l]{para]
[para}[l [n}5.864{]}οἵη δʼ ἐκ νεφέων ἐρεβεννὴ φαίνεται ἀὴρ{l]
[l [n}5.865{]}καύματος ἐξ ἀνέμοιο δυσαέος ὀρνυμένοιο,{l]
[l [n}5.866{]}τοῖος Τυδεΐδῃ Διομήδεϊ χάλκεος Ἄρης{l]
[l [n}5.867{]}φαίνεθʼ ὁμοῦ νεφέεσσιν ἰὼν εἰς οὐρανὸν εὐρύν.{l]
[l [n}5.868{]}καρπαλίμως δʼ ἵκανε θεῶν ἕδος αἰπὺν Ὄλυμπον,{l]
[l [n}5.869{]}πὰρ δὲ Διὶ Κρονίωνι καθέζετο θυμὸν ἀχεύων,{l]
[l [n}5.870{]}δεῖξεν δʼ ἄμβροτον αἷμα καταρρέον ἐξ ὠτειλῆς,{l]
[l [n}5.871{]}καί ῥʼ ὀλοφυρόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}5.872{]}Ζεῦ πάτερ οὐ νεμεσίζῃ ὁρῶν τάδε καρτερὰ ἔργα;{l]
[l [n}5.873{]}αἰεί τοι ῥίγιστα θεοὶ τετληότες εἰμὲν{l]
[l [n}5.874{]}ἀλλήλων ἰότητι, χάριν ἄνδρεσσι φέροντες.{l]
[l [n}5.875{]}σοὶ πάντες μαχόμεσθα· σὺ γὰρ τέκες ἄφρονα κούρην{l]
[l [n}5.876{]}οὐλομένην, ᾗ τʼ αἰὲν ἀήσυλα ἔργα μέμηλεν.{l]
[l [n}5.877{]}ἄλλοι μὲν γὰρ πάντες ὅσοι θεοί εἰσʼ ἐν Ὀλύμπῳ{l]
[l [n}5.878{]}σοί τʼ ἐπιπείθονται καὶ δεδμήμεσθα ἕκαστος·{l]
[l [n}5.879{]}ταύτην δʼ οὔτʼ ἔπεϊ προτιβάλλεαι οὔτέ τι ἔργῳ,{l]
[l [n}5.880{]}ἀλλʼ ἀνιεῖς, ἐπεὶ αὐτὸς ἐγείναο παῖδʼ ἀΐδηλον·{l]
[l [n}5.881{]}ἣ νῦν Τυδέος υἱὸν ὑπερφίαλον Διομήδεα{l]
[l [n}5.882{]}μαργαίνειν ἀνέηκεν ἐπʼ ἀθανάτοισι θεοῖσι.{l]
[l [n}5.883{]}Κύπριδα μὲν πρῶτον σχεδὸν οὔτασε χεῖρʼ ἐπὶ καρπῷ,{l]
[l [n}5.884{]}αὐτὰρ ἔπειτʼ αὐτῷ μοι ἐπέσσυτο δαίμονι ἶσος·{l]
[l [n}5.885{]}ἀλλά μʼ ὑπήνεικαν ταχέες πόδες· ἦ τέ κε δηρὸν{l]
[l [n}5.886{]}αὐτοῦ πήματʼ ἔπασχον ἐν αἰνῇσιν νεκάδεσσιν,{l]
[l [n}5.887{]}ἤ κε ζὼς ἀμενηνὸς ἔα χαλκοῖο τυπῇσι.{l]{q]{para]
[para}[l [n}5.888{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη νεφεληγερέτα Ζεύς.{l]
[q}[l [n}5.889{]}μή τί μοι ἀλλοπρόσαλλε παρεζόμενος μινύριζε.{l]
[l [n}5.890{]}ἔχθιστος δέ μοί ἐσσι θεῶν οἳ Ὄλυμπον ἔχουσιν·{l]
[l [n}5.891{]}αἰεὶ γάρ τοι ἔρις τε φίλη πόλεμοί τε μάχαι τε.{l]
[l [n}5.892{]}μητρός τοι μένος ἐστὶν ἀάσχετον οὐκ ἐπιεικτὸν{l]
[l [n}5.893{]}Ἥρης· τὴν μὲν ἐγὼ σπουδῇ δάμνημʼ ἐπέεσσι·{l]
[l [n}5.894{]}τώ σʼ ὀΐω κείνης τάδε πάσχειν ἐννεσίῃσιν.{l]
[l [n}5.895{]}ἀλλʼ οὐ μάν σʼ ἔτι δηρὸν ἀνέξομαι ἄλγεʼ ἔχοντα·{l]
[l [n}5.896{]}ἐκ γὰρ ἐμεῦ γένος ἐσσί, ἐμοὶ δέ σε γείνατο μήτηρ·{l]
[l [n}5.897{]}εἰ δέ τευ ἐξ ἄλλου γε θεῶν γένευ ὧδʼ ἀΐδηλος{l]
[l [n}5.898{]}καί κεν δὴ πάλαι ἦσθα ἐνέρτερος Οὐρανιώνων.{l]{q]{para]
[para}[l [n}5.899{]}ὣς φάτο, καὶ Παιήονʼ ἀνώγειν ἰήσασθαι.{l]
[l [n}5.900{]}τῷ δʼ ἐπὶ Παιήων ὀδυνήφατα φάρμακα πάσσων{l]
[l [n}5.901{]}ἠκέσατʼ· οὐ μὲν γάρ τι καταθνητός γʼ ἐτέτυκτο.{l]
[l [n}5.902{]}ὡς δʼ ὅτʼ ὀπὸς γάλα λευκὸν ἐπειγόμενος συνέπηξεν{l]
[l [n}5.903{]}ὑγρὸν ἐόν, μάλα δʼ ὦκα περιτρέφεται κυκόωντι,{l]
[l [n}5.904{]}ὣς ἄρα καρπαλίμως ἰήσατο θοῦρον Ἄρηα.{l]
[l [n}5.905{]}τὸν δʼ Ἥβη λοῦσεν, χαρίεντα δὲ εἵματα ἕσσε·{l]
[l [n}5.906{]}πὰρ δὲ Διὶ Κρονίωνι καθέζετο κύδεϊ γαίων.{l]{para]
[para}[l [n}5.907{]}αἳ δʼ αὖτις πρὸς δῶμα Διὸς μεγάλοιο νέοντο{l]
[l [n}5.908{]}Ἥρη τʼ Ἀργείη καὶ Ἀλαλκομενηῒς Ἀθήνη{l]
[l [n}5.909{]}παύσασαι βροτολοιγὸν Ἄρηʼ ἀνδροκτασιάων.{l]{para]
{book]
[book [n}6{]}
[para}[l [n}6.1{]}Τρώων δʼ οἰώθη καὶ Ἀχαιῶν φύλοπις αἰνή·{l]
[l [n}6.2{]}πολλὰ δʼ ἄρʼ ἔνθα καὶ ἔνθʼ ἴθυσε μάχη πεδίοιο{l]
[l [n}6.3{]}ἀλλήλων ἰθυνομένων χαλκήρεα δοῦρα{l]
[l [n}6.4{]}μεσσηγὺς Σιμόεντος ἰδὲ Ξάνθοιο ῥοάων.{l]{para]
[para}[l [n}6.5{]}Αἴας δὲ πρῶτος Τελαμώνιος ἕρκος Ἀχαιῶν{l]
[l [n}6.6{]}Τρώων ῥῆξε φάλαγγα, φόως δʼ ἑτάροισιν ἔθηκεν,{l]
[l [n}6.7{]}ἄνδρα βαλὼν ὃς ἄριστος ἐνὶ Θρῄκεσσι τέτυκτο{l]
[l [n}6.8{]}υἱὸν Ἐϋσσώρου Ἀκάμαντʼ ἠΰν τε μέγαν τε.{l]
[l [n}6.9{]}τόν ῥʼ ἔβαλε πρῶτος κόρυθος φάλον ἱπποδασείης,{l]
[l [n}6.10{]}ἐν δὲ μετώπῳ πῆξε, πέρησε δʼ ἄρʼ ὀστέον εἴσω{l]
[l [n}6.11{]}αἰχμὴ χαλκείη· τὸν δὲ σκότος ὄσσε κάλυψεν.{l]{para]
[para}[l [n}6.12{]}Ἄξυλον δʼ ἄρʼ ἔπεφνε βοὴν ἀγαθὸς Διομήδης{l]
[l [n}6.13{]}Τευθρανίδην, ὃς ἔναιεν ἐϋκτιμένῃ ἐν Ἀρίσβῃ{l]
[l [n}6.14{]}ἀφνειὸς βιότοιο, φίλος δʼ ἦν ἀνθρώποισι.{l]
[l [n}6.15{]}πάντας γὰρ φιλέεσκεν ὁδῷ ἔπι οἰκία ναίων.{l]
[l [n}6.16{]}ἀλλά οἱ οὔ τις τῶν γε τότʼ ἤρκεσε λυγρὸν ὄλεθρον{l]
[l [n}6.17{]}πρόσθεν ὑπαντιάσας, ἀλλʼ ἄμφω θυμὸν ἀπηύρα{l]
[l [n}6.18{]}αὐτὸν καὶ θεράποντα Καλήσιον, ὅς ῥα τόθʼ ἵππων{l]
[l [n}6.19{]}ἔσκεν ὑφηνίοχος· τὼ δʼ ἄμφω γαῖαν ἐδύτην.{l]{para]
[para}[l [n}6.20{]}Δρῆσον δʼ Εὐρύαλος καὶ Ὀφέλτιον ἐξενάριξε·{l]
[l [n}6.21{]}βῆ δὲ μετʼ Αἴσηπον καὶ Πήδασον, οὕς ποτε νύμφη{l]
[l [n}6.22{]}νηῒς Ἀβαρβαρέη τέκʼ ἀμύμονι Βουκολίωνι.{l]
[l [n}6.23{]}Βουκολίων δʼ ἦν υἱὸς ἀγαυοῦ Λαομέδοντος{l]
[l [n}6.24{]}πρεσβύτατος γενεῇ, σκότιον δέ ἑ γείνατο μήτηρ·{l]
[l [n}6.25{]}ποιμαίνων δʼ ἐπʼ ὄεσσι μίγη φιλότητι καὶ εὐνῇ,{l]
[l [n}6.26{]}ἣ δʼ ὑποκυσαμένη διδυμάονε γείνατο παῖδε.{l]
[l [n}6.27{]}καὶ μὲν τῶν ὑπέλυσε μένος καὶ φαίδιμα γυῖα{l]
[l [n}6.28{]}Μηκιστηϊάδης καὶ ἀπʼ ὤμων τεύχεʼ ἐσύλα.{l]{para]
[para}[l [n}6.29{]}Ἀστύαλον δʼ ἄρʼ ἔπεφνε μενεπτόλεμος Πολυποίτης·{l]
[l [n}6.30{]}Πιδύτην δʼ Ὀδυσεὺς Περκώσιον ἐξενάριξεν{l]
[l [n}6.31{]}ἔγχεϊ χαλκείῳ, Τεῦκρος δʼ Ἀρετάονα δῖον.{l]
[l [n}6.32{]}Ἀντίλοχος δʼ Ἄβληρον ἐνήρατο δουρὶ φαεινῷ{l]
[l [n}6.33{]}Νεστορίδης, Ἔλατον δὲ ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[l [n}6.34{]}ναῖε δὲ Σατνιόεντος ἐϋρρείταο παρʼ ὄχθας{l]
[l [n}6.35{]}Πήδασον αἰπεινήν. Φύλακον δʼ ἕλε Λήϊτος ἥρως{l]
[l [n}6.36{]}φεύγοντʼ· Εὐρύπυλος δὲ Μελάνθιον ἐξενάριξεν.{l]{para]
[para}[l [n}6.37{]}Ἄδρηστον δʼ ἄρʼ ἔπειτα βοὴν ἀγαθὸς Μενέλαος{l]
[l [n}6.38{]}ζωὸν ἕλʼ· ἵππω γάρ οἱ ἀτυζομένω πεδίοιο{l]
[l [n}6.39{]}ὄζῳ ἔνι βλαφθέντε μυρικίνῳ ἀγκύλον ἅρμα{l]
[l [n}6.40{]}ἄξαντʼ ἐν πρώτῳ ῥυμῷ αὐτὼ μὲν ἐβήτην{l]
[l [n}6.41{]}πρὸς πόλιν, ᾗ περ οἱ ἄλλοι ἀτυζόμενοι φοβέοντο,{l]
[l [n}6.42{]}αὐτὸς δʼ ἐκ δίφροιο παρὰ τροχὸν ἐξεκυλίσθη{l]
[l [n}6.43{]}πρηνὴς ἐν κονίῃσιν ἐπὶ στόμα· πὰρ δέ οἱ ἔστη{l]
[l [n}6.44{]}Ἀτρεΐδης Μενέλαος ἔχων δολιχόσκιον ἔγχος.{l]
[l [n}6.45{]}Ἄδρηστος δʼ ἄρʼ ἔπειτα λαβὼν ἐλίσσετο γούνων·{l]
[q}[l [n}6.46{]}ζώγρει Ἀτρέος υἱέ, σὺ δʼ ἄξια δέξαι ἄποινα·{l]
[l [n}6.47{]}πολλὰ δʼ ἐν ἀφνειοῦ πατρὸς κειμήλια κεῖται{l]
[l [n}6.48{]}χαλκός τε χρυσός τε πολύκμητός τε σίδηρος,{l]
[l [n}6.49{]}τῶν κέν τοι χαρίσαιτο πατὴρ ἀπερείσιʼ ἄποινα{l]
[l [n}6.50{]}εἴ κεν ἐμὲ ζωὸν πεπύθοιτʼ ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}6.51{]}ὣς φάτο, τῷ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ἔπειθε·{l]
[l [n}6.52{]}καὶ δή μιν τάχʼ ἔμελλε θοὰς ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}6.53{]}δώσειν ᾧ θεράποντι καταξέμεν· ἀλλʼ Ἀγαμέμνων{l]
[l [n}6.54{]}ἀντίος ἦλθε θέων, καὶ ὁμοκλήσας ἔπος ηὔδα·{l]
[q}[l [n}6.55{]}ὦ πέπον ὦ Μενέλαε, τί ἢ δὲ σὺ κήδεαι οὕτως{l]
[l [n}6.56{]}ἀνδρῶν; ἦ σοὶ ἄριστα πεποίηται κατὰ οἶκον{l]
[l [n}6.57{]}πρὸς Τρώων; τῶν μή τις ὑπεκφύγοι αἰπὺν ὄλεθρον{l]
[l [n}6.58{]}χεῖράς θʼ ἡμετέρας, μηδʼ ὅν τινα γαστέρι μήτηρ{l]
[l [n}6.59{]}κοῦρον ἐόντα φέροι, μηδʼ ὃς φύγοι, ἀλλʼ ἅμα πάντες{l]
[l [n}6.60{]}Ἰλίου ἐξαπολοίατʼ ἀκήδεστοι καὶ ἄφαντοι.{l]{q]{para]
[para}[l [n}6.61{]}ὣς εἰπὼν ἔτρεψεν ἀδελφειοῦ φρένας ἥρως{l]
[l [n}6.62{]}αἴσιμα παρειπών· ὃ δʼ ἀπὸ ἕθεν ὤσατο χειρὶ{l]
[l [n}6.63{]}ἥρωʼ Ἄδρηστον· τὸν δὲ κρείων Ἀγαμέμνων{l]
[l [n}6.64{]}οὖτα κατὰ λαπάρην· ὃ δʼ ἀνετράπετʼ, Ἀτρεΐδης δὲ{l]
[l [n}6.65{]}λὰξ ἐν στήθεσι βὰς ἐξέσπασε μείλινον ἔγχος.{l]{para]
[para}[l [n}6.66{]}Νέστωρ δʼ Ἀργείοισιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}6.67{]}ὦ φίλοι ἥρωες Δαναοὶ θεράποντες Ἄρηος{l]
[l [n}6.68{]}μή τις νῦν ἐνάρων ἐπιβαλλόμενος μετόπισθε{l]
[l [n}6.69{]}μιμνέτω ὥς κε πλεῖστα φέρων ἐπὶ νῆας ἵκηται,{l]
[l [n}6.70{]}ἀλλʼ ἄνδρας κτείνωμεν· ἔπειτα δὲ καὶ τὰ ἕκηλοι{l]
[l [n}6.71{]}νεκροὺς ἂμ πεδίον συλήσετε τεθνηῶτας.{l]{q]{para]
[para}[l [n}6.72{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}6.73{]}ἔνθά κεν αὖτε Τρῶες ἀρηϊφίλων ὑπʼ Ἀχαιῶν{l]
[l [n}6.74{]}Ἴλιον εἰσανέβησαν ἀναλκείῃσι δαμέντες,{l]
[l [n}6.75{]}εἰ μὴ ἄρʼ Αἰνείᾳ τε καὶ Ἕκτορι εἶπε παραστὰς{l]
[l [n}6.76{]}Πριαμίδης Ἕλενος οἰωνοπόλων ὄχʼ ἄριστος·{l]
[q}[l [n}6.77{]}Αἰνεία τε καὶ Ἕκτορ, ἐπεὶ πόνος ὔμμι μάλιστα{l]
[l [n}6.78{]}Τρώων καὶ Λυκίων ἐγκέκλιται, οὕνεκʼ ἄριστοι{l]
[l [n}6.79{]}πᾶσαν ἐπʼ ἰθύν ἐστε μάχεσθαί τε φρονέειν τε,{l]
[l [n}6.80{]}στῆτʼ αὐτοῦ, καὶ λαὸν ἐρυκάκετε πρὸ πυλάων{l]
[l [n}6.81{]}πάντῃ ἐποιχόμενοι πρὶν αὖτʼ ἐν χερσὶ γυναικῶν{l]
[l [n}6.82{]}φεύγοντας πεσέειν, δηΐοισι δὲ χάρμα γενέσθαι.{l]
[l [n}6.83{]}αὐτὰρ ἐπεί κε φάλαγγας ἐποτρύνητον ἁπάσας,{l]
[l [n}6.84{]}ἡμεῖς μὲν Δαναοῖσι μαχησόμεθʼ αὖθι μένοντες,{l]
[l [n}6.85{]}καὶ μάλα τειρόμενοί περ· ἀναγκαίη γὰρ ἐπείγει·{l]
[l [n}6.86{]}Ἕκτορ ἀτὰρ σὺ πόλιν δὲ μετέρχεο, εἰπὲ δʼ ἔπειτα{l]
[l [n}6.87{]}μητέρι σῇ καὶ ἐμῇ· ἣ δὲ ξυνάγουσα γεραιὰς{l]
[l [n}6.88{]}νηὸν Ἀθηναίης γλαυκώπιδος ἐν πόλει ἄκρῃ{l]
[l [n}6.89{]}οἴξασα κληῗδι θύρας ἱεροῖο δόμοιο{l]
[l [n}6.90{]}πέπλον, ὅς οἱ δοκέει χαριέστατος ἠδὲ μέγιστος{l]
[l [n}6.91{]}εἶναι ἐνὶ μεγάρῳ καί οἱ πολὺ φίλτατος αὐτῇ,{l]
[l [n}6.92{]}θεῖναι Ἀθηναίης ἐπὶ γούνασιν ἠϋκόμοιο,{l]
[l [n}6.93{]}καί οἱ ὑποσχέσθαι δυοκαίδεκα βοῦς ἐνὶ νηῷ{l]
[l [n}6.94{]}ἤνις ἠκέστας ἱερευσέμεν, αἴ κʼ ἐλεήσῃ{l]
[l [n}6.95{]}ἄστύ τε καὶ Τρώων ἀλόχους καὶ νήπια τέκνα,{l]
[l [n}6.96{]}ὥς κεν Τυδέος υἱὸν ἀπόσχῃ Ἰλίου ἱρῆς{l]
[l [n}6.97{]}ἄγριον αἰχμητὴν κρατερὸν μήστωρα φόβοιο,{l]
[l [n}6.98{]}ὃν δὴ ἐγὼ κάρτιστον Ἀχαιῶν φημι γενέσθαι.{l]
[l [n}6.99{]}οὐδʼ Ἀχιλῆά ποθʼ ὧδέ γʼ ἐδείδιμεν ὄρχαμον ἀνδρῶν,{l]
[l [n}6.100{]}ὅν πέρ φασι θεᾶς ἐξέμμεναι· ἀλλʼ ὅδε λίην{l]
[l [n}6.101{]}μαίνεται, οὐδέ τίς οἱ δύναται μένος ἰσοφαρίζειν.{l]{q]{para]
[para}[l [n}6.102{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ οὔ τι κασιγνήτῳ ἀπίθησεν.{l]
[l [n}6.103{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε,{l]
[l [n}6.104{]}πάλλων δʼ ὀξέα δοῦρα κατὰ στρατὸν ᾤχετο πάντῃ{l]
[l [n}6.105{]}ὀτρύνων μαχέσασθαι, ἔγειρε δὲ φύλοπιν αἰνήν.{l]
[l [n}6.106{]}οἳ δʼ ἐλελίχθησαν καὶ ἐναντίοι ἔσταν Ἀχαιῶν·{l]
[l [n}6.107{]}Ἀργεῖοι δʼ ὑπεχώρησαν, λῆξαν δὲ φόνοιο,{l]
[l [n}6.108{]}φὰν δέ τινʼ ἀθανάτων ἐξ οὐρανοῦ ἀστερόεντος{l]
[l [n}6.109{]}Τρωσὶν ἀλεξήσοντα κατελθέμεν, ὡς ἐλέλιχθεν.{l]
[l [n}6.110{]}Ἕκτωρ δὲ Τρώεσσιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}6.111{]}Τρῶες ὑπέρθυμοι τηλεκλειτοί τʼ ἐπίκουροι{l]
[l [n}6.112{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς,{l]
[l [n}6.113{]}ὄφρʼ ἂν ἐγὼ βείω προτὶ Ἴλιον, ἠδὲ γέρουσιν{l]
[l [n}6.114{]}εἴπω βουλευτῇσι καὶ ἡμετέρῃς ἀλόχοισι{l]
[l [n}6.115{]}δαίμοσιν ἀρήσασθαι, ὑποσχέσθαι δʼ ἑκατόμβας.{l]{q]{para]
[para}[l [n}6.116{]}ὣς ἄρα φωνήσας ἀπέβη κορυθαίολος Ἕκτωρ·{l]
[l [n}6.117{]}ἀμφὶ δέ μιν σφυρὰ τύπτε καὶ αὐχένα δέρμα κελαινὸν{l]
[l [n}6.118{]}ἄντυξ ἣ πυμάτη θέεν ἀσπίδος ὀμφαλοέσσης.{l]{para]
[para}[l [n}6.119{]}Γλαῦκος δʼ Ἱππολόχοιο πάϊς καὶ Τυδέος υἱὸς{l]
[l [n}6.120{]}ἐς μέσον ἀμφοτέρων συνίτην μεμαῶτε μάχεσθαι.{l]
[l [n}6.121{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντε,{l]
[l [n}6.122{]}τὸν πρότερος προσέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}6.123{]}τίς δὲ σύ ἐσσι φέριστε καταθνητῶν ἀνθρώπων;{l]
[l [n}6.124{]}οὐ μὲν γάρ ποτʼ ὄπωπα μάχῃ ἔνι κυδιανείρῃ{l]
[l [n}6.125{]}τὸ πρίν· ἀτὰρ μὲν νῦν γε πολὺ προβέβηκας ἁπάντων{l]
[l [n}6.126{]}σῷ θάρσει, ὅ τʼ ἐμὸν δολιχόσκιον ἔγχος ἔμεινας·{l]
[l [n}6.127{]}δυστήνων δέ τε παῖδες ἐμῷ μένει ἀντιόωσιν.{l]
[l [n}6.128{]}εἰ δέ τις ἀθανάτων γε κατʼ οὐρανοῦ εἰλήλουθας,{l]
[l [n}6.129{]}οὐκ ἂν ἔγωγε θεοῖσιν ἐπουρανίοισι μαχοίμην.{l]
[l [n}6.130{]}οὐδὲ γὰρ οὐδὲ Δρύαντος υἱὸς κρατερὸς Λυκόοργος{l]
[l [n}6.131{]}δὴν ἦν, ὅς ῥα θεοῖσιν ἐπουρανίοισιν ἔριζεν·{l]
[l [n}6.132{]}ὅς ποτε μαινομένοιο Διωνύσοιο τιθήνας{l]
[l [n}6.133{]}σεῦε κατʼ ἠγάθεον Νυσήϊον· αἳ δʼ ἅμα πᾶσαι{l]
[l [n}6.134{]}θύσθλα χαμαὶ κατέχευαν ὑπʼ ἀνδροφόνοιο Λυκούργου{l]
[l [n}6.135{]}θεινόμεναι βουπλῆγι· Διώνυσος δὲ φοβηθεὶς{l]
[l [n}6.136{]}δύσεθʼ ἁλὸς κατὰ κῦμα, Θέτις δʼ ὑπεδέξατο κόλπῳ{l]
[l [n}6.137{]}δειδιότα· κρατερὸς γὰρ ἔχε τρόμος ἀνδρὸς ὁμοκλῇ.{l]
[l [n}6.138{]}τῷ μὲν ἔπειτʼ ὀδύσαντο θεοὶ ῥεῖα ζώοντες,{l]
[l [n}6.139{]}καί μιν τυφλὸν ἔθηκε Κρόνου πάϊς· οὐδʼ ἄρʼ ἔτι δὴν{l]
[l [n}6.140{]}ἦν, ἐπεὶ ἀθανάτοισιν ἀπήχθετο πᾶσι θεοῖσιν·{l]
[l [n}6.141{]}οὐδʼ ἂν ἐγὼ μακάρεσσι θεοῖς ἐθέλοιμι μάχεσθαι.{l]
[l [n}6.142{]}εἰ δέ τίς ἐσσι βροτῶν οἳ ἀρούρης καρπὸν ἔδουσιν,{l]
[l [n}6.143{]}ἆσσον ἴθʼ ὥς κεν θᾶσσον ὀλέθρου πείραθʼ ἵκηαι.{l]{q]{para]
[para}[l [n}6.144{]}τὸν δʼ αὖθʼ Ἱππολόχοιο προσηύδα φαίδιμος υἱός·{l]
[q}[l [n}6.145{]}Τυδεΐδη μεγάθυμε τί ἢ γενεὴν ἐρεείνεις;{l]
[l [n}6.146{]}οἵη περ φύλλων γενεὴ τοίη δὲ καὶ ἀνδρῶν.{l]
[l [n}6.147{]}φύλλα τὰ μέν τʼ ἄνεμος χαμάδις χέει, ἄλλα δέ θʼ ὕλη{l]
[l [n}6.148{]}τηλεθόωσα φύει, ἔαρος δʼ ἐπιγίγνεται ὥρη·{l]
[l [n}6.149{]}ὣς ἀνδρῶν γενεὴ ἣ μὲν φύει ἣ δʼ ἀπολήγει.{l]
[l [n}6.150{]}εἰ δʼ ἐθέλεις καὶ ταῦτα δαήμεναι ὄφρʼ ἐῢ εἰδῇς{l]
[l [n}6.151{]}ἡμετέρην γενεήν, πολλοὶ δέ μιν ἄνδρες ἴσασιν·{l]
[l [n}6.152{]}ἔστι πόλις Ἐφύρη μυχῷ Ἄργεος ἱπποβότοιο,{l]
[l [n}6.153{]}ἔνθα δὲ Σίσυφος ἔσκεν, ὃ κέρδιστος γένετʼ ἀνδρῶν,{l]
[l [n}6.154{]}Σίσυφος Αἰολίδης· ὃ δʼ ἄρα Γλαῦκον τέκεθʼ υἱόν,{l]
[l [n}6.155{]}αὐτὰρ Γλαῦκος τίκτεν ἀμύμονα Βελλεροφόντην·{l]
[l [n}6.156{]}τῷ δὲ θεοὶ κάλλός τε καὶ ἠνορέην ἐρατεινὴν{l]
[l [n}6.157{]}ὤπασαν· αὐτάρ οἱ Προῖτος κακὰ μήσατο θυμῷ,{l]
[l [n}6.158{]}ὅς ῥʼ ἐκ δήμου ἔλασσεν, ἐπεὶ πολὺ φέρτερος ἦεν,{l]
[l [n}6.159{]}Ἀργείων· Ζεὺς γάρ οἱ ὑπὸ σκήπτρῳ ἐδάμασσε.{l]
[l [n}6.160{]}τῷ δὲ γυνὴ Προίτου ἐπεμήνατο δῖʼ Ἄντεια{l]
[l [n}6.161{]}κρυπταδίῃ φιλότητι μιγήμεναι· ἀλλὰ τὸν οὔ τι{l]
[l [n}6.162{]}πεῖθʼ ἀγαθὰ φρονέοντα δαΐφρονα Βελλεροφόντην.{l]
[l [n}6.163{]}ἣ δὲ ψευσαμένη Προῖτον βασιλῆα προσηύδα·{l]
[q}[l [n}6.164{]}τεθναίης ὦ Προῖτʼ, ἢ κάκτανε Βελλεροφόντην,{l]
[l [n}6.165{]}ὅς μʼ ἔθελεν φιλότητι μιγήμεναι οὐκ ἐθελούσῃ.{l]{q][l [n}6.166{]}ὣς φάτο, τὸν δὲ ἄνακτα χόλος λάβεν οἷον ἄκουσε·{l]
[l [n}6.167{]}κτεῖναι μέν ῥʼ ἀλέεινε, σεβάσσατο γὰρ τό γε θυμῷ,{l]
[l [n}6.168{]}πέμπε δέ μιν Λυκίην δέ, πόρεν δʼ ὅ γε σήματα λυγρὰ{l]
[l [n}6.169{]}γράψας ἐν πίνακι πτυκτῷ θυμοφθόρα πολλά,{l]
[l [n}6.170{]}δεῖξαι δʼ ἠνώγειν ᾧ πενθερῷ ὄφρʼ ἀπόλοιτο.{l]
[l [n}6.171{]}αὐτὰρ ὁ βῆ Λυκίην δὲ θεῶν ὑπʼ ἀμύμονι πομπῇ.{l]
[l [n}6.172{]}ἀλλʼ ὅτε δὴ Λυκίην ἷξε Ξάνθόν τε ῥέοντα,{l]
[l [n}6.173{]}προφρονέως μιν τῖεν ἄναξ Λυκίης εὐρείης·{l]
[l [n}6.174{]}ἐννῆμαρ ξείνισσε καὶ ἐννέα βοῦς ἱέρευσεν.{l]
[l [n}6.175{]}ἀλλʼ ὅτε δὴ δεκάτη ἐφάνη ῥοδοδάκτυλος Ἠὼς{l]
[l [n}6.176{]}καὶ τότε μιν ἐρέεινε καὶ ᾔτεε σῆμα ἰδέσθαι{l]
[l [n}6.177{]}ὅττί ῥά οἱ γαμβροῖο πάρα Προίτοιο φέροιτο.{l]
[l [n}6.178{]}αὐτὰρ ἐπεὶ δὴ σῆμα κακὸν παρεδέξατο γαμβροῦ,{l]
[l [n}6.179{]}πρῶτον μέν ῥα Χίμαιραν ἀμαιμακέτην ἐκέλευσε{l]
[l [n}6.180{]}πεφνέμεν· ἣ δʼ ἄρʼ ἔην θεῖον γένος οὐδʼ ἀνθρώπων,{l]
[l [n}6.181{]}πρόσθε λέων, ὄπιθεν δὲ δράκων, μέσση δὲ χίμαιρα,{l]
[l [n}6.182{]}δεινὸν ἀποπνείουσα πυρὸς μένος αἰθομένοιο,{l]
[l [n}6.183{]}καὶ τὴν μὲν κατέπεφνε θεῶν τεράεσσι πιθήσας.{l]
[l [n}6.184{]}δεύτερον αὖ Σολύμοισι μαχέσσατο κυδαλίμοισι·{l]
[l [n}6.185{]}καρτίστην δὴ τήν γε μάχην φάτο δύμεναι ἀνδρῶν.{l]
[l [n}6.186{]}τὸ τρίτον αὖ κατέπεφνεν Ἀμαζόνας ἀντιανείρας.{l]
[l [n}6.187{]}τῷ δʼ ἄρʼ ἀνερχομένῳ πυκινὸν δόλον ἄλλον ὕφαινε·{l]
[l [n}6.188{]}κρίνας ἐκ Λυκίης εὐρείης φῶτας ἀρίστους{l]
[l [n}6.189{]}εἷσε λόχον· τοὶ δʼ οὔ τι πάλιν οἶκον δὲ νέοντο·{l]
[l [n}6.190{]}πάντας γὰρ κατέπεφνεν ἀμύμων Βελλεροφόντης.{l]
[l [n}6.191{]}ἀλλʼ ὅτε δὴ γίγνωσκε θεοῦ γόνον ἠῢν ἐόντα{l]
[l [n}6.192{]}αὐτοῦ μιν κατέρυκε, δίδου δʼ ὅ γε θυγατέρα ἥν,{l]
[l [n}6.193{]}δῶκε δέ οἱ τιμῆς βασιληΐδος ἥμισυ πάσης·{l]
[l [n}6.194{]}καὶ μέν οἱ Λύκιοι τέμενος τάμον ἔξοχον ἄλλων{l]
[l [n}6.195{]}καλὸν φυταλιῆς καὶ ἀρούρης, ὄφρα νέμοιτο.{l]
[l [n}6.196{]}ἣ δʼ ἔτεκε τρία τέκνα δαΐφρονι Βελλεροφόντῃ{l]
[l [n}6.197{]}Ἴσανδρόν τε καὶ Ἱππόλοχον καὶ Λαοδάμειαν.{l]
[l [n}6.198{]}Λαοδαμείῃ μὲν παρελέξατο μητίετα Ζεύς,{l]
[l [n}6.199{]}ἣ δʼ ἔτεκʼ ἀντίθεον Σαρπηδόνα χαλκοκορυστήν.{l]
[l [n}6.200{]}ἀλλʼ ὅτε δὴ καὶ κεῖνος ἀπήχθετο πᾶσι θεοῖσιν,{l]
[l [n}6.201{]}ἤτοι ὃ κὰπ πεδίον τὸ Ἀλήϊον οἶος ἀλᾶτο{l]
[l [n}6.202{]}ὃν θυμὸν κατέδων, πάτον ἀνθρώπων ἀλεείνων·{l]
[l [n}6.203{]}Ἴσανδρον δέ οἱ υἱὸν Ἄρης ἆτος πολέμοιο{l]
[l [n}6.204{]}μαρνάμενον Σολύμοισι κατέκτανε κυδαλίμοισι·{l]
[l [n}6.205{]}τὴν δὲ χολωσαμένη χρυσήνιος Ἄρτεμις ἔκτα.{l]
[l [n}6.206{]}Ἱππόλοχος δέ μʼ ἔτικτε, καὶ ἐκ τοῦ φημι γενέσθαι·{l]
[l [n}6.207{]}πέμπε δέ μʼ ἐς Τροίην, καί μοι μάλα πόλλʼ ἐπέτελλεν{l]
[l [n}6.208{]}αἰὲν ἀριστεύειν καὶ ὑπείροχον ἔμμεναι ἄλλων,{l]
[l [n}6.209{]}μηδὲ γένος πατέρων αἰσχυνέμεν, οἳ μέγʼ ἄριστοι{l]
[l [n}6.210{]}ἔν τʼ Ἐφύρῃ ἐγένοντο καὶ ἐν Λυκίῃ εὐρείῃ.{l]
[l [n}6.211{]}ταύτης τοι γενεῆς τε καὶ αἵματος εὔχομαι εἶναι.{l]{q]{para]
[para}[l [n}6.212{]}ὣς φάτο, γήθησεν δὲ βοὴν ἀγαθὸς Διομήδης·{l]
[l [n}6.213{]}ἔγχος μὲν κατέπηξεν ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}6.214{]}αὐτὰρ ὃ μειλιχίοισι προσηύδα ποιμένα λαῶν·{l]
[q}[l [n}6.215{]}ἦ ῥά νύ μοι ξεῖνος πατρώϊός ἐσσι παλαιός·{l]
[l [n}6.216{]}Οἰνεὺς γάρ ποτε δῖος ἀμύμονα Βελλεροφόντην{l]
[l [n}6.217{]}ξείνισʼ ἐνὶ μεγάροισιν ἐείκοσιν ἤματʼ ἐρύξας·{l]
[l [n}6.218{]}οἳ δὲ καὶ ἀλλήλοισι πόρον ξεινήϊα καλά·{l]
[l [n}6.219{]}Οἰνεὺς μὲν ζωστῆρα δίδου φοίνικι φαεινόν,{l]
[l [n}6.220{]}Βελλεροφόντης δὲ χρύσεον δέπας ἀμφικύπελλον{l]
[l [n}6.221{]}καί μιν ἐγὼ κατέλειπον ἰὼν ἐν δώμασʼ ἐμοῖσι.{l]
[l [n}6.222{]}Τυδέα δʼ οὐ μέμνημαι, ἐπεί μʼ ἔτι τυτθὸν ἐόντα{l]
[l [n}6.223{]}κάλλιφʼ, ὅτʼ ἐν Θήβῃσιν ἀπώλετο λαὸς Ἀχαιῶν.{l]
[l [n}6.224{]}τὼ νῦν σοὶ μὲν ἐγὼ ξεῖνος φίλος Ἄργεϊ μέσσῳ{l]
[l [n}6.225{]}εἰμί, σὺ δʼ ἐν Λυκίῃ ὅτε κεν τῶν δῆμον ἵκωμαι.{l]
[l [n}6.226{]}ἔγχεα δʼ ἀλλήλων ἀλεώμεθα καὶ διʼ ὁμίλου·{l]
[l [n}6.227{]}πολλοὶ μὲν γὰρ ἐμοὶ Τρῶες κλειτοί τʼ ἐπίκουροι{l]
[l [n}6.228{]}κτείνειν ὅν κε θεός γε πόρῃ καὶ ποσσὶ κιχείω,{l]
[l [n}6.229{]}πολλοὶ δʼ αὖ σοὶ Ἀχαιοὶ ἐναιρέμεν ὅν κε δύνηαι.{l]
[l [n}6.230{]}τεύχεα δʼ ἀλλήλοις ἐπαμείψομεν, ὄφρα καὶ οἵδε{l]
[l [n}6.231{]}γνῶσιν ὅτι ξεῖνοι πατρώϊοι εὐχόμεθʼ εἶναι.{l]{q]{para]
[para}[l [n}6.232{]}ὣς ἄρα φωνήσαντε καθʼ ἵππων ἀΐξαντε{l]
[l [n}6.233{]}χεῖράς τʼ ἀλλήλων λαβέτην καὶ πιστώσαντο·{l]
[l [n}6.234{]}ἔνθʼ αὖτε Γλαύκῳ Κρονίδης φρένας ἐξέλετο Ζεύς,{l]
[l [n}6.235{]}ὃς πρὸς Τυδεΐδην Διομήδεα τεύχεʼ ἄμειβε{l]
[l [n}6.236{]}χρύσεα χαλκείων, ἑκατόμβοιʼ ἐννεαβοίων.{l]{para]
[para}[l [n}6.237{]}Ἕκτωρ δʼ ὡς Σκαιάς τε πύλας καὶ φηγὸν ἵκανεν,{l]
[l [n}6.238{]}ἀμφʼ ἄρα μιν Τρώων ἄλοχοι θέον ἠδὲ θύγατρες{l]
[l [n}6.239{]}εἰρόμεναι παῖδάς τε κασιγνήτους τε ἔτας τε{l]
[l [n}6.240{]}καὶ πόσιας· ὃ δʼ ἔπειτα θεοῖς εὔχεσθαι ἀνώγει{l]
[l [n}6.241{]}πάσας ἑξείης· πολλῇσι δὲ κήδεʼ ἐφῆπτο.{l]{para]
[para}[l [n}6.242{]}ἀλλʼ ὅτε δὴ Πριάμοιο δόμον περικαλλέʼ ἵκανε{l]
[l [n}6.243{]}ξεστῇς αἰθούσῃσι τετυγμένον· αὐτὰρ ἐν αὐτῷ{l]
[l [n}6.244{]}πεντήκοντʼ ἔνεσαν θάλαμοι ξεστοῖο λίθοιο{l]
[l [n}6.245{]}πλησίον ἀλλήλων δεδμημένοι, ἔνθα δὲ παῖδες{l]
[l [n}6.246{]}κοιμῶντο Πριάμοιο παρὰ μνηστῇς ἀλόχοισι,{l]
[l [n}6.247{]}κουράων δʼ ἑτέρωθεν ἐναντίοι ἔνδοθεν αὐλῆς{l]
[l [n}6.248{]}δώδεκʼ ἔσαν τέγεοι θάλαμοι ξεστοῖο λίθοιο{l]
[l [n}6.249{]}πλησίον ἀλλήλων δεδμημένοι, ἔνθα δὲ γαμβροὶ{l]
[l [n}6.250{]}κοιμῶντο Πριάμοιο παρʼ αἰδοίῃς ἀλόχοισιν·{l]
[l [n}6.251{]}ἔνθά οἱ ἠπιόδωρος ἐναντίη ἤλυθε μήτηρ{l]
[l [n}6.252{]}Λαοδίκην ἐσάγουσα θυγατρῶν εἶδος ἀρίστην·{l]
[l [n}6.253{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}6.254{]}τέκνον τίπτε λιπὼν πόλεμον θρασὺν εἰλήλουθας;{l]
[l [n}6.255{]}ἦ μάλα δὴ τείρουσι δυσώνυμοι υἷες Ἀχαιῶν{l]
[l [n}6.256{]}μαρνάμενοι περὶ ἄστυ· σὲ δʼ ἐνθάδε θυμὸς ἀνῆκεν{l]
[l [n}6.257{]}ἐλθόντʼ ἐξ ἄκρης πόλιος Διὶ χεῖρας ἀνασχεῖν.{l]
[l [n}6.258{]}ἀλλὰ μένʼ ὄφρά κέ τοι μελιηδέα οἶνον ἐνείκω,{l]
[l [n}6.259{]}ὡς σπείσῃς Διὶ πατρὶ καὶ ἄλλοις ἀθανάτοισι{l]
[l [n}6.260{]}πρῶτον, ἔπειτα δὲ καὐτὸς ὀνήσεαι αἴ κε πίῃσθα.{l]
[l [n}6.261{]}ἀνδρὶ δὲ κεκμηῶτι μένος μέγα οἶνος ἀέξει,{l]
[l [n}6.262{]}ὡς τύνη κέκμηκας ἀμύνων σοῖσιν ἔτῃσι.{l]{q]{para]
[para}[l [n}6.263{]}τὴν δʼ ἠμείβετʼ ἔπειτα μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}6.264{]}μή μοι οἶνον ἄειρε μελίφρονα πότνια μῆτερ,{l]
[l [n}6.265{]}μή μʼ ἀπογυιώσῃς μένεος, ἀλκῆς τε λάθωμαι·{l]
[l [n}6.266{]}χερσὶ δʼ ἀνίπτοισιν Διὶ λείβειν αἴθοπα οἶνον{l]
[l [n}6.267{]}ἅζομαι· οὐδέ πῃ ἔστι κελαινεφέϊ Κρονίωνι{l]
[l [n}6.268{]}αἵματι καὶ λύθρῳ πεπαλαγμένον εὐχετάασθαι.{l]
[l [n}6.269{]}ἀλλὰ σὺ μὲν πρὸς νηὸν Ἀθηναίης ἀγελείης{l]
[l [n}6.270{]}ἔρχεο σὺν θυέεσσιν ἀολλίσσασα γεραιάς·{l]
[l [n}6.271{]}πέπλον δʼ, ὅς τίς τοι χαριέστατος ἠδὲ μέγιστος{l]
[l [n}6.272{]}ἔστιν ἐνὶ μεγάρῳ καί τοι πολὺ φίλτατος αὐτῇ,{l]
[l [n}6.273{]}τὸν θὲς Ἀθηναίης ἐπὶ γούνασιν ἠϋκόμοιο,{l]
[l [n}6.274{]}καί οἱ ὑποσχέσθαι δυοκαίδεκα βοῦς ἐνὶ νηῷ{l]
[l [n}6.275{]}ἤνις ἠκέστας ἱερευσέμεν, αἴ κʼ ἐλεήσῃ{l]
[l [n}6.276{]}ἄστύ τε καὶ Τρώων ἀλόχους καὶ νήπια τέκνα,{l]
[l [n}6.277{]}αἴ κεν Τυδέος υἱὸν ἀπόσχῃ Ἰλίου ἱρῆς{l]
[l [n}6.278{]}ἄγριον αἰχμητὴν κρατερὸν μήστωρα φόβοιο.{l]
[l [n}6.279{]}ἀλλὰ σὺ μὲν πρὸς νηὸν Ἀθηναίης ἀγελείης{l]
[l [n}6.280{]}ἔρχευ, ἐγὼ δὲ Πάριν μετελεύσομαι ὄφρα καλέσσω{l]
[l [n}6.281{]}αἴ κʼ ἐθέλῃσʼ εἰπόντος ἀκουέμεν· ὥς κέ οἱ αὖθι{l]
[l [n}6.282{]}γαῖα χάνοι· μέγα γάρ μιν Ὀλύμπιος ἔτρεφε πῆμα{l]
[l [n}6.283{]}Τρωσί τε καὶ Πριάμῳ μεγαλήτορι τοῖό τε παισίν.{l]
[l [n}6.284{]}εἰ κεῖνόν γε ἴδοιμι κατελθόντʼ Ἄϊδος εἴσω{l]
[l [n}6.285{]}φαίην κε φρένʼ ἀτέρπου ὀϊζύος ἐκλελαθέσθαι.{l]{q]{para]
[para}[l [n}6.286{]}ὣς ἔφαθʼ, ἣ δὲ μολοῦσα ποτὶ μέγαρʼ ἀμφιπόλοισι{l]
[l [n}6.287{]}κέκλετο· ταὶ δʼ ἄρʼ ἀόλλισσαν κατὰ ἄστυ γεραιάς.{l]
[l [n}6.288{]}αὐτὴ δʼ ἐς θάλαμον κατεβήσετο κηώεντα,{l]
[l [n}6.289{]}ἔνθʼ ἔσάν οἱ πέπλοι παμποίκιλα ἔργα γυναικῶν{l]
[l [n}6.290{]}Σιδονίων, τὰς αὐτὸς Ἀλέξανδρος θεοειδὴς{l]
[l [n}6.291{]}ἤγαγε Σιδονίηθεν ἐπιπλὼς εὐρέα πόντον,{l]
[l [n}6.292{]}τὴν ὁδὸν ἣν Ἑλένην περ ἀνήγαγεν εὐπατέρειαν·{l]
[l [n}6.293{]}τῶν ἕνʼ ἀειραμένη Ἑκάβη φέρε δῶρον Ἀθήνῃ,{l]
[l [n}6.294{]}ὃς κάλλιστος ἔην ποικίλμασιν ἠδὲ μέγιστος,{l]
[l [n}6.295{]}ἀστὴρ δʼ ὣς ἀπέλαμπεν· ἔκειτο δὲ νείατος ἄλλων.{l]
[l [n}6.296{]}βῆ δʼ ἰέναι, πολλαὶ δὲ μετεσσεύοντο γεραιαί.{l]{para]
[para}[l [n}6.297{]}αἱ δʼ ὅτε νηὸν ἵκανον Ἀθήνης ἐν πόλει ἄκρῃ,{l]
[l [n}6.298{]}τῇσι θύρας ὤϊξε Θεανὼ καλλιπάρῃος{l]
[l [n}6.299{]}Κισσηῒς ἄλοχος Ἀντήνορος ἱπποδάμοιο·{l]
[l [n}6.300{]}τὴν γὰρ Τρῶες ἔθηκαν Ἀθηναίης ἱέρειαν.{l]
[l [n}6.301{]}αἳ δʼ ὀλολυγῇ πᾶσαι Ἀθήνῃ χεῖρας ἀνέσχον·{l]
[l [n}6.302{]}ἣ δʼ ἄρα πέπλον ἑλοῦσα Θεανὼ καλλιπάρῃος{l]
[l [n}6.303{]}θῆκεν Ἀθηναίης ἐπὶ γούνασιν ἠϋκόμοιο,{l]
[l [n}6.304{]}εὐχομένη δʼ ἠρᾶτο Διὸς κούρῃ μεγάλοιο·{l]
[q}[l [n}6.305{]}πότνιʼ Ἀθηναίη ἐρυσίπτολι δῖα θεάων{l]
[l [n}6.306{]}ἆξον δὴ ἔγχος Διομήδεος, ἠδὲ καὶ αὐτὸν{l]
[l [n}6.307{]}πρηνέα δὸς πεσέειν Σκαιῶν προπάροιθε πυλάων,{l]
[l [n}6.308{]}ὄφρά τοι αὐτίκα νῦν δυοκαίδεκα βοῦς ἐνὶ νηῷ{l]
[l [n}6.309{]}ἤνις ἠκέστας ἱερεύσομεν, αἴ κʼ ἐλεήσῃς{l]
[l [n}6.310{]}ἄστύ τε καὶ Τρώων ἀλόχους καὶ νήπια τέκνα.{l]{q]{para]
[para}[l [n}6.311{]}ὣς ἔφατʼ εὐχομένη, ἀνένευε δὲ Παλλὰς Ἀθήνη.{l]
[l [n}6.312{]}ὣς αἳ μέν ῥʼ εὔχοντο Διὸς κούρῃ μεγάλοιο,{l]
[l [n}6.313{]}Ἕκτωρ δὲ πρὸς δώματʼ Ἀλεξάνδροιο βεβήκει{l]
[l [n}6.314{]}καλά, τά ῥʼ αὐτὸς ἔτευξε σὺν ἀνδράσιν οἳ τότʼ ἄριστοι{l]
[l [n}6.315{]}ἦσαν ἐνὶ Τροίῃ ἐριβώλακι τέκτονες ἄνδρες,{l]
[l [n}6.316{]}οἵ οἱ ἐποίησαν θάλαμον καὶ δῶμα καὶ αὐλὴν{l]
[l [n}6.317{]}ἐγγύθι τε Πριάμοιο καὶ Ἕκτορος ἐν πόλει ἄκρῃ.{l]
[l [n}6.318{]}ἔνθʼ Ἕκτωρ εἰσῆλθε Διῒ φίλος, ἐν δʼ ἄρα χειρὶ{l]
[l [n}6.319{]}ἔγχος ἔχʼ ἑνδεκάπηχυ· πάροιθε δὲ λάμπετο δουρὸς{l]
[l [n}6.320{]}αἰχμὴ χαλκείη, περὶ δὲ χρύσεος θέε πόρκης.{l]
[l [n}6.321{]}τὸν δʼ εὗρʼ ἐν θαλάμῳ περικαλλέα τεύχεʼ ἕποντα{l]
[l [n}6.322{]}ἀσπίδα καὶ θώρηκα, καὶ ἀγκύλα τόξʼ ἁφόωντα·{l]
[l [n}6.323{]}Ἀργείη δʼ Ἑλένη μετʼ ἄρα δμῳῇσι γυναιξὶν{l]
[l [n}6.324{]}ἧστο καὶ ἀμφιπόλοισι περικλυτὰ ἔργα κέλευε.{l]
[l [n}6.325{]}τὸν δʼ Ἕκτωρ νείκεσσεν ἰδὼν αἰσχροῖς ἐπέεσσι·{l]
[q}[l [n}6.326{]}δαιμόνιʼ οὐ μὲν καλὰ χόλον τόνδʼ ἔνθεο θυμῷ,{l]
[l [n}6.327{]}λαοὶ μὲν φθινύθουσι περὶ πτόλιν αἰπύ τε τεῖχος{l]
[l [n}6.328{]}μαρνάμενοι· σέο δʼ εἵνεκʼ ἀϋτή τε πτόλεμός τε{l]
[l [n}6.329{]}ἄστυ τόδʼ ἀμφιδέδηε· σὺ δʼ ἂν μαχέσαιο καὶ ἄλλῳ,{l]
[l [n}6.330{]}ὅν τινά που μεθιέντα ἴδοις στυγεροῦ πολέμοιο.{l]
[l [n}6.331{]}ἀλλʼ ἄνα μὴ τάχα ἄστυ πυρὸς δηΐοιο θέρηται.{l]{q]{para]
[para}[l [n}6.332{]}τὸν δʼ αὖτε προσέειπεν Ἀλέξανδρος θεοειδής·{l]
[q}[l [n}6.333{]}Ἕκτορ ἐπεί με κατʼ αἶσαν ἐνείκεσας οὐδʼ ὑπὲρ αἶσαν,{l]
[l [n}6.334{]}τοὔνεκά τοι ἐρέω· σὺ δὲ σύνθεο καί μευ ἄκουσον·{l]
[l [n}6.335{]}οὔ τοι ἐγὼ Τρώων τόσσον χόλῳ οὐδὲ νεμέσσι{l]
[l [n}6.336{]}ἥμην ἐν θαλάμῳ, ἔθελον δʼ ἄχεϊ προτραπέσθαι.{l]
[l [n}6.337{]}νῦν δέ με παρειποῦσʼ ἄλοχος μαλακοῖς ἐπέεσσιν{l]
[l [n}6.338{]}ὅρμησʼ ἐς πόλεμον· δοκέει δέ μοι ὧδε καὶ αὐτῷ{l]
[l [n}6.339{]}λώϊον ἔσσεσθαι· νίκη δʼ ἐπαμείβεται ἄνδρας.{l]
[l [n}6.340{]}ἀλλʼ ἄγε νῦν ἐπίμεινον, Ἀρήϊα τεύχεα δύω·{l]
[l [n}6.341{]}ἢ ἴθʼ, ἐγὼ δὲ μέτειμι· κιχήσεσθαι δέ σʼ ὀΐω.{l]{q]{para]
[para}[l [n}6.342{]}ὣς φάτο, τὸν δʼ οὔ τι προσέφη κορυθαίολος Ἕκτωρ·{l]
[l [n}6.343{]}τὸν δʼ Ἑλένη μύθοισι προσηύδα μειλιχίοισι·{l]
[q}[l [n}6.344{]}δᾶερ ἐμεῖο κυνὸς κακομηχάνου ὀκρυοέσσης,{l]
[l [n}6.345{]}ὥς μʼ ὄφελʼ ἤματι τῷ ὅτε με πρῶτον τέκε μήτηρ{l]
[l [n}6.346{]}οἴχεσθαι προφέρουσα κακὴ ἀνέμοιο θύελλα{l]
[l [n}6.347{]}εἰς ὄρος ἢ εἰς κῦμα πολυφλοίσβοιο θαλάσσης,{l]
[l [n}6.348{]}ἔνθά με κῦμʼ ἀπόερσε πάρος τάδε ἔργα γενέσθαι.{l]
[l [n}6.349{]}αὐτὰρ ἐπεὶ τάδε γʼ ὧδε θεοὶ κακὰ τεκμήραντο,{l]
[l [n}6.350{]}ἀνδρὸς ἔπειτʼ ὤφελλον ἀμείνονος εἶναι ἄκοιτις,{l]
[l [n}6.351{]}ὃς ᾔδη νέμεσίν τε καὶ αἴσχεα πόλλʼ ἀνθρώπων.{l]
[l [n}6.352{]}τούτῳ δʼ οὔτʼ ἂρ νῦν φρένες ἔμπεδοι οὔτʼ ἄρʼ ὀπίσσω{l]
[l [n}6.353{]}ἔσσονται· τὼ καί μιν ἐπαυρήσεσθαι ὀΐω.{l]
[l [n}6.354{]}ἀλλʼ ἄγε νῦν εἴσελθε καὶ ἕζεο τῷδʼ ἐπὶ δίφρῳ{l]
[l [n}6.355{]}δᾶερ, ἐπεί σε μάλιστα πόνος φρένας ἀμφιβέβηκεν{l]
[l [n}6.356{]}εἵνεκʼ ἐμεῖο κυνὸς καὶ Ἀλεξάνδρου ἕνεκʼ ἄτης,{l]
[l [n}6.357{]}οἷσιν ἐπὶ Ζεὺς θῆκε κακὸν μόρον, ὡς καὶ ὀπίσσω{l]
[l [n}6.358{]}ἀνθρώποισι πελώμεθʼ ἀοίδιμοι ἐσσομένοισι.{l]{q]{para]
[para}[l [n}6.359{]}τὴν δʼ ἠμείβετʼ ἔπειτα μέγας κορυθαίολος Ἕκτωρ{l]
[q}[l [n}6.360{]}μή με κάθιζʼ Ἑλένη φιλέουσά περ· οὐδέ με πείσεις·{l]
[l [n}6.361{]}ἤδη γάρ μοι θυμὸς ἐπέσσυται ὄφρʼ ἐπαμύνω{l]
[l [n}6.362{]}Τρώεσσʼ, οἳ μέγʼ ἐμεῖο ποθὴν ἀπεόντος ἔχουσιν.{l]
[l [n}6.363{]}ἀλλὰ σύ γʼ ὄρνυθι τοῦτον, ἐπειγέσθω δὲ καὶ αὐτός,{l]
[l [n}6.364{]}ὥς κεν ἔμʼ ἔντοσθεν πόλιος καταμάρψῃ ἐόντα.{l]
[l [n}6.365{]}καὶ γὰρ ἐγὼν οἶκον δὲ ἐλεύσομαι ὄφρα ἴδωμαι{l]
[l [n}6.366{]}οἰκῆας ἄλοχόν τε φίλην καὶ νήπιον υἱόν.{l]
[l [n}6.367{]}οὐ γὰρ οἶδʼ εἰ ἔτι σφιν ὑπότροπος ἵξομαι αὖτις,{l]
[l [n}6.368{]}ἦ ἤδη μʼ ὑπὸ χερσὶ θεοὶ δαμόωσιν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}6.369{]}ὣς ἄρα φωνήσας ἀπέβη κορυθαίολος Ἕκτωρ·{l]
[l [n}6.370{]}αἶψα δʼ ἔπειθʼ ἵκανε δόμους εὖ ναιετάοντας,{l]
[l [n}6.371{]}οὐδʼ εὗρʼ Ἀνδρομάχην λευκώλενον ἐν μεγάροισιν,{l]
[l [n}6.372{]}ἀλλʼ ἥ γε ξὺν παιδὶ καὶ ἀμφιπόλῳ ἐϋπέπλῳ{l]
[l [n}6.373{]}πύργῳ ἐφεστήκει γοόωσά τε μυρομένη τε.{l]
[l [n}6.374{]}Ἕκτωρ δʼ ὡς οὐκ ἔνδον ἀμύμονα τέτμεν ἄκοιτιν{l]
[l [n}6.375{]}ἔστη ἐπʼ οὐδὸν ἰών, μετὰ δὲ δμῳῇσιν ἔειπεν·{l]
[q}[l [n}6.376{]}εἰ δʼ ἄγε μοι δμῳαὶ νημερτέα μυθήσασθε·{l]
[l [n}6.377{]}πῇ ἔβη Ἀνδρομάχη λευκώλενος ἐκ μεγάροιο;{l]
[l [n}6.378{]}ἠέ πῃ ἐς γαλόων ἢ εἰνατέρων ἐϋπέπλων{l]
[l [n}6.379{]}ἢ ἐς Ἀθηναίης ἐξοίχεται, ἔνθά περ ἄλλαι{l]
[l [n}6.380{]}Τρῳαὶ ἐϋπλόκαμοι δεινὴν θεὸν ἱλάσκονται;{l]{q]{para]
[para}[l [n}6.381{]}τὸν δʼ αὖτʼ ὀτρηρὴ ταμίη πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}6.382{]}Ἕκτορ ἐπεὶ μάλʼ ἄνωγας ἀληθέα μυθήσασθαι,{l]
[l [n}6.383{]}οὔτέ πῃ ἐς γαλόων οὔτʼ εἰνατέρων ἐϋπέπλων{l]
[l [n}6.384{]}οὔτʼ ἐς Ἀθηναίης ἐξοίχεται, ἔνθά περ ἄλλαι{l]
[l [n}6.385{]}Τρῳαὶ ἐϋπλόκαμοι δεινὴν θεὸν ἱλάσκονται,{l]
[l [n}6.386{]}ἀλλʼ ἐπὶ πύργον ἔβη μέγαν Ἰλίου, οὕνεκʼ ἄκουσε{l]
[l [n}6.387{]}τείρεσθαι Τρῶας, μέγα δὲ κράτος εἶναι Ἀχαιῶν.{l]
[l [n}6.388{]}ἣ μὲν δὴ πρὸς τεῖχος ἐπειγομένη ἀφικάνει{l]
[l [n}6.389{]}μαινομένῃ ἐϊκυῖα· φέρει δʼ ἅμα παῖδα τιθήνη.{l]{q]{para]
[para}[l [n}6.390{]}ἦ ῥα γυνὴ ταμίη, ὃ δʼ ἀπέσσυτο δώματος Ἕκτωρ{l]
[l [n}6.391{]}τὴν αὐτὴν ὁδὸν αὖτις ἐϋκτιμένας κατʼ ἀγυιάς.{l]
[l [n}6.392{]}εὖτε πύλας ἵκανε διερχόμενος μέγα ἄστυ{l]
[l [n}6.393{]}Σκαιάς, τῇ ἄρʼ ἔμελλε διεξίμεναι πεδίον δέ,{l]
[l [n}6.394{]}ἔνθʼ ἄλοχος πολύδωρος ἐναντίη ἦλθε θέουσα{l]
[l [n}6.395{]}Ἀνδρομάχη θυγάτηρ μεγαλήτορος Ἠετίωνος{l]
[l [n}6.396{]}Ἠετίων ὃς ἔναιεν ὑπὸ Πλάκῳ ὑληέσσῃ{l]
[l [n}6.397{]}Θήβῃ Ὑποπλακίῃ Κιλίκεσσʼ ἄνδρεσσιν ἀνάσσων·{l]
[l [n}6.398{]}τοῦ περ δὴ θυγάτηρ ἔχεθʼ Ἕκτορι χαλκοκορυστῇ.{l]
[l [n}6.399{]}ἥ οἱ ἔπειτʼ ἤντησʼ, ἅμα δʼ ἀμφίπολος κίεν αὐτῇ{l]
[l [n}6.400{]}παῖδʼ ἐπὶ κόλπῳ ἔχουσʼ ἀταλάφρονα νήπιον αὔτως{l]
[l [n}6.401{]}Ἑκτορίδην ἀγαπητὸν ἀλίγκιον ἀστέρι καλῷ,{l]
[l [n}6.402{]}τόν ῥʼ Ἕκτωρ καλέεσκε Σκαμάνδριον, αὐτὰρ οἱ ἄλλοι{l]
[l [n}6.403{]}Ἀστυάνακτʼ· οἶος γὰρ ἐρύετο Ἴλιον Ἕκτωρ.{l]
[l [n}6.404{]}ἤτοι ὃ μὲν μείδησεν ἰδὼν ἐς παῖδα σιωπῇ·{l]
[l [n}6.405{]}Ἀνδρομάχη δέ οἱ ἄγχι παρίστατο δάκρυ χέουσα,{l]
[l [n}6.406{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}6.407{]}δαιμόνιε φθίσει σε τὸ σὸν μένος, οὐδʼ ἐλεαίρεις{l]
[l [n}6.408{]}παῖδά τε νηπίαχον καὶ ἔμʼ ἄμμορον, ἣ τάχα χήρη{l]
[l [n}6.409{]}σεῦ ἔσομαι· τάχα γάρ σε κατακτανέουσιν Ἀχαιοὶ{l]
[l [n}6.410{]}πάντες ἐφορμηθέντες· ἐμοὶ δέ κε κέρδιον εἴη{l]
[l [n}6.411{]}σεῦ ἀφαμαρτούσῃ χθόνα δύμεναι· οὐ γὰρ ἔτʼ ἄλλη{l]
[l [n}6.412{]}ἔσται θαλπωρὴ ἐπεὶ ἂν σύ γε πότμον ἐπίσπῃς{l]
[l [n}6.413{]}ἀλλʼ ἄχεʼ· οὐδέ μοι ἔστι πατὴρ καὶ πότνια μήτηρ.{l]
[l [n}6.414{]}ἤτοι γὰρ πατέρʼ ἁμὸν ἀπέκτανε δῖος Ἀχιλλεύς,{l]
[l [n}6.415{]}ἐκ δὲ πόλιν πέρσεν Κιλίκων εὖ ναιετάουσαν{l]
[l [n}6.416{]}Θήβην ὑψίπυλον· κατὰ δʼ ἔκτανεν Ἠετίωνα,{l]
[l [n}6.417{]}οὐδέ μιν ἐξενάριξε, σεβάσσατο γὰρ τό γε θυμῷ,{l]
[l [n}6.418{]}ἀλλʼ ἄρα μιν κατέκηε σὺν ἔντεσι δαιδαλέοισιν{l]
[l [n}6.419{]}ἠδʼ ἐπὶ σῆμʼ ἔχεεν· περὶ δὲ πτελέας ἐφύτευσαν{l]
[l [n}6.420{]}νύμφαι ὀρεστιάδες κοῦραι Διὸς αἰγιόχοιο.{l]
[l [n}6.421{]}οἳ δέ μοι ἑπτὰ κασίγνητοι ἔσαν ἐν μεγάροισιν{l]
[l [n}6.422{]}οἳ μὲν πάντες ἰῷ κίον ἤματι Ἄϊδος εἴσω·{l]
[l [n}6.423{]}πάντας γὰρ κατέπεφνε ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}6.424{]}βουσὶν ἐπʼ εἰλιπόδεσσι καὶ ἀργεννῇς ὀΐεσσι.{l]
[l [n}6.425{]}μητέρα δʼ, ἣ βασίλευεν ὑπὸ Πλάκῳ ὑληέσσῃ,{l]
[l [n}6.426{]}τὴν ἐπεὶ ἂρ δεῦρʼ ἤγαγʼ ἅμʼ ἄλλοισι κτεάτεσσιν,{l]
[l [n}6.427{]}ἂψ ὅ γε τὴν ἀπέλυσε λαβὼν ἀπερείσιʼ ἄποινα,{l]
[l [n}6.428{]}πατρὸς δʼ ἐν μεγάροισι βάλʼ Ἄρτεμις ἰοχέαιρα.{l]
[l [n}6.429{]}Ἕκτορ ἀτὰρ σύ μοί ἐσσι πατὴρ καὶ πότνια μήτηρ{l]
[l [n}6.430{]}ἠδὲ κασίγνητος, σὺ δέ μοι θαλερὸς παρακοίτης·{l]
[l [n}6.431{]}ἀλλʼ ἄγε νῦν ἐλέαιρε καὶ αὐτοῦ μίμνʼ ἐπὶ πύργῳ,{l]
[l [n}6.432{]}μὴ παῖδʼ ὀρφανικὸν θήῃς χήρην τε γυναῖκα·{l]
[l [n}6.433{]}λαὸν δὲ στῆσον παρʼ ἐρινεόν, ἔνθα μάλιστα{l]
[l [n}6.434{]}ἀμβατός ἐστι πόλις καὶ ἐπίδρομον ἔπλετο τεῖχος.{l]
[l [n}6.435{]}τρὶς γὰρ τῇ γʼ ἐλθόντες ἐπειρήσανθʼ οἱ ἄριστοι{l]
[l [n}6.436{]}ἀμφʼ Αἴαντε δύω καὶ ἀγακλυτὸν Ἰδομενῆα{l]
[l [n}6.437{]}ἠδʼ ἀμφʼ Ἀτρεΐδας καὶ Τυδέος ἄλκιμον υἱόν·{l]
[l [n}6.438{]}ἤ πού τίς σφιν ἔνισπε θεοπροπίων ἐῢ εἰδώς,{l]
[l [n}6.439{]}ἤ νυ καὶ αὐτῶν θυμὸς ἐποτρύνει καὶ ἀνώγει.{l]{q]{para]
[para}[l [n}6.440{]}τὴν δʼ αὖτε προσέειπε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}6.441{]}ἦ καὶ ἐμοὶ τάδε πάντα μέλει γύναι· ἀλλὰ μάλʼ αἰνῶς{l]
[l [n}6.442{]}αἰδέομαι Τρῶας καὶ Τρῳάδας ἑλκεσιπέπλους,{l]
[l [n}6.443{]}αἴ κε κακὸς ὣς νόσφιν ἀλυσκάζω πολέμοιο·{l]
[l [n}6.444{]}οὐδέ με θυμὸς ἄνωγεν, ἐπεὶ μάθον ἔμμεναι ἐσθλὸς{l]
[l [n}6.445{]}αἰεὶ καὶ πρώτοισι μετὰ Τρώεσσι μάχεσθαι{l]
[l [n}6.446{]}ἀρνύμενος πατρός τε μέγα κλέος ἠδʼ ἐμὸν αὐτοῦ.{l]
[l [n}6.447{]}εὖ γὰρ ἐγὼ τόδε οἶδα κατὰ φρένα καὶ κατὰ θυμόν·{l]
[l [n}6.448{]}ἔσσεται ἦμαρ ὅτʼ ἄν ποτʼ ὀλώλῃ Ἴλιος ἱρὴ{l]
[l [n}6.449{]}καὶ Πρίαμος καὶ λαὸς ἐϋμμελίω Πριάμοιο.{l]
[l [n}6.450{]}ἀλλʼ οὔ μοι Τρώων τόσσον μέλει ἄλγος ὀπίσσω,{l]
[l [n}6.451{]}οὔτʼ αὐτῆς Ἑκάβης οὔτε Πριάμοιο ἄνακτος{l]
[l [n}6.452{]}οὔτε κασιγνήτων, οἵ κεν πολέες τε καὶ ἐσθλοὶ{l]
[l [n}6.453{]}ἐν κονίῃσι πέσοιεν ὑπʼ ἀνδράσι δυσμενέεσσιν,{l]
[l [n}6.454{]}ὅσσον σεῦ, ὅτε κέν τις Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}6.455{]}δακρυόεσσαν ἄγηται ἐλεύθερον ἦμαρ ἀπούρας·{l]
[l [n}6.456{]}καί κεν ἐν Ἄργει ἐοῦσα πρὸς ἄλλης ἱστὸν ὑφαίνοις,{l]
[l [n}6.457{]}καί κεν ὕδωρ φορέοις Μεσσηΐδος ἢ Ὑπερείης{l]
[l [n}6.458{]}πόλλʼ ἀεκαζομένη, κρατερὴ δʼ ἐπικείσετʼ ἀνάγκη·{l]
[l [n}6.459{]}καί ποτέ τις εἴπῃσιν ἰδὼν κατὰ δάκρυ χέουσαν·{l]
[q}[l [n}6.460{]}Ἕκτορος ἥδε γυνὴ ὃς ἀριστεύεσκε μάχεσθαι{l]
[l [n}6.461{]}Τρώων ἱπποδάμων ὅτε Ἴλιον ἀμφεμάχοντο.{l]{q][l [n}6.462{]}ὥς ποτέ τις ἐρέει· σοὶ δʼ αὖ νέον ἔσσεται ἄλγος{l]
[l [n}6.463{]}χήτεϊ τοιοῦδʼ ἀνδρὸς ἀμύνειν δούλιον ἦμαρ.{l]
[l [n}6.464{]}ἀλλά με τεθνηῶτα χυτὴ κατὰ γαῖα καλύπτοι{l]
[l [n}6.465{]}πρίν γέ τι σῆς τε βοῆς σοῦ θʼ ἑλκηθμοῖο πυθέσθαι.{l]{q]{para]
[para}[l [n}6.466{]}ὣς εἰπὼν οὗ παιδὸς ὀρέξατο φαίδιμος Ἕκτωρ·{l]
[l [n}6.467{]}ἂψ δʼ ὃ πάϊς πρὸς κόλπον ἐϋζώνοιο τιθήνης{l]
[l [n}6.468{]}ἐκλίνθη ἰάχων πατρὸς φίλου ὄψιν ἀτυχθεὶς{l]
[l [n}6.469{]}ταρβήσας χαλκόν τε ἰδὲ λόφον ἱππιοχαίτην,{l]
[l [n}6.470{]}δεινὸν ἀπʼ ἀκροτάτης κόρυθος νεύοντα νοήσας.{l]
[l [n}6.471{]}ἐκ δʼ ἐγέλασσε πατήρ τε φίλος καὶ πότνια μήτηρ·{l]
[l [n}6.472{]}αὐτίκʼ ἀπὸ κρατὸς κόρυθʼ εἵλετο φαίδιμος Ἕκτωρ,{l]
[l [n}6.473{]}καὶ τὴν μὲν κατέθηκεν ἐπὶ χθονὶ παμφανόωσαν·{l]
[l [n}6.474{]}αὐτὰρ ὅ γʼ ὃν φίλον υἱὸν ἐπεὶ κύσε πῆλέ τε χερσὶν{l]
[l [n}6.475{]}εἶπε δʼ ἐπευξάμενος Διί τʼ ἄλλοισίν τε θεοῖσι·{l]
[q}[l [n}6.476{]}Ζεῦ ἄλλοι τε θεοὶ δότε δὴ καὶ τόνδε γενέσθαι{l]
[l [n}6.477{]}παῖδʼ ἐμὸν ὡς καὶ ἐγώ περ ἀριπρεπέα Τρώεσσιν,{l]
[l [n}6.478{]}ὧδε βίην τʼ ἀγαθόν, καὶ Ἰλίου ἶφι ἀνάσσειν·{l]
[l [n}6.479{]}καί ποτέ τις εἴποι πατρός γʼ ὅδε πολλὸν ἀμείνων{l]
[l [n}6.480{]}ἐκ πολέμου ἀνιόντα· φέροι δʼ ἔναρα βροτόεντα{l]
[l [n}6.481{]}κτείνας δήϊον ἄνδρα, χαρείη δὲ φρένα μήτηρ.{l]{q]{para]
[para}[l [n}6.482{]}ὣς εἰπὼν ἀλόχοιο φίλης ἐν χερσὶν ἔθηκε{l]
[l [n}6.483{]}παῖδʼ ἑόν· ἣ δʼ ἄρα μιν κηώδεϊ δέξατο κόλπῳ{l]
[l [n}6.484{]}δακρυόεν γελάσασα· πόσις δʼ ἐλέησε νοήσας,{l]
[l [n}6.485{]}χειρί τέ μιν κατέρεξεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}6.486{]}δαιμονίη μή μοί τι λίην ἀκαχίζεο θυμῷ·{l]
[l [n}6.487{]}οὐ γάρ τίς μʼ ὑπὲρ αἶσαν ἀνὴρ Ἄϊδι προϊάψει·{l]
[l [n}6.488{]}μοῖραν δʼ οὔ τινά φημι πεφυγμένον ἔμμεναι ἀνδρῶν,{l]
[l [n}6.489{]}οὐ κακὸν οὐδὲ μὲν ἐσθλόν, ἐπὴν τὰ πρῶτα γένηται.{l]
[l [n}6.490{]}ἀλλʼ εἰς οἶκον ἰοῦσα τὰ σʼ αὐτῆς ἔργα κόμιζε{l]
[l [n}6.491{]}ἱστόν τʼ ἠλακάτην τε, καὶ ἀμφιπόλοισι κέλευε{l]
[l [n}6.492{]}ἔργον ἐποίχεσθαι· πόλεμος δʼ ἄνδρεσσι μελήσει{l]
[l [n}6.493{]}πᾶσι, μάλιστα δʼ ἐμοί, τοὶ Ἰλίῳ ἐγγεγάασιν.{l]{q]{para]
[para}[l [n}6.494{]}ὣς ἄρα φωνήσας κόρυθʼ εἵλετο φαίδιμος Ἕκτωρ{l]
[l [n}6.495{]}ἵππουριν· ἄλοχος δὲ φίλη οἶκον δὲ βεβήκει{l]
[l [n}6.496{]}ἐντροπαλιζομένη, θαλερὸν κατὰ δάκρυ χέουσα.{l]
[l [n}6.497{]}αἶψα δʼ ἔπειθʼ ἵκανε δόμους εὖ ναιετάοντας{l]
[l [n}6.498{]}Ἕκτορος ἀνδροφόνοιο, κιχήσατο δʼ ἔνδοθι πολλὰς{l]
[l [n}6.499{]}ἀμφιπόλους, τῇσιν δὲ γόον πάσῃσιν ἐνῶρσεν.{l]
[l [n}6.500{]}αἳ μὲν ἔτι ζωὸν γόον Ἕκτορα ᾧ ἐνὶ οἴκῳ·{l]
[l [n}6.501{]}οὐ γάρ μιν ἔτʼ ἔφαντο ὑπότροπον ἐκ πολέμοιο{l]
[l [n}6.502{]}ἵξεσθαι προφυγόντα μένος καὶ χεῖρας Ἀχαιῶν.{l]{para]
[para}[l [n}6.503{]}οὐδὲ Πάρις δήθυνεν ἐν ὑψηλοῖσι δόμοισιν,{l]
[l [n}6.504{]}ἀλλʼ ὅ γʼ, ἐπεὶ κατέδυ κλυτὰ τεύχεα ποικίλα χαλκῷ,{l]
[l [n}6.505{]}σεύατʼ ἔπειτʼ ἀνὰ ἄστυ ποσὶ κραιπνοῖσι πεποιθώς.{l]
[l [n}6.506{]}ὡς δʼ ὅτε τις στατὸς ἵππος ἀκοστήσας ἐπὶ φάτνῃ{l]
[l [n}6.507{]}δεσμὸν ἀπορρήξας θείῃ πεδίοιο κροαίνων{l]
[l [n}6.508{]}εἰωθὼς λούεσθαι ἐϋρρεῖος ποταμοῖο{l]
[l [n}6.509{]}κυδιόων· ὑψοῦ δὲ κάρη ἔχει, ἀμφὶ δὲ χαῖται{l]
[l [n}6.510{]}ὤμοις ἀΐσσονται· ὃ δʼ ἀγλαΐηφι πεποιθὼς{l]
[l [n}6.511{]}ῥίμφά ἑ γοῦνα φέρει μετά τʼ ἤθεα καὶ νομὸν ἵππων·{l]
[l [n}6.512{]}ὣς υἱὸς Πριάμοιο Πάρις κατὰ Περγάμου ἄκρης{l]
[l [n}6.513{]}τεύχεσι παμφαίνων ὥς τʼ ἠλέκτωρ ἐβεβήκει{l]
[l [n}6.514{]}καγχαλόων, ταχέες δὲ πόδες φέρον· αἶψα δʼ ἔπειτα{l]
[l [n}6.515{]}Ἕκτορα δῖον ἔτετμεν ἀδελφεὸν εὖτʼ ἄρʼ ἔμελλε{l]
[l [n}6.516{]}στρέψεσθʼ ἐκ χώρης ὅθι ᾗ ὀάριζε γυναικί.{l]
[l [n}6.517{]}τὸν πρότερος προσέειπεν Ἀλέξανδρος θεοειδής·{l]
[q}[l [n}6.518{]}ἠθεῖʼ ἦ μάλα δή σε καὶ ἐσσύμενον κατερύκω{l]
[l [n}6.519{]}δηθύνων, οὐδʼ ἦλθον ἐναίσιμον ὡς ἐκέλευες;{l]{q]{para]
[para}[l [n}6.520{]}τὸν δʼ ἀπαμειβόμενος προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}6.521{]}δαιμόνιʼ οὐκ ἄν τίς τοι ἀνὴρ ὃς ἐναίσιμος εἴη{l]
[l [n}6.522{]}ἔργον ἀτιμήσειε μάχης, ἐπεὶ ἄλκιμός ἐσσι·{l]
[l [n}6.523{]}ἀλλὰ ἑκὼν μεθιεῖς τε καὶ οὐκ ἐθέλεις· τὸ δʼ ἐμὸν κῆρ{l]
[l [n}6.524{]}ἄχνυται ἐν θυμῷ, ὅθʼ ὑπὲρ σέθεν αἴσχεʼ ἀκούω{l]
[l [n}6.525{]}πρὸς Τρώων, οἳ ἔχουσι πολὺν πόνον εἵνεκα σεῖο.{l]
[l [n}6.526{]}ἀλλʼ ἴομεν· τὰ δʼ ὄπισθεν ἀρεσσόμεθʼ, αἴ κέ ποθι Ζεὺς{l]
[l [n}6.527{]}δώῃ ἐπουρανίοισι θεοῖς αἰειγενέτῃσι{l]
[l [n}6.528{]}κρητῆρα στήσασθαι ἐλεύθερον ἐν μεγάροισιν{l]
[l [n}6.529{]}ἐκ Τροίης ἐλάσαντας ἐϋκνήμιδας Ἀχαιούς.{l]{q]
{book]
[book [n}7{]}
[para}[l [n}7.1{]}ὣς εἰπὼν πυλέων ἐξέσσυτο φαίδιμος Ἕκτωρ,{l]
[l [n}7.2{]}τῷ δʼ ἅμʼ Ἀλέξανδρος κίʼ ἀδελφεός· ἐν δʼ ἄρα θυμῷ{l]
[l [n}7.3{]}ἀμφότεροι μέμασαν πολεμίζειν ἠδὲ μάχεσθαι.{l]
[l [n}7.4{]}ὡς δὲ θεὸς ναύτῃσιν ἐελδομένοισιν ἔδωκεν{l]
[l [n}7.5{]}οὖρον, ἐπεί κε κάμωσιν ἐϋξέστῃς ἐλάτῃσι{l]
[l [n}7.6{]}πόντον ἐλαύνοντες, καμάτῳ δʼ ὑπὸ γυῖα λέλυνται,{l]
[l [n}7.7{]}ὣς ἄρα τὼ Τρώεσσιν ἐελδομένοισι φανήτην.{l]{para]
[para}[l [n}7.8{]}ἔνθʼ ἑλέτην ὃ μὲν υἱὸν Ἀρηϊθόοιο ἄνακτος{l]
[l [n}7.9{]}Ἄρνῃ ναιετάοντα Μενέσθιον, ὃν κορυνήτης{l]
[l [n}7.10{]}γείνατʼ Ἀρηΐθοος καὶ Φυλομέδουσα βοῶπις·{l]
[l [n}7.11{]}Ἕκτωρ δʼ Ἠϊονῆα βάλʼ ἔγχεϊ ὀξυόεντι{l]
[l [n}7.12{]}αὐχένʼ ὑπὸ στεφάνης εὐχάλκου, λύντο δὲ γυῖα.{l]
[l [n}7.13{]}Γλαῦκος δʼ Ἱππολόχοιο πάϊς Λυκίων ἀγὸς ἀνδρῶν{l]
[l [n}7.14{]}Ἰφίνοον βάλε δουρὶ κατὰ κρατερὴν ὑσμίνην{l]
[l [n}7.15{]}Δεξιάδην ἵππων ἐπιάλμενον ὠκειάων{l]
[l [n}7.16{]}ὦμον· ὃ δʼ ἐξ ἵππων χαμάδις πέσε, λύντο δὲ γυῖα.{l]{para]
[para}[l [n}7.17{]}τοὺς δʼ ὡς οὖν ἐνόησε θεὰ γλαυκῶπις Ἀθήνη{l]
[l [n}7.18{]}Ἀργείους ὀλέκοντας ἐνὶ κρατερῇ ὑσμίνῃ,{l]
[l [n}7.19{]}βῆ ῥα κατʼ Οὐλύμποιο καρήνων ἀΐξασα{l]
[l [n}7.20{]}Ἴλιον εἰς ἱερήν· τῇ δʼ ἀντίος ὄρνυτʼ Ἀπόλλων{l]
[l [n}7.21{]}Περγάμου ἐκκατιδών, Τρώεσσι δὲ βούλετο νίκην·{l]
[l [n}7.22{]}ἀλλήλοισι δὲ τώ γε συναντέσθην παρὰ φηγῷ.{l]
[l [n}7.23{]}τὴν πρότερος προσέειπεν ἄναξ Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}7.24{]}τίπτε σὺ δʼ αὖ μεμαυῖα Διὸς θύγατερ μεγάλοιο{l]
[l [n}7.25{]}ἦλθες ἀπʼ Οὐλύμποιο, μέγας δέ σε θυμὸς ἀνῆκεν;{l]
[l [n}7.26{]}ἦ ἵνα δὴ Δαναοῖσι μάχης ἑτεραλκέα νίκην{l]
[l [n}7.27{]}δῷς; ἐπεὶ οὔ τι Τρῶας ἀπολλυμένους ἐλεαίρεις.{l]
[l [n}7.28{]}ἀλλʼ εἴ μοί τι πίθοιο τό κεν πολὺ κέρδιον εἴη·{l]
[l [n}7.29{]}νῦν μὲν παύσωμεν πόλεμον καὶ δηϊοτῆτα{l]
[l [n}7.30{]}σήμερον· ὕστερον αὖτε μαχήσοντʼ εἰς ὅ κε τέκμωρ{l]
[l [n}7.31{]}Ἰλίου εὕρωσιν, ἐπεὶ ὣς φίλον ἔπλετο θυμῷ{l]
[l [n}7.32{]}ὑμῖν ἀθανάτῃσι, διαπραθέειν τόδε ἄστυ.{l]{q]{para]
[para}[l [n}7.33{]}τὸν δʼ αὖτε προσέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}7.34{]}ὧδʼ ἔστω ἑκάεργε· τὰ γὰρ φρονέουσα καὶ αὐτὴ{l]
[l [n}7.35{]}ἦλθον ἀπʼ Οὐλύμποιο μετὰ Τρῶας καὶ Ἀχαιούς.{l]
[l [n}7.36{]}ἀλλʼ ἄγε πῶς μέμονας πόλεμον καταπαυσέμεν ἀνδρῶν;{l]{q]{para]
[para}[l [n}7.37{]}τὴν δʼ αὖτε προσέειπεν ἄναξ Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}7.38{]}Ἕκτορος ὄρσωμεν κρατερὸν μένος ἱπποδάμοιο,{l]
[l [n}7.39{]}ἤν τινά που Δαναῶν προκαλέσσεται οἰόθεν οἶος{l]
[l [n}7.40{]}ἀντίβιον μαχέσασθαι ἐν αἰνῇ δηϊοτῆτι,{l]
[l [n}7.41{]}οἳ δέ κʼ ἀγασσάμενοι χαλκοκνήμιδες Ἀχαιοὶ{l]
[l [n}7.42{]}οἶον ἐπόρσειαν πολεμίζειν Ἕκτορι δίῳ.{l]{q]{para]
[para}[l [n}7.43{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ γλαυκῶπις Ἀθήνη.{l]
[l [n}7.44{]}τῶν δʼ Ἕλενος Πριάμοιο φίλος παῖς σύνθετο θυμῷ{l]
[l [n}7.45{]}βουλήν, ἥ ῥα θεοῖσιν ἐφήνδανε μητιόωσι·{l]
[l [n}7.46{]}στῆ δὲ παρʼ Ἕκτορʼ ἰὼν καί μιν πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}7.47{]}Ἕκτορ υἱὲ Πριάμοιο Διὶ μῆτιν ἀτάλαντε{l]
[l [n}7.48{]}ἦ ῥά νύ μοί τι πίθοιο, κασίγνητος δέ τοί εἰμι·{l]
[l [n}7.49{]}ἄλλους μὲν κάθισον Τρῶας καὶ πάντας Ἀχαιούς,{l]
[l [n}7.50{]}αὐτὸς δὲ προκάλεσσαι Ἀχαιῶν ὅς τις ἄριστος{l]
[l [n}7.51{]}ἀντίβιον μαχέσασθαι ἐν αἰνῇ δηϊοτῆτι·{l]
[l [n}7.52{]}οὐ γάρ πώ τοι μοῖρα θανεῖν καὶ πότμον ἐπισπεῖν·{l]
[l [n}7.53{]}ὣς γὰρ ἐγὼ ὄπʼ ἄκουσα θεῶν αἰειγενετάων.{l]{q]{para]
[para}[l [n}7.54{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ αὖτε χάρη μέγα μῦθον ἀκούσας,{l]
[l [n}7.55{]}καί ῥʼ ἐς μέσσον ἰὼν Τρώων ἀνέεργε φάλαγγας,{l]
[l [n}7.56{]}μέσσου δουρὸς ἑλών· οἳ δʼ ἱδρύνθησαν ἅπαντες.{l]
[l [n}7.57{]}κὰδ δʼ Ἀγαμέμνων εἷσεν ἐϋκνήμιδας Ἀχαιούς·{l]
[l [n}7.58{]}κὰδ δʼ ἄρʼ Ἀθηναίη τε καὶ ἀργυρότοξος Ἀπόλλων{l]
[l [n}7.59{]}ἑζέσθην ὄρνισιν ἐοικότες αἰγυπιοῖσι{l]
[l [n}7.60{]}φηγῷ ἐφʼ ὑψηλῇ πατρὸς Διὸς αἰγιόχοιο{l]
[l [n}7.61{]}ἀνδράσι τερπόμενοι· τῶν δὲ στίχες εἵατο πυκναὶ{l]
[l [n}7.62{]}ἀσπίσι καὶ κορύθεσσι καὶ ἔγχεσι πεφρικυῖαι.{l]
[l [n}7.63{]}οἵη δὲ Ζεφύροιο ἐχεύατο πόντον ἔπι φρὶξ{l]
[l [n}7.64{]}ὀρνυμένοιο νέον, μελάνει δέ τε πόντος ὑπʼ αὐτῆς,{l]
[l [n}7.65{]}τοῖαι ἄρα στίχες εἵατʼ Ἀχαιῶν τε Τρώων τε{l]
[l [n}7.66{]}ἐν πεδίῳ· Ἕκτωρ δὲ μετʼ ἀμφοτέροισιν ἔειπε·{l]
[q}[l [n}7.67{]}κέκλυτέ μευ Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}7.68{]}ὄφρʼ εἴπω τά με θυμὸς ἐνὶ στήθεσσι κελεύει.{l]
[l [n}7.69{]}ὅρκια μὲν Κρονίδης ὑψίζυγος οὐκ ἐτέλεσσεν,{l]
[l [n}7.70{]}ἀλλὰ κακὰ φρονέων τεκμαίρεται ἀμφοτέροισιν{l]
[l [n}7.71{]}εἰς ὅ κεν ἢ ὑμεῖς Τροίην εὔπυργον ἕλητε{l]
[l [n}7.72{]}ἢ αὐτοὶ παρὰ νηυσὶ δαμείετε ποντοπόροισιν.{l]
[l [n}7.73{]}ὑμῖν δʼ ἐν γὰρ ἔασιν ἀριστῆες Παναχαιῶν·{l]
[l [n}7.74{]}τῶν νῦν ὅν τινα θυμὸς ἐμοὶ μαχέσασθαι ἀνώγει{l]
[l [n}7.75{]}δεῦρʼ ἴτω ἐκ πάντων πρόμος ἔμμεναι Ἕκτορι δίῳ.{l]
[l [n}7.76{]}ὧδε δὲ μυθέομαι, Ζεὺς δʼ ἄμμʼ ἐπιμάρτυρος ἔστω·{l]
[l [n}7.77{]}εἰ μέν κεν ἐμὲ κεῖνος ἕλῃ ταναήκεϊ χαλκῷ,{l]
[l [n}7.78{]}τεύχεα συλήσας φερέτω κοίλας ἐπὶ νῆας,{l]
[l [n}7.79{]}σῶμα δὲ οἴκαδʼ ἐμὸν δόμεναι πάλιν, ὄφρα πυρός με{l]
[l [n}7.80{]}Τρῶες καὶ Τρώων ἄλοχοι λελάχωσι θανόντα.{l]
[l [n}7.81{]}εἰ δέ κʼ ἐγὼ τὸν ἕλω, δώῃ δέ μοι εὖχος Ἀπόλλων,{l]
[l [n}7.82{]}τεύχεα σύλησας οἴσω προτὶ Ἴλιον ἱρήν,{l]
[l [n}7.83{]}καὶ κρεμόω προτὶ νηὸν Ἀπόλλωνος ἑκάτοιο,{l]
[l [n}7.84{]}τὸν δὲ νέκυν ἐπὶ νῆας ἐϋσσέλμους ἀποδώσω,{l]
[l [n}7.85{]}ὄφρά ἑ ταρχύσωσι κάρη κομόωντες Ἀχαιοί,{l]
[l [n}7.86{]}σῆμά τέ οἱ χεύωσιν ἐπὶ πλατεῖ Ἑλλησπόντῳ.{l]
[l [n}7.87{]}καί ποτέ τις εἴπῃσι καὶ ὀψιγόνων ἀνθρώπων{l]
[l [n}7.88{]}νηῒ πολυκλήϊδι πλέων ἐπὶ οἴνοπα πόντον·{l]
[q}[l [n}7.89{]}ἀνδρὸς μὲν τόδε σῆμα πάλαι κατατεθνηῶτος,{l]
[l [n}7.90{]}ὅν ποτʼ ἀριστεύοντα κατέκτανε φαίδιμος Ἕκτωρ.{l]{q][l [n}7.91{]}ὥς ποτέ τις ἐρέει· τὸ δʼ ἐμὸν κλέος οὔ ποτʼ ὀλεῖται.{l]{q]{para]
[para}[l [n}7.92{]}ὣς ἔφαθʼ, οἱ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ·{l]
[l [n}7.93{]}αἴδεσθεν μὲν ἀνήνασθαι, δεῖσαν δʼ ὑποδέχθαι·{l]
[l [n}7.94{]}ὀψὲ δὲ δὴ Μενέλαος ἀνίστατο καὶ μετέειπε{l]
[l [n}7.95{]}νείκει ὀνειδίζων, μέγα δὲ στεναχίζετο θυμῷ·{l]
[q}[l [n}7.96{]}ὤ μοι ἀπειλητῆρες Ἀχαιΐδες οὐκέτʼ Ἀχαιοί·{l]
[l [n}7.97{]}ἦ μὲν δὴ λώβη τάδε γʼ ἔσσεται αἰνόθεν αἰνῶς{l]
[l [n}7.98{]}εἰ μή τις Δαναῶν νῦν Ἕκτορος ἀντίος εἶσιν.{l]
[l [n}7.99{]}ἀλλʼ ὑμεῖς μὲν πάντες ὕδωρ καὶ γαῖα γένοισθε{l]
[l [n}7.100{]}ἥμενοι αὖθι ἕκαστοι ἀκήριοι ἀκλεὲς αὔτως·{l]
[l [n}7.101{]}τῷδε δʼ ἐγὼν αὐτὸς θωρήξομαι· αὐτὰρ ὕπερθε{l]
[l [n}7.102{]}νίκης πείρατʼ ἔχονται ἐν ἀθανάτοισι θεοῖσιν.{l]{q]{para]
[para}[l [n}7.103{]}ὣς ἄρα φωνήσας κατεδύσετο τεύχεα καλά.{l]
[l [n}7.104{]}ἔνθά κέ τοι Μενέλαε φάνη βιότοιο τελευτὴ{l]
[l [n}7.105{]}Ἕκτορος ἐν παλάμῃσιν, ἐπεὶ πολὺ φέρτερος ἦεν,{l]
[l [n}7.106{]}εἰ μὴ ἀναΐξαντες ἕλον βασιλῆες Ἀχαιῶν,{l]
[l [n}7.107{]}αὐτός τʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}7.108{]}δεξιτερῆς ἕλε χειρὸς ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζεν·{l]
[q}[l [n}7.109{]}ἀφραίνεις Μενέλαε διοτρεφές, οὐδέ τί σε χρὴ{l]
[l [n}7.110{]}ταύτης ἀφροσύνης· ἀνὰ δὲ σχέο κηδόμενός περ,{l]
[l [n}7.111{]}μηδʼ ἔθελʼ ἐξ ἔριδος σεῦ ἀμείνονι φωτὶ μάχεσθαι{l]
[l [n}7.112{]}Ἕκτορι Πριαμίδῃ, τόν τε στυγέουσι καὶ ἄλλοι.{l]
[l [n}7.113{]}καὶ δʼ Ἀχιλεὺς τούτῳ γε μάχῃ ἔνι κυδιανείρῃ{l]
[l [n}7.114{]}ἔρριγʼ ἀντιβολῆσαι, ὅ περ σέο πολλὸν ἀμείνων.{l]
[l [n}7.115{]}ἀλλὰ σὺ μὲν νῦν ἵζευ ἰὼν μετὰ ἔθνος ἑταίρων,{l]
[l [n}7.116{]}τούτῳ δὲ πρόμον ἄλλον ἀναστήσουσιν Ἀχαιοί.{l]
[l [n}7.117{]}εἴ περ ἀδειής τʼ ἐστὶ καὶ εἰ μόθου ἔστʼ ἀκόρητος,{l]
[l [n}7.118{]}φημί μιν ἀσπασίως γόνυ κάμψειν, αἴ κε φύγῃσι{l]
[l [n}7.119{]}δηΐου ἐκ πολέμοιο καὶ αἰνῆς δηϊοτῆτος.{l]{q]{para]
[para}[l [n}7.120{]}ὣς εἰπὼν παρέπεισεν ἀδελφειοῦ φρένας ἥρως{l]
[l [n}7.121{]}αἴσιμα παρειπών, ὃ δʼ ἐπείθετο· τοῦ μὲν ἔπειτα{l]
[l [n}7.122{]}γηθόσυνοι θεράποντες ἀπʼ ὤμων τεύχεʼ ἕλοντο·{l]
[l [n}7.123{]}Νέστωρ δʼ Ἀργείοισιν ἀνίστατο καὶ μετέειπεν·{l]
[q}[l [n}7.124{]}ὢ πόποι ἦ μέγα πένθος Ἀχαιΐδα γαῖαν ἱκάνει.{l]
[l [n}7.125{]}ἦ κε μέγʼ οἰμώξειε γέρων ἱππηλάτα Πηλεὺς{l]
[l [n}7.126{]}ἐσθλὸς Μυρμιδόνων βουληφόρος ἠδʼ ἀγορητής,{l]
[l [n}7.127{]}ὅς ποτέ μʼ εἰρόμενος μέγʼ ἐγήθεεν ᾧ ἐνὶ οἴκῳ{l]
[l [n}7.128{]}πάντων Ἀργείων ἐρέων γενεήν τε τόκον τε.{l]
[l [n}7.129{]}τοὺς νῦν εἰ πτώσσοντας ὑφʼ Ἕκτορι πάντας ἀκούσαι,{l]
[l [n}7.130{]}πολλά κεν ἀθανάτοισι φίλας ἀνὰ χεῖρας ἀείραι{l]
[l [n}7.131{]}θυμὸν ἀπὸ μελέων δῦναι δόμον Ἄϊδος εἴσω.{l]
[l [n}7.132{]}αἲ γὰρ Ζεῦ τε πάτερ καὶ Ἀθηναίη καὶ Ἄπολλον{l]
[l [n}7.133{]}ἡβῷμʼ ὡς ὅτʼ ἐπʼ ὠκυρόῳ Κελάδοντι μάχοντο{l]
[l [n}7.134{]}ἀγρόμενοι Πύλιοί τε καὶ Ἀρκάδες ἐγχεσίμωροι{l]
[l [n}7.135{]}Φειᾶς πὰρ τείχεσσιν Ἰαρδάνου ἀμφὶ ῥέεθρα.{l]
[l [n}7.136{]}τοῖσι δʼ Ἐρευθαλίων πρόμος ἵστατο ἰσόθεος φὼς{l]
[l [n}7.137{]}τεύχεʼ ἔχων ὤμοισιν Ἀρηϊθόοιο ἄνακτος{l]
[l [n}7.138{]}δίου Ἀρηϊθόου, τὸν ἐπίκλησιν κορυνήτην{l]
[l [n}7.139{]}ἄνδρες κίκλησκον καλλίζωνοί τε γυναῖκες{l]
[l [n}7.140{]}οὕνεκʼ ἄρʼ οὐ τόξοισι μαχέσκετο δουρί τε μακρῷ,{l]
[l [n}7.141{]}ἀλλὰ σιδηρείῃ κορύνῃ ῥήγνυσκε φάλαγγας.{l]
[l [n}7.142{]}τὸν Λυκόοργος ἔπεφνε δόλῳ, οὔ τι κράτεΐ γε,{l]
[l [n}7.143{]}στεινωπῷ ἐν ὁδῷ ὅθʼ ἄρʼ οὐ κορύνη οἱ ὄλεθρον{l]
[l [n}7.144{]}χραῖσμε σιδηρείη· πρὶν γὰρ Λυκόοργος ὑποφθὰς{l]
[l [n}7.145{]}δουρὶ μέσον περόνησεν, ὃ δʼ ὕπτιος οὔδει ἐρείσθη·{l]
[l [n}7.146{]}τεύχεα δʼ ἐξενάριξε, τά οἱ πόρε χάλκεος Ἄρης.{l]
[l [n}7.147{]}καὶ τὰ μὲν αὐτὸς ἔπειτα φόρει μετὰ μῶλον Ἄρηος·{l]
[l [n}7.148{]}αὐτὰρ ἐπεὶ Λυκόοργος ἐνὶ μεγάροισιν ἐγήρα,{l]
[l [n}7.149{]}δῶκε δʼ Ἐρευθαλίωνι φίλῳ θεράποντι φορῆναι·{l]
[l [n}7.150{]}τοῦ ὅ γε τεύχεʼ ἔχων προκαλίζετο πάντας ἀρίστους.{l]
[l [n}7.151{]}οἳ δὲ μάλʼ ἐτρόμεον καὶ ἐδείδισαν, οὐδέ τις ἔτλη·{l]
[l [n}7.152{]}ἀλλʼ ἐμὲ θυμὸς ἀνῆκε πολυτλήμων πολεμίζειν{l]
[l [n}7.153{]}θάρσεϊ ᾧ· γενεῇ δὲ νεώτατος ἔσκον ἁπάντων·{l]
[l [n}7.154{]}καὶ μαχόμην οἱ ἐγώ, δῶκεν δέ μοι εὖχος Ἀθήνη.{l]
[l [n}7.155{]}τὸν δὴ μήκιστον καὶ κάρτιστον κτάνον ἄνδρα·{l]
[l [n}7.156{]}πολλὸς γάρ τις ἔκειτο παρήορος ἔνθα καὶ ἔνθα.{l]
[l [n}7.157{]}εἴθʼ ὣς ἡβώοιμι, βίη δέ μοι ἔμπεδος εἴη·{l]
[l [n}7.158{]}τώ κε τάχʼ ἀντήσειε μάχης κορυθαίολος Ἕκτωρ.{l]
[l [n}7.159{]}ὑμέων δʼ οἵ περ ἔασιν ἀριστῆες Παναχαιῶν{l]
[l [n}7.160{]}οὐδʼ οἳ προφρονέως μέμαθʼ Ἕκτορος ἀντίον ἐλθεῖν.{l]{q]{para]
[para}[l [n}7.161{]}ὣς νείκεσσʼ ὃ γέρων, οἳ δʼ ἐννέα πάντες ἀνέσταν.{l]
[l [n}7.162{]}ὦρτο πολὺ πρῶτος μὲν ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}7.163{]}τῷ δʼ ἐπὶ Τυδεΐδης ὦρτο κρατερὸς Διομήδης,{l]
[l [n}7.164{]}τοῖσι δʼ ἐπʼ Αἴαντες θοῦριν ἐπιειμένοι ἀλκήν,{l]
[l [n}7.165{]}τοῖσι δʼ ἐπʼ Ἰδομενεὺς καὶ ὀπάων Ἰδομενῆος{l]
[l [n}7.166{]}Μηριόνης ἀτάλαντος Ἐνυαλίῳ ἀνδρειφόντῃ,{l]
[l [n}7.167{]}τοῖσι δʼ ἐπʼ Εὐρύπυλος Εὐαίμονος ἀγλαὸς υἱός,{l]
[l [n}7.168{]}ἂν δὲ Θόας Ἀνδραιμονίδης καὶ δῖος Ὀδυσσεύς·{l]
[l [n}7.169{]}πάντες ἄρʼ οἵ γʼ ἔθελον πολεμίζειν Ἕκτορι δίῳ.{l]
[l [n}7.170{]}τοῖς δʼ αὖτις μετέειπε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}7.171{]}κλήρῳ νῦν πεπάλασθε διαμπερὲς ὅς κε λάχῃσιν·{l]
[l [n}7.172{]}οὗτος γὰρ δὴ ὀνήσει ἐϋκνήμιδας Ἀχαιούς,{l]
[l [n}7.173{]}καὶ δʼ αὐτὸς ὃν θυμὸν ὀνήσεται αἴ κε φύγῃσι{l]
[l [n}7.174{]}δηΐου ἐκ πολέμοιο καὶ αἰνῆς δηϊοτῆτος.{l]{q]{para]
[para}[l [n}7.175{]}ὣς ἔφαθʼ, οἳ δὲ κλῆρον ἐσημήναντο ἕκαστος,{l]
[l [n}7.176{]}ἐν δʼ ἔβαλον κυνέῃ Ἀγαμέμνονος Ἀτρεΐδαο.{l]
[l [n}7.177{]}λαοὶ δʼ ἠρήσαντο, θεοῖσι δὲ χεῖρας ἀνέσχον·{l]
[l [n}7.178{]}ὧδε δέ τις εἴπεσκεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}7.179{]}Ζεῦ πάτερ ἢ Αἴαντα λαχεῖν, ἢ Τυδέος υἱόν,{l]
[l [n}7.180{]}ἢ αὐτὸν βασιλῆα πολυχρύσοιο Μυκήνης.{l]{q]{para]
[para}[l [n}7.181{]}ὣς ἄρʼ ἔφαν, πάλλεν δὲ Γερήνιος ἱππότα Νέστωρ,{l]
[l [n}7.182{]}ἐκ δʼ ἔθορε κλῆρος κυνέης ὃν ἄρʼ ἤθελον αὐτοὶ{l]
[l [n}7.183{]}Αἴαντος· κῆρυξ δὲ φέρων ἀνʼ ὅμιλον ἁπάντῃ{l]
[l [n}7.184{]}δεῖξʼ ἐνδέξια πᾶσιν ἀριστήεσσιν Ἀχαιῶν.{l]
[l [n}7.185{]}οἳ δʼ οὐ γιγνώσκοντες ἀπηνήναντο ἕκαστος.{l]
[l [n}7.186{]}ἀλλʼ ὅτε δὴ τὸν ἵκανε φέρων ἀνʼ ὅμιλον ἁπάντῃ{l]
[l [n}7.187{]}ὅς μιν ἐπιγράψας κυνέῃ βάλε φαίδιμος Αἴας,{l]
[l [n}7.188{]}ἤτοι ὑπέσχεθε χεῖρʼ, ὃ δʼ ἄρʼ ἔμβαλεν ἄγχι παραστάς,{l]
[l [n}7.189{]}γνῶ δὲ κλήρου σῆμα ἰδών, γήθησε δὲ θυμῷ.{l]
[l [n}7.190{]}τὸν μὲν πὰρ πόδʼ ἑὸν χαμάδις βάλε φώνησέν τε·{l]
[q}[l [n}7.191{]}ὦ φίλοι ἤτοι κλῆρος ἐμός, χαίρω δὲ καὶ αὐτὸς{l]
[l [n}7.192{]}θυμῷ, ἐπεὶ δοκέω νικησέμεν Ἕκτορα δῖον.{l]
[l [n}7.193{]}ἀλλʼ ἄγετʼ ὄφρʼ ἂν ἐγὼ πολεμήϊα τεύχεα δύω,{l]
[l [n}7.194{]}τόφρʼ ὑμεῖς εὔχεσθε Διὶ Κρονίωνι ἄνακτι{l]
[l [n}7.195{]}σιγῇ ἐφʼ ὑμείων ἵνα μὴ Τρῶές γε πύθωνται,{l]
[l [n}7.196{]}ἠὲ καὶ ἀμφαδίην, ἐπεὶ οὔ τινα δείδιμεν ἔμπης·{l]
[l [n}7.197{]}οὐ γάρ τίς με βίῃ γε ἑκὼν ἀέκοντα δίηται{l]
[l [n}7.198{]}οὐδέ τι ἰδρείῃ, ἐπεὶ οὐδʼ ἐμὲ νήϊδά γʼ οὕτως{l]
[l [n}7.199{]}ἔλπομαι ἐν Σαλαμῖνι γενέσθαι τε τραφέμεν τε.{l]{q]{para]
[para}[l [n}7.200{]}ὣς ἔφαθʼ, οἳ δʼ εὔχοντο Διὶ Κρονίωνι ἄνακτι·{l]
[l [n}7.201{]}ὧδε δέ τις εἴπεσκεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}7.202{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε{l]
[l [n}7.203{]}δὸς νίκην Αἴαντι καὶ ἀγλαὸν εὖχος ἀρέσθαι·{l]
[l [n}7.204{]}εἰ δὲ καὶ Ἕκτορά περ φιλέεις καὶ κήδεαι αὐτοῦ,{l]
[l [n}7.205{]}ἴσην ἀμφοτέροισι βίην καὶ κῦδος ὄπασσον.{l]{q]{para]
[para}[l [n}7.206{]}ὣς ἄρʼ ἔφαν, Αἴας δὲ κορύσσετο νώροπι χαλκῷ.{l]
[l [n}7.207{]}αὐτὰρ ἐπεὶ δὴ πάντα περὶ χροῒ ἕσσατο τεύχεα,{l]
[l [n}7.208{]}σεύατʼ ἔπειθʼ οἷός τε πελώριος ἔρχεται Ἄρης,{l]
[l [n}7.209{]}ὅς τʼ εἶσιν πόλεμον δὲ μετʼ ἀνέρας οὕς τε Κρονίων{l]
[l [n}7.210{]}θυμοβόρου ἔριδος μένεϊ ξυνέηκε μάχεσθαι.{l]
[l [n}7.211{]}τοῖος ἄρʼ Αἴας ὦρτο πελώριος ἕρκος Ἀχαιῶν{l]
[l [n}7.212{]}μειδιόων βλοσυροῖσι προσώπασι· νέρθε δὲ ποσσὶν{l]
[l [n}7.213{]}ἤϊε μακρὰ βιβάς, κραδάων δολιχόσκιον ἔγχος.{l]
[l [n}7.214{]}τὸν δὲ καὶ Ἀργεῖοι μὲν ἐγήθεον εἰσορόωντες,{l]
[l [n}7.215{]}Τρῶας δὲ τρόμος αἰνὸς ὑπήλυθε γυῖα ἕκαστον,{l]
[l [n}7.216{]}Ἕκτορί τʼ αὐτῷ θυμὸς ἐνὶ στήθεσσι πάτασσεν·{l]
[l [n}7.217{]}ἀλλʼ οὔ πως ἔτι εἶχεν ὑποτρέσαι οὐδʼ ἀναδῦναι{l]
[l [n}7.218{]}ἂψ λαῶν ἐς ὅμιλον, ἐπεὶ προκαλέσσατο χάρμῃ.{l]
[l [n}7.219{]}Αἴας δʼ ἐγγύθεν ἦλθε φέρων σάκος ἠΰτε πύργον{l]
[l [n}7.220{]}χάλκεον ἑπταβόειον, ὅ οἱ Τυχίος κάμε τεύχων{l]
[l [n}7.221{]}σκυτοτόμων ὄχʼ ἄριστος Ὕλῃ ἔνι οἰκία ναίων,{l]
[l [n}7.222{]}ὅς οἱ ἐποίησεν σάκος αἰόλον ἑπταβόειον{l]
[l [n}7.223{]}ταύρων ζατρεφέων, ἐπὶ δʼ ὄγδοον ἤλασε χαλκόν.{l]
[l [n}7.224{]}τὸ πρόσθε στέρνοιο φέρων Τελαμώνιος Αἴας{l]
[l [n}7.225{]}στῆ ῥα μάλʼ Ἕκτορος ἐγγύς, ἀπειλήσας δὲ προσηύδα·{l]
[q}[l [n}7.226{]}Ἕκτορ νῦν μὲν δὴ σάφα εἴσεαι οἰόθεν οἶος{l]
[l [n}7.227{]}οἷοι καὶ Δαναοῖσιν ἀριστῆες μετέασι{l]
[l [n}7.228{]}καὶ μετʼ Ἀχιλλῆα ῥηξήνορα θυμολέοντα.{l]
[l [n}7.229{]}ἀλλʼ ὃ μὲν ἐν νήεσσι κορωνίσι ποντοπόροισι{l]
[l [n}7.230{]}κεῖτʼ ἀπομηνίσας Ἀγαμέμνονι ποιμένι λαῶν·{l]
[l [n}7.231{]}ἡμεῖς δʼ εἰμὲν τοῖοι οἳ ἂν σέθεν ἀντιάσαιμεν{l]
[l [n}7.232{]}καὶ πολέες· ἀλλʼ ἄρχε μάχης ἠδὲ πτολέμοιο.{l]{q]{para]
[para}[l [n}7.233{]}τὸν δʼ αὖτε προσέειπε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}7.234{]}Αἶαν διογενὲς Τελαμώνιε κοίρανε λαῶν{l]
[l [n}7.235{]}μή τί μευ ἠΰτε παιδὸς ἀφαυροῦ πειρήτιζε{l]
[l [n}7.236{]}ἠὲ γυναικός, ἣ οὐκ οἶδεν πολεμήϊα ἔργα.{l]
[l [n}7.237{]}αὐτὰρ ἐγὼν εὖ οἶδα μάχας τʼ ἀνδροκτασίας τε·{l]
[l [n}7.238{]}οἶδʼ ἐπὶ δεξιά, οἶδʼ ἐπʼ ἀριστερὰ νωμῆσαι βῶν{l]
[l [n}7.239{]}ἀζαλέην, τό μοι ἔστι ταλαύρινον πολεμίζειν·{l]
[l [n}7.240{]}οἶδα δʼ ἐπαΐξαι μόθον ἵππων ὠκειάων·{l]
[l [n}7.241{]}οἶδα δʼ ἐνὶ σταδίῃ δηΐῳ μέλπεσθαι Ἄρηϊ.{l]
[l [n}7.242{]}ἀλλʼ οὐ γάρ σʼ ἐθέλω βαλέειν τοιοῦτον ἐόντα{l]
[l [n}7.243{]}λάθρῃ ὀπιπεύσας, ἀλλʼ ἀμφαδόν, αἴ κε τύχωμι.{l]{q]{para]
[para}[l [n}7.244{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος,{l]
[l [n}7.245{]}καὶ βάλεν Αἴαντος δεινὸν σάκος ἑπταβόειον{l]
[l [n}7.246{]}ἀκρότατον κατὰ χαλκόν, ὃς ὄγδοος ἦεν ἐπʼ αὐτῷ.{l]
[l [n}7.247{]}ἓξ δὲ διὰ πτύχας ἦλθε δαΐζων χαλκὸς ἀτειρής,{l]
[l [n}7.248{]}ἐν τῇ δʼ ἑβδομάτῃ ῥινῷ σχέτο· δεύτερος αὖτε{l]
[l [n}7.249{]}Αἴας διογενὴς προΐει δολιχόσκιον ἔγχος,{l]
[l [n}7.250{]}καὶ βάλε Πριαμίδαο κατʼ ἀσπίδα πάντοσʼ ἐΐσην.{l]
[l [n}7.251{]}διὰ μὲν ἀσπίδος ἦλθε φαεινῆς ὄβριμον ἔγχος,{l]
[l [n}7.252{]}καὶ διὰ θώρηκος πολυδαιδάλου ἠρήρειστο·{l]
[l [n}7.253{]}ἀντικρὺ δὲ παραὶ λαπάρην διάμησε χιτῶνα{l]
[l [n}7.254{]}ἔγχος· ὃ δʼ ἐκλίνθη καὶ ἀλεύατο κῆρα μέλαιναν.{l]
[l [n}7.255{]}τὼ δʼ ἐκσπασσαμένω δολίχʼ ἔγχεα χερσὶν ἅμʼ ἄμφω{l]
[l [n}7.256{]}σύν ῥʼ ἔπεσον λείουσιν ἐοικότες ὠμοφάγοισιν{l]
[l [n}7.257{]}ἢ συσὶ κάπροισιν, τῶν τε σθένος οὐκ ἀλαπαδνόν.{l]
[l [n}7.258{]}Πριαμίδης μὲν ἔπειτα μέσον σάκος οὔτασε δουρί,{l]
[l [n}7.259{]}οὐδʼ ἔρρηξεν χαλκός, ἀνεγνάμφθη δέ οἱ αἰχμή.{l]
[l [n}7.260{]}Αἴας δʼ ἀσπίδα νύξεν ἐπάλμενος· ἣ δὲ διαπρὸ{l]
[l [n}7.261{]}ἤλυθεν ἐγχείη, στυφέλιξε δέ μιν μεμαῶτα,{l]
[l [n}7.262{]}τμήδην δʼ αὐχένʼ ἐπῆλθε, μέλαν δʼ ἀνεκήκιεν αἷμα,{l]
[l [n}7.263{]}ἀλλʼ οὐδʼ ὧς ἀπέληγε μάχης κορυθαίολος Ἕκτωρ,{l]
[l [n}7.264{]}ἀλλʼ ἀναχασσάμενος λίθον εἵλετο χειρὶ παχείῃ{l]
[l [n}7.265{]}κείμενον ἐν πεδίῳ μέλανα τρηχύν τε μέγαν τε·{l]
[l [n}7.266{]}τῷ βάλεν Αἴαντος δεινὸν σάκος ἑπταβόειον{l]
[l [n}7.267{]}μέσσον ἐπομφάλιον· περιήχησεν δʼ ἄρα χαλκός.{l]
[l [n}7.268{]}δεύτερος αὖτʼ Αἴας πολὺ μείζονα λᾶαν ἀείρας{l]
[l [n}7.269{]}ἧκʼ ἐπιδινήσας, ἐπέρεισε δὲ ἶνʼ ἀπέλεθρον,{l]
[l [n}7.270{]}εἴσω δʼ ἀσπίδʼ ἔαξε βαλὼν μυλοειδέϊ πέτρῳ,{l]
[l [n}7.271{]}βλάψε δέ οἱ φίλα γούναθʼ· ὃ δʼ ὕπτιος ἐξετανύσθη{l]
[l [n}7.272{]}ἀσπίδι ἐγχριμφθείς· τὸν δʼ αἶψʼ ὤρθωσεν Ἀπόλλων.{l]
[l [n}7.273{]}καί νύ κε δὴ ξιφέεσσʼ αὐτοσχεδὸν οὐτάζοντο,{l]
[l [n}7.274{]}εἰ μὴ κήρυκες Διὸς ἄγγελοι ἠδὲ καὶ ἀνδρῶν{l]
[l [n}7.275{]}ἦλθον, ὃ μὲν Τρώων, ὃ δʼ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}7.276{]}Ταλθύβιός τε καὶ Ἰδαῖος πεπνυμένω ἄμφω·{l]
[l [n}7.277{]}μέσσῳ δʼ ἀμφοτέρων σκῆπτρα σχέθον, εἶπέ τε μῦθον{l]
[l [n}7.278{]}κῆρυξ Ἰδαῖος πεπνυμένα μήδεα εἰδώς·{l]
[q}[l [n}7.279{]}μηκέτι παῖδε φίλω πολεμίζετε μηδὲ μάχεσθον·{l]
[l [n}7.280{]}ἀμφοτέρω γὰρ σφῶϊ φιλεῖ νεφεληγερέτα Ζεύς,{l]
[l [n}7.281{]}ἄμφω δʼ αἰχμητά· τό γε δὴ καὶ ἴδμεν ἅπαντες.{l]
[l [n}7.282{]}νὺξ δʼ ἤδη τελέθει· ἀγαθὸν καὶ νυκτὶ πιθέσθαι.{l]{q]{para]
[para}[l [n}7.283{]}τὸν δʼ ἀπαμειβόμενος προσέφη Τελαμώνιος Αἴας·{l]
[q}[l [n}7.284{]}Ἰδαῖʼ Ἕκτορα ταῦτα κελεύετε μυθήσασθαι·{l]
[l [n}7.285{]}αὐτὸς γὰρ χάρμῃ προκαλέσσατο πάντας ἀρίστους.{l]
[l [n}7.286{]}ἀρχέτω· αὐτὰρ ἐγὼ μάλα πείσομαι ᾗ περ ἂν οὗτος.{l]{q]{para]
[para}[l [n}7.287{]}τὸν δʼ αὖτε προσέειπε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}7.288{]}Αἶαν ἐπεί τοι δῶκε θεὸς μέγεθός τε βίην τε{l]
[l [n}7.289{]}καὶ πινυτήν, περὶ δʼ ἔγχει Ἀχαιῶν φέρτατός ἐσσι,{l]
[l [n}7.290{]}νῦν μὲν παυσώμεσθα μάχης καὶ δηϊοτῆτος{l]
[l [n}7.291{]}σήμερον· ὕστερον αὖτε μαχησόμεθʼ εἰς ὅ κε δαίμων{l]
[l [n}7.292{]}ἄμμε διακρίνῃ, δώῃ δʼ ἑτέροισί γε νίκην.{l]
[l [n}7.293{]}νὺξ δʼ ἤδη τελέθει· ἀγαθὸν καὶ νυκτὶ πιθέσθαι,{l]
[l [n}7.294{]}ὡς σύ τʼ ἐϋφρήνῃς πάντας παρὰ νηυσὶν Ἀχαιούς,{l]
[l [n}7.295{]}σούς τε μάλιστα ἔτας καὶ ἑταίρους, οἵ τοι ἔασιν·{l]
[l [n}7.296{]}αὐτὰρ ἐγὼ κατὰ ἄστυ μέγα Πριάμοιο ἄνακτος{l]
[l [n}7.297{]}Τρῶας ἐϋφρανέω καὶ Τρῳάδας ἑλκεσιπέπλους,{l]
[l [n}7.298{]}αἵ τέ μοι εὐχόμεναι θεῖον δύσονται ἀγῶνα.{l]
[l [n}7.299{]}δῶρα δʼ ἄγʼ ἀλλήλοισι περικλυτὰ δώομεν ἄμφω,{l]
[l [n}7.300{]}ὄφρά τις ὧδʼ εἴπῃσιν Ἀχαιῶν τε Τρώων τε·{l]
[q}[l [n}7.301{]}ἠμὲν ἐμαρνάσθην ἔριδος πέρι θυμοβόροιο,{l]
[l [n}7.302{]}ἠδʼ αὖτʼ ἐν φιλότητι διέτμαγεν ἀρθμήσαντε.{l]{q]{q]{para]
[para}[l [n}7.303{]}ὣς ἄρα φωνήσας δῶκε ξίφος ἀργυρόηλον{l]
[l [n}7.304{]}σὺν κολεῷ τε φέρων καὶ ἐϋτμήτῳ τελαμῶνι·{l]
[l [n}7.305{]}Αἴας δὲ ζωστῆρα δίδου φοίνικι φαεινόν.{l]
[l [n}7.306{]}τὼ δὲ διακρινθέντε ὃ μὲν μετὰ λαὸν Ἀχαιῶν{l]
[l [n}7.307{]}ἤϊʼ, ὃ δʼ ἐς Τρώων ὅμαδον κίε· τοὶ δὲ χάρησαν,{l]
[l [n}7.308{]}ὡς εἶδον ζωόν τε καὶ ἀρτεμέα προσιόντα,{l]
[l [n}7.309{]}Αἴαντος προφυγόντα μένος καὶ χεῖρας ἀάπτους·{l]
[l [n}7.310{]}καί ῥʼ ἦγον προτὶ ἄστυ ἀελπτέοντες σόον εἶναι.{l]
[l [n}7.311{]}Αἴαντʼ αὖθʼ ἑτέρωθεν ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}7.312{]}εἰς Ἀγαμέμνονα δῖον ἄγον κεχαρηότα νίκῃ.{l]{para]
[para}[l [n}7.313{]}οἳ δʼ ὅτε δὴ κλισίῃσιν ἐν Ἀτρεΐδαο γένοντο,{l]
[l [n}7.314{]}τοῖσι δὲ βοῦν ἱέρευσεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}7.315{]}ἄρσενα πενταέτηρον ὑπερμενέϊ Κρονίωνι.{l]
[l [n}7.316{]}τὸν δέρον ἀμφί θʼ ἕπον, καί μιν διέχευαν ἅπαντα,{l]
[l [n}7.317{]}μίστυλλόν τʼ ἄρʼ ἐπισταμένως πεῖράν τʼ ὀβελοῖσιν,{l]
[l [n}7.318{]}ὄπτησάν τε περιφραδέως, ἐρύσαντό τε πάντα.{l]
[l [n}7.319{]}αὐτὰρ ἐπεὶ παύσαντο πόνου τετύκοντό τε δαῖτα,{l]
[l [n}7.320{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης·{l]
[l [n}7.321{]}νώτοισιν δʼ Αἴαντα διηνεκέεσσι γέραιρεν{l]
[l [n}7.322{]}ἥρως Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων.{l]
[l [n}7.323{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}7.324{]}τοῖς ὁ γέρων πάμπρωτος ὑφαίνειν ἤρχετο μῆτιν{l]
[l [n}7.325{]}Νέστωρ, οὗ καὶ πρόσθεν ἀρίστη φαίνετο βουλή·{l]
[l [n}7.326{]}ὅ σφιν ἐϋφρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}7.327{]}Ἀτρεΐδη τε καὶ ἄλλοι ἀριστῆες Παναχαιῶν,{l]
[l [n}7.328{]}πολλοὶ γὰρ τεθνᾶσι κάρη κομόωντες Ἀχαιοί,{l]
[l [n}7.329{]}τῶν νῦν αἷμα κελαινὸν ἐΰρροον ἀμφὶ Σκάμανδρον{l]
[l [n}7.330{]}ἐσκέδασʼ ὀξὺς Ἄρης, ψυχαὶ δʼ Ἄϊδος δὲ κατῆλθον·{l]
[l [n}7.331{]}τώ σε χρὴ πόλεμον μὲν ἅμʼ ἠοῖ παῦσαι Ἀχαιῶν,{l]
[l [n}7.332{]}αὐτοὶ δʼ ἀγρόμενοι κυκλήσομεν ἐνθάδε νεκροὺς{l]
[l [n}7.333{]}βουσὶ καὶ ἡμιόνοισιν· ἀτὰρ κατακήομεν αὐτοὺς{l]
[l [n}7.334{]}τυτθὸν ἀπὸ πρὸ νεῶν, ὥς κʼ ὀστέα παισὶν ἕκαστος{l]
[l [n}7.335{]}οἴκαδʼ ἄγῃ ὅτʼ ἂν αὖτε νεώμεθα πατρίδα γαῖαν.{l]
[l [n}7.336{]}τύμβον δʼ ἀμφὶ πυρὴν ἕνα χεύομεν ἐξαγαγόντες{l]
[l [n}7.337{]}ἄκριτον ἐκ πεδίου· ποτὶ δʼ αὐτὸν δείμομεν ὦκα{l]
[l [n}7.338{]}πύργους ὑψηλοὺς εἶλαρ νηῶν τε καὶ αὐτῶν.{l]
[l [n}7.339{]}ἐν δʼ αὐτοῖσι πύλας ποιήσομεν εὖ ἀραρυίας,{l]
[l [n}7.340{]}ὄφρα διʼ αὐτάων ἱππηλασίη ὁδὸς εἴη·{l]
[l [n}7.341{]}ἔκτοσθεν δὲ βαθεῖαν ὀρύξομεν ἐγγύθι τάφρον,{l]
[l [n}7.342{]}ἥ χʼ ἵππον καὶ λαὸν ἐρυκάκοι ἀμφὶς ἐοῦσα,{l]
[l [n}7.343{]}μή ποτʼ ἐπιβρίσῃ πόλεμος Τρώων ἀγερώχων.{l]{q]{para]
[para}[l [n}7.344{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπῄνησαν βασιλῆες.{l]
[l [n}7.345{]}Τρώων αὖτʼ ἀγορὴ γένετʼ Ἰλίου ἐν πόλει ἄκρῃ{l]
[l [n}7.346{]}δεινὴ τετρηχυῖα, παρὰ Πριάμοιο θύρῃσι·{l]
[l [n}7.347{]}τοῖσιν δʼ Ἀντήνωρ πεπνυμένος ἦρχʼ ἀγορεύειν·{l]
[q}[l [n}7.348{]}κέκλυτέ μευ Τρῶες καὶ Δάρδανοι ἠδʼ ἐπίκουροι,{l]
[l [n}7.349{]}ὄφρʼ εἴπω τά με θυμὸς ἐνὶ στήθεσσι κελεύει.{l]
[l [n}7.350{]}δεῦτʼ ἄγετʼ Ἀργείην Ἑλένην καὶ κτήμαθʼ ἅμʼ αὐτῇ{l]
[l [n}7.351{]}δώομεν Ἀτρεΐδῃσιν ἄγειν· νῦν δʼ ὅρκια πιστὰ{l]
[l [n}7.352{]}ψευσάμενοι μαχόμεσθα· τὼ οὔ νύ τι κέρδιον ἡμῖν{l]
[l [n}7.353{]}ἔλπομαι ἐκτελέεσθαι, ἵνα μὴ ῥέξομεν ὧδε.{l]{q]{para]
[para}[l [n}7.354{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο· τοῖσι δʼ ἀνέστη{l]
[l [n}7.355{]}δῖος Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο,{l]
[l [n}7.356{]}ὅς μιν ἀμειβόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}7.357{]}Ἀντῆνορ σὺ μὲν οὐκέτʼ ἐμοὶ φίλα ταῦτʼ ἀγορεύεις·{l]
[l [n}7.358{]}οἶσθα καὶ ἄλλον μῦθον ἀμείνονα τοῦδε νοῆσαι.{l]
[l [n}7.359{]}εἰ δʼ ἐτεὸν δὴ τοῦτον ἀπὸ σπουδῆς ἀγορεύεις,{l]
[l [n}7.360{]}ἐξ ἄρα δή τοι ἔπειτα θεοὶ φρένας ὤλεσαν αὐτοί.{l]
[l [n}7.361{]}αὐτὰρ ἐγὼ Τρώεσσι μεθʼ ἱπποδάμοις ἀγορεύσω·{l]
[l [n}7.362{]}ἀντικρὺ δʼ ἀπόφημι γυναῖκα μὲν οὐκ ἀποδώσω·{l]
[l [n}7.363{]}κτήματα δʼ ὅσσʼ ἀγόμην ἐξ Ἄργεος ἡμέτερον δῶ{l]
[l [n}7.364{]}πάντʼ ἐθέλω δόμεναι καὶ οἴκοθεν ἄλλʼ ἐπιθεῖναι.{l]{q]{para]
[para}[l [n}7.365{]}ἤτοι ὅ γʼ ὣς εἰπὼν κατʼ ἄρʼ ἕζετο· τοῖσι δʼ ἀνέστη{l]
[l [n}7.366{]}Δαρδανίδης Πρίαμος, θεόφιν μήστωρ ἀτάλαντος,{l]
[l [n}7.367{]}ὅ σφιν ἐϋφρονέων ἀγορήσατο καὶ μετέειπε·{l]
[q}[l [n}7.368{]}κέκλυτέ μευ Τρῶες καὶ Δάρδανοι ἠδʼ ἐπίκουροι,{l]
[l [n}7.369{]}ὄφρʼ εἴπω τά με θυμὸς ἐνὶ στήθεσσι κελεύει.{l]
[l [n}7.370{]}νῦν μὲν δόρπον ἕλεσθε κατὰ πτόλιν ὡς τὸ πάρος περ,{l]
[l [n}7.371{]}καὶ φυλακῆς μνήσασθε καὶ ἐγρήγορθε ἕκαστος·{l]
[l [n}7.372{]}ἠῶθεν δʼ Ἰδαῖος ἴτω κοίλας ἐπὶ νῆας{l]
[l [n}7.373{]}εἰπέμεν Ἀτρεΐδῃς Ἀγαμέμνονι καὶ Μενελάῳ{l]
[l [n}7.374{]}μῦθον Ἀλεξάνδροιο, τοῦ εἵνεκα νεῖκος ὄρωρε·{l]
[l [n}7.375{]}καὶ δὲ τόδʼ εἰπέμεναι πυκινὸν ἔπος, αἴ κʼ ἐθέλωσι{l]
[l [n}7.376{]}παύσασθαι πολέμοιο δυσηχέος, εἰς ὅ κε νεκροὺς{l]
[l [n}7.377{]}κήομεν· ὕστερον αὖτε μαχησόμεθʼ εἰς ὅ κε δαίμων{l]
[l [n}7.378{]}ἄμμε διακρίνῃ, δώῃ δʼ ἑτέροισί γε νίκην.{l]{q]{para]
[para}[l [n}7.379{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδʼ ἐπίθοντο·{l]
[l [n}7.380{]}δόρπον ἔπειθʼ εἵλοντο κατὰ στρατὸν ἐν τελέεσσιν·{l]
[l [n}7.381{]}ἠῶθεν δʼ Ἰδαῖος ἔβη κοίλας ἐπὶ νῆας·{l]
[l [n}7.382{]}τοὺς δʼ εὗρʼ εἰν ἀγορῇ Δαναοὺς θεράποντας Ἄρηος{l]
[l [n}7.383{]}νηῒ πάρα πρύμνῃ Ἀγαμέμνονος· αὐτὰρ ὃ τοῖσι{l]
[l [n}7.384{]}στὰς ἐν μέσσοισιν μετεφώνεεν ἠπύτα κῆρυξ·{l]
[q}[l [n}7.385{]}Ἀτρεΐδη τε καὶ ἄλλοι ἀριστῆες Παναχαιῶν{l]
[l [n}7.386{]}ἠνώγει Πρίαμός τε καὶ ἄλλοι Τρῶες ἀγαυοὶ{l]
[l [n}7.387{]}εἰπεῖν, αἴ κέ περ ὔμμι φίλον καὶ ἡδὺ γένοιτο,{l]
[l [n}7.388{]}μῦθον Ἀλεξάνδροιο, τοῦ εἵνεκα νεῖκος ὄρωρε·{l]
[l [n}7.389{]}κτήματα μὲν ὅσʼ Ἀλέξανδρος κοίλῃς ἐνὶ νηυσὶν{l]
[l [n}7.390{]}ἠγάγετο Τροίηνδʼ· ὡς πρὶν ὤφελλʼ ἀπολέσθαι·{l]
[l [n}7.391{]}πάντʼ ἐθέλει δόμεναι καὶ οἴκοθεν ἄλλʼ ἐπιθεῖναι·{l]
[l [n}7.392{]}κουριδίην δʼ ἄλοχον Μενελάου κυδαλίμοιο{l]
[l [n}7.393{]}οὔ φησιν δώσειν· ἦ μὴν Τρῶές γε κέλονται.{l]
[l [n}7.394{]}καὶ δὲ τόδʼ ἠνώγεον εἰπεῖν ἔπος αἴ κʼ ἐθέλητε{l]
[l [n}7.395{]}παύσασθαι πολέμοιο δυσηχέος εἰς ὅ κε νεκροὺς{l]
[l [n}7.396{]}κήομεν· ὕστερον αὖτε μαχησόμεθʼ εἰς ὅ κε δαίμων{l]
[l [n}7.397{]}ἄμμε διακρίνῃ, δώῃ δʼ ἑτέροισί γε νίκην.{l]{q]{para]
[para}[l [n}7.398{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ·{l]
[l [n}7.399{]}ὀψὲ δὲ δὴ μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}7.400{]}μήτʼ ἄρ τις νῦν κτήματʼ Ἀλεξάνδροιο δεχέσθω{l]
[l [n}7.401{]}μήθʼ Ἑλένην· γνωτὸν δὲ καὶ ὃς μάλα νήπιός ἐστιν{l]
[l [n}7.402{]}ὡς ἤδη Τρώεσσιν ὀλέθρου πείρατʼ ἐφῆπται.{l]{q]{para]
[para}[l [n}7.403{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπίαχον υἷες Ἀχαιῶν{l]
[l [n}7.404{]}μῦθον ἀγασσάμενοι Διομήδεος ἱπποδάμοιο·{l]
[l [n}7.405{]}καὶ τότʼ ἄρʼ Ἰδαῖον προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}7.406{]}Ἰδαῖʼ ἤτοι μῦθον Ἀχαιῶν αὐτὸς ἀκούεις{l]
[l [n}7.407{]}ὥς τοι ὑποκρίνονται· ἐμοὶ δʼ ἐπιανδάνει οὕτως{l]
[l [n}7.408{]}ἀμφὶ δὲ νεκροῖσιν κατακαιέμεν οὔ τι μεγαίρω·{l]
[l [n}7.409{]}οὐ γάρ τις φειδὼ νεκύων κατατεθνηώτων{l]
[l [n}7.410{]}γίγνετʼ ἐπεί κε θάνωσι πυρὸς μειλισσέμεν ὦκα.{l]
[l [n}7.411{]}ὅρκια δὲ Ζεὺς ἴστω ἐρίγδουπος πόσις Ἥρης.{l]{q]{para]
[para}[l [n}7.412{]}ὣς εἰπὼν τὸ σκῆπτρον ἀνέσχεθε πᾶσι θεοῖσιν,{l]
[l [n}7.413{]}ἄψορρον δʼ Ἰδαῖος ἔβη προτὶ Ἴλιον ἱρήν.{l]
[l [n}7.414{]}οἳ δʼ ἕατʼ εἰν ἀγορῇ Τρῶες καὶ Δαρδανίωνες{l]
[l [n}7.415{]}πάντες ὁμηγερέες, ποτιδέγμενοι ὁππότʼ ἄρʼ ἔλθοι{l]
[l [n}7.416{]}Ἰδαῖος· ὃ δʼ ἄρʼ ἦλθε καὶ ἀγγελίην ἀπέειπε{l]
[l [n}7.417{]}στὰς ἐν μέσσοισιν· τοὶ δʼ ὁπλίζοντο μάλʼ ὦκα,{l]
[l [n}7.418{]}ἀμφότερον νέκυάς τʼ ἀγέμεν ἕτεροι δὲ μεθʼ ὕλην·{l]
[l [n}7.419{]}Ἀργεῖοι δʼ ἑτέρωθεν ἐϋσσέλμων ἀπὸ νηῶν{l]
[l [n}7.420{]}ὀτρύνοντο νέκυς τʼ ἀγέμεν, ἕτεροι δὲ μεθʼ ὕλην.{l]{para]
[para}[l [n}7.421{]}Ἠέλιος μὲν ἔπειτα νέον προσέβαλλεν ἀρούρας{l]
[l [n}7.422{]}ἐξ ἀκαλαρρείταο βαθυρρόου Ὠκεανοῖο{l]
[l [n}7.423{]}οὐρανὸν εἰσανιών· οἳ δʼ ἤντεον ἀλλήλοισιν.{l]
[l [n}7.424{]}ἔνθα διαγνῶναι χαλεπῶς ἦν ἄνδρα ἕκαστον·{l]
[l [n}7.425{]}ἀλλʼ ὕδατι νίζοντες ἄπο βρότον αἱματόεντα{l]
[l [n}7.426{]}δάκρυα θερμὰ χέοντες ἀμαξάων ἐπάειραν.{l]
[l [n}7.427{]}οὐδʼ εἴα κλαίειν Πρίαμος μέγας· οἳ δὲ σιωπῇ{l]
[l [n}7.428{]}νεκροὺς πυρκαϊῆς ἐπινήνεον ἀχνύμενοι κῆρ,{l]
[l [n}7.429{]}ἐν δὲ πυρὶ πρήσαντες ἔβαν προτὶ Ἴλιον ἱρήν.{l]
[l [n}7.430{]}ὣς δʼ αὔτως ἑτέρωθεν ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}7.431{]}νεκροὺς πυρκαϊῆς ἐπινήνεον ἀχνύμενοι κῆρ,{l]
[l [n}7.432{]}ἐν δὲ πυρὶ πρήσαντες ἔβαν κοίλας ἐπὶ νῆας.{l]{para]
[para}[l [n}7.433{]}ἦμος δʼ οὔτʼ ἄρ πω ἠώς, ἔτι δʼ ἀμφιλύκη νύξ,{l]
[l [n}7.434{]}τῆμος ἄρʼ ἀμφὶ πυρὴν κριτὸς ἔγρετο λαὸς Ἀχαιῶν,{l]
[l [n}7.435{]}τύμβον δʼ ἀμφʼ αὐτὴν ἕνα ποίεον ἐξαγαγόντες{l]
[l [n}7.436{]}ἄκριτον ἐκ πεδίου, ποτὶ δʼ αὐτὸν τεῖχος ἔδειμαν{l]
[l [n}7.437{]}πύργους θʼ ὑψηλούς, εἶλαρ νηῶν τε καὶ αὐτῶν.{l]
[l [n}7.438{]}ἐν δʼ αὐτοῖσι πύλας ἐνεποίεον εὖ ἀραρυίας,{l]
[l [n}7.439{]}ὄφρα διʼ αὐτάων ἱππηλασίη ὁδὸς εἴη·{l]
[l [n}7.440{]}ἔκτοσθεν δὲ βαθεῖαν ἐπʼ αὐτῷ τάφρον ὄρυξαν{l]
[l [n}7.441{]}εὐρεῖαν μεγάλην, ἐν δὲ σκόλοπας κατέπηξαν.{l]{para]
[para}[l [n}7.442{]}ὣς οἳ μὲν πονέοντο κάρη κομόωντες Ἀχαιοί·{l]
[l [n}7.443{]}οἳ δὲ θεοὶ πὰρ Ζηνὶ καθήμενοι ἀστεροπητῇ{l]
[l [n}7.444{]}θηεῦντο μέγα ἔργον Ἀχαιῶν χαλκοχιτώνων.{l]
[l [n}7.445{]}τοῖσι δὲ μύθων ἦρχε Ποσειδάων ἐνοσίχθων·{l]
[q}[l [n}7.446{]}Ζεῦ πάτερ, ἦ ῥά τίς ἐστι βροτῶν ἐπʼ ἀπείρονα γαῖαν{l]
[l [n}7.447{]}ὅς τις ἔτʼ ἀθανάτοισι νόον καὶ μῆτιν ἐνίψει;{l]
[l [n}7.448{]}οὐχ ὁράᾳς ὅτι δʼ αὖτε κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}7.449{]}τεῖχος ἐτειχίσσαντο νεῶν ὕπερ, ἀμφὶ δὲ τάφρον{l]
[l [n}7.450{]}ἤλασαν, οὐδὲ θεοῖσι δόσαν κλειτὰς ἑκατόμβας;{l]
[l [n}7.451{]}τοῦ δʼ ἤτοι κλέος ἔσται ὅσον τʼ ἐπικίδναται ἠώς·{l]
[l [n}7.452{]}τοῦ δʼ ἐπιλήσονται τὸ ἐγὼ καὶ Φοῖβος Ἀπόλλων{l]
[l [n}7.453{]}ἥρῳ Λαομέδοντι πολίσσαμεν ἀθλήσαντε.{l]{q]{para]
[para}[l [n}7.454{]}τὸν δὲ μέγʼ ὀχθήσας προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}7.455{]}ὢ πόποι ἐννοσίγαιʼ εὐρυσθενές, οἷον ἔειπες.{l]
[l [n}7.456{]}ἄλλός κέν τις τοῦτο θεῶν δείσειε νόημα,{l]
[l [n}7.457{]}ὃς σέο πολλὸν ἀφαυρότερος χεῖράς τε μένος τε·{l]
[l [n}7.458{]}σὸν δʼ ἤτοι κλέος ἔσται ὅσον τʼ ἐπικίδναται ἠώς.{l]
[l [n}7.459{]}ἄγρει μὰν ὅτʼ ἂν αὖτε κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}7.460{]}οἴχωνται σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν{l]
[l [n}7.461{]}τεῖχος ἀναρρήξας τὸ μὲν εἰς ἅλα πᾶν καταχεῦαι,{l]
[l [n}7.462{]}αὖτις δʼ ἠϊόνα μεγάλην ψαμάθοισι καλύψαι,{l]
[l [n}7.463{]}ὥς κέν τοι μέγα τεῖχος ἀμαλδύνηται Ἀχαιῶν.{l]{q]{para]
[para}[l [n}7.464{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον,{l]
[l [n}7.465{]}δύσετο δʼ ἠέλιος, τετέλεστο δὲ ἔργον Ἀχαιῶν,{l]
[l [n}7.466{]}βουφόνεον δὲ κατὰ κλισίας καὶ δόρπον ἕλοντο.{l]
[l [n}7.467{]}νῆες δʼ ἐκ Λήμνοιο παρέσταν οἶνον ἄγουσαι{l]
[l [n}7.468{]}πολλαί, τὰς προέηκεν Ἰησονίδης Εὔνηος,{l]
[l [n}7.469{]}τόν ῥʼ ἔτεχʼ Ὑψιπύλη ὑπʼ Ἰήσονι ποιμένι λαῶν.{l]
[l [n}7.470{]}χωρὶς δʼ Ἀτρεΐδῃς Ἀγαμέμνονι καὶ Μενελάῳ{l]
[l [n}7.471{]}δῶκεν Ἰησονίδης ἀγέμεν μέθυ χίλια μέτρα.{l]
[l [n}7.472{]}ἔνθεν οἰνίζοντο κάρη κομόωντες Ἀχαιοί,{l]
[l [n}7.473{]}ἄλλοι μὲν χαλκῷ, ἄλλοι δʼ αἴθωνι σιδήρῳ,{l]
[l [n}7.474{]}ἄλλοι δὲ ῥινοῖς, ἄλλοι δʼ αὐτῇσι βόεσσιν,{l]
[l [n}7.475{]}ἄλλοι δʼ ἀνδραπόδεσσι· τίθεντο δὲ δαῖτα θάλειαν.{l]
[l [n}7.476{]}παννύχιοι μὲν ἔπειτα κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}7.477{]}δαίνυντο, Τρῶες δὲ κατὰ πτόλιν ἠδʼ ἐπίκουροι·{l]
[l [n}7.478{]}παννύχιος δέ σφιν κακὰ μήδετο μητίετα Ζεὺς{l]
[l [n}7.479{]}σμερδαλέα κτυπέων· τοὺς δὲ χλωρὸν δέος ᾕρει·{l]
[l [n}7.480{]}οἶνον δʼ ἐκ δεπάων χαμάδις χέον, οὐδέ τις ἔτλη{l]
[l [n}7.481{]}πρὶν πιέειν πρὶν λεῖψαι ὑπερμενέϊ Κρονίωνι.{l]
[l [n}7.482{]}κοιμήσαντʼ ἄρʼ ἔπειτα καὶ ὕπνου δῶρον ἕλοντο.{l]{para]
{book]
[book [n}8{]}
[para}[l [n}8.1{]}Ἠὼς μὲν κροκόπεπλος ἐκίδνατο πᾶσαν ἐπʼ αἶαν,{l]
[l [n}8.2{]}Ζεὺς δὲ θεῶν ἀγορὴν ποιήσατο τερπικέραυνος{l]
[l [n}8.3{]}ἀκροτάτῃ κορυφῇ πολυδειράδος Οὐλύμποιο·{l]
[l [n}8.4{]}αὐτὸς δέ σφʼ ἀγόρευε, θεοὶ δʼ ὑπὸ πάντες ἄκουον·{l]
[q}[l [n}8.5{]}κέκλυτέ μευ πάντές τε θεοὶ πᾶσαί τε θέαιναι,{l]
[l [n}8.6{]}ὄφρʼ εἴπω τά με θυμὸς ἐνὶ στήθεσσι κελεύει.{l]
[l [n}8.7{]}μήτέ τις οὖν θήλεια θεὸς τό γε μήτέ τις ἄρσην{l]
[l [n}8.8{]}πειράτω διακέρσαι ἐμὸν ἔπος, ἀλλʼ ἅμα πάντες{l]
[l [n}8.9{]}αἰνεῖτʼ, ὄφρα τάχιστα τελευτήσω τάδε ἔργα.{l]
[l [n}8.10{]}ὃν δʼ ἂν ἐγὼν ἀπάνευθε θεῶν ἐθέλοντα νοήσω{l]
[l [n}8.11{]}ἐλθόντʼ ἢ Τρώεσσιν ἀρηγέμεν ἢ Δαναοῖσι{l]
[l [n}8.12{]}πληγεὶς οὐ κατὰ κόσμον ἐλεύσεται Οὔλυμπον δέ·{l]
[l [n}8.13{]}ἤ μιν ἑλὼν ῥίψω ἐς Τάρταρον ἠερόεντα{l]
[l [n}8.14{]}τῆλε μάλʼ, ἧχι βάθιστον ὑπὸ χθονός ἐστι βέρεθρον,{l]
[l [n}8.15{]}ἔνθα σιδήρειαί τε πύλαι καὶ χάλκεος οὐδός,{l]
[l [n}8.16{]}τόσσον ἔνερθʼ Ἀΐδεω ὅσον οὐρανός ἐστʼ ἀπὸ γαίης·{l]
[l [n}8.17{]}γνώσετʼ ἔπειθʼ ὅσον εἰμὶ θεῶν κάρτιστος ἁπάντων.{l]
[l [n}8.18{]}εἰ δʼ ἄγε πειρήσασθε θεοὶ ἵνα εἴδετε πάντες·{l]
[l [n}8.19{]}σειρὴν χρυσείην ἐξ οὐρανόθεν κρεμάσαντες{l]
[l [n}8.20{]}πάντές τʼ ἐξάπτεσθε θεοὶ πᾶσαί τε θέαιναι·{l]
[l [n}8.21{]}ἀλλʼ οὐκ ἂν ἐρύσαιτʼ ἐξ οὐρανόθεν πεδίον δὲ{l]
[l [n}8.22{]}Ζῆνʼ ὕπατον μήστωρʼ, οὐδʼ εἰ μάλα πολλὰ κάμοιτε.{l]
[l [n}8.23{]}ἀλλʼ ὅτε δὴ καὶ ἐγὼ πρόφρων ἐθέλοιμι ἐρύσσαι,{l]
[l [n}8.24{]}αὐτῇ κεν γαίῃ ἐρύσαιμʼ αὐτῇ τε θαλάσσῃ·{l]
[l [n}8.25{]}σειρὴν μέν κεν ἔπειτα περὶ ῥίον Οὐλύμποιο{l]
[l [n}8.26{]}δησαίμην, τὰ δέ κʼ αὖτε μετήορα πάντα γένοιτο.{l]
[l [n}8.27{]}τόσσον ἐγὼ περί τʼ εἰμὶ θεῶν περί τʼ εἴμʼ ἀνθρώπων.{l]{q]{para]
[para}[l [n}8.28{]}ὣς ἔφαθʼ, οἱ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ{l]
[l [n}8.29{]}μῦθον ἀγασσάμενοι· μάλα γὰρ κρατερῶς ἀγόρευσεν.{l]
[l [n}8.30{]}ὀψὲ δὲ δὴ μετέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}8.31{]}ὦ πάτερ ἡμέτερε Κρονίδη ὕπατε κρειόντων{l]
[l [n}8.32{]}εὖ νυ καὶ ἡμεῖς ἴδμεν ὅ τοι σθένος οὐκ ἐπιεικτόν·{l]
[l [n}8.33{]}ἀλλʼ ἔμπης Δαναῶν ὀλοφυρόμεθʼ αἰχμητάων,{l]
[l [n}8.34{]}οἵ κεν δὴ κακὸν οἶτον ἀναπλήσαντες ὄλωνται.{l]
[l [n}8.35{]}ἀλλʼ ἤτοι πολέμου μὲν ἀφεξόμεθʼ ὡς σὺ κελεύεις·{l]
[l [n}8.36{]}βουλὴν δʼ Ἀργείοις ὑποθησόμεθʼ ἥ τις ὀνήσει,{l]
[l [n}8.37{]}ὡς μὴ πάντες ὄλωνται ὀδυσσαμένοιο τεοῖο.{l]{q]{para]
[para}[l [n}8.38{]}τὴν δʼ ἐπιμειδήσας προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}8.39{]}θάρσει Τριτογένεια φίλον τέκος· οὔ νύ τι θυμῷ{l]
[l [n}8.40{]}πρόφρονι μυθέομαι, ἐθέλω δέ τοι ἤπιος εἶναι.{l]{q]{para]
[para}[l [n}8.41{]}ὣς εἰπὼν ὑπʼ ὄχεσφι τιτύσκετο χαλκόποδʼ ἵππω{l]
[l [n}8.42{]}ὠκυπέτα χρυσέῃσιν ἐθείρῃσιν κομόωντε,{l]
[l [n}8.43{]}χρυσὸν δʼ αὐτὸς ἔδυνε περὶ χροΐ, γέντο δʼ ἱμάσθλην{l]
[l [n}8.44{]}χρυσείην εὔτυκτον, ἑοῦ δʼ ἐπεβήσετο δίφρου,{l]
[l [n}8.45{]}μάστιξεν δʼ ἐλάαν· τὼ δʼ οὐκ ἀέκοντε πετέσθην{l]
[l [n}8.46{]}μεσσηγὺς γαίης τε καὶ οὐρανοῦ ἀστερόεντος.{l]
[l [n}8.47{]}Ἴδην δʼ ἵκανεν πολυπίδακα μητέρα θηρῶν{l]
[l [n}8.48{]}Γάργαρον, ἔνθά τέ οἱ τέμενος βωμός τε θυήεις.{l]
[l [n}8.49{]}ἔνθʼ ἵππους ἔστησε πατὴρ ἀνδρῶν τε θεῶν τε{l]
[l [n}8.50{]}λύσας ἐξ ὀχέων, κατὰ δʼ ἠέρα πουλὺν ἔχευεν.{l]
[l [n}8.51{]}αὐτὸς δʼ ἐν κορυφῇσι καθέζετο κύδεϊ γαίων{l]
[l [n}8.52{]}εἰσορόων Τρώων τε πόλιν καὶ νῆας Ἀχαιῶν.{l]{para]
[para}[l [n}8.53{]}οἳ δʼ ἄρα δεῖπνον ἕλοντο κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}8.54{]}ῥίμφα κατὰ κλισίας, ἀπὸ δʼ αὐτοῦ θωρήσσοντο.{l]
[l [n}8.55{]}Τρῶες δʼ αὖθʼ ἑτέρωθεν ἀνὰ πτόλιν ὁπλίζοντο{l]
[l [n}8.56{]}παυρότεροι· μέμασαν δὲ καὶ ὧς ὑσμῖνι μάχεσθαι{l]
[l [n}8.57{]}χρειοῖ ἀναγκαίῃ, πρό τε παίδων καὶ πρὸ γυναικῶν.{l]
[l [n}8.58{]}πᾶσαι δʼ ὠΐγνυντο πύλαι, ἐκ δʼ ἔσσυτο λαός,{l]
[l [n}8.59{]}πεζοί θʼ ἱππῆές τε· πολὺς δʼ ὀρυμαγδὸς ὀρώρει.{l]{para]
[para}[l [n}8.60{]}οἳ δʼ ὅτε δή ῥʼ ἐς χῶρον ἕνα ξυνιόντες ἵκοντο{l]
[l [n}8.61{]}σύν ῥʼ ἔβαλον ῥινούς, σὺν δʼ ἔγχεα καὶ μένεʼ ἀνδρῶν{l]
[l [n}8.62{]}χαλκεοθωρήκων· ἀτὰρ ἀσπίδες ὀμφαλόεσσαι{l]
[l [n}8.63{]}ἔπληντʼ ἀλλήλῃσι, πολὺς δʼ ὀρυμαγδὸς ὀρώρει.{l]
[l [n}8.64{]}ἔνθα δʼ ἅμʼ οἰμωγή τε καὶ εὐχωλὴ πέλεν ἀνδρῶν{l]
[l [n}8.65{]}ὀλλύντων τε καὶ ὀλλυμένων, ῥέε δʼ αἵματι γαῖα.{l]{para]
[para}[l [n}8.66{]}ὄφρα μὲν ἠὼς ἦν καὶ ἀέξετο ἱερὸν ἦμαρ,{l]
[l [n}8.67{]}τόφρα μάλʼ ἀμφοτέρων βέλεʼ ἥπτετο, πῖπτε δὲ λαός.{l]
[l [n}8.68{]}ἦμος δʼ Ἠέλιος μέσον οὐρανὸν ἀμφιβεβήκει,{l]
[l [n}8.69{]}καὶ τότε δὴ χρύσεια πατὴρ ἐτίταινε τάλαντα·{l]
[l [n}8.70{]}ἐν δʼ ἐτίθει δύο κῆρε τανηλεγέος θανάτοιο{l]
[l [n}8.71{]}Τρώων θʼ ἱπποδάμων καὶ Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}8.72{]}ἕλκε δὲ μέσσα λαβών· ῥέπε δʼ αἴσιμον ἦμαρ Ἀχαιῶν.{l]
[l [n}8.73{]}αἳ μὲν Ἀχαιῶν κῆρες ἐπὶ χθονὶ πουλυβοτείρῃ{l]
[l [n}8.74{]}ἑζέσθην, Τρώων δὲ πρὸς οὐρανὸν εὐρὺν ἄερθεν·{l]
[l [n}8.75{]}αὐτὸς δʼ ἐξ Ἴδης μεγάλʼ ἔκτυπε, δαιόμενον δὲ{l]
[l [n}8.76{]}ἧκε σέλας μετὰ λαὸν Ἀχαιῶν· οἳ δὲ ἰδόντες{l]
[l [n}8.77{]}θάμβησαν, καὶ πάντας ὑπὸ χλωρὸν δέος εἷλεν.{l]{para]
[para}[l [n}8.78{]}ἔνθʼ οὔτʼ Ἰδομενεὺς τλῆ μίμνειν οὔτʼ Ἀγαμέμνων,{l]
[l [n}8.79{]}οὔτε δύʼ Αἴαντες μενέτην θεράποντες Ἄρηος·{l]
[l [n}8.80{]}Νέστωρ οἶος ἔμιμνε Γερήνιος οὖρος Ἀχαιῶν{l]
[l [n}8.81{]}οὔ τι ἑκών, ἀλλʼ ἵππος ἐτείρετο, τὸν βάλεν ἰῷ{l]
[l [n}8.82{]}δῖος Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο{l]
[l [n}8.83{]}ἄκρην κὰκ κορυφήν, ὅθι τε πρῶται τρίχες ἵππων{l]
[l [n}8.84{]}κρανίῳ ἐμπεφύασι, μάλιστα δὲ καίριόν ἐστιν.{l]
[l [n}8.85{]}ἀλγήσας δʼ ἀνέπαλτο, βέλος δʼ εἰς ἐγκέφαλον δῦ,{l]
[l [n}8.86{]}σὺν δʼ ἵππους ἐτάραξε κυλινδόμενος περὶ χαλκῷ.{l]
[l [n}8.87{]}ὄφρʼ ὁ γέρων ἵπποιο παρηορίας ἀπέταμνε{l]
[l [n}8.88{]}φασγάνῳ ἀΐσσων, τόφρʼ Ἕκτορος ὠκέες ἵπποι{l]
[l [n}8.89{]}ἦλθον ἀνʼ ἰωχμὸν θρασὺν ἡνίοχον φορέοντες{l]
[l [n}8.90{]}Ἕκτορα· καί νύ κεν ἔνθʼ ὁ γέρων ἀπὸ θυμὸν ὄλεσσεν{l]
[l [n}8.91{]}εἰ μὴ ἄρʼ ὀξὺ νόησε βοὴν ἀγαθὸς Διομήδης·{l]
[l [n}8.92{]}σμερδαλέον δʼ ἐβόησεν ἐποτρύνων Ὀδυσῆα·{l]
[q}[l [n}8.93{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}8.94{]}πῇ φεύγεις μετὰ νῶτα βαλὼν κακὸς ὣς ἐν ὁμίλῳ;{l]
[l [n}8.95{]}μή τίς τοι φεύγοντι μεταφρένῳ ἐν δόρυ πήξῃ·{l]
[l [n}8.96{]}ἀλλὰ μένʼ ὄφρα γέροντος ἀπώσομεν ἄγριον ἄνδρα.{l]{q]{para]
[para}[l [n}8.97{]}ὣς ἔφατʼ, οὐδʼ ἐσάκουσε πολύτλας δῖος Ὀδυσσεύς,{l]
[l [n}8.98{]}ἀλλὰ παρήϊξεν κοίλας ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}8.99{]}Τυδεΐδης δʼ αὐτός περ ἐὼν προμάχοισιν ἐμίχθη,{l]
[l [n}8.100{]}στῆ δὲ πρόσθʼ ἵππων Νηληϊάδαο γέροντος,{l]
[l [n}8.101{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}8.102{]}ὦ γέρον ἦ μάλα δή σε νέοι τείρουσι μαχηταί,{l]
[l [n}8.103{]}σὴ δὲ βίη λέλυται, χαλεπὸν δέ σε γῆρας ὀπάζει,{l]
[l [n}8.104{]}ἠπεδανὸς δέ νύ τοι θεράπων, βραδέες δέ τοι ἵπποι.{l]
[l [n}8.105{]}ἀλλʼ ἄγʼ ἐμῶν ὀχέων ἐπιβήσεο, ὄφρα ἴδηαι{l]
[l [n}8.106{]}οἷοι Τρώϊοι ἵπποι ἐπιστάμενοι πεδίοιο{l]
[l [n}8.107{]}κραιπνὰ μάλʼ ἔνθα καὶ ἔνθα διωκέμεν ἠδὲ φέβεσθαι,{l]
[l [n}8.108{]}οὕς ποτʼ ἀπʼ Αἰνείαν ἑλόμην μήστωρε φόβοιο.{l]
[l [n}8.109{]}τούτω μὲν θεράποντε κομείτων, τώδε δὲ νῶϊ{l]
[l [n}8.110{]}Τρωσὶν ἐφʼ ἱπποδάμοις ἰθύνομεν, ὄφρα καὶ Ἕκτωρ{l]
[l [n}8.111{]}εἴσεται εἰ καὶ ἐμὸν δόρυ μαίνεται ἐν παλάμῃσιν.{l]{q]{para]
[para}[l [n}8.112{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε Γερήνιος ἱππότα Νέστωρ.{l]
[l [n}8.113{]}Νεστορέας μὲν ἔπειθʼ ἵππους θεράποντε κομείτην{l]
[l [n}8.114{]}ἴφθιμοι Σθένελός τε καὶ Εὐρυμέδων ἀγαπήνωρ.{l]
[l [n}8.115{]}τὼ δʼ εἰς ἀμφοτέρω Διομήδεος ἅρματα βήτην·{l]
[l [n}8.116{]}Νέστωρ δʼ ἐν χείρεσσι λάβʼ ἡνία σιγαλόεντα,{l]
[l [n}8.117{]}μάστιξεν δʼ ἵππους· τάχα δʼ Ἕκτορος ἄγχι γένοντο.{l]
[l [n}8.118{]}τοῦ δʼ ἰθὺς μεμαῶτος ἀκόντισε Τυδέος υἱός·{l]
[l [n}8.119{]}καὶ τοῦ μέν ῥʼ ἀφάμαρτεν, ὃ δʼ ἡνίοχον θεράποντα{l]
[l [n}8.120{]}υἱὸν ὑπερθύμου Θηβαίου Ἠνιοπῆα{l]
[l [n}8.121{]}ἵππων ἡνίʼ ἔχοντα βάλε στῆθος παρὰ μαζόν.{l]
[l [n}8.122{]}ἤριπε δʼ ἐξ ὀχέων, ὑπερώησαν δέ οἱ ἵπποι{l]
[l [n}8.123{]}ὠκύποδες· τοῦ δʼ αὖθι λύθη ψυχή τε μένος τε.{l]
[l [n}8.124{]}Ἕκτορα δʼ αἰνὸν ἄχος πύκασε φρένας ἡνιόχοιο·{l]
[l [n}8.125{]}τὸν μὲν ἔπειτʼ εἴασε καὶ ἀχνύμενός περ ἑταίρου{l]
[l [n}8.126{]}κεῖσθαι, ὃ δʼ ἡνίοχον μέθεπε θρασύν· οὐδʼ ἄρʼ ἔτι δὴν{l]
[l [n}8.127{]}ἵππω δευέσθην σημάντορος· αἶψα γὰρ εὗρεν{l]
[l [n}8.128{]}Ἰφιτίδην Ἀρχεπτόλεμον θρασύν, ὅν ῥα τόθʼ ἵππων{l]
[l [n}8.129{]}ὠκυπόδων ἐπέβησε, δίδου δέ οἱ ἡνία χερσίν.{l]{para]
[para}[l [n}8.130{]}ἔνθά κε λοιγὸς ἔην καὶ ἀμήχανα ἔργα γένοντο,{l]
[l [n}8.131{]}καί νύ κε σήκασθεν κατὰ Ἴλιον ἠΰτε ἄρνες,{l]
[l [n}8.132{]}εἰ μὴ ἄρʼ ὀξὺ νόησε πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[l [n}8.133{]}βροντήσας δʼ ἄρα δεινὸν ἀφῆκʼ ἀργῆτα κεραυνόν,{l]
[l [n}8.134{]}κὰδ δὲ πρόσθʼ ἵππων Διομήδεος ἧκε χαμᾶζε·{l]
[l [n}8.135{]}δεινὴ δὲ φλὸξ ὦρτο θεείου καιομένοιο,{l]
[l [n}8.136{]}τὼ δʼ ἵππω δείσαντε καταπτήτην ὑπʼ ὄχεσφι·{l]
[l [n}8.137{]}Νέστορα δʼ ἐκ χειρῶν φύγον ἡνία σιγαλόεντα,{l]
[l [n}8.138{]}δεῖσε δʼ ὅ γʼ ἐν θυμῷ, Διομήδεα δὲ προσέειπε·{l]
[q}[l [n}8.139{]}Τυδεΐδη ἄγε δʼ αὖτε φόβον δʼ ἔχε μώνυχας ἵππους.{l]
[l [n}8.140{]}ἦ οὐ γιγνώσκεις ὅ τοι ἐκ Διὸς οὐχ ἕπετʼ ἀλκή;{l]
[l [n}8.141{]}νῦν μὲν γὰρ τούτῳ Κρονίδης Ζεὺς κῦδος ὀπάζει{l]
[l [n}8.142{]}σήμερον· ὕστερον αὖτε καὶ ἡμῖν, αἴ κʼ ἐθέλῃσι,{l]
[l [n}8.143{]}δώσει· ἀνὴρ δέ κεν οὔ τι Διὸς νόον εἰρύσσαιτο{l]
[l [n}8.144{]}οὐδὲ μάλʼ ἴφθιμος, ἐπεὶ ἦ πολὺ φέρτερός ἐστι.{l]{q]{para]
[para}[l [n}8.145{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}8.146{]}ναὶ δὴ ταῦτά γε πάντα γέρον κατὰ μοῖραν ἔειπες·{l]
[l [n}8.147{]}ἀλλὰ τόδʼ αἰνὸν ἄχος κραδίην καὶ θυμὸν ἱκάνει·{l]
[l [n}8.148{]}Ἕκτωρ γάρ ποτε φήσει ἐνὶ Τρώεσσʼ ἀγορεύων·{l]
[l [n}8.149{]}Τυδεΐδης ὑπʼ ἐμεῖο φοβεύμενος ἵκετο νῆας.{l]
[l [n}8.150{]}ὥς ποτʼ ἀπειλήσει· τότε μοι χάνοι εὐρεῖα χθών.{l]{q]{para]
[para}[l [n}8.151{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}8.152{]}ὤ μοι Τυδέος υἱὲ δαΐφρονος, οἷον ἔειπες.{l]
[l [n}8.153{]}εἴ περ γάρ σʼ Ἕκτωρ γε κακὸν καὶ ἀνάλκιδα φήσει,{l]
[l [n}8.154{]}ἀλλʼ οὐ πείσονται Τρῶες καὶ Δαρδανίωνες{l]
[l [n}8.155{]}καὶ Τρώων ἄλοχοι μεγαθύμων ἀσπιστάων,{l]
[l [n}8.156{]}τάων ἐν κονίῃσι βάλες θαλεροὺς παρακοίτας.{l]{q]{para]
[para}[l [n}8.157{]}ὣς ἄρα φωνήσας φύγαδε τράπε μώνυχας ἵππους{l]
[l [n}8.158{]}αὖτις ἀνʼ ἰωχμόν· ἐπὶ δὲ Τρῶές τε καὶ Ἕκτωρ{l]
[l [n}8.159{]}ἠχῇ θεσπεσίῃ βέλεα στονόεντα χέοντο.{l]
[l [n}8.160{]}τῷ δʼ ἐπὶ μακρὸν ἄϋσε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}8.161{]}Τυδεΐδη περὶ μέν σε τίον Δαναοὶ ταχύπωλοι{l]
[l [n}8.162{]}ἕδρῃ τε κρέασίν τε ἰδὲ πλείοις δεπάεσσι·{l]
[l [n}8.163{]}νῦν δέ σʼ ἀτιμήσουσι· γυναικὸς ἄρʼ ἀντὶ τέτυξο.{l]
[l [n}8.164{]}ἔρρε κακὴ γλήνη, ἐπεὶ οὐκ εἴξαντος ἐμεῖο{l]
[l [n}8.165{]}πύργων ἡμετέρων ἐπιβήσεαι, οὐδὲ γυναῖκας{l]
[l [n}8.166{]}ἄξεις ἐν νήεσσι· πάρος τοι δαίμονα δώσω.{l]{q]{para]
[para}[l [n}8.167{]}ὣς φάτο, Τυδεΐδης δὲ διάνδιχα μερμήριξεν{l]
[l [n}8.168{]}ἵππους τε στρέψαι καὶ ἐναντίβιον μαχέσασθαι.{l]
[l [n}8.169{]}τρὶς μὲν μερμήριξε κατὰ φρένα καὶ κατὰ θυμόν,{l]
[l [n}8.170{]}τρὶς δʼ ἄρʼ ἀπʼ Ἰδαίων ὀρέων κτύπε μητίετα Ζεὺς{l]
[l [n}8.171{]}σῆμα τιθεὶς Τρώεσσι μάχης ἑτεραλκέα νίκην.{l]
[l [n}8.172{]}Ἕκτωρ δὲ Τρώεσσιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}8.173{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταὶ{l]
[l [n}8.174{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς.{l]
[l [n}8.175{]}γιγνώσκω δʼ ὅτι μοι πρόφρων κατένευσε Κρονίων{l]
[l [n}8.176{]}νίκην καὶ μέγα κῦδος, ἀτὰρ Δαναοῖσί γε πῆμα·{l]
[l [n}8.177{]}νήπιοι οἳ ἄρα δὴ τάδε τείχεα μηχανόωντο{l]
[l [n}8.178{]}ἀβλήχρʼ οὐδενόσωρα· τὰ δʼ οὐ μένος ἁμὸν ἐρύξει·{l]
[l [n}8.179{]}ἵπποι δὲ ῥέα τάφρον ὑπερθορέονται ὀρυκτήν.{l]
[l [n}8.180{]}ἀλλʼ ὅτε κεν δὴ νηυσὶν ἔπι γλαφυρῇσι γένωμαι,{l]
[l [n}8.181{]}μνημοσύνη τις ἔπειτα πυρὸς δηΐοιο γενέσθω,{l]
[l [n}8.182{]}ὡς πυρὶ νῆας ἐνιπρήσω, κτείνω δὲ καὶ αὐτοὺς{l]
[l [n}8.183{]}Ἀργείους παρὰ νηυσὶν ἀτυζομένους ὑπὸ καπνοῦ.{l]{q]{para]
[para}[l [n}8.184{]}ὣς εἰπὼν ἵπποισιν ἐκέκλετο φώνησέν τε·{l]
[q}[l [n}8.185{]}Ξάνθέ τε καὶ σὺ Πόδαργε καὶ Αἴθων Λάμπέ τε δῖε{l]
[l [n}8.186{]}νῦν μοι τὴν κομιδὴν ἀποτίνετον, ἣν μάλα πολλὴν{l]
[l [n}8.187{]}Ἀνδρομάχη θυγάτηρ μεγαλήτορος Ἠετίωνος{l]
[l [n}8.188{]}ὑμῖν πὰρ προτέροισι μελίφρονα πυρὸν ἔθηκεν{l]
[l [n}8.189{]}οἶνόν τʼ ἐγκεράσασα πιεῖν, ὅτε θυμὸς ἀνώγοι,{l]
[l [n}8.190{]}ἢ ἐμοί, ὅς πέρ οἱ θαλερὸς πόσις εὔχομαι εἶναι.{l]
[l [n}8.191{]}ἀλλʼ ἐφομαρτεῖτον καὶ σπεύδετον ὄφρα λάβωμεν{l]
[l [n}8.192{]}ἀσπίδα Νεστορέην, τῆς νῦν κλέος οὐρανὸν ἵκει{l]
[l [n}8.193{]}πᾶσαν χρυσείην ἔμεναι, κανόνας τε καὶ αὐτήν,{l]
[l [n}8.194{]}αὐτὰρ ἀπʼ ὤμοιιν Διομήδεος ἱπποδάμοιο{l]
[l [n}8.195{]}δαιδάλεον θώρηκα, τὸν Ἥφαιστος κάμε τεύχων.{l]
[l [n}8.196{]}εἰ τούτω κε λάβοιμεν, ἐελποίμην κεν Ἀχαιοὺς{l]
[l [n}8.197{]}αὐτονυχὶ νηῶν ἐπιβησέμεν ὠκειάων.{l]{q]{para]
[para}[l [n}8.198{]}ὣς ἔφατʼ εὐχόμενος, νεμέσησε δὲ πότνια Ἥρη,{l]
[l [n}8.199{]}σείσατο δʼ εἰνὶ θρόνῳ, ἐλέλιξε δὲ μακρὸν Ὄλυμπον,{l]
[l [n}8.200{]}καί ῥα Ποσειδάωνα μέγαν θεὸν ἀντίον ηὔδα·{l]
[q}[l [n}8.201{]}ὢ πόποι ἐννοσίγαιʼ εὐρυσθενές, οὐδέ νυ σοί περ{l]
[l [n}8.202{]}ὀλλυμένων Δαναῶν ὀλοφύρεται ἐν φρεσὶ θυμός.{l]
[l [n}8.203{]}οἳ δέ τοι εἰς Ἑλίκην τε καὶ Αἰγὰς δῶρʼ ἀνάγουσι{l]
[l [n}8.204{]}πολλά τε καὶ χαρίεντα· σὺ δέ σφισι βούλεο νίκην.{l]
[l [n}8.205{]}εἴ περ γάρ κʼ ἐθέλοιμεν, ὅσοι Δαναοῖσιν ἀρωγοί,{l]
[l [n}8.206{]}Τρῶας ἀπώσασθαι καὶ ἐρυκέμεν εὐρύοπα Ζῆν,{l]
[l [n}8.207{]}αὐτοῦ κʼ ἔνθʼ ἀκάχοιτο καθήμενος οἶος ἐν Ἴδῃ.{l]{q]{para]
[para}[l [n}8.208{]}τὴν δὲ μέγʼ ὀχθήσας προσέφη κρείων ἐνοσίχθων·{l]
[q}[l [n}8.209{]}Ἥρη ἀπτοεπὲς ποῖον τὸν μῦθον ἔειπες.{l]
[l [n}8.210{]}οὐκ ἂν ἔγωγʼ ἐθέλοιμι Διὶ Κρονίωνι μάχεσθαι{l]
[l [n}8.211{]}ἡμέας τοὺς ἄλλους, ἐπεὶ ἦ πολὺ φέρτερός ἐστιν.{l]{q]{para]
[para}[l [n}8.212{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον·{l]
[l [n}8.213{]}τῶν δʼ ὅσον ἐκ νηῶν ἀπὸ πύργου τάφρος ἔεργε{l]
[l [n}8.214{]}πλῆθεν ὁμῶς ἵππων τε καὶ ἀνδρῶν ἀσπιστάων{l]
[l [n}8.215{]}εἰλομένων· εἴλει δὲ θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}8.216{]}Ἕκτωρ Πριαμίδης, ὅτε οἱ Ζεὺς κῦδος ἔδωκε.{l]
[l [n}8.217{]}καί νύ κʼ ἐνέπρησεν πυρὶ κηλέῳ νῆας ἐΐσας,{l]
[l [n}8.218{]}εἰ μὴ ἐπὶ φρεσὶ θῆκʼ Ἀγαμέμνονι πότνια Ἥρη{l]
[l [n}8.219{]}αὐτῷ ποιπνύσαντι θοῶς ὀτρῦναι Ἀχαιούς.{l]
[l [n}8.220{]}βῆ δʼ ἰέναι παρά τε κλισίας καὶ νῆας Ἀχαιῶν{l]
[l [n}8.221{]}πορφύρεον μέγα φᾶρος ἔχων ἐν χειρὶ παχείῃ,{l]
[l [n}8.222{]}στῆ δʼ ἐπʼ Ὀδυσσῆος μεγακήτεϊ νηῒ μελαίνῃ,{l]
[l [n}8.223{]}ἥ ῥʼ ἐν μεσσάτῳ ἔσκε γεγωνέμεν ἀμφοτέρωσε,{l]
[l [n}8.224{]}ἠμὲν ἐπʼ Αἴαντος κλισίας Τελαμωνιάδαο{l]
[l [n}8.225{]}ἠδʼ ἐπʼ Ἀχιλλῆος, τοί ῥʼ ἔσχατα νῆας ἐΐσας{l]
[l [n}8.226{]}εἴρυσαν, ἠνορέῃ πίσυνοι καὶ κάρτεϊ χειρῶν·{l]
[l [n}8.227{]}ἤϋσεν δὲ διαπρύσιον Δαναοῖσι γεγωνώς·{l]
[q}[l [n}8.228{]}αἰδὼς Ἀργεῖοι, κάκʼ ἐλέγχεα, εἶδος ἀγητοί·{l]
[l [n}8.229{]}πῇ ἔβαν εὐχωλαί, ὅτε δὴ φάμεν εἶναι ἄριστοι,{l]
[l [n}8.230{]}ἃς ὁπότʼ ἐν Λήμνῳ κενεαυχέες ἠγοράασθε,{l]
[l [n}8.231{]}ἔσθοντες κρέα πολλὰ βοῶν ὀρθοκραιράων{l]
[l [n}8.232{]}πίνοντες κρητῆρας ἐπιστεφέας οἴνοιο,{l]
[l [n}8.233{]}Τρώων ἄνθʼ ἑκατόν τε διηκοσίων τε ἕκαστος{l]
[l [n}8.234{]}στήσεσθʼ ἐν πολέμῳ· νῦν δʼ οὐδʼ ἑνὸς ἄξιοί εἰμεν{l]
[l [n}8.235{]}Ἕκτορος, ὃς τάχα νῆας ἐνιπρήσει πυρὶ κηλέῳ.{l]
[l [n}8.236{]}Ζεῦ πάτερ, ἦ ῥά τινʼ ἤδη ὑπερμενέων βασιλήων{l]
[l [n}8.237{]}τῇδʼ ἄτῃ ἄασας καί μιν μέγα κῦδος ἀπηύρας;{l]
[l [n}8.238{]}οὐ μὲν δή ποτέ φημι τεὸν περικαλλέα βωμὸν{l]
[l [n}8.239{]}νηῒ πολυκλήϊδι παρελθέμεν ἐνθάδε ἔρρων,{l]
[l [n}8.240{]}ἀλλʼ ἐπὶ πᾶσι βοῶν δημὸν καὶ μηρίʼ ἔκηα{l]
[l [n}8.241{]}ἱέμενος Τροίην εὐτείχεον ἐξαλαπάξαι.{l]
[l [n}8.242{]}ἀλλὰ Ζεῦ τόδε πέρ μοι ἐπικρήηνον ἐέλδωρ·{l]
[l [n}8.243{]}αὐτοὺς δή περ ἔασον ὑπεκφυγέειν καὶ ἀλύξαι,{l]
[l [n}8.244{]}μηδʼ οὕτω Τρώεσσιν ἔα δάμνασθαι Ἀχαιούς.{l]{q]{para]
[para}[l [n}8.245{]}ὣς φάτο, τὸν δὲ πατὴρ ὀλοφύρατο δάκρυ χέοντα,{l]
[l [n}8.246{]}νεῦσε δέ οἱ λαὸν σόον ἔμμεναι οὐδʼ ἀπολέσθαι.{l]
[l [n}8.247{]}αὐτίκα δʼ αἰετὸν ἧκε τελειότατον πετεηνῶν,{l]
[l [n}8.248{]}νεβρὸν ἔχοντʼ ὀνύχεσσι τέκος ἐλάφοιο ταχείης·{l]
[l [n}8.249{]}πὰρ δὲ Διὸς βωμῷ περικαλλέϊ κάββαλε νεβρόν,{l]
[l [n}8.250{]}ἔνθα πανομφαίῳ Ζηνὶ ῥέζεσκον Ἀχαιοί.{l]
[l [n}8.251{]}οἳ δʼ ὡς οὖν εἴδονθʼ ὅ τʼ ἄρʼ ἐκ Διὸς ἤλυθεν ὄρνις,{l]
[l [n}8.252{]}μᾶλλον ἐπὶ Τρώεσσι θόρον, μνήσαντο δὲ χάρμης.{l]{para]
[para}[l [n}8.253{]}ἔνθʼ οὔ τις πρότερος Δαναῶν πολλῶν περ ἐόντων{l]
[l [n}8.254{]}εὔξατο Τυδεΐδαο πάρος σχέμεν ὠκέας ἵππους{l]
[l [n}8.255{]}τάφρου τʼ ἐξελάσαι καὶ ἐναντίβιον μαχέσασθαι,{l]
[l [n}8.256{]}ἀλλὰ πολὺ πρῶτος Τρώων ἕλεν ἄνδρα κορυστὴν{l]
[l [n}8.257{]}Φραδμονίδην Ἀγέλαον· ὃ μὲν φύγαδʼ ἔτραπεν ἵππους·{l]
[l [n}8.258{]}τῷ δὲ μεταστρεφθέντι μεταφρένῳ ἐν δόρυ πῆξεν{l]
[l [n}8.259{]}ὤμων μεσσηγύς, διὰ δὲ στήθεσφιν ἔλασσεν·{l]
[l [n}8.260{]}ἤριπε δʼ ἐξ ὀχέων, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]{para]
[para}[l [n}8.261{]}τὸν δὲ μετʼ Ἀτρεΐδαι Ἀγαμέμνων καὶ Μενέλαος,{l]
[l [n}8.262{]}τοῖσι δʼ ἐπʼ Αἴαντες θοῦριν ἐπιειμένοι ἀλκήν,{l]
[l [n}8.263{]}τοῖσι δʼ ἐπʼ Ἰδομενεὺς καὶ ὀπάων Ἰδομενῆος{l]
[l [n}8.264{]}Μηριόνης ἀτάλαντος Ἐνυαλίῳ ἀνδρειφόντῃ,{l]
[l [n}8.265{]}τοῖσι δʼ ἐπʼ Εὐρύπυλος Εὐαίμονος ἀγλαὸς υἱός·{l]
[l [n}8.266{]}Τεῦκρος δʼ εἴνατος ἦλθε παλίντονα τόξα τιταίνων,{l]
[l [n}8.267{]}στῆ δʼ ἄρʼ ὑπʼ Αἴαντος σάκεϊ Τελαμωνιάδαο.{l]
[l [n}8.268{]}ἔνθʼ Αἴας μὲν ὑπεξέφερεν σάκος· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}8.269{]}παπτήνας, ἐπεὶ ἄρ τινʼ ὀϊστεύσας ἐν ὁμίλῳ{l]
[l [n}8.270{]}βεβλήκοι, ὃ μὲν αὖθι πεσὼν ἀπὸ θυμὸν ὄλεσσεν,{l]
[l [n}8.271{]}αὐτὰρ ὃ αὖτις ἰὼν πάϊς ὣς ὑπὸ μητέρα δύσκεν{l]
[l [n}8.272{]}εἰς Αἴανθʼ· ὃ δέ μιν σάκεϊ κρύπτασκε φαεινῷ.{l]{para]
[para}[l [n}8.273{]}ἔνθα τίνα πρῶτον Τρώων ἕλε Τεῦκρος ἀμύμων;{l]
[l [n}8.274{]}Ὀρσίλοχον μὲν πρῶτα καὶ Ὄρμενον ἠδʼ Ὀφελέστην{l]
[l [n}8.275{]}Δαίτορά τε Χρομίον τε καὶ ἀντίθεον Λυκοφόντην{l]
[l [n}8.276{]}καὶ Πολυαιμονίδην Ἀμοπάονα καὶ Μελάνιππον,{l]
[l [n}8.277{]}πάντας ἐπασσυτέρους πέλασε χθονὶ πουλυβοτείρῃ.{l]
[l [n}8.278{]}τὸν δὲ ἰδὼν γήθησεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}8.279{]}τόξου ἄπο κρατεροῦ Τρώων ὀλέκοντα φάλαγγας·{l]
[l [n}8.280{]}στῆ δὲ παρʼ αὐτὸν ἰὼν καί μιν πρὸς μῦθον ἔειπε·{l]
[q}[l [n}8.281{]}Τεῦκρε φίλη κεφαλή, Τελαμώνιε κοίρανε λαῶν{l]
[l [n}8.282{]}βάλλʼ οὕτως, αἴ κέν τι φόως Δαναοῖσι γένηαι{l]
[l [n}8.283{]}πατρί τε σῷ Τελαμῶνι, ὅ σʼ ἔτρεφε τυτθὸν ἐόντα,{l]
[l [n}8.284{]}καί σε νόθον περ ἐόντα κομίσσατο ᾧ ἐνὶ οἴκῳ·{l]
[l [n}8.285{]}τὸν καὶ τηλόθʼ ἐόντα ἐϋκλείης ἐπίβησον.{l]
[l [n}8.286{]}σοὶ δʼ ἐγὼ ἐξερέω ὡς καὶ τετελεσμένον ἔσται·{l]
[l [n}8.287{]}αἴ κέν μοι δώῃ Ζεύς τʼ αἰγίοχος καὶ Ἀθήνη{l]
[l [n}8.288{]}Ἰλίου ἐξαλαπάξαι ἐϋκτίμενον πτολίεθρον,{l]
[l [n}8.289{]}πρώτῳ τοι μετʼ ἐμὲ πρεσβήϊον ἐν χερὶ θήσω,{l]
[l [n}8.290{]}ἢ τρίποδʼ ἠὲ δύω ἵππους αὐτοῖσιν ὄχεσφιν{l]
[l [n}8.291{]}ἠὲ γυναῖχʼ, ἥ κέν τοι ὁμὸν λέχος εἰσαναβαίνοι.{l]{q]{para]
[para}[l [n}8.292{]}τὸν δʼ ἀπαμειβόμενος προσεφώνεε Τεῦκρος ἀμύμων·{l]
[q}[l [n}8.293{]}Ἀτρεΐδη κύδιστε τί με σπεύδοντα καὶ αὐτὸν{l]
[l [n}8.294{]}ὀτρύνεις; οὐ μέν τοι ὅση δύναμίς γε πάρεστι{l]
[l [n}8.295{]}παύομαι, ἀλλʼ ἐξ οὗ προτὶ Ἴλιον ὠσάμεθʼ αὐτοὺς{l]
[l [n}8.296{]}ἐκ τοῦ δὴ τόξοισι δεδεγμένος ἄνδρας ἐναίρω.{l]
[l [n}8.297{]}ὀκτὼ δὴ προέηκα τανυγλώχινας ὀϊστούς,{l]
[l [n}8.298{]}πάντες δʼ ἐν χροῒ πῆχθεν ἀρηϊθόων αἰζηῶν·{l]
[l [n}8.299{]}τοῦτον δʼ οὐ δύναμαι βαλέειν κύνα λυσσητῆρα.{l]{q]{para]
[para}[l [n}8.300{]}ἦ ῥα καὶ ἄλλον ὀϊστὸν ἀπὸ νευρῆφιν ἴαλλεν{l]
[l [n}8.301{]}Ἕκτορος ἀντικρύ, βαλέειν δέ ἑ ἵετο θυμός·{l]
[l [n}8.302{]}καὶ τοῦ μέν ῥʼ ἀφάμαρθʼ, ὃ δʼ ἀμύμονα Γοργυθίωνα{l]
[l [n}8.303{]}υἱὸν ἐῢν Πριάμοιο κατὰ στῆθος βάλεν ἰῷ,{l]
[l [n}8.304{]}τόν ῥʼ ἐξ Αἰσύμηθεν ὀπυιομένη τέκε μήτηρ{l]
[l [n}8.305{]}καλὴ Καστιάνειρα δέμας ἐϊκυῖα θεῇσι.{l]
[l [n}8.306{]}μήκων δʼ ὡς ἑτέρωσε κάρη βάλεν, ἥ τʼ ἐνὶ κήπῳ{l]
[l [n}8.307{]}καρπῷ βριθομένη νοτίῃσί τε εἰαρινῇσιν,{l]
[l [n}8.308{]}ὣς ἑτέρωσʼ ἤμυσε κάρη πήληκι βαρυνθέν.{l]{para]
[para}[l [n}8.309{]}Τεῦκρος δʼ ἄλλον ὀϊστὸν ἀπὸ νευρῆφιν ἴαλλεν{l]
[l [n}8.310{]}Ἕκτορος ἀντικρύ, βαλέειν δέ ἑ ἵετο θυμός.{l]
[l [n}8.311{]}ἀλλʼ ὅ γε καὶ τόθʼ ἅμαρτε· παρέσφηλεν γὰρ Ἀπόλλων·{l]
[l [n}8.312{]}ἀλλʼ Ἀρχεπτόλεμον θρασὺν Ἕκτορος ἡνιοχῆα{l]
[l [n}8.313{]}ἱέμενον πόλεμον δὲ βάλε στῆθος παρὰ μαζόν·{l]
[l [n}8.314{]}ἤριπε δʼ ἐξ ὀχέων, ὑπερώησαν δέ οἱ ἵπποι{l]
[l [n}8.315{]}ὠκύποδες· τοῦ δʼ αὖθι λύθη ψυχή τε μένος τε.{l]
[l [n}8.316{]}Ἕκτορα δʼ αἰνὸν ἄχος πύκασε φρένας ἡνιόχοιο·{l]
[l [n}8.317{]}τὸν μὲν ἔπειτʼ εἴασε καὶ ἀχνύμενός περ ἑταίρου,{l]
[l [n}8.318{]}Κεβριόνην δʼ ἐκέλευσεν ἀδελφεὸν ἐγγὺς ἐόντα{l]
[l [n}8.319{]}ἵππων ἡνίʼ ἑλεῖν· ὃ δʼ ἄρʼ οὐκ ἀπίθησεν ἀκούσας.{l]
[l [n}8.320{]}αὐτὸς δʼ ἐκ δίφροιο χαμαὶ θόρε παμφανόωντος{l]
[l [n}8.321{]}σμερδαλέα ἰάχων· ὃ δὲ χερμάδιον λάβε χειρί,{l]
[l [n}8.322{]}βῆ δʼ ἰθὺς Τεύκρου, βαλέειν δέ ἑ θυμὸς ἀνώγει.{l]
[l [n}8.323{]}ἤτοι ὃ μὲν φαρέτρης ἐξείλετο πικρὸν ὀϊστόν,{l]
[l [n}8.324{]}θῆκε δʼ ἐπὶ νευρῇ· τὸν δʼ αὖ κορυθαίολος Ἕκτωρ{l]
[l [n}8.325{]}αὐερύοντα παρʼ ὦμον, ὅθι κληῒς ἀποέργει{l]
[l [n}8.326{]}αὐχένα τε στῆθός τε, μάλιστα δὲ καίριόν ἐστι,{l]
[l [n}8.327{]}τῇ ῥʼ ἐπὶ οἷ μεμαῶτα βάλεν λίθῳ ὀκριόεντι,{l]
[l [n}8.328{]}ῥῆξε δέ οἱ νευρήν· νάρκησε δὲ χεὶρ ἐπὶ καρπῷ,{l]
[l [n}8.329{]}στῆ δὲ γνὺξ ἐριπών, τόξον δέ οἱ ἔκπεσε χειρός.{l]
[l [n}8.330{]}Αἴας δʼ οὐκ ἀμέλησε κασιγνήτοιο πεσόντος,{l]
[l [n}8.331{]}ἀλλὰ θέων περίβη καί οἱ σάκος ἀμφεκάλυψε.{l]
[l [n}8.332{]}τὸν μὲν ἔπειθʼ ὑποδύντε δύω ἐρίηρες ἑταῖροι{l]
[l [n}8.333{]}Μηκιστεὺς Ἐχίοιο πάϊς καὶ δῖος Ἀλάστωρ{l]
[l [n}8.334{]}νῆας ἔπι γλαφυρὰς φερέτην βαρέα στενάχοντα.{l]{para]
[para}[l [n}8.335{]}ἂψ δʼ αὖτις Τρώεσσιν Ὀλύμπιος ἐν μένος ὦρσεν·{l]
[l [n}8.336{]}οἳ δʼ ἰθὺς τάφροιο βαθείης ὦσαν Ἀχαιούς·{l]
[l [n}8.337{]}Ἕκτωρ δʼ ἐν πρώτοισι κίε σθένεϊ βλεμεαίνων.{l]
[l [n}8.338{]}ὡς δʼ ὅτε τίς τε κύων συὸς ἀγρίου ἠὲ λέοντος{l]
[l [n}8.339{]}ἅπτηται κατόπισθε ποσὶν ταχέεσσι διώκων{l]
[l [n}8.340{]}ἰσχία τε γλουτούς τε, ἑλισσόμενόν τε δοκεύει,{l]
[l [n}8.341{]}ὣς Ἕκτωρ ὤπαζε κάρη κομόωντας Ἀχαιούς,{l]
[l [n}8.342{]}αἰὲν ἀποκτείνων τὸν ὀπίστατον· οἳ δὲ φέβοντο.{l]
[l [n}8.343{]}αὐτὰρ ἐπεὶ διά τε σκόλοπας καὶ τάφρον ἔβησαν{l]
[l [n}8.344{]}φεύγοντες, πολλοὶ δὲ δάμεν Τρώων ὑπὸ χερσίν,{l]
[l [n}8.345{]}οἳ μὲν δὴ παρὰ νηυσὶν ἐρητύοντο μένοντες,{l]
[l [n}8.346{]}ἀλλήλοισί τε κεκλόμενοι καὶ πᾶσι θεοῖσι{l]
[l [n}8.347{]}χεῖρας ἀνίσχοντες μεγάλʼ εὐχετόωντο ἕκαστος·{l]
[l [n}8.348{]}Ἕκτωρ δʼ ἀμφιπεριστρώφα καλλίτριχας ἵππους{l]
[l [n}8.349{]}Γοργοῦς ὄμματʼ ἔχων ἠδὲ βροτολοιγοῦ Ἄρηος.{l]{para]
[para}[l [n}8.350{]}τοὺς δὲ ἰδοῦσʼ ἐλέησε θεὰ λευκώλενος Ἥρη,{l]
[l [n}8.351{]}αἶψα δʼ Ἀθηναίην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}8.352{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος οὐκέτι νῶϊ{l]
[l [n}8.353{]}ὀλλυμένων Δαναῶν κεκαδησόμεθʼ ὑστάτιόν περ;{l]
[l [n}8.354{]}οἵ κεν δὴ κακὸν οἶτον ἀναπλήσαντες ὄλωνται{l]
[l [n}8.355{]}ἀνδρὸς ἑνὸς ῥιπῇ, ὃ δὲ μαίνεται οὐκέτʼ ἀνεκτῶς{l]
[l [n}8.356{]}Ἕκτωρ Πριαμίδης, καὶ δὴ κακὰ πολλὰ ἔοργε.{l]{q]{para]
[para}[l [n}8.357{]}τὴν δʼ αὖτε προσέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}8.358{]}καὶ λίην οὗτός γε μένος θυμόν τʼ ὀλέσειε{l]
[l [n}8.359{]}χερσὶν ὑπʼ Ἀργείων φθίμενος ἐν πατρίδι γαίῃ·{l]
[l [n}8.360{]}ἀλλὰ πατὴρ οὑμὸς φρεσὶ μαίνεται οὐκ ἀγαθῇσι{l]
[l [n}8.361{]}σχέτλιος, αἰὲν ἀλιτρός, ἐμῶν μενέων ἀπερωεύς·{l]
[l [n}8.362{]}οὐδέ τι τῶν μέμνηται, ὅ οἱ μάλα πολλάκις υἱὸν{l]
[l [n}8.363{]}τειρόμενον σώεσκον ὑπʼ Εὐρυσθῆος ἀέθλων.{l]
[l [n}8.364{]}ἤτοι ὃ μὲν κλαίεσκε πρὸς οὐρανόν, αὐτὰρ ἐμὲ Ζεὺς{l]
[l [n}8.365{]}τῷ ἐπαλεξήσουσαν ἀπʼ οὐρανόθεν προΐαλλεν.{l]
[l [n}8.366{]}εἰ γὰρ ἐγὼ τάδε ᾔδεʼ ἐνὶ φρεσὶ πευκαλίμῃσιν{l]
[l [n}8.367{]}εὖτέ μιν εἰς Ἀΐδαο πυλάρταο προὔπεμψεν{l]
[l [n}8.368{]}ἐξ Ἐρέβευς ἄξοντα κύνα στυγεροῦ Ἀΐδαο,{l]
[l [n}8.369{]}οὐκ ἂν ὑπεξέφυγε Στυγὸς ὕδατος αἰπὰ ῥέεθρα.{l]
[l [n}8.370{]}νῦν δʼ ἐμὲ μὲν στυγέει, Θέτιδος δʼ ἐξήνυσε βουλάς,{l]
[l [n}8.371{]}ἥ οἱ γούνατʼ ἔκυσσε καὶ ἔλλαβε χειρὶ γενείου,{l]
[l [n}8.372{]}λισσομένη τιμῆσαι Ἀχιλλῆα πτολίπορθον.{l]
[l [n}8.373{]}ἔσται μὰν ὅτʼ ἂν αὖτε φίλην γλαυκώπιδα εἴπῃ.{l]
[l [n}8.374{]}ἀλλὰ σὺ μὲν νῦν νῶϊν ἐπέντυε μώνυχας ἵππους,{l]
[l [n}8.375{]}ὄφρʼ ἂν ἐγὼ καταδῦσα Διὸς δόμον αἰγιόχοιο{l]
[l [n}8.376{]}τεύχεσιν ἐς πόλεμον θωρήξομαι, ὄφρα ἴδωμαι{l]
[l [n}8.377{]}ἢ νῶϊ Πριάμοιο πάϊς κορυθαίολος Ἕκτωρ{l]
[l [n}8.378{]}γηθήσει προφανέντε ἀνὰ πτολέμοιο γεφύρας,{l]
[l [n}8.379{]}ἦ τις καὶ Τρώων κορέει κύνας ἠδʼ οἰωνοὺς{l]
[l [n}8.380{]}δημῷ καὶ σάρκεσσι, πεσὼν ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}8.381{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ λευκώλενος Ἥρη.{l]
[l [n}8.382{]}ἣ μὲν ἐποιχομένη χρυσάμπυκας ἔντυεν ἵππους{l]
[l [n}8.383{]}Ἥρη πρέσβα θεὰ θυγάτηρ μεγάλοιο Κρόνοιο·{l]
[l [n}8.384{]}αὐτὰρ Ἀθηναίη κούρη Διὸς αἰγιόχοιο{l]
[l [n}8.385{]}πέπλον μὲν κατέχευεν ἑανὸν πατρὸς ἐπʼ οὔδει{l]
[l [n}8.386{]}ποικίλον, ὅν ῥʼ αὐτὴ ποιήσατο καὶ κάμε χερσίν,{l]
[l [n}8.387{]}ἣ δὲ χιτῶνʼ ἐνδῦσα Διὸς νεφεληγερέταο{l]
[l [n}8.388{]}τεύχεσιν ἐς πόλεμον θωρήσσετο δακρυόεντα.{l]
[l [n}8.389{]}ἐς δʼ ὄχεα φλόγεα ποσὶ βήσετο, λάζετο δʼ ἔγχος{l]
[l [n}8.390{]}βριθὺ μέγα στιβαρόν, τῷ δάμνησι στίχας ἀνδρῶν{l]
[l [n}8.391{]}ἡρώων, τοῖσίν τε κοτέσσεται ὀβριμοπάτρη.{l]
[l [n}8.392{]}Ἥρη δὲ μάστιγι θοῶς ἐπεμαίετʼ ἄρʼ ἵππους·{l]
[l [n}8.393{]}αὐτόμαται δὲ πύλαι μύκον οὐρανοῦ ἃς ἔχον Ὧραι,{l]
[l [n}8.394{]}τῇς ἐπιτέτραπται μέγας οὐρανὸς Οὔλυμπός τε{l]
[l [n}8.395{]}ἠμὲν ἀνακλῖναι πυκινὸν νέφος ἠδʼ ἐπιθεῖναι.{l]
[l [n}8.396{]}τῇ ῥα διʼ αὐτάων κεντρηνεκέας ἔχον ἵππους.{l]{para]
[para}[l [n}8.397{]}Ζεὺς δὲ πατὴρ Ἴδηθεν ἐπεὶ ἴδε χώσατʼ ἄρʼ αἰνῶς,{l]
[l [n}8.398{]}Ἶριν δʼ ὄτρυνε χρυσόπτερον ἀγγελέουσαν·{l]
[q}[l [n}8.399{]}βάσκʼ ἴθι Ἶρι ταχεῖα, πάλιν τρέπε μηδʼ ἔα ἄντην{l]
[l [n}8.400{]}ἔρχεσθʼ· οὐ γὰρ καλὰ συνοισόμεθα πτόλεμον δέ.{l]
[l [n}8.401{]}ὧδε γὰρ ἐξερέω, τὸ δὲ καὶ τετελεσμένον ἔσται·{l]
[l [n}8.402{]}γυιώσω μέν σφωϊν ὑφʼ ἅρμασιν ὠκέας ἵππους,{l]
[l [n}8.403{]}αὐτὰς δʼ ἐκ δίφρου βαλέω κατά θʼ ἅρματα ἄξω·{l]
[l [n}8.404{]}οὐδέ κεν ἐς δεκάτους περιτελλομένους ἐνιαυτοὺς{l]
[l [n}8.405{]}ἕλκεʼ ἀπαλθήσεσθον, ἅ κεν μάρπτῃσι κεραυνός·{l]
[l [n}8.406{]}ὄφρα ἰδῇ γλαυκῶπις ὅτʼ ἂν ᾧ πατρὶ μάχηται.{l]
[l [n}8.407{]}Ἥρῃ δʼ οὔ τι τόσον νεμεσίζομαι οὐδὲ χολοῦμαι·{l]
[l [n}8.408{]}αἰεὶ γάρ μοι ἔωθεν ἐνικλᾶν ὅττί κεν εἴπω.{l]{q]{para]
[para}[l [n}8.409{]}ὣς ἔφατʼ, ὦρτο δὲ Ἶρις ἀελλόπος ἀγγελέουσα,{l]
[l [n}8.410{]}βῆ δʼ ἐξ Ἰδαίων ὀρέων ἐς μακρὸν Ὄλυμπον.{l]
[l [n}8.411{]}πρώτῃσιν δὲ πύλῃσι πολυπτύχου Οὐλύμποιο{l]
[l [n}8.412{]}ἀντομένη κατέρυκε, Διὸς δέ σφʼ ἔννεπε μῦθον·{l]
[q}[l [n}8.413{]}πῇ μέματον; τί σφῶϊν ἐνὶ φρεσὶ μαίνεται ἦτορ;{l]
[l [n}8.414{]}οὐκ ἐάᾳ Κρονίδης ἐπαμυνέμεν Ἀργείοισιν.{l]
[l [n}8.415{]}ὧδε γὰρ ἠπείλησε Κρόνου πάϊς, ᾗ τελέει περ,{l]
[l [n}8.416{]}γυιώσειν μὲν σφῶϊν ὑφʼ ἅρμασιν ὠκέας ἵππους,{l]
[l [n}8.417{]}αὐτὰς δʼ ἐκ δίφρου βαλέειν κατά θʼ ἅρματα ἄξειν·{l]
[l [n}8.418{]}οὐδέ κεν ἐς δεκάτους περιτελλομένους ἐνιαυτοὺς{l]
[l [n}8.419{]}ἕλκεʼ ἀπαλθήσεσθον, ἅ κεν μάρπτῃσι κεραυνός·{l]
[l [n}8.420{]}ὄφρα ἰδῇς γλαυκῶπι ὅτʼ ἂν σῷ πατρὶ μάχηαι.{l]
[l [n}8.421{]}Ἥρῃ δʼ οὔ τι τόσον νεμεσίζεται οὐδὲ χολοῦται·{l]
[l [n}8.422{]}αἰεὶ γάρ οἱ ἔωθεν ἐνικλᾶν ὅττι κεν εἴπῃ·{l]
[l [n}8.423{]}ἀλλὰ σύ γʼ αἰνοτάτη κύον ἀδεὲς εἰ ἐτεόν γε{l]
[l [n}8.424{]}τολμήσεις Διὸς ἄντα πελώριον ἔγχος ἀεῖραι.{l]{q]{para]
[para}[l [n}8.425{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπέβη πόδας ὠκέα Ἶρις,{l]
[l [n}8.426{]}αὐτὰρ Ἀθηναίην Ἥρη πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}8.427{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος, οὐκέτʼ ἔγωγε{l]
[l [n}8.428{]}νῶϊ ἐῶ Διὸς ἄντα βροτῶν ἕνεκα πτολεμίζειν·{l]
[l [n}8.429{]}τῶν ἄλλος μὲν ἀποφθίσθω, ἄλλος δὲ βιώτω,{l]
[l [n}8.430{]}ὅς κε τύχῃ· κεῖνος δὲ τὰ ἃ φρονέων ἐνὶ θυμῷ{l]
[l [n}8.431{]}Τρωσί τε καὶ Δαναοῖσι δικαζέτω, ὡς ἐπιεικές.{l]{q]{para]
[para}[l [n}8.432{]}ὣς ἄρα φωνήσασα πάλιν τρέπε μώνυχας ἵππους·{l]
[l [n}8.433{]}τῇσιν δʼ Ὧραι μὲν λῦσαν καλλίτριχας ἵππους,{l]
[l [n}8.434{]}καὶ τοὺς μὲν κατέδησαν ἐπʼ ἀμβροσίῃσι κάπῃσιν,{l]
[l [n}8.435{]}ἅρματα δʼ ἔκλιναν πρὸς ἐνώπια παμφανόωντα·{l]
[l [n}8.436{]}αὐταὶ δὲ χρυσέοισιν ἐπὶ κλισμοῖσι κάθιζον{l]
[l [n}8.437{]}μίγδʼ ἄλλοισι θεοῖσι, φίλον τετιημέναι ἦτορ.{l]{para]
[para}[l [n}8.438{]}Ζεὺς δὲ πατὴρ Ἴδηθεν ἐΰτροχον ἅρμα καὶ ἵππους{l]
[l [n}8.439{]}Οὔλυμπον δὲ δίωκε, θεῶν δʼ ἐξίκετο θώκους.{l]
[l [n}8.440{]}τῷ δὲ καὶ ἵππους μὲν λῦσε κλυτὸς ἐννοσίγαιος,{l]
[l [n}8.441{]}ἅρματα δʼ ἂμ βωμοῖσι τίθει κατὰ λῖτα πετάσσας·{l]
[l [n}8.442{]}αὐτὸς δὲ χρύσειον ἐπὶ θρόνον εὐρύοπα Ζεὺς{l]
[l [n}8.443{]}ἕζετο, τῷ δʼ ὑπὸ ποσσὶ μέγας πελεμίζετʼ Ὄλυμπος.{l]
[l [n}8.444{]}αἳ δʼ οἶαι Διὸς ἀμφὶς Ἀθηναίη τε καὶ Ἥρη{l]
[l [n}8.445{]}ἥσθην, οὐδέ τί μιν προσεφώνεον οὐδʼ ἐρέοντο·{l]
[l [n}8.446{]}αὐτὰρ ὃ ἔγνω ᾗσιν ἐνὶ φρεσὶ φώνησέν τε·{l]
[q}[l [n}8.447{]}τίφθʼ οὕτω τετίησθον Ἀθηναίη τε καὶ Ἥρη;{l]
[l [n}8.448{]}οὐ μέν θην κάμετόν γε μάχῃ ἔνι κυδιανείρῃ{l]
[l [n}8.449{]}ὀλλῦσαι Τρῶας, τοῖσιν κότον αἰνὸν ἔθεσθε.{l]
[l [n}8.450{]}πάντως, οἷον ἐμόν γε μένος καὶ χεῖρες ἄαπτοι,{l]
[l [n}8.451{]}οὐκ ἄν με τρέψειαν ὅσοι θεοί εἰσʼ ἐν Ὀλύμπῳ.{l]
[l [n}8.452{]}σφῶϊν δὲ πρίν περ τρόμος ἔλλαβε φαίδιμα γυῖα{l]
[l [n}8.453{]}πρὶν πόλεμόν τε ἰδεῖν πολέμοιό τε μέρμερα ἔργα.{l]
[l [n}8.454{]}ὧδε γὰρ ἐξερέω, τὸ δέ κεν τετελεσμένον ἦεν·{l]
[l [n}8.455{]}οὐκ ἂν ἐφʼ ὑμετέρων ὀχέων πληγέντε κεραυνῷ{l]
[l [n}8.456{]}ἂψ ἐς Ὄλυμπον ἵκεσθον, ἵνʼ ἀθανάτων ἕδος ἐστίν.{l]{q]{para]
[para}[l [n}8.457{]}ὣς ἔφαθʼ, αἳ δʼ ἐπέμυξαν Ἀθηναίη τε καὶ Ἥρη·{l]
[l [n}8.458{]}πλησίαι αἵ γʼ ἥσθην, κακὰ δὲ Τρώεσσι μεδέσθην.{l]
[l [n}8.459{]}ἤτοι Ἀθηναίη ἀκέων ἦν οὐδέ τι εἶπε{l]
[l [n}8.460{]}σκυζομένη Διὶ πατρί, χόλος δέ μιν ἄγριος ᾕρει·{l]
[l [n}8.461{]}Ἥρῃ δʼ οὐκ ἔχαδε στῆθος χόλον, ἀλλὰ προσηύδα·{l]
[q}[l [n}8.462{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες.{l]
[l [n}8.463{]}εὖ νυ καὶ ἡμεῖς ἴδμεν ὅ τοι σθένος οὐκ ἀλαπαδνόν·{l]
[l [n}8.464{]}ἀλλʼ ἔμπης Δαναῶν ὀλοφυρόμεθʼ αἰχμητάων,{l]
[l [n}8.465{]}οἵ κεν δὴ κακὸν οἶτον ἀναπλήσαντες ὄλωνται.{l]
[l [n}8.466{]}ἀλλʼ ἤτοι πολέμου μὲν ἀφεξόμεθʼ, εἰ σὺ κελεύεις·{l]
[l [n}8.467{]}βουλὴν δʼ Ἀργείοις ὑποθησόμεθʼ ἥ τις ὀνήσει,{l]
[l [n}8.468{]}ὡς μὴ πάντες ὄλωνται ὀδυσσαμένοιο τεοῖο.{l]{q]{para]
[para}[l [n}8.469{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}8.470{]}ἠοῦς δὴ καὶ μᾶλλον ὑπερμενέα Κρονίωνα{l]
[l [n}8.471{]}ὄψεαι, αἴ κʼ ἐθέλῃσθα, βοῶπις πότνια Ἥρη{l]
[l [n}8.472{]}ὀλλύντʼ Ἀργείων πουλὺν στρατὸν αἰχμητάων·{l]
[l [n}8.473{]}οὐ γὰρ πρὶν πολέμου ἀποπαύσεται ὄβριμος Ἕκτωρ{l]
[l [n}8.474{]}πρὶν ὄρθαι παρὰ ναῦφι ποδώκεα Πηλεΐωνα,{l]
[l [n}8.475{]}ἤματι τῷ ὅτʼ ἂν οἳ μὲν ἐπὶ πρύμνῃσι μάχωνται{l]
[l [n}8.476{]}στείνει ἐν αἰνοτάτῳ περὶ Πατρόκλοιο θανόντος·{l]
[l [n}8.477{]}ὣς γὰρ θέσφατόν ἐστι· σέθεν δʼ ἐγὼ οὐκ ἀλεγίζω{l]
[l [n}8.478{]}χωομένης, οὐδʼ εἴ κε τὰ νείατα πείραθʼ ἵκηαι{l]
[l [n}8.479{]}γαίης καὶ πόντοιο, ἵνʼ Ἰάπετός τε Κρόνος τε{l]
[l [n}8.480{]}ἥμενοι οὔτʼ αὐγῇς Ὑπερίονος Ἠελίοιο{l]
[l [n}8.481{]}τέρποντʼ οὔτʼ ἀνέμοισι, βαθὺς δέ τε Τάρταρος ἀμφίς·{l]
[l [n}8.482{]}οὐδʼ ἢν ἔνθʼ ἀφίκηαι ἀλωμένη, οὔ σευ ἔγωγε{l]
[l [n}8.483{]}σκυζομένης ἀλέγω, ἐπεὶ οὐ σέο κύντερον ἄλλο.{l]{q]{para]
[para}[l [n}8.484{]}ὣς φάτο, τὸν δʼ οὔ τι προσέφη λευκώλενος Ἥρη.{l]
[l [n}8.485{]}ἐν δʼ ἔπεσʼ Ὠκεανῷ λαμπρὸν φάος ἠελίοιο{l]
[l [n}8.486{]}ἕλκον νύκτα μέλαιναν ἐπὶ ζείδωρον ἄρουραν.{l]
[l [n}8.487{]}Τρωσὶν μέν ῥʼ ἀέκουσιν ἔδυ φάος, αὐτὰρ Ἀχαιοῖς{l]
[l [n}8.488{]}ἀσπασίη τρίλλιστος ἐπήλυθε νὺξ ἐρεβεννή.{l]{para]
[para}[l [n}8.489{]}Τρώων αὖτʼ ἀγορὴν ποιήσατο φαίδιμος Ἕκτωρ{l]
[l [n}8.490{]}νόσφι νεῶν ἀγαγὼν ποταμῷ ἔπι δινήεντι,{l]
[l [n}8.491{]}ἐν καθαρῷ ὅθι δὴ νεκύων διεφαίνετο χῶρος.{l]
[l [n}8.492{]}ἐξ ἵππων δʼ ἀποβάντες ἐπὶ χθόνα μῦθον ἄκουον{l]
[l [n}8.493{]}τόν ῥʼ Ἕκτωρ ἀγόρευε Διῒ φίλος· ἐν δʼ ἄρα χειρὶ{l]
[l [n}8.494{]}ἔγχος ἔχʼ ἑνδεκάπηχυ· πάροιθε δὲ λάμπετο δουρὸς{l]
[l [n}8.495{]}αἰχμὴ χαλκείη, περὶ δὲ χρύσεος θέε πόρκης,{l]
[l [n}8.496{]}τῷ ὅ γʼ ἐρεισάμενος ἔπεα Τρώεσσι μετηύδα·{l]
[q}[l [n}8.497{]}κέκλυτέ μευ Τρῶες καὶ Δάρδανοι ἠδʼ ἐπίκουροι·{l]
[l [n}8.498{]}νῦν ἐφάμην νῆάς τʼ ὀλέσας καὶ πάντας Ἀχαιοὺς{l]
[l [n}8.499{]}ἂψ ἀπονοστήσειν προτὶ Ἴλιον ἠνεμόεσσαν·{l]
[l [n}8.500{]}ἀλλὰ πρὶν κνέφας ἦλθε, τὸ νῦν ἐσάωσε μάλιστα{l]
[l [n}8.501{]}Ἀργείους καὶ νῆας ἐπὶ ῥηγμῖνι θαλάσσης.{l]
[l [n}8.502{]}ἀλλʼ ἤτοι νῦν μὲν πειθώμεθα νυκτὶ μελαίνῃ{l]
[l [n}8.503{]}δόρπά τʼ ἐφοπλισόμεσθα· ἀτὰρ καλλίτριχας ἵππους{l]
[l [n}8.504{]}λύσαθʼ ὑπὲξ ὀχέων, παρὰ δέ σφισι βάλλετʼ ἐδωδήν·{l]
[l [n}8.505{]}ἐκ πόλιος δʼ ἄξεσθε βόας καὶ ἴφια μῆλα{l]
[l [n}8.506{]}καρπαλίμως, οἶνον δὲ μελίφρονα οἰνίζεσθε{l]
[l [n}8.507{]}σῖτόν τʼ ἐκ μεγάρων, ἐπὶ δὲ ξύλα πολλὰ λέγεσθε,{l]
[l [n}8.508{]}ὥς κεν παννύχιοι μέσφʼ ἠοῦς ἠριγενείης{l]
[l [n}8.509{]}καίωμεν πυρὰ πολλά, σέλας δʼ εἰς οὐρανὸν ἵκῃ,{l]
[l [n}8.510{]}μή πως καὶ διὰ νύκτα κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}8.511{]}φεύγειν ὁρμήσωνται ἐπʼ εὐρέα νῶτα θαλάσσης.{l]
[l [n}8.512{]}μὴ μὰν ἀσπουδί γε νεῶν ἐπιβαῖεν ἕκηλοι,{l]
[l [n}8.513{]}ἀλλʼ ὥς τις τούτων γε βέλος καὶ οἴκοθι πέσσῃ{l]
[l [n}8.514{]}βλήμενος ἢ ἰῷ ἢ ἔγχεϊ ὀξυόεντι{l]
[l [n}8.515{]}νηὸς ἐπιθρῴσκων, ἵνα τις στυγέῃσι καὶ ἄλλος{l]
[l [n}8.516{]}Τρωσὶν ἐφʼ ἱπποδάμοισι φέρειν πολύδακρυν Ἄρηα.{l]
[l [n}8.517{]}κήρυκες δʼ ἀνὰ ἄστυ Διῒ φίλοι ἀγγελλόντων{l]
[l [n}8.518{]}παῖδας πρωθήβας πολιοκροτάφους τε γέροντας{l]
[l [n}8.519{]}λέξασθαι περὶ ἄστυ θεοδμήτων ἐπὶ πύργων·{l]
[l [n}8.520{]}θηλύτεραι δὲ γυναῖκες ἐνὶ μεγάροισιν ἑκάστη{l]
[l [n}8.521{]}πῦρ μέγα καιόντων· φυλακὴ δέ τις ἔμπεδος ἔστω{l]
[l [n}8.522{]}μὴ λόχος εἰσέλθῃσι πόλιν λαῶν ἀπεόντων.{l]
[l [n}8.523{]}ὧδʼ ἔστω Τρῶες μεγαλήτορες ὡς ἀγορεύω·{l]
[l [n}8.524{]}μῦθος δʼ ὃς μὲν νῦν ὑγιὴς εἰρημένος ἔστω,{l]
[l [n}8.525{]}τὸν δʼ ἠοῦς Τρώεσσι μεθʼ ἱπποδάμοις ἀγορεύσω.{l]
[l [n}8.526{]}ἔλπομαι εὐχόμενος Διί τʼ ἄλλοισίν τε θεοῖσιν{l]
[l [n}8.527{]}ἐξελάαν ἐνθένδε κύνας κηρεσσιφορήτους,{l]
[l [n}8.528{]}οὓς κῆρες φορέουσι μελαινάων ἐπὶ νηῶν.{l]
[l [n}8.529{]}ἀλλʼ ἤτοι ἐπὶ νυκτὶ φυλάξομεν ἡμέας αὐτούς,{l]
[l [n}8.530{]}πρῶϊ δʼ ὑπηοῖοι σὺν τεύχεσι θωρηχθέντες{l]
[l [n}8.531{]}νηυσὶν ἔπι γλαφυρῇσιν ἐγείρομεν ὀξὺν Ἄρηα.{l]
[l [n}8.532{]}εἴσομαι εἴ κέ μʼ ὁ Τυδεΐδης κρατερὸς Διομήδης{l]
[l [n}8.533{]}πὰρ νηῶν πρὸς τεῖχος ἀπώσεται, ἤ κεν ἐγὼ τὸν{l]
[l [n}8.534{]}χαλκῷ δῃώσας ἔναρα βροτόεντα φέρωμαι.{l]
[l [n}8.535{]}αὔριον ἣν ἀρετὴν διαείσεται, εἴ κʼ ἐμὸν ἔγχος{l]
[l [n}8.536{]}μείνῃ ἐπερχόμενον· ἀλλʼ ἐν πρώτοισιν ὀΐω{l]
[l [n}8.537{]}κείσεται οὐτηθείς, πολέες δʼ ἀμφʼ αὐτὸν ἑταῖροι{l]
[l [n}8.538{]}ἠελίου ἀνιόντος ἐς αὔριον· εἰ γὰρ ἐγὼν ὣς{l]
[l [n}8.539{]}εἴην ἀθάνατος καὶ ἀγήρως ἤματα πάντα,{l]
[l [n}8.540{]}τιοίμην δʼ ὡς τίετʼ Ἀθηναίη καὶ Ἀπόλλων,{l]
[l [n}8.541{]}ὡς νῦν ἡμέρη ἥδε κακὸν φέρει Ἀργείοισιν.{l]{q]{para]
[para}[l [n}8.542{]}ὣς Ἕκτωρ ἀγόρευʼ, ἐπὶ δὲ Τρῶες κελάδησαν.{l]
[l [n}8.543{]}οἳ δʼ ἵππους μὲν λῦσαν ὑπὸ ζυγοῦ ἱδρώοντας,{l]
[l [n}8.544{]}δῆσαν δʼ ἱμάντεσσι παρʼ ἅρμασιν οἷσιν ἕκαστος·{l]
[l [n}8.545{]}ἐκ πόλιος δʼ ἄξοντο βόας καὶ ἴφια μῆλα{l]
[l [n}8.546{]}καρπαλίμως, οἶνον δὲ μελίφρονα οἰνίζοντο,{l]
[l [n}8.547{]}σῖτόν τʼ ἐκ μεγάρων, ἐπὶ δὲ ξύλα πολλὰ λέγοντο.{l]
[l [n}8.548{]}
                  [del}ἔρδον δ’ ἀθανάτοισι τεληέσσας ἑκατόμβας{del]
               {l]
[l [n}8.549{]}κνίσην δʼ ἐκ πεδίου ἄνεμοι φέρον οὐρανὸν εἴσω.{l]
[l [n}8.550{]}
                  [del}ἡδεῖαν· τῆς δ’ οὔ τι θεοὶ μάκαρες δατέοντο,{del]
               {l]
[l [n}8.551{]}
                  [del}οὐδ’ ἔθελον· μάλα γάρ σφιν ἀπήχθετο Ἴλιος ἱρή,{del]
               {l]
[l [n}8.552{]}
                  [del}καὶ Πρίαμος καὶ λαὸς ἐϋμμελίω Πριάμοιο{del]
               {l]{para]
[para}[l [n}8.553{]}οἳ δὲ μέγα φρονέοντες ἐπὶ πτολέμοιο γεφύρας{l]
[l [n}8.554{]}εἴατο παννύχιοι, πυρὰ δέ σφισι καίετο πολλά.{l]
[l [n}8.555{]}ὡς δʼ ὅτʼ ἐν οὐρανῷ ἄστρα φαεινὴν ἀμφὶ σελήνην{l]
[l [n}8.556{]}φαίνετʼ ἀριπρεπέα, ὅτε τʼ ἔπλετο νήνεμος αἰθήρ·{l]
[l [n}8.557{]}ἔκ τʼ ἔφανεν πᾶσαι σκοπιαὶ καὶ πρώονες ἄκροι{l]
[l [n}8.558{]}καὶ νάπαι· οὐρανόθεν δʼ ἄρʼ ὑπερράγη ἄσπετος αἰθήρ,{l]
[l [n}8.559{]}πάντα δὲ εἴδεται ἄστρα, γέγηθε δέ τε φρένα ποιμήν·{l]
[l [n}8.560{]}τόσσα μεσηγὺ νεῶν ἠδὲ Ξάνθοιο ῥοάων{l]
[l [n}8.561{]}Τρώων καιόντων πυρὰ φαίνετο Ἰλιόθι πρό.{l]
[l [n}8.562{]}χίλιʼ ἄρʼ ἐν πεδίῳ πυρὰ καίετο, πὰρ δὲ ἑκάστῳ{l]
[l [n}8.563{]}εἴατο πεντήκοντα σέλᾳ πυρὸς αἰθομένοιο.{l]
[l [n}8.564{]}ἵπποι δὲ κρῖ λευκὸν ἐρεπτόμενοι καὶ ὀλύρας{l]
[l [n}8.565{]}ἑσταότες παρʼ ὄχεσφιν ἐΰθρονον Ἠῶ μίμνον.{l]{para]
{book]
[book [n}9{]}
[para}[l [n}9.1{]}ὣς οἱ μὲν Τρῶες φυλακὰς ἔχον· αὐτὰρ Ἀχαιοὺς{l]
[l [n}9.2{]}θεσπεσίη ἔχε φύζα φόβου κρυόεντος ἑταίρη,{l]
[l [n}9.3{]}πένθεϊ δʼ ἀτλήτῳ βεβολήατο πάντες ἄριστοι.{l]
[l [n}9.4{]}ὡς δʼ ἄνεμοι δύο πόντον ὀρίνετον ἰχθυόεντα{l]
[l [n}9.5{]}Βορέης καὶ Ζέφυρος, τώ τε Θρῄκηθεν ἄητον{l]
[l [n}9.6{]}ἐλθόντʼ ἐξαπίνης· ἄμυδις δέ τε κῦμα κελαινὸν{l]
[l [n}9.7{]}κορθύεται, πολλὸν δὲ παρὲξ ἅλα φῦκος ἔχευεν·{l]
[l [n}9.8{]}ὣς ἐδαΐζετο θυμὸς ἐνὶ στήθεσσιν Ἀχαιῶν.{l]{para]
[para}[l [n}9.9{]}Ἀτρεΐδης δʼ ἄχεϊ μεγάλῳ βεβολημένος ἦτορ{l]
[l [n}9.10{]}φοίτα κηρύκεσσι λιγυφθόγγοισι κελεύων{l]
[l [n}9.11{]}κλήδην εἰς ἀγορὴν κικλήσκειν ἄνδρα ἕκαστον,{l]
[l [n}9.12{]}μὴ δὲ βοᾶν· αὐτὸς δὲ μετὰ πρώτοισι πονεῖτο.{l]
[l [n}9.13{]}ἷζον δʼ εἰν ἀγορῇ τετιηότες· ἂν δʼ Ἀγαμέμνων{l]
[l [n}9.14{]}ἵστατο δάκρυ χέων ὥς τε κρήνη μελάνυδρος{l]
[l [n}9.15{]}ἥ τε κατʼ αἰγίλιπος πέτρης δνοφερὸν χέει ὕδωρ·{l]
[l [n}9.16{]}ὣς ὃ βαρὺ στενάχων ἔπεʼ Ἀργείοισι μετηύδα·{l]
[q}[l [n}9.17{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}9.18{]}Ζεύς με μέγα Κρονίδης ἄτῃ ἐνέδησε βαρείῃ{l]
[l [n}9.19{]}σχέτλιος, ὃς τότε μέν μοι ὑπέσχετο καὶ κατένευσεν{l]
[l [n}9.20{]}Ἴλιον ἐκπέρσαντʼ εὐτείχεον ἀπονέεσθαι,{l]
[l [n}9.21{]}νῦν δὲ κακὴν ἀπάτην βουλεύσατο, καί με κελεύει{l]
[l [n}9.22{]}δυσκλέα Ἄργος ἱκέσθαι, ἐπεὶ πολὺν ὤλεσα λαόν.{l]
[l [n}9.23{]}οὕτω που Διὶ μέλλει ὑπερμενέϊ φίλον εἶναι,{l]
[l [n}9.24{]}ὃς δὴ πολλάων πολίων κατέλυσε κάρηνα{l]
[l [n}9.25{]}ἠδʼ ἔτι καὶ λύσει· τοῦ γὰρ κράτος ἐστὶ μέγιστον.{l]
[l [n}9.26{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}9.27{]}φεύγωμεν σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν·{l]
[l [n}9.28{]}οὐ γὰρ ἔτι Τροίην αἱρήσομεν εὐρυάγυιαν.{l]{q]{para]
[para}[l [n}9.29{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ.{l]
[l [n}9.30{]}δὴν δʼ ἄνεῳ ἦσαν τετιηότες υἷες Ἀχαιῶν·{l]
[l [n}9.31{]}ὀψὲ δὲ δὴ μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}9.32{]}Ἀτρεΐδη σοὶ πρῶτα μαχήσομαι ἀφραδέοντι,{l]
[l [n}9.33{]}ἣ θέμις ἐστὶν ἄναξ ἀγορῇ· σὺ δὲ μή τι χολωθῇς.{l]
[l [n}9.34{]}ἀλκὴν μέν μοι πρῶτον ὀνείδισας ἐν Δαναοῖσι{l]
[l [n}9.35{]}φὰς ἔμεν ἀπτόλεμον καὶ ἀνάλκιδα· ταῦτα δὲ πάντα{l]
[l [n}9.36{]}ἴσασʼ Ἀργείων ἠμὲν νέοι ἠδὲ γέροντες.{l]
[l [n}9.37{]}σοὶ δὲ διάνδιχα δῶκε Κρόνου πάϊς ἀγκυλομήτεω·{l]
[l [n}9.38{]}σκήπτρῳ μέν τοι δῶκε τετιμῆσθαι περὶ πάντων,{l]
[l [n}9.39{]}ἀλκὴν δʼ οὔ τοι δῶκεν, ὅ τε κράτος ἐστὶ μέγιστον.{l]
[l [n}9.40{]}δαιμόνιʼ οὕτω που μάλα ἔλπεαι υἷας Ἀχαιῶν{l]
[l [n}9.41{]}ἀπτολέμους τʼ ἔμεναι καὶ ἀνάλκιδας ὡς ἀγορεύεις;{l]
[l [n}9.42{]}εἰ δέ τοι αὐτῷ θυμὸς ἐπέσσυται ὥς τε νέεσθαι{l]
[l [n}9.43{]}ἔρχεο· πάρ τοι ὁδός, νῆες δέ τοι ἄγχι θαλάσσης{l]
[l [n}9.44{]}ἑστᾶσʼ, αἵ τοι ἕποντο Μυκήνηθεν μάλα πολλαί.{l]
[l [n}9.45{]}ἀλλʼ ἄλλοι μενέουσι κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}9.46{]}εἰς ὅ κέ περ Τροίην διαπέρσομεν. εἰ δὲ καὶ αὐτοὶ{l]
[l [n}9.47{]}φευγόντων σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν·{l]
[l [n}9.48{]}νῶϊ δʼ ἐγὼ Σθένελός τε μαχησόμεθʼ εἰς ὅ κε τέκμωρ{l]
[l [n}9.49{]}Ἰλίου εὕρωμεν· σὺν γὰρ θεῷ εἰλήλουθμεν.{l]{q]{para]
[para}[l [n}9.50{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπίαχον υἷες Ἀχαιῶν{l]
[l [n}9.51{]}μῦθον ἀγασσάμενοι Διομήδεος ἱπποδάμοιο.{l]
[l [n}9.52{]}τοῖσι δʼ ἀνιστάμενος μετεφώνεεν ἱππότα Νέστωρ·{l]
[q}[l [n}9.53{]}Τυδεΐδη περὶ μὲν πολέμῳ ἔνι καρτερός ἐσσι,{l]
[l [n}9.54{]}καὶ βουλῇ μετὰ πάντας ὁμήλικας ἔπλευ ἄριστος.{l]
[l [n}9.55{]}οὔ τίς τοι τὸν μῦθον ὀνόσσεται ὅσσοι Ἀχαιοί,{l]
[l [n}9.56{]}οὐδὲ πάλιν ἐρέει· ἀτὰρ οὐ τέλος ἵκεο μύθων.{l]
[l [n}9.57{]}ἦ μὲν καὶ νέος ἐσσί, ἐμὸς δέ κε καὶ πάϊς εἴης{l]
[l [n}9.58{]}ὁπλότατος γενεῆφιν· ἀτὰρ πεπνυμένα βάζεις{l]
[l [n}9.59{]}Ἀργείων βασιλῆας, ἐπεὶ κατὰ μοῖραν ἔειπες.{l]
[l [n}9.60{]}ἀλλʼ ἄγʼ ἐγών, ὃς σεῖο γεραίτερος εὔχομαι εἶναι,{l]
[l [n}9.61{]}ἐξείπω καὶ πάντα διίξομαι· οὐδέ κέ τίς μοι{l]
[l [n}9.62{]}μῦθον ἀτιμήσειʼ, οὐδὲ κρείων Ἀγαμέμνων.{l]
[l [n}9.63{]}ἀφρήτωρ ἀθέμιστος ἀνέστιός ἐστιν ἐκεῖνος{l]
[l [n}9.64{]}ὃς πολέμου ἔραται ἐπιδημίου ὀκρυόεντος.{l]
[l [n}9.65{]}ἀλλʼ ἤτοι νῦν μὲν πειθώμεθα νυκτὶ μελαίνῃ{l]
[l [n}9.66{]}δόρπά τʼ ἐφοπλισόμεσθα· φυλακτῆρες δὲ ἕκαστοι{l]
[l [n}9.67{]}λεξάσθων παρὰ τάφρον ὀρυκτὴν τείχεος ἐκτός.{l]
[l [n}9.68{]}κούροισιν μὲν ταῦτʼ ἐπιτέλλομαι· αὐτὰρ ἔπειτα{l]
[l [n}9.69{]}Ἀτρεΐδη σὺ μὲν ἄρχε· σὺ γὰρ βασιλεύτατός ἐσσι.{l]
[l [n}9.70{]}δαίνυ δαῖτα γέρουσιν· ἔοικέ τοι, οὔ τοι ἀεικές.{l]
[l [n}9.71{]}πλεῖαί τοι οἴνου κλισίαι, τὸν νῆες Ἀχαιῶν{l]
[l [n}9.72{]}ἠμάτιαι Θρῄκηθεν ἐπʼ εὐρέα πόντον ἄγουσι·{l]
[l [n}9.73{]}πᾶσά τοί ἐσθʼ ὑποδεξίη, πολέεσσι δʼ ἀνάσσεις.{l]
[l [n}9.74{]}πολλῶν δʼ ἀγρομένων τῷ πείσεαι ὅς κεν ἀρίστην{l]
[l [n}9.75{]}βουλὴν βουλεύσῃ· μάλα δὲ χρεὼ πάντας Ἀχαιοὺς{l]
[l [n}9.76{]}ἐσθλῆς καὶ πυκινῆς, ὅτι δήϊοι ἐγγύθι νηῶν{l]
[l [n}9.77{]}καίουσιν πυρὰ πολλά· τίς ἂν τάδε γηθήσειε;{l]
[l [n}9.78{]}νὺξ δʼ ἧδʼ ἠὲ διαρραίσει στρατὸν ἠὲ σαώσει.{l]{q]{para]
[para}[l [n}9.79{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο.{l]
[l [n}9.80{]}ἐκ δὲ φυλακτῆρες σὺν τεύχεσιν ἐσσεύοντο{l]
[l [n}9.81{]}ἀμφί τε Νεστορίδην Θρασυμήδεα ποιμένα λαῶν,{l]
[l [n}9.82{]}ἠδʼ ἀμφʼ Ἀσκάλαφον καὶ Ἰάλμενον υἷας Ἄρηος{l]
[l [n}9.83{]}ἀμφί τε Μηριόνην Ἀφαρῆά τε Δηΐπυρόν τε,{l]
[l [n}9.84{]}ἠδʼ ἀμφὶ Κρείοντος υἱὸν Λυκομήδεα δῖον.{l]
[l [n}9.85{]}ἕπτʼ ἔσαν ἡγεμόνες φυλάκων, ἑκατὸν δὲ ἑκάστῳ{l]
[l [n}9.86{]}κοῦροι ἅμα στεῖχον δολίχʼ ἔγχεα χερσὶν ἔχοντες·{l]
[l [n}9.87{]}κὰδ δὲ μέσον τάφρου καὶ τείχεος ἷζον ἰόντες·{l]
[l [n}9.88{]}ἔνθα δὲ πῦρ κήαντο, τίθεντο δὲ δόρπα ἕκαστος.{l]{para]
[para}[l [n}9.89{]}Ἀτρεΐδης δὲ γέροντας ἀολλέας ἦγεν Ἀχαιῶν{l]
[l [n}9.90{]}ἐς κλισίην, παρὰ δέ σφι τίθει μενοεικέα δαῖτα.{l]
[l [n}9.91{]}οἳ δʼ ἐπʼ ὀνείαθʼ ἑτοῖμα προκείμενα χεῖρας ἴαλλον.{l]
[l [n}9.92{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}9.93{]}τοῖς ὁ γέρων πάμπρωτος ὑφαίνειν ἤρχετο μῆτιν{l]
[l [n}9.94{]}Νέστωρ, οὗ καὶ πρόσθεν ἀρίστη φαίνετο βουλή·{l]
[l [n}9.95{]}ὅ σφιν ἐϋφρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}9.96{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}9.97{]}ἐν σοὶ μὲν λήξω, σέο δʼ ἄρξομαι, οὕνεκα πολλῶν{l]
[l [n}9.98{]}λαῶν ἐσσι ἄναξ καί τοι Ζεὺς ἐγγυάλιξε{l]
[l [n}9.99{]}σκῆπτρόν τʼ ἠδὲ θέμιστας, ἵνά σφισι βουλεύῃσθα.{l]
[l [n}9.100{]}τώ σε χρὴ περὶ μὲν φάσθαι ἔπος ἠδʼ ἐπακοῦσαι,{l]
[l [n}9.101{]}κρηῆναι δὲ καὶ ἄλλῳ, ὅτʼ ἄν τινα θυμὸς ἀνώγῃ{l]
[l [n}9.102{]}εἰπεῖν εἰς ἀγαθόν· σέο δʼ ἕξεται ὅττί κεν ἄρχῃ.{l]
[l [n}9.103{]}αὐτὰρ ἐγὼν ἐρέω ὥς μοι δοκεῖ εἶναι ἄριστα.{l]
[l [n}9.104{]}οὐ γάρ τις νόον ἄλλος ἀμείνονα τοῦδε νοήσει{l]
[l [n}9.105{]}οἷον ἐγὼ νοέω ἠμὲν πάλαι ἠδʼ ἔτι καὶ νῦν{l]
[l [n}9.106{]}ἐξ ἔτι τοῦ ὅτε διογενὲς Βρισηΐδα κούρην{l]
[l [n}9.107{]}χωομένου Ἀχιλῆος ἔβης κλισίηθεν ἀπούρας{l]
[l [n}9.108{]}οὔ τι καθʼ ἡμέτερόν γε νόον· μάλα γάρ τοι ἔγωγε{l]
[l [n}9.109{]}πόλλʼ ἀπεμυθεόμην· σὺ δὲ σῷ μεγαλήτορι θυμῷ{l]
[l [n}9.110{]}εἴξας ἄνδρα φέριστον, ὃν ἀθάνατοί περ ἔτισαν,{l]
[l [n}9.111{]}ἠτίμησας, ἑλὼν γὰρ ἔχεις γέρας· ἀλλʼ ἔτι καὶ νῦν{l]
[l [n}9.112{]}φραζώμεσθʼ ὥς κέν μιν ἀρεσσάμενοι πεπίθωμεν{l]
[l [n}9.113{]}δώροισίν τʼ ἀγανοῖσιν ἔπεσσί τε μειλιχίοισι.{l]{q]{para]
[para}[l [n}9.114{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}9.115{]}ὦ γέρον οὔ τι ψεῦδος ἐμὰς ἄτας κατέλεξας·{l]
[l [n}9.116{]}ἀασάμην, οὐδʼ αὐτὸς ἀναίνομαι. ἀντί νυ πολλῶν{l]
[l [n}9.117{]}λαῶν ἐστὶν ἀνὴρ ὅν τε Ζεὺς κῆρι φιλήσῃ,{l]
[l [n}9.118{]}ὡς νῦν τοῦτον ἔτισε, δάμασσε δὲ λαὸν Ἀχαιῶν.{l]
[l [n}9.119{]}ἀλλʼ ἐπεὶ ἀασάμην φρεσὶ λευγαλέῃσι πιθήσας,{l]
[l [n}9.120{]}ἂψ ἐθέλω ἀρέσαι δόμεναί τʼ ἀπερείσιʼ ἄποινα.{l]
[l [n}9.121{]}ὑμῖν δʼ ἐν πάντεσσι περικλυτὰ δῶρʼ ὀνομήνω{l]
[l [n}9.122{]}ἕπτʼ ἀπύρους τρίποδας, δέκα δὲ χρυσοῖο τάλαντα,{l]
[l [n}9.123{]}αἴθωνας δὲ λέβητας ἐείκοσι, δώδεκα δʼ ἵππους{l]
[l [n}9.124{]}πηγοὺς ἀθλοφόρους, οἳ ἀέθλια ποσσὶν ἄροντο.{l]
[l [n}9.125{]}οὔ κεν ἀλήϊος εἴη ἀνὴρ ᾧ τόσσα γένοιτο,{l]
[l [n}9.126{]}οὐδέ κεν ἀκτήμων ἐριτίμοιο χρυσοῖο,{l]
[l [n}9.127{]}ὅσσά μοι ἠνείκαντο ἀέθλια μώνυχες ἵπποι.{l]
[l [n}9.128{]}δώσω δʼ ἑπτὰ γυναῖκας ἀμύμονα ἔργα ἰδυίας{l]
[l [n}9.129{]}Λεσβίδας, ἃς ὅτε Λέσβον ἐϋκτιμένην ἕλεν αὐτὸς{l]
[l [n}9.130{]}ἐξελόμην, αἳ κάλλει ἐνίκων φῦλα γυναικῶν.{l]
[l [n}9.131{]}τὰς μέν οἱ δώσω, μετὰ δʼ ἔσσεται ἣν τότʼ ἀπηύρων{l]
[l [n}9.132{]}κούρη Βρισῆος· ἐπὶ δὲ μέγαν ὅρκον ὀμοῦμαι{l]
[l [n}9.133{]}μή ποτε τῆς εὐνῆς ἐπιβήμεναι ἠδὲ μιγῆναι,{l]
[l [n}9.134{]}ἣ θέμις ἀνθρώπων πέλει ἀνδρῶν ἠδὲ γυναικῶν.{l]
[l [n}9.135{]}ταῦτα μὲν αὐτίκα πάντα παρέσσεται· εἰ δέ κεν αὖτε{l]
[l [n}9.136{]}ἄστυ μέγα Πριάμοιο θεοὶ δώωσʼ ἀλαπάξαι,{l]
[l [n}9.137{]}νῆα ἅλις χρυσοῦ καὶ χαλκοῦ νηησάσθω{l]
[l [n}9.138{]}εἰσελθών, ὅτε κεν δατεώμεθα ληΐδʼ Ἀχαιοί,{l]
[l [n}9.139{]}Τρωϊάδας δὲ γυναῖκας ἐείκοσιν αὐτὸς ἑλέσθω,{l]
[l [n}9.140{]}αἴ κε μετʼ Ἀργείην Ἑλένην κάλλισται ἔωσιν.{l]
[l [n}9.141{]}εἰ δέ κεν Ἄργος ἱκοίμεθʼ Ἀχαιϊκὸν οὖθαρ ἀρούρης{l]
[l [n}9.142{]}γαμβρός κέν μοι ἔοι· τίσω δέ μιν ἶσον Ὀρέστῃ,{l]
[l [n}9.143{]}ὅς μοι τηλύγετος τρέφεται θαλίῃ ἔνι πολλῇ.{l]
[l [n}9.144{]}τρεῖς δέ μοί εἰσι θύγατρες ἐνὶ μεγάρῳ εὐπήκτῳ{l]
[l [n}9.145{]}Χρυσόθεμις καὶ Λαοδίκη καὶ Ἰφιάνασσα,{l]
[l [n}9.146{]}τάων ἥν κʼ ἐθέλῃσι φίλην ἀνάεδνον ἀγέσθω{l]
[l [n}9.147{]}πρὸς οἶκον Πηλῆος· ἐγὼ δʼ ἐπὶ μείλια δώσω{l]
[l [n}9.148{]}πολλὰ μάλʼ, ὅσσʼ οὔ πώ τις ἑῇ ἐπέδωκε θυγατρί·{l]
[l [n}9.149{]}ἑπτὰ δέ οἱ δώσω εὖ ναιόμενα πτολίεθρα{l]
[l [n}9.150{]}Καρδαμύλην Ἐνόπην τε καὶ Ἱρὴν ποιήεσσαν{l]
[l [n}9.151{]}Φηράς τε ζαθέας ἠδʼ Ἄνθειαν βαθύλειμον{l]
[l [n}9.152{]}καλήν τʼ Αἴπειαν καὶ Πήδασον ἀμπελόεσσαν.{l]
[l [n}9.153{]}πᾶσαι δʼ ἐγγὺς ἁλός, νέαται Πύλου ἠμαθόεντος·{l]
[l [n}9.154{]}ἐν δʼ ἄνδρες ναίουσι πολύρρηνες πολυβοῦται,{l]
[l [n}9.155{]}οἵ κέ ἑ δωτίνῃσι θεὸν ὣς τιμήσουσι{l]
[l [n}9.156{]}καί οἱ ὑπὸ σκήπτρῳ λιπαρὰς τελέουσι θέμιστας.{l]
[l [n}9.157{]}ταῦτά κέ οἱ τελέσαιμι μεταλήξαντι χόλοιο.{l]
[l [n}9.158{]}δμηθήτω· Ἀΐδης τοι ἀμείλιχος ἠδʼ ἀδάμαστος,{l]
[l [n}9.159{]}τοὔνεκα καί τε βροτοῖσι θεῶν ἔχθιστος ἁπάντων·{l]
[l [n}9.160{]}καί μοι ὑποστήτω ὅσσον βασιλεύτερός εἰμι{l]
[l [n}9.161{]}ἠδʼ ὅσσον γενεῇ προγενέστερος εὔχομαι εἶναι.{l]{q]{para]
[para}[l [n}9.162{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}9.163{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}9.164{]}δῶρα μὲν οὐκέτʼ ὀνοστὰ διδοῖς Ἀχιλῆϊ ἄνακτι·{l]
[l [n}9.165{]}ἀλλʼ ἄγετε κλητοὺς ὀτρύνομεν, οἵ κε τάχιστα{l]
[l [n}9.166{]}ἔλθωσʼ ἐς κλισίην Πηληϊάδεω Ἀχιλῆος.{l]
[l [n}9.167{]}εἰ δʼ ἄγε τοὺς ἂν ἐγὼ ἐπιόψομαι οἳ δὲ πιθέσθων.{l]
[l [n}9.168{]}Φοῖνιξ μὲν πρώτιστα Διῒ φίλος ἡγησάσθω,{l]
[l [n}9.169{]}αὐτὰρ ἔπειτʼ Αἴας τε μέγας καὶ δῖος Ὀδυσσεύς·{l]
[l [n}9.170{]}κηρύκων δʼ Ὀδίος τε καὶ Εὐρυβάτης ἅμʼ ἑπέσθων.{l]
[l [n}9.171{]}φέρτε δὲ χερσὶν ὕδωρ, εὐφημῆσαί τε κέλεσθε,{l]
[l [n}9.172{]}ὄφρα Διὶ Κρονίδῃ ἀρησόμεθʼ, αἴ κʼ ἐλεήσῃ.{l]{q]{para]
[para}[l [n}9.173{]}ὣς φάτο, τοῖσι δὲ πᾶσιν ἑαδότα μῦθον ἔειπεν.{l]
[l [n}9.174{]}αὐτίκα κήρυκες μὲν ὕδωρ ἐπὶ χεῖρας ἔχευαν,{l]
[l [n}9.175{]}κοῦροι δὲ κρητῆρας ἐπεστέψαντο ποτοῖο,{l]
[l [n}9.176{]}νώμησαν δʼ ἄρα πᾶσιν ἐπαρξάμενοι δεπάεσσιν.{l]
[l [n}9.177{]}αὐτὰρ ἐπεὶ σπεῖσάν τʼ ἔπιόν θʼ ὅσον ἤθελε θυμός,{l]
[l [n}9.178{]}ὁρμῶντʼ ἐκ κλισίης Ἀγαμέμνονος Ἀτρεΐδαο.{l]
[l [n}9.179{]}τοῖσι δὲ πόλλʼ ἐπέτελλε Γερήνιος ἱππότα Νέστωρ{l]
[l [n}9.180{]}δενδίλλων ἐς ἕκαστον, Ὀδυσσῆϊ δὲ μάλιστα,{l]
[l [n}9.181{]}πειρᾶν ὡς πεπίθοιεν ἀμύμονα Πηλεΐωνα.{l]{para]
[para}[l [n}9.182{]}τὼ δὲ βάτην παρὰ θῖνα πολυφλοίσβοιο θαλάσσης{l]
[l [n}9.183{]}πολλὰ μάλʼ εὐχομένω γαιηόχῳ ἐννοσιγαίῳ{l]
[l [n}9.184{]}ῥηϊδίως πεπιθεῖν μεγάλας φρένας Αἰακίδαο.{l]
[l [n}9.185{]}Μυρμιδόνων δʼ ἐπί τε κλισίας καὶ νῆας ἱκέσθην,{l]
[l [n}9.186{]}τὸν δʼ εὗρον φρένα τερπόμενον φόρμιγγι λιγείῃ{l]
[l [n}9.187{]}καλῇ δαιδαλέῃ, ἐπὶ δʼ ἀργύρεον ζυγὸν ἦεν,{l]
[l [n}9.188{]}τὴν ἄρετʼ ἐξ ἐνάρων πόλιν Ἠετίωνος ὀλέσσας·{l]
[l [n}9.189{]}τῇ ὅ γε θυμὸν ἔτερπεν, ἄειδε δʼ ἄρα κλέα ἀνδρῶν.{l]
[l [n}9.190{]}Πάτροκλος δέ οἱ οἶος ἐναντίος ἧστο σιωπῇ,{l]
[l [n}9.191{]}δέγμενος Αἰακίδην ὁπότε λήξειεν ἀείδων,{l]
[l [n}9.192{]}τὼ δὲ βάτην προτέρω, ἡγεῖτο δὲ δῖος Ὀδυσσεύς,{l]
[l [n}9.193{]}στὰν δὲ πρόσθʼ αὐτοῖο· ταφὼν δʼ ἀνόρουσεν Ἀχιλλεὺς{l]
[l [n}9.194{]}αὐτῇ σὺν φόρμιγγι λιπὼν ἕδος ἔνθα θάασσεν.{l]
[l [n}9.195{]}ὣς δʼ αὔτως Πάτροκλος, ἐπεὶ ἴδε φῶτας, ἀνέστη.{l]
[l [n}9.196{]}τὼ καὶ δεικνύμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}9.197{]}χαίρετον· ἦ φίλοι ἄνδρες ἱκάνετον ἦ τι μάλα χρεώ,{l]
[l [n}9.198{]}οἵ μοι σκυζομένῳ περ Ἀχαιῶν φίλτατοί ἐστον.{l]{q]{para]
[para}[l [n}9.199{]}ὣς ἄρα φωνήσας προτέρω ἄγε δῖος Ἀχιλλεύς,{l]
[l [n}9.200{]}εἷσεν δʼ ἐν κλισμοῖσι τάπησί τε πορφυρέοισιν.{l]
[l [n}9.201{]}αἶψα δὲ Πάτροκλον προσεφώνεεν ἐγγὺς ἐόντα·{l]
[q}[l [n}9.202{]}μείζονα δὴ κρητῆρα Μενοιτίου υἱὲ καθίστα,{l]
[l [n}9.203{]}ζωρότερον δὲ κέραιε, δέπας δʼ ἔντυνον ἑκάστῳ·{l]
[l [n}9.204{]}οἳ γὰρ φίλτατοι ἄνδρες ἐμῷ ὑπέασι μελάθρῳ.{l]{q]{para]
[para}[l [n}9.205{]}ὣς φάτο, Πάτροκλος δὲ φίλῳ ἐπεπείθεθʼ ἑταίρῳ.{l]
[l [n}9.206{]}αὐτὰρ ὅ γε κρεῖον μέγα κάββαλεν ἐν πυρὸς αὐγῇ,{l]
[l [n}9.207{]}ἐν δʼ ἄρα νῶτον ἔθηκʼ ὄϊος καὶ πίονος αἰγός,{l]
[l [n}9.208{]}ἐν δὲ συὸς σιάλοιο ῥάχιν τεθαλυῖαν ἀλοιφῇ.{l]
[l [n}9.209{]}τῷ δʼ ἔχεν Αὐτομέδων, τάμνεν δʼ ἄρα δῖος Ἀχιλλεύς.{l]
[l [n}9.210{]}καὶ τὰ μὲν εὖ μίστυλλε καὶ ἀμφʼ ὀβελοῖσιν ἔπειρε,{l]
[l [n}9.211{]}πῦρ δὲ Μενοιτιάδης δαῖεν μέγα ἰσόθεος φώς.{l]
[l [n}9.212{]}αὐτὰρ ἐπεὶ κατὰ πῦρ ἐκάη καὶ φλὸξ ἐμαράνθη,{l]
[l [n}9.213{]}ἀνθρακιὴν στορέσας ὀβελοὺς ἐφύπερθε τάνυσσε,{l]
[l [n}9.214{]}πάσσε δʼ ἁλὸς θείοιο κρατευτάων ἐπαείρας.{l]
[l [n}9.215{]}αὐτὰρ ἐπεί ῥʼ ὤπτησε καὶ εἰν ἐλεοῖσιν ἔχευε,{l]
[l [n}9.216{]}Πάτροκλος μὲν σῖτον ἑλὼν ἐπένειμε τραπέζῃ{l]
[l [n}9.217{]}καλοῖς ἐν κανέοισιν, ἀτὰρ κρέα νεῖμεν Ἀχιλλεύς.{l]
[l [n}9.218{]}αὐτὸς δʼ ἀντίον ἷζεν Ὀδυσσῆος θείοιο{l]
[l [n}9.219{]}τοίχου τοῦ ἑτέροιο, θεοῖσι δὲ θῦσαι ἀνώγει{l]
[l [n}9.220{]}Πάτροκλον ὃν ἑταῖρον· ὃ δʼ ἐν πυρὶ βάλλε θυηλάς.{l]
[l [n}9.221{]}οἳ δʼ ἐπʼ ὀνείαθʼ ἑτοῖμα προκείμενα χεῖρας ἴαλλον.{l]
[l [n}9.222{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}9.223{]}νεῦσʼ Αἴας Φοίνικι· νόησε δὲ δῖος Ὀδυσσεύς,{l]
[l [n}9.224{]}πλησάμενος δʼ οἴνοιο δέπας δείδεκτʼ Ἀχιλῆα·{l]
[q}[l [n}9.225{]}χαῖρʼ Ἀχιλεῦ· δαιτὸς μὲν ἐΐσης οὐκ ἐπιδευεῖς{l]
[l [n}9.226{]}ἠμὲν ἐνὶ κλισίῃ Ἀγαμέμνονος Ἀτρεΐδαο{l]
[l [n}9.227{]}ἠδὲ καὶ ἐνθάδε νῦν, πάρα γὰρ μενοεικέα πολλὰ{l]
[l [n}9.228{]}δαίνυσθʼ· ἀλλʼ οὐ δαιτὸς ἐπηράτου ἔργα μέμηλεν,{l]
[l [n}9.229{]}ἀλλὰ λίην μέγα πῆμα διοτρεφὲς εἰσορόωντες{l]
[l [n}9.230{]}δείδιμεν· ἐν δοιῇ δὲ σαωσέμεν ἢ ἀπολέσθαι{l]
[l [n}9.231{]}νῆας ἐϋσσέλμους, εἰ μὴ σύ γε δύσεαι ἀλκήν.{l]
[l [n}9.232{]}ἐγγὺς γὰρ νηῶν καὶ τείχεος αὖλιν ἔθεντο{l]
[l [n}9.233{]}Τρῶες ὑπέρθυμοι τηλεκλειτοί τʼ ἐπίκουροι{l]
[l [n}9.234{]}κηάμενοι πυρὰ πολλὰ κατὰ στρατόν, οὐδʼ ἔτι φασὶ{l]
[l [n}9.235{]}σχήσεσθʼ, ἀλλʼ ἐν νηυσὶ μελαίνῃσιν πεσέεσθαι.{l]
[l [n}9.236{]}Ζεὺς δέ σφι Κρονίδης ἐνδέξια σήματα φαίνων{l]
[l [n}9.237{]}ἀστράπτει· Ἕκτωρ δὲ μέγα σθένεϊ βλεμεαίνων{l]
[l [n}9.238{]}μαίνεται ἐκπάγλως πίσυνος Διί, οὐδέ τι τίει{l]
[l [n}9.239{]}ἀνέρας οὐδὲ θεούς· κρατερὴ δέ ἑ λύσσα δέδυκεν.{l]
[l [n}9.240{]}ἀρᾶται δὲ τάχιστα φανήμεναι Ἠῶ δῖαν·{l]
[l [n}9.241{]}στεῦται γὰρ νηῶν ἀποκόψειν ἄκρα κόρυμβα{l]
[l [n}9.242{]}αὐτάς τʼ ἐμπρήσειν μαλεροῦ πυρός, αὐτὰρ Ἀχαιοὺς{l]
[l [n}9.243{]}δῃώσειν παρὰ τῇσιν ὀρινομένους ὑπὸ καπνοῦ.{l]
[l [n}9.244{]}ταῦτʼ αἰνῶς δείδοικα κατὰ φρένα, μή οἱ ἀπειλὰς{l]
[l [n}9.245{]}ἐκτελέσωσι θεοί, ἡμῖν δὲ δὴ αἴσιμον εἴη{l]
[l [n}9.246{]}φθίσθαι ἐνὶ Τροίῃ ἑκὰς Ἄργεος ἱπποβότοιο.{l]
[l [n}9.247{]}ἀλλʼ ἄνα εἰ μέμονάς γε καὶ ὀψέ περ υἷας Ἀχαιῶν{l]
[l [n}9.248{]}τειρομένους ἐρύεσθαι ὑπὸ Τρώων ὀρυμαγδοῦ.{l]
[l [n}9.249{]}αὐτῷ τοι μετόπισθʼ ἄχος ἔσσεται, οὐδέ τι μῆχος{l]
[l [n}9.250{]}ῥεχθέντος κακοῦ ἔστʼ ἄκος εὑρεῖν· ἀλλὰ πολὺ πρὶν{l]
[l [n}9.251{]}φράζευ ὅπως Δαναοῖσιν ἀλεξήσεις κακὸν ἦμαρ.{l]
[l [n}9.252{]}ὦ πέπον ἦ μὲν σοί γε πατὴρ ἐπετέλλετο Πηλεὺς{l]
[l [n}9.253{]}ἤματι τῷ ὅτε σʼ ἐκ Φθίης Ἀγαμέμνονι πέμπε·{l]
[q}[l [n}9.254{]}τέκνον ἐμὸν κάρτος μὲν Ἀθηναίη τε καὶ Ἥρη{l]
[l [n}9.255{]}δώσουσʼ αἴ κʼ ἐθέλωσι, σὺ δὲ μεγαλήτορα θυμὸν{l]
[l [n}9.256{]}ἴσχειν ἐν στήθεσσι· φιλοφροσύνη γὰρ ἀμείνων·{l]
[l [n}9.257{]}ληγέμεναι δʼ ἔριδος κακομηχάνου, ὄφρά σε μᾶλλον{l]
[l [n}9.258{]}τίωσʼ Ἀργείων ἠμὲν νέοι ἠδὲ γέροντες.{l]{q][l [n}9.259{]}ὣς ἐπέτελλʼ ὃ γέρων, σὺ δὲ λήθεαι· ἀλλʼ ἔτι καὶ νῦν{l]
[l [n}9.260{]}παύεʼ, ἔα δὲ χόλον θυμαλγέα· σοὶ δʼ Ἀγαμέμνων{l]
[l [n}9.261{]}ἄξια δῶρα δίδωσι μεταλήξαντι χόλοιο.{l]
[l [n}9.262{]}εἰ δὲ σὺ μέν μευ ἄκουσον, ἐγὼ δέ κέ τοι καταλέξω{l]
[l [n}9.263{]}ὅσσά τοι ἐν κλισίῃσιν ὑπέσχετο δῶρʼ Ἀγαμέμνων·{l]
[l [n}9.264{]}ἕπτʼ ἀπύρους τρίποδας, δέκα δὲ χρυσοῖο τάλαντα,{l]
[l [n}9.265{]}αἴθωνας δὲ λέβητας ἐείκοσι, δώδεκα δʼ ἵππους{l]
[l [n}9.266{]}πηγοὺς ἀθλοφόρους, οἳ ἀέθλια ποσσὶν ἄροντο.{l]
[l [n}9.267{]}οὔ κεν ἀλήϊος εἴη ἀνὴρ ᾧ τόσσα γένοιτο{l]
[l [n}9.268{]}οὐδέ κεν ἀκτήμων ἐριτίμοιο χρυσοῖο,{l]
[l [n}9.269{]}ὅσσʼ Ἀγαμέμνονος ἵπποι ἀέθλια ποσσὶν ἄροντο.{l]
[l [n}9.270{]}δώσει δʼ ἑπτὰ γυναῖκας ἀμύμονα ἔργα ἰδυίας{l]
[l [n}9.271{]}Λεσβίδας, ἃς ὅτε Λέσβον ἐϋκτιμένην ἕλες αὐτὸς{l]
[l [n}9.272{]}ἐξέλεθʼ, αἳ τότε κάλλει ἐνίκων φῦλα γυναικῶν.{l]
[l [n}9.273{]}τὰς μέν τοι δώσει, μετὰ δʼ ἔσσεται ἣν τότʼ ἀπηύρα{l]
[l [n}9.274{]}κούρη Βρισῆος· ἐπὶ δὲ μέγαν ὅρκον ὀμεῖται{l]
[l [n}9.275{]}μή ποτε τῆς εὐνῆς ἐπιβήμεναι ἠδὲ μιγῆναι{l]
[l [n}9.276{]}ἣ θέμις ἐστὶν ἄναξ ἤτʼ ἀνδρῶν ἤτε γυναικῶν.{l]
[l [n}9.277{]}ταῦτα μὲν αὐτίκα πάντα παρέσσεται· εἰ δέ κεν αὖτε{l]
[l [n}9.278{]}ἄστυ μέγα Πριάμοιο θεοὶ δώωσʼ ἀλαπάξαι,{l]
[l [n}9.279{]}νῆα ἅλις χρυσοῦ καὶ χαλκοῦ νηήσασθαι{l]
[l [n}9.280{]}εἰσελθών, ὅτε κεν δατεώμεθα ληΐδʼ Ἀχαιοί,{l]
[l [n}9.281{]}Τρωϊάδας δὲ γυναῖκας ἐείκοσιν αὐτὸς ἑλέσθαι,{l]
[l [n}9.282{]}αἵ κε μετʼ Ἀργείην Ἑλένην κάλλισται ἔωσιν.{l]
[l [n}9.283{]}εἰ δέ κεν Ἄργος ἱκοίμεθʼ Ἀχαιϊκὸν οὖθαρ ἀρούρης{l]
[l [n}9.284{]}γαμβρός κέν οἱ ἔοις· τίσει δέ σε ἶσον Ὀρέστῃ,{l]
[l [n}9.285{]}ὅς οἱ τηλύγετος τρέφεται θαλίῃ ἔνι πολλῇ.{l]
[l [n}9.286{]}τρεῖς δέ οἵ εἰσι θύγατρες ἐνὶ μεγάρῳ εὐπήκτῳ{l]
[l [n}9.287{]}Χρυσόθεμις καὶ Λαοδίκη καὶ Ἰφιάνασσα,{l]
[l [n}9.288{]}τάων ἥν κʼ ἐθέλῃσθα φίλην ἀνάεδνον ἄγεσθαι{l]
[l [n}9.289{]}πρὸς οἶκον Πηλῆος· ὃ δʼ αὖτʼ ἐπὶ μείλια δώσει{l]
[l [n}9.290{]}πολλὰ μάλʼ, ὅσσʼ οὔ πώ τις ἑῇ ἐπέδωκε θυγατρί·{l]
[l [n}9.291{]}ἑπτὰ δέ τοι δώσει εὖ ναιόμενα πτολίεθρα{l]
[l [n}9.292{]}Καρδαμύλην Ἐνόπην τε καὶ Ἱρὴν ποιήεσσαν{l]
[l [n}9.293{]}Φηράς τε ζαθέας ἠδʼ Ἄνθειαν βαθύλειμον{l]
[l [n}9.294{]}καλήν τʼ Αἴπειαν καὶ Πήδασον ἀμπελόεσσαν.{l]
[l [n}9.295{]}πᾶσαι δʼ ἐγγὺς ἁλός, νέαται Πύλου ἠμαθόεντος·{l]
[l [n}9.296{]}ἐν δʼ ἄνδρες ναίουσι πολύρρηνες πολυβοῦται,{l]
[l [n}9.297{]}οἵ κέ σε δωτίνῃσι θεὸν ὣς τιμήσουσι{l]
[l [n}9.298{]}καί τοι ὑπὸ σκήπτρῳ λιπαρὰς τελέουσι θέμιστας.{l]
[l [n}9.299{]}ταῦτά κέ τοι τελέσειε μεταλήξαντι χόλοιο.{l]
[l [n}9.300{]}εἰ δέ τοι Ἀτρεΐδης μὲν ἀπήχθετο κηρόθι μᾶλλον{l]
[l [n}9.301{]}αὐτὸς καὶ τοῦ δῶρα, σὺ δʼ ἄλλους περ Παναχαιοὺς{l]
[l [n}9.302{]}τειρομένους ἐλέαιρε κατὰ στρατόν, οἵ σε θεὸν ὣς{l]
[l [n}9.303{]}τίσουσʼ· ἦ γάρ κέ σφι μάλα μέγα κῦδος ἄροιο·{l]
[l [n}9.304{]}νῦν γάρ χʼ Ἕκτορʼ ἕλοις, ἐπεὶ ἂν μάλα τοι σχεδὸν ἔλθοι{l]
[l [n}9.305{]}λύσσαν ἔχων ὀλοήν, ἐπεὶ οὔ τινά φησιν ὁμοῖον{l]
[l [n}9.306{]}οἷ ἔμεναι Δαναῶν οὓς ἐνθάδε νῆες ἔνεικαν.{l]{q]{para]
[para}[l [n}9.307{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}9.308{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}9.309{]}χρὴ μὲν δὴ τὸν μῦθον ἀπηλεγέως ἀποειπεῖν,{l]
[l [n}9.310{]}ᾗ περ δὴ φρονέω τε καὶ ὡς τετελεσμένον ἔσται,{l]
[l [n}9.311{]}ὡς μή μοι τρύζητε παρήμενοι ἄλλοθεν ἄλλος.{l]
[l [n}9.312{]}ἐχθρὸς γάρ μοι κεῖνος ὁμῶς Ἀΐδαο πύλῃσιν{l]
[l [n}9.313{]}ὅς χʼ ἕτερον μὲν κεύθῃ ἐνὶ φρεσίν, ἄλλο δὲ εἴπῃ.{l]
[l [n}9.314{]}αὐτὰρ ἐγὼν ἐρέω ὥς μοι δοκεῖ εἶναι ἄριστα·{l]
[l [n}9.315{]}οὔτʼ ἔμεγʼ Ἀτρεΐδην Ἀγαμέμνονα πεισέμεν οἴω{l]
[l [n}9.316{]}οὔτʼ ἄλλους Δαναούς, ἐπεὶ οὐκ ἄρα τις χάρις ἦεν{l]
[l [n}9.317{]}μάρνασθαι δηΐοισιν ἐπʼ ἀνδράσι νωλεμὲς αἰεί.{l]
[l [n}9.318{]}ἴση μοῖρα μένοντι καὶ εἰ μάλα τις πολεμίζοι·{l]
[l [n}9.319{]}ἐν δὲ ἰῇ τιμῇ ἠμὲν κακὸς ἠδὲ καὶ ἐσθλός·{l]
[l [n}9.320{]}κάτθανʼ ὁμῶς ὅ τʼ ἀεργὸς ἀνὴρ ὅ τε πολλὰ ἐοργώς.{l]
[l [n}9.321{]}οὐδέ τί μοι περίκειται, ἐπεὶ πάθον ἄλγεα θυμῷ{l]
[l [n}9.322{]}αἰεὶ ἐμὴν ψυχὴν παραβαλλόμενος πολεμίζειν.{l]
[l [n}9.323{]}ὡς δʼ ὄρνις ἀπτῆσι νεοσσοῖσι προφέρῃσι{l]
[l [n}9.324{]}μάστακʼ ἐπεί κε λάβῃσι, κακῶς δʼ ἄρα οἱ πέλει αὐτῇ,{l]
[l [n}9.325{]}ὣς καὶ ἐγὼ πολλὰς μὲν ἀΰπνους νύκτας ἴαυον,{l]
[l [n}9.326{]}ἤματα δʼ αἱματόεντα διέπρησσον πολεμίζων{l]
[l [n}9.327{]}ἀνδράσι μαρνάμενος ὀάρων ἕνεκα σφετεράων.{l]
[l [n}9.328{]}δώδεκα δὴ σὺν νηυσὶ πόλεις ἀλάπαξʼ ἀνθρώπων,{l]
[l [n}9.329{]}πεζὸς δʼ ἕνδεκά φημι κατὰ Τροίην ἐρίβωλον·{l]
[l [n}9.330{]}τάων ἐκ πασέων κειμήλια πολλὰ καὶ ἐσθλὰ{l]
[l [n}9.331{]}ἐξελόμην, καὶ πάντα φέρων Ἀγαμέμνονι δόσκον{l]
[l [n}9.332{]}Ἀτρεΐδῃ· ὃ δʼ ὄπισθε μένων παρὰ νηυσὶ θοῇσι{l]
[l [n}9.333{]}δεξάμενος διὰ παῦρα δασάσκετο, πολλὰ δʼ ἔχεσκεν.{l]
[l [n}9.334{]}ἄλλα δʼ ἀριστήεσσι δίδου γέρα καὶ βασιλεῦσι·{l]
[l [n}9.335{]}τοῖσι μὲν ἔμπεδα κεῖται, ἐμεῦ δʼ ἀπὸ μούνου Ἀχαιῶν{l]
[l [n}9.336{]}εἵλετʼ, ἔχει δʼ ἄλοχον θυμαρέα· τῇ παριαύων{l]
[l [n}9.337{]}τερπέσθω. τί δὲ δεῖ πολεμιζέμεναι Τρώεσσιν{l]
[l [n}9.338{]}Ἀργείους; τί δὲ λαὸν ἀνήγαγεν ἐνθάδʼ ἀγείρας{l]
[l [n}9.339{]}Ἀτρεΐδης; ἦ οὐχ Ἑλένης ἕνεκʼ ἠϋκόμοιο;{l]
[l [n}9.340{]}ἦ μοῦνοι φιλέουσʼ ἀλόχους μερόπων ἀνθρώπων{l]
[l [n}9.341{]}Ἀτρεΐδαι; ἐπεὶ ὅς τις ἀνὴρ ἀγαθὸς καὶ ἐχέφρων{l]
[l [n}9.342{]}τὴν αὐτοῦ φιλέει καὶ κήδεται, ὡς καὶ ἐγὼ τὴν{l]
[l [n}9.343{]}ἐκ θυμοῦ φίλεον δουρικτητήν περ ἐοῦσαν.{l]
[l [n}9.344{]}νῦν δʼ ἐπεὶ ἐκ χειρῶν γέρας εἵλετο καί μʼ ἀπάτησε{l]
[l [n}9.345{]}μή μευ πειράτω εὖ εἰδότος· οὐδέ με πείσει.{l]
[l [n}9.346{]}ἀλλʼ Ὀδυσεῦ σὺν σοί τε καὶ ἄλλοισιν βασιλεῦσι{l]
[l [n}9.347{]}φραζέσθω νήεσσιν ἀλεξέμεναι δήϊον πῦρ.{l]
[l [n}9.348{]}ἦ μὲν δὴ μάλα πολλὰ πονήσατο νόσφιν ἐμεῖο,{l]
[l [n}9.349{]}καὶ δὴ τεῖχος ἔδειμε, καὶ ἤλασε τάφρον ἐπʼ αὐτῷ{l]
[l [n}9.350{]}εὐρεῖαν μεγάλην, ἐν δὲ σκόλοπας κατέπηξεν·{l]
[l [n}9.351{]}ἀλλʼ οὐδʼ ὧς δύναται σθένος Ἕκτορος ἀνδροφόνοιο{l]
[l [n}9.352{]}ἴσχειν· ὄφρα δʼ ἐγὼ μετʼ Ἀχαιοῖσιν πολέμιζον{l]
[l [n}9.353{]}οὐκ ἐθέλεσκε μάχην ἀπὸ τείχεος ὀρνύμεν Ἕκτωρ,{l]
[l [n}9.354{]}ἀλλʼ ὅσον ἐς Σκαιάς τε πύλας καὶ φηγὸν ἵκανεν·{l]
[l [n}9.355{]}ἔνθά ποτʼ οἶον ἔμιμνε, μόγις δέ μευ ἔκφυγεν ὁρμήν.{l]
[l [n}9.356{]}νῦν δʼ ἐπεὶ οὐκ ἐθέλω πολεμιζέμεν Ἕκτορι δίῳ{l]
[l [n}9.357{]}αὔριον ἱρὰ Διὶ ῥέξας καὶ πᾶσι θεοῖσι{l]
[l [n}9.358{]}νηήσας εὖ νῆας, ἐπὴν ἅλα δὲ προερύσσω,{l]
[l [n}9.359{]}ὄψεαι, αἴ κʼ ἐθέλῃσθα καὶ αἴ κέν τοι τὰ μεμήλῃ,{l]
[l [n}9.360{]}ἦρι μάλʼ Ἑλλήσποντον ἐπʼ ἰχθυόεντα πλεούσας{l]
[l [n}9.361{]}νῆας ἐμάς, ἐν δʼ ἄνδρας ἐρεσσέμεναι μεμαῶτας·{l]
[l [n}9.362{]}εἰ δέ κεν εὐπλοίην δώῃ κλυτὸς ἐννοσίγαιος{l]
[l [n}9.363{]}ἤματί κε τριτάτῳ Φθίην ἐρίβωλον ἱκοίμην.{l]
[l [n}9.364{]}ἔστι δέ μοι μάλα πολλά, τὰ κάλλιπον ἐνθάδε ἔρρων·{l]
[l [n}9.365{]}ἄλλον δʼ ἐνθένδε χρυσὸν καὶ χαλκὸν ἐρυθρὸν{l]
[l [n}9.366{]}ἠδὲ γυναῖκας ἐϋζώνους πολιόν τε σίδηρον{l]
[l [n}9.367{]}ἄξομαι, ἅσσʼ ἔλαχόν γε· γέρας δέ μοι, ὅς περ ἔδωκεν,{l]
[l [n}9.368{]}αὖτις ἐφυβρίζων ἕλετο κρείων Ἀγαμέμνων{l]
[l [n}9.369{]}Ἀτρεΐδης· τῷ πάντʼ ἀγορευέμεν ὡς ἐπιτέλλω{l]
[l [n}9.370{]}ἀμφαδόν, ὄφρα καὶ ἄλλοι ἐπισκύζωνται Ἀχαιοὶ{l]
[l [n}9.371{]}εἴ τινά που Δαναῶν ἔτι ἔλπεται ἐξαπατήσειν{l]
[l [n}9.372{]}αἰὲν ἀναιδείην ἐπιειμένος· οὐδʼ ἂν ἔμοιγε{l]
[l [n}9.373{]}τετλαίη κύνεός περ ἐὼν εἰς ὦπα ἰδέσθαι·{l]
[l [n}9.374{]}οὐδέ τί οἱ βουλὰς συμφράσσομαι, οὐδὲ μὲν ἔργον·{l]
[l [n}9.375{]}ἐκ γὰρ δή μʼ ἀπάτησε καὶ ἤλιτεν· οὐδʼ ἂν ἔτʼ αὖτις{l]
[l [n}9.376{]}ἐξαπάφοιτʼ ἐπέεσσιν· ἅλις δέ οἱ· ἀλλὰ ἕκηλος{l]
[l [n}9.377{]}ἐρρέτω· ἐκ γάρ εὑ φρένας εἵλετο μητίετα Ζεύς.{l]
[l [n}9.378{]}ἐχθρὰ δέ μοι τοῦ δῶρα, τίω δέ μιν ἐν καρὸς αἴσῃ.{l]
[l [n}9.379{]}οὐδʼ εἴ μοι δεκάκις τε καὶ εἰκοσάκις τόσα δοίη{l]
[l [n}9.380{]}ὅσσά τέ οἱ νῦν ἔστι, καὶ εἴ ποθεν ἄλλα γένοιτο,{l]
[l [n}9.381{]}οὐδʼ ὅσʼ ἐς Ὀρχομενὸν ποτινίσεται, οὐδʼ ὅσα Θήβας{l]
[l [n}9.382{]}Αἰγυπτίας, ὅθι πλεῖστα δόμοις ἐν κτήματα κεῖται,{l]
[l [n}9.383{]}αἵ θʼ ἑκατόμπυλοί εἰσι, διηκόσιοι δʼ ἀνʼ ἑκάστας{l]
[l [n}9.384{]}ἀνέρες ἐξοιχνεῦσι σὺν ἵπποισιν καὶ ὄχεσφιν·{l]
[l [n}9.385{]}οὐδʼ εἴ μοι τόσα δοίη ὅσα ψάμαθός τε κόνις τε,{l]
[l [n}9.386{]}οὐδέ κεν ὧς ἔτι θυμὸν ἐμὸν πείσειʼ Ἀγαμέμνων{l]
[l [n}9.387{]}πρίν γʼ ἀπὸ πᾶσαν ἐμοὶ δόμεναι θυμαλγέα λώβην.{l]
[l [n}9.388{]}κούρην δʼ οὐ γαμέω Ἀγαμέμνονος Ἀτρεΐδαο,{l]
[l [n}9.389{]}οὐδʼ εἰ χρυσείῃ Ἀφροδίτῃ κάλλος ἐρίζοι,{l]
[l [n}9.390{]}ἔργα δʼ Ἀθηναίῃ γλαυκώπιδι ἰσοφαρίζοι·{l]
[l [n}9.391{]}οὐδέ μιν ὧς γαμέω· ὃ δʼ Ἀχαιῶν ἄλλον ἑλέσθω,{l]
[l [n}9.392{]}ὅς τις οἷ τʼ ἐπέοικε καὶ ὃς βασιλεύτερός ἐστιν.{l]
[l [n}9.393{]}ἢν γὰρ δή με σαῶσι θεοὶ καὶ οἴκαδʼ ἵκωμαι,{l]
[l [n}9.394{]}Πηλεύς θήν μοι ἔπειτα γυναῖκά γε μάσσεται αὐτός.{l]
[l [n}9.395{]}πολλαὶ Ἀχαιΐδες εἰσὶν ἀνʼ Ἑλλάδα τε Φθίην τε{l]
[l [n}9.396{]}κοῦραι ἀριστήων, οἵ τε πτολίεθρα ῥύονται,{l]
[l [n}9.397{]}τάων ἥν κʼ ἐθέλωμι φίλην ποιήσομʼ ἄκοιτιν.{l]
[l [n}9.398{]}ἔνθα δέ μοι μάλα πολλὸν ἐπέσσυτο θυμὸς ἀγήνωρ{l]
[l [n}9.399{]}γήμαντα μνηστὴν ἄλοχον ἐϊκυῖαν ἄκοιτιν{l]
[l [n}9.400{]}κτήμασι τέρπεσθαι τὰ γέρων ἐκτήσατο Πηλεύς·{l]
[l [n}9.401{]}οὐ γὰρ ἐμοὶ ψυχῆς ἀντάξιον οὐδʼ ὅσα φασὶν{l]
[l [n}9.402{]}Ἴλιον ἐκτῆσθαι εὖ ναιόμενον πτολίεθρον{l]
[l [n}9.403{]}τὸ πρὶν ἐπʼ εἰρήνης, πρὶν ἐλθεῖν υἷας Ἀχαιῶν,{l]
[l [n}9.404{]}οὐδʼ ὅσα λάϊνος οὐδὸς ἀφήτορος ἐντὸς ἐέργει{l]
[l [n}9.405{]}Φοίβου Ἀπόλλωνος Πυθοῖ ἔνι πετρηέσσῃ.{l]
[l [n}9.406{]}ληϊστοὶ μὲν γάρ τε βόες καὶ ἴφια μῆλα,{l]
[l [n}9.407{]}κτητοὶ δὲ τρίποδές τε καὶ ἵππων ξανθὰ κάρηνα,{l]
[l [n}9.408{]}ἀνδρὸς δὲ ψυχὴ πάλιν ἐλθεῖν οὔτε λεϊστὴ{l]
[l [n}9.409{]}οὔθʼ ἑλετή, ἐπεὶ ἄρ κεν ἀμείψεται ἕρκος ὀδόντων.{l]
[l [n}9.410{]}μήτηρ γάρ τέ μέ φησι θεὰ Θέτις ἀργυρόπεζα{l]
[l [n}9.411{]}διχθαδίας κῆρας φερέμεν θανάτοιο τέλος δέ.{l]
[l [n}9.412{]}εἰ μέν κʼ αὖθι μένων Τρώων πόλιν ἀμφιμάχωμαι,{l]
[l [n}9.413{]}ὤλετο μέν μοι νόστος, ἀτὰρ κλέος ἄφθιτον ἔσται·{l]
[l [n}9.414{]}εἰ δέ κεν οἴκαδʼ ἵκωμι φίλην ἐς πατρίδα γαῖαν,{l]
[l [n}9.415{]}ὤλετό μοι κλέος ἐσθλόν, ἐπὶ δηρὸν δέ μοι αἰὼν{l]
[l [n}9.416{]}ἔσσεται, οὐδέ κέ μʼ ὦκα τέλος θανάτοιο κιχείη.{l]
[l [n}9.417{]}καὶ δʼ ἂν τοῖς ἄλλοισιν ἐγὼ παραμυθησαίμην{l]
[l [n}9.418{]}οἴκαδʼ ἀποπλείειν, ἐπεὶ οὐκέτι δήετε τέκμωρ{l]
[l [n}9.419{]}Ἰλίου αἰπεινῆς· μάλα γάρ ἑθεν εὐρύοπα Ζεὺς{l]
[l [n}9.420{]}χεῖρα ἑὴν ὑπερέσχε, τεθαρσήκασι δὲ λαοί.{l]
[l [n}9.421{]}ἀλλʼ ὑμεῖς μὲν ἰόντες ἀριστήεσσιν Ἀχαιῶν{l]
[l [n}9.422{]}ἀγγελίην ἀπόφασθε· τὸ γὰρ γέρας ἐστὶ γερόντων·{l]
[l [n}9.423{]}ὄφρʼ ἄλλην φράζωνται ἐνὶ φρεσὶ μῆτιν ἀμείνω,{l]
[l [n}9.424{]}ἥ κέ σφιν νῆάς τε σαῷ καὶ λαὸν Ἀχαιῶν{l]
[l [n}9.425{]}νηυσὶν ἔπι γλαφυρῇς, ἐπεὶ οὔ σφισιν ἥδέ γʼ ἑτοίμη{l]
[l [n}9.426{]}ἣν νῦν ἐφράσσαντο ἐμεῦ ἀπομηνίσαντος·{l]
[l [n}9.427{]}Φοῖνιξ δʼ αὖθι παρʼ ἄμμι μένων κατακοιμηθήτω,{l]
[l [n}9.428{]}ὄφρά μοι ἐν νήεσσι φίλην ἐς πατρίδʼ ἕπηται{l]
[l [n}9.429{]}αὔριον ἢν ἐθέλῃσιν· ἀνάγκῃ δʼ οὔ τί μιν ἄξω.{l]{q]{para]
[para}[l [n}9.430{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ{l]
[l [n}9.431{]}μῦθον ἀγασσάμενοι· μάλα γὰρ κρατερῶς ἀπέειπεν·{l]
[l [n}9.432{]}ὀψὲ δὲ δὴ μετέειπε γέρων ἱππηλάτα Φοῖνιξ{l]
[l [n}9.433{]}δάκρυʼ ἀναπρήσας· περὶ γὰρ δίε νηυσὶν Ἀχαιῶν·{l]
[q}[l [n}9.434{]}εἰ μὲν δὴ νόστόν γε μετὰ φρεσὶ φαίδιμʼ Ἀχιλλεῦ{l]
[l [n}9.435{]}βάλλεαι, οὐδέ τι πάμπαν ἀμύνειν νηυσὶ θοῇσι{l]
[l [n}9.436{]}πῦρ ἐθέλεις ἀΐδηλον, ἐπεὶ χόλος ἔμπεσε θυμῷ,{l]
[l [n}9.437{]}πῶς ἂν ἔπειτʼ ἀπὸ σεῖο φίλον τέκος αὖθι λιποίμην{l]
[l [n}9.438{]}οἶος; σοὶ δέ μʼ ἔπεμπε γέρων ἱππηλάτα Πηλεὺς{l]
[l [n}9.439{]}ἤματι τῷ ὅτε σʼ ἐκ Φθίης Ἀγαμέμνονι πέμπε{l]
[l [n}9.440{]}νήπιον οὔ πω εἰδόθʼ ὁμοιΐου πολέμοιο{l]
[l [n}9.441{]}οὐδʼ ἀγορέων, ἵνα τʼ ἄνδρες ἀριπρεπέες τελέθουσι.{l]
[l [n}9.442{]}τοὔνεκά με προέηκε διδασκέμεναι τάδε πάντα,{l]
[l [n}9.443{]}μύθων τε ῥητῆρʼ ἔμεναι πρηκτῆρά τε ἔργων.{l]
[l [n}9.444{]}ὡς ἂν ἔπειτʼ ἀπὸ σεῖο φίλον τέκος οὐκ ἐθέλοιμι{l]
[l [n}9.445{]}λείπεσθʼ, οὐδʼ εἴ κέν μοι ὑποσταίη θεὸς αὐτὸς{l]
[l [n}9.446{]}γῆρας ἀποξύσας θήσειν νέον ἡβώοντα,{l]
[l [n}9.447{]}οἷον ὅτε πρῶτον λίπον Ἑλλάδα καλλιγύναικα{l]
[l [n}9.448{]}φεύγων νείκεα πατρὸς Ἀμύντορος Ὀρμενίδαο,{l]
[l [n}9.449{]}ὅς μοι παλλακίδος περιχώσατο καλλικόμοιο,{l]
[l [n}9.450{]}τὴν αὐτὸς φιλέεσκεν, ἀτιμάζεσκε δʼ ἄκοιτιν{l]
[l [n}9.451{]}μητέρʼ ἐμήν· ἣ δʼ αἰὲν ἐμὲ λισσέσκετο γούνων{l]
[l [n}9.452{]}παλλακίδι προμιγῆναι, ἵνʼ ἐχθήρειε γέροντα.{l]
[l [n}9.453{]}τῇ πιθόμην καὶ ἔρεξα· πατὴρ δʼ ἐμὸς αὐτίκʼ ὀϊσθεὶς{l]
[l [n}9.454{]}πολλὰ κατηρᾶτο, στυγερὰς δʼ ἐπεκέκλετʼ Ἐρινῦς,{l]
[l [n}9.455{]}μή ποτε γούνασιν οἷσιν ἐφέσσεσθαι φίλον υἱὸν{l]
[l [n}9.456{]}ἐξ ἐμέθεν γεγαῶτα· θεοὶ δʼ ἐτέλειον ἐπαρὰς{l]
[l [n}9.457{]}Ζεύς τε καταχθόνιος καὶ ἐπαινὴ Περσεφόνεια.{l][note [resp}perseus{]}This edition omits lines 458-461.{note][l [n}9.462{]}ἔνθʼ ἐμοὶ οὐκέτι πάμπαν ἐρητύετʼ ἐν φρεσὶ θυμὸς{l]
[l [n}9.463{]}πατρὸς χωομένοιο κατὰ μέγαρα στρωφᾶσθαι.{l]
[l [n}9.464{]}ἦ μὲν πολλὰ ἔται καὶ ἀνεψιοὶ ἀμφὶς ἐόντες{l]
[l [n}9.465{]}αὐτοῦ λισσόμενοι κατερήτυον ἐν μεγάροισι,{l]
[l [n}9.466{]}πολλὰ δὲ ἴφια μῆλα καὶ εἰλίποδας ἕλικας βοῦς{l]
[l [n}9.467{]}ἔσφαζον, πολλοὶ δὲ σύες θαλέθοντες ἀλοιφῇ{l]
[l [n}9.468{]}εὑόμενοι τανύοντο διὰ φλογὸς Ἡφαίστοιο,{l]
[l [n}9.469{]}πολλὸν δʼ ἐκ κεράμων μέθυ πίνετο τοῖο γέροντος.{l]
[l [n}9.470{]}εἰνάνυχες δέ μοι ἀμφʼ αὐτῷ παρὰ νύκτας ἴαυον·{l]
[l [n}9.471{]}οἳ μὲν ἀμειβόμενοι φυλακὰς ἔχον, οὐδέ ποτʼ ἔσβη{l]
[l [n}9.472{]}πῦρ, ἕτερον μὲν ὑπʼ αἰθούσῃ εὐερκέος αὐλῆς,{l]
[l [n}9.473{]}ἄλλο δʼ ἐνὶ προδόμῳ, πρόσθεν θαλάμοιο θυράων.{l]
[l [n}9.474{]}ἀλλʼ ὅτε δὴ δεκάτη μοι ἐπήλυθε νὺξ ἐρεβεννή,{l]
[l [n}9.475{]}καὶ τότʼ ἐγὼ θαλάμοιο θύρας πυκινῶς ἀραρυίας{l]
[l [n}9.476{]}ῥήξας ἐξῆλθον, καὶ ὑπέρθορον ἑρκίον αὐλῆς{l]
[l [n}9.477{]}ῥεῖα, λαθὼν φύλακάς τʼ ἄνδρας δμῳάς τε γυναῖκας.{l]
[l [n}9.478{]}φεῦγον ἔπειτʼ ἀπάνευθε διʼ Ἑλλάδος εὐρυχόροιο,{l]
[l [n}9.479{]}Φθίην δʼ ἐξικόμην ἐριβώλακα μητέρα μήλων{l]
[l [n}9.480{]}ἐς Πηλῆα ἄναχθʼ· ὃ δέ με πρόφρων ὑπέδεκτο,{l]
[l [n}9.481{]}καί μʼ ἐφίλησʼ ὡς εἴ τε πατὴρ ὃν παῖδα φιλήσῃ{l]
[l [n}9.482{]}μοῦνον τηλύγετον πολλοῖσιν ἐπὶ κτεάτεσσι,{l]
[l [n}9.483{]}καί μʼ ἀφνειὸν ἔθηκε, πολὺν δέ μοι ὤπασε λαόν·{l]
[l [n}9.484{]}ναῖον δʼ ἐσχατιὴν Φθίης Δολόπεσσιν ἀνάσσων.{l]
[l [n}9.485{]}καί σε τοσοῦτον ἔθηκα θεοῖς ἐπιείκελʼ Ἀχιλλεῦ,{l]
[l [n}9.486{]}ἐκ θυμοῦ φιλέων, ἐπεὶ οὐκ ἐθέλεσκες ἅμʼ ἄλλῳ{l]
[l [n}9.487{]}οὔτʼ ἐς δαῖτʼ ἰέναι οὔτʼ ἐν μεγάροισι πάσασθαι,{l]
[l [n}9.488{]}πρίν γʼ ὅτε δή σʼ ἐπʼ ἐμοῖσιν ἐγὼ γούνεσσι καθίσσας{l]
[l [n}9.489{]}ὄψου τʼ ἄσαιμι προταμὼν καὶ οἶνον ἐπισχών.{l]
[l [n}9.490{]}πολλάκι μοι κατέδευσας ἐπὶ στήθεσσι χιτῶνα{l]
[l [n}9.491{]}οἴνου ἀποβλύζων ἐν νηπιέῃ ἀλεγεινῇ.{l]
[l [n}9.492{]}ὣς ἐπὶ σοὶ μάλα πολλὰ πάθον καὶ πολλὰ μόγησα,{l]
[l [n}9.493{]}τὰ φρονέων ὅ μοι οὔ τι θεοὶ γόνον ἐξετέλειον{l]
[l [n}9.494{]}ἐξ ἐμεῦ· ἀλλὰ σὲ παῖδα θεοῖς ἐπιείκελʼ Ἀχιλλεῦ{l]
[l [n}9.495{]}ποιεύμην, ἵνα μοί ποτʼ ἀεικέα λοιγὸν ἀμύνῃς.{l]
[l [n}9.496{]}ἀλλʼ Ἀχιλεῦ δάμασον θυμὸν μέγαν· οὐδέ τί σε χρὴ{l]
[l [n}9.497{]}νηλεὲς ἦτορ ἔχειν· στρεπτοὶ δέ τε καὶ θεοὶ αὐτοί,{l]
[l [n}9.498{]}τῶν περ καὶ μείζων ἀρετὴ τιμή τε βίη τε.{l]
[l [n}9.499{]}καὶ μὲν τοὺς θυέεσσι καὶ εὐχωλῇς ἀγανῇσι{l]
[l [n}9.500{]}λοιβῇ τε κνίσῃ τε παρατρωπῶσʼ ἄνθρωποι{l]
[l [n}9.501{]}λισσόμενοι, ὅτε κέν τις ὑπερβήῃ καὶ ἁμάρτῃ.{l]
[l [n}9.502{]}καὶ γάρ τε λιταί εἰσι Διὸς κοῦραι μεγάλοιο{l]
[l [n}9.503{]}χωλαί τε ῥυσαί τε παραβλῶπές τʼ ὀφθαλμώ,{l]
[l [n}9.504{]}αἵ ῥά τε καὶ μετόπισθʼ ἄτης ἀλέγουσι κιοῦσαι.{l]
[l [n}9.505{]}ἣ δʼ ἄτη σθεναρή τε καὶ ἀρτίπος, οὕνεκα πάσας{l]
[l [n}9.506{]}πολλὸν ὑπεκπροθέει, φθάνει δέ τε πᾶσαν ἐπʼ αἶαν{l]
[l [n}9.507{]}βλάπτουσʼ ἀνθρώπους· αἳ δʼ ἐξακέονται ὀπίσσω.{l]
[l [n}9.508{]}ὃς μέν τʼ αἰδέσεται κούρας Διὸς ἆσσον ἰούσας,{l]
[l [n}9.509{]}τὸν δὲ μέγʼ ὤνησαν καί τʼ ἔκλυον εὐχομένοιο·{l]
[l [n}9.510{]}ὃς δέ κʼ ἀνήνηται καί τε στερεῶς ἀποείπῃ,{l]
[l [n}9.511{]}λίσσονται δʼ ἄρα ταί γε Δία Κρονίωνα κιοῦσαι{l]
[l [n}9.512{]}τῷ ἄτην ἅμʼ ἕπεσθαι, ἵνα βλαφθεὶς ἀποτίσῃ.{l]
[l [n}9.513{]}ἀλλʼ Ἀχιλεῦ πόρε καὶ σὺ Διὸς κούρῃσιν ἕπεσθαι{l]
[l [n}9.514{]}τιμήν, ἥ τʼ ἄλλων περ ἐπιγνάμπτει νόον ἐσθλῶν.{l]
[l [n}9.515{]}εἰ μὲν γὰρ μὴ δῶρα φέροι τὰ δʼ ὄπισθʼ ὀνομάζοι{l]
[l [n}9.516{]}Ἀτρεΐδης, ἀλλʼ αἰὲν ἐπιζαφελῶς χαλεπαίνοι,{l]
[l [n}9.517{]}οὐκ ἂν ἔγωγέ σε μῆνιν ἀπορρίψαντα κελοίμην{l]
[l [n}9.518{]}Ἀργείοισιν ἀμυνέμεναι χατέουσί περ ἔμπης·{l]
[l [n}9.519{]}νῦν δʼ ἅμα τʼ αὐτίκα πολλὰ διδοῖ τὰ δʼ ὄπισθεν ὑπέστη,{l]
[l [n}9.520{]}ἄνδρας δὲ λίσσεσθαι ἐπιπροέηκεν ἀρίστους{l]
[l [n}9.521{]}κρινάμενος κατὰ λαὸν Ἀχαιϊκόν, οἵ τε σοὶ αὐτῷ{l]
[l [n}9.522{]}φίλτατοι Ἀργείων· τῶν μὴ σύ γε μῦθον ἐλέγξῃς{l]
[l [n}9.523{]}μηδὲ πόδας· πρὶν δʼ οὔ τι νεμεσσητὸν κεχολῶσθαι.{l]
[l [n}9.524{]}οὕτω καὶ τῶν πρόσθεν ἐπευθόμεθα κλέα ἀνδρῶν{l]
[l [n}9.525{]}ἡρώων, ὅτε κέν τινʼ ἐπιζάφελος χόλος ἵκοι·{l]
[l [n}9.526{]}δωρητοί τε πέλοντο παράρρητοί τʼ ἐπέεσσι.{l]
[l [n}9.527{]}μέμνημαι τόδε ἔργον ἐγὼ πάλαι οὔ τι νέον γε{l]
[l [n}9.528{]}ὡς ἦν· ἐν δʼ ὑμῖν ἐρέω πάντεσσι φίλοισι.{l]
[l [n}9.529{]}Κουρῆτές τʼ ἐμάχοντο καὶ Αἰτωλοὶ μενεχάρμαι{l]
[l [n}9.530{]}ἀμφὶ πόλιν Καλυδῶνα καὶ ἀλλήλους ἐνάριζον,{l]
[l [n}9.531{]}Αἰτωλοὶ μὲν ἀμυνόμενοι Καλυδῶνος ἐραννῆς,{l]
[l [n}9.532{]}Κουρῆτες δὲ διαπραθέειν μεμαῶτες Ἄρηϊ.{l]
[l [n}9.533{]}καὶ γὰρ τοῖσι κακὸν χρυσόθρονος Ἄρτεμις ὦρσε{l]
[l [n}9.534{]}χωσαμένη ὅ οἱ οὔ τι θαλύσια γουνῷ ἀλωῆς{l]
[l [n}9.535{]}Οἰνεὺς ῥέξʼ· ἄλλοι δὲ θεοὶ δαίνυνθʼ ἑκατόμβας,{l]
[l [n}9.536{]}οἴῃ δʼ οὐκ ἔρρεξε Διὸς κούρῃ μεγάλοιο.{l]
[l [n}9.537{]}ἢ λάθετʼ ἢ οὐκ ἐνόησεν· ἀάσατο δὲ μέγα θυμῷ.{l]
[l [n}9.538{]}ἣ δὲ χολωσαμένη δῖον γένος ἰοχέαιρα{l]
[l [n}9.539{]}ὦρσεν ἔπι χλούνην σῦν ἄγριον ἀργιόδοντα,{l]
[l [n}9.540{]}ὃς κακὰ πόλλʼ ἕρδεσκεν ἔθων Οἰνῆος ἀλωήν·{l]
[l [n}9.541{]}πολλὰ δʼ ὅ γε προθέλυμνα χαμαὶ βάλε δένδρεα μακρὰ{l]
[l [n}9.542{]}αὐτῇσιν ῥίζῃσι καὶ αὐτοῖς ἄνθεσι μήλων.{l]
[l [n}9.543{]}τὸν δʼ υἱὸς Οἰνῆος ἀπέκτεινεν Μελέαγρος{l]
[l [n}9.544{]}πολλέων ἐκ πολίων θηρήτορας ἄνδρας ἀγείρας{l]
[l [n}9.545{]}καὶ κύνας· οὐ μὲν γάρ κε δάμη παύροισι βροτοῖσι·{l]
[l [n}9.546{]}τόσσος ἔην, πολλοὺς δὲ πυρῆς ἐπέβησʼ ἀλεγεινῆς.{l]
[l [n}9.547{]}ἣ δʼ ἀμφʼ αὐτῷ θῆκε πολὺν κέλαδον καὶ ἀϋτὴν{l]
[l [n}9.548{]}ἀμφὶ συὸς κεφαλῇ καὶ δέρματι λαχνήεντι,{l]
[l [n}9.549{]}Κουρήτων τε μεσηγὺ καὶ Αἰτωλῶν μεγαθύμων.{l]
[l [n}9.550{]}ὄφρα μὲν οὖν Μελέαγρος ἄρηι φίλος πολέμιζε,{l]
[l [n}9.551{]}τόφρα δὲ Κουρήτεσσι κακῶς ἦν, οὐδὲ δύναντο{l]
[l [n}9.552{]}τείχεος ἔκτοσθεν μίμνειν πολέες περ ἐόντες·{l]
[l [n}9.553{]}ἀλλʼ ὅτε δὴ Μελέαγρον ἔδυ χόλος, ὅς τε καὶ ἄλλων{l]
[l [n}9.554{]}οἰδάνει ἐν στήθεσσι νόον πύκα περ φρονεόντων,{l]
[l [n}9.555{]}ἤτοι ὃ μητρὶ φίλῃ Ἀλθαίῃ χωόμενος κῆρ{l]
[l [n}9.556{]}κεῖτο παρὰ μνηστῇ ἀλόχῳ καλῇ Κλεοπάτρῃ{l]
[l [n}9.557{]}κούρῃ Μαρπήσσης καλλισφύρου Εὐηνίνης{l]
[l [n}9.558{]}Ἴδεώ θʼ, ὃς κάρτιστος ἐπιχθονίων γένετʼ ἀνδρῶν{l]
[l [n}9.559{]}τῶν τότε· καί ῥα ἄνακτος ἐναντίον εἵλετο τόξον{l]
[l [n}9.560{]}Φοίβου Ἀπόλλωνος καλλισφύρου εἵνεκα νύμφης,{l]
[l [n}9.561{]}τὴν δὲ τότʼ ἐν μεγάροισι πατὴρ καὶ πότνια μήτηρ{l]
[l [n}9.562{]}Ἀλκυόνην καλέεσκον ἐπώνυμον, οὕνεκʼ ἄρʼ αὐτῆς{l]
[l [n}9.563{]}μήτηρ ἀλκυόνος πολυπενθέος οἶτον ἔχουσα{l]
[l [n}9.564{]}κλαῖεν ὅ μιν ἑκάεργος ἀνήρπασε Φοῖβος Ἀπόλλων·{l]
[l [n}9.565{]}τῇ ὅ γε παρκατέλεκτο χόλον θυμαλγέα πέσσων{l]
[l [n}9.566{]}ἐξ ἀρέων μητρὸς κεχολωμένος, ἥ ῥα θεοῖσι{l]
[l [n}9.567{]}πόλλʼ ἀχέουσʼ ἠρᾶτο κασιγνήτοιο φόνοιο,{l]
[l [n}9.568{]}πολλὰ δὲ καὶ γαῖαν πολυφόρβην χερσὶν ἀλοία{l]
[l [n}9.569{]}κικλήσκουσʼ Ἀΐδην καὶ ἐπαινὴν Περσεφόνειαν{l]
[l [n}9.570{]}πρόχνυ καθεζομένη, δεύοντο δὲ δάκρυσι κόλποι,{l]
[l [n}9.571{]}παιδὶ δόμεν θάνατον· τῆς δʼ ἠεροφοῖτις Ἐρινὺς{l]
[l [n}9.572{]}ἔκλυεν ἐξ Ἐρέβεσφιν ἀμείλιχον ἦτορ ἔχουσα.{l]
[l [n}9.573{]}τῶν δὲ τάχʼ ἀμφὶ πύλας ὅμαδος καὶ δοῦπος ὀρώρει{l]
[l [n}9.574{]}πύργων βαλλομένων· τὸν δὲ λίσσοντο γέροντες{l]
[l [n}9.575{]}Αἰτωλῶν, πέμπον δὲ θεῶν ἱερῆας ἀρίστους,{l]
[l [n}9.576{]}ἐξελθεῖν καὶ ἀμῦναι ὑποσχόμενοι μέγα δῶρον·{l]
[l [n}9.577{]}ὁππόθι πιότατον πεδίον Καλυδῶνος ἐραννῆς,{l]
[l [n}9.578{]}ἔνθά μιν ἤνωγον τέμενος περικαλλὲς ἑλέσθαι{l]
[l [n}9.579{]}πεντηκοντόγυον, τὸ μὲν ἥμισυ οἰνοπέδοιο,{l]
[l [n}9.580{]}ἥμισυ δὲ ψιλὴν ἄροσιν πεδίοιο ταμέσθαι.{l]
[l [n}9.581{]}πολλὰ δέ μιν λιτάνευε γέρων ἱππηλάτα Οἰνεὺς{l]
[l [n}9.582{]}οὐδοῦ ἐπεμβεβαὼς ὑψηρεφέος θαλάμοιο{l]
[l [n}9.583{]}σείων κολλητὰς σανίδας γουνούμενος υἱόν·{l]
[l [n}9.584{]}πολλὰ δὲ τόν γε κασίγνηται καὶ πότνια μήτηρ{l]
[l [n}9.585{]}ἐλλίσσονθʼ· ὃ δὲ μᾶλλον ἀναίνετο· πολλὰ δʼ ἑταῖροι,{l]
[l [n}9.586{]}οἵ οἱ κεδνότατοι καὶ φίλτατοι ἦσαν ἁπάντων·{l]
[l [n}9.587{]}ἀλλʼ οὐδʼ ὧς τοῦ θυμὸν ἐνὶ στήθεσσιν ἔπειθον,{l]
[l [n}9.588{]}πρίν γʼ ὅτε δὴ θάλαμος πύκʼ ἐβάλλετο, τοὶ δʼ ἐπὶ πύργων{l]
[l [n}9.589{]}βαῖνον Κουρῆτες καὶ ἐνέπρηθον μέγα ἄστυ.{l]
[l [n}9.590{]}καὶ τότε δὴ Μελέαγρον ἐΰζωνος παράκοιτις{l]
[l [n}9.591{]}λίσσετʼ ὀδυρομένη, καί οἱ κατέλεξεν ἅπαντα{l]
[l [n}9.592{]}κήδεʼ, ὅσʼ ἀνθρώποισι πέλει τῶν ἄστυ ἁλώῃ·{l]
[l [n}9.593{]}ἄνδρας μὲν κτείνουσι, πόλιν δέ τε πῦρ ἀμαθύνει,{l]
[l [n}9.594{]}τέκνα δέ τʼ ἄλλοι ἄγουσι βαθυζώνους τε γυναῖκας.{l]
[l [n}9.595{]}τοῦ δʼ ὠρίνετο θυμὸς ἀκούοντος κακὰ ἔργα,{l]
[l [n}9.596{]}βῆ δʼ ἰέναι, χροῒ δʼ ἔντεʼ ἐδύσετο παμφανόωντα.{l]
[l [n}9.597{]}ὣς ὃ μὲν Αἰτωλοῖσιν ἀπήμυνεν κακὸν ἦμαρ{l]
[l [n}9.598{]}εἴξας ᾧ θυμῷ· τῷ δʼ οὐκέτι δῶρα τέλεσσαν{l]
[l [n}9.599{]}πολλά τε καὶ χαρίεντα, κακὸν δʼ ἤμυνε καὶ αὔτως.{l]
[l [n}9.600{]}ἀλλὰ σὺ μή μοι ταῦτα νόει φρεσί, μὴ δέ σε δαίμων{l]
[l [n}9.601{]}ἐνταῦθα τρέψειε φίλος· κάκιον δέ κεν εἴη{l]
[l [n}9.602{]}νηυσὶν καιομένῃσιν ἀμυνέμεν· ἀλλʼ ἐπὶ δώρων{l]
[l [n}9.603{]}ἔρχεο· ἶσον γάρ σε θεῷ τίσουσιν Ἀχαιοί.{l]
[l [n}9.604{]}εἰ δέ κʼ ἄτερ δώρων πόλεμον φθισήνορα δύῃς{l]
[l [n}9.605{]}οὐκέθʼ ὁμῶς τιμῆς ἔσεαι πόλεμόν περ ἀλαλκών.{l]{q]{para]
[para}[l [n}9.606{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}9.607{]}Φοῖνιξ ἄττα γεραιὲ διοτρεφὲς οὔ τί με ταύτης{l]
[l [n}9.608{]}χρεὼ τιμῆς· φρονέω δὲ τετιμῆσθαι Διὸς αἴσῃ,{l]
[l [n}9.609{]}ἥ μʼ ἕξει παρὰ νηυσὶ κορωνίσιν εἰς ὅ κʼ ἀϋτμὴ{l]
[l [n}9.610{]}ἐν στήθεσσι μένῃ καί μοι φίλα γούνατʼ ὀρώρῃ.{l]
[l [n}9.611{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσι·{l]
[l [n}9.612{]}μή μοι σύγχει θυμὸν ὀδυρόμενος καὶ ἀχεύων{l]
[l [n}9.613{]}Ἀτρεΐδῃ ἥρωϊ φέρων χάριν· οὐδέ τί σε χρὴ{l]
[l [n}9.614{]}τὸν φιλέειν, ἵνα μή μοι ἀπέχθηαι φιλέοντι.{l]
[l [n}9.615{]}καλόν τοι σὺν ἐμοὶ τὸν κήδειν ὅς κʼ ἐμὲ κήδῃ·{l]
[l [n}9.616{]}ἶσον ἐμοὶ βασίλευε καὶ ἥμισυ μείρεο τιμῆς.{l]
[l [n}9.617{]}οὗτοι δʼ ἀγγελέουσι, σὺ δʼ αὐτόθι λέξεο μίμνων{l]
[l [n}9.618{]}εὐνῇ ἔνι μαλακῇ· ἅμα δʼ ἠοῖ φαινομένηφι{l]
[l [n}9.619{]}φρασσόμεθʼ ἤ κε νεώμεθʼ ἐφʼ ἡμέτερʼ ἦ κε μένωμεν.{l]{q]{para]
[para}[l [n}9.620{]}ἦ καὶ Πατρόκλῳ ὅ γʼ ἐπʼ ὀφρύσι νεῦσε σιωπῇ{l]
[l [n}9.621{]}Φοίνικι στορέσαι πυκινὸν λέχος, ὄφρα τάχιστα{l]
[l [n}9.622{]}ἐκ κλισίης νόστοιο μεδοίατο· τοῖσι δʼ ἄρʼ Αἴας{l]
[l [n}9.623{]}ἀντίθεος Τελαμωνιάδης μετὰ μῦθον ἔειπε·{l]
[q}[l [n}9.624{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}9.625{]}ἴομεν· οὐ γάρ μοι δοκέει μύθοιο τελευτὴ{l]
[l [n}9.626{]}τῇδέ γʼ ὁδῷ κρανέεσθαι· ἀπαγγεῖλαι δὲ τάχιστα{l]
[l [n}9.627{]}χρὴ μῦθον Δαναοῖσι καὶ οὐκ ἀγαθόν περ ἐόντα{l]
[l [n}9.628{]}οἵ που νῦν ἕαται ποτιδέγμενοι. αὐτάρ Ἀχιλλεὺς{l]
[l [n}9.629{]}ἄγριον ἐν στήθεσσι θέτο μεγαλήτορα θυμὸν{l]
[l [n}9.630{]}σχέτλιος, οὐδὲ μετατρέπεται φιλότητος ἑταίρων{l]
[l [n}9.631{]}τῆς ᾗ μιν παρὰ νηυσὶν ἐτίομεν ἔξοχον ἄλλων{l]
[l [n}9.632{]}νηλής· καὶ μέν τίς τε κασιγνήτοιο φονῆος{l]
[l [n}9.633{]}ποινὴν ἢ οὗ παιδὸς ἐδέξατο τεθνηῶτος·{l]
[l [n}9.634{]}καί ῥʼ ὃ μὲν ἐν δήμῳ μένει αὐτοῦ πόλλʼ ἀποτίσας,{l]
[l [n}9.635{]}τοῦ δέ τʼ ἐρητύεται κραδίη καὶ θυμὸς ἀγήνωρ{l]
[l [n}9.636{]}ποινὴν δεξαμένῳ· σοὶ δʼ ἄληκτόν τε κακόν τε{l]
[l [n}9.637{]}θυμὸν ἐνὶ στήθεσσι θεοὶ θέσαν εἵνεκα κούρης{l]
[l [n}9.638{]}οἴης· νῦν δέ τοι ἑπτὰ παρίσχομεν ἔξοχʼ ἀρίστας,{l]
[l [n}9.639{]}ἄλλά τε πόλλʼ ἐπὶ τῇσι· σὺ δʼ ἵλαον ἔνθεο θυμόν,{l]
[l [n}9.640{]}αἴδεσσαι δὲ μέλαθρον· ὑπωρόφιοι δέ τοί εἰμεν{l]
[l [n}9.641{]}πληθύος ἐκ Δαναῶν, μέμαμεν δέ τοι ἔξοχον ἄλλων{l]
[l [n}9.642{]}κήδιστοί τʼ ἔμεναι καὶ φίλτατοι ὅσσοι Ἀχαιοί.{l]{q]{para]
[para}[l [n}9.643{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}9.644{]}Αἶαν διογενὲς Τελαμώνιε κοίρανε λαῶν{l]
[l [n}9.645{]}πάντά τί μοι κατὰ θυμὸν ἐείσαο μυθήσασθαι·{l]
[l [n}9.646{]}ἀλλά μοι οἰδάνεται κραδίη χόλῳ ὁππότε κείνων{l]
[l [n}9.647{]}μνήσομαι ὥς μʼ ἀσύφηλον ἐν Ἀργείοισιν ἔρεξεν{l]
[l [n}9.648{]}Ἀτρεΐδης ὡς εἴ τινʼ ἀτίμητον μετανάστην.{l]
[l [n}9.649{]}ἀλλʼ ὑμεῖς ἔρχεσθε καὶ ἀγγελίην ἀπόφασθε·{l]
[l [n}9.650{]}οὐ γὰρ πρὶν πολέμοιο μεδήσομαι αἱματόεντος{l]
[l [n}9.651{]}πρίν γʼ υἱὸν Πριάμοιο δαΐφρονος Ἕκτορα δῖον{l]
[l [n}9.652{]}Μυρμιδόνων ἐπί τε κλισίας καὶ νῆας ἱκέσθαι{l]
[l [n}9.653{]}κτείνοντʼ Ἀργείους, κατά τε σμῦξαι πυρὶ νῆας.{l]
[l [n}9.654{]}ἀμφὶ δέ τοι τῇ ἐμῇ κλισίῃ καὶ νηῒ μελαίνῃ{l]
[l [n}9.655{]}Ἕκτορα καὶ μεμαῶτα μάχης σχήσεσθαι ὀΐω.{l]{q]{para]
[para}[l [n}9.656{]}ὣς ἔφαθʼ, οἳ δὲ ἕκαστος ἑλὼν δέπας ἀμφικύπελλον{l]
[l [n}9.657{]}σπείσαντες παρὰ νῆας ἴσαν πάλιν· ἦρχε δʼ Ὀδυσσεύς.{l]
[l [n}9.658{]}Πάτροκλος δʼ ἑτάροισιν ἰδὲ δμωῇσι κέλευσε{l]
[l [n}9.659{]}Φοίνικι στορέσαι πυκινὸν λέχος ὅττι τάχιστα.{l]
[l [n}9.660{]}αἳ δʼ ἐπιπειθόμεναι στόρεσαν λέχος ὡς ἐκέλευσε{l]
[l [n}9.661{]}κώεά τε ῥῆγός τε λίνοιό τε λεπτὸν ἄωτον.{l]
[l [n}9.662{]}ἔνθʼ ὃ γέρων κατέλεκτο καὶ ἠῶ δῖαν ἔμιμνεν.{l]
[l [n}9.663{]}αὐτὰρ Ἀχιλλεὺς εὗδε μυχῷ κλισίης εὐπήκτου·{l]
[l [n}9.664{]}τῷ δʼ ἄρα παρκατέλεκτο γυνή, τὴν Λεσβόθεν ἦγε,{l]
[l [n}9.665{]}Φόρβαντος θυγάτηρ Διομήδη καλλιπάρῃος.{l]
[l [n}9.666{]}Πάτροκλος δʼ ἑτέρωθεν ἐλέξατο· πὰρ δʼ ἄρα καὶ τῷ{l]
[l [n}9.667{]}Ἶφις ἐΰζωνος, τήν οἱ πόρε δῖος Ἀχιλλεὺς{l]
[l [n}9.668{]}Σκῦρον ἑλὼν αἰπεῖαν Ἐνυῆος πτολίεθρον.{l]{para]
[para}[l [n}9.669{]}οἳ δʼ ὅτε δὴ κλισίῃσιν ἐν Ἀτρεΐδαο γένοντο.{l]
[l [n}9.670{]}τοὺς μὲν ἄρα χρυσέοισι κυπέλλοις υἷες Ἀχαιῶν{l]
[l [n}9.671{]}δειδέχατʼ ἄλλοθεν ἄλλος ἀνασταδόν, ἔκ τʼ ἐρέοντο·{l]
[l [n}9.672{]}πρῶτος δʼ ἐξερέεινεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}9.673{]}εἴπʼ ἄγε μʼ ὦ πολύαινʼ Ὀδυσεῦ μέγα κῦδος Ἀχαιῶν{l]
[l [n}9.674{]}ἤ ῥʼ ἐθέλει νήεσσιν ἀλεξέμεναι δήϊον πῦρ,{l]
[l [n}9.675{]}ἦ ἀπέειπε, χόλος δʼ ἔτʼ ἔχει μεγαλήτορα θυμόν;{l]{q]{para]
[para}[l [n}9.676{]}τὸν δʼ αὖτε προσέειπε πολύτλας δῖος Ὀδυσσεύς·{l]
[q}[l [n}9.677{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}9.678{]}κεῖνός γʼ οὐκ ἐθέλει σβέσσαι χόλον, ἀλλʼ ἔτι μᾶλλον{l]
[l [n}9.679{]}πιμπλάνεται μένεος, σὲ δʼ ἀναίνεται ἠδὲ σὰ δῶρα.{l]
[l [n}9.680{]}αὐτόν σε φράζεσθαι ἐν Ἀργείοισιν ἄνωγεν{l]
[l [n}9.681{]}ὅππως κεν νῆάς τε σαῷς καὶ λαὸν Ἀχαιῶν·{l]
[l [n}9.682{]}αὐτὸς δʼ ἠπείλησεν ἅμʼ ἠοῖ φαινομένηφι{l]
[l [n}9.683{]}νῆας ἐϋσσέλμους ἅλαδʼ ἑλκέμεν ἀμφιελίσσας.{l]
[l [n}9.684{]}καὶ δʼ ἂν τοῖς ἄλλοισιν ἔφη παραμυθήσασθαι{l]
[l [n}9.685{]}οἴκαδʼ ἀποπλείειν, ἐπεὶ οὐκέτι δήετε τέκμωρ{l]
[l [n}9.686{]}Ἰλίου αἰπεινῆς· μάλα γάρ ἑθεν εὐρύοπα Ζεὺς{l]
[l [n}9.687{]}χεῖρα ἑὴν ὑπερέσχε, τεθαρσήκασι δὲ λαοί.{l]
[l [n}9.688{]}ὣς ἔφατʼ· εἰσὶ καὶ οἵδε τάδʼ εἰπέμεν, οἵ μοι ἕποντο,{l]
[l [n}9.689{]}Αἴας καὶ κήρυκε δύω πεπνυμένω ἄμφω.{l]
[l [n}9.690{]}Φοῖνιξ δʼ αὖθʼ ὃ γέρων κατελέξατο, ὡς γὰρ ἀνώγει,{l]
[l [n}9.691{]}ὄφρά οἱ ἐν νήεσσι φίλην ἐς πατρίδʼ ἕπηται{l]
[l [n}9.692{]}αὔριον, ἢν ἐθέλῃσιν· ἀνάγκῃ δʼ οὔ τί μιν ἄξει.{l]{q]{para]
[para}[l [n}9.693{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ{l]
[l [n}9.694{]}μῦθον ἀγασσάμενοι· μάλα γὰρ κρατερῶς ἀγόρευσε.{l]
[l [n}9.695{]}δὴν δʼ ἄνεῳ ἦσαν τετιηότες υἷες Ἀχαιῶν·{l]
[l [n}9.696{]}ὀψὲ δὲ δὴ μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}9.697{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}9.698{]}μὴ ὄφελες λίσσεσθαι ἀμύμονα Πηλεΐωνα{l]
[l [n}9.699{]}μυρία δῶρα διδούς· ὃ δʼ ἀγήνωρ ἐστὶ καὶ ἄλλως·{l]
[l [n}9.700{]}νῦν αὖ μιν πολὺ μᾶλλον ἀγηνορίῃσιν ἐνῆκας.{l]
[l [n}9.701{]}ἀλλʼ ἤτοι κεῖνον μὲν ἐάσομεν ἤ κεν ἴῃσιν{l]
[l [n}9.702{]}ἦ κε μένῃ· τότε δʼ αὖτε μαχήσεται ὁππότε κέν μιν{l]
[l [n}9.703{]}θυμὸς ἐνὶ στήθεσσιν ἀνώγῃ καὶ θεὸς ὄρσῃ.{l]
[l [n}9.704{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}9.705{]}νῦν μὲν κοιμήσασθε τεταρπόμενοι φίλον ἦτορ{l]
[l [n}9.706{]}σίτου καὶ οἴνοιο· τὸ γὰρ μένος ἐστὶ καὶ ἀλκή·{l]
[l [n}9.707{]}αὐτὰρ ἐπεί κε φανῇ καλὴ ῥοδοδάκτυλος Ἠώς,{l]
[l [n}9.708{]}καρπαλίμως πρὸ νεῶν ἐχέμεν λαόν τε καὶ ἵππους{l]
[l [n}9.709{]}ὀτρύνων, καὶ δʼ αὐτὸς ἐνὶ πρώτοισι μάχεσθαι.{l]{q]{para]
[para}[l [n}9.710{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπῄνησαν βασιλῆες{l]
[l [n}9.711{]}μῦθον ἀγασσάμενοι Διομήδεος ἱπποδάμοιο.{l]
[l [n}9.712{]}καὶ τότε δὴ σπείσαντες ἔβαν κλισίην δὲ ἕκαστος,{l]
[l [n}9.713{]}ἔνθα δὲ κοιμήσαντο καὶ ὕπνου δῶρον ἕλοντο.{l]{para]
{book]
[book [n}10{]}
[para}[l [n}10.1{]}ἄλλοι μὲν παρὰ νηυσὶν ἀριστῆες Παναχαιῶν{l]
[l [n}10.2{]}εὗδον παννύχιοι μαλακῷ δεδμημένοι ὕπνῳ·{l]
[l [n}10.3{]}ἀλλʼ οὐκ Ἀτρεΐδην Ἀγαμέμνονα ποιμένα λαῶν{l]
[l [n}10.4{]}ὕπνος ἔχε γλυκερὸς πολλὰ φρεσὶν ὁρμαίνοντα.{l]
[l [n}10.5{]}ὡς δʼ ὅτʼ ἂν ἀστράπτῃ πόσις Ἥρης ἠϋκόμοιο{l]
[l [n}10.6{]}τεύχων ἢ πολὺν ὄμβρον ἀθέσφατον ἠὲ χάλαζαν{l]
[l [n}10.7{]}ἢ νιφετόν, ὅτε πέρ τε χιὼν ἐπάλυνεν ἀρούρας,{l]
[l [n}10.8{]}ἠέ ποθι πτολέμοιο μέγα στόμα πευκεδανοῖο,{l]
[l [n}10.9{]}ὣς πυκίνʼ ἐν στήθεσσιν ἀνεστενάχιζʼ Ἀγαμέμνων{l]
[l [n}10.10{]}νειόθεν ἐκ κραδίης, τρομέοντο δέ οἱ φρένες ἐντός.{l]
[l [n}10.11{]}ἤτοι ὅτʼ ἐς πεδίον τὸ Τρωϊκὸν ἀθρήσειε,{l]
[l [n}10.12{]}θαύμαζεν πυρὰ πολλὰ τὰ καίετο Ἰλιόθι πρὸ{l]
[l [n}10.13{]}αὐλῶν συρίγγων τʼ ἐνοπὴν ὅμαδόν τʼ ἀνθρώπων.{l]
[l [n}10.14{]}αὐτὰρ ὅτʼ ἐς νῆάς τε ἴδοι καὶ λαὸν Ἀχαιῶν,{l]
[l [n}10.15{]}πολλὰς ἐκ κεφαλῆς προθελύμνους ἕλκετο χαίτας{l]
[l [n}10.16{]}ὑψόθʼ ἐόντι Διί, μέγα δʼ ἔστενε κυδάλιμον κῆρ.{l]
[l [n}10.17{]}ἥδε δέ οἱ κατὰ θυμὸν ἀρίστη φαίνετο βουλὴ{l]
[l [n}10.18{]}Νέστορʼ ἔπι πρῶτον Νηλήϊον ἐλθέμεν ἀνδρῶν,{l]
[l [n}10.19{]}εἴ τινά οἱ σὺν μῆτιν ἀμύμονα τεκτήναιτο,{l]
[l [n}10.20{]}ἥ τις ἀλεξίκακος πᾶσιν Δαναοῖσι γένοιτο.{l]
[l [n}10.21{]}ὀρθωθεὶς δʼ ἔνδυνε περὶ στήθεσσι χιτῶνα,{l]
[l [n}10.22{]}ποσσὶ δʼ ὑπὸ λιπαροῖσιν ἐδήσατο καλὰ πέδιλα,{l]
[l [n}10.23{]}ἀμφὶ δʼ ἔπειτα δαφοινὸν ἑέσσατο δέρμα λέοντος{l]
[l [n}10.24{]}αἴθωνος μεγάλοιο ποδηνεκές, εἵλετο δʼ ἔγχος.{l]{para]
[para}[l [n}10.25{]}ὣς δʼ αὔτως Μενέλαον ἔχε τρόμος· οὐδὲ γὰρ αὐτῷ{l]
[l [n}10.26{]}ὕπνος ἐπὶ βλεφάροισιν ἐφίζανε· μή τι πάθοιεν{l]
[l [n}10.27{]}Ἀργεῖοι, τοὶ δὴ ἕθεν εἵνεκα πουλὺν ἐφʼ ὑγρὴν{l]
[l [n}10.28{]}ἤλυθον ἐς Τροίην πόλεμον θρασὺν ὁρμαίνοντες.{l]
[l [n}10.29{]}παρδαλέῃ μὲν πρῶτα μετάφρενον εὐρὺ κάλυψε{l]
[l [n}10.30{]}ποικίλῃ, αὐτὰρ ἐπὶ στεφάνην κεφαλῆφιν ἀείρας{l]
[l [n}10.31{]}θήκατο χαλκείην, δόρυ δʼ εἵλετο χειρὶ παχείῃ.{l]
[l [n}10.32{]}βῆ δʼ ἴμεν ἀνστήσων ὃν ἀδελφεόν, ὃς μέγα πάντων{l]
[l [n}10.33{]}Ἀργείων ἤνασσε, θεὸς δʼ ὣς τίετο δήμῳ.{l]
[l [n}10.34{]}τὸν δʼ εὗρʼ ἀμφʼ ὤμοισι τιθήμενον ἔντεα καλὰ{l]
[l [n}10.35{]}νηῒ πάρα πρύμνῃ· τῷ δʼ ἀσπάσιος γένετʼ ἐλθών.{l]
[l [n}10.36{]}τὸν πρότερος προσέειπε βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}10.37{]}τίφθʼ οὕτως ἠθεῖε κορύσσεαι; ἦ τινʼ ἑταίρων{l]
[l [n}10.38{]}ὀτρυνέεις Τρώεσσιν ἐπίσκοπον; ἀλλὰ μάλʼ αἰνῶς{l]
[l [n}10.39{]}δείδω μὴ οὔ τίς τοι ὑπόσχηται τόδε ἔργον{l]
[l [n}10.40{]}ἄνδρας δυσμενέας σκοπιαζέμεν οἶος ἐπελθὼν{l]
[l [n}10.41{]}νύκτα διʼ ἀμβροσίην· μάλα τις θρασυκάρδιος ἔσται.{l]{q]{para]
[para}[l [n}10.42{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}10.43{]}χρεὼ βουλῆς ἐμὲ καὶ σὲ διοτρεφὲς ὦ Μενέλαε{l]
[l [n}10.44{]}κερδαλέης, ἥ τίς κεν ἐρύσσεται ἠδὲ σαώσει{l]
[l [n}10.45{]}Ἀργείους καὶ νῆας, ἐπεὶ Διὸς ἐτράπετο φρήν.{l]
[l [n}10.46{]}Ἑκτορέοις ἄρα μᾶλλον ἐπὶ φρένα θῆχʼ ἱεροῖσιν·{l]
[l [n}10.47{]}οὐ γάρ πω ἰδόμην, οὐδʼ ἔκλυον αὐδήσαντος{l]
[l [n}10.48{]}ἄνδρʼ ἕνα τοσσάδε μέρμερʼ ἐπʼ ἤματι μητίσασθαι,{l]
[l [n}10.49{]}ὅσσʼ Ἕκτωρ ἔρρεξε Διῒ φίλος υἷας Ἀχαιῶν{l]
[l [n}10.50{]}αὔτως, οὔτε θεᾶς υἱὸς φίλος οὔτε θεοῖο.{l]
[l [n}10.51{]}ἔργα δʼ ἔρεξʼ ὅσα φημὶ μελησέμεν Ἀργείοισι{l]
[l [n}10.52{]}δηθά τε καὶ δολιχόν· τόσα γὰρ κακὰ μήσατʼ Ἀχαιούς.{l]
[l [n}10.53{]}ἀλλʼ ἴθι νῦν Αἴαντα καὶ Ἰδομενῆα κάλεσσον{l]
[l [n}10.54{]}ῥίμφα θέων παρὰ νῆας· ἐγὼ δʼ ἐπὶ Νέστορα δῖον{l]
[l [n}10.55{]}εἶμι, καὶ ὀτρυνέω ἀνστήμεναι, αἴ κʼ ἐθέλῃσιν{l]
[l [n}10.56{]}ἐλθεῖν ἐς φυλάκων ἱερὸν τέλος ἠδʼ ἐπιτεῖλαι.{l]
[l [n}10.57{]}κείνῳ γάρ κε μάλιστα πιθοίατο· τοῖο γὰρ υἱὸς{l]
[l [n}10.58{]}σημαίνει φυλάκεσσι καὶ Ἰδομενῆος ὀπάων{l]
[l [n}10.59{]}Μηριόνης· τοῖσιν γὰρ ἐπετράπομέν γε μάλιστα.{l]{q]{para]
[para}[l [n}10.60{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}10.61{]}πῶς γάρ μοι μύθῳ ἐπιτέλλεαι ἠδὲ κελεύεις;{l]
[l [n}10.62{]}αὖθι μένω μετὰ τοῖσι δεδεγμένος εἰς ὅ κεν ἔλθῃς,{l]
[l [n}10.63{]}ἦε θέω μετὰ σʼ αὖτις, ἐπὴν εὖ τοῖς ἐπιτείλω;{l]{q]{para]
[para}[l [n}10.64{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[q}[l [n}10.65{]}αὖθι μένειν, μή πως ἀβροτάξομεν ἀλλήλοιιν{l]
[l [n}10.66{]}ἐρχομένω· πολλαὶ γὰρ ἀνὰ στρατόν εἰσι κέλευθοι.{l]
[l [n}10.67{]}φθέγγεο δʼ ᾗ κεν ἴῃσθα καὶ ἐγρήγορθαι ἄνωχθι{l]
[l [n}10.68{]}πατρόθεν ἐκ γενεῆς ὀνομάζων ἄνδρα ἕκαστον{l]
[l [n}10.69{]}πάντας κυδαίνων· μηδὲ μεγαλίζεο θυμῷ,{l]
[l [n}10.70{]}ἀλλὰ καὶ αὐτοί περ πονεώμεθα· ὧδέ που ἄμμι{l]
[l [n}10.71{]}Ζεὺς ἐπὶ γιγνομένοισιν ἵει κακότητα βαρεῖαν.{l]{q]{para]
[para}[l [n}10.72{]}ὣς εἰπὼν ἀπέπεμπεν ἀδελφεὸν εὖ ἐπιτείλας·{l]
[l [n}10.73{]}αὐτὰρ ὃ βῆ ῥʼ ἰέναι μετὰ Νέστορα ποιμένα λαῶν·{l]
[l [n}10.74{]}τὸν δʼ εὗρεν παρά τε κλισίῃ καὶ νηῒ μελαίνῃ{l]
[l [n}10.75{]}εὐνῇ ἔνι μαλακῇ· παρὰ δʼ ἔντεα ποικίλʼ ἔκειτο{l]
[l [n}10.76{]}ἀσπὶς καὶ δύο δοῦρε φαεινή τε τρυφάλεια.{l]
[l [n}10.77{]}πὰρ δὲ ζωστὴρ κεῖτο παναίολος, ᾧ ῥʼ ὁ γεραιὸς{l]
[l [n}10.78{]}ζώννυθʼ ὅτʼ ἐς πόλεμον φθισήνορα θωρήσσοιτο{l]
[l [n}10.79{]}λαὸν ἄγων, ἐπεὶ οὐ μὲν ἐπέτρεπε γήραϊ λυγρῷ.{l]
[l [n}10.80{]}ὀρθωθεὶς δʼ ἄρʼ ἐπʼ ἀγκῶνος κεφαλὴν ἐπαείρας{l]
[l [n}10.81{]}Ἀτρεΐδην προσέειπε καὶ ἐξερεείνετο μύθῳ·{l]
[q}[l [n}10.82{]}τίς δʼ οὗτος κατὰ νῆας ἀνὰ στρατὸν ἔρχεαι οἶος{l]
[l [n}10.83{]}νύκτα διʼ ὀρφναίην, ὅτε θʼ εὕδουσι βροτοὶ ἄλλοι,{l]
[l [n}10.84{]}ἠέ τινʼ οὐρήων διζήμενος, ἤ τινʼ ἑταίρων;{l]
[l [n}10.85{]}φθέγγεο, μηδʼ ἀκέων ἐπʼ ἔμʼ ἔρχεο· τίπτε δέ σε χρεώ;{l]{q]{para]
[para}[l [n}10.86{]}τὸν δʼ ἠμείβετʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}10.87{]}ὦ Νέστορ Νηληϊάδη μέγα κῦδος Ἀχαιῶν{l]
[l [n}10.88{]}γνώσεαι Ἀτρεΐδην Ἀγαμέμνονα, τὸν περὶ πάντων{l]
[l [n}10.89{]}Ζεὺς ἐνέηκε πόνοισι διαμπερὲς εἰς ὅ κʼ ἀϋτμὴ{l]
[l [n}10.90{]}ἐν στήθεσσι μένῃ καί μοι φίλα γούνατʼ ὀρώρῃ.{l]
[l [n}10.91{]}πλάζομαι ὧδʼ ἐπεὶ οὔ μοι ἐπʼ ὄμμασι νήδυμος ὕπνος{l]
[l [n}10.92{]}ἱζάνει, ἀλλὰ μέλει πόλεμος καὶ κήδεʼ Ἀχαιῶν.{l]
[l [n}10.93{]}αἰνῶς γὰρ Δαναῶν περιδείδια, οὐδέ μοι ἦτορ{l]
[l [n}10.94{]}ἔμπεδον, ἀλλʼ ἀλαλύκτημαι, κραδίη δέ μοι ἔξω{l]
[l [n}10.95{]}στηθέων ἐκθρῴσκει, τρομέει δʼ ὑπὸ φαίδιμα γυῖα.{l]
[l [n}10.96{]}ἀλλʼ εἴ τι δραίνεις, ἐπεὶ οὐδὲ σέ γʼ ὕπνος ἱκάνει,{l]
[l [n}10.97{]}δεῦρʼ ἐς τοὺς φύλακας καταβήομεν, ὄφρα ἴδωμεν{l]
[l [n}10.98{]}μὴ τοὶ μὲν καμάτῳ ἀδηκότες ἠδὲ καὶ ὕπνῳ{l]
[l [n}10.99{]}κοιμήσωνται, ἀτὰρ φυλακῆς ἐπὶ πάγχυ λάθωνται.{l]
[l [n}10.100{]}δυσμενέες δʼ ἄνδρες σχεδὸν εἵαται· οὐδέ τι ἴδμεν{l]
[l [n}10.101{]}μή πως καὶ διὰ νύκτα μενοινήσωσι μάχεσθαι.{l]{q]{para]
[para}[l [n}10.102{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.103{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}10.104{]}οὔ θην Ἕκτορι πάντα νοήματα μητίετα Ζεὺς{l]
[l [n}10.105{]}ἐκτελέει, ὅσα πού νυν ἐέλπεται· ἀλλά μιν οἴω{l]
[l [n}10.106{]}κήδεσι μοχθήσειν καὶ πλείοσιν, εἴ κεν Ἀχιλλεὺς{l]
[l [n}10.107{]}ἐκ χόλου ἀργαλέοιο μεταστρέψῃ φίλον ἦτορ.{l]
[l [n}10.108{]}σοὶ δὲ μάλʼ ἕψομʼ ἐγώ· ποτὶ δʼ αὖ καὶ ἐγείρομεν ἄλλους{l]
[l [n}10.109{]}ἠμὲν Τυδεΐδην δουρὶ κλυτὸν ἠδʼ Ὀδυσῆα{l]
[l [n}10.110{]}ἠδʼ Αἴαντα ταχὺν καὶ Φυλέος ἄλκιμον υἱόν.{l]
[l [n}10.111{]}ἀλλʼ εἴ τις καὶ τούσδε μετοιχόμενος καλέσειεν{l]
[l [n}10.112{]}ἀντίθεόν τʼ Αἴαντα καὶ Ἰδομενῆα ἄνακτα·{l]
[l [n}10.113{]}τῶν γὰρ νῆες ἔασιν ἑκαστάτω, οὐδὲ μάλʼ ἐγγύς.{l]
[l [n}10.114{]}ἀλλὰ φίλον περ ἐόντα καὶ αἰδοῖον Μενέλαον{l]
[l [n}10.115{]}νεικέσω, εἴ πέρ μοι νεμεσήσεαι, οὐδʼ ἐπικεύσω{l]
[l [n}10.116{]}ὡς εὕδει, σοὶ δʼ οἴῳ ἐπέτρεψεν πονέεσθαι.{l]
[l [n}10.117{]}νῦν ὄφελεν κατὰ πάντας ἀριστῆας πονέεσθαι{l]
[l [n}10.118{]}λισσόμενος· χρειὼ γὰρ ἱκάνεται οὐκέτʼ ἀνεκτός.{l]{q]{para]
[para}[l [n}10.119{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}10.120{]}ὦ γέρον ἄλλοτε μέν σε καὶ αἰτιάασθαι ἄνωγα·{l]
[l [n}10.121{]}πολλάκι γὰρ μεθιεῖ τε καὶ οὐκ ἐθέλει πονέεσθαι{l]
[l [n}10.122{]}οὔτʼ ὄκνῳ εἴκων οὔτʼ ἀφραδίῃσι νόοιο,{l]
[l [n}10.123{]}ἀλλʼ ἐμέ τʼ εἰσορόων καὶ ἐμὴν ποτιδέγμενος ὁρμήν.{l]
[l [n}10.124{]}νῦν δʼ ἐμέο πρότερος μάλʼ ἐπέγρετο καί μοι ἐπέστη·{l]
[l [n}10.125{]}τὸν μὲν ἐγὼ προέηκα καλήμεναι οὓς σὺ μεταλλᾷς.{l]
[l [n}10.126{]}ἀλλʼ ἴομεν· κείνους δὲ κιχησόμεθα πρὸ πυλάων{l]
[l [n}10.127{]}ἐν φυλάκεσσʼ, ἵνα γάρ σφιν ἐπέφραδον ἠγερέθεσθαι.{l]{q]{para]
[para}[l [n}10.128{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.129{]}οὕτως οὔ τίς οἱ νεμεσήσεται οὐδʼ ἀπιθήσει{l]
[l [n}10.130{]}Ἀργείων, ὅτε κέν τινʼ ἐποτρύνῃ καὶ ἀνώγῃ.{l]{q]{para]
[para}[l [n}10.131{]}ὣς εἰπὼν ἔνδυνε περὶ στήθεσσι χιτῶνα,{l]
[l [n}10.132{]}ποσσὶ δʼ ὑπὸ λιπαροῖσιν ἐδήσατο καλὰ πέδιλα,{l]
[l [n}10.133{]}ἀμφὶ δʼ ἄρα χλαῖναν περονήσατο φοινικόεσσαν{l]
[l [n}10.134{]}διπλῆν ἐκταδίην, οὔλη δʼ ἐπενήνοθε λάχνη.{l]
[l [n}10.135{]}εἵλετο δʼ ἄλκιμον ἔγχος ἀκαχμένον ὀξέϊ χαλκῷ,{l]
[l [n}10.136{]}βῆ δʼ ἰέναι κατὰ νῆας Ἀχαιῶν χαλκοχιτώνων.{l]
[l [n}10.137{]}πρῶτον ἔπειτʼ Ὀδυσῆα Διὶ μῆτιν ἀτάλαντον{l]
[l [n}10.138{]}ἐξ ὕπνου ἀνέγειρε Γερήνιος ἱππότα Νέστωρ{l]
[l [n}10.139{]}φθεγξάμενος· τὸν δʼ αἶψα περὶ φρένας ἤλυθʼ ἰωή,{l]
[l [n}10.140{]}ἐκ δʼ ἦλθε κλισίης καί σφεας πρὸς μῦθον ἔειπε·{l]
[q}[l [n}10.141{]}τίφθʼ οὕτω κατὰ νῆας ἀνὰ στρατὸν οἶοι ἀλᾶσθε{l]
[l [n}10.142{]}νύκτα διʼ ἀμβροσίην, ὅ τι δὴ χρειὼ τόσον ἵκει;{l]{q]{para]
[para}[l [n}10.143{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.144{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}10.145{]}μὴ νεμέσα· τοῖον γὰρ ἄχος βεβίηκεν Ἀχαιούς.{l]
[l [n}10.146{]}ἀλλʼ ἕπεʼ, ὄφρα καὶ ἄλλον ἐγείρομεν ὅν τʼ ἐπέοικε{l]
[l [n}10.147{]}βουλὰς βουλεύειν, ἢ φευγέμεν ἠὲ μάχεσθαι.{l]{q]{para]
[para}[l [n}10.148{]}ὣς φάθʼ, ὃ δὲ κλισίην δὲ κιὼν πολύμητις Ὀδυσσεὺς{l]
[l [n}10.149{]}ποικίλον ἀμφʼ ὤμοισι σάκος θέτο, βῆ δὲ μετʼ αὐτούς.{l]
[l [n}10.150{]}βὰν δʼ ἐπὶ Τυδεΐδην Διομήδεα· τὸν δὲ κίχανον{l]
[l [n}10.151{]}ἐκτὸς ἀπὸ κλισίης σὺν τεύχεσιν· ἀμφὶ δʼ ἑταῖροι{l]
[l [n}10.152{]}εὗδον, ὑπὸ κρασὶν δʼ ἔχον ἀσπίδας· ἔγχεα δέ σφιν{l]
[l [n}10.153{]}ὄρθʼ ἐπὶ σαυρωτῆρος ἐλήλατο, τῆλε δὲ χαλκὸς{l]
[l [n}10.154{]}λάμφʼ ὥς τε στεροπὴ πατρὸς Διός· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}10.155{]}εὗδʼ, ὑπὸ δʼ ἔστρωτο ῥινὸν βοὸς ἀγραύλοιο,{l]
[l [n}10.156{]}αὐτὰρ ὑπὸ κράτεσφι τάπης τετάνυστο φαεινός.{l]
[l [n}10.157{]}τὸν παρστὰς ἀνέγειρε Γερήνιος ἱππότα Νέστωρ,{l]
[l [n}10.158{]}λὰξ ποδὶ κινήσας, ὄτρυνέ τε νείκεσέ τʼ ἄντην·{l]
[q}[l [n}10.159{]}ἔγρεο Τυδέος υἱέ· τί πάννυχον ὕπνον ἀωτεῖς;{l]
[l [n}10.160{]}οὐκ ἀΐεις ὡς Τρῶες ἐπὶ θρωσμῷ πεδίοιο{l]
[l [n}10.161{]}εἵαται ἄγχι νεῶν, ὀλίγος δʼ ἔτι χῶρος ἐρύκει;{l]{q]{para]
[para}[l [n}10.162{]}ὣς φάθʼ, ὃ δʼ ἐξ ὕπνοιο μάλα κραιπνῶς ἀνόρουσε,{l]
[l [n}10.163{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}10.164{]}σχέτλιός ἐσσι γεραιέ· σὺ μὲν πόνου οὔ ποτε λήγεις.{l]
[l [n}10.165{]}οὔ νυ καὶ ἄλλοι ἔασι νεώτεροι υἷες Ἀχαιῶν{l]
[l [n}10.166{]}οἵ κεν ἔπειτα ἕκαστον ἐγείρειαν βασιλήων{l]
[l [n}10.167{]}πάντῃ ἐποιχόμενοι; σὺ δʼ ἀμήχανός ἐσσι γεραιέ.{l]{q]{para]
[para}[l [n}10.168{]}τὸν δʼ αὖτε προσέειπε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.169{]}ναὶ δὴ ταῦτά γε πάντα φίλος κατὰ μοῖραν ἔειπες.{l]
[l [n}10.170{]}εἰσὶν μέν μοι παῖδες ἀμύμονες, εἰσὶ δὲ λαοὶ{l]
[l [n}10.171{]}καὶ πολέες, τῶν κέν τις ἐποιχόμενος καλέσειεν·{l]
[l [n}10.172{]}ἀλλὰ μάλα μεγάλη χρειὼ βεβίηκεν Ἀχαιούς.{l]
[l [n}10.173{]}νῦν γὰρ δὴ πάντεσσιν ἐπὶ ξυροῦ ἵσταται ἀκμῆς{l]
[l [n}10.174{]}ἢ μάλα λυγρὸς ὄλεθρος Ἀχαιοῖς ἠὲ βιῶναι.{l]
[l [n}10.175{]}ἀλλʼ ἴθι νῦν Αἴαντα ταχὺν καὶ Φυλέος υἱὸν{l]
[l [n}10.176{]}ἄνστησον· σὺ γάρ ἐσσι νεώτερος· εἴ μʼ ἐλεαίρεις.{l]{q]{para]
[para}[l [n}10.177{]}ὣς φάθʼ, ὃ δʼ ἀμφʼ ὤμοισιν ἑέσσατο δέρμα λέοντος{l]
[l [n}10.178{]}αἴθωνος μεγάλοιο ποδηνεκές, εἵλετο δʼ ἔγχος.{l]
[l [n}10.179{]}βῆ δʼ ἰέναι, τοὺς δʼ ἔνθεν ἀναστήσας ἄγεν ἥρως.{l]{para]
[para}[l [n}10.180{]}οἳ δʼ ὅτε δὴ φυλάκεσσιν ἐν ἀγρομένοισιν ἔμιχθεν,{l]
[l [n}10.181{]}οὐδὲ μὲν εὕδοντας φυλάκων ἡγήτορας εὗρον,{l]
[l [n}10.182{]}ἀλλʼ ἐγρηγορτὶ σὺν τεύχεσιν εἵατο πάντες.{l]
[l [n}10.183{]}ὡς δὲ κύνες περὶ μῆλα δυσωρήσωνται ἐν αὐλῇ{l]
[l [n}10.184{]}θηρὸς ἀκούσαντες κρατερόφρονος, ὅς τε καθʼ ὕλην{l]
[l [n}10.185{]}ἔρχηται διʼ ὄρεσφι· πολὺς δʼ ὀρυμαγδὸς ἐπʼ αὐτῷ{l]
[l [n}10.186{]}ἀνδρῶν ἠδὲ κυνῶν, ἀπό τέ σφισιν ὕπνος ὄλωλεν·{l]
[l [n}10.187{]}ὣς τῶν νήδυμος ὕπνος ἀπὸ βλεφάροιιν ὀλώλει{l]
[l [n}10.188{]}νύκτα φυλασσομένοισι κακήν· πεδίον δὲ γὰρ αἰεὶ{l]
[l [n}10.189{]}τετράφαθʼ, ὁππότʼ ἐπὶ Τρώων ἀΐοιεν ἰόντων.{l]
[l [n}10.190{]}τοὺς δʼ ὃ γέρων γήθησεν ἰδὼν θάρσυνέ τε μύθῳ{l]
[l [n}10.191{]}καί σφεας φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}10.192{]}οὕτω νῦν φίλα τέκνα φυλάσσετε· μηδέ τινʼ ὕπνος{l]
[l [n}10.193{]}αἱρείτω, μὴ χάρμα γενώμεθα δυσμενέεσσιν.{l]{q]{para]
[para}[l [n}10.194{]}ὣς εἰπὼν τάφροιο διέσσυτο· τοὶ δʼ ἅμʼ ἕποντο{l]
[l [n}10.195{]}Ἀργείων βασιλῆες ὅσοι κεκλήατο βουλήν.{l]
[l [n}10.196{]}τοῖς δʼ ἅμα Μηριόνης καὶ Νέστορος ἀγλαὸς υἱὸς{l]
[l [n}10.197{]}ἤϊσαν· αὐτοὶ γὰρ κάλεον συμμητιάασθαι.{l]
[l [n}10.198{]}τάφρον δʼ ἐκδιαβάντες ὀρυκτὴν ἑδριόωντο{l]
[l [n}10.199{]}ἐν καθαρῷ, ὅθι δὴ νεκύων διεφαίνετο χῶρος{l]
[l [n}10.200{]}πιπτόντων· ὅθεν αὖτις ἀπετράπετʼ ὄβριμος Ἕκτωρ{l]
[l [n}10.201{]}ὀλλὺς Ἀργείους, ὅτε δὴ περὶ νὺξ ἐκάλυψεν.{l]
[l [n}10.202{]}ἔνθα καθεζόμενοι ἔπεʼ ἀλλήλοισι πίφαυσκον·{l]
[l [n}10.203{]}τοῖσι δὲ μύθων ἦρχε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.204{]}ὦ φίλοι οὐκ ἂν δή τις ἀνὴρ πεπίθοιθʼ ἑῷ αὐτοῦ{l]
[l [n}10.205{]}θυμῷ τολμήεντι μετὰ Τρῶας μεγαθύμους{l]
[l [n}10.206{]}ἐλθεῖν, εἴ τινά που δηΐων ἕλοι ἐσχατόωντα,{l]
[l [n}10.207{]}ἤ τινά που καὶ φῆμιν ἐνὶ Τρώεσσι πύθοιτο,{l]
[l [n}10.208{]}ἅσσά τε μητιόωσι μετὰ σφίσιν, ἢ μεμάασιν{l]
[l [n}10.209{]}αὖθι μένειν παρὰ νηυσὶν ἀπόπροθεν, ἦε πόλιν δὲ{l]
[l [n}10.210{]}ἂψ ἀναχωρήσουσιν, ἐπεὶ δαμάσαντό γʼ Ἀχαιούς.{l]
[l [n}10.211{]}ταῦτά κε πάντα πύθοιτο, καὶ ἂψ εἰς ἡμέας ἔλθοι{l]
[l [n}10.212{]}ἀσκηθής· μέγα κέν οἱ ὑπουράνιον κλέος εἴη{l]
[l [n}10.213{]}πάντας ἐπʼ ἀνθρώπους, καί οἱ δόσις ἔσσεται ἐσθλή·{l]
[l [n}10.214{]}ὅσσοι γὰρ νήεσσιν ἐπικρατέουσιν ἄριστοι{l]
[l [n}10.215{]}τῶν πάντων οἱ ἕκαστος ὄϊν δώσουσι μέλαιναν{l]
[l [n}10.216{]}θῆλυν ὑπόρρηνον· τῇ μὲν κτέρας οὐδὲν ὁμοῖον,{l]
[l [n}10.217{]}αἰεὶ δʼ ἐν δαίτῃσι καὶ εἰλαπίνῃσι παρέσται.{l]{q]{para]
[para}[l [n}10.218{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ.{l]
[l [n}10.219{]}τοῖσι δὲ καὶ μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}10.220{]}Νέστορ ἔμʼ ὀτρύνει κραδίη καὶ θυμὸς ἀγήνωρ{l]
[l [n}10.221{]}ἀνδρῶν δυσμενέων δῦναι στρατὸν ἐγγὺς ἐόντων{l]
[l [n}10.222{]}Τρώων· ἀλλʼ εἴ τίς μοι ἀνὴρ ἅμʼ ἕποιτο καὶ ἄλλος{l]
[l [n}10.223{]}μᾶλλον θαλπωρὴ καὶ θαρσαλεώτερον ἔσται.{l]
[l [n}10.224{]}σύν τε δύʼ ἐρχομένω καί τε πρὸ ὃ τοῦ ἐνόησεν{l]
[l [n}10.225{]}ὅππως κέρδος ἔῃ· μοῦνος δʼ εἴ πέρ τε νοήσῃ{l]
[l [n}10.226{]}ἀλλά τέ οἱ βράσσων τε νόος, λεπτὴ δέ τε μῆτις.{l]{q]{para]
[para}[l [n}10.227{]}ὣς ἔφαθʼ, οἳ δʼ ἔθελον Διομήδεϊ πολλοὶ ἕπεσθαι.{l]
[l [n}10.228{]}ἠθελέτην Αἴαντε δύω θεράποντες Ἄρηος,{l]
[l [n}10.229{]}ἤθελε Μηριόνης, μάλα δʼ ἤθελε Νέστορος υἱός,{l]
[l [n}10.230{]}ἤθελε δʼ Ἀτρεΐδης δουρικλειτὸς Μενέλαος,{l]
[l [n}10.231{]}ἤθελε δʼ ὁ τλήμων Ὀδυσεὺς καταδῦναι ὅμιλον{l]
[l [n}10.232{]}Τρώων· αἰεὶ γάρ οἱ ἐνὶ φρεσὶ θυμὸς ἐτόλμα.{l]
[l [n}10.233{]}τοῖσι δὲ καὶ μετέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}10.234{]}Τυδεΐδη Διόμηδες ἐμῷ κεχαρισμένε θυμῷ{l]
[l [n}10.235{]}τὸν μὲν δὴ ἕταρόν γʼ αἱρήσεαι ὅν κʼ ἐθέλῃσθα,{l]
[l [n}10.236{]}φαινομένων τὸν ἄριστον, ἐπεὶ μεμάασί γε πολλοί.{l]
[l [n}10.237{]}μηδὲ σύ γʼ αἰδόμενος σῇσι φρεσὶ τὸν μὲν ἀρείω{l]
[l [n}10.238{]}καλλείπειν, σὺ δὲ χείρονʼ ὀπάσσεαι αἰδοῖ εἴκων{l]
[l [n}10.239{]}ἐς γενεὴν ὁρόων, μηδʼ εἰ βασιλεύτερός ἐστιν.{l]{q]{para]
[para}[l [n}10.240{]}ὣς ἔφατʼ, ἔδεισεν δὲ περὶ ξανθῷ Μενελάῳ.{l]
[l [n}10.241{]}τοῖς δʼ αὖτις μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}10.242{]}εἰ μὲν δὴ ἕταρόν γε κελεύετέ μʼ αὐτὸν ἑλέσθαι,{l]
[l [n}10.243{]}πῶς ἂν ἔπειτʼ Ὀδυσῆος ἐγὼ θείοιο λαθοίμην,{l]
[l [n}10.244{]}οὗ πέρι μὲν πρόφρων κραδίη καὶ θυμὸς ἀγήνωρ{l]
[l [n}10.245{]}ἐν πάντεσσι πόνοισι, φιλεῖ δέ ἑ Παλλὰς Ἀθήνη.{l]
[l [n}10.246{]}τούτου γʼ ἑσπομένοιο καὶ ἐκ πυρὸς αἰθομένοιο{l]
[l [n}10.247{]}ἄμφω νοστήσαιμεν, ἐπεὶ περίοιδε νοῆσαι.{l]{q]{para]
[para}[l [n}10.248{]}τὸν δʼ αὖτε προσέειπε πολύτλας δῖος Ὀδυσσεύς·{l]
[q}[l [n}10.249{]}Τυδεΐδη μήτʼ ἄρ με μάλʼ αἴνεε μήτέ τι νείκει·{l]
[l [n}10.250{]}εἰδόσι γάρ τοι ταῦτα μετʼ Ἀργείοις ἀγορεύεις.{l]
[l [n}10.251{]}ἀλλʼ ἴομεν· μάλα γὰρ νὺξ ἄνεται, ἐγγύθι δʼ ἠώς,{l]
[l [n}10.252{]}ἄστρα δὲ δὴ προβέβηκε, παροίχωκεν δὲ πλέων νὺξ{l]
[l [n}10.253{]}τῶν δύο μοιράων, τριτάτη δʼ ἔτι μοῖρα λέλειπται.{l]{q]{para]
[para}[l [n}10.254{]}ὣς εἰπόνθʼ ὅπλοισιν ἔνι δεινοῖσιν ἐδύτην.{l]
[l [n}10.255{]}Τυδεΐδῃ μὲν δῶκε μενεπτόλεμος Θρασυμήδης{l]
[l [n}10.256{]}φάσγανον ἄμφηκες· τὸ δʼ ἑὸν παρὰ νηῒ λέλειπτο·{l]
[l [n}10.257{]}καὶ σάκος· ἀμφὶ δέ οἱ κυνέην κεφαλῆφιν ἔθηκε{l]
[l [n}10.258{]}ταυρείην, ἄφαλόν τε καὶ ἄλλοφον, ἥ τε καταῖτυξ{l]
[l [n}10.259{]}κέκληται, ῥύεται δὲ κάρη θαλερῶν αἰζηῶν.{l]
[l [n}10.260{]}Μηριόνης δʼ Ὀδυσῆϊ δίδου βιὸν ἠδὲ φαρέτρην{l]
[l [n}10.261{]}καὶ ξίφος, ἀμφὶ δέ οἱ κυνέην κεφαλῆφιν ἔθηκε{l]
[l [n}10.262{]}ῥινοῦ ποιητήν· πολέσιν δʼ ἔντοσθεν ἱμᾶσιν{l]
[l [n}10.263{]}ἐντέτατο στερεῶς· ἔκτοσθε δὲ λευκοὶ ὀδόντες{l]
[l [n}10.264{]}ἀργιόδοντος ὑὸς θαμέες ἔχον ἔνθα καὶ ἔνθα{l]
[l [n}10.265{]}εὖ καὶ ἐπισταμένως· μέσσῃ δʼ ἐνὶ πῖλος ἀρήρει.{l]
[l [n}10.266{]}τήν ῥά ποτʼ ἐξ Ἐλεῶνος Ἀμύντορος Ὀρμενίδαο{l]
[l [n}10.267{]}ἐξέλετʼ Αὐτόλυκος πυκινὸν δόμον ἀντιτορήσας,{l]
[l [n}10.268{]}Σκάνδειαν δʼ ἄρα δῶκε Κυθηρίῳ Ἀμφιδάμαντι·{l]
[l [n}10.269{]}Ἀμφιδάμας δὲ Μόλῳ δῶκε ξεινήϊον εἶναι,{l]
[l [n}10.270{]}αὐτὰρ ὃ Μηριόνῃ δῶκεν ᾧ παιδὶ φορῆναι·{l]
[l [n}10.271{]}δὴ τότʼ Ὀδυσσῆος πύκασεν κάρη ἀμφιτεθεῖσα.{l]{para]
[para}[l [n}10.272{]}τὼ δʼ ἐπεὶ οὖν ὅπλοισιν ἔνι δεινοῖσιν ἐδύτην,{l]
[l [n}10.273{]}βάν ῥʼ ἰέναι, λιπέτην δὲ κατʼ αὐτόθι πάντας ἀρίστους.{l]
[l [n}10.274{]}τοῖσι δὲ δεξιὸν ἧκεν ἐρῳδιὸν ἐγγὺς ὁδοῖο{l]
[l [n}10.275{]}Παλλὰς Ἀθηναίη· τοὶ δʼ οὐκ ἴδον ὀφθαλμοῖσι{l]
[l [n}10.276{]}νύκτα διʼ ὀρφναίην, ἀλλὰ κλάγξαντος ἄκουσαν.{l]
[l [n}10.277{]}χαῖρε δὲ τῷ ὄρνιθʼ Ὀδυσεύς, ἠρᾶτο δʼ Ἀθήνῃ·{l]
[q}[l [n}10.278{]}κλῦθί μευ αἰγιόχοιο Διὸς τέκος, ἥ τέ μοι αἰεὶ{l]
[l [n}10.279{]}ἐν πάντεσσι πόνοισι παρίστασαι, οὐδέ σε λήθω{l]
[l [n}10.280{]}κινύμενος· νῦν αὖτε μάλιστά με φῖλαι Ἀθήνη,{l]
[l [n}10.281{]}δὸς δὲ πάλιν ἐπὶ νῆας ἐϋκλεῖας ἀφικέσθαι{l]
[l [n}10.282{]}ῥέξαντας μέγα ἔργον, ὅ κε Τρώεσσι μελήσῃ.{l]{q]{para]
[para}[l [n}10.283{]}δεύτερος αὖτʼ ἠρᾶτο βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}10.284{]}κέκλυθι νῦν καὶ ἐμεῖο Διὸς τέκος Ἀτρυτώνη·{l]
[l [n}10.285{]}σπεῖό μοι ὡς ὅτε πατρὶ ἅμʼ ἕσπεο Τυδέϊ δίῳ{l]
[l [n}10.286{]}ἐς Θήβας, ὅτε τε πρὸ Ἀχαιῶν ἄγγελος ᾔει.{l]
[l [n}10.287{]}τοὺς δʼ ἄρʼ ἐπʼ Ἀσωπῷ λίπε χαλκοχίτωνας Ἀχαιούς,{l]
[l [n}10.288{]}αὐτὰρ ὃ μειλίχιον μῦθον φέρε Καδμείοισι{l]
[l [n}10.289{]}κεῖσʼ· ἀτὰρ ἂψ ἀπιὼν μάλα μέρμερα μήσατο ἔργα{l]
[l [n}10.290{]}σὺν σοὶ δῖα θεά, ὅτε οἱ πρόφρασσα παρέστης.{l]
[l [n}10.291{]}ὣς νῦν μοι ἐθέλουσα παρίσταο καί με φύλασσε.{l]
[l [n}10.292{]}σοὶ δʼ αὖ ἐγὼ ῥέξω βοῦν ἦνιν εὐρυμέτωπον{l]
[l [n}10.293{]}ἀδμήτην, ἣν οὔ πω ὑπὸ ζυγὸν ἤγαγεν ἀνήρ·{l]
[l [n}10.294{]}τήν τοι ἐγὼ ῥέξω χρυσὸν κέρασιν περιχεύας.{l]{q]{para]
[para}[l [n}10.295{]}ὣς ἔφαν εὐχόμενοι, τῶν δʼ ἔκλυε Παλλὰς Ἀθήνη.{l]
[l [n}10.296{]}οἳ δʼ ἐπεὶ ἠρήσαντο Διὸς κούρῃ μεγάλοιο,{l]
[l [n}10.297{]}βάν ῥʼ ἴμεν ὥς τε λέοντε δύω διὰ νύκτα μέλαιναν{l]
[l [n}10.298{]}ἂμ φόνον, ἂν νέκυας, διά τʼ ἔντεα καὶ μέλαν αἷμα.{l]{para]
[para}[l [n}10.299{]}οὐδὲ μὲν οὐδὲ Τρῶας ἀγήνορας εἴασεν Ἕκτωρ{l]
[l [n}10.300{]}εὕδειν, ἀλλʼ ἄμυδις κικλήσκετο πάντας ἀρίστους,{l]
[l [n}10.301{]}ὅσσοι ἔσαν Τρώων ἡγήτορες ἠδὲ μέδοντες·{l]
[l [n}10.302{]}τοὺς ὅ γε συγκαλέσας πυκινὴν ἀρτύνετο βουλήν·{l]
[q}[l [n}10.303{]}τίς κέν μοι τόδε ἔργον ὑποσχόμενος τελέσειε{l]
[l [n}10.304{]}δώρῳ ἔπι μεγάλῳ; μισθὸς δέ οἱ ἄρκιος ἔσται.{l]
[l [n}10.305{]}δώσω γὰρ δίφρόν τε δύω τʼ ἐριαύχενας ἵππους{l]
[l [n}10.306{]}οἵ κεν ἄριστοι ἔωσι θοῇς ἐπὶ νηυσὶν Ἀχαιῶν{l]
[l [n}10.307{]}ὅς τίς κε τλαίη, οἷ τʼ αὐτῷ κῦδος ἄροιτο,{l]
[l [n}10.308{]}νηῶν ὠκυπόρων σχεδὸν ἐλθέμεν, ἔκ τε πυθέσθαι{l]
[l [n}10.309{]}ἠέ φυλάσσονται νῆες θοαὶ ὡς τὸ πάρος περ,{l]
[l [n}10.310{]}ἦ ἤδη χείρεσσιν ὑφʼ ἡμετέρῃσι δαμέντες{l]
[l [n}10.311{]}φύξιν βουλεύουσι μετὰ σφίσιν, οὐδʼ ἐθέλουσι{l]
[l [n}10.312{]}νύκτα φυλασσέμεναι, καμάτῳ ἀδηκότες αἰνῷ.{l]{q]{para]
[para}[l [n}10.313{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ.{l]
[l [n}10.314{]}ἦν δέ τις ἐν Τρώεσσι Δόλων Εὐμήδεος υἱὸς{l]
[l [n}10.315{]}κήρυκος θείοιο πολύχρυσος πολύχαλκος,{l]
[l [n}10.316{]}ὃς δή τοι εἶδος μὲν ἔην κακός, ἀλλὰ ποδώκης·{l]
[l [n}10.317{]}αὐτὰρ ὃ μοῦνος ἔην μετὰ πέντε κασιγνήτῃσιν.{l]
[l [n}10.318{]}ὅς ῥα τότε Τρωσίν τε καὶ Ἕκτορι μῦθον ἔειπεν·{l]
[q}[l [n}10.319{]}Ἕκτορ ἔμʼ ὀτρύνει κραδίη καὶ θυμὸς ἀγήνωρ{l]
[l [n}10.320{]}νηῶν ὠκυπόρων σχεδὸν ἐλθέμεν ἔκ τε πυθέσθαι.{l]
[l [n}10.321{]}ἀλλʼ ἄγε μοι τὸ σκῆπτρον ἀνάσχεο, καί μοι ὄμοσσον{l]
[l [n}10.322{]}ἦ μὲν τοὺς ἵππους τε καὶ ἅρματα ποικίλα χαλκῷ{l]
[l [n}10.323{]}δωσέμεν, οἳ φορέουσιν ἀμύμονα Πηλεΐωνα,{l]
[l [n}10.324{]}σοὶ δʼ ἐγὼ οὐχ ἅλιος σκοπὸς ἔσσομαι οὐδʼ ἀπὸ δόξης·{l]
[l [n}10.325{]}τόφρα γὰρ ἐς στρατὸν εἶμι διαμπερὲς ὄφρʼ ἂν ἵκωμαι{l]
[l [n}10.326{]}νῆʼ Ἀγαμεμνονέην, ὅθι που μέλλουσιν ἄριστοι{l]
[l [n}10.327{]}βουλὰς βουλεύειν ἢ φευγέμεν ἠὲ μάχεσθαι.{l]{q]{para]
[para}[l [n}10.328{]}ὣς φάθʼ, ὃ δʼ ἐν χερσὶ σκῆπτρον λάβε καί οἱ ὄμοσσεν·{l]
[q}[l [n}10.329{]}ἴστω νῦν Ζεὺς αὐτὸς ἐρίγδουπος πόσις Ἥρης{l]
[l [n}10.330{]}μὴ μὲν τοῖς ἵπποισιν ἀνὴρ ἐποχήσεται ἄλλος{l]
[l [n}10.331{]}Τρώων, ἀλλά σέ φημι διαμπερὲς ἀγλαϊεῖσθαι.{l]{q]{para]
[para}[l [n}10.332{]}ὣς φάτο καί ῥʼ ἐπίορκον ἐπώμοσε, τὸν δʼ ὀρόθυνεν·{l]
[l [n}10.333{]}αὐτίκα δʼ ἀμφʼ ὤμοισιν ἐβάλλετο καμπύλα τόξα,{l]
[l [n}10.334{]}ἕσσατο δʼ ἔκτοσθεν ῥινὸν πολιοῖο λύκοιο,{l]
[l [n}10.335{]}κρατὶ δʼ ἐπὶ κτιδέην κυνέην, ἕλε δʼ ὀξὺν ἄκοντα,{l]
[l [n}10.336{]}βῆ δʼ ἰέναι προτὶ νῆας ἀπὸ στρατοῦ· οὐδʼ ἄρʼ ἔμελλεν{l]
[l [n}10.337{]}ἐλθὼν ἐκ νηῶν ἂψ Ἕκτορι μῦθον ἀποίσειν.{l]
[l [n}10.338{]}ἀλλʼ ὅτε δή ῥʼ ἵππων τε καὶ ἀνδρῶν κάλλιφʼ ὅμιλον,{l]
[l [n}10.339{]}βῆ ῥʼ ἀνʼ ὁδὸν μεμαώς· τὸν δὲ φράσατο προσιόντα{l]
[l [n}10.340{]}διογενὴς Ὀδυσεύς, Διομήδεα δὲ προσέειπεν·{l]
[q}[l [n}10.341{]}οὗτός τις Διόμηδες ἀπὸ στρατοῦ ἔρχεται ἀνήρ,{l]
[l [n}10.342{]}οὐκ οἶδʼ ἢ νήεσσιν ἐπίσκοπος ἡμετέρῃσιν,{l]
[l [n}10.343{]}ἦ τινα συλήσων νεκύων κατατεθνηώτων.{l]
[l [n}10.344{]}ἀλλʼ ἐῶμέν μιν πρῶτα παρεξελθεῖν πεδίοιο{l]
[l [n}10.345{]}τυτθόν· ἔπειτα δέ κʼ αὐτὸν ἐπαΐξαντες ἕλοιμεν{l]
[l [n}10.346{]}καρπαλίμως· εἰ δʼ ἄμμε παραφθαίησι πόδεσσιν,{l]
[l [n}10.347{]}αἰεί μιν ἐπὶ νῆας ἀπὸ στρατόφι προτιειλεῖν{l]
[l [n}10.348{]}ἔγχει ἐπαΐσσων, μή πως προτὶ ἄστυ ἀλύξῃ.{l]{q]{para]
[para}[l [n}10.349{]}ὣς ἄρα φωνήσαντε παρὲξ ὁδοῦ ἐν νεκύεσσι{l]
[l [n}10.350{]}κλινθήτην· ὃ δʼ ἄρʼ ὦκα παρέδραμεν ἀφραδίῃσιν.{l]
[l [n}10.351{]}ἀλλʼ ὅτε δή ῥʼ ἀπέην ὅσσόν τʼ ἐπὶ οὖρα πέλονται{l]
[l [n}10.352{]}ἡμιόνων· αἱ γάρ τε βοῶν προφερέστεραί εἰσιν{l]
[l [n}10.353{]}ἑλκέμεναι νειοῖο βαθείης πηκτὸν ἄροτρον·{l]
[l [n}10.354{]}τὼ μὲν ἐπεδραμέτην, ὃ δʼ ἄρʼ ἔστη δοῦπον ἀκούσας.{l]
[l [n}10.355{]}ἔλπετο γὰρ κατὰ θυμὸν ἀποστρέψοντας ἑταίρους{l]
[l [n}10.356{]}ἐκ Τρώων ἰέναι πάλιν Ἕκτορος ὀτρύναντος.{l]
[l [n}10.357{]}ἀλλʼ ὅτε δή ῥʼ ἄπεσαν δουρηνεκὲς ἢ καὶ ἔλασσον,{l]
[l [n}10.358{]}γνῶ ῥʼ ἄνδρας δηΐους, λαιψηρὰ δὲ γούνατʼ ἐνώμα{l]
[l [n}10.359{]}φευγέμεναι· τοὶ δʼ αἶψα διώκειν ὁρμήθησαν.{l]
[l [n}10.360{]}ὡς δʼ ὅτε καρχαρόδοντε δύω κύνε εἰδότε θήρης{l]
[l [n}10.361{]}ἢ κεμάδʼ ἠὲ λαγωὸν ἐπείγετον ἐμμενὲς αἰεὶ{l]
[l [n}10.362{]}χῶρον ἀνʼ ὑλήενθʼ, ὃ δέ τε προθέῃσι μεμηκώς,{l]
[l [n}10.363{]}ὣς τὸν Τυδεΐδης ἠδʼ ὃ πτολίπορθος Ὀδυσσεὺς{l]
[l [n}10.364{]}λαοῦ ἀποτμήξαντε διώκετον ἐμμενὲς αἰεί.{l]
[l [n}10.365{]}ἀλλʼ ὅτε δὴ τάχʼ ἔμελλε μιγήσεσθαι φυλάκεσσι{l]
[l [n}10.366{]}φεύγων ἐς νῆας, τότε δὴ μένος ἔμβαλʼ Ἀθήνη{l]
[l [n}10.367{]}Τυδεΐδῃ, ἵνα μή τις Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}10.368{]}φθαίη ἐπευξάμενος βαλέειν, ὃ δὲ δεύτερος ἔλθοι.{l]
[l [n}10.369{]}δουρὶ δʼ ἐπαΐσσων προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}10.370{]}ἠὲ μένʼ ἠέ σε δουρὶ κιχήσομαι, οὐδέ σέ φημι{l]
[l [n}10.371{]}δηρὸν ἐμῆς ἀπὸ χειρὸς ἀλύξειν αἰπὺν ὄλεθρον.{l]{q]{para]
[para}[l [n}10.372{]}ἦ ῥα καὶ ἔγχος ἀφῆκεν, ἑκὼν δʼ ἡμάρτανε φωτός·{l]
[l [n}10.373{]}δεξιτερὸν δʼ ὑπὲρ ὦμον ἐΰξου δουρὸς ἀκωκὴ{l]
[l [n}10.374{]}ἐν γαίῃ ἐπάγη· ὃ δʼ ἄρʼ ἔστη τάρβησέν τε{l]
[l [n}10.375{]}βαμβαίνων· ἄραβος δὲ διὰ στόμα γίγνετʼ ὀδόντων·{l]
[l [n}10.376{]}χλωρὸς ὑπαὶ δείους· τὼ δʼ ἀσθμαίνοντε κιχήτην,{l]
[l [n}10.377{]}χειρῶν δʼ ἁψάσθην· ὃ δὲ δακρύσας ἔπος ηὔδα·{l]
[q}[l [n}10.378{]}ζωγρεῖτʼ, αὐτὰρ ἐγὼν ἐμὲ λύσομαι· ἔστι γὰρ ἔνδον{l]
[l [n}10.379{]}χαλκός τε χρυσός τε πολύκμητός τε σίδηρος,{l]
[l [n}10.380{]}τῶν κʼ ὔμμιν χαρίσαιτο πατὴρ ἀπερείσιʼ ἄποινα{l]
[l [n}10.381{]}εἴ κεν ἐμὲ ζωὸν πεπύθοιτʼ ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}10.382{]}τὸν δʼ ἀπαμειβόμενος προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}10.383{]}θάρσει, μηδέ τί τοι θάνατος καταθύμιος ἔστω.{l]
[l [n}10.384{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ καὶ ἀτρεκέως κατάλεξον·{l]
[l [n}10.385{]}πῇ δὴ οὕτως ἐπὶ νῆας ἀπὸ στρατοῦ ἔρχεαι οἶος{l]
[l [n}10.386{]}νύκτα διʼ ὀρφναίην, ὅτε θʼ εὕδουσι βροτοὶ ἄλλοι;{l]
[l [n}10.387{]}ἤ τινα συλήσων νεκύων κατατεθνηώτων;{l]
[l [n}10.388{]}ἦ σʼ Ἕκτωρ προέηκε διασκοπιᾶσθαι ἕκαστα{l]
[l [n}10.389{]}νῆας ἔπι γλαφυράς; ἦ σʼ αὐτὸν θυμὸς ἀνῆκε;{l]{q]{para]
[para}[l [n}10.390{]}τὸν δʼ ἠμείβετʼ ἔπειτα Δόλων, ὑπὸ δʼ ἔτρεμε γυῖα·{l]
[q}[l [n}10.391{]}πολλῇσίν μʼ ἄτῃσι παρὲκ νόον ἤγαγεν Ἕκτωρ,{l]
[l [n}10.392{]}ὅς μοι Πηλεΐωνος ἀγαυοῦ μώνυχας ἵππους{l]
[l [n}10.393{]}δωσέμεναι κατένευσε καὶ ἅρματα ποικίλα χαλκῷ,{l]
[l [n}10.394{]}ἠνώγει δέ μʼ ἰόντα θοὴν διὰ νύκτα μέλαιναν{l]
[l [n}10.395{]}ἀνδρῶν δυσμενέων σχεδὸν ἐλθέμεν, ἔκ τε πυθέσθαι{l]
[l [n}10.396{]}ἠὲ φυλάσσονται νῆες θοαὶ ὡς τὸ πάρος περ,{l]
[l [n}10.397{]}ἦ ἤδη χείρεσσιν ὑφʼ ἡμετέρῃσι δαμέντες{l]
[l [n}10.398{]}φύξιν βουλεύουσι μετὰ σφίσιν, οὐδʼ ἐθέλουσι{l]
[l [n}10.399{]}νύκτα φυλασσέμεναι, καμάτῳ ἀδηκότες αἰνῷ.{l]{q]{para]
[para}[l [n}10.400{]}τὸν δʼ ἐπιμειδήσας προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}10.401{]}ἦ ῥά νύ τοι μεγάλων δώρων ἐπεμαίετο θυμὸς{l]
[l [n}10.402{]}ἵππων Αἰακίδαο δαΐφρονος· οἳ δʼ ἀλεγεινοὶ{l]
[l [n}10.403{]}ἀνδράσι γε θνητοῖσι δαμήμεναι ἠδʼ ὀχέεσθαι{l]
[l [n}10.404{]}ἄλλῳ γʼ ἢ Ἀχιλῆϊ, τὸν ἀθανάτη τέκε μήτηρ.{l]
[l [n}10.405{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ καὶ ἀτρεκέως κατάλεξον·{l]
[l [n}10.406{]}ποῦ νῦν δεῦρο κιὼν λίπες Ἕκτορα ποιμένα λαῶν;{l]
[l [n}10.407{]}ποῦ δέ οἱ ἔντεα κεῖται ἀρήϊα, ποῦ δέ οἱ ἵπποι;{l]
[l [n}10.408{]}πῶς δαὶ τῶν ἄλλων Τρώων φυλακαί τε καὶ εὐναί;{l]
[l [n}10.409{]}ἅσσά τε μητιόωσι μετὰ σφίσιν, ἢ μεμάασιν{l]
[l [n}10.410{]}αὖθι μένειν παρὰ νηυσὶν ἀπόπροθεν, ἦε πόλιν δὲ{l]
[l [n}10.411{]}ἂψ ἀναχωρήσουσιν, ἐπεὶ δαμάσαντό γʼ Ἀχαιούς.{l]{q]{para]
[para}[l [n}10.412{]}τὸν δʼ αὖτε προσέειπε Δόλων Εὐμήδεος υἱός·{l]
[q}[l [n}10.413{]}τοὶ γὰρ ἐγώ τοι ταῦτα μάλʼ ἀτρεκέως καταλέξω.{l]
[l [n}10.414{]}Ἕκτωρ μὲν μετὰ τοῖσιν, ὅσοι βουληφόροι εἰσί,{l]
[l [n}10.415{]}βουλὰς βουλεύει θείου παρὰ σήματι Ἴλου{l]
[l [n}10.416{]}νόσφιν ἀπὸ φλοίσβου· φυλακὰς δʼ ἃς εἴρεαι ἥρως{l]
[l [n}10.417{]}οὔ τις κεκριμένη ῥύεται στρατὸν οὐδὲ φυλάσσει.{l]
[l [n}10.418{]}ὅσσαι μὲν Τρώων πυρὸς ἐσχάραι, οἷσιν ἀνάγκη{l]
[l [n}10.419{]}οἷ δʼ ἐγρηγόρθασι φυλασσέμεναί τε κέλονται{l]
[l [n}10.420{]}ἀλλήλοις· ἀτὰρ αὖτε πολύκλητοι ἐπίκουροι{l]
[l [n}10.421{]}εὕδουσι· Τρωσὶν γὰρ ἐπιτραπέουσι φυλάσσειν·{l]
[l [n}10.422{]}οὐ γάρ σφιν παῖδες σχεδὸν εἵαται οὐδὲ γυναῖκες.{l]
[para}[l [n}10.423{]}τὸν δʼ ἀπαμειβόμενος προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}10.424{]}πῶς γὰρ νῦν Τρώεσσι μεμιγμένοι ἱπποδάμοισιν{l]
[l [n}10.425{]}εὕδουσʼ ἦ ἀπάνευθε; δίειπέ μοι ὄφρα δαείω.{l]{q]{para]
[para}[l [n}10.426{]}τὸν δʼ ἠμείβετʼ ἔπειτα Δόλων Εὐμήδεος υἱός·{l]
[q}[l [n}10.427{]}τοὶ γὰρ ἐγὼ καὶ ταῦτα μάλʼ ἀτρεκέως καταλέξω.{l]
[l [n}10.428{]}πρὸς μὲν ἁλὸς Κᾶρες καὶ Παίονες ἀγκυλότοξοι{l]
[l [n}10.429{]}καὶ Λέλεγες καὶ Καύκωνες δῖοί τε Πελασγοί,{l]
[l [n}10.430{]}πρὸς Θύμβρης δʼ ἔλαχον Λύκιοι Μυσοί τʼ ἀγέρωχοι{l]
[l [n}10.431{]}καὶ Φρύγες ἱππόμαχοι καὶ Μῄονες ἱπποκορυσταί.{l]
[l [n}10.432{]}ἀλλὰ τί ἢ ἐμὲ ταῦτα διεξερέεσθε ἕκαστα;{l]
[l [n}10.433{]}εἰ γὰρ δὴ μέματον Τρώων καταδῦναι ὅμιλον{l]
[l [n}10.434{]}Θρήϊκες οἷδʼ ἀπάνευθε νεήλυδες ἔσχατοι ἄλλων·{l]
[l [n}10.435{]}ἐν δέ σφιν Ῥῆσος βασιλεὺς πάϊς Ἠϊονῆος.{l]
[l [n}10.436{]}τοῦ δὴ καλλίστους ἵππους ἴδον ἠδὲ μεγίστους·{l]
[l [n}10.437{]}λευκότεροι χιόνος, θείειν δʼ ἀνέμοισιν ὁμοῖοι·{l]
[l [n}10.438{]}ἅρμα δέ οἱ χρυσῷ τε καὶ ἀργύρῳ εὖ ἤσκηται·{l]
[l [n}10.439{]}τεύχεα δὲ χρύσεια πελώρια θαῦμα ἰδέσθαι{l]
[l [n}10.440{]}ἤλυθʼ ἔχων· τὰ μὲν οὔ τι καταθνητοῖσιν ἔοικεν{l]
[l [n}10.441{]}ἄνδρεσσιν φορέειν, ἀλλʼ ἀθανάτοισι θεοῖσιν.{l]
[l [n}10.442{]}ἀλλʼ ἐμὲ μὲν νῦν νηυσὶ πελάσσετον ὠκυπόροισιν,{l]
[l [n}10.443{]}ἠέ με δήσαντες λίπετʼ αὐτόθι νηλέϊ δεσμῷ,{l]
[l [n}10.444{]}ὄφρά κεν ἔλθητον καὶ πειρηθῆτον ἐμεῖο{l]
[l [n}10.445{]}ἠὲ κατʼ αἶσαν ἔειπον ἐν ὑμῖν, ἦε καὶ οὐκί.{l]{q]{para]
[para}[l [n}10.446{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}10.447{]}μὴ δή μοι φύξίν γε Δόλων ἐμβάλλεο θυμῷ·{l]
[l [n}10.448{]}ἐσθλά περ ἀγγείλας, ἐπεὶ ἵκεο χεῖρας ἐς ἁμάς.{l]
[l [n}10.449{]}εἰ μὲν γάρ κέ σε νῦν ἀπολύσομεν ἠὲ μεθῶμεν,{l]
[l [n}10.450{]}ἦ τε καὶ ὕστερον εἶσθα θοὰς ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}10.451{]}ἠὲ διοπτεύσων ἢ ἐναντίβιον πολεμίξων·{l]
[l [n}10.452{]}εἰ δέ κʼ ἐμῇς ὑπὸ χερσὶ δαμεὶς ἀπὸ θυμὸν ὀλέσσῃς,{l]
[l [n}10.453{]}οὐκέτʼ ἔπειτα σὺ πῆμά ποτʼ ἔσσεαι Ἀργείοισιν.{l]{q]{para]
[para}[l [n}10.454{]}ἦ, καὶ ὃ μέν μιν ἔμελλε γενείου χειρὶ παχείῃ{l]
[l [n}10.455{]}ἁψάμενος λίσσεσθαι, ὃ δʼ αὐχένα μέσσον ἔλασσε{l]
[l [n}10.456{]}φασγάνῳ ἀΐξας, ἀπὸ δʼ ἄμφω κέρσε τένοντε·{l]
[l [n}10.457{]}φθεγγομένου δʼ ἄρα τοῦ γε κάρη κονίῃσιν ἐμίχθη.{l]
[l [n}10.458{]}τοῦ δʼ ἀπὸ μὲν κτιδέην κυνέην κεφαλῆφιν ἕλοντο{l]
[l [n}10.459{]}καὶ λυκέην καὶ τόξα παλίντονα καὶ δόρυ μακρόν·{l]
[l [n}10.460{]}καὶ τά γʼ Ἀθηναίῃ ληΐτιδι δῖος Ὀδυσσεὺς{l]
[l [n}10.461{]}ὑψόσʼ ἀνέσχεθε χειρὶ καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}10.462{]}χαῖρε θεὰ τοῖσδεσσι· σὲ γὰρ πρώτην ἐν Ὀλύμπῳ{l]
[l [n}10.463{]}πάντων ἀθανάτων ἐπιδωσόμεθʼ· ἀλλὰ καὶ αὖτις{l]
[l [n}10.464{]}πέμψον ἐπὶ Θρῃκῶν ἀνδρῶν ἵππους τε καὶ εὐνάς.{l]{q]{para]
[para}[l [n}10.465{]}ὣς ἄρʼ ἐφώνησεν, καὶ ἀπὸ ἕθεν ὑψόσʼ ἀείρας{l]
[l [n}10.466{]}θῆκεν ἀνὰ μυρίκην· δέελον δʼ ἐπὶ σῆμά τʼ ἔθηκε{l]
[l [n}10.467{]}συμμάρψας δόνακας μυρίκης τʼ ἐριθηλέας ὄζους,{l]
[l [n}10.468{]}μὴ λάθοι αὖτις ἰόντε θοὴν διὰ νύκτα μέλαιναν.{l]
[l [n}10.469{]}τὼ δὲ βάτην προτέρω διά τʼ ἔντεα καὶ μέλαν αἷμα,{l]
[l [n}10.470{]}αἶψα δʼ ἐπὶ Θρῃκῶν ἀνδρῶν τέλος ἷξον ἰόντες.{l]
[l [n}10.471{]}οἳ δʼ εὗδον καμάτῳ ἀδηκότες, ἔντεα δέ σφιν{l]
[l [n}10.472{]}καλὰ παρʼ αὐτοῖσι χθονὶ κέκλιτο εὖ κατὰ κόσμον{l]
[l [n}10.473{]}τριστοιχί· παρὰ δέ σφιν ἑκάστῳ δίζυγες ἵπποι.{l]
[l [n}10.474{]}Ῥῆσος δʼ ἐν μέσῳ εὗδε, παρʼ αὐτῷ δʼ ὠκέες ἵπποι{l]
[l [n}10.475{]}ἐξ ἐπιδιφριάδος πυμάτης ἱμᾶσι δέδεντο.{l]
[l [n}10.476{]}τὸν δʼ Ὀδυσεὺς προπάροιθεν ἰδὼν Διομήδεϊ δεῖξεν·{l]
[l [n}10.477{]}οὗτός τοι Διόμηδες ἀνήρ, οὗτοι δέ τοι ἵπποι,{l]
[l [n}10.478{]}οὓς νῶϊν πίφαυσκε Δόλων ὃν ἐπέφνομεν ἡμεῖς.{l]
[l [n}10.479{]}ἀλλʼ ἄγε δὴ πρόφερε κρατερὸν μένος· οὐδέ τί σε χρὴ{l]
[l [n}10.480{]}ἑστάμεναι μέλεον σὺν τεύχεσιν, ἀλλὰ λύʼ ἵππους·{l]
[l [n}10.481{]}ἠὲ σύ γʼ ἄνδρας ἔναιρε, μελήσουσιν δʼ ἐμοὶ ἵπποι.{l]{q]{para]
[para}[l [n}10.482{]}ὣς φάτο, τῷ δʼ ἔμπνευσε μένος γλαυκῶπις Ἀθήνη,{l]
[l [n}10.483{]}κτεῖνε δʼ ἐπιστροφάδην· τῶν δὲ στόνος ὄρνυτʼ ἀεικὴς{l]
[l [n}10.484{]}ἄορι θεινομένων, ἐρυθαίνετο δʼ αἵματι γαῖα.{l]
[l [n}10.485{]}ὡς δὲ λέων μήλοισιν ἀσημάντοισιν ἐπελθὼν{l]
[l [n}10.486{]}αἴγεσιν ἢ ὀΐεσσι κακὰ φρονέων ἐνορούσῃ,{l]
[l [n}10.487{]}ὣς μὲν Θρήϊκας ἄνδρας ἐπῴχετο Τυδέος υἱὸς{l]
[l [n}10.488{]}ὄφρα δυώδεκʼ ἔπεφνεν· ἀτὰρ πολύμητις Ὀδυσσεὺς{l]
[l [n}10.489{]}ὅν τινα Τυδεΐδης ἄορι πλήξειε παραστὰς{l]
[l [n}10.490{]}τὸν δʼ Ὀδυσεὺς μετόπισθε λαβὼν ποδὸς ἐξερύσασκε,{l]
[l [n}10.491{]}τὰ φρονέων κατὰ θυμὸν ὅπως καλλίτριχες ἵπποι{l]
[l [n}10.492{]}ῥεῖα διέλθοιεν μηδὲ τρομεοίατο θυμῷ{l]
[l [n}10.493{]}νεκροῖς ἀμβαίνοντες· ἀήθεσσον γὰρ ἔτʼ αὐτῶν.{l]
[l [n}10.494{]}ἀλλʼ ὅτε δὴ βασιλῆα κιχήσατο Τυδέος υἱός,{l]
[l [n}10.495{]}τὸν τρισκαιδέκατον μελιηδέα θυμὸν ἀπηύρα{l]
[l [n}10.496{]}ἀσθμαίνοντα· κακὸν γὰρ ὄναρ κεφαλῆφιν ἐπέστη{l]
[l [n}10.497{]}τὴν νύκτʼ Οἰνεΐδαο πάϊς διὰ μῆτιν Ἀθήνης.{l]
[l [n}10.498{]}τόφρα δʼ ἄρʼ ὃ τλήμων Ὀδυσεὺς λύε μώνυχας ἵππους,{l]
[l [n}10.499{]}σὺν δʼ ἤειρεν ἱμᾶσι καὶ ἐξήλαυνεν ὁμίλου{l]
[l [n}10.500{]}τόξῳ ἐπιπλήσσων, ἐπεὶ οὐ μάστιγα φαεινὴν{l]
[l [n}10.501{]}ποικίλου ἐκ δίφροιο νοήσατο χερσὶν ἑλέσθαι·{l]
[l [n}10.502{]}ῥοίζησεν δʼ ἄρα πιφαύσκων Διομήδεϊ δίῳ.{l]{para]
[para}[l [n}10.503{]}αὐτὰρ ὃ μερμήριζε μένων ὅ τι κύντατον ἕρδοι,{l]
[l [n}10.504{]}ἢ ὅ γε δίφρον ἑλών, ὅθι ποικίλα τεύχεʼ ἔκειτο,{l]
[l [n}10.505{]}ῥυμοῦ ἐξερύοι ἢ ἐκφέροι ὑψόσʼ ἀείρας,{l]
[l [n}10.506{]}ἦ ἔτι τῶν πλεόνων Θρῃκῶν ἀπὸ θυμὸν ἕλοιτο.{l]
[l [n}10.507{]}εἷος ὃ ταῦθʼ ὥρμαινε κατὰ φρένα, τόφρα δʼ Ἀθήνη{l]
[l [n}10.508{]}ἐγγύθεν ἱσταμένη προσέφη Διομήδεα δῖον·{l]
[q}[l [n}10.509{]}νόστου δὴ μνῆσαι μεγαθύμου Τυδέος υἱὲ{l]
[l [n}10.510{]}νῆας ἔπι γλαφυράς, μὴ καὶ πεφοβημένος ἔλθῃς,{l]
[l [n}10.511{]}μή πού τις καὶ Τρῶας ἐγείρῃσιν θεὸς ἄλλος.{l]{q]{para]
[para}[l [n}10.512{]}ὣς φάθʼ, ὃ δὲ ξυνέηκε θεᾶς ὄπα φωνησάσης,{l]
[l [n}10.513{]}καρπαλίμως δʼ ἵππων ἐπεβήσετο· κόψε δʼ Ὀδυσσεὺς{l]
[l [n}10.514{]}τόξῳ· τοὶ δʼ ἐπέτοντο θοὰς ἐπὶ νῆας Ἀχαιῶν.{l]{para]
[para}[l [n}10.515{]}οὐδʼ ἀλαοσκοπιὴν εἶχʼ ἀργυρότοξος Ἀπόλλων{l]
[l [n}10.516{]}ὡς ἴδʼ Ἀθηναίην μετὰ Τυδέος υἱὸν ἕπουσαν·{l]
[l [n}10.517{]}τῇ κοτέων Τρώων κατεδύσετο πουλὺν ὅμιλον,{l]
[l [n}10.518{]}ὦρσεν δὲ Θρῃκῶν βουληφόρον Ἱπποκόωντα{l]
[l [n}10.519{]}Ῥήσου ἀνεψιὸν ἐσθλόν· ὃ δʼ ἐξ ὕπνου ἀνορούσας{l]
[l [n}10.520{]}ὡς ἴδε χῶρον ἐρῆμον, ὅθʼ ἕστασαν ὠκέες ἵπποι,{l]
[l [n}10.521{]}ἄνδράς τʼ ἀσπαίροντας ἐν ἀργαλέῃσι φονῇσιν,{l]
[l [n}10.522{]}ᾤμωξέν τʼ ἄρʼ ἔπειτα φίλον τʼ ὀνόμηνεν ἑταῖρον.{l]
[l [n}10.523{]}Τρώων δὲ κλαγγή τε καὶ ἄσπετος ὦρτο κυδοιμὸς{l]
[l [n}10.524{]}θυνόντων ἄμυδις· θηεῦντο δὲ μέρμερα ἔργα{l]
[l [n}10.525{]}ὅσσʼ ἄνδρες ῥέξαντες ἔβαν κοίλας ἐπὶ νῆας.{l]{para]
[para}[l [n}10.526{]}οἳ δʼ ὅτε δή ῥʼ ἵκανον ὅθι σκοπὸν Ἕκτορος ἔκταν,{l]
[l [n}10.527{]}ἔνθʼ Ὀδυσεὺς μὲν ἔρυξε Διῒ φίλος ὠκέας ἵππους,{l]
[l [n}10.528{]}Τυδεΐδης δὲ χαμᾶζε θορὼν ἔναρα βροτόεντα{l]
[l [n}10.529{]}ἐν χείρεσσʼ Ὀδυσῆϊ τίθει, ἐπεβήσετο δʼ ἵππων·{l]
[l [n}10.530{]}μάστιξεν δʼ ἵππους, τὼ δʼ οὐκ ἀέκοντε πετέσθην{l]
[l [n}10.531{]}νῆας ἔπι γλαφυράς· τῇ γὰρ φίλον ἔπλετο θυμῷ.{l]
[l [n}10.532{]}Νέστωρ δὲ πρῶτος κτύπον ἄϊε φώνησέν τε·{l]
[q}[l [n}10.533{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}10.534{]}ψεύσομαι, ἦ ἔτυμον ἐρέω; κέλεται δέ με θυμός.{l]
[l [n}10.535{]}ἵππων μʼ ὠκυπόδων ἀμφὶ κτύπος οὔατα βάλλει.{l]
[l [n}10.536{]}αἲ γὰρ δὴ Ὀδυσεύς τε καὶ ὃ κρατερὸς Διομήδης{l]
[l [n}10.537{]}ὧδʼ ἄφαρ ἐκ Τρώων ἐλασαίατο μώνυχας ἵππους·{l]
[l [n}10.538{]}ἀλλʼ αἰνῶς δείδοικα κατὰ φρένα μή τι πάθωσιν{l]
[l [n}10.539{]}Ἀργείων οἳ ἄριστοι ὑπὸ Τρώων ὀρυμαγδοῦ.{l]{q]{para]
[para}[l [n}10.540{]}οὔ πω πᾶν εἴρητο ἔπος ὅτʼ ἄρʼ ἤλυθον αὐτοί.{l]
[l [n}10.541{]}καί ῥʼ οἳ μὲν κατέβησαν ἐπὶ χθόνα, τοὶ δὲ χαρέντες{l]
[l [n}10.542{]}δεξιῇ ἠσπάζοντο ἔπεσσί τε μειλιχίοισι·{l]
[l [n}10.543{]}πρῶτος δʼ ἐξερέεινε Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}10.544{]}εἴπʼ ἄγε μʼ ὦ πολύαινʼ Ὀδυσεῦ μέγα κῦδος Ἀχαιῶν{l]
[l [n}10.545{]}ὅππως τοῦσδʼ ἵππους λάβετον καταδύντες ὅμιλον{l]
[l [n}10.546{]}Τρώων, ἦ τίς σφωε πόρεν θεὸς ἀντιβολήσας.{l]
[l [n}10.547{]}αἰνῶς ἀκτίνεσσιν ἐοικότες ἠελίοιο.{l]
[l [n}10.548{]}αἰεὶ μὲν Τρώεσσʼ ἐπιμίσγομαι, οὐδέ τί φημι{l]
[l [n}10.549{]}μιμνάζειν παρὰ νηυσὶ γέρων περ ἐὼν πολεμιστής·{l]
[l [n}10.550{]}ἀλλʼ οὔ πω τοίους ἵππους ἴδον οὐδὲ νόησα.{l]
[l [n}10.551{]}ἀλλά τινʼ ὔμμʼ ὀΐω δόμεναι θεὸν ἀντιάσαντα·{l]
[l [n}10.552{]}ἀμφοτέρω γὰρ σφῶϊ φιλεῖ νεφεληγερέτα Ζεὺς{l]
[l [n}10.553{]}κούρη τʼ αἰγιόχοιο Διὸς γλαυκῶπις Ἀθήνη.{l]{q]{para]
[para}[l [n}10.554{]}τὸν δʼ ἀπαμειβόμενος προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}10.555{]}ὦ Νέστορ Νηληϊάδη μέγα κῦδος Ἀχαιῶν{l]
[l [n}10.556{]}ῥεῖα θεός γʼ ἐθέλων καὶ ἀμείνονας ἠέ περ οἵδε{l]
[l [n}10.557{]}ἵππους δωρήσαιτʼ, ἐπεὶ ἢ πολὺ φέρτεροί εἰσιν.{l]
[l [n}10.558{]}ἵπποι δʼ οἵδε γεραιὲ νεήλυδες οὓς ἐρεείνεις{l]
[l [n}10.559{]}Θρηΐκιοι· τὸν δέ σφιν ἄνακτʼ ἀγαθὸς Διομήδης{l]
[l [n}10.560{]}ἔκτανε, πὰρ δʼ ἑτάρους δυοκαίδεκα πάντας ἀρίστους.{l]
[l [n}10.561{]}τὸν τρισκαιδέκατον σκοπὸν εἵλομεν ἐγγύθι νηῶν,{l]
[l [n}10.562{]}τόν ῥα διοπτῆρα στρατοῦ ἔμμεναι ἡμετέροιο{l]
[l [n}10.563{]}Ἕκτωρ τε προέηκε καὶ ἄλλοι Τρῶες ἀγαυοί.{l]{q]{para]
[para}[l [n}10.564{]}ὣς εἰπὼν τάφροιο διήλασε μώνυχας ἵππους{l]
[l [n}10.565{]}καγχαλόων· ἅμα δʼ ἄλλοι ἴσαν χαίροντες Ἀχαιοί.{l]
[l [n}10.566{]}οἳ δʼ ὅτε Τυδεΐδεω κλισίην εὔτυκτον ἵκοντο,{l]
[l [n}10.567{]}ἵππους μὲν κατέδησαν ἐϋτμήτοισιν ἱμᾶσι{l]
[l [n}10.568{]}φάτνῃ ἐφʼ ἱππείῃ, ὅθι περ Διομήδεος ἵπποι{l]
[l [n}10.569{]}ἕστασαν ὠκύποδες μελιηδέα πυρὸν ἔδοντες·{l]
[l [n}10.570{]}νηῒ δʼ ἐνὶ πρυμνῇ ἔναρα βροτόεντα Δόλωνος{l]
[l [n}10.571{]}θῆκʼ Ὀδυσεύς, ὄφρʼ ἱρὸν ἑτοιμασσαίατʼ Ἀθήνῃ.{l]
[l [n}10.572{]}αὐτοὶ δʼ ἱδρῶ πολλὸν ἀπενίζοντο θαλάσσῃ{l]
[l [n}10.573{]}ἐσβάντες κνήμας τε ἰδὲ λόφον ἀμφί τε μηρούς.{l]
[l [n}10.574{]}αὐτὰρ ἐπεί σφιν κῦμα θαλάσσης ἱδρῶ πολλὸν{l]
[l [n}10.575{]}νίψεν ἀπὸ χρωτὸς καὶ ἀνέψυχθεν φίλον ἦτορ,{l]
[l [n}10.576{]}ἔς ῥʼ ἀσαμίνθους βάντες ἐϋξέστας λούσαντο.{l]
[l [n}10.577{]}τὼ δὲ λοεσσαμένω καὶ ἀλειψαμένω λίπʼ ἐλαίῳ{l]
[l [n}10.578{]}δείπνῳ ἐφιζανέτην, ἀπὸ δὲ κρητῆρος Ἀθήνῃ{l]
[l [n}10.579{]}πλείου ἀφυσσόμενοι λεῖβον μελιηδέα οἶνον.{l]{para]
{book]
[book [n}11{]}
[para}[l [n}11.1{]}Ἠὼς δʼ ἐκ λεχέων παρʼ ἀγαυοῦ Τιθωνοῖο{l]
[l [n}11.2{]}ὄρνυθʼ, ἵνʼ ἀθανάτοισι φόως φέροι ἠδὲ βροτοῖσι·{l]
[l [n}11.3{]}Ζεὺς δʼ Ἔριδα προΐαλλε θοὰς ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}11.4{]}ἀργαλέην, πολέμοιο τέρας μετὰ χερσὶν ἔχουσαν.{l]
[l [n}11.5{]}στῆ δʼ ἐπʼ Ὀδυσσῆος μεγακήτεϊ νηῒ μελαίνῃ,{l]
[l [n}11.6{]}ἥ ῥʼ ἐν μεσσάτῳ ἔσκε γεγωνέμεν ἀμφοτέρωσε,{l]
[l [n}11.7{]}ἠμὲν ἐπʼ Αἴαντος κλισίας Τελαμωνιάδαο{l]
[l [n}11.8{]}ἠδʼ ἐπʼ Ἀχιλλῆος, τοί ῥʼ ἔσχατα νῆας ἐΐσας{l]
[l [n}11.9{]}εἴρυσαν ἠνορέῃ πίσυνοι καὶ κάρτεϊ χειρῶν{l]
[l [n}11.10{]}ἔνθα στᾶσʼ ἤϋσε θεὰ μέγα τε δεινόν τε{l]
[l [n}11.11{]}ὄρθιʼ, Ἀχαιοῖσιν δὲ μέγα σθένος ἔμβαλʼ ἑκάστῳ{l]
[l [n}11.12{]}καρδίῃ ἄληκτον πολεμίζειν ἠδὲ μάχεσθαι.{l]
[l [n}11.13{]}τοῖσι δʼ ἄφαρ πόλεμος γλυκίων γένετʼ ἠὲ νέεσθαι{l]
[l [n}11.14{]}ἐν νηυσὶ γλαφυρῇσι φίλην ἐς πατρίδα γαῖαν.{l]{para]
[para}[l [n}11.15{]}Ἀτρεΐδης δʼ ἐβόησεν ἰδὲ ζώννυσθαι ἄνωγεν{l]
[l [n}11.16{]}Ἀργείους· ἐν δʼ αὐτὸς ἐδύσετο νώροπα χαλκόν.{l]
[l [n}11.17{]}κνημῖδας μὲν πρῶτα περὶ κνήμῃσιν ἔθηκε{l]
[l [n}11.18{]}καλὰς ἀργυρέοισιν ἐπισφυρίοις ἀραρυίας·{l]
[l [n}11.19{]}δεύτερον αὖ θώρηκα περὶ στήθεσσιν ἔδυνε,{l]
[l [n}11.20{]}τόν ποτέ οἱ Κινύρης δῶκε ξεινήϊον εἶναι.{l]
[l [n}11.21{]}πεύθετο γὰρ Κύπρον δὲ μέγα κλέος οὕνεκʼ Ἀχαιοὶ{l]
[l [n}11.22{]}ἐς Τροίην νήεσσιν ἀναπλεύσεσθαι ἔμελλον·{l]
[l [n}11.23{]}τοὔνεκά οἱ τὸν δῶκε χαριζόμενος βασιλῆϊ.{l]
[l [n}11.24{]}τοῦ δʼ ἤτοι δέκα οἶμοι ἔσαν μέλανος κυάνοιο,{l]
[l [n}11.25{]}δώδεκα δὲ χρυσοῖο καὶ εἴκοσι κασσιτέροιο·{l]
[l [n}11.26{]}κυάνεοι δὲ δράκοντες ὀρωρέχατο προτὶ δειρὴν{l]
[l [n}11.27{]}τρεῖς ἑκάτερθʼ ἴρισσιν ἐοικότες, ἅς τε Κρονίων{l]
[l [n}11.28{]}ἐν νέφεϊ στήριξε, τέρας μερόπων ἀνθρώπων.{l]
[l [n}11.29{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος· ἐν δέ οἱ ἧλοι{l]
[l [n}11.30{]}χρύσειοι πάμφαινον, ἀτὰρ περὶ κουλεὸν ἦεν{l]
[l [n}11.31{]}ἀργύρεον χρυσέοισιν ἀορτήρεσσιν ἀρηρός.{l]
[l [n}11.32{]}ἂν δʼ ἕλετʼ ἀμφιβρότην πολυδαίδαλον ἀσπίδα θοῦριν{l]
[l [n}11.33{]}καλήν, ἣν πέρι μὲν κύκλοι δέκα χάλκεοι ἦσαν,{l]
[l [n}11.34{]}ἐν δέ οἱ ὀμφαλοὶ ἦσαν ἐείκοσι κασσιτέροιο{l]
[l [n}11.35{]}λευκοί, ἐν δὲ μέσοισιν ἔην μέλανος κυάνοιο.{l]
[l [n}11.36{]}τῇ δʼ ἐπὶ μὲν Γοργὼ βλοσυρῶπις ἐστεφάνωτο{l]
[l [n}11.37{]}δεινὸν δερκομένη, περὶ δὲ Δεῖμός τε Φόβος τε.{l]
[l [n}11.38{]}τῆς δʼ ἐξ ἀργύρεος τελαμὼν ἦν· αὐτὰρ ἐπʼ αὐτοῦ{l]
[l [n}11.39{]}κυάνεος ἐλέλικτο δράκων, κεφαλαὶ δέ οἱ ἦσαν{l]
[l [n}11.40{]}τρεῖς ἀμφιστρεφέες ἑνὸς αὐχένος ἐκπεφυυῖαι.{l]
[l [n}11.41{]}κρατὶ δʼ ἐπʼ ἀμφίφαλον κυνέην θέτο τετραφάληρον{l]
[l [n}11.42{]}ἵππουριν· δεινὸν δὲ λόφος καθύπερθεν ἔνευεν.{l]
[l [n}11.43{]}εἵλετο δʼ ἄλκιμα δοῦρε δύω κεκορυθμένα χαλκῷ{l]
[l [n}11.44{]}ὀξέα· τῆλε δὲ χαλκὸς ἀπʼ αὐτόφιν οὐρανὸν εἴσω{l]
[l [n}11.45{]}λάμπʼ· ἐπὶ δʼ ἐγδούπησαν Ἀθηναίη τε καὶ Ἥρη{l]
[l [n}11.46{]}τιμῶσαι βασιλῆα πολυχρύσοιο Μυκήνης.{l]{para]
[para}[l [n}11.47{]}ἡνιόχῳ μὲν ἔπειτα ἑῷ ἐπέτελλεν ἕκαστος{l]
[l [n}11.48{]}ἵππους εὖ κατὰ κόσμον ἐρυκέμεν αὖθʼ ἐπὶ τάφρῳ,{l]
[l [n}11.49{]}αὐτοὶ δὲ πρυλέες σὺν τεύχεσι θωρηχθέντες{l]
[l [n}11.50{]}ῥώοντʼ· ἄσβεστος δὲ βοὴ γένετʼ ἠῶθι πρό.{l]
[l [n}11.51{]}φθὰν δὲ μέγʼ ἱππήων ἐπὶ τάφρῳ κοσμηθέντες,{l]
[l [n}11.52{]}ἱππῆες δʼ ὀλίγον μετεκίαθον· ἐν δὲ κυδοιμὸν{l]
[l [n}11.53{]}ὦρσε κακὸν Κρονίδης, κατὰ δʼ ὑψόθεν ἧκεν ἐέρσας{l]
[l [n}11.54{]}αἵματι μυδαλέας ἐξ αἰθέρος, οὕνεκʼ ἔμελλε{l]
[l [n}11.55{]}πολλὰς ἰφθίμους κεφαλὰς Ἄϊδι προϊάψειν.{l]{para]
[para}[l [n}11.56{]}Τρῶες δʼ αὖθʼ ἑτέρωθεν ἐπὶ θρωσμῷ πεδίοιο{l]
[l [n}11.57{]}Ἕκτορά τʼ ἀμφὶ μέγαν καὶ ἀμύμονα Πουλυδάμαντα{l]
[l [n}11.58{]}Αἰνείαν θʼ, ὃς Τρωσὶ θεὸς ὣς τίετο δήμῳ,{l]
[l [n}11.59{]}τρεῖς τʼ Ἀντηνορίδας Πόλυβον καὶ Ἀγήνορα δῖον{l]
[l [n}11.60{]}ἠΐθεόν τʼ Ἀκάμαντʼ ἐπιείκελον ἀθανάτοισιν.{l]
[l [n}11.61{]}Ἕκτωρ δʼ ἐν πρώτοισι φέρʼ ἀσπίδα πάντοσʼ ἐΐσην,{l]
[l [n}11.62{]}οἷος δʼ ἐκ νεφέων ἀναφαίνεται οὔλιος ἀστὴρ{l]
[l [n}11.63{]}παμφαίνων, τοτὲ δʼ αὖτις ἔδυ νέφεα σκιόεντα,{l]
[l [n}11.64{]}ὣς Ἕκτωρ ὁτὲ μέν τε μετὰ πρώτοισι φάνεσκεν,{l]
[l [n}11.65{]}ἄλλοτε δʼ ἐν πυμάτοισι κελεύων· πᾶς δʼ ἄρα χαλκῷ{l]
[l [n}11.66{]}λάμφʼ ὥς τε στεροπὴ πατρὸς Διὸς αἰγιόχοιο.{l]{para]
[para}[l [n}11.67{]}οἳ δʼ, ὥς τʼ ἀμητῆρες ἐναντίοι ἀλλήλοισιν{l]
[l [n}11.68{]}ὄγμον ἐλαύνωσιν ἀνδρὸς μάκαρος κατʼ ἄρουραν{l]
[l [n}11.69{]}πυρῶν ἢ κριθῶν· τὰ δὲ δράγματα ταρφέα πίπτει·{l]
[l [n}11.70{]}ὣς Τρῶες καὶ Ἀχαιοὶ ἐπʼ ἀλλήλοισι θορόντες{l]
[l [n}11.71{]}δῄουν, οὐδʼ ἕτεροι μνώοντʼ ὀλοοῖο φόβοιο.{l]
[l [n}11.72{]}ἴσας δʼ ὑσμίνη κεφαλὰς ἔχεν, οἳ δὲ λύκοι ὣς{l]
[l [n}11.73{]}θῦνον· Ἔρις δʼ ἄρʼ ἔχαιρε πολύστονος εἰσορόωσα·{l]
[l [n}11.74{]}οἴη γάρ ῥα θεῶν παρετύγχανε μαρναμένοισιν,{l]
[l [n}11.75{]}οἳ δʼ ἄλλοι οὔ σφιν πάρεσαν θεοί, ἀλλὰ ἕκηλοι{l]
[l [n}11.76{]}σφοῖσιν ἐνὶ μεγάροισι καθήατο, ἧχι ἑκάστῳ{l]
[l [n}11.77{]}δώματα καλὰ τέτυκτο κατὰ πτύχας Οὐλύμποιο.{l]
[l [n}11.78{]}πάντες δʼ ᾐτιόωντο κελαινεφέα Κρονίωνα{l]
[l [n}11.79{]}οὕνεκʼ ἄρα Τρώεσσιν ἐβούλετο κῦδος ὀρέξαι.{l]
[l [n}11.80{]}τῶν μὲν ἄρʼ οὐκ ἀλέγιζε πατήρ· ὃ δὲ νόσφι λιασθεὶς{l]
[l [n}11.81{]}τῶν ἄλλων ἀπάνευθε καθέζετο κύδεϊ γαίων{l]
[l [n}11.82{]}εἰσορόων Τρώων τε πόλιν καὶ νῆας Ἀχαιῶν{l]
[l [n}11.83{]}χαλκοῦ τε στεροπήν, ὀλλύντάς τʼ ὀλλυμένους τε.{l]{para]
[para}[l [n}11.84{]}ὄφρα μὲν ἠὼς ἦν καὶ ἀέξετο ἱερὸν ἦμαρ,{l]
[l [n}11.85{]}τόφρα μάλʼ ἀμφοτέρων βέλεʼ ἥπτετο, πῖπτε δὲ λαός·{l]
[l [n}11.86{]}ἦμος δὲ δρυτόμος περ ἀνὴρ ὁπλίσσατο δεῖπνον{l]
[l [n}11.87{]}οὔρεος ἐν βήσσῃσιν, ἐπεί τʼ ἐκορέσσατο χεῖρας{l]
[l [n}11.88{]}τάμνων δένδρεα μακρά, ἅδος τέ μιν ἵκετο θυμόν,{l]
[l [n}11.89{]}σίτου τε γλυκεροῖο περὶ φρένας ἵμερος αἱρεῖ,{l]
[l [n}11.90{]}τῆμος σφῇ ἀρετῇ Δαναοὶ ῥήξαντο φάλαγγας{l]
[l [n}11.91{]}κεκλόμενοι ἑτάροισι κατὰ στίχας· ἐν δʼ Ἀγαμέμνων{l]
[l [n}11.92{]}πρῶτος ὄρουσʼ, ἕλε δʼ ἄνδρα Βιάνορα ποιμένα λαῶν{l]
[l [n}11.93{]}αὐτόν, ἔπειτα δʼ ἑταῖρον Ὀϊλῆα πλήξιππον.{l]
[l [n}11.94{]}ἤτοι ὅ γʼ ἐξ ἵππων κατεπάλμενος ἀντίος ἔστη·{l]
[l [n}11.95{]}τὸν δʼ ἰθὺς μεμαῶτα μετώπιον ὀξέϊ δουρὶ{l]
[l [n}11.96{]}νύξʼ, οὐδὲ στεφάνη δόρυ οἱ σχέθε χαλκοβάρεια,{l]
[l [n}11.97{]}ἀλλὰ διʼ αὐτῆς ἦλθε καὶ ὀστέου, ἐγκέφαλος δὲ{l]
[l [n}11.98{]}ἔνδον ἅπας πεπάλακτο· δάμασσε δέ μιν μεμαῶτα.{l]
[l [n}11.99{]}καὶ τοὺς μὲν λίπεν αὖθι ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}11.100{]}στήθεσι παμφαίνοντας, ἐπεὶ περίδυσε χιτῶνας·{l]
[l [n}11.101{]}αὐτὰρ ὃ βῆ Ἶσόν τε καὶ Ἄντιφον ἐξεναρίξων{l]
[l [n}11.102{]}υἷε δύω Πριάμοιο νόθον καὶ γνήσιον ἄμφω{l]
[l [n}11.103{]}εἰν ἑνὶ δίφρῳ ἐόντας· ὃ μὲν νόθος ἡνιόχευεν,{l]
[l [n}11.104{]}Ἄντιφος αὖ παρέβασκε περικλυτός· ὥ ποτʼ Ἀχιλλεὺς{l]
[l [n}11.105{]}Ἴδης ἐν κνημοῖσι δίδη μόσχοισι λύγοισι,{l]
[l [n}11.106{]}ποιμαίνοντʼ ἐπʼ ὄεσσι λαβών, καὶ ἔλυσεν ἀποίνων.{l]
[l [n}11.107{]}δὴ τότε γʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}11.108{]}τὸν μὲν ὑπὲρ μαζοῖο κατὰ στῆθος βάλε δουρί,{l]
[l [n}11.109{]}Ἄντιφον αὖ παρὰ οὖς ἔλασε ξίφει, ἐκ δʼ ἔβαλʼ ἵππων.{l]
[l [n}11.110{]}σπερχόμενος δʼ ἀπὸ τοῖιν ἐσύλα τεύχεα καλὰ{l]
[l [n}11.111{]}γιγνώσκων· καὶ γάρ σφε πάρος παρὰ νηυσὶ θοῇσιν{l]
[l [n}11.112{]}εἶδεν, ὅτʼ ἐξ Ἴδης ἄγαγεν πόδας ὠκὺς Ἀχιλλεύς.{l]
[l [n}11.113{]}ὡς δὲ λέων ἐλάφοιο ταχείης νήπια τέκνα{l]
[l [n}11.114{]}ῥηϊδίως συνέαξε λαβὼν κρατεροῖσιν ὀδοῦσιν{l]
[l [n}11.115{]}ἐλθὼν εἰς εὐνήν, ἁπαλόν τέ σφʼ ἦτορ ἀπηύρα·{l]
[l [n}11.116{]}ἣ δʼ εἴ πέρ τε τύχῃσι μάλα σχεδόν, οὐ δύναταί σφι{l]
[l [n}11.117{]}χραισμεῖν· αὐτὴν γάρ μιν ὑπὸ τρόμος αἰνὸς ἱκάνει·{l]
[l [n}11.118{]}καρπαλίμως δʼ ἤϊξε διὰ δρυμὰ πυκνὰ καὶ ὕλην{l]
[l [n}11.119{]}σπεύδουσʼ ἱδρώουσα κραταιοῦ θηρὸς ὑφʼ ὁρμῆς·{l]
[l [n}11.120{]}ὣς ἄρα τοῖς οὔ τις δύνατο χραισμῆσαι ὄλεθρον{l]
[l [n}11.121{]}Τρώων, ἀλλὰ καὶ αὐτοὶ ὑπʼ Ἀργείοισι φέβοντο.{l]{para]
[para}[l [n}11.122{]}αὐτὰρ ὃ Πείσανδρόν τε καὶ Ἱππόλοχον μενεχάρμην{l]
[l [n}11.123{]}υἱέας Ἀντιμάχοιο δαΐφρονος, ὅς ῥα μάλιστα{l]
[l [n}11.124{]}χρυσὸν Ἀλεξάνδροιο δεδεγμένος ἀγλαὰ δῶρα{l]
[l [n}11.125{]}οὐκ εἴασχʼ Ἑλένην δόμεναι ξανθῷ Μενελάῳ,{l]
[l [n}11.126{]}τοῦ περ δὴ δύο παῖδε λάβε κρείων Ἀγαμέμνων{l]
[l [n}11.127{]}εἰν ἑνὶ δίφρῳ ἐόντας, ὁμοῦ δʼ ἔχον ὠκέας ἵππους·{l]
[l [n}11.128{]}ἐκ γάρ σφεας χειρῶν φύγον ἡνία σιγαλόεντα,{l]
[l [n}11.129{]}τὼ δὲ κυκηθήτην· ὃ δʼ ἐναντίον ὦρτο λέων ὣς{l]
[l [n}11.130{]}Ἀτρεΐδης· τὼ δʼ αὖτʼ ἐκ δίφρου γουναζέσθην·{l]
[q}[l [n}11.131{]}ζώγρει Ἀτρέος υἱέ, σὺ δʼ ἄξια δέξαι ἄποινα·{l]
[l [n}11.132{]}πολλὰ δʼ ἐν Ἀντιμάχοιο δόμοις κειμήλια κεῖται{l]
[l [n}11.133{]}χαλκός τε χρυσός τε πολύκμητός τε σίδηρος,{l]
[l [n}11.134{]}τῶν κέν τοι χαρίσαιτο πατὴρ ἀπερείσιʼ ἄποινα,{l]
[l [n}11.135{]}εἰ νῶϊ ζωοὺς πεπύθοιτʼ ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}11.136{]}ὣς τώ γε κλαίοντε προσαυδήτην βασιλῆα{l]
[l [n}11.137{]}μειλιχίοις ἐπέεσσιν· ἀμείλικτον δʼ ὄπʼ ἄκουσαν·{l]
[q}[l [n}11.138{]}εἰ μὲν δὴ Ἀντιμάχοιο δαΐφρονος υἱέες ἐστόν,{l]
[l [n}11.139{]}ὅς ποτʼ ἐνὶ Τρώων ἀγορῇ Μενέλαον ἄνωγεν{l]
[l [n}11.140{]}ἀγγελίην ἐλθόντα σὺν ἀντιθέῳ Ὀδυσῆϊ{l]
[l [n}11.141{]}αὖθι κατακτεῖναι μηδʼ ἐξέμεν ἂψ ἐς Ἀχαιούς,{l]
[l [n}11.142{]}νῦν μὲν δὴ τοῦ πατρὸς ἀεικέα τίσετε λώβην.{l]{q]{para]
[para}[l [n}11.143{]}ἦ, καὶ Πείσανδρον μὲν ἀφʼ ἵππων ὦσε χαμᾶζε{l]
[l [n}11.144{]}δουρὶ βαλὼν πρὸς στῆθος· ὃ δʼ ὕπτιος οὔδει ἐρείσθη.{l]
[l [n}11.145{]}Ἱππόλοχος δʼ ἀπόρουσε, τὸν αὖ χαμαὶ ἐξενάριξε{l]
[l [n}11.146{]}χεῖρας ἀπὸ ξίφεϊ τμήξας ἀπό τʼ αὐχένα κόψας,{l]
[l [n}11.147{]}ὅλμον δʼ ὣς ἔσσευε κυλίνδεσθαι διʼ ὁμίλου.{l]
[l [n}11.148{]}τοὺς μὲν ἔασʼ· ὃ δʼ ὅθι πλεῖσται κλονέοντο φάλαγγες,{l]
[l [n}11.149{]}τῇ ῥʼ ἐνόρουσʼ, ἅμα δʼ ἄλλοι ἐϋκνήμιδες Ἀχαιοί.{l]
[l [n}11.150{]}πεζοὶ μὲν πεζοὺς ὄλεκον φεύγοντας ἀνάγκῃ,{l]
[l [n}11.151{]}ἱππεῖς δʼ ἱππῆας· ὑπὸ δέ σφισιν ὦρτο κονίη{l]
[l [n}11.152{]}ἐκ πεδίου, τὴν ὦρσαν ἐρίγδουποι πόδες ἵππων{l]
[l [n}11.153{]}χαλκῷ δηϊόωντες· ἀτὰρ κρείων Ἀγαμέμνων{l]
[l [n}11.154{]}αἰὲν ἀποκτείνων ἕπετʼ Ἀργείοισι κελεύων.{l]
[l [n}11.155{]}ὡς δʼ ὅτε πῦρ ἀΐδηλον ἐν ἀξύλῳ ἐμπέσῃ ὕλῃ,{l]
[l [n}11.156{]}πάντῃ τʼ εἰλυφόων ἄνεμος φέρει, οἳ δέ τε θάμνοι{l]
[l [n}11.157{]}πρόρριζοι πίπτουσιν ἐπειγόμενοι πυρὸς ὁρμῇ·{l]
[l [n}11.158{]}ὣς ἄρʼ ὑπʼ Ἀτρεΐδῃ Ἀγαμέμνονι πῖπτε κάρηνα{l]
[l [n}11.159{]}Τρώων φευγόντων, πολλοὶ δʼ ἐριαύχενες ἵπποι{l]
[l [n}11.160{]}κείνʼ ὄχεα κροτάλιζον ἀνὰ πτολέμοιο γεφύρας{l]
[l [n}11.161{]}ἡνιόχους ποθέοντες ἀμύμονας· οἳ δʼ ἐπὶ γαίῃ{l]
[l [n}11.162{]}κείατο, γύπεσσιν πολὺ φίλτεροι ἢ ἀλόχοισιν.{l]{para]
[para}[l [n}11.163{]}Ἕκτορα δʼ ἐκ βελέων ὕπαγε Ζεὺς ἔκ τε κονίης{l]
[l [n}11.164{]}ἔκ τʼ ἀνδροκτασίης ἔκ θʼ αἵματος ἔκ τε κυδοιμοῦ·{l]
[l [n}11.165{]}Ἀτρεΐδης δʼ ἕπετο σφεδανὸν Δαναοῖσι κελεύων.{l]
[l [n}11.166{]}οἳ δὲ παρʼ Ἴλου σῆμα παλαιοῦ Δαρδανίδαο{l]
[l [n}11.167{]}μέσσον κὰπ πεδίον παρʼ ἐρινεὸν ἐσσεύοντο{l]
[l [n}11.168{]}ἱέμενοι πόλιος· ὃ δὲ κεκλήγων ἕπετʼ αἰεὶ{l]
[l [n}11.169{]}Ἀτρεΐδης, λύθρῳ δὲ παλάσσετο χεῖρας ἀάπτους.{l]
[l [n}11.170{]}ἀλλʼ ὅτε δὴ Σκαιάς τε πύλας καὶ φηγὸν ἵκοντο,{l]
[l [n}11.171{]}ἔνθʼ ἄρα δὴ ἵσταντο καὶ ἀλλήλους ἀνέμιμνον.{l]
[l [n}11.172{]}οἳ δʼ ἔτι κὰμ μέσσον πεδίον φοβέοντο βόες ὥς,{l]
[l [n}11.173{]}ἅς τε λέων ἐφόβησε μολὼν ἐν νυκτὸς ἀμολγῷ{l]
[l [n}11.174{]}πάσας· τῇ δέ τʼ ἰῇ ἀναφαίνεται αἰπὺς ὄλεθρος·{l]
[l [n}11.175{]}τῆς δʼ ἐξ αὐχένʼ ἔαξε λαβὼν κρατεροῖσιν ὀδοῦσι{l]
[l [n}11.176{]}πρῶτον, ἔπειτα δέ θʼ αἷμα καὶ ἔγκατα πάντα λαφύσσει·{l]
[l [n}11.177{]}ὣς τοὺς Ἀτρεΐδης ἔφεπε κρείων Ἀγαμέμνων{l]
[l [n}11.178{]}αἰὲν ἀποκτείνων τὸν ὀπίστατον· οἳ δʼ ἐφέβοντο.{l]
[l [n}11.179{]}πολλοὶ δὲ πρηνεῖς τε καὶ ὕπτιοι ἔκπεσον ἵππων{l]
[l [n}11.180{]}Ἀτρεΐδεω ὑπὸ χερσί· περὶ πρὸ γὰρ ἔγχεϊ θῦεν.{l]
[l [n}11.181{]}ἀλλʼ ὅτε δὴ τάχʼ ἔμελλεν ὑπὸ πτόλιν αἰπύ τε τεῖχος{l]
[l [n}11.182{]}ἵξεσθαι, τότε δή ῥα πατὴρ ἀνδρῶν τε θεῶν τε{l]
[l [n}11.183{]}Ἴδης ἐν κορυφῇσι καθέζετο πιδηέσσης{l]
[l [n}11.184{]}οὐρανόθεν καταβάς· ἔχε δʼ ἀστεροπὴν μετὰ χερσίν.{l]
[l [n}11.185{]}Ἶριν δʼ ὄτρυνε χρυσόπτερον ἀγγελέουσαν·{l]
[q}[l [n}11.186{]}βάσκʼ ἴθι Ἶρι ταχεῖα, τὸν Ἕκτορι μῦθον ἐνίσπες·{l]
[l [n}11.187{]}ὄφρʼ ἂν μέν κεν ὁρᾷ Ἀγαμέμνονα ποιμένα λαῶν{l]
[l [n}11.188{]}θύνοντʼ ἐν προμάχοισιν ἐναίροντα στίχας ἀνδρῶν,{l]
[l [n}11.189{]}τόφρʼ ἀναχωρείτω, τὸν δʼ ἄλλον λαὸν ἀνώχθω{l]
[l [n}11.190{]}μάρνασθαι δηΐοισι κατὰ κρατερὴν ὑσμίνην.{l]
[l [n}11.191{]}αὐτὰρ ἐπεί κʼ ἢ δουρὶ τυπεὶς ἢ βλήμενος ἰῷ{l]
[l [n}11.192{]}εἰς ἵππους ἅλεται, τότε οἱ κράτος ἐγγυαλίξω{l]
[l [n}11.193{]}κτείνειν εἰς ὅ κε νῆας ἐϋσσέλμους ἀφίκηται{l]
[l [n}11.194{]}δύῃ τʼ ἠέλιος καὶ ἐπὶ κνέφας ἱερὸν ἔλθῃ.{l]{q]{para]
[para}[l [n}11.195{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε ποδήνεμος ὠκέα Ἶρις,{l]
[l [n}11.196{]}βῆ δὲ κατʼ Ἰδαίων ὀρέων εἰς Ἴλιον ἱρήν.{l]
[l [n}11.197{]}εὗρʼ υἱὸν Πριάμοιο δαΐφρονος Ἕκτορα δῖον{l]
[l [n}11.198{]}ἑσταότʼ ἔν θʼ ἵπποισι καὶ ἅρμασι κολλητοῖσιν·{l]
[l [n}11.199{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}11.200{]}Ἕκτορ υἱὲ Πριάμοιο Διὶ μῆτιν ἀτάλαντε{l]
[l [n}11.201{]}Ζεύς με πατὴρ προέηκε τεῒν τάδε μυθήσασθαι.{l]
[l [n}11.202{]}ὄφρʼ ἂν μέν κεν ὁρᾷς Ἀγαμέμνονα ποιμένα λαῶν{l]
[l [n}11.203{]}θύνοντʼ ἐν προμάχοισιν, ἐναίροντα στίχας ἀνδρῶν,{l]
[l [n}11.204{]}τόφρʼ ὑπόεικε μάχης, τὸν δʼ ἄλλον λαὸν ἄνωχθι{l]
[l [n}11.205{]}μάρνασθαι δηΐοισι κατὰ κρατερὴν ὑσμίνην.{l]
[l [n}11.206{]}αὐτὰρ ἐπεί κʼ ἢ δουρὶ τυπεὶς ἢ βλήμενος ἰῷ{l]
[l [n}11.207{]}εἰς ἵππους ἅλεται, τότε τοι κράτος ἐγγυαλίξει{l]
[l [n}11.208{]}κτείνειν, εἰς ὅ κε νῆας ἐϋσσέλμους ἀφίκηαι{l]
[l [n}11.209{]}δύῃ τʼ ἠέλιος καὶ ἐπὶ κνέφας ἱερὸν ἔλθῃ.{l]{q]{para]
[para}[l [n}11.210{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπέβη πόδας ὠκέα Ἶρις,{l]
[l [n}11.211{]}Ἕκτωρ δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε,{l]
[l [n}11.212{]}πάλλων δʼ ὀξέα δοῦρα κατὰ στρατὸν ᾤχετο πάντῃ{l]
[l [n}11.213{]}ὀτρύνων μαχέσασθαι, ἔγειρε δὲ φύλοπιν αἰνήν.{l]
[l [n}11.214{]}οἳ δʼ ἐλελίχθησαν καὶ ἐναντίοι ἔσταν Ἀχαιῶν,{l]
[l [n}11.215{]}Ἀργεῖοι δʼ ἑτέρωθεν ἐκαρτύναντο φάλαγγας.{l]
[l [n}11.216{]}ἀρτύνθη δὲ μάχη, στὰν δʼ ἀντίοι· ἐν δʼ Ἀγαμέμνων{l]
[l [n}11.217{]}πρῶτος ὄρουσʼ, ἔθελεν δὲ πολὺ προμάχεσθαι ἁπάντων.{l]{para]
[para}[l [n}11.218{]}ἔσπετε νῦν μοι Μοῦσαι Ὀλύμπια δώματʼ ἔχουσαι{l]
[l [n}11.219{]}ὅς τις δὴ πρῶτος Ἀγαμέμνονος ἀντίον ἦλθεν{l]
[l [n}11.220{]}ἢ αὐτῶν Τρώων ἠὲ κλειτῶν ἐπικούρων.{l]{para]
[para}[l [n}11.221{]}Ἰφιδάμας Ἀντηνορίδης ἠΰς τε μέγας τε{l]
[l [n}11.222{]}ὃς τράφη ἐν Θρῄκῃ ἐριβώλακι μητέρι μήλων·{l]
[l [n}11.223{]}Κισσῆς τόν γʼ ἔθρεψε δόμοις ἔνι τυτθὸν ἐόντα{l]
[l [n}11.224{]}μητροπάτωρ, ὃς τίκτε Θεανὼ καλλιπάρῃον·{l]
[l [n}11.225{]}αὐτὰρ ἐπεί ῥʼ ἥβης ἐρικυδέος ἵκετο μέτρον,{l]
[l [n}11.226{]}αὐτοῦ μιν κατέρυκε, δίδου δʼ ὅ γε θυγατέρα ἥν·{l]
[l [n}11.227{]}γήμας δʼ ἐκ θαλάμοιο μετὰ κλέος ἵκετʼ Ἀχαιῶν{l]
[l [n}11.228{]}σὺν δυοκαίδεκα νηυσὶ κορωνίσιν, αἵ οἱ ἕποντο.{l]
[l [n}11.229{]}τὰς μὲν ἔπειτʼ ἐν Περκώτῃ λίπε νῆας ἐΐσας,{l]
[l [n}11.230{]}αὐτὰρ ὃ πεζὸς ἐὼν ἐς Ἴλιον εἰληλούθει·{l]
[l [n}11.231{]}ὅς ῥα τότʼ Ἀτρεΐδεω Ἀγαμέμνονος ἀντίον ἦλθεν.{l]
[l [n}11.232{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}11.233{]}Ἀτρεΐδης μὲν ἅμαρτε, παραὶ δέ οἱ ἐτράπετʼ ἔγχος,{l]
[l [n}11.234{]}Ἰφιδάμας δὲ κατὰ ζώνην θώρηκος ἔνερθε{l]
[l [n}11.235{]}νύξʼ, ἐπὶ δʼ αὐτὸς ἔρεισε βαρείῃ χειρὶ πιθήσας·{l]
[l [n}11.236{]}οὐδʼ ἔτορε ζωστῆρα παναίολον, ἀλλὰ πολὺ πρὶν{l]
[l [n}11.237{]}ἀργύρῳ ἀντομένη μόλιβος ὣς ἐτράπετʼ αἰχμή.{l]
[l [n}11.238{]}καὶ τό γε χειρὶ λαβὼν εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}11.239{]}ἕλκʼ ἐπὶ οἷ μεμαὼς ὥς τε λίς, ἐκ δʼ ἄρα χειρὸς{l]
[l [n}11.240{]}σπάσσατο· τὸν δʼ ἄορι πλῆξʼ αὐχένα, λῦσε δὲ γυῖα.{l]
[l [n}11.241{]}ὣς ὃ μὲν αὖθι πεσὼν κοιμήσατο χάλκεον ὕπνον{l]
[l [n}11.242{]}οἰκτρὸς ἀπὸ μνηστῆς ἀλόχου, ἀστοῖσιν ἀρήγων,{l]
[l [n}11.243{]}κουριδίης, ἧς οὔ τι χάριν ἴδε, πολλὰ δʼ ἔδωκε·{l]
[l [n}11.244{]}πρῶθʼ ἑκατὸν βοῦς δῶκεν, ἔπειτα δὲ χίλιʼ ὑπέστη{l]
[l [n}11.245{]}αἶγας ὁμοῦ καὶ ὄϊς, τά οἱ ἄσπετα ποιμαίνοντο.{l]
[l [n}11.246{]}δὴ τότε γʼ Ἀτρεΐδης Ἀγαμέμνων ἐξενάριξε,{l]
[l [n}11.247{]}βῆ δὲ φέρων ἀνʼ ὅμιλον Ἀχαιῶν τεύχεα καλά.{l]{para]
[para}[l [n}11.248{]}τὸν δʼ ὡς οὖν ἐνόησε Κόων ἀριδείκετος ἀνδρῶν{l]
[l [n}11.249{]}πρεσβυγενὴς Ἀντηνορίδης, κρατερόν ῥά ἑ πένθος{l]
[l [n}11.250{]}ὀφθαλμοὺς ἐκάλυψε κασιγνήτοιο πεσόντος.{l]
[l [n}11.251{]}στῆ δʼ εὐρὰξ σὺν δουρὶ λαθὼν Ἀγαμέμνονα δῖον,{l]
[l [n}11.252{]}νύξε δέ μιν κατὰ χεῖρα μέσην ἀγκῶνος ἔνερθε,{l]
[l [n}11.253{]}ἀντικρὺ δὲ διέσχε φαεινοῦ δουρὸς ἀκωκή.{l]
[l [n}11.254{]}ῥίγησέν τʼ ἄρʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[l [n}11.255{]}ἀλλʼ οὐδʼ ὧς ἀπέληγε μάχης ἠδὲ πτολέμοιο,{l]
[l [n}11.256{]}ἀλλʼ ἐπόρουσε Κόωνι ἔχων ἀνεμοτρεφὲς ἔγχος.{l]
[l [n}11.257{]}ἤτοι ὃ Ἰφιδάμαντα κασίγνητον καὶ ὄπατρον{l]
[l [n}11.258{]}ἕλκε ποδὸς μεμαώς, καὶ ἀΰτει πάντας ἀρίστους·{l]
[l [n}11.259{]}τὸν δʼ ἕλκοντʼ ἀνʼ ὅμιλον ὑπʼ ἀσπίδος ὀμφαλοέσσης{l]
[l [n}11.260{]}οὔτησε ξυστῷ χαλκήρεϊ, λῦσε δὲ γυῖα·{l]
[l [n}11.261{]}τοῖο δʼ ἐπʼ Ἰφιδάμαντι κάρη ἀπέκοψε παραστάς.{l]
[l [n}11.262{]}ἔνθʼ Ἀντήνορος υἷες ὑπʼ Ἀτρεΐδῃ βασιλῆϊ{l]
[l [n}11.263{]}πότμον ἀναπλήσαντες ἔδυν δόμον Ἄϊδος εἴσω.{l]{para]
[para}[l [n}11.264{]}αὐτὰρ ὃ τῶν ἄλλων ἐπεπωλεῖτο στίχας ἀνδρῶν{l]
[l [n}11.265{]}ἔγχεΐ τʼ ἄορί τε μεγάλοισί τε χερμαδίοισιν,{l]
[l [n}11.266{]}ὄφρά οἱ αἷμʼ ἔτι θερμὸν ἀνήνοθεν ἐξ ὠτειλῆς.{l]
[l [n}11.267{]}αὐτὰρ ἐπεὶ τὸ μὲν ἕλκος ἐτέρσετο, παύσατο δʼ αἷμα,{l]
[l [n}11.268{]}ὀξεῖαι δʼ ὀδύναι δῦνον μένος Ἀτρεΐδαο.{l]
[l [n}11.269{]}ὡς δʼ ὅτʼ ἂν ὠδίνουσαν ἔχῃ βέλος ὀξὺ γυναῖκα{l]
[l [n}11.270{]}δριμύ, τό τε προϊεῖσι μογοστόκοι Εἰλείθυιαι{l]
[l [n}11.271{]}Ἥρης θυγατέρες πικρὰς ὠδῖνας ἔχουσαι,{l]
[l [n}11.272{]}ὣς ὀξεῖʼ ὀδύναι δῦνον μένος Ἀτρεΐδαο.{l]
[l [n}11.273{]}ἐς δίφρον δʼ ἀνόρουσε, καὶ ἡνιόχῳ ἐπέτελλε{l]
[l [n}11.274{]}νηυσὶν ἔπι γλαφυρῇσιν ἐλαυνέμεν· ἤχθετο γὰρ κῆρ.{l]
[l [n}11.275{]}ἤϋσεν δὲ διαπρύσιον Δαναοῖσι γεγωνώς·{l]
[q}[l [n}11.276{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}11.277{]}ὑμεῖς μὲν νῦν νηυσὶν ἀμύνετε ποντοπόροισι{l]
[l [n}11.278{]}φύλοπιν ἀργαλέην, ἐπεὶ οὐκ ἐμὲ μητίετα Ζεὺς{l]
[l [n}11.279{]}εἴασε Τρώεσσι πανημέριον πολεμίζειν.{l]{q]{para]
[para}[l [n}11.280{]}ὣς ἔφαθʼ, ἡνίοχος δʼ ἵμασεν καλλίτριχας ἵππους{l]
[l [n}11.281{]}νῆας ἔπι γλαφυράς· τὼ δʼ οὐκ ἀέκοντε πετέσθην·{l]
[l [n}11.282{]}ἄφρεον δὲ στήθεα, ῥαίνοντο δὲ νέρθε κονίῃ{l]
[l [n}11.283{]}τειρόμενον βασιλῆα μάχης ἀπάνευθε φέροντες.{l]{para]
[para}[l [n}11.284{]}Ἕκτωρ δʼ ὡς ἐνόησʼ Ἀγαμέμνονα νόσφι κιόντα{l]
[l [n}11.285{]}Τρωσί τε καὶ Λυκίοισιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}11.286{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταὶ{l]
[l [n}11.287{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς.{l]
[l [n}11.288{]}οἴχετʼ ἀνὴρ ὤριστος, ἐμοὶ δὲ μέγʼ εὖχος ἔδωκε{l]
[l [n}11.289{]}Ζεὺς Κρονίδης· ἀλλʼ ἰθὺς ἐλαύνετε μώνυχας ἵππους{l]
[l [n}11.290{]}ἰφθίμων Δαναῶν, ἵνʼ ὑπέρτερον εὖχος ἄρησθε.{l]{q]{para]
[para}[l [n}11.291{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}11.292{]}ὡς δʼ ὅτε πού τις θηρητὴρ κύνας ἀργιόδοντας{l]
[l [n}11.293{]}σεύῃ ἐπʼ ἀγροτέρῳ συῒ καπρίῳ ἠὲ λέοντι,{l]
[l [n}11.294{]}ὣς ἐπʼ Ἀχαιοῖσιν σεῦε Τρῶας μεγαθύμους{l]
[l [n}11.295{]}Ἕκτωρ Πριαμίδης βροτολοιγῷ ἶσος Ἄρηϊ.{l]
[l [n}11.296{]}αὐτὸς δʼ ἐν πρώτοισι μέγα φρονέων ἐβεβήκει,{l]
[l [n}11.297{]}ἐν δʼ ἔπεσʼ ὑσμίνῃ ὑπεραέϊ ἶσος ἀέλλῃ,{l]
[l [n}11.298{]}ἥ τε καθαλλομένη ἰοειδέα πόντον ὀρίνει.{l]{para]
[para}[l [n}11.299{]}ἔνθα τίνα πρῶτον, τίνα δʼ ὕστατον ἐξενάριξεν{l]
[l [n}11.300{]}Ἕκτωρ Πριαμίδης, ὅτε οἱ Ζεὺς κῦδος ἔδωκεν;{l]
[l [n}11.301{]}Ἀσαῖον μὲν πρῶτα καὶ Αὐτόνοον καὶ Ὀπίτην{l]
[l [n}11.302{]}καὶ Δόλοπα Κλυτίδην καὶ Ὀφέλτιον ἠδʼ Ἀγέλαον{l]
[l [n}11.303{]}Αἴσυμνόν τʼ Ὦρόν τε καὶ Ἱππόνοον μενεχάρμην.{l]
[l [n}11.304{]}τοὺς ἄρʼ ὅ γʼ ἡγεμόνας Δαναῶν ἕλεν, αὐτὰρ ἔπειτα{l]
[l [n}11.305{]}πληθύν, ὡς ὁπότε νέφεα Ζέφυρος στυφελίξῃ{l]
[l [n}11.306{]}ἀργεστᾶο Νότοιο βαθείῃ λαίλαπι τύπτων·{l]
[l [n}11.307{]}πολλὸν δὲ τρόφι κῦμα κυλίνδεται, ὑψόσε δʼ ἄχνη{l]
[l [n}11.308{]}σκίδναται ἐξ ἀνέμοιο πολυπλάγκτοιο ἰωῆς·{l]
[l [n}11.309{]}ὣς ἄρα πυκνὰ καρήαθʼ ὑφʼ Ἕκτορι δάμνατο λαῶν.{l]{para]
[para}[l [n}11.310{]}ἔνθά κε λοιγὸς ἔην καὶ ἀμήχανα ἔργα γένοντο,{l]
[l [n}11.311{]}καί νύ κεν ἐν νήεσσι πέσον φεύγοντες Ἀχαιοί,{l]
[l [n}11.312{]}εἰ μὴ Τυδεΐδῃ Διομήδεϊ κέκλετʼ Ὀδυσσεύς·{l]
[q}[l [n}11.313{]}Τυδεΐδη τί παθόντε λελάσμεθα θούριδος ἀλκῆς;{l]
[l [n}11.314{]}ἀλλʼ ἄγε δεῦρο πέπον, παρʼ ἔμʼ ἵσταο· δὴ γὰρ ἔλεγχος{l]
[l [n}11.315{]}ἔσσεται εἴ κεν νῆας ἕλῃ κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}11.316{]}τὸν δʼ ἀπαμειβόμενος προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}11.317{]}ἤτοι ἐγὼ μενέω καὶ τλήσομαι· ἀλλὰ μίνυνθα{l]
[l [n}11.318{]}ἡμέων ἔσσεται ἦδος, ἐπεὶ νεφεληγερέτα Ζεὺς{l]
[l [n}11.319{]}Τρωσὶν δὴ βόλεται δοῦναι κράτος ἠέ περ ἡμῖν.{l]{q]{para]
[para}[l [n}11.320{]}ἦ καὶ Θυμβραῖον μὲν ἀφʼ ἵππων ὦσε χαμᾶζε{l]
[l [n}11.321{]}δουρὶ βαλὼν κατὰ μαζὸν ἀριστερόν· αὐτὰρ Ὀδυσσεὺς{l]
[l [n}11.322{]}ἀντίθεον θεράποντα Μολίονα τοῖο ἄνακτος.{l]
[l [n}11.323{]}τοὺς μὲν ἔπειτʼ εἴασαν, ἐπεὶ πολέμου ἀπέπαυσαν·{l]
[l [n}11.324{]}τὼ δʼ ἀνʼ ὅμιλον ἰόντε κυδοίμεον, ὡς ὅτε κάπρω{l]
[l [n}11.325{]}ἐν κυσὶ θηρευτῇσι μέγα φρονέοντε πέσητον·{l]
[l [n}11.326{]}ὣς ὄλεκον Τρῶας πάλιν ὀρμένω· αὐτὰρ Ἀχαιοὶ{l]
[l [n}11.327{]}ἀσπασίως φεύγοντες ἀνέπνεον Ἕκτορα δῖον.{l]{para]
[para}[l [n}11.328{]}ἔνθʼ ἑλέτην δίφρόν τε καὶ ἀνέρε δήμου ἀρίστω{l]
[l [n}11.329{]}υἷε δύω Μέροπος Περκωσίου, ὃς περὶ πάντων{l]
[l [n}11.330{]}ᾔδεε μαντοσύνας, οὐδὲ οὓς παῖδας ἔασκε{l]
[l [n}11.331{]}στείχειν ἐς πόλεμον φθισήνορα· τὼ δέ οἱ οὔ τι{l]
[l [n}11.332{]}πειθέσθην· κῆρες γὰρ ἄγον μέλανος θανάτοιο.{l]
[l [n}11.333{]}τοὺς μὲν Τυδεΐδης δουρικλειτὸς Διομήδης{l]
[l [n}11.334{]}θυμοῦ καὶ ψυχῆς κεκαδὼν κλυτὰ τεύχεʼ ἀπηύρα·{l]
[l [n}11.335{]}Ἱππόδαμον δʼ Ὀδυσεὺς καὶ Ὑπείροχον ἐξενάριξεν.{l]{para]
[para}[l [n}11.336{]}ἔνθά σφιν κατὰ ἶσα μάχην ἐτάνυσσε Κρονίων{l]
[l [n}11.337{]}ἐξ Ἴδης καθορῶν· τοὶ δʼ ἀλλήλους ἐνάριζον.{l]
[l [n}11.338{]}ἤτοι Τυδέος υἱὸς Ἀγάστροφον οὔτασε δουρὶ{l]
[l [n}11.339{]}Παιονίδην ἥρωα κατʼ ἰσχίον· οὐ δέ οἱ ἵπποι{l]
[l [n}11.340{]}ἐγγὺς ἔσαν προφυγεῖν, ἀάσατο δὲ μέγα θυμῷ.{l]
[l [n}11.341{]}τοὺς μὲν γὰρ θεράπων ἀπάνευθʼ ἔχεν, αὐτὰρ ὃ πεζὸς{l]
[l [n}11.342{]}θῦνε διὰ προμάχων, εἷος φίλον ὤλεσε θυμόν.{l]
[l [n}11.343{]}Ἕκτωρ δʼ ὀξὺ νόησε κατὰ στίχας, ὦρτο δʼ ἐπʼ αὐτοὺς{l]
[l [n}11.344{]}κεκλήγων· ἅμα δὲ Τρώων εἵποντο φάλαγγες.{l]
[l [n}11.345{]}τὸν δὲ ἰδὼν ῥίγησε βοὴν ἀγαθὸς Διομήδης,{l]
[l [n}11.346{]}αἶψα δʼ Ὀδυσσῆα προσεφώνεεν ἐγγὺς ἐόντα·{l]
[q}[l [n}11.347{]}νῶϊν δὴ τόδε πῆμα κυλίνδεται ὄβριμος Ἕκτωρ·{l]
[l [n}11.348{]}ἀλλʼ ἄγε δὴ στέωμεν καὶ ἀλεξώμεσθα μένοντες.{l]{q]{para]
[para}[l [n}11.349{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος{l]
[l [n}11.350{]}καὶ βάλεν, οὐδʼ ἀφάμαρτε τιτυσκόμενος κεφαλῆφιν,{l]
[l [n}11.351{]}ἄκρην κὰκ κόρυθα· πλάγχθη δʼ ἀπὸ χαλκόφι χαλκός,{l]
[l [n}11.352{]}οὐδʼ ἵκετο χρόα καλόν· ἐρύκακε γὰρ τρυφάλεια{l]
[l [n}11.353{]}τρίπτυχος αὐλῶπις, τήν οἱ πόρε Φοῖβος Ἀπόλλων.{l]
[l [n}11.354{]}Ἕκτωρ δʼ ὦκʼ ἀπέλεθρον ἀνέδραμε, μίκτο δʼ ὁμίλῳ,{l]
[l [n}11.355{]}στῆ δὲ γνὺξ ἐριπὼν καὶ ἐρείσατο χειρὶ παχείῃ{l]
[l [n}11.356{]}γαίης· ἀμφὶ δὲ ὄσσε κελαινὴ νὺξ ἐκάλυψεν.{l]
[l [n}11.357{]}ὄφρα δὲ Τυδεΐδης μετὰ δούρατος ᾤχετʼ ἐρωὴν{l]
[l [n}11.358{]}τῆλε διὰ προμάχων, ὅθι οἱ καταείσατο γαίης{l]
[l [n}11.359{]}τόφρʼ Ἕκτωρ ἔμπνυτο, καὶ ἂψ ἐς δίφρον ὀρούσας{l]
[l [n}11.360{]}ἐξέλασʼ ἐς πληθύν, καὶ ἀλεύατο κῆρα μέλαιναν.{l]
[l [n}11.361{]}δουρὶ δʼ ἐπαΐσσων προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}11.362{]}ἐξ αὖ νῦν ἔφυγες θάνατον κύον· ἦ τέ τοι ἄγχι{l]
[l [n}11.363{]}ἦλθε κακόν· νῦν αὖτέ σʼ ἐρύσατο Φοῖβος Ἀπόλλων{l]
[l [n}11.364{]}ᾧ μέλλεις εὔχεσθαι ἰὼν ἐς δοῦπον ἀκόντων.{l]
[l [n}11.365{]}ἦ θήν σʼ ἐξανύω γε καὶ ὕστερον ἀντιβολήσας,{l]
[l [n}11.366{]}εἴ πού τις καὶ ἔμοιγε θεῶν ἐπιτάρροθός ἐστι.{l]
[l [n}11.367{]}νῦν αὖ τοὺς ἄλλους ἐπιείσομαι, ὅν κε κιχείω.{l]{q]{para]
[para}[l [n}11.368{]}ἦ, καὶ Παιονίδην δουρὶ κλυτὸν ἐξενάριζεν.{l]
[l [n}11.369{]}αὐτὰρ Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο{l]
[l [n}11.370{]}Τυδεΐδῃ ἔπι τόξα τιταίνετο ποιμένι λαῶν,{l]
[l [n}11.371{]}στήλῃ κεκλιμένος ἀνδροκμήτῳ ἐπὶ τύμβῳ{l]
[l [n}11.372{]}Ἴλου Δαρδανίδαο, παλαιοῦ δημογέροντος.{l]
[l [n}11.373{]}ἤτοι ὃ μὲν θώρηκα Ἀγαστρόφου ἰφθίμοιο{l]
[l [n}11.374{]}αἴνυτʼ ἀπὸ στήθεσφι παναίολον ἀσπίδα τʼ ὤμων{l]
[l [n}11.375{]}καὶ κόρυθα βριαρήν· ὃ δὲ τόξου πῆχυν ἄνελκε{l]
[l [n}11.376{]}καὶ βάλεν, οὐδʼ ἄρα μιν ἅλιον βέλος ἔκφυγε χειρός,{l]
[l [n}11.377{]}ταρσὸν δεξιτεροῖο ποδός· διὰ δʼ ἀμπερὲς ἰὸς{l]
[l [n}11.378{]}ἐν γαίῃ κατέπηκτο· ὃ δὲ μάλα ἡδὺ γελάσσας{l]
[l [n}11.379{]}ἐκ λόχου ἀμπήδησε καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}11.380{]}βέβληαι οὐδʼ ἅλιον βέλος ἔκφυγεν· ὡς ὄφελόν τοι{l]
[l [n}11.381{]}νείατον ἐς κενεῶνα βαλὼν ἐκ θυμὸν ἑλέσθαι.{l]
[l [n}11.382{]}οὕτω κεν καὶ Τρῶες ἀνέπνευσαν κακότητος,{l]
[l [n}11.383{]}οἵ τέ σε πεφρίκασι λέονθʼ ὡς μηκάδες αἶγες.{l]{q]{para]
[para}[l [n}11.384{]}τὸν δʼ οὐ ταρβήσας προσέφη κρατερὸς Διομήδης·{l]
[q}[l [n}11.385{]}τοξότα λωβητὴρ κέρᾳ ἀγλαὲ παρθενοπῖπα{l]
[l [n}11.386{]}εἰ μὲν δὴ ἀντίβιον σὺν τεύχεσι πειρηθείης,{l]
[l [n}11.387{]}οὐκ ἄν τοι χραίσμῃσι βιὸς καὶ ταρφέες ἰοί·{l]
[l [n}11.388{]}νῦν δέ μʼ ἐπιγράψας ταρσὸν ποδὸς εὔχεαι αὔτως.{l]
[l [n}11.389{]}οὐκ ἀλέγω, ὡς εἴ με γυνὴ βάλοι ἢ πάϊς ἄφρων·{l]
[l [n}11.390{]}κωφὸν γὰρ βέλος ἀνδρὸς ἀνάλκιδος οὐτιδανοῖο.{l]
[l [n}11.391{]}ἦ τʼ ἄλλως ὑπʼ ἐμεῖο, καὶ εἴ κʼ ὀλίγον περ ἐπαύρῃ,{l]
[l [n}11.392{]}ὀξὺ βέλος πέλεται, καὶ ἀκήριον αἶψα τίθησι.{l]
[l [n}11.393{]}τοῦ δὲ γυναικὸς μέν τʼ ἀμφίδρυφοί εἰσι παρειαί,{l]
[l [n}11.394{]}παῖδες δʼ ὀρφανικοί· ὃ δέ θʼ αἵματι γαῖαν ἐρεύθων{l]
[l [n}11.395{]}πύθεται, οἰωνοὶ δὲ περὶ πλέες ἠὲ γυναῖκες.{l]{q]{para]
[para}[l [n}11.396{]}ὣς φάτο, τοῦ δʼ Ὀδυσεὺς δουρικλυτὸς ἐγγύθεν ἐλθὼν{l]
[l [n}11.397{]}ἔστη πρόσθʼ· ὃ δʼ ὄπισθε καθεζόμενος βέλος ὠκὺ{l]
[l [n}11.398{]}ἐκ ποδὸς ἕλκʼ, ὀδύνη δὲ διὰ χροὸς ἦλθʼ ἀλεγεινή.{l]
[l [n}11.399{]}ἐς δίφρον δʼ ἀνόρουσε, καὶ ἡνιόχῳ ἐπέτελλε{l]
[l [n}11.400{]}νηυσὶν ἔπι γλαφυρῇσιν ἐλαυνέμεν· ἤχθετο γὰρ κῆρ.{l]{para]
[para}[l [n}11.401{]}οἰώθη δʼ Ὀδυσεὺς δουρὶ κλυτός, οὐδέ τις αὐτῷ{l]
[l [n}11.402{]}Ἀργείων παρέμεινεν, ἐπεὶ φόβος ἔλλαβε πάντας·{l]
[l [n}11.403{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}11.404{]}ὤ μοι ἐγὼ τί πάθω; μέγα μὲν κακὸν αἴ κε φέβωμαι{l]
[l [n}11.405{]}πληθὺν ταρβήσας· τὸ δὲ ῥίγιον αἴ κεν ἁλώω{l]
[l [n}11.406{]}μοῦνος· τοὺς δʼ ἄλλους Δαναοὺς ἐφόβησε Κρονίων.{l]
[l [n}11.407{]}ἀλλὰ τί ἤ μοι ταῦτα φίλος διελέξατο θυμός;{l]
[l [n}11.408{]}οἶδα γὰρ ὅττι κακοὶ μὲν ἀποίχονται πολέμοιο,{l]
[l [n}11.409{]}ὃς δέ κʼ ἀριστεύῃσι μάχῃ ἔνι τὸν δὲ μάλα χρεὼ{l]
[l [n}11.410{]}ἑστάμεναι κρατερῶς, ἤ τʼ ἔβλητʼ ἤ τʼ ἔβαλʼ ἄλλον.{l]{q]{para]
[para}[l [n}11.411{]}εἷος ὃ ταῦθʼ ὥρμαινε κατὰ φρένα καὶ κατὰ θυμόν,{l]
[l [n}11.412{]}τόφρα δʼ ἐπὶ Τρώων στίχες ἤλυθον ἀσπιστάων,{l]
[l [n}11.413{]}ἔλσαν δʼ ἐν μέσσοισι, μετὰ σφίσι πῆμα τιθέντες.{l]
[l [n}11.414{]}ὡς δʼ ὅτε κάπριον ἀμφὶ κύνες θαλεροί τʼ αἰζηοὶ{l]
[l [n}11.415{]}σεύωνται, ὃ δέ τʼ εἶσι βαθείης ἐκ ξυλόχοιο{l]
[l [n}11.416{]}θήγων λευκὸν ὀδόντα μετὰ γναμπτῇσι γένυσσιν,{l]
[l [n}11.417{]}ἀμφὶ δέ τʼ ἀΐσσονται, ὑπαὶ δέ τε κόμπος ὀδόντων{l]
[l [n}11.418{]}γίγνεται, οἳ δὲ μένουσιν ἄφαρ δεινόν περ ἐόντα,{l]
[l [n}11.419{]}ὥς ῥα τότʼ ἀμφʼ Ὀδυσῆα Διῒ φίλον ἐσσεύοντο{l]
[l [n}11.420{]}Τρῶες· ὃ δὲ πρῶτον μὲν ἀμύμονα Δηϊοπίτην{l]
[l [n}11.421{]}οὔτασεν ὦμον ὕπερθεν ἐπάλμενος ὀξέϊ δουρί,{l]
[l [n}11.422{]}αὐτὰρ ἔπειτα Θόωνα καὶ Ἔννομον ἐξενάριξε.{l]
[l [n}11.423{]}Χερσιδάμαντα δʼ ἔπειτα καθʼ ἵππων ἀΐξαντα{l]
[l [n}11.424{]}δουρὶ κατὰ πρότμησιν ὑπʼ ἀσπίδος ὀμφαλοέσσης{l]
[l [n}11.425{]}νύξεν· ὃ δʼ ἐν κονίῃσι πεσὼν ἕλε γαῖαν ἀγοστῷ.{l]
[l [n}11.426{]}τοὺς μὲν ἔασʼ, ὃ δʼ ἄρʼ Ἱππασίδην Χάροπʼ οὔτασε δουρὶ{l]
[l [n}11.427{]}αὐτοκασίγνητον εὐηφενέος Σώκοιο.{l]
[l [n}11.428{]}τῷ δʼ ἐπαλεξήσων Σῶκος κίεν ἰσόθεος φώς,{l]
[l [n}11.429{]}στῆ δὲ μάλʼ ἐγγὺς ἰὼν καί μιν πρὸς μῦθον ἔειπεν{l]
[q}[l [n}11.430{]}ὦ Ὀδυσεῦ πολύαινε δόλων ἆτʼ ἠδὲ πόνοιο{l]
[l [n}11.431{]}σήμερον ἢ δοιοῖσιν ἐπεύξεαι Ἱππασίδῃσι{l]
[l [n}11.432{]}τοιώδʼ ἄνδρε κατακτείνας καὶ τεύχεʼ ἀπούρας,{l]
[l [n}11.433{]}ἤ κεν ἐμῷ ὑπὸ δουρὶ τυπεὶς ἀπὸ θυμὸν ὀλέσσῃς.{l]{q]{para]
[para}[l [n}11.434{]}ὣς εἰπὼν οὔτησε κατʼ ἀσπίδα πάντοσʼ ἐΐσην.{l]
[l [n}11.435{]}διὰ μὲν ἀσπίδος ἦλθε φαεινῆς ὄβριμον ἔγχος,{l]
[l [n}11.436{]}καὶ διὰ θώρηκος πολυδαιδάλου ἠρήρειστο,{l]
[l [n}11.437{]}πάντα δʼ ἀπὸ πλευρῶν χρόα ἔργαθεν, οὐδʼ ἔτʼ ἔασε{l]
[l [n}11.438{]}Παλλὰς Ἀθηναίη μιχθήμεναι ἔγκασι φωτός.{l]
[l [n}11.439{]}γνῶ δʼ Ὀδυσεὺς ὅ οἱ οὔ τι τέλος κατακαίριον ἦλθεν,{l]
[l [n}11.440{]}ἂψ δʼ ἀναχωρήσας Σῶκον πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}11.441{]}ἆ δείλʼ ἦ μάλα δή σε κιχάνεται αἰπὺς ὄλεθρος.{l]
[l [n}11.442{]}ἤτοι μέν ῥʼ ἔμʼ ἔπαυσας ἐπὶ Τρώεσσι μάχεσθαι·{l]
[l [n}11.443{]}σοὶ δʼ ἐγὼ ἐνθάδε φημὶ φόνον καὶ κῆρα μέλαιναν{l]
[l [n}11.444{]}ἤματι τῷδʼ ἔσσεσθαι, ἐμῷ δʼ ὑπὸ δουρὶ δαμέντα{l]
[l [n}11.445{]}εὖχος ἐμοὶ δώσειν, ψυχὴν δʼ Ἄϊδι κλυτοπώλῳ.{l]{q]{para]
[para}[l [n}11.446{]}ἦ, καὶ ὃ μὲν φύγαδʼ αὖτις ὑποστρέψας ἐβεβήκει,{l]
[l [n}11.447{]}τῷ δὲ μεταστρεφθέντι μεταφρένῳ ἐν δόρυ πῆξεν{l]
[l [n}11.448{]}ὤμων μεσσηγύς, διὰ δὲ στήθεσφιν ἔλασσε,{l]
[l [n}11.449{]}δούπησεν δὲ πεσών· ὃ δʼ ἐπεύξατο δῖος Ὀδυσσεύς·{l]
[q}[l [n}11.450{]}ὦ Σῶχʼ Ἱππάσου υἱὲ δαΐφρονος ἱπποδάμοιο{l]
[l [n}11.451{]}φθῆ σε τέλος θανάτοιο κιχήμενον, οὐδʼ ὑπάλυξας.{l]
[l [n}11.452{]}ἆ δείλʼ οὐ μὲν σοί γε πατὴρ καὶ πότνια μήτηρ{l]
[l [n}11.453{]}ὄσσε καθαιρήσουσι θανόντι περ, ἀλλʼ οἰωνοὶ{l]
[l [n}11.454{]}ὠμησταὶ ἐρύουσι, περὶ πτερὰ πυκνὰ βαλόντες.{l]
[l [n}11.455{]}αὐτὰρ ἔμʼ, εἴ κε θάνω, κτεριοῦσί γε δῖοι Ἀχαιοί.{l]{q]{para]
[para}[l [n}11.456{]}ὣς εἰπὼν Σώκοιο δαΐφρονος ὄβριμον ἔγχος{l]
[l [n}11.457{]}ἔξω τε χροὸς ἕλκε καὶ ἀσπίδος ὀμφαλοέσσης·{l]
[l [n}11.458{]}αἷμα δέ οἱ σπασθέντος ἀνέσσυτο, κῆδε δὲ θυμόν.{l]
[l [n}11.459{]}Τρῶες δὲ μεγάθυμοι ὅπως ἴδον αἷμʼ Ὀδυσῆος{l]
[l [n}11.460{]}κεκλόμενοι καθʼ ὅμιλον ἐπʼ αὐτῷ πάντες ἔβησαν.{l]
[l [n}11.461{]}αὐτὰρ ὅ γʼ ἐξοπίσω ἀνεχάζετο, αὖε δʼ ἑταίρους.{l]
[l [n}11.462{]}τρὶς μὲν ἔπειτʼ ἤϋσεν ὅσον κεφαλὴ χάδε φωτός,{l]
[l [n}11.463{]}τρὶς δʼ ἄϊεν ἰάχοντος ἄρηι φίλος Μενέλαος.{l]
[l [n}11.464{]}αἶψα δʼ ἄρʼ Αἴαντα προσεφώνεεν ἐγγὺς ἐόντα·{l]
[q}[l [n}11.465{]}Αἶαν διογενὲς Τελαμώνιε κοίρανε λαῶν{l]
[l [n}11.466{]}ἀμφί μʼ Ὀδυσσῆος ταλασίφρονος ἵκετʼ ἀϋτὴ{l]
[l [n}11.467{]}τῷ ἰκέλη ὡς εἴ ἑ βιῴατο μοῦνον ἐόντα{l]
[l [n}11.468{]}Τρῶες ἀποτμήξαντες ἐνὶ κρατερῇ ὑσμίνῃ.{l]
[l [n}11.469{]}ἀλλʼ ἴομεν καθʼ ὅμιλον· ἀλεξέμεναι γὰρ ἄμεινον.{l]
[l [n}11.470{]}δείδω μή τι πάθῃσιν ἐνὶ Τρώεσσι μονωθεὶς{l]
[l [n}11.471{]}ἐσθλὸς ἐών, μεγάλη δὲ ποθὴ Δαναοῖσι γένηται.{l]{q]{para]
[para}[l [n}11.472{]}ὣς εἰπὼν ὃ μὲν ἦρχʼ, ὃ δʼ ἅμʼ ἕσπετο ἰσόθεος φώς.{l]
[l [n}11.473{]}εὗρον ἔπειτʼ Ὀδυσῆα Διῒ φίλον· ἀμφὶ δʼ ἄρʼ αὐτὸν{l]
[l [n}11.474{]}Τρῶες ἕπονθʼ ὡς εἴ τε δαφοινοὶ θῶες ὄρεσφιν{l]
[l [n}11.475{]}ἀμφʼ ἔλαφον κεραὸν βεβλημένον, ὅν τʼ ἔβαλʼ ἀνὴρ{l]
[l [n}11.476{]}ἰῷ ἀπὸ νευρῆς· τὸν μέν τʼ ἤλυξε πόδεσσι{l]
[l [n}11.477{]}φεύγων, ὄφρʼ αἷμα λιαρὸν καὶ γούνατʼ ὀρώρῃ·{l]
[l [n}11.478{]}αὐτὰρ ἐπεὶ δὴ τόν γε δαμάσσεται ὠκὺς ὀϊστός,{l]
[l [n}11.479{]}ὠμοφάγοι μιν θῶες ἐν οὔρεσι δαρδάπτουσιν{l]
[l [n}11.480{]}ἐν νέμεϊ σκιερῷ· ἐπί τε λῖν ἤγαγε δαίμων{l]
[l [n}11.481{]}σίντην· θῶες μέν τε διέτρεσαν, αὐτὰρ ὃ δάπτει·{l]
[l [n}11.482{]}ὥς ῥα τότʼ ἀμφʼ Ὀδυσῆα δαΐφρονα ποικιλομήτην{l]
[l [n}11.483{]}Τρῶες ἕπον πολλοί τε καὶ ἄλκιμοι, αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}11.484{]}ἀΐσσων ᾧ ἔγχει ἀμύνετο νηλεὲς ἦμαρ.{l]
[l [n}11.485{]}Αἴας δʼ ἐγγύθεν ἦλθε φέρων σάκος ἠΰτε πύργον,{l]
[l [n}11.486{]}στῆ δὲ παρέξ· Τρῶες δὲ διέτρεσαν ἄλλυδις ἄλλος.{l]
[l [n}11.487{]}ἤτοι τὸν Μενέλαος ἀρήϊος ἔξαγʼ ὁμίλου{l]
[l [n}11.488{]}χειρὸς ἔχων, εἷος θεράπων σχεδὸν ἤλασεν ἵππους.{l]{para]
[para}[l [n}11.489{]}Αἴας δὲ Τρώεσσιν ἐπάλμενος εἷλε Δόρυκλον{l]
[l [n}11.490{]}Πριαμίδην νόθον υἱόν, ἔπειτα δὲ Πάνδοκον οὖτα,{l]
[l [n}11.491{]}οὖτα δὲ Λύσανδρον καὶ Πύρασον ἠδὲ Πυλάρτην.{l]
[l [n}11.492{]}ὡς δʼ ὁπότε πλήθων ποταμὸς πεδίον δὲ κάτεισι{l]
[l [n}11.493{]}χειμάρρους κατʼ ὄρεσφιν ὀπαζόμενος Διὸς ὄμβρῳ,{l]
[l [n}11.494{]}πολλὰς δὲ δρῦς ἀζαλέας, πολλὰς δέ τε πεύκας{l]
[l [n}11.495{]}ἐσφέρεται, πολλὸν δέ τʼ ἀφυσγετὸν εἰς ἅλα βάλλει,{l]
[l [n}11.496{]}ὣς ἔφεπε κλονέων πεδίον τότε φαίδιμος Αἴας,{l]
[l [n}11.497{]}δαΐζων ἵππους τε καὶ ἀνέρας· οὐδέ πω Ἕκτωρ{l]
[l [n}11.498{]}πεύθετʼ, ἐπεί ῥα μάχης ἐπʼ ἀριστερὰ μάρνατο πάσης{l]
[l [n}11.499{]}ὄχθας πὰρ ποταμοῖο Σκαμάνδρου, τῇ ῥα μάλιστα{l]
[l [n}11.500{]}ἀνδρῶν πῖπτε κάρηνα, βοὴ δʼ ἄσβεστος ὀρώρει{l]
[l [n}11.501{]}Νέστορά τʼ ἀμφὶ μέγαν καὶ ἀρήϊον Ἰδομενῆα.{l]
[l [n}11.502{]}Ἕκτωρ μὲν μετὰ τοῖσιν ὁμίλει μέρμερα ῥέζων{l]
[l [n}11.503{]}ἔγχεΐ θʼ ἱπποσύνῃ τε, νέων δʼ ἀλάπαζε φάλαγγας·{l]
[l [n}11.504{]}οὐδʼ ἄν πω χάζοντο κελεύθου δῖοι Ἀχαιοὶ{l]
[l [n}11.505{]}εἰ μὴ Ἀλέξανδρος Ἑλένης πόσις ἠϋκόμοιο{l]
[l [n}11.506{]}παῦσεν ἀριστεύοντα Μαχάονα ποιμένα λαῶν,{l]
[l [n}11.507{]}ἰῷ τριγλώχινι βαλὼν κατὰ δεξιὸν ὦμον.{l]
[l [n}11.508{]}τῷ ῥα περίδεισαν μένεα πνείοντες Ἀχαιοὶ{l]
[l [n}11.509{]}μή πώς μιν πολέμοιο μετακλινθέντος ἕλοιεν.{l]
[l [n}11.510{]}αὐτίκα δʼ Ἰδομενεὺς προσεφώνεε Νέστορα δῖον·{l]
[q}[l [n}11.511{]}ὦ Νέστορ Νηληϊάδη μέγα κῦδος Ἀχαιῶν{l]
[l [n}11.512{]}ἄγρει σῶν ὀχέων ἐπιβήσεο, πὰρ δὲ Μαχάων{l]
[l [n}11.513{]}βαινέτω, ἐς νῆας δὲ τάχιστʼ ἔχε μώνυχας ἵππους·{l]
[l [n}11.514{]}ἰητρὸς γὰρ ἀνὴρ πολλῶν ἀντάξιος ἄλλων{l]
[l [n}11.515{]}ἰούς τʼ ἐκτάμνειν ἐπί τʼ ἤπια φάρμακα πάσσειν.{l]{q]{para]
[para}[l [n}11.516{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε Γερήνιος ἱππότα Νέστωρ.{l]
[l [n}11.517{]}αὐτίκα δʼ ὧν ὀχέων ἐπεβήσετο, πὰρ δὲ Μαχάων{l]
[l [n}11.518{]}βαῖνʼ Ἀσκληπιοῦ υἱὸς ἀμύμονος ἰητῆρος·{l]
[l [n}11.519{]}μάστιξεν δʼ ἵππους, τὼ δʼ οὐκ ἀέκοντε πετέσθην{l]
[l [n}11.520{]}νῆας ἔπι γλαφυράς· τῇ γὰρ φίλον ἔπλετο θυμῷ.{l]{para]
[para}[l [n}11.521{]}Κεβριόνης δὲ Τρῶας ὀρινομένους ἐνόησεν{l]
[l [n}11.522{]}Ἕκτορι παρβεβαώς, καί μιν πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}11.523{]}Ἕκτορ νῶϊ μὲν ἐνθάδʼ ὁμιλέομεν Δαναοῖσιν{l]
[l [n}11.524{]}ἐσχατιῇ πολέμοιο δυσηχέος· οἳ δὲ δὴ ἄλλοι{l]
[l [n}11.525{]}Τρῶες ὀρίνονται ἐπιμὶξ ἵπποι τε καὶ αὐτοί.{l]
[l [n}11.526{]}Αἴας δὲ κλονέει Τελαμώνιος· εὖ δέ μιν ἔγνων·{l]
[l [n}11.527{]}εὐρὺ γὰρ ἀμφʼ ὤμοισιν ἔχει σάκος· ἀλλὰ καὶ ἡμεῖς{l]
[l [n}11.528{]}κεῖσʼ ἵππους τε καὶ ἅρμʼ ἰθύνομεν, ἔνθα μάλιστα{l]
[l [n}11.529{]}ἱππῆες πεζοί τε κακὴν ἔριδα προβαλόντες{l]
[l [n}11.530{]}ἀλλήλους ὀλέκουσι, βοὴ δʼ ἄσβεστος ὄρωρεν.{l]{q]{para]
[para}[l [n}11.531{]}ὣς ἄρα φωνήσας ἵμασεν καλλίτριχας ἵππους{l]
[l [n}11.532{]}μάστιγι λιγυρῇ· τοὶ δὲ πληγῆς ἀΐοντες{l]
[l [n}11.533{]}ῥίμφʼ ἔφερον θοὸν ἅρμα μετὰ Τρῶας καὶ Ἀχαιοὺς{l]
[l [n}11.534{]}στείβοντες νέκυάς τε καὶ ἀσπίδας· αἵματι δʼ ἄξων{l]
[l [n}11.535{]}νέρθεν ἅπας πεπάλακτο καὶ ἄντυγες αἳ περὶ δίφρον,{l]
[l [n}11.536{]}ἃς ἄρʼ ἀφʼ ἱππείων ὁπλέων ῥαθάμιγγες ἔβαλλον{l]
[l [n}11.537{]}αἵ τʼ ἀπʼ ἐπισσώτρων. ὃ δὲ ἵετο δῦναι ὅμιλον{l]
[l [n}11.538{]}ἀνδρόμεον ῥῆξαί τε μετάλμενος· ἐν δὲ κυδοιμὸν{l]
[l [n}11.539{]}ἧκε κακὸν Δαναοῖσι, μίνυνθα δὲ χάζετο δουρός.{l]
[l [n}11.540{]}αὐτὰρ ὃ τῶν ἄλλων ἐπεπωλεῖτο στίχας ἀνδρῶν{l]
[l [n}11.541{]}ἔγχεΐ τʼ ἄορί τε μεγάλοισί τε χερμαδίοισιν,{l]
[l [n}11.542{]}Αἴαντος δʼ ἀλέεινε μάχην Τελαμωνιάδαο.{l]{para]
[para}[l [n}11.544{]}Ζεὺς δὲ πατὴρ Αἴανθʼ ὑψίζυγος ἐν φόβον ὦρσε·{l]
[l [n}11.545{]}στῆ δὲ ταφών, ὄπιθεν δὲ σάκος βάλεν ἑπταβόειον,{l]
[l [n}11.546{]}τρέσσε δὲ παπτήνας ἐφʼ ὁμίλου θηρὶ ἐοικὼς{l]
[l [n}11.547{]}ἐντροπαλιζόμενος ὀλίγον γόνυ γουνὸς ἀμείβων.{l]
[l [n}11.548{]}ὡς δʼ αἴθωνα λέοντα βοῶν ἀπὸ μεσσαύλοιο{l]
[l [n}11.549{]}ἐσσεύαντο κύνες τε καὶ ἀνέρες ἀγροιῶται,{l]
[l [n}11.550{]}οἵ τέ μιν οὐκ εἰῶσι βοῶν ἐκ πῖαρ ἑλέσθαι{l]
[l [n}11.551{]}πάννυχοι ἐγρήσσοντες· ὃ δὲ κρειῶν ἐρατίζων{l]
[l [n}11.552{]}ἰθύει, ἀλλʼ οὔ τι πρήσσει· θαμέες γὰρ ἄκοντες{l]
[l [n}11.553{]}ἀντίον ἀΐσσουσι θρασειάων ἀπὸ χειρῶν{l]
[l [n}11.554{]}καιόμεναί τε δεταί, τάς τε τρεῖ ἐσσύμενός περ·{l]
[l [n}11.555{]}ἠῶθεν δʼ ἀπὸ νόσφιν ἔβη τετιηότι θυμῷ·{l]
[l [n}11.556{]}ὣς Αἴας τότʼ ἀπὸ Τρώων τετιημένος ἦτορ{l]
[l [n}11.557{]}ἤϊε πόλλʼ ἀέκων· περὶ γὰρ δίε νηυσὶν Ἀχαιῶν.{l]
[l [n}11.558{]}ὡς δʼ ὅτʼ ὄνος παρʼ ἄρουραν ἰὼν ἐβιήσατο παῖδας{l]
[l [n}11.559{]}νωθής, ᾧ δὴ πολλὰ περὶ ῥόπαλʼ ἀμφὶς ἐάγῃ,{l]
[l [n}11.560{]}κείρει τʼ εἰσελθὼν βαθὺ λήϊον· οἳ δέ τε παῖδες{l]
[l [n}11.561{]}τύπτουσιν ῥοπάλοισι· βίη δέ τε νηπίη αὐτῶν·{l]
[l [n}11.562{]}σπουδῇ τʼ ἐξήλασσαν, ἐπεί τʼ ἐκορέσσατο φορβῆς·{l]
[l [n}11.563{]}ὣς τότʼ ἔπειτʼ Αἴαντα μέγαν Τελαμώνιον υἱὸν{l]
[l [n}11.564{]}Τρῶες ὑπέρθυμοι πολυηγερέες τʼ ἐπίκουροι{l]
[l [n}11.565{]}νύσσοντες ξυστοῖσι μέσον σάκος αἰὲν ἕποντο.{l]
[l [n}11.566{]}Αἴας δʼ ἄλλοτε μὲν μνησάσκετο θούριδος ἀλκῆς{l]
[l [n}11.567{]}αὖτις ὑποστρεφθείς, καὶ ἐρητύσασκε φάλαγγας{l]
[l [n}11.568{]}Τρώων ἱπποδάμων· ὁτὲ δὲ τρωπάσκετο φεύγειν.{l]
[l [n}11.569{]}πάντας δὲ προέεργε θοὰς ἐπὶ νῆας ὁδεύειν,{l]
[l [n}11.570{]}αὐτὸς δὲ Τρώων καὶ Ἀχαιῶν θῦνε μεσηγὺ{l]
[l [n}11.571{]}ἱστάμενος· τὰ δὲ δοῦρα θρασειάων ἀπὸ χειρῶν{l]
[l [n}11.572{]}ἄλλα μὲν ἐν σάκεϊ μεγάλῳ πάγεν ὄρμενα πρόσσω,{l]
[l [n}11.573{]}πολλὰ δὲ καὶ μεσσηγύ, πάρος χρόα λευκὸν ἐπαυρεῖν,{l]
[l [n}11.574{]}ἐν γαίῃ ἵσταντο λιλαιόμενα χροὸς ἆσαι.{l]{para]
[para}[l [n}11.575{]}τὸν δʼ ὡς οὖν ἐνόησʼ Εὐαίμονος ἀγλαὸς υἱὸς{l]
[l [n}11.576{]}Εὐρύπυλος πυκινοῖσι βιαζόμενον βελέεσσι,{l]
[l [n}11.577{]}στῆ ῥα παρʼ αὐτὸν ἰών, καὶ ἀκόντισε δουρὶ φαεινῷ,{l]
[l [n}11.578{]}καὶ βάλε Φαυσιάδην Ἀπισάονα ποιμένα λαῶν{l]
[l [n}11.579{]}ἧπαρ ὑπὸ πραπίδων, εἶθαρ δʼ ὑπὸ γούνατʼ ἔλυσεν·{l]
[l [n}11.580{]}Εὐρύπυλος δʼ ἐπόρουσε καὶ αἴνυτο τεύχεʼ ἀπʼ ὤμων.{l]
[l [n}11.581{]}τὸν δʼ ὡς οὖν ἐνόησεν Ἀλέξανδρος θεοειδὴς{l]
[l [n}11.582{]}τεύχεʼ ἀπαινύμενον Ἀπισάονος, αὐτίκα τόξον{l]
[l [n}11.583{]}ἕλκετʼ ἐπʼ Εὐρυπύλῳ, καί μιν βάλε μηρὸν ὀϊστῷ{l]
[l [n}11.584{]}δεξιόν· ἐκλάσθη δὲ δόναξ, ἐβάρυνε δὲ μηρόν.{l]
[l [n}11.585{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων,{l]
[l [n}11.586{]}ἤϋσεν δὲ διαπρύσιον Δαναοῖσι γεγωνώς·{l]
[q}[l [n}11.587{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}11.588{]}στῆτʼ ἐλελιχθέντες καὶ ἀμύνετε νηλεὲς ἦμαρ{l]
[l [n}11.589{]}Αἴανθʼ, ὃς βελέεσσι βιάζεται, οὐδέ ἕ φημι{l]
[l [n}11.590{]}φεύξεσθʼ ἐκ πολέμοιο δυσηχέος· ἀλλὰ μάλʼ ἄντην{l]
[l [n}11.591{]}ἵστασθʼ ἀμφʼ Αἴαντα μέγαν Τελαμώνιον υἱόν.{l]{q]{para]
[para}[l [n}11.592{]}ὣς ἔφατʼ Εὐρύπυλος βεβλημένος· οἳ δὲ παρʼ αὐτὸν{l]
[l [n}11.593{]}πλησίοι ἔστησαν σάκεʼ ὤμοισι κλίναντες{l]
[l [n}11.594{]}δούρατʼ ἀνασχόμενοι· τῶν δʼ ἀντίος ἤλυθεν Αἴας.{l]
[l [n}11.595{]}στῆ δὲ μεταστρεφθείς, ἐπεὶ ἵκετο ἔθνος ἑταίρων.{l]{para]
[para}[l [n}11.596{]}ὣς οἳ μὲν μάρναντο δέμας πυρὸς αἰθομένοιο·{l]
[l [n}11.597{]}Νέστορα δʼ ἐκ πολέμοιο φέρον Νηλήϊαι ἵπποι{l]
[l [n}11.598{]}ἱδρῶσαι, ἦγον δὲ Μαχάονα ποιμένα λαῶν.{l]
[l [n}11.599{]}τὸν δὲ ἰδὼν ἐνόησε ποδάρκης δῖος Ἀχιλλεύς·{l]
[l [n}11.600{]}ἑστήκει γὰρ ἐπὶ πρυμνῇ μεγακήτεϊ νηῒ{l]
[l [n}11.601{]}εἰσορόων πόνον αἰπὺν ἰῶκά τε δακρυόεσσαν.{l]
[l [n}11.602{]}αἶψα δʼ ἑταῖρον ἑὸν Πατροκλῆα προσέειπε{l]
[l [n}11.603{]}φθεγξάμενος παρὰ νηός· ὃ δὲ κλισίηθεν ἀκούσας{l]
[l [n}11.604{]}ἔκμολεν ἶσος Ἄρηϊ, κακοῦ δʼ ἄρα οἱ πέλεν ἀρχή.{l]
[l [n}11.605{]}τὸν πρότερος προσέειπε Μενοιτίου ἄλκιμος υἱός·{l]
[q}[l [n}11.606{]}τίπτέ με κικλήσκεις Ἀχιλεῦ; τί δέ σε χρεὼ ἐμεῖο;{l]{q][l [n}11.607{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}11.608{]}δῖε Μενοιτιάδη τῷ ἐμῷ κεχαρισμένε θυμῷ{l]
[l [n}11.609{]}νῦν ὀΐω περὶ γούνατʼ ἐμὰ στήσεσθαι Ἀχαιοὺς{l]
[l [n}11.610{]}λισσομένους· χρειὼ γὰρ ἱκάνεται οὐκέτʼ ἀνεκτός.{l]
[l [n}11.611{]}ἀλλʼ ἴθι νῦν Πάτροκλε Διῒ φίλε Νέστορʼ ἔρειο{l]
[l [n}11.612{]}ὅν τινα τοῦτον ἄγει βεβλημένον ἐκ πολέμοιο·{l]
[l [n}11.613{]}ἤτοι μὲν τά γʼ ὄπισθε Μαχάονι πάντα ἔοικε{l]
[l [n}11.614{]}τῷ Ἀσκληπιάδῃ, ἀτὰρ οὐκ ἴδον ὄμματα φωτός·{l]
[l [n}11.615{]}ἵπποι γάρ με παρήϊξαν πρόσσω μεμαυῖαι.{l]{q]{para]
[para}[l [n}11.616{]}ὣς φάτο, Πάτροκλος δὲ φίλῳ ἐπεπείθεθʼ ἑταίρῳ,{l]
[l [n}11.617{]}βῆ δὲ θέειν παρά τε κλισίας καὶ νῆας Ἀχαιῶν.{l]{para]
[para}[l [n}11.618{]}οἳ δʼ ὅτε δὴ κλισίην Νηληϊάδεω ἀφίκοντο,{l]
[l [n}11.619{]}αὐτοὶ μέν ῥʼ ἀπέβησαν ἐπὶ χθόνα πουλυβότειραν,{l]
[l [n}11.620{]}ἵππους δʼ Εὐρυμέδων θεράπων λύε τοῖο γέροντος{l]
[l [n}11.621{]}ἐξ ὀχέων· τοὶ δʼ ἱδρῶ ἀπεψύχοντο χιτώνων{l]
[l [n}11.622{]}στάντε ποτὶ πνοιὴν παρὰ θῖνʼ ἁλός· αὐτὰρ ἔπειτα{l]
[l [n}11.623{]}ἐς κλισίην ἐλθόντες ἐπὶ κλισμοῖσι κάθιζον.{l]
[l [n}11.624{]}τοῖσι δὲ τεῦχε κυκειῶ ἐϋπλόκαμος Ἑκαμήδη,{l]
[l [n}11.625{]}τὴν ἄρετʼ ἐκ Τενέδοιο γέρων, ὅτε πέρσεν Ἀχιλλεύς,{l]
[l [n}11.626{]}θυγατέρʼ Ἀρσινόου μεγαλήτορος, ἥν οἱ Ἀχαιοὶ{l]
[l [n}11.627{]}ἔξελον οὕνεκα βουλῇ ἀριστεύεσκεν ἁπάντων.{l]
[l [n}11.628{]}ἥ σφωϊν πρῶτον μὲν ἐπιπροΐηλε τράπεζαν{l]
[l [n}11.629{]}καλὴν κυανόπεζαν ἐΰξοον, αὐτὰρ ἐπʼ αὐτῆς{l]
[l [n}11.630{]}χάλκειον κάνεον, ἐπὶ δὲ κρόμυον ποτῷ ὄψον,{l]
[l [n}11.631{]}ἠδὲ μέλι χλωρόν, παρὰ δʼ ἀλφίτου ἱεροῦ ἀκτήν,{l]
[l [n}11.632{]}πὰρ δὲ δέπας περικαλλές, ὃ οἴκοθεν ἦγʼ ὁ γεραιός,{l]
[l [n}11.633{]}χρυσείοις ἥλοισι πεπαρμένον· οὔατα δʼ αὐτοῦ{l]
[l [n}11.634{]}τέσσαρʼ ἔσαν, δοιαὶ δὲ πελειάδες ἀμφὶς ἕκαστον{l]
[l [n}11.635{]}χρύσειαι νεμέθοντο, δύω δʼ ὑπὸ πυθμένες ἦσαν.{l]
[l [n}11.636{]}ἄλλος μὲν μογέων ἀποκινήσασκε τραπέζης{l]
[l [n}11.637{]}πλεῖον ἐόν, Νέστωρ δʼ ὁ γέρων ἀμογητὶ ἄειρεν.{l]
[l [n}11.638{]}ἐν τῷ ῥά σφι κύκησε γυνὴ ἐϊκυῖα θεῇσιν{l]
[l [n}11.639{]}οἴνῳ Πραμνείῳ, ἐπὶ δʼ αἴγειον κνῆ τυρὸν{l]
[l [n}11.640{]}κνήστι χαλκείῃ, ἐπὶ δʼ ἄλφιτα λευκὰ πάλυνε,{l]
[l [n}11.641{]}πινέμεναι δʼ ἐκέλευσεν, ἐπεί ῥʼ ὥπλισσε κυκειῶ.{l]
[l [n}11.642{]}τὼ δʼ ἐπεὶ οὖν πίνοντʼ ἀφέτην πολυκαγκέα δίψαν{l]
[l [n}11.643{]}μύθοισιν τέρποντο πρὸς ἀλλήλους ἐνέποντες,{l]
[l [n}11.644{]}Πάτροκλος δὲ θύρῃσιν ἐφίστατο ἰσόθεος φώς.{l]
[l [n}11.645{]}τὸν δὲ ἰδὼν ὁ γεραιὸς ἀπὸ θρόνου ὦρτο φαεινοῦ,{l]
[l [n}11.646{]}ἐς δʼ ἄγε χειρὸς ἑλών, κατὰ δʼ ἑδριάασθαι ἄνωγε.{l]
[l [n}11.647{]}Πάτροκλος δʼ ἑτέρωθεν ἀναίνετο εἶπέ τε μῦθον·{l]
[q}[l [n}11.648{]}οὐχ ἕδος ἐστὶ γεραιὲ διοτρεφές, οὐδέ με πείσεις.{l]
[l [n}11.649{]}αἰδοῖος νεμεσητὸς ὅ με προέηκε πυθέσθαι{l]
[l [n}11.650{]}ὅν τινα τοῦτον ἄγεις βεβλημένον· ἀλλὰ καὶ αὐτὸς{l]
[l [n}11.651{]}γιγνώσκω, ὁρόω δὲ Μαχάονα ποιμένα λαῶν.{l]
[l [n}11.652{]}νῦν δὲ ἔπος ἐρέων πάλιν ἄγγελος εἶμʼ Ἀχιλῆϊ.{l]
[l [n}11.653{]}εὖ δὲ σὺ οἶσθα γεραιὲ διοτρεφές, οἷος ἐκεῖνος{l]
[l [n}11.654{]}δεινὸς ἀνήρ· τάχα κεν καὶ ἀναίτιον αἰτιόῳτο.{l]{q]{para]
[para}[l [n}11.655{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}11.656{]}τίπτε τὰρ ὧδʼ Ἀχιλεὺς ὀλοφύρεται υἷας Ἀχαιῶν,{l]
[l [n}11.657{]}ὅσσοι δὴ βέλεσιν βεβλήαται; οὐδέ τι οἶδε{l]
[l [n}11.658{]}πένθεος, ὅσσον ὄρωρε κατὰ στρατόν· οἳ γὰρ ἄριστοι{l]
[l [n}11.659{]}ἐν νηυσὶν κέαται βεβλημένοι οὐτάμενοί τε.{l]
[l [n}11.660{]}βέβληται μὲν ὃ Τυδεΐδης κρατερὸς Διομήδης,{l]
[l [n}11.661{]}οὔτασται δʼ Ὀδυσεὺς δουρὶ κλυτὸς ἠδʼ Ἀγαμέμνων·{l]
[l [n}11.662{]}βέβληται δὲ καὶ Εὐρύπυλος κατὰ μηρὸν ὀϊστῷ·{l]
[l [n}11.663{]}τοῦτον δʼ ἄλλον ἐγὼ νέον ἤγαγον ἐκ πολέμοιο{l]
[l [n}11.664{]}ἰῷ ἀπὸ νευρῆς βεβλημένον. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}11.665{]}ἐσθλὸς ἐὼν Δαναῶν οὐ κήδεται οὐδʼ ἐλεαίρει.{l]
[l [n}11.666{]}ἦ μένει εἰς ὅ κε δὴ νῆες θοαὶ ἄγχι θαλάσσης{l]
[l [n}11.667{]}Ἀργείων ἀέκητι πυρὸς δηΐοιο θέρωνται,{l]
[l [n}11.668{]}αὐτοί τε κτεινώμεθʼ ἐπισχερώ; οὐ γὰρ ἐμὴ ἲς{l]
[l [n}11.669{]}ἔσθʼ οἵη πάρος ἔσκεν ἐνὶ γναμπτοῖσι μέλεσσιν.{l]
[l [n}11.670{]}εἴθʼ ὣς ἡβώοιμι βίη δέ μοι ἔμπεδος εἴη{l]
[l [n}11.671{]}ὡς ὁπότʼ Ἠλείοισι καὶ ἡμῖν νεῖκος ἐτύχθη{l]
[l [n}11.672{]}ἀμφὶ βοηλασίῃ, ὅτʼ ἐγὼ κτάνον Ἰτυμονῆα{l]
[l [n}11.673{]}ἐσθλὸν Ὑπειροχίδην, ὃς ἐν Ἤλιδι ναιετάασκε,{l]
[l [n}11.674{]}ῥύσιʼ ἐλαυνόμενος· ὃ δʼ ἀμύνων ᾗσι βόεσσιν{l]
[l [n}11.675{]}ἔβλητʼ ἐν πρώτοισιν ἐμῆς ἀπὸ χειρὸς ἄκοντι,{l]
[l [n}11.676{]}κὰδ δʼ ἔπεσεν, λαοὶ δὲ περίτρεσαν ἀγροιῶται.{l]
[l [n}11.677{]}ληΐδα δʼ ἐκ πεδίου συνελάσσαμεν ἤλιθα πολλὴν{l]
[l [n}11.678{]}πεντήκοντα βοῶν ἀγέλας, τόσα πώεα οἰῶν,{l]
[l [n}11.679{]}τόσσα συῶν συβόσια, τόσʼ αἰπόλια πλατέʼ αἰγῶν,{l]
[l [n}11.680{]}ἵππους δὲ ξανθὰς ἑκατὸν καὶ πεντήκοντα{l]
[l [n}11.681{]}πάσας θηλείας, πολλῇσι δὲ πῶλοι ὑπῆσαν.{l]
[l [n}11.682{]}καὶ τὰ μὲν ἠλασάμεσθα Πύλον Νηλήϊον εἴσω{l]
[l [n}11.683{]}ἐννύχιοι προτὶ ἄστυ· γεγήθει δὲ φρένα Νηλεύς,{l]
[l [n}11.684{]}οὕνεκά μοι τύχε πολλὰ νέῳ πόλεμον δὲ κιόντι.{l]
[l [n}11.685{]}κήρυκες δʼ ἐλίγαινον ἅμʼ ἠοῖ φαινομένηφι{l]
[l [n}11.686{]}τοὺς ἴμεν οἷσι χρεῖος ὀφείλετʼ ἐν Ἤλιδι δίῃ·{l]
[l [n}11.687{]}οἳ δὲ συναγρόμενοι Πυλίων ἡγήτορες ἄνδρες{l]
[l [n}11.688{]}δαίτρευον· πολέσιν γὰρ Ἐπειοὶ χρεῖος ὄφειλον,{l]
[l [n}11.689{]}ὡς ἡμεῖς παῦροι κεκακωμένοι ἐν Πύλῳ ἦμεν·{l]
[l [n}11.690{]}ἐλθὼν γάρ ῥʼ ἐκάκωσε βίη Ἡρακληείη{l]
[l [n}11.691{]}τῶν προτέρων ἐτέων, κατὰ δʼ ἔκταθεν ὅσσοι ἄριστοι·{l]
[l [n}11.692{]}δώδεκα γὰρ Νηλῆος ἀμύμονος υἱέες ἦμεν·{l]
[l [n}11.693{]}τῶν οἶος λιπόμην, οἳ δʼ ἄλλοι πάντες ὄλοντο.{l]
[l [n}11.694{]}ταῦθʼ ὑπερηφανέοντες Ἐπειοὶ χαλκοχίτωνες{l]
[l [n}11.695{]}ἡμέας ὑβρίζοντες ἀτάσθαλα μηχανόωντο.{l]
[l [n}11.696{]}ἐκ δʼ ὃ γέρων ἀγέλην τε βοῶν καὶ πῶϋ μέγʼ οἰῶν{l]
[l [n}11.697{]}εἵλετο κρινάμενος τριηκόσιʼ ἠδὲ νομῆας.{l]
[l [n}11.698{]}καὶ γὰρ τῷ χρεῖος μέγʼ ὀφείλετʼ ἐν Ἤλιδι δίῃ{l]
[l [n}11.699{]}τέσσαρες ἀθλοφόροι ἵπποι αὐτοῖσιν ὄχεσφιν{l]
[l [n}11.700{]}ἐλθόντες μετʼ ἄεθλα· περὶ τρίποδος γὰρ ἔμελλον{l]
[l [n}11.701{]}θεύσεσθαι· τοὺς δʼ αὖθι ἄναξ ἀνδρῶν Αὐγείας{l]
[l [n}11.702{]}κάσχεθε, τὸν δʼ ἐλατῆρʼ ἀφίει ἀκαχήμενον ἵππων.{l]
[l [n}11.703{]}τῶν ὃ γέρων ἐπέων κεχολωμένος ἠδὲ καὶ ἔργων{l]
[l [n}11.704{]}ἐξέλετʼ ἄσπετα πολλά· τὰ δʼ ἄλλʼ ἐς δῆμον ἔδωκε{l]
[l [n}11.705{]}δαιτρεύειν, μή τίς οἱ ἀτεμβόμενος κίοι ἴσης.{l]
[l [n}11.706{]}ἡμεῖς μὲν τὰ ἕκαστα διείπομεν, ἀμφί τε ἄστυ{l]
[l [n}11.707{]}ἕρδομεν ἱρὰ θεοῖς· οἳ δὲ τρίτῳ ἤματι πάντες{l]
[l [n}11.708{]}ἦλθον ὁμῶς αὐτοί τε πολεῖς καὶ μώνυχες ἵπποι{l]
[l [n}11.709{]}πανσυδίῃ· μετὰ δέ σφι Μολίονε θωρήσσοντο{l]
[l [n}11.710{]}παῖδʼ ἔτʼ ἐόντʼ, οὔ πω μάλα εἰδότε θούριδος ἀλκῆς.{l]
[l [n}11.711{]}ἔστι δέ τις Θρυόεσσα πόλις αἰπεῖα κολώνη{l]
[l [n}11.712{]}τηλοῦ ἐπʼ Ἀλφειῷ, νεάτη Πύλου ἠμαθόεντος·{l]
[l [n}11.713{]}τὴν ἀμφεστρατόωντο διαρραῖσαι μεμαῶτες.{l]
[l [n}11.714{]}ἀλλʼ ὅτε πᾶν πεδίον μετεκίαθον, ἄμμι δʼ Ἀθήνη{l]
[l [n}11.715{]}ἄγγελος ἦλθε θέουσʼ ἀπʼ Ὀλύμπου θωρήσσεσθαι{l]
[l [n}11.716{]}ἔννυχος, οὐδʼ ἀέκοντα Πύλον κάτα λαὸν ἄγειρεν{l]
[l [n}11.717{]}ἀλλὰ μάλʼ ἐσσυμένους πολεμίζειν. οὐδέ με Νηλεὺς{l]
[l [n}11.718{]}εἴα θωρήσσεσθαι, ἀπέκρυψεν δέ μοι ἵππους·{l]
[l [n}11.719{]}οὐ γάρ πώ τί μʼ ἔφη ἴδμεν πολεμήϊα ἔργα.{l]
[l [n}11.720{]}ἀλλὰ καὶ ὧς ἱππεῦσι μετέπρεπον ἡμετέροισι{l]
[l [n}11.721{]}καὶ πεζός περ ἐών, ἐπεὶ ὧς ἄγε νεῖκος Ἀθήνη.{l]
[l [n}11.722{]}ἔστι δέ τις ποταμὸς Μινυήϊος εἰς ἅλα βάλλων{l]
[l [n}11.723{]}ἐγγύθεν Ἀρήνης, ὅθι μείναμεν Ἠῶ δῖαν{l]
[l [n}11.724{]}ἱππῆες Πυλίων, τὰ δʼ ἐπέρρεον ἔθνεα πεζῶν.{l]
[l [n}11.725{]}ἔνθεν πανσυδίῃ σὺν τεύχεσι θωρηχθέντες{l]
[l [n}11.726{]}ἔνδιοι ἱκόμεσθʼ ἱερὸν ῥόον Ἀλφειοῖο.{l]
[l [n}11.727{]}ἔνθα Διὶ ῥέξαντες ὑπερμενεῖ ἱερὰ καλά,{l]
[l [n}11.728{]}ταῦρον δʼ Ἀλφειῷ, ταῦρον δὲ Ποσειδάωνι,{l]
[l [n}11.729{]}αὐτὰρ Ἀθηναίη γλαυκώπιδι βοῦν ἀγελαίην,{l]
[l [n}11.730{]}δόρπον ἔπειθʼ ἑλόμεσθα κατὰ στρατὸν ἐν τελέεσσι,{l]
[l [n}11.731{]}καὶ κατεκοιμήθημεν ἐν ἔντεσιν οἷσιν ἕκαστος{l]
[l [n}11.732{]}ἀμφὶ ῥοὰς ποταμοῖο. ἀτὰρ μεγάθυμοι Ἐπειοὶ{l]
[l [n}11.733{]}ἀμφέσταν δὴ ἄστυ διαρραῖσαι μεμαῶτες·{l]
[l [n}11.734{]}ἀλλά σφι προπάροιθε φάνη μέγα ἔργον Ἄρηος·{l]
[l [n}11.735{]}εὖτε γὰρ ἠέλιος φαέθων ὑπερέσχεθε γαίης,{l]
[l [n}11.736{]}συμφερόμεσθα μάχῃ Διί τʼ εὐχόμενοι καὶ Ἀθήνῃ.{l]
[l [n}11.737{]}ἀλλʼ ὅτε δὴ Πυλίων καὶ Ἐπειῶν ἔπλετο νεῖκος,{l]
[l [n}11.738{]}πρῶτος ἐγὼν ἕλον ἄνδρα, κόμισσα δὲ μώνυχας ἵππους,{l]
[l [n}11.739{]}Μούλιον αἰχμητήν· γαμβρὸς δʼ ἦν Αὐγείαο,{l]
[l [n}11.740{]}πρεσβυτάτην δὲ θύγατρʼ εἶχε ξανθὴν Ἀγαμήδην,{l]
[l [n}11.741{]}ἣ τόσα φάρμακα ᾔδη ὅσα τρέφει εὐρεῖα χθών.{l]
[l [n}11.742{]}τὸν μὲν ἐγὼ προσιόντα βάλον χαλκήρεϊ δουρί,{l]
[l [n}11.743{]}ἤριπε δʼ ἐν κονίῃσιν· ἐγὼ δʼ ἐς δίφρον ὀρούσας{l]
[l [n}11.744{]}στῆν ῥα μετὰ προμάχοισιν· ἀτὰρ μεγάθυμοι Ἐπειοὶ{l]
[l [n}11.745{]}ἔτρεσαν ἄλλυδις ἄλλος, ἐπεὶ ἴδον ἄνδρα πεσόντα{l]
[l [n}11.746{]}ἡγεμόνʼ ἱππήων, ὃς ἀριστεύεσκε μάχεσθαι.{l]
[l [n}11.747{]}αὐτὰρ ἐγὼν ἐπόρουσα κελαινῇ λαίλαπι ἶσος,{l]
[l [n}11.748{]}πεντήκοντα δʼ ἕλον δίφρους, δύο δʼ ἀμφὶς ἕκαστον{l]
[l [n}11.749{]}φῶτες ὀδὰξ ἕλον οὖδας ἐμῷ ὑπὸ δουρὶ δαμέντες.{l]
[l [n}11.750{]}καί νύ κεν Ἀκτορίωνε Μολίονε παῖδʼ ἀλάπαξα,{l]
[l [n}11.751{]}εἰ μή σφωε πατὴρ εὐρὺ κρείων ἐνοσίχθων{l]
[l [n}11.752{]}ἐκ πολέμου ἐσάωσε καλύψας ἠέρι πολλῇ.{l]
[l [n}11.753{]}ἔνθα Ζεὺς Πυλίοισι μέγα κράτος ἐγγυάλιξε·{l]
[l [n}11.754{]}τόφρα γὰρ οὖν ἑπόμεσθα διὰ σπιδέος πεδίοιο{l]
[l [n}11.755{]}κτείνοντές τʼ αὐτοὺς ἀνά τʼ ἔντεα καλὰ λέγοντες,{l]
[l [n}11.756{]}ὄφρʼ ἐπὶ Βουπρασίου πολυπύρου βήσαμεν ἵππους{l]
[l [n}11.757{]}πέτρης τʼ Ὠλενίης, καὶ Ἀλησίου ἔνθα κολώνη{l]
[l [n}11.758{]}κέκληται· ὅθεν αὖτις ἀπέτραπε λαὸν Ἀθήνη.{l]
[l [n}11.759{]}ἔνθʼ ἄνδρα κτείνας πύματον λίπον· αὐτὰρ Ἀχαιοὶ{l]
[l [n}11.760{]}ἂψ ἀπὸ Βουπρασίοιο Πύλονδʼ ἔχον ὠκέας ἵππους,{l]
[l [n}11.761{]}πάντες δʼ εὐχετόωντο θεῶν Διὶ Νέστορί τʼ ἀνδρῶν.{l]
[l [n}11.762{]}ὣς ἔον, εἴ ποτʼ ἔον γε, μετʼ ἀνδράσιν. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}11.763{]}οἶος τῆς ἀρετῆς ἀπονήσεται· ἦ τέ μιν οἴω{l]
[l [n}11.764{]}πολλὰ μετακλαύσεσθαι ἐπεί κʼ ἀπὸ λαὸς ὄληται.{l]
[l [n}11.765{]}ὦ πέπον ἦ μὲν σοί γε Μενοίτιος ὧδʼ ἐπέτελλεν{l]
[l [n}11.766{]}ἤματι τῷ ὅτε σʼ ἐκ Φθίης Ἀγαμέμνονι πέμπε,{l]
[l [n}11.767{]}νῶϊ δέ τʼ ἔνδον ἐόντες ἐγὼ καὶ δῖος Ὀδυσσεὺς{l]
[l [n}11.768{]}πάντα μάλʼ ἐν μεγάροις ἠκούομεν ὡς ἐπέτελλε.{l]
[l [n}11.769{]}Πηλῆος δʼ ἱκόμεσθα δόμους εὖ ναιετάοντας{l]
[l [n}11.770{]}λαὸν ἀγείροντες κατʼ Ἀχαιΐδα πουλυβότειραν.{l]
[l [n}11.771{]}ἔνθα δʼ ἔπειθʼ ἥρωα Μενοίτιον εὕρομεν ἔνδον{l]
[l [n}11.772{]}ἠδὲ σέ, πὰρ δʼ Ἀχιλῆα· γέρων δʼ ἱππηλάτα Πηλεὺς{l]
[l [n}11.773{]}πίονα μηρία καῖε βοὸς Διὶ τερπικεραύνῳ{l]
[l [n}11.774{]}αὐλῆς ἐν χόρτῳ· ἔχε δὲ χρύσειον ἄλεισον{l]
[l [n}11.775{]}σπένδων αἴθοπα οἶνον ἐπʼ αἰθομένοις ἱεροῖσι.{l]
[l [n}11.776{]}σφῶϊ μὲν ἀμφὶ βοὸς ἕπετον κρέα, νῶϊ δʼ ἔπειτα{l]
[l [n}11.777{]}στῆμεν ἐνὶ προθύροισι· ταφὼν δʼ ἀνόρουσεν Ἀχιλλεύς,{l]
[l [n}11.778{]}ἐς δʼ ἄγε χειρὸς ἑλών, κατὰ δʼ ἑδριάασθαι ἄνωγε,{l]
[l [n}11.779{]}ξείνιά τʼ εὖ παρέθηκεν, ἅ τε ξείνοις θέμις ἐστίν.{l]
[l [n}11.780{]}αὐτὰρ ἐπεὶ τάρπημεν ἐδητύος ἠδὲ ποτῆτος,{l]
[l [n}11.781{]}ἦρχον ἐγὼ μύθοιο κελεύων ὔμμʼ ἅμʼ ἕπεσθαι·{l]
[l [n}11.782{]}σφὼ δὲ μάλʼ ἠθέλετον, τὼ δʼ ἄμφω πόλλʼ ἐπέτελλον.{l]
[l [n}11.783{]}Πηλεὺς μὲν ᾧ παιδὶ γέρων ἐπέτελλʼ Ἀχιλῆϊ{l]
[l [n}11.784{]}αἰὲν ἀριστεύειν καὶ ὑπείροχον ἔμμεναι ἄλλων·{l]
[l [n}11.785{]}σοὶ δʼ αὖθʼ ὧδʼ ἐπέτελλε Μενοίτιος Ἄκτορος υἱός·{l]
[q}[l [n}11.786{]}τέκνον ἐμὸν γενεῇ μὲν ὑπέρτερός ἐστιν Ἀχιλλεύς,{l]
[l [n}11.787{]}πρεσβύτερος δὲ σύ ἐσσι· βίῃ δʼ ὅ γε πολλὸν ἀμείνων.{l]
[l [n}11.788{]}ἀλλʼ εὖ οἱ φάσθαι πυκινὸν ἔπος ἠδʼ ὑποθέσθαι{l]
[l [n}11.789{]}καί οἱ σημαίνειν· ὃ δὲ πείσεται εἰς ἀγαθόν περ.{l]{q][l [n}11.790{]}ὣς ἐπέτελλʼ ὃ γέρων, σὺ δὲ λήθεαι· ἀλλʼ ἔτι καὶ νῦν{l]
[l [n}11.791{]}ταῦτʼ εἴποις Ἀχιλῆϊ δαΐφρονι αἴ κε πίθηται.{l]
[l [n}11.792{]}τίς δʼ οἶδʼ εἴ κέν οἱ σὺν δαίμονι θυμὸν ὀρίναις{l]
[l [n}11.793{]}παρειπών; ἀγαθὴ δὲ παραίφασίς ἐστιν ἑταίρου.{l]
[l [n}11.794{]}εἰ δέ τινα φρεσὶν ᾗσι θεοπροπίην ἀλεείνει{l]
[l [n}11.795{]}καί τινά οἱ πὰρ Ζηνὸς ἐπέφραδε πότνια μήτηρ,{l]
[l [n}11.796{]}ἀλλὰ σέ περ προέτω, ἅμα δʼ ἄλλος λαὸς ἑπέσθω{l]
[l [n}11.797{]}Μυρμιδόνων, αἴ κέν τι φόως Δαναοῖσι γένηαι·{l]
[l [n}11.798{]}καί τοι τεύχεα καλὰ δότω πόλεμον δὲ φέρεσθαι,{l]
[l [n}11.799{]}αἴ κέ σε τῷ εἴσκοντες ἀπόσχωνται πολέμοιο{l]
[l [n}11.800{]}Τρῶες, ἀναπνεύσωσι δʼ ἀρήϊοι υἷες Ἀχαιῶν{l]
[l [n}11.801{]}τειρόμενοι· ὀλίγη δέ τʼ ἀνάπνευσις πολέμοιο.{l]
[l [n}11.802{]}ῥεῖα δέ κʼ ἀκμῆτες κεκμηότας ἄνδρας ἀϋτῇ{l]
[l [n}11.803{]}ὤσαισθε προτὶ ἄστυ νεῶν ἄπο καὶ κλισιάων.{l]{q]{para]
[para}[l [n}11.804{]}ὣς φάτο, τῷ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ὄρινε,{l]
[l [n}11.805{]}βῆ δὲ θέειν παρὰ νῆας ἐπʼ Αἰακίδην Ἀχιλῆα.{l]
[l [n}11.806{]}ἀλλʼ ὅτε δὴ κατὰ νῆας Ὀδυσσῆος θείοιο{l]
[l [n}11.807{]}ἷξε θέων Πάτροκλος, ἵνά σφʼ ἀγορή τε θέμις τε{l]
[l [n}11.808{]}ἤην, τῇ δὴ καί σφι θεῶν ἐτετεύχατο βωμοί,{l]
[l [n}11.809{]}ἔνθά οἱ Εὐρύπυλος βεβλημένος ἀντεβόλησε{l]
[l [n}11.810{]}διογενὴς Εὐαιμονίδης κατὰ μηρὸν ὀϊστῷ{l]
[l [n}11.811{]}σκάζων ἐκ πολέμου· κατὰ δὲ νότιος ῥέεν ἱδρὼς{l]
[l [n}11.812{]}ὤμων καὶ κεφαλῆς, ἀπὸ δʼ ἕλκεος ἀργαλέοιο{l]
[l [n}11.813{]}αἷμα μέλαν κελάρυζε· νόος γε μὲν ἔμπεδος ἦεν.{l]
[l [n}11.814{]}τὸν δὲ ἰδὼν ᾤκτειρε Μενοιτίου ἄλκιμος υἱός,{l]
[l [n}11.815{]}καί ῥʼ ὀλοφυρόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}11.816{]}ἆ δειλοὶ Δαναῶν ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}11.817{]}ὣς ἄρʼ ἐμέλλετε τῆλε φίλων καὶ πατρίδος αἴης{l]
[l [n}11.818{]}ἄσειν ἐν Τροίῃ ταχέας κύνας ἀργέτι δημῷ.{l]
[l [n}11.819{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ διοτρεφὲς Εὐρύπυλʼ ἥρως,{l]
[l [n}11.820{]}ἤ ῥʼ ἔτι που σχήσουσι πελώριον Ἕκτορʼ Ἀχαιοί,{l]
[l [n}11.821{]}ἦ ἤδη φθίσονται ὑπʼ αὐτοῦ δουρὶ δαμέντες;{l]{q]{para]
[para}[l [n}11.822{]}τὸν δʼ αὖτʼ Εὐρύπυλος βεβλημένος ἀντίον ηὔδα·{l]
[q}[l [n}11.823{]}οὐκέτι διογενὲς Πατρόκλεες ἄλκαρ Ἀχαιῶν{l]
[l [n}11.824{]}ἔσσεται, ἀλλʼ ἐν νηυσὶ μελαίνῃσιν πεσέονται.{l]
[l [n}11.825{]}οἳ μὲν γὰρ δὴ πάντες, ὅσοι πάρος ἦσαν ἄριστοι,{l]
[l [n}11.826{]}ἐν νηυσὶν κέαται βεβλημένοι οὐτάμενοί τε{l]
[l [n}11.827{]}χερσὶν ὕπο Τρώων· τῶν δὲ σθένος ὄρνυται αἰέν.{l]
[l [n}11.828{]}ἀλλʼ ἐμὲ μὲν σὺ σάωσον ἄγων ἐπὶ νῆα μέλαιναν,{l]
[l [n}11.829{]}μηροῦ δʼ ἔκταμʼ ὀϊστόν, ἀπʼ αὐτοῦ δʼ αἷμα κελαινὸν{l]
[l [n}11.830{]}νίζʼ ὕδατι λιαρῷ, ἐπὶ δʼ ἤπια φάρμακα πάσσε{l]
[l [n}11.831{]}ἐσθλά, τά σε προτί φασιν Ἀχιλλῆος δεδιδάχθαι,{l]
[l [n}11.832{]}ὃν Χείρων ἐδίδαξε δικαιότατος Κενταύρων.{l]
[l [n}11.833{]}ἰητροὶ μὲν γὰρ Ποδαλείριος ἠδὲ Μαχάων{l]
[l [n}11.834{]}τὸν μὲν ἐνὶ κλισίῃσιν ὀΐομαι ἕλκος ἔχοντα{l]
[l [n}11.835{]}χρηΐζοντα καὶ αὐτὸν ἀμύμονος ἰητῆρος{l]
[l [n}11.836{]}κεῖσθαι· ὃ δʼ ἐν πεδίῳ Τρώων μένει ὀξὺν Ἄρηα.{l]{q]{para]
[para}[l [n}11.837{]}τὸν δʼ αὖτε προσέειπε Μενοιτίου ἄλκιμος υἱός·{l]
[q}[l [n}11.838{]}πῶς τὰρ ἔοι τάδε ἔργα; τί ῥέξομεν Εὐρύπυλʼ ἥρως;{l]
[l [n}11.839{]}ἔρχομαι ὄφρʼ Ἀχιλῆϊ δαΐφρονι μῦθον ἐνίσπω{l]
[l [n}11.840{]}ὃν Νέστωρ ἐπέτελλε Γερήνιος οὖρος Ἀχαιῶν·{l]
[l [n}11.841{]}ἀλλʼ οὐδʼ ὧς περ σεῖο μεθήσω τειρομένοιο.{l]{q]{para]
[para}[l [n}11.842{]}ἦ, καὶ ὑπὸ στέρνοιο λαβὼν ἄγε ποιμένα λαῶν{l]
[l [n}11.843{]}ἐς κλισίην· θεράπων δὲ ἰδὼν ὑπέχευε βοείας.{l]
[l [n}11.844{]}ἔνθά μιν ἐκτανύσας ἐκ μηροῦ τάμνε μαχαίρῃ{l]
[l [n}11.845{]}ὀξὺ βέλος περιπευκές, ἀπʼ αὐτοῦ δʼ αἷμα κελαινὸν{l]
[l [n}11.846{]}νίζʼ ὕδατι λιαρῷ, ἐπὶ δὲ ῥίζαν βάλε πικρὴν{l]
[l [n}11.847{]}χερσὶ διατρίψας ὀδυνήφατον, ἥ οἱ ἁπάσας{l]
[l [n}11.848{]}ἔσχʼ ὀδύνας· τὸ μὲν ἕλκος ἐτέρσετο, παύσατο δʼ αἷμα.{l]{para]
{book]
[book [n}12{]}
[para}[l [n}12.1{]}ὣς ὃ μὲν ἐν κλισίῃσι Μενοιτίου ἄλκιμος υἱὸς{l]
[l [n}12.2{]}ἰᾶτʼ Εὐρύπυλον βεβλημένον· οἳ δὲ μάχοντο{l]
[l [n}12.3{]}Ἀργεῖοι καὶ Τρῶες ὁμιλαδόν· οὐδʼ ἄρʼ ἔμελλε{l]
[l [n}12.4{]}τάφρος ἔτι σχήσειν Δαναῶν καὶ τεῖχος ὕπερθεν{l]
[l [n}12.5{]}εὐρύ, τὸ ποιήσαντο νεῶν ὕπερ, ἀμφὶ δὲ τάφρον{l]
[l [n}12.6{]}ἤλασαν· οὐδὲ θεοῖσι δόσαν κλειτὰς ἑκατόμβας·{l]
[l [n}12.7{]}ὄφρά σφιν νῆάς τε θοὰς καὶ ληΐδα πολλὴν{l]
[l [n}12.8{]}ἐντὸς ἔχον ῥύοιτο· θεῶν δʼ ἀέκητι τέτυκτο{l]
[l [n}12.9{]}ἀθανάτων· τὸ καὶ οὔ τι πολὺν χρόνον ἔμπεδον ἦεν.{l]
[l [n}12.10{]}ὄφρα μὲν Ἕκτωρ ζωὸς ἔην καὶ μήνιʼ Ἀχιλλεὺς{l]
[l [n}12.11{]}καὶ Πριάμοιο ἄνακτος ἀπόρθητος πόλις ἔπλεν,{l]
[l [n}12.12{]}τόφρα δὲ καὶ μέγα τεῖχος Ἀχαιῶν ἔμπεδον ἦεν.{l]
[l [n}12.13{]}αὐτὰρ ἐπεὶ κατὰ μὲν Τρώων θάνον ὅσσοι ἄριστοι,{l]
[l [n}12.14{]}πολλοὶ δʼ Ἀργείων οἳ μὲν δάμεν, οἳ δὲ λίποντο,{l]
[l [n}12.15{]}πέρθετο δὲ Πριάμοιο πόλις δεκάτῳ ἐνιαυτῷ,{l]
[l [n}12.16{]}Ἀργεῖοι δʼ ἐν νηυσὶ φίλην ἐς πατρίδʼ ἔβησαν,{l]
[l [n}12.17{]}δὴ τότε μητιόωντο Ποσειδάων καὶ Ἀπόλλων{l]
[l [n}12.18{]}τεῖχος ἀμαλδῦναι ποταμῶν μένος εἰσαγαγόντες.{l]
[l [n}12.19{]}ὅσσοι ἀπʼ Ἰδαίων ὀρέων ἅλα δὲ προρέουσι,{l]
[l [n}12.20{]}Ῥῆσός θʼ Ἑπτάπορός τε Κάρησός τε Ῥοδίος τε{l]
[l [n}12.21{]}Γρήνικός τε καὶ Αἴσηπος δῖός τε Σκάμανδρος{l]
[l [n}12.22{]}καὶ Σιμόεις, ὅθι πολλὰ βοάγρια καὶ τρυφάλειαι{l]
[l [n}12.23{]}κάππεσον ἐν κονίῃσι καὶ ἡμιθέων γένος ἀνδρῶν·{l]
[l [n}12.24{]}τῶν πάντων ὁμόσε στόματʼ ἔτραπε Φοῖβος Ἀπόλλων,{l]
[l [n}12.25{]}ἐννῆμαρ δʼ ἐς τεῖχος ἵει ῥόον· ὗε δʼ ἄρα Ζεὺς{l]
[l [n}12.26{]}συνεχές, ὄφρά κε θᾶσσον ἁλίπλοα τείχεα θείη.{l]
[l [n}12.27{]}αὐτὸς δʼ ἐννοσίγαιος ἔχων χείρεσσι τρίαιναν{l]
[l [n}12.28{]}ἡγεῖτʼ, ἐκ δʼ ἄρα πάντα θεμείλια κύμασι πέμπε{l]
[l [n}12.29{]}φιτρῶν καὶ λάων, τὰ θέσαν μογέοντες Ἀχαιοί,{l]
[l [n}12.30{]}λεῖα δʼ ἐποίησεν παρʼ ἀγάρροον Ἑλλήσποντον,{l]
[l [n}12.31{]}αὖτις δʼ ἠϊόνα μεγάλην ψαμάθοισι κάλυψε{l]
[l [n}12.32{]}τεῖχος ἀμαλδύνας· ποταμοὺς δʼ ἔτρεψε νέεσθαι{l]
[l [n}12.33{]}κὰρ ῥόον, ᾗ περ πρόσθεν ἵεν καλλίρροον ὕδωρ.{l]{para]
[para}[l [n}12.34{]}ὣς ἄρʼ ἔμελλον ὄπισθε Ποσειδάων καὶ Ἀπόλλων{l]
[l [n}12.35{]}θησέμεναι· τότε δʼ ἀμφὶ μάχη ἐνοπή τε δεδήει{l]
[l [n}12.36{]}τεῖχος ἐΰδμητον, κανάχιζε δὲ δούρατα πύργων{l]
[l [n}12.37{]}βαλλόμενʼ· Ἀργεῖοι δὲ Διὸς μάστιγι δαμέντες{l]
[l [n}12.38{]}νηυσὶν ἔπι γλαφυρῇσιν ἐελμένοι ἰσχανόωντο{l]
[l [n}12.39{]}Ἕκτορα δειδιότες, κρατερὸν μήστωρα φόβοιο·{l]
[l [n}12.40{]}αὐτὰρ ὅ γʼ ὡς τὸ πρόσθεν ἐμάρνατο ἶσος ἀέλλῃ·{l]
[l [n}12.41{]}ὡς δʼ ὅτʼ ἂν ἔν τε κύνεσσι καὶ ἀνδράσι θηρευτῇσι{l]
[l [n}12.42{]}κάπριος ἠὲ λέων στρέφεται σθένεϊ βλεμεαίνων·{l]
[l [n}12.43{]}οἳ δέ τε πυργηδὸν σφέας αὐτοὺς ἀρτύναντες{l]
[l [n}12.44{]}ἀντίον ἵστανται καὶ ἀκοντίζουσι θαμειὰς{l]
[l [n}12.45{]}αἰχμὰς ἐκ χειρῶν· τοῦ δʼ οὔ ποτε κυδάλιμον κῆρ{l]
[l [n}12.46{]}ταρβεῖ οὐδὲ φοβεῖται, ἀγηνορίη δέ μιν ἔκτα·{l]
[l [n}12.47{]}ταρφέα τε στρέφεται στίχας ἀνδρῶν πειρητίζων·{l]
[l [n}12.48{]}ὅππῃ τʼ ἰθύσῃ τῇ εἴκουσι στίχες ἀνδρῶν·{l]
[l [n}12.49{]}ὣς Ἕκτωρ ἀνʼ ὅμιλον ἰὼν ἐλλίσσεθʼ ἑταίρους{l]
[l [n}12.50{]}τάφρον ἐποτρύνων διαβαινέμεν· οὐδέ οἱ ἵπποι{l]
[l [n}12.51{]}τόλμων ὠκύποδες, μάλα δὲ χρεμέτιζον ἐπʼ ἄκρῳ{l]
[l [n}12.52{]}χείλει ἐφεσταότες· ἀπὸ γὰρ δειδίσσετο τάφρος{l]
[l [n}12.53{]}εὐρεῖʼ, οὔτʼ ἄρʼ ὑπερθορέειν σχεδὸν οὔτε περῆσαι{l]
[l [n}12.54{]}ῥηϊδίη· κρημνοὶ γὰρ ἐπηρεφέες περὶ πᾶσαν{l]
[l [n}12.55{]}ἕστασαν ἀμφοτέρωθεν, ὕπερθεν δὲ σκολόπεσσιν{l]
[l [n}12.56{]}ὀξέσιν ἠρήρει, τοὺς ἵστασαν υἷες Ἀχαιῶν{l]
[l [n}12.57{]}πυκνοὺς καὶ μεγάλους δηΐων ἀνδρῶν ἀλεωρήν.{l]
[l [n}12.58{]}ἔνθʼ οὔ κεν ῥέα ἵππος ἐΰτροχον ἅρμα τιταίνων{l]
[l [n}12.59{]}ἐσβαίη, πεζοὶ δὲ μενοίνεον εἰ τελέουσι.{l]
[l [n}12.60{]}δὴ τότε Πουλυδάμας θρασὺν Ἕκτορα εἶπε παραστάς·{l]
[q}[l [n}12.61{]}Ἕκτορ τʼ ἠδʼ ἄλλοι Τρώων ἀγοὶ ἠδʼ ἐπικούρων{l]
[l [n}12.62{]}ἀφραδέως διὰ τάφρον ἐλαύνομεν ὠκέας ἵππους·{l]
[l [n}12.63{]}ἣ δὲ μάλʼ ἀργαλέη περάαν· σκόλοπες γὰρ ἐν αὐτῇ{l]
[l [n}12.64{]}ὀξέες ἑστᾶσιν, ποτὶ δʼ αὐτοὺς τεῖχος Ἀχαιῶν,{l]
[l [n}12.65{]}ἔνθʼ οὔ πως ἔστιν καταβήμεναι οὐδὲ μάχεσθαι{l]
[l [n}12.66{]}ἱππεῦσι· στεῖνος γάρ, ὅθι τρώσεσθαι ὀΐω.{l]
[l [n}12.67{]}εἰ μὲν γὰρ τοὺς πάγχυ κακὰ φρονέων ἀλαπάζει{l]
[l [n}12.68{]}Ζεὺς ὑψιβρεμέτης, Τρώεσσι δὲ ἵετʼ ἀρήγειν,{l]
[l [n}12.69{]}ἦ τʼ ἂν ἔγωγʼ ἐθέλοιμι καὶ αὐτίκα τοῦτο γενέσθαι,{l]
[l [n}12.70{]}νωνύμνους ἀπολέσθαι ἀπʼ Ἄργεος ἐνθάδʼ Ἀχαιούς·{l]
[l [n}12.71{]}εἰ δέ χʼ ὑποστρέψωσι, παλίωξις δὲ γένηται{l]
[l [n}12.72{]}ἐκ νηῶν καὶ τάφρῳ ἐνιπλήξωμεν ὀρυκτῇ,{l]
[l [n}12.73{]}οὐκέτʼ ἔπειτʼ ὀΐω οὐδʼ ἄγγελον ἀπονέεσθαι{l]
[l [n}12.74{]}ἄψορρον προτὶ ἄστυ ἑλιχθέντων ὑπʼ Ἀχαιῶν.{l]
[l [n}12.75{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}12.76{]}ἵππους μὲν θεράποντες ἐρυκόντων ἐπὶ τάφρῳ,{l]
[l [n}12.77{]}αὐτοὶ δὲ πρυλέες σὺν τεύχεσι θωρηχθέντες{l]
[l [n}12.78{]}Ἕκτορι πάντες ἑπώμεθʼ ἀολλέες· αὐτὰρ Ἀχαιοὶ{l]
[l [n}12.79{]}οὐ μενέουσʼ εἰ δή σφιν ὀλέθρου πείρατʼ ἐφῆπται.{l]{q]{para]
[para}[l [n}12.80{]}ὣς φάτο Πουλυδάμας, ἅδε δʼ Ἕκτορι μῦθος ἀπήμων,{l]
[l [n}12.81{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε.{l]
[l [n}12.82{]}οὐδὲ μὲν ἄλλοι Τρῶες ἐφʼ ἵππων ἠγερέθοντο,{l]
[l [n}12.83{]}ἀλλʼ ἀπὸ πάντες ὄρουσαν, ἐπεὶ ἴδον Ἕκτορα δῖον.{l]
[l [n}12.84{]}ἡνιόχῳ μὲν ἔπειτα ἑῷ ἐπέτελλεν ἕκαστος{l]
[l [n}12.85{]}ἵππους εὖ κατὰ κόσμον ἐρυκέμεν αὖθʼ ἐπὶ τάφρῳ·{l]
[l [n}12.86{]}οἳ δὲ διαστάντες σφέας αὐτοὺς ἀρτύναντες{l]
[l [n}12.87{]}πένταχα κοσμηθέντες ἅμʼ ἡγεμόνεσσιν ἕποντο.{l]{para]
[para}[l [n}12.88{]}οἳ μὲν ἅμʼ Ἕκτορʼ ἴσαν καὶ ἀμύμονι Πουλυδάμαντι,{l]
[l [n}12.89{]}οἳ πλεῖστοι καὶ ἄριστοι ἔσαν, μέμασαν δὲ μάλιστα{l]
[l [n}12.90{]}τεῖχος ῥηξάμενοι κοίλῃς ἐπὶ νηυσὶ μάχεσθαι.{l]
[l [n}12.91{]}καί σφιν Κεβριόνης τρίτος εἵπετο· πὰρ δʼ ἄρʼ ὄχεσφιν{l]
[l [n}12.92{]}ἄλλον Κεβριόναο χερείονα κάλλιπεν Ἕκτωρ.{l]
[l [n}12.93{]}τῶν δʼ ἑτέρων Πάρις ἦρχε καὶ Ἀλκάθοος καὶ Ἀγήνωρ,{l]
[l [n}12.94{]}τῶν δὲ τρίτων Ἕλενος καὶ Δηΐφοβος θεοειδὴς{l]
[l [n}12.95{]}υἷε δύω Πριάμοιο· τρίτος δʼ ἦν Ἄσιος ἥρως{l]
[l [n}12.96{]}Ἄσιος Ὑρτακίδης, ὃν Ἀρίσβηθεν φέρον ἵπποι{l]
[l [n}12.97{]}αἴθωνες μεγάλοι ποταμοῦ ἄπο Σελλήεντος.{l]
[l [n}12.98{]}τῶν δὲ τετάρτων ἦρχεν ἐῢς πάϊς Ἀγχίσαο{l]
[l [n}12.99{]}Αἰνείας, ἅμα τῷ γε δύω Ἀντήνορος υἷε{l]
[l [n}12.100{]}Ἀρχέλοχός τʼ Ἀκάμας τε μάχης εὖ εἰδότε πάσης.{l]
[l [n}12.101{]}Σαρπηδὼν δʼ ἡγήσατʼ ἀγακλειτῶν ἐπικούρων,{l]
[l [n}12.102{]}πρὸς δʼ ἕλετο Γλαῦκον καὶ ἀρήϊον Ἀστεροπαῖον·{l]
[l [n}12.103{]}οἳ γάρ οἱ εἴσαντο διακριδὸν εἶναι ἄριστοι{l]
[l [n}12.104{]}τῶν ἄλλων μετά γʼ αὐτόν· ὃ δʼ ἔπρεπε καὶ διὰ πάντων.{l]
[l [n}12.105{]}οἳ δʼ ἐπεὶ ἀλλήλους ἄραρον τυκτῇσι βόεσσι{l]
[l [n}12.106{]}βάν ῥʼ ἰθὺς Δαναῶν λελιημένοι, οὐδʼ ἔτʼ ἔφαντο{l]
[l [n}12.107{]}σχήσεσθʼ, ἀλλʼ ἐν νηυσὶ μελαίνῃσιν πεσέεσθαι.{l]{para]
[para}[l [n}12.108{]}ἔνθʼ ἄλλοι Τρῶες τηλεκλειτοί τʼ ἐπίκουροι{l]
[l [n}12.109{]}βουλῇ Πουλυδάμαντος ἀμωμήτοιο πίθοντο·{l]
[l [n}12.110{]}ἀλλʼ οὐχ Ὑρτακίδης ἔθελʼ Ἄσιος ὄρχαμος ἀνδρῶν{l]
[l [n}12.111{]}αὖθι λιπεῖν ἵππους τε καὶ ἡνίοχον θεράποντα,{l]
[l [n}12.112{]}ἀλλὰ σὺν αὐτοῖσιν πέλασεν νήεσσι θοῇσι{l]
[l [n}12.113{]}νήπιος, οὐδʼ ἄρʼ ἔμελλε κακὰς ὑπὸ κῆρας ἀλύξας{l]
[l [n}12.114{]}ἵπποισιν καὶ ὄχεσφιν ἀγαλλόμενος παρὰ νηῶν{l]
[l [n}12.115{]}ἂψ ἀπονοστήσειν προτὶ Ἴλιον ἠνεμόεσσαν·{l]
[l [n}12.116{]}πρόσθεν γάρ μιν μοῖρα δυσώνυμος ἀμφεκάλυψεν{l]
[l [n}12.117{]}ἔγχεϊ Ἰδομενῆος ἀγαυοῦ Δευκαλίδαο.{l]
[l [n}12.118{]}εἴσατο γὰρ νηῶν ἐπʼ ἀριστερά, τῇ περ Ἀχαιοὶ{l]
[l [n}12.119{]}ἐκ πεδίου νίσοντο σὺν ἵπποισιν καὶ ὄχεσφι·{l]
[l [n}12.120{]}τῇ ῥʼ ἵππους τε καὶ ἅρμα διήλασεν, οὐδὲ πύλῃσιν{l]
[l [n}12.121{]}εὗρʼ ἐπικεκλιμένας σανίδας καὶ μακρὸν ὀχῆα,{l]
[l [n}12.122{]}ἀλλʼ ἀναπεπταμένας ἔχον ἀνέρες, εἴ τινʼ ἑταίρων{l]
[l [n}12.123{]}ἐκ πολέμου φεύγοντα σαώσειαν μετὰ νῆας.{l]
[l [n}12.124{]}τῇ ῥʼ ἰθὺς φρονέων ἵππους ἔχε, τοὶ δʼ ἅμʼ ἕποντο{l]
[l [n}12.125{]}ὀξέα κεκλήγοντες· ἔφαντο γὰρ οὐκ ἔτʼ Ἀχαιοὺς{l]
[l [n}12.126{]}σχήσεσθʼ, ἀλλʼ ἐν νηυσὶ μελαίνῃσιν πεσέεσθαι{l]
[l [n}12.127{]}νήπιοι, ἐν δὲ πύλῃσι δύʼ ἀνέρας εὗρον ἀρίστους{l]
[l [n}12.128{]}υἷας ὑπερθύμους Λαπιθάων αἰχμητάων,{l]
[l [n}12.129{]}τὸν μὲν Πειριθόου υἷα κρατερὸν Πολυποίτην,{l]
[l [n}12.130{]}τὸν δὲ Λεοντῆα βροτολοιγῷ ἶσον Ἄρηϊ.{l]
[l [n}12.131{]}τὼ μὲν ἄρα προπάροιθε πυλάων ὑψηλάων{l]
[l [n}12.132{]}ἕστασαν ὡς ὅτε τε δρύες οὔρεσιν ὑψικάρηνοι,{l]
[l [n}12.133{]}αἵ τʼ ἄνεμον μίμνουσι καὶ ὑετὸν ἤματα πάντα{l]
[l [n}12.134{]}ῥίζῃσιν μεγάλῃσι διηνεκέεσσʼ ἀραρυῖαι·{l]
[l [n}12.135{]}ὣς ἄρα τὼ χείρεσσι πεποιθότες ἠδὲ βίηφι{l]
[l [n}12.136{]}μίμνον ἐπερχόμενον μέγαν Ἄσιον οὐδὲ φέβοντο.{l]
[l [n}12.137{]}οἳ δʼ ἰθὺς πρὸς τεῖχος ἐΰδμητον βόας αὔας{l]
[l [n}12.138{]}ὑψόσʼ ἀνασχόμενοι ἔκιον μεγάλῳ ἀλαλητῷ{l]
[l [n}12.139{]}Ἄσιον ἀμφὶ ἄνακτα καὶ Ἰαμενὸν καὶ Ὀρέστην{l]
[l [n}12.140{]}Ἀσιάδην τʼ Ἀδάμαντα Θόωνά τε Οἰνόμαόν τε.{l]
[l [n}12.141{]}οἳ δʼ ἤτοι εἷος μὲν ἐϋκνήμιδας Ἀχαιοὺς{l]
[l [n}12.142{]}ὄρνυον ἔνδον ἐόντες ἀμύνεσθαι περὶ νηῶν·{l]
[l [n}12.143{]}αὐτὰρ ἐπεὶ δὴ τεῖχος ἐπεσσυμένους ἐνόησαν{l]
[l [n}12.144{]}Τρῶας, ἀτὰρ Δαναῶν γένετο ἰαχή τε φόβος τε,{l]
[l [n}12.145{]}ἐκ δὲ τὼ ἀΐξαντε πυλάων πρόσθε μαχέσθην{l]
[l [n}12.146{]}ἀγροτέροισι σύεσσιν ἐοικότε, τώ τʼ ἐν ὄρεσσιν{l]
[l [n}12.147{]}ἀνδρῶν ἠδὲ κυνῶν δέχαται κολοσυρτὸν ἰόντα,{l]
[l [n}12.148{]}δοχμώ τʼ ἀΐσσοντε περὶ σφίσιν ἄγνυτον ὕλην{l]
[l [n}12.149{]}πρυμνὴν ἐκτάμνοντες, ὑπαὶ δέ τε κόμπος ὀδόντων{l]
[l [n}12.150{]}γίγνεται εἰς ὅ κέ τίς τε βαλὼν ἐκ θυμὸν ἕληται·{l]
[l [n}12.151{]}ὣς τῶν κόμπει χαλκὸς ἐπὶ στήθεσσι φαεινὸς{l]
[l [n}12.152{]}ἄντην βαλλομένων· μάλα γὰρ κρατερῶς ἐμάχοντο{l]
[l [n}12.153{]}λαοῖσιν καθύπερθε πεποιθότες ἠδὲ βίηφιν.{l]
[l [n}12.154{]}οἳ δʼ ἄρα χερμαδίοισιν ἐϋδμήτων ἀπὸ πύργων{l]
[l [n}12.155{]}βάλλον ἀμυνόμενοι σφῶν τʼ αὐτῶν καὶ κλισιάων{l]
[l [n}12.156{]}νηῶν τʼ ὠκυπόρων· νιφάδες δʼ ὡς πῖπτον ἔραζε,{l]
[l [n}12.157{]}ἅς τʼ ἄνεμος ζαὴς νέφεα σκιόεντα δονήσας{l]
[l [n}12.158{]}ταρφειὰς κατέχευεν ἐπὶ χθονὶ πουλυβοτείρῃ·{l]
[l [n}12.159{]}ὣς τῶν ἐκ χειρῶν βέλεα ῥέον ἠμὲν Ἀχαιῶν{l]
[l [n}12.160{]}ἠδὲ καὶ ἐκ Τρώων· κόρυθες δʼ ἀμφʼ αὖον ἀΰτευν{l]
[l [n}12.161{]}βαλλομένων μυλάκεσσι καὶ ἀσπίδες ὀμφαλόεσσαι.{l]
[l [n}12.162{]}δή ῥα τότʼ ᾤμωξεν καὶ ὣ πεπλήγετο μηρὼ{l]
[l [n}12.163{]}Ἄσιος Ὑρτακίδης, καὶ ἀλαστήσας ἔπος ηὔδα·{l]
[q}[l [n}12.164{]}Ζεῦ πάτερ ἦ ῥά νυ καὶ σὺ φιλοψευδὴς ἐτέτυξο{l]
[l [n}12.165{]}πάγχυ μάλʼ· οὐ γὰρ ἔγωγʼ ἐφάμην ἥρωας Ἀχαιοὺς{l]
[l [n}12.166{]}σχήσειν ἡμέτερόν γε μένος καὶ χεῖρας ἀάπτους.{l]
[l [n}12.167{]}οἳ δʼ, ὥς τε σφῆκες μέσον αἰόλοι ἠὲ μέλισσαι{l]
[l [n}12.168{]}οἰκία ποιήσωνται ὁδῷ ἔπι παιπαλοέσσῃ,{l]
[l [n}12.169{]}οὐδʼ ἀπολείπουσιν κοῖλον δόμον, ἀλλὰ μένοντες{l]
[l [n}12.170{]}ἄνδρας θηρητῆρας ἀμύνονται περὶ τέκνων,{l]
[l [n}12.171{]}ὣς οἵ γʼ οὐκ ἐθέλουσι πυλάων καὶ δύʼ ἐόντε{l]
[l [n}12.172{]}χάσσασθαι πρίν γʼ ἠὲ κατακτάμεν ἠὲ ἁλῶναι.{l]{q]{para]
[para}[l [n}12.173{]}ὣς ἔφατʼ, οὐδὲ Διὸς πεῖθε φρένα ταῦτʼ ἀγορεύων·{l]
[l [n}12.174{]}Ἕκτορι γάρ οἱ θυμὸς ἐβούλετο κῦδος ὀρέξαι.{l]{para]
[para}[l [n}12.175{]}ἄλλοι δʼ ἀμφʼ ἄλλῃσι μάχην ἐμάχοντο πύλῃσιν·{l]
[l [n}12.176{]}ἀργαλέον δέ με ταῦτα θεὸν ὣς πάντʼ ἀγορεῦσαι·{l]
[l [n}12.177{]}πάντῃ γὰρ περὶ τεῖχος ὀρώρει θεσπιδαὲς πῦρ{l]
[l [n}12.178{]}λάϊνον· Ἀργεῖοι δὲ καὶ ἀχνύμενοί περ ἀνάγκῃ{l]
[l [n}12.179{]}νηῶν ἠμύνοντο· θεοὶ δʼ ἀκαχήατο θυμὸν{l]
[l [n}12.180{]}πάντες ὅσοι Δαναοῖσι μάχης ἐπιτάρροθοι ἦσαν.{l]
[l [n}12.181{]}σὺν δʼ ἔβαλον Λαπίθαι πόλεμον καὶ δηϊοτῆτα.{l]{para]
[para}[l [n}12.182{]}ἔνθʼ αὖ Πειριθόου υἱὸς κρατερὸς Πολυποίτης{l]
[l [n}12.183{]}δουρὶ βάλεν Δάμασον κυνέης διὰ χαλκοπαρῄου·{l]
[l [n}12.184{]}οὐδʼ ἄρα χαλκείη κόρυς ἔσχεθεν, ἀλλὰ διὰ πρὸ{l]
[l [n}12.185{]}αἰχμὴ χαλκείη ῥῆξʼ ὀστέον, ἐγκέφαλος δὲ{l]
[l [n}12.186{]}ἔνδον ἅπας πεπάλακτο· δάμασσε δέ μιν μεμαῶτα·{l]
[l [n}12.187{]}αὐτὰρ ἔπειτα Πύλωνα καὶ Ὄρμενον ἐξενάριξεν.{l]
[l [n}12.188{]}υἱὸν δʼ Ἀντιμάχοιο Λεοντεὺς ὄζος Ἄρηος{l]
[l [n}12.189{]}Ἱππόμαχον βάλε δουρὶ κατὰ ζωστῆρα τυχήσας.{l]
[l [n}12.190{]}αὖτις δʼ ἐκ κολεοῖο ἐρυσσάμενος ξίφος ὀξὺ{l]
[l [n}12.191{]}Ἀντιφάτην μὲν πρῶτον ἐπαΐξας διʼ ὁμίλου{l]
[l [n}12.192{]}πλῆξʼ αὐτοσχεδίην· ὃ δʼ ἄρʼ ὕπτιος οὔδει ἐρείσθη·{l]
[l [n}12.193{]}αὐτὰρ ἔπειτα Μένωνα καὶ Ἰαμενὸν καὶ Ὀρέστην{l]
[l [n}12.194{]}πάντας ἐπασσυτέρους πέλασε χθονὶ πουλυβοτείρῃ.{l]{para]
[para}[l [n}12.195{]}ὄφρʼ οἳ τοὺς ἐνάριζον ἀπʼ ἔντεα μαρμαίροντα,{l]
[l [n}12.196{]}τόφρʼ οἳ Πουλυδάμαντι καὶ Ἕκτορι κοῦροι ἕποντο,{l]
[l [n}12.197{]}οἳ πλεῖστοι καὶ ἄριστοι ἔσαν, μέμασαν δὲ μάλιστα{l]
[l [n}12.198{]}τεῖχός τε ῥήξειν καὶ ἐνιπρήσειν πυρὶ νῆας,{l]
[l [n}12.199{]}οἵ ῥʼ ἔτι μερμήριζον ἐφεσταότες παρὰ τάφρῳ.{l]
[l [n}12.200{]}ὄρνις γάρ σφιν ἐπῆλθε περησέμεναι μεμαῶσιν{l]
[l [n}12.201{]}αἰετὸς ὑψιπέτης ἐπʼ ἀριστερὰ λαὸν ἐέργων{l]
[l [n}12.202{]}φοινήεντα δράκοντα φέρων ὀνύχεσσι πέλωρον{l]
[l [n}12.203{]}ζωὸν ἔτʼ ἀσπαίροντα, καὶ οὔ πω λήθετο χάρμης,{l]
[l [n}12.204{]}κόψε γὰρ αὐτὸν ἔχοντα κατὰ στῆθος παρὰ δειρὴν{l]
[l [n}12.205{]}ἰδνωθεὶς ὀπίσω· ὃ δʼ ἀπὸ ἕθεν ἧκε χαμᾶζε{l]
[l [n}12.206{]}ἀλγήσας ὀδύνῃσι, μέσῳ δʼ ἐνὶ κάββαλʼ ὁμίλῳ,{l]
[l [n}12.207{]}αὐτὸς δὲ κλάγξας πέτετο πνοιῇς ἀνέμοιο.{l]
[l [n}12.208{]}Τρῶες δʼ ἐρρίγησαν ὅπως ἴδον αἰόλον ὄφιν{l]
[l [n}12.209{]}κείμενον ἐν μέσσοισι Διὸς τέρας αἰγιόχοιο.{l]
[l [n}12.210{]}δὴ τότε Πουλυδάμας θρασὺν Ἕκτορα εἶπε παραστάς·{l]
[q}[l [n}12.211{]}Ἕκτορ ἀεὶ μέν πώς μοι ἐπιπλήσσεις ἀγορῇσιν{l]
[l [n}12.212{]}ἐσθλὰ φραζομένῳ, ἐπεὶ οὐδὲ μὲν οὐδὲ ἔοικε{l]
[l [n}12.213{]}δῆμον ἐόντα παρὲξ ἀγορευέμεν, οὔτʼ ἐνὶ βουλῇ{l]
[l [n}12.214{]}οὔτέ ποτʼ ἐν πολέμῳ, σὸν δὲ κράτος αἰὲν ἀέξειν·{l]
[l [n}12.215{]}νῦν αὖτʼ ἐξερέω ὥς μοι δοκεῖ εἶναι ἄριστα.{l]
[l [n}12.216{]}μὴ ἴομεν Δαναοῖσι μαχησόμενοι περὶ νηῶν.{l]
[l [n}12.217{]}ὧδε γὰρ ἐκτελέεσθαι ὀΐομαι, εἰ ἐτεόν γε{l]
[l [n}12.218{]}Τρωσὶν ὅδʼ ὄρνις ἦλθε περησέμεναι μεμαῶσιν{l]
[l [n}12.219{]}αἰετὸς ὑψιπέτης ἐπʼ ἀριστερὰ λαὸν ἐέργων{l]
[l [n}12.220{]}φοινήεντα δράκοντα φέρων ὀνύχεσσι πέλωρον{l]
[l [n}12.221{]}ζωόν· ἄφαρ δʼ ἀφέηκε πάρος φίλα οἰκίʼ ἱκέσθαι,{l]
[l [n}12.222{]}οὐδʼ ἐτέλεσσε φέρων δόμεναι τεκέεσσιν ἑοῖσιν.{l]
[l [n}12.223{]}ὣς ἡμεῖς, εἴ πέρ τε πύλας καὶ τεῖχος Ἀχαιῶν{l]
[l [n}12.224{]}ῥηξόμεθα σθένεϊ μεγάλῳ, εἴξωσι δʼ Ἀχαιοί,{l]
[l [n}12.225{]}οὐ κόσμῳ παρὰ ναῦφιν ἐλευσόμεθʼ αὐτὰ κέλευθα·{l]
[l [n}12.226{]}πολλοὺς γὰρ Τρώων καταλείψομεν, οὕς κεν Ἀχαιοὶ{l]
[l [n}12.227{]}χαλκῷ δῃώσωσιν ἀμυνόμενοι περὶ νηῶν.{l]
[l [n}12.228{]}ὧδέ χʼ ὑποκρίναιτο θεοπρόπος, ὃς σάφα θυμῷ{l]
[l [n}12.229{]}εἰδείη τεράων καί οἱ πειθοίατο λαοί.{l]{q]{para]
[para}[l [n}12.230{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}12.231{]}Πουλυδάμα, σὺ μὲν οὐκ ἔτʼ ἐμοὶ φίλα ταῦτʼ ἀγορεύεις·{l]
[l [n}12.232{]}οἶσθα καὶ ἄλλον μῦθον ἀμείνονα τοῦδε νοῆσαι.{l]
[l [n}12.233{]}εἰ δʼ ἐτεὸν δὴ τοῦτον ἀπὸ σπουδῆς ἀγορεύεις,{l]
[l [n}12.234{]}ἐξ ἄρα δή τοι ἔπειτα θεοὶ φρένας ὤλεσαν αὐτοί,{l]
[l [n}12.235{]}ὃς κέλεαι Ζηνὸς μὲν ἐριγδούποιο λαθέσθαι{l]
[l [n}12.236{]}βουλέων, ἅς τέ μοι αὐτὸς ὑπέσχετο καὶ κατένευσε·{l]
[l [n}12.237{]}τύνη δʼ οἰωνοῖσι τανυπτερύγεσσι κελεύεις{l]
[l [n}12.238{]}πείθεσθαι, τῶν οὔ τι μετατρέπομʼ οὐδʼ ἀλεγίζω{l]
[l [n}12.239{]}εἴτʼ ἐπὶ δεξίʼ ἴωσι πρὸς ἠῶ τʼ ἠέλιόν τε,{l]
[l [n}12.240{]}εἴτʼ ἐπʼ ἀριστερὰ τοί γε ποτὶ ζόφον ἠερόεντα.{l]
[l [n}12.241{]}ἡμεῖς δὲ μεγάλοιο Διὸς πειθώμεθα βουλῇ,{l]
[l [n}12.242{]}ὃς πᾶσι θνητοῖσι καὶ ἀθανάτοισιν ἀνάσσει.{l]
[l [n}12.243{]}εἷς οἰωνὸς ἄριστος ἀμύνεσθαι περὶ πάτρης.{l]
[l [n}12.244{]}τίπτε σὺ δείδοικας πόλεμον καὶ δηϊοτῆτα;{l]
[l [n}12.245{]}εἴ περ γάρ τʼ ἄλλοι γε περὶ κτεινώμεθα πάντες{l]
[l [n}12.246{]}νηυσὶν ἐπʼ Ἀργείων, σοὶ δʼ οὐ δέος ἔστʼ ἀπολέσθαι·{l]
[l [n}12.247{]}οὐ γάρ τοι κραδίη μενεδήϊος οὐδὲ μαχήμων.{l]
[l [n}12.248{]}εἰ δὲ σὺ δηϊοτῆτος ἀφέξεαι, ἠέ τινʼ ἄλλον{l]
[l [n}12.249{]}παρφάμενος ἐπέεσσιν ἀποτρέψεις πολέμοιο,{l]
[l [n}12.250{]}αὐτίκʼ ἐμῷ ὑπὸ δουρὶ τυπεὶς ἀπὸ θυμὸν ὀλέσσεις.{l]{q]{para]
[para}[l [n}12.251{]}ὣς ἄρα φωνήσας ἡγήσατο, τοὶ δʼ ἅμʼ ἕποντο{l]
[l [n}12.252{]}ἠχῇ θεσπεσίῃ· ἐπὶ δὲ Ζεὺς τερπικέραυνος{l]
[l [n}12.253{]}ὦρσεν ἀπʼ Ἰδαίων ὀρέων ἀνέμοιο θύελλαν,{l]
[l [n}12.254{]}ἥ ῥʼ ἰθὺς νηῶν κονίην φέρεν· αὐτὰρ Ἀχαιῶν{l]
[l [n}12.255{]}θέλγε νόον, Τρωσὶν δὲ καὶ Ἕκτορι κῦδος ὄπαζε.{l]
[l [n}12.256{]}τοῦ περ δὴ τεράεσσι πεποιθότες ἠδὲ βίηφι{l]
[l [n}12.257{]}ῥήγνυσθαι μέγα τεῖχος Ἀχαιῶν πειρήτιζον.{l]
[l [n}12.258{]}κρόσσας μὲν πύργων ἔρυον, καὶ ἔρειπον ἐπάλξεις,{l]
[l [n}12.259{]}στήλας τε προβλῆτας ἐμόχλεον, ἃς ἄρʼ Ἀχαιοὶ{l]
[l [n}12.260{]}πρώτας ἐν γαίῃ θέσαν ἔμμεναι ἔχματα πύργων.{l]
[l [n}12.261{]}τὰς οἵ γʼ αὐέρυον, ἔλποντο δὲ τεῖχος Ἀχαιῶν{l]
[l [n}12.262{]}ῥήξειν· οὐδέ νύ πω Δαναοὶ χάζοντο κελεύθου,{l]
[l [n}12.263{]}ἀλλʼ οἵ γε ῥινοῖσι βοῶν φράξαντες ἐπάλξεις{l]
[l [n}12.264{]}βάλλον ἀπʼ αὐτάων δηΐους ὑπὸ τεῖχος ἰόντας.{l]{para]
[para}[l [n}12.265{]}ἀμφοτέρω δʼ Αἴαντε κελευτιόωντʼ ἐπὶ πύργων{l]
[l [n}12.266{]}πάντοσε φοιτήτην μένος ὀτρύνοντες Ἀχαιῶν.{l]
[l [n}12.267{]}ἄλλον μειλιχίοις, ἄλλον στερεοῖς ἐπέεσσι{l]
[l [n}12.268{]}νείκεον, ὅν τινα πάγχυ μάχης μεθιέντα ἴδοιεν·{l]
[q}[l [n}12.269{]}ὦ φίλοι Ἀργείων ὅς τʼ ἔξοχος ὅς τε μεσήεις{l]
[l [n}12.270{]}ὅς τε χερειότερος, ἐπεὶ οὔ πω πάντες ὁμοῖοι{l]
[l [n}12.271{]}ἀνέρες ἐν πολέμῳ, νῦν ἔπλετο ἔργον ἅπασι·{l]
[l [n}12.272{]}καὶ δʼ αὐτοὶ τόδε που γιγνώσκετε. μή τις ὀπίσσω{l]
[l [n}12.273{]}τετράφθω ποτὶ νῆας ὁμοκλητῆρος ἀκούσας,{l]
[l [n}12.274{]}ἀλλὰ πρόσω ἵεσθε καὶ ἀλλήλοισι κέλεσθε,{l]
[l [n}12.275{]}αἴ κε Ζεὺς δώῃσιν Ὀλύμπιος ἀστεροπητὴς{l]
[l [n}12.276{]}νεῖκος ἀπωσαμένους δηΐους προτὶ ἄστυ δίεσθαι.{l]{q]{para]
[para}[l [n}12.277{]}ὣς τώ γε προβοῶντε μάχην ὄτρυνον Ἀχαιῶν.{l]
[l [n}12.278{]}τῶν δʼ, ὥς τε νιφάδες χιόνος πίπτωσι θαμειαὶ{l]
[l [n}12.279{]}ἤματι χειμερίῳ, ὅτε τʼ ὤρετο μητίετα Ζεὺς{l]
[l [n}12.280{]}νιφέμεν ἀνθρώποισι πιφαυσκόμενος τὰ ἃ κῆλα·{l]
[l [n}12.281{]}κοιμήσας δʼ ἀνέμους χέει ἔμπεδον, ὄφρα καλύψῃ{l]
[l [n}12.282{]}ὑψηλῶν ὀρέων κορυφὰς καὶ πρώονας ἄκρους{l]
[l [n}12.283{]}καὶ πεδία λωτοῦντα καὶ ἀνδρῶν πίονα ἔργα,{l]
[l [n}12.284{]}καί τʼ ἐφʼ ἁλὸς πολιῆς κέχυται λιμέσιν τε καὶ ἀκταῖς,{l]
[l [n}12.285{]}κῦμα δέ μιν προσπλάζον ἐρύκεται· ἄλλά τε πάντα{l]
[l [n}12.286{]}εἴλυται καθύπερθʼ, ὅτʼ ἐπιβρίσῃ Διὸς ὄμβρος·{l]
[l [n}12.287{]}ὣς τῶν ἀμφοτέρωσε λίθοι πωτῶντο θαμειαί,{l]
[l [n}12.288{]}αἱ μὲν ἄρʼ ἐς Τρῶας, αἱ δʼ ἐκ Τρώων ἐς Ἀχαιούς,{l]
[l [n}12.289{]}βαλλομένων· τὸ δὲ τεῖχος ὕπερ πᾶν δοῦπος ὀρώρει.{l]{para]
[para}[l [n}12.290{]}οὐδʼ ἄν πω τότε γε Τρῶες καὶ φαίδιμος Ἕκτωρ{l]
[l [n}12.291{]}τείχεος ἐρρήξαντο πύλας καὶ μακρὸν ὀχῆα,{l]
[l [n}12.292{]}εἰ μὴ ἄρʼ υἱὸν ἑὸν Σαρπηδόνα μητίετα Ζεὺς{l]
[l [n}12.293{]}ὦρσεν ἐπʼ Ἀργείοισι λέονθʼ ὣς βουσὶν ἕλιξιν.{l]
[l [n}12.294{]}αὐτίκα δʼ ἀσπίδα μὲν πρόσθʼ ἔσχετο πάντοσʼ ἐΐσην{l]
[l [n}12.295{]}καλὴν χαλκείην ἐξήλατον, ἣν ἄρα χαλκεὺς{l]
[l [n}12.296{]}ἤλασεν, ἔντοσθεν δὲ βοείας ῥάψε θαμειὰς{l]
[l [n}12.297{]}χρυσείῃς ῥάβδοισι διηνεκέσιν περὶ κύκλον.{l]
[l [n}12.298{]}τὴν ἄρʼ ὅ γε πρόσθε σχόμενος δύο δοῦρε τινάσσων{l]
[l [n}12.299{]}βῆ ῥʼ ἴμεν ὥς τε λέων ὀρεσίτροφος, ὅς τʼ ἐπιδευὴς{l]
[l [n}12.300{]}δηρὸν ἔῃ κρειῶν, κέλεται δέ ἑ θυμὸς ἀγήνωρ{l]
[l [n}12.301{]}μήλων πειρήσοντα καὶ ἐς πυκινὸν δόμον ἐλθεῖν·{l]
[l [n}12.302{]}εἴ περ γάρ χʼ εὕρῃσι παρʼ αὐτόφι βώτορας ἄνδρας{l]
[l [n}12.303{]}σὺν κυσὶ καὶ δούρεσσι φυλάσσοντας περὶ μῆλα,{l]
[l [n}12.304{]}οὔ ῥά τʼ ἀπείρητος μέμονε σταθμοῖο δίεσθαι,{l]
[l [n}12.305{]}ἀλλʼ ὅ γʼ ἄρʼ ἢ ἥρπαξε μετάλμενος, ἠὲ καὶ αὐτὸς{l]
[l [n}12.306{]}ἔβλητʼ ἐν πρώτοισι θοῆς ἀπὸ χειρὸς ἄκοντι·{l]
[l [n}12.307{]}ὥς ῥα τότʼ ἀντίθεον Σαρπηδόνα θυμὸς ἀνῆκε{l]
[l [n}12.308{]}τεῖχος ἐπαΐξαι διά τε ῥήξασθαι ἐπάλξεις.{l]
[l [n}12.309{]}αὐτίκα δὲ Γλαῦκον προσέφη παῖδʼ Ἱππολόχοιο·{l]
[q}[l [n}12.310{]}Γλαῦκε τί ἢ δὴ νῶϊ τετιμήμεσθα μάλιστα{l]
[l [n}12.311{]}ἕδρῃ τε κρέασίν τε ἰδὲ πλείοις δεπάεσσιν{l]
[l [n}12.312{]}ἐν Λυκίῃ, πάντες δὲ θεοὺς ὣς εἰσορόωσι,{l]
[l [n}12.313{]}καὶ τέμενος νεμόμεσθα μέγα Ξάνθοιο παρʼ ὄχθας{l]
[l [n}12.314{]}καλὸν φυταλιῆς καὶ ἀρούρης πυροφόροιο;{l]
[l [n}12.315{]}τὼ νῦν χρὴ Λυκίοισι μέτα πρώτοισιν ἐόντας{l]
[l [n}12.316{]}ἑστάμεν ἠδὲ μάχης καυστείρης ἀντιβολῆσαι,{l]
[l [n}12.317{]}ὄφρά τις ὧδʼ εἴπῃ Λυκίων πύκα θωρηκτάων·{l]
[q}[l [n}12.318{]}οὐ μὰν ἀκλεέες Λυκίην κάτα κοιρανέουσιν{l]
[l [n}12.319{]}ἡμέτεροι βασιλῆες, ἔδουσί τε πίονα μῆλα{l]
[l [n}12.320{]}οἶνόν τʼ ἔξαιτον μελιηδέα· ἀλλʼ ἄρα καὶ ἲς{l]
[l [n}12.321{]}ἐσθλή, ἐπεὶ Λυκίοισι μέτα πρώτοισι μάχονται.{l]{q][l [n}12.322{]}ὦ πέπον εἰ μὲν γὰρ πόλεμον περὶ τόνδε φυγόντε{l]
[l [n}12.323{]}αἰεὶ δὴ μέλλοιμεν ἀγήρω τʼ ἀθανάτω τε{l]
[l [n}12.324{]}ἔσσεσθʼ, οὔτέ κεν αὐτὸς ἐνὶ πρώτοισι μαχοίμην{l]
[l [n}12.325{]}οὔτέ κε σὲ στέλλοιμι μάχην ἐς κυδιάνειραν·{l]
[l [n}12.326{]}νῦν δʼ ἔμπης γὰρ κῆρες ἐφεστᾶσιν θανάτοιο{l]
[l [n}12.327{]}μυρίαι, ἃς οὐκ ἔστι φυγεῖν βροτὸν οὐδʼ ὑπαλύξαι,{l]
[l [n}12.328{]}ἴομεν ἠέ τῳ εὖχος ὀρέξομεν ἠέ τις ἡμῖν.{l]{q]{para]
[para}[l [n}12.329{]}ὣς ἔφατʼ, οὐδὲ Γλαῦκος ἀπετράπετʼ οὐδʼ ἀπίθησε·{l]
[l [n}12.330{]}τὼ δʼ ἰθὺς βήτην Λυκίων μέγα ἔθνος ἄγοντε.{l]
[l [n}12.331{]}τοὺς δὲ ἰδὼν ῥίγησʼ υἱὸς Πετεῶο Μενεσθεύς·{l]
[l [n}12.332{]}τοῦ γὰρ δὴ πρὸς πύργον ἴσαν κακότητα φέροντες.{l]
[l [n}12.333{]}πάπτηνεν δʼ ἀνὰ πύργον Ἀχαιῶν εἴ τινʼ ἴδοιτο{l]
[l [n}12.334{]}ἡγεμόνων, ὅς τίς οἱ ἀρὴν ἑτάροισιν ἀμύναι·{l]
[l [n}12.335{]}ἐς δʼ ἐνόησʼ Αἴαντε δύω πολέμου ἀκορήτω{l]
[l [n}12.336{]}ἑσταότας, Τεῦκρόν τε νέον κλισίηθεν ἰόντα{l]
[l [n}12.337{]}ἐγγύθεν· ἀλλʼ οὔ πώς οἱ ἔην βώσαντι γεγωνεῖν·{l]
[l [n}12.338{]}τόσσος γὰρ κτύπος ἦεν, ἀϋτὴ δʼ οὐρανὸν ἷκε,{l]
[l [n}12.339{]}βαλλομένων σακέων τε καὶ ἱπποκόμων τρυφαλειῶν{l]
[l [n}12.340{]}καὶ πυλέων· πᾶσαι γὰρ ἐπώχατο, τοὶ δὲ κατʼ αὐτὰς{l]
[l [n}12.341{]}ἱστάμενοι πειρῶντο βίῃ ῥήξαντες ἐσελθεῖν.{l]
[l [n}12.342{]}αἶψα δʼ ἐπʼ Αἴαντα προΐει κήρυκα Θοώτην·{l]
[q}[l [n}12.343{]}ἔρχεο δῖε Θοῶτα, θέων Αἴαντα κάλεσσον,{l]
[l [n}12.344{]}ἀμφοτέρω μὲν μᾶλλον· ὃ γάρ κʼ ὄχʼ ἄριστον ἁπάντων{l]
[l [n}12.345{]}εἴη, ἐπεὶ τάχα τῇδε τετεύξεται αἰπὺς ὄλεθρος.{l]
[l [n}12.346{]}ὧδε γὰρ ἔβρισαν Λυκίων ἀγοί, οἳ τὸ πάρος περ{l]
[l [n}12.347{]}ζαχρηεῖς τελέθουσι κατὰ κρατερὰς ὑσμίνας.{l]
[l [n}12.348{]}εἰ δέ σφιν καὶ κεῖθι πόνος καὶ νεῖκος ὄρωρεν,{l]
[l [n}12.349{]}ἀλλά περ οἶος ἴτω Τελαμώνιος ἄλκιμος Αἴας,{l]
[l [n}12.350{]}καί οἱ Τεῦκρος ἅμα σπέσθω τόξων ἐῢ εἰδώς.{l]{q]{para]
[para}[l [n}12.351{]}ὣς ἔφατʼ, οὐδʼ ἄρα οἱ κῆρυξ ἀπίθησεν ἀκούσας,{l]
[l [n}12.352{]}βῆ δὲ θέειν παρὰ τεῖχος Ἀχαιῶν χαλκοχιτώνων,{l]
[l [n}12.353{]}στῆ δὲ παρʼ Αἰάντεσσι κιών, εἶθαρ δὲ προσηύδα·{l]
[q}[l [n}12.354{]}Αἴαντʼ Ἀργείων ἡγήτορε χαλκοχιτώνων{l]
[l [n}12.355{]}ἠνώγει Πετεῶο διοτρεφέος φίλος υἱὸς{l]
[l [n}12.356{]}κεῖσʼ ἴμεν, ὄφρα πόνοιο μίνυνθά περ ἀντιάσητον{l]
[l [n}12.357{]}ἀμφοτέρω μὲν μᾶλλον· ὃ γάρ κʼ ὄχʼ ἄριστον ἁπάντων{l]
[l [n}12.358{]}εἴη, ἐπεὶ τάχα κεῖθι τετεύξεται αἰπὺς ὄλεθρος·{l]
[l [n}12.359{]}ὧδε γὰρ ἔβρισαν Λυκίων ἀγοί, οἳ τὸ πάρος περ{l]
[l [n}12.360{]}ζαχρηεῖς τελέθουσι κατὰ κρατερὰς ὑσμίνας.{l]
[l [n}12.361{]}εἰ δὲ καὶ ἐνθάδε περ πόλεμος καὶ νεῖκος ὄρωρεν,{l]
[l [n}12.362{]}ἀλλά περ οἶος ἴτω Τελαμώνιος ἄλκιμος Αἴας,{l]
[l [n}12.363{]}καί οἱ Τεῦκρος ἅμα σπέσθω τόξων ἐῢ εἰδώς.{l]{q]{para]
[para}[l [n}12.364{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε μέγας Τελαμώνιος Αἴας.{l]
[l [n}12.365{]}αὐτίκʼ Ὀϊλιάδην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}12.366{]}Αἶαν σφῶϊ μὲν αὖθι, σὺ καὶ κρατερὸς Λυκομήδης,{l]
[l [n}12.367{]}ἑσταότες Δαναοὺς ὀτρύνετον ἶφι μάχεσθαι·{l]
[l [n}12.368{]}αὐτὰρ ἐγὼ κεῖσʼ εἶμι καὶ ἀντιόω πολέμοιο·{l]
[l [n}12.369{]}αἶψα δʼ ἐλεύσομαι αὖτις, ἐπὴν εὖ τοῖς ἐπαμύνω.{l]{q]{para]
[para}[l [n}12.370{]}ὣς ἄρα φωνήσας ἀπέβη Τελαμώνιος Αἴας,{l]
[l [n}12.371{]}καί οἱ Τεῦκρος ἅμʼ ᾖε κασίγνητος καὶ ὄπατρος·{l]
[l [n}12.372{]}τοῖς δʼ ἅμα Πανδίων Τεύκρου φέρε καμπύλα τόξα.{l]
[l [n}12.373{]}εὖτε Μενεσθῆος μεγαθύμου πύργον ἵκοντο{l]
[l [n}12.374{]}τείχεος ἐντὸς ἰόντες, ἐπειγομένοισι δʼ ἵκοντο,{l]
[l [n}12.375{]}οἳ δʼ ἐπʼ ἐπάλξεις βαῖνον ἐρεμνῇ λαίλαπι ἶσοι{l]
[l [n}12.376{]}ἴφθιμοι Λυκίων ἡγήτορες ἠδὲ μέδοντες·{l]
[l [n}12.377{]}σὺν δʼ ἐβάλοντο μάχεσθαι ἐναντίον, ὦρτο δʼ ἀϋτή.{l]{para]
[para}[l [n}12.378{]}Αἴας δὲ πρῶτος Τελαμώνιος ἄνδρα κατέκτα{l]
[l [n}12.379{]}Σαρπήδοντος ἑταῖρον Ἐπικλῆα μεγάθυμον{l]
[l [n}12.380{]}μαρμάρῳ ὀκριόεντι βαλών, ὅ ῥα τείχεος ἐντὸς{l]
[l [n}12.381{]}κεῖτο μέγας παρʼ ἔπαλξιν ὑπέρτατος· οὐδέ κέ μιν ῥέα{l]
[l [n}12.382{]}χείρεσσʼ ἀμφοτέρῃς ἔχοι ἀνὴρ οὐδὲ μάλʼ ἡβῶν,{l]
[l [n}12.383{]}οἷοι νῦν βροτοί εἰσʼ· ὃ δʼ ἄρʼ ὑψόθεν ἔμβαλʼ ἀείρας,{l]
[l [n}12.384{]}θλάσσε δὲ τετράφαλον κυνέην, σὺν δʼ ὀστέʼ ἄραξε{l]
[l [n}12.385{]}πάντʼ ἄμυδις κεφαλῆς· ὃ δʼ ἄρʼ ἀρνευτῆρι ἐοικὼς{l]
[l [n}12.386{]}κάππεσʼ ἀφʼ ὑψηλοῦ πύργου, λίπε δʼ ὀστέα θυμός.{l]
[l [n}12.387{]}Τεῦκρος δὲ Γλαῦκον κρατερὸν παῖδʼ Ἱππολόχοιο{l]
[l [n}12.388{]}ἰῷ ἐπεσσύμενον βάλε τείχεος ὑψηλοῖο,{l]
[l [n}12.389{]}ᾗ ῥʼ ἴδε γυμνωθέντα βραχίονα, παῦσε δὲ χάρμης.{l]
[l [n}12.390{]}ἂψ δʼ ἀπὸ τείχεος ἆλτο λαθών, ἵνα μή τις Ἀχαιῶν{l]
[l [n}12.391{]}βλήμενον ἀθρήσειε καὶ εὐχετόῳτʼ ἐπέεσσι.{l]
[l [n}12.392{]}Σαρπήδοντι δʼ ἄχος γένετο Γλαύκου ἀπιόντος{l]
[l [n}12.393{]}αὐτίκʼ ἐπεί τʼ ἐνόησεν· ὅμως δʼ οὐ λήθετο χάρμης,{l]
[l [n}12.394{]}ἀλλʼ ὅ γε Θεστορίδην Ἀλκμάονα δουρὶ τυχήσας{l]
[l [n}12.395{]}νύξʼ, ἐκ δʼ ἔσπασεν ἔγχος· ὃ δʼ ἑσπόμενος πέσε δουρὶ{l]
[l [n}12.396{]}πρηνής, ἀμφὶ δέ οἱ βράχε τεύχεα ποικίλα χαλκῷ,{l]
[l [n}12.397{]}Σαρπηδὼν δʼ ἄρʼ ἔπαλξιν ἑλὼν χερσὶ στιβαρῇσιν{l]
[l [n}12.398{]}ἕλχʼ, ἣ δʼ ἕσπετο πᾶσα διαμπερές, αὐτὰρ ὕπερθε{l]
[l [n}12.399{]}τεῖχος ἐγυμνώθη, πολέεσσι δὲ θῆκε κέλευθον.{l]{para]
[para}[l [n}12.400{]}τὸν δʼ Αἴας καὶ Τεῦκρος ὁμαρτήσανθʼ ὃ μὲν ἰῷ{l]
[l [n}12.401{]}βεβλήκει τελαμῶνα περὶ στήθεσσι φαεινὸν{l]
[l [n}12.402{]}ἀσπίδος ἀμφιβρότης· ἀλλὰ Ζεὺς κῆρας ἄμυνε{l]
[l [n}12.403{]}παιδὸς ἑοῦ, μὴ νηυσὶν ἔπι πρύμνῃσι δαμείη·{l]
[l [n}12.404{]}Αἴας δʼ ἀσπίδα νύξεν ἐπάλμενος, οὐδὲ διὰ πρὸ{l]
[l [n}12.405{]}ἤλυθεν ἐγχείη, στυφέλιξε δέ μιν μεμαῶτα.{l]
[l [n}12.406{]}χώρησεν δʼ ἄρα τυτθὸν ἐπάλξιος· οὐδʼ ὅ γε πάμπαν{l]
[l [n}12.407{]}χάζετʼ, ἐπεί οἱ θυμὸς ἐέλπετο κῦδος ἀρέσθαι.{l]
[l [n}12.408{]}κέκλετο δʼ ἀντιθέοισιν ἑλιξάμενος Λυκίοισιν·{l]
[q}[l [n}12.409{]}ὦ Λύκιοι τί τʼ ἄρʼ ὧδε μεθίετε θούριδος ἀλκῆς;{l]
[l [n}12.410{]}ἀργαλέον δέ μοί ἐστι καὶ ἰφθίμῳ περ ἐόντι{l]
[l [n}12.411{]}μούνῳ ῥηξαμένῳ θέσθαι παρὰ νηυσὶ κέλευθον·{l]
[l [n}12.412{]}ἀλλʼ ἐφομαρτεῖτε· πλεόνων δέ τι ἔργον ἄμεινον.{l]{q]{para]
[para}[l [n}12.413{]}ὣς ἔφαθʼ, οἳ δὲ ἄνακτος ὑποδείσαντες ὁμοκλὴν{l]
[l [n}12.414{]}μᾶλλον ἐπέβρισαν βουληφόρον ἀμφὶ ἄνακτα.{l]
[l [n}12.415{]}Ἀργεῖοι δʼ ἑτέρωθεν ἐκαρτύναντο φάλαγγας{l]
[l [n}12.416{]}τείχεος ἔντοσθεν, μέγα δέ σφισι φαίνετο ἔργον·{l]
[l [n}12.417{]}οὔτε γὰρ ἴφθιμοι Λύκιοι Δαναῶν ἐδύναντο{l]
[l [n}12.418{]}τεῖχος ῥηξάμενοι θέσθαι παρὰ νηυσὶ κέλευθον,{l]
[l [n}12.419{]}οὔτέ ποτʼ αἰχμηταὶ Δαναοὶ Λυκίους ἐδύναντο{l]
[l [n}12.420{]}τείχεος ἂψ ὤσασθαι, ἐπεὶ τὰ πρῶτα πέλασθεν.{l]
[l [n}12.421{]}ἀλλʼ ὥς τʼ ἀμφʼ οὔροισι δύʼ ἀνέρε δηριάασθον{l]
[l [n}12.422{]}μέτρʼ ἐν χερσὶν ἔχοντες ἐπιξύνῳ ἐν ἀρούρῃ,{l]
[l [n}12.423{]}ὥ τʼ ὀλίγῳ ἐνὶ χώρῳ ἐρίζητον περὶ ἴσης,{l]
[l [n}12.424{]}ὣς ἄρα τοὺς διέεργον ἐπάλξιες· οἳ δʼ ὑπὲρ αὐτέων{l]
[l [n}12.425{]}δῄουν ἀλλήλων ἀμφὶ στήθεσσι βοείας{l]
[l [n}12.426{]}ἀσπίδας εὐκύκλους λαισήϊά τε πτερόεντα.{l]
[l [n}12.427{]}πολλοὶ δʼ οὐτάζοντο κατὰ χρόα νηλέϊ χαλκῷ,{l]
[l [n}12.428{]}ἠμὲν ὅτεῳ στρεφθέντι μετάφρενα γυμνωθείη{l]
[l [n}12.429{]}μαρναμένων, πολλοὶ δὲ διαμπερὲς ἀσπίδος αὐτῆς.{l]
[l [n}12.430{]}πάντῃ δὴ πύργοι καὶ ἐπάλξιες αἵματι φωτῶν{l]
[l [n}12.431{]}ἐρράδατʼ ἀμφοτέρωθεν ἀπὸ Τρώων καὶ Ἀχαιῶν.{l]
[l [n}12.432{]}ἀλλʼ οὐδʼ ὧς ἐδύναντο φόβον ποιῆσαι Ἀχαιῶν,{l]
[l [n}12.433{]}ἀλλʼ ἔχον ὥς τε τάλαντα γυνὴ χερνῆτις ἀληθής,{l]
[l [n}12.434{]}ἥ τε σταθμὸν ἔχουσα καὶ εἴριον ἀμφὶς ἀνέλκει{l]
[l [n}12.435{]}ἰσάζουσʼ, ἵνα παισὶν ἀεικέα μισθὸν ἄρηται·{l]
[l [n}12.436{]}ὣς μὲν τῶν ἐπὶ ἶσα μάχη τέτατο πτόλεμός τε,{l]
[l [n}12.437{]}πρίν γʼ ὅτε δὴ Ζεὺς κῦδος ὑπέρτερον Ἕκτορι δῶκε{l]
[l [n}12.438{]}Πριαμίδῃ, ὃς πρῶτος ἐσήλατο τεῖχος Ἀχαιῶν.{l]
[l [n}12.439{]}ἤϋσεν δὲ διαπρύσιον Τρώεσσι γεγωνώς·{l]
[q}[l [n}12.440{]}ὄρνυσθʼ ἱππόδαμοι Τρῶες, ῥήγνυσθε δὲ τεῖχος{l]
[l [n}12.441{]}Ἀργείων καὶ νηυσὶν ἐνίετε θεσπιδαὲς πῦρ.{l]{q]{para]
[para}[l [n}12.442{]}ὣς φάτʼ ἐποτρύνων, οἳ δʼ οὔασι πάντες ἄκουον,{l]
[l [n}12.443{]}ἴθυσαν δʼ ἐπὶ τεῖχος ἀολλέες· οἳ μὲν ἔπειτα{l]
[l [n}12.444{]}κροσσάων ἐπέβαινον ἀκαχμένα δούρατʼ ἔχοντες,{l]
[l [n}12.445{]}Ἕκτωρ δʼ ἁρπάξας λᾶαν φέρεν, ὅς ῥα πυλάων{l]
[l [n}12.446{]}ἑστήκει πρόσθε πρυμνὸς παχύς, αὐτὰρ ὕπερθεν{l]
[l [n}12.447{]}ὀξὺς ἔην· τὸν δʼ οὔ κε δύʼ ἀνέρε δήμου ἀρίστω{l]
[l [n}12.448{]}ῥηϊδίως ἐπʼ ἄμαξαν ἀπʼ οὔδεος ὀχλίσσειαν,{l]
[l [n}12.449{]}οἷοι νῦν βροτοί εἰσʼ· ὃ δέ μιν ῥέα πάλλε καὶ οἶος.{l]
[l [n}12.450{]}τόν οἱ ἐλαφρὸν ἔθηκε Κρόνου πάϊς ἀγκυλομήτεω.{l]
[l [n}12.451{]}ὡς δʼ ὅτε ποιμὴν ῥεῖα φέρει πόκον ἄρσενος οἰὸς{l]
[l [n}12.452{]}χειρὶ λαβὼν ἑτέρῃ, ὀλίγον τέ μιν ἄχθος ἐπείγει,{l]
[l [n}12.453{]}ὣς Ἕκτωρ ἰθὺς σανίδων φέρε λᾶαν ἀείρας,{l]
[l [n}12.454{]}αἵ ῥα πύλας εἴρυντο πύκα στιβαρῶς ἀραρυίας{l]
[l [n}12.455{]}δικλίδας ὑψηλάς· δοιοὶ δʼ ἔντοσθεν ὀχῆες{l]
[l [n}12.456{]}εἶχον ἐπημοιβοί, μία δὲ κληῒς ἐπαρήρει.{l]
[l [n}12.457{]}στῆ δὲ μάλʼ ἐγγὺς ἰών, καὶ ἐρεισάμενος βάλε μέσσας{l]
[l [n}12.458{]}εὖ διαβάς, ἵνα μή οἱ ἀφαυρότερον βέλος εἴη,{l]
[l [n}12.459{]}ῥῆξε δʼ ἀπʼ ἀμφοτέρους θαιρούς· πέσε δὲ λίθος εἴσω{l]
[l [n}12.460{]}βριθοσύνῃ, μέγα δʼ ἀμφὶ πύλαι μύκον, οὐδʼ ἄρʼ ὀχῆες{l]
[l [n}12.461{]}ἐσχεθέτην, σανίδες δὲ διέτμαγεν ἄλλυδις ἄλλη{l]
[l [n}12.462{]}λᾶος ὑπὸ ῥιπῆς· ὃ δʼ ἄρʼ ἔσθορε φαίδιμος Ἕκτωρ{l]
[l [n}12.463{]}νυκτὶ θοῇ ἀτάλαντος ὑπώπια· λάμπε δὲ χαλκῷ{l]
[l [n}12.464{]}σμερδαλέῳ, τὸν ἕεστο περὶ χροΐ, δοιὰ δὲ χερσὶ{l]
[l [n}12.465{]}δοῦρʼ ἔχεν· οὔ κέν τίς μιν ἐρύκακεν ἀντιβολήσας{l]
[l [n}12.466{]}νόσφι θεῶν ὅτʼ ἐσᾶλτο πύλας· πυρὶ δʼ ὄσσε δεδήει.{l]
[l [n}12.467{]}κέκλετο δὲ Τρώεσσιν ἑλιξάμενος καθʼ ὅμιλον{l]
[l [n}12.468{]}τεῖχος ὑπερβαίνειν· τοὶ δʼ ὀτρύνοντι πίθοντο.{l]
[l [n}12.469{]}αὐτίκα δʼ οἳ μὲν τεῖχος ὑπέρβασαν, οἳ δὲ κατʼ αὐτὰς{l]
[l [n}12.470{]}ποιητὰς ἐσέχυντο πύλας· Δαναοὶ δὲ φόβηθεν{l]
[l [n}12.471{]}νῆας ἀνὰ γλαφυράς, ὅμαδος δʼ ἀλίαστος ἐτύχθη.{l]{para]
{book]
[book [n}13{]}
[para}[l [n}13.1{]}Ζεὺς δʼ ἐπεὶ οὖν Τρῶάς τε καὶ Ἕκτορα νηυσὶ πέλασσε,{l]
[l [n}13.2{]}τοὺς μὲν ἔα παρὰ τῇσι πόνον τʼ ἐχέμεν καὶ ὀϊζὺν{l]
[l [n}13.3{]}νωλεμέως, αὐτὸς δὲ πάλιν τρέπεν ὄσσε φαεινὼ{l]
[l [n}13.4{]}νόσφιν ἐφʼ ἱπποπόλων Θρῃκῶν καθορώμενος αἶαν{l]
[l [n}13.5{]}Μυσῶν τʼ ἀγχεμάχων καὶ ἀγαυῶν ἱππημολγῶν{l]
[l [n}13.6{]}γλακτοφάγων Ἀβίων τε δικαιοτάτων ἀνθρώπων.{l]
[l [n}13.7{]}ἐς Τροίην δʼ οὐ πάμπαν ἔτι τρέπεν ὄσσε φαεινώ·{l]
[l [n}13.8{]}οὐ γὰρ ὅ γʼ ἀθανάτων τινα ἔλπετο ὃν κατὰ θυμὸν{l]
[l [n}13.9{]}ἐλθόντʼ ἢ Τρώεσσιν ἀρηξέμεν ἢ Δαναοῖσιν.{l]{para]
[para}[l [n}13.10{]}οὐδʼ ἀλαοσκοπιὴν εἶχε κρείων ἐνοσίχθων·{l]
[l [n}13.11{]}καὶ γὰρ ὃ θαυμάζων ἧστο πτόλεμόν τε μάχην τε{l]
[l [n}13.12{]}ὑψοῦ ἐπʼ ἀκροτάτης κορυφῆς Σάμου ὑληέσσης{l]
[l [n}13.13{]}Θρηϊκίης· ἔνθεν γὰρ ἐφαίνετο πᾶσα μὲν Ἴδη,{l]
[l [n}13.14{]}φαίνετο δὲ Πριάμοιο πόλις καὶ νῆες Ἀχαιῶν.{l]
[l [n}13.15{]}ἔνθʼ ἄρʼ ὅ γʼ ἐξ ἁλὸς ἕζετʼ ἰών, ἐλέαιρε δʼ Ἀχαιοὺς{l]
[l [n}13.16{]}Τρωσὶν δαμναμένους, Διὶ δὲ κρατερῶς ἐνεμέσσα.{l]{para]
[para}[l [n}13.17{]}αὐτίκα δʼ ἐξ ὄρεος κατεβήσετο παιπαλόεντος{l]
[l [n}13.18{]}κραιπνὰ ποσὶ προβιβάς· τρέμε δʼ οὔρεα μακρὰ καὶ ὕλη{l]
[l [n}13.19{]}ποσσὶν ὑπʼ ἀθανάτοισι Ποσειδάωνος ἰόντος.{l]
[l [n}13.20{]}τρὶς μὲν ὀρέξατʼ ἰών, τὸ δὲ τέτρατον ἵκετο τέκμωρ{l]
[l [n}13.21{]}Αἰγάς, ἔνθα δέ οἱ κλυτὰ δώματα βένθεσι λίμνης{l]
[l [n}13.22{]}χρύσεα μαρμαίροντα τετεύχαται ἄφθιτα αἰεί.{l]
[l [n}13.23{]}ἔνθʼ ἐλθὼν ὑπʼ ὄχεσφι τιτύσκετο χαλκόποδʼ ἵππω{l]
[l [n}13.24{]}ὠκυπέτα χρυσέῃσιν ἐθείρῃσιν κομόωντε,{l]
[l [n}13.25{]}χρυσὸν δʼ αὐτὸς ἔδυνε περὶ χροΐ, γέντο δʼ ἱμάσθλην{l]
[l [n}13.26{]}χρυσείην εὔτυκτον, ἑοῦ δʼ ἐπεβήσετο δίφρου,{l]
[l [n}13.27{]}βῆ δʼ ἐλάαν ἐπὶ κύματʼ· ἄταλλε δὲ κήτεʼ ὑπʼ αὐτοῦ{l]
[l [n}13.28{]}πάντοθεν ἐκ κευθμῶν, οὐδʼ ἠγνοίησεν ἄνακτα·{l]
[l [n}13.29{]}γηθοσύνῃ δὲ θάλασσα διίστατο· τοὶ δὲ πέτοντο{l]
[l [n}13.30{]}ῥίμφα μάλʼ, οὐδʼ ὑπένερθε διαίνετο χάλκεος ἄξων·{l]
[l [n}13.31{]}τὸν δʼ ἐς Ἀχαιῶν νῆας ἐΰσκαρθμοι φέρον ἵπποι.{l]{para]
[para}[l [n}13.32{]}ἔστι δέ τι σπέος εὐρὺ βαθείης βένθεσι λίμνης{l]
[l [n}13.33{]}μεσσηγὺς Τενέδοιο καὶ Ἴμβρου παιπαλοέσσης·{l]
[l [n}13.34{]}ἔνθʼ ἵππους ἔστησε Ποσειδάων ἐνοσίχθων{l]
[l [n}13.35{]}λύσας ἐξ ὀχέων, παρὰ δʼ ἀμβρόσιον βάλεν εἶδαρ{l]
[l [n}13.36{]}ἔδμεναι· ἀμφὶ δὲ ποσσὶ πέδας ἔβαλε χρυσείας{l]
[l [n}13.37{]}ἀρρήκτους ἀλύτους, ὄφρʼ ἔμπεδον αὖθι μένοιεν{l]
[l [n}13.38{]}νοστήσαντα ἄνακτα· ὃ δʼ ἐς στρατὸν ᾤχετʼ Ἀχαιῶν.{l]{para]
[para}[l [n}13.39{]}Τρῶες δὲ φλογὶ ἶσοι ἀολλέες ἠὲ θυέλλῃ{l]
[l [n}13.40{]}Ἕκτορι Πριαμίδῃ ἄμοτον μεμαῶτες ἕποντο{l]
[l [n}13.41{]}ἄβρομοι αὐΐαχοι· ἔλποντο δὲ νῆας Ἀχαιῶν{l]
[l [n}13.42{]}αἱρήσειν, κτενέειν δὲ παρʼ αὐτόθι πάντας ἀρίστους.{l]
[l [n}13.43{]}ἀλλὰ Ποσειδάων γαιήοχος ἐννοσίγαιος{l]
[l [n}13.44{]}Ἀργείους ὄτρυνε βαθείης ἐξ ἁλὸς ἐλθὼν{l]
[l [n}13.45{]}εἰσάμενος Κάλχαντι δέμας καὶ ἀτειρέα φωνήν·{l]
[l [n}13.46{]}Αἴαντε πρώτω προσέφη μεμαῶτε καὶ αὐτώ·{l]
[q}[l [n}13.47{]}Αἴαντε σφὼ μέν τε σαώσετε λαὸν Ἀχαιῶν{l]
[l [n}13.48{]}ἀλκῆς μνησαμένω, μὴ δὲ κρυεροῖο φόβοιο.{l]
[l [n}13.49{]}ἄλλῃ μὲν γὰρ ἔγωγʼ οὐ δείδια χεῖρας ἀάπτους{l]
[l [n}13.50{]}Τρώων, οἳ μέγα τεῖχος ὑπερκατέβησαν ὁμίλῳ·{l]
[l [n}13.51{]}ἕξουσιν γὰρ πάντας ἐϋκνήμιδες Ἀχαιοί·{l]
[l [n}13.52{]}τῇ δὲ δὴ αἰνότατον περιδείδια μή τι πάθωμεν,{l]
[l [n}13.53{]}ᾗ ῥʼ ὅ γʼ ὁ λυσσώδης φλογὶ εἴκελος ἡγεμονεύει{l]
[l [n}13.54{]}Ἕκτωρ, ὃς Διὸς εὔχετʼ ἐρισθενέος πάϊς εἶναι.{l]
[l [n}13.55{]}σφῶϊν δʼ ὧδε θεῶν τις ἐνὶ φρεσὶ ποιήσειεν{l]
[l [n}13.56{]}αὐτώ θʼ ἑστάμεναι κρατερῶς καὶ ἀνωγέμεν ἄλλους·{l]
[l [n}13.57{]}τώ κε καὶ ἐσσύμενόν περ ἐρωήσαιτʼ ἀπὸ νηῶν{l]
[l [n}13.58{]}ὠκυπόρων, εἰ καί μιν Ὀλύμπιος αὐτὸς ἐγείρει.{l]{q]{para]
[para}[l [n}13.59{]}ἦ καὶ σκηπανίῳ γαιήοχος ἐννοσίγαιος{l]
[l [n}13.60{]}ἀμφοτέρω κεκοπὼς  πλῆσεν μένεος κρατεροῖο,{l]
[l [n}13.61{]}γυῖα δʼ ἔθηκεν ἐλαφρὰ πόδας καὶ χεῖρας ὕπερθεν.{l]
[l [n}13.62{]}αὐτὸς δʼ ὥς τʼ ἴρηξ ὠκύπτερος ὦρτο πέτεσθαι,{l]
[l [n}13.63{]}ὅς ῥά τʼ ἀπʼ αἰγίλιπος πέτρης περιμήκεος ἀρθεὶς{l]
[l [n}13.64{]}ὁρμήσῃ πεδίοιο διώκειν ὄρνεον ἄλλο,{l]
[l [n}13.65{]}ὣς ἀπὸ τῶν ἤϊξε Ποσειδάων ἐνοσίχθων.{l]
[l [n}13.66{]}τοῖιν δʼ ἔγνω πρόσθεν Ὀϊλῆος ταχὺς Αἴας,{l]
[l [n}13.67{]}αἶψα δʼ ἄρʼ Αἴαντα προσέφη Τελαμώνιον υἱόν·{l]
[q}[l [n}13.68{]}Αἶαν ἐπεί τις νῶϊ θεῶν οἳ Ὄλυμπον ἔχουσι{l]
[l [n}13.69{]}μάντεϊ εἰδόμενος κέλεται παρὰ νηυσὶ μάχεσθαι,{l]
[l [n}13.70{]}οὐδʼ ὅ γε Κάλχας ἐστὶ θεοπρόπος οἰωνιστής·{l]
[l [n}13.71{]}ἴχνια γὰρ μετόπισθε ποδῶν ἠδὲ κνημάων{l]
[l [n}13.72{]}ῥεῖʼ ἔγνων ἀπιόντος· ἀρίγνωτοι δὲ θεοί περ·{l]
[l [n}13.73{]}καὶ δʼ ἐμοὶ αὐτῷ θυμὸς ἐνὶ στήθεσσι φίλοισι{l]
[l [n}13.74{]}μᾶλλον ἐφορμᾶται πολεμίζειν ἠδὲ μάχεσθαι,{l]
[l [n}13.75{]}μαιμώωσι δʼ ἔνερθε πόδες καὶ χεῖρες ὕπερθε.{l]{q]{para]
[para}[l [n}13.76{]}τὸν δʼ ἀπαμειβόμενος προσέφη Τελαμώνιος Αἴας·{l]
[q}[l [n}13.77{]}οὕτω νῦν καὶ ἐμοὶ περὶ δούρατι χεῖρες ἄαπτοι{l]
[l [n}13.78{]}μαιμῶσιν, καί μοι μένος ὤρορε, νέρθε δὲ ποσσὶν{l]
[l [n}13.79{]}ἔσσυμαι ἀμφοτέροισι· μενοινώω δὲ καὶ οἶος{l]
[l [n}13.80{]}Ἕκτορι Πριαμίδῃ ἄμοτον μεμαῶτι μάχεσθαι.{l]{q]{para]
[para}[l [n}13.81{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον{l]
[l [n}13.82{]}χάρμῃ γηθόσυνοι, τήν σφιν θεὸς ἔμβαλε θυμῷ·{l]
[l [n}13.83{]}τόφρα δὲ τοὺς ὄπιθεν γαιήοχος ὦρσεν Ἀχαιούς,{l]
[l [n}13.84{]}οἳ παρὰ νηυσὶ θοῇσιν ἀνέψυχον φίλον ἦτορ.{l]
[l [n}13.85{]}τῶν ῥʼ ἅμα τʼ ἀργαλέῳ καμάτῳ φίλα γυῖα λέλυντο,{l]
[l [n}13.86{]}καί σφιν ἄχος κατὰ θυμὸν ἐγίγνετο δερκομένοισι{l]
[l [n}13.87{]}Τρῶας, τοὶ μέγα τεῖχος ὑπερκατέβησαν ὁμίλῳ.{l]
[l [n}13.88{]}τοὺς οἵ γʼ εἰσορόωντες ὑπʼ ὀφρύσι δάκρυα λεῖβον·{l]
[l [n}13.89{]}οὐ γὰρ ἔφαν φεύξεσθαι ὑπʼ ἐκ κακοῦ· ἀλλʼ ἐνοσίχθων{l]
[l [n}13.90{]}ῥεῖα μετεισάμενος κρατερὰς ὄτρυνε φάλαγγας.{l]
[l [n}13.91{]}Τεῦκρον ἔπι πρῶτον καὶ Λήϊτον ἦλθε κελεύων{l]
[l [n}13.92{]}Πηνέλεών θʼ ἥρωα Θόαντά τε Δηΐπυρόν τε{l]
[l [n}13.93{]}Μηριόνην τε καὶ Ἀντίλοχον μήστωρας ἀϋτῆς·{l]
[l [n}13.94{]}τοὺς ὅ γʼ ἐποτρύνων ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}13.95{]}αἰδὼς Ἀργεῖοι, κοῦροι νέοι· ὔμμιν ἔγωγε{l]
[l [n}13.96{]}μαρναμένοισι πέποιθα σαωσέμεναι νέας ἁμάς·{l]
[l [n}13.97{]}εἰ δʼ ὑμεῖς πολέμοιο μεθήσετε λευγαλέοιο,{l]
[l [n}13.98{]}νῦν δὴ εἴδεται ἦμαρ ὑπὸ Τρώεσσι δαμῆναι.{l]
[l [n}13.99{]}ὢ πόποι ἦ μέγα θαῦμα τόδʼ ὀφθαλμοῖσιν ὁρῶμαι{l]
[l [n}13.100{]}δεινόν, ὃ οὔ ποτʼ ἔγωγε τελευτήσεσθαι ἔφασκον,{l]
[l [n}13.101{]}Τρῶας ἐφʼ ἡμετέρας ἰέναι νέας, οἳ τὸ πάρος περ{l]
[l [n}13.102{]}φυζακινῇς ἐλάφοισιν ἐοίκεσαν, αἵ τε καθʼ ὕλην{l]
[l [n}13.103{]}θώων παρδαλίων τε λύκων τʼ ἤϊα πέλονται{l]
[l [n}13.104{]}αὔτως ἠλάσκουσαι ἀνάλκιδες, οὐδʼ ἔπι χάρμη·{l]
[l [n}13.105{]}ὣς Τρῶες τὸ πρίν γε μένος καὶ χεῖρας Ἀχαιῶν{l]
[l [n}13.106{]}μίμνειν οὐκ ἐθέλεσκον ἐναντίον, οὐδʼ ἠβαιόν·{l]
[l [n}13.107{]}νῦν δὲ ἑκὰς πόλιος κοίλῃς ἐπὶ νηυσὶ μάχονται{l]
[l [n}13.108{]}ἡγεμόνος κακότητι μεθημοσύνῃσί τε λαῶν,{l]
[l [n}13.109{]}οἳ κείνῳ ἐρίσαντες ἀμυνέμεν οὐκ ἐθέλουσι{l]
[l [n}13.110{]}νηῶν ὠκυπόρων, ἀλλὰ κτείνονται ἀνʼ αὐτάς.{l]
[l [n}13.111{]}ἀλλʼ εἰ δὴ καὶ πάμπαν ἐτήτυμον αἴτιός ἐστιν{l]
[l [n}13.112{]}ἥρως Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}13.113{]}οὕνεκʼ ἀπητίμησε ποδώκεα Πηλεΐωνα,{l]
[l [n}13.114{]}ἡμέας γʼ οὔ πως ἔστι μεθιέμεναι πολέμοιο.{l]
[l [n}13.115{]}ἀλλʼ ἀκεώμεθα θᾶσσον· ἀκεσταί τοι φρένες ἐσθλῶν.{l]
[l [n}13.116{]}ὑμεῖς δʼ οὐκ ἔτι καλὰ μεθίετε θούριδος ἀλκῆς{l]
[l [n}13.117{]}πάντες ἄριστοι ἐόντες ἀνὰ στρατόν. οὐδʼ ἂν ἔγωγε{l]
[l [n}13.118{]}ἀνδρὶ μαχεσσαίμην ὅς τις πολέμοιο μεθείη{l]
[l [n}13.119{]}λυγρὸς ἐών· ὑμῖν δὲ νεμεσσῶμαι περὶ κῆρι.{l]
[l [n}13.120{]}ὦ πέπονες τάχα δή τι κακὸν ποιήσετε μεῖζον{l]
[l [n}13.121{]}τῇδε μεθημοσύνῃ· ἀλλʼ ἐν φρεσὶ θέσθε ἕκαστος{l]
[l [n}13.122{]}αἰδῶ καὶ νέμεσιν· δὴ γὰρ μέγα νεῖκος ὄρωρεν.{l]
[l [n}13.123{]}Ἕκτωρ δὴ παρὰ νηυσὶ βοὴν ἀγαθὸς πολεμίζει{l]
[l [n}13.124{]}καρτερός, ἔρρηξεν δὲ πύλας καὶ μακρὸν ὀχῆα.{l]{q]{para]
[para}[l [n}13.125{]}ὥς ῥα κελευτιόων γαιήοχος ὦρσεν Ἀχαιούς.{l]
[l [n}13.126{]}ἀμφὶ δʼ ἄρʼ Αἴαντας δοιοὺς ἵσταντο φάλαγγες{l]
[l [n}13.127{]}καρτεραί, ἃς οὔτʼ ἄν κεν Ἄρης ὀνόσαιτο μετελθὼν{l]
[l [n}13.128{]}οὔτε κʼ Ἀθηναίη λαοσσόος· οἳ γὰρ ἄριστοι{l]
[l [n}13.129{]}κρινθέντες Τρῶάς τε καὶ Ἕκτορα δῖον ἔμιμνον,{l]
[l [n}13.130{]}φράξαντες δόρυ δουρί, σάκος σάκεϊ προθελύμνῳ·{l]
[l [n}13.131{]}ἀσπὶς ἄρʼ ἀσπίδʼ ἔρειδε, κόρυς κόρυν, ἀνέρα δʼ ἀνήρ·{l]
[l [n}13.132{]}ψαῦον δʼ ἱππόκομοι κόρυθες λαμπροῖσι φάλοισι{l]
[l [n}13.133{]}νευόντων, ὡς πυκνοὶ ἐφέστασαν ἀλλήλοισιν·{l]
[l [n}13.134{]}ἔγχεα δʼ ἐπτύσσοντο θρασειάων ἀπὸ χειρῶν{l]
[l [n}13.135{]}σειόμενʼ· οἳ δʼ ἰθὺς φρόνεον, μέμασαν δὲ μάχεσθαι.{l]{para]
[para}[l [n}13.136{]}Τρῶες δὲ προὔτυψαν ἀολλέες, ἦρχε δʼ ἄρʼ Ἕκτωρ{l]
[l [n}13.137{]}ἀντικρὺ μεμαώς, ὀλοοίτροχος ὣς ἀπὸ πέτρης,{l]
[l [n}13.138{]}ὅν τε κατὰ στεφάνης ποταμὸς χειμάρροος ὤσῃ{l]
[l [n}13.139{]}ῥήξας ἀσπέτῳ ὄμβρῳ ἀναιδέος ἔχματα πέτρης·{l]
[l [n}13.140{]}ὕψι δʼ ἀναθρῴσκων πέτεται, κτυπέει δέ θʼ ὑπʼ αὐτοῦ{l]
[l [n}13.141{]}ὕλη· ὃ δʼ ἀσφαλέως θέει ἔμπεδον, εἷος ἵκηται{l]
[l [n}13.142{]}ἰσόπεδον, τότε δʼ οὔ τι κυλίνδεται ἐσσύμενός περ·{l]
[l [n}13.143{]}ὣς Ἕκτωρ εἷος μὲν ἀπείλει μέχρι θαλάσσης{l]
[l [n}13.144{]}ῥέα διελεύσεσθαι κλισίας καὶ νῆας Ἀχαιῶν{l]
[l [n}13.145{]}κτείνων· ἀλλʼ ὅτε δὴ πυκινῇς ἐνέκυρσε φάλαγξι{l]
[l [n}13.146{]}στῆ ῥα μάλʼ ἐγχριμφθείς· οἳ δʼ ἀντίοι υἷες Ἀχαιῶν{l]
[l [n}13.147{]}νύσσοντες ξίφεσίν τε καὶ ἔγχεσιν ἀμφιγύοισιν{l]
[l [n}13.148{]}ὦσαν ἀπὸ σφείων· ὃ δὲ χασσάμενος πελεμίχθη.{l]
[l [n}13.149{]}ἤϋσεν δὲ διαπρύσιον Τρώεσσι γεγωνώς·{l]
[q}[l [n}13.150{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταὶ{l]
[l [n}13.151{]}παρμένετʼ· οὔ τοι δηρὸν ἐμὲ σχήσουσιν Ἀχαιοὶ{l]
[l [n}13.152{]}καὶ μάλα πυργηδὸν σφέας αὐτοὺς ἀρτύναντες,{l]
[l [n}13.153{]}ἀλλʼ ὀΐω χάσσονται ὑπʼ ἔγχεος, εἰ ἐτεόν με{l]
[l [n}13.154{]}ὦρσε θεῶν ὤριστος, ἐρίγδουπος πόσις Ἥρης.{l]{q]{para]
[para}[l [n}13.155{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}13.156{]}Δηΐφοβος δʼ ἐν τοῖσι μέγα φρονέων ἐβεβήκει{l]
[l [n}13.157{]}Πριαμίδης, πρόσθεν δʼ ἔχεν ἀσπίδα πάντοσʼ ἐΐσην{l]
[l [n}13.158{]}κοῦφα ποσὶ προβιβὰς καὶ ὑπασπίδια προποδίζων.{l]
[l [n}13.159{]}Μηριόνης δʼ αὐτοῖο τιτύσκετο δουρὶ φαεινῷ{l]
[l [n}13.160{]}καὶ βάλεν, οὐδʼ ἀφάμαρτε, κατʼ ἀσπίδα πάντοσʼ ἐΐσην{l]
[l [n}13.161{]}ταυρείην· τῆς δʼ οὔ τι διήλασεν, ἀλλὰ πολὺ πρὶν{l]
[l [n}13.162{]}ἐν καυλῷ ἐάγη δολιχὸν δόρυ· Δηΐφοβος δὲ{l]
[l [n}13.163{]}ἀσπίδα ταυρείην σχέθʼ ἀπὸ ἕο, δεῖσε δὲ θυμῷ{l]
[l [n}13.164{]}ἔγχος Μηριόναο δαΐφρονος· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}13.165{]}ἂψ ἑτάρων εἰς ἔθνος ἐχάζετο, χώσατο δʼ αἰνῶς{l]
[l [n}13.166{]}ἀμφότερον, νίκης τε καὶ ἔγχεος ὃ ξυνέαξε.{l]
[l [n}13.167{]}βῆ δʼ ἰέναι παρά τε κλισίας καὶ νῆας Ἀχαιῶν{l]
[l [n}13.168{]}οἰσόμενος δόρυ μακρόν, ὅ οἱ κλισίηφι λέλειπτο.{l]{para]
[para}[l [n}13.169{]}οἳ δʼ ἄλλοι μάρναντο, βοὴ δʼ ἄσβεστος ὀρώρει.{l]
[l [n}13.170{]}Τεῦκρος δὲ πρῶτος Τελαμώνιος ἄνδρα κατέκτα{l]
[l [n}13.171{]}Ἴμβριον αἰχμητὴν πολυΐππου Μέντορος υἱόν·{l]
[l [n}13.172{]}ναῖε δὲ Πήδαιον πρὶν ἐλθεῖν υἷας Ἀχαιῶν,{l]
[l [n}13.173{]}κούρην δὲ Πριάμοιο νόθην ἔχε, Μηδεσικάστην·{l]
[l [n}13.174{]}αὐτὰρ ἐπεὶ Δαναῶν νέες ἤλυθον ἀμφιέλισσαι,{l]
[l [n}13.175{]}ἂψ ἐς Ἴλιον ἦλθε, μετέπρεπε δὲ Τρώεσσι,{l]
[l [n}13.176{]}ναῖε δὲ πὰρ Πριάμῳ· ὃ δέ μιν τίεν ἶσα τέκεσσι.{l]
[l [n}13.177{]}τόν ῥʼ υἱὸς Τελαμῶνος ὑπʼ οὔατος ἔγχεϊ μακρῷ{l]
[l [n}13.178{]}νύξʼ, ἐκ δʼ ἔσπασεν ἔγχος· ὃ δʼ αὖτʼ ἔπεσεν μελίη ὣς{l]
[l [n}13.179{]}ἥ τʼ ὄρεος κορυφῇ ἕκαθεν περιφαινομένοιο{l]
[l [n}13.180{]}χαλκῷ ταμνομένη τέρενα χθονὶ φύλλα πελάσσῃ·{l]
[l [n}13.181{]}ὣς πέσεν, ἀμφὶ δέ οἱ βράχε τεύχεα ποικίλα χαλκῷ.{l]
[l [n}13.182{]}Τεῦκρος δʼ ὁρμήθη μεμαὼς ἀπὸ τεύχεα δῦσαι·{l]
[l [n}13.183{]}Ἕκτωρ δʼ ὁρμηθέντος ἀκόντισε δουρὶ φαεινῷ.{l]
[l [n}13.184{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος{l]
[l [n}13.185{]}τυτθόν· ὃ δʼ Ἀμφίμαχον Κτεάτου υἷʼ Ἀκτορίωνος{l]
[l [n}13.186{]}νισόμενον πόλεμον δὲ κατὰ στῆθος βάλε δουρί·{l]
[l [n}13.187{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]
[l [n}13.188{]}Ἕκτωρ δʼ ὁρμήθη κόρυθα κροτάφοις ἀραρυῖαν{l]
[l [n}13.189{]}κρατὸς ἀφαρπάξαι μεγαλήτορος Ἀμφιμάχοιο·{l]
[l [n}13.190{]}Αἴας δʼ ὁρμηθέντος ὀρέξατο δουρὶ φαεινῷ{l]
[l [n}13.191{]}Ἕκτορος· ἀλλʼ οὔ πῃ χροὸς εἴσατο, πᾶς δʼ ἄρα χαλκῷ{l]
[l [n}13.192{]}σμερδαλέῳ κεκάλυφθʼ· ὃ δʼ ἄρʼ ἀσπίδος ὀμφαλὸν οὖτα,{l]
[l [n}13.193{]}ὦσε δέ μιν σθένεϊ μεγάλῳ· ὃ δὲ χάσσατʼ ὀπίσσω{l]
[l [n}13.194{]}νεκρῶν ἀμφοτέρων, τοὺς δʼ ἐξείρυσσαν Ἀχαιοί.{l]
[l [n}13.195{]}Ἀμφίμαχον μὲν ἄρα Στιχίος δῖός τε Μενεσθεὺς{l]
[l [n}13.196{]}ἀρχοὶ Ἀθηναίων κόμισαν μετὰ λαὸν Ἀχαιῶν·{l]
[l [n}13.197{]}Ἴμβριον αὖτʼ Αἴαντε μεμαότε θούριδος ἀλκῆς{l]
[l [n}13.198{]}ὥς τε δύʼ αἶγα λέοντε κυνῶν ὕπο καρχαροδόντων{l]
[l [n}13.199{]}ἁρπάξαντε φέρητον ἀνὰ ῥωπήϊα πυκνὰ{l]
[l [n}13.200{]}ὑψοῦ ὑπὲρ γαίης μετὰ γαμφηλῇσιν ἔχοντε,{l]
[l [n}13.201{]}ὥς ῥα τὸν ὑψοῦ ἔχοντε δύω Αἴαντε κορυστὰ{l]
[l [n}13.202{]}τεύχεα συλήτην· κεφαλὴν δʼ ἁπαλῆς ἀπὸ δειρῆς{l]
[l [n}13.203{]}κόψεν Ὀϊλιάδης κεχολωμένος Ἀμφιμάχοιο,{l]
[l [n}13.204{]}ἧκε δέ μιν σφαιρηδὸν ἑλιξάμενος διʼ ὁμίλου·{l]
[l [n}13.205{]}Ἕκτορι δὲ προπάροιθε ποδῶν πέσεν ἐν κονίῃσι.{l]{para]
[para}[l [n}13.206{]}καὶ τότε δὴ περὶ κῆρι Ποσειδάων ἐχολώθη{l]
[l [n}13.207{]}υἱωνοῖο πεσόντος ἐν αἰνῇ δηϊοτῆτι,{l]
[l [n}13.208{]}βῆ δʼ ἰέναι παρά τε κλισίας καὶ νῆας Ἀχαιῶν{l]
[l [n}13.209{]}ὀτρυνέων Δαναούς, Τρώεσσι δὲ κήδεα τεῦχεν.{l]
[l [n}13.210{]}Ἰδομενεὺς δʼ ἄρα οἱ δουρικλυτὸς ἀντεβόλησεν{l]
[l [n}13.211{]}ἐρχόμενος παρʼ ἑταίρου, ὅ οἱ νέον ἐκ πολέμοιο{l]
[l [n}13.212{]}ἦλθε κατʼ ἰγνύην βεβλημένος ὀξέϊ χαλκῷ.{l]
[l [n}13.213{]}τὸν μὲν ἑταῖροι ἔνεικαν, ὃ δʼ ἰητροῖς ἐπιτείλας{l]
[l [n}13.214{]}ἤϊεν ἐς κλισίην· ἔτι γὰρ πολέμοιο μενοίνα{l]
[l [n}13.215{]}ἀντιάαν· τὸν δὲ προσέφη κρείων ἐνοσίχθων{l]
[l [n}13.216{]}εἰσάμενος φθογγὴν Ἀνδραίμονος υἷϊ Θόαντι{l]
[l [n}13.217{]}ὃς πάσῃ Πλευρῶνι καὶ αἰπεινῇ Καλυδῶνι{l]
[l [n}13.218{]}Αἰτωλοῖσιν ἄνασσε, θεὸς δʼ ὣς τίετο δήμῳ·{l]
[q}[l [n}13.219{]}Ἰδομενεῦ Κρητῶν βουληφόρε ποῦ τοι ἀπειλαὶ{l]
[l [n}13.220{]}οἴχονται, τὰς Τρωσὶν ἀπείλεον υἷες Ἀχαιῶν;{l]{q]{para]
[para}[l [n}13.221{]}τὸν δʼ αὖτʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}13.222{]}ὦ Θόαν οὔ τις ἀνὴρ νῦν γʼ αἴτιος, ὅσσον ἔγωγε{l]
[l [n}13.223{]}γιγνώσκω· πάντες γὰρ ἐπιστάμεθα πτολεμίζειν.{l]
[l [n}13.224{]}οὔτέ τινα δέος ἴσχει ἀκήριον οὔτέ τις ὄκνῳ{l]
[l [n}13.225{]}εἴκων ἀνδύεται πόλεμον κακόν· ἀλλά που οὕτω{l]
[l [n}13.226{]}μέλλει δὴ φίλον εἶναι ὑπερμενέϊ Κρονίωνι{l]
[l [n}13.227{]}νωνύμνους ἀπολέσθαι ἀπʼ Ἄργεος ἐνθάδʼ Ἀχαιούς.{l]
[l [n}13.228{]}ἀλλὰ Θόαν, καὶ γὰρ τὸ πάρος μενεδήϊος ἦσθα,{l]
[l [n}13.229{]}ὀτρύνεις δὲ καὶ ἄλλον ὅθι μεθιέντα ἴδηαι·{l]
[l [n}13.230{]}τὼ νῦν μήτʼ ἀπόληγε κέλευέ τε φωτὶ ἑκάστῳ.{l]{q]{para]
[para}[l [n}13.231{]}τὸν δʼ ἠμείβετʼ ἔπειτα Ποσειδάων ἐνοσίχθων·{l]
[q}[l [n}13.232{]}Ἰδομενεῦ μὴ κεῖνος ἀνὴρ ἔτι νοστήσειεν{l]
[l [n}13.233{]}ἐκ Τροίης, ἀλλʼ αὖθι κυνῶν μέλπηθρα γένοιτο,{l]
[l [n}13.234{]}ὅς τις ἐπʼ ἤματι τῷδε ἑκὼν μεθίῃσι μάχεσθαι.{l]
[l [n}13.235{]}ἀλλʼ ἄγε τεύχεα δεῦρο λαβὼν ἴθι· ταῦτα δʼ ἅμα χρὴ{l]
[l [n}13.236{]}σπεύδειν, αἴ κʼ ὄφελός τι γενώμεθα καὶ δύʼ ἐόντε.{l]
[l [n}13.237{]}συμφερτὴ δʼ ἀρετὴ πέλει ἀνδρῶν καὶ μάλα λυγρῶν,{l]
[l [n}13.238{]}νῶϊ δὲ καί κʼ ἀγαθοῖσιν ἐπισταίμεσθα μάχεσθαι.{l]{q]{para]
[para}[l [n}13.239{]}ὣς εἰπὼν ὃ μὲν αὖτις ἔβη θεὸς ἂμ πόνον ἀνδρῶν·{l]
[l [n}13.240{]}Ἰδομενεὺς δʼ ὅτε δὴ κλισίην εὔτυκτον ἵκανε{l]
[l [n}13.241{]}δύσετο τεύχεα καλὰ περὶ χροΐ, γέντο δὲ δοῦρε,{l]
[l [n}13.242{]}βῆ δʼ ἴμεν ἀστεροπῇ ἐναλίγκιος, ἥν τε Κρονίων{l]
[l [n}13.243{]}χειρὶ λαβὼν ἐτίναξεν ἀπʼ αἰγλήεντος Ὀλύμπου{l]
[l [n}13.244{]}δεικνὺς σῆμα βροτοῖσιν· ἀρίζηλοι δέ οἱ αὐγαί·{l]
[l [n}13.245{]}ὣς τοῦ χαλκὸς ἔλαμπε περὶ στήθεσσι θέοντος.{l]
[l [n}13.246{]}Μηριόνης δʼ ἄρα οἱ θεράπων ἐῢς ἀντεβόλησεν{l]
[l [n}13.247{]}ἐγγὺς ἔτι κλισίης· μετὰ γὰρ δόρυ χάλκεον ᾔει{l]
[l [n}13.248{]}οἰσόμενος· τὸν δὲ προσέφη σθένος Ἰδομενῆος·{l]
[q}[l [n}13.249{]}Μηριόνη Μόλου υἱὲ πόδας ταχὺ φίλταθʼ ἑταίρων{l]
[l [n}13.250{]}τίπτʼ ἦλθες πόλεμόν τε λιπὼν καὶ δηϊοτῆτα;{l]
[l [n}13.251{]}ἠέ τι βέβληαι, βέλεος δέ σε τείρει ἀκωκή,{l]
[l [n}13.252{]}ἦέ τευ ἀγγελίης μετʼ ἔμʼ ἤλυθες; οὐδέ τοι αὐτὸς{l]
[l [n}13.253{]}ἧσθαι ἐνὶ κλισίῃσι λιλαίομαι, ἀλλὰ μάχεσθαι.{l]{q]{para]
[para}[l [n}13.254{]}τὸν δʼ αὖ Μηριόνης πεπνυμένος ἀντίον ηὔδα·{l]
[q}[l [n}13.255{]}Ἰδομενεῦ, Κρητῶν βουληφόρε χαλκοχιτώνων,{l]
[l [n}13.256{]}ἔρχομαι εἴ τί τοι ἔγχος ἐνὶ κλισίῃσι λέλειπται{l]
[l [n}13.257{]}οἰσόμενος· τό νυ γὰρ κατεάξαμεν ὃ πρὶν ἔχεσκον{l]
[l [n}13.258{]}ἀσπίδα Δηϊφόβοιο βαλὼν ὑπερηνορέοντος.{l]{q]{para]
[para}[l [n}13.259{]}τὸν δʼ αὖτʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}13.260{]}δούρατα δʼ αἴ κʼ ἐθέλῃσθα καὶ ἓν καὶ εἴκοσι δήεις{l]
[l [n}13.261{]}ἑσταότʼ ἐν κλισίῃ πρὸς ἐνώπια παμφανόωντα{l]
[l [n}13.262{]}Τρώϊα, τὰ κταμένων ἀποαίνυμαι· οὐ γὰρ ὀΐω{l]
[l [n}13.263{]}ἀνδρῶν δυσμενέων ἑκὰς ἱστάμενος πολεμίζειν.{l]
[l [n}13.264{]}τώ μοι δούρατά τʼ ἔστι καὶ ἀσπίδες ὀμφαλόεσσαι{l]
[l [n}13.265{]}καὶ κόρυθες καὶ θώρηκες λαμπρὸν γανόωντες.{l]{q]{para]
[para}[l [n}13.266{]}τὸν δʼ αὖ Μηριόνης πεπνυμένος ἀντίον ηὔδα·{l]
[q}[l [n}13.267{]}καί τοι ἐμοὶ παρά τε κλισίῃ καὶ νηῒ μελαίνῃ{l]
[l [n}13.268{]}πόλλʼ ἔναρα Τρώων· ἀλλʼ οὐ σχεδόν ἐστιν ἑλέσθαι.{l]
[l [n}13.269{]}οὐδὲ γὰρ οὐδʼ ἐμέ φημι λελασμένον ἔμμεναι ἀλκῆς,{l]
[l [n}13.270{]}ἀλλὰ μετὰ πρώτοισι μάχην ἀνὰ κυδιάνειραν{l]
[l [n}13.271{]}ἵσταμαι, ὁππότε νεῖκος ὀρώρηται πολέμοιο.{l]
[l [n}13.272{]}ἄλλόν πού τινα μᾶλλον Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}13.273{]}λήθω μαρνάμενος, σὲ δὲ ἴδμεναι αὐτὸν ὀΐω.{l]{q]{para]
[para}[l [n}13.274{]}τὸν δʼ αὖτʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}13.275{]}οἶδʼ ἀρετὴν οἷός ἐσσι· τί σε χρὴ ταῦτα λέγεσθαι;{l]
[l [n}13.276{]}εἰ γὰρ νῦν παρὰ νηυσὶ λεγοίμεθα πάντες ἄριστοι{l]
[l [n}13.277{]}ἐς λόχον, ἔνθα μάλιστʼ ἀρετὴ διαείδεται ἀνδρῶν,{l]
[l [n}13.278{]}ἔνθʼ ὅ τε δειλὸς ἀνὴρ ὅς τʼ ἄλκιμος ἐξεφαάνθη·{l]
[l [n}13.279{]}τοῦ μὲν γάρ τε κακοῦ τρέπεται χρὼς ἄλλυδις ἄλλῃ,{l]
[l [n}13.280{]}οὐδέ οἱ ἀτρέμας ἧσθαι ἐρητύετʼ ἐν φρεσὶ θυμός,{l]
[l [n}13.281{]}ἀλλὰ μετοκλάζει καὶ ἐπʼ ἀμφοτέρους πόδας ἵζει,{l]
[l [n}13.282{]}ἐν δέ τέ οἱ κραδίη μεγάλα στέρνοισι πατάσσει{l]
[l [n}13.283{]}κῆρας ὀϊομένῳ, πάταγος δέ τε γίγνετʼ ὀδόντων·{l]
[l [n}13.284{]}τοῦ δʼ ἀγαθοῦ οὔτʼ ἂρ τρέπεται χρὼς οὔτέ τι λίην{l]
[l [n}13.285{]}ταρβεῖ, ἐπειδὰν πρῶτον ἐσίζηται λόχον ἀνδρῶν,{l]
[l [n}13.286{]}ἀρᾶται δὲ τάχιστα μιγήμεναι ἐν δαῒ λυγρῇ·{l]
[l [n}13.287{]}οὐδέ κεν ἔνθα τεόν γε μένος καὶ χεῖρας ὄνοιτο.{l]
[l [n}13.288{]}εἴ περ γάρ κε βλεῖο πονεύμενος ἠὲ τυπείης{l]
[l [n}13.289{]}οὐκ ἂν ἐν αὐχένʼ ὄπισθε πέσοι βέλος οὐδʼ ἐνὶ νώτῳ,{l]
[l [n}13.290{]}ἀλλά κεν ἢ στέρνων ἢ νηδύος ἀντιάσειε{l]
[l [n}13.291{]}πρόσσω ἱεμένοιο μετὰ προμάχων ὀαριστύν.{l]
[l [n}13.292{]}ἀλλʼ ἄγε μηκέτι ταῦτα λεγώμεθα νηπύτιοι ὣς{l]
[l [n}13.293{]}ἑσταότες, μή πού τις ὑπερφιάλως νεμεσήσῃ·{l]
[l [n}13.294{]}ἀλλὰ σύ γε κλισίην δὲ κιὼν ἕλευ ὄβριμον ἔγχος.{l]{q]{para]
[para}[l [n}13.295{]}ὣς φάτο, Μηριόνης δὲ θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}13.296{]}καρπαλίμως κλισίηθεν ἀνείλετο χάλκεον ἔγχος,{l]
[l [n}13.297{]}βῆ δὲ μετʼ Ἰδομενῆα μέγα πτολέμοιο μεμηλώς.{l]
[l [n}13.298{]}οἷος δὲ βροτολοιγὸς Ἄρης πόλεμον δὲ μέτεισι,{l]
[l [n}13.299{]}τῷ δὲ Φόβος φίλος υἱὸς ἅμα κρατερὸς καὶ ἀταρβὴς{l]
[l [n}13.300{]}ἕσπετο, ὅς τʼ ἐφόβησε ταλάφρονά περ πολεμιστήν·{l]
[l [n}13.301{]}τὼ μὲν ἄρʼ ἐκ Θρῄκης Ἐφύρους μέτα θωρήσσεσθον,{l]
[l [n}13.302{]}ἠὲ μετὰ Φλεγύας μεγαλήτορας· οὐδʼ ἄρα τώ γε{l]
[l [n}13.303{]}ἔκλυον ἀμφοτέρων, ἑτέροισι δὲ κῦδος ἔδωκαν·{l]
[l [n}13.304{]}τοῖοι Μηριόνης τε καὶ Ἰδομενεὺς ἀγοὶ ἀνδρῶν{l]
[l [n}13.305{]}ἤϊσαν ἐς πόλεμον κεκορυθμένοι αἴθοπι χαλκῷ.{l]
[l [n}13.306{]}τὸν καὶ Μηριόνης πρότερος πρὸς μῦθον ἔειπε·{l]
[q}[l [n}13.307{]}Δευκαλίδη πῇ τὰρ μέμονας καταδῦναι ὅμιλον;{l]
[l [n}13.308{]}ἢ ἐπὶ δεξιόφιν παντὸς στρατοῦ, ἦ ἀνὰ μέσσους,{l]
[l [n}13.309{]}ἦ ἐπʼ ἀριστερόφιν; ἐπεὶ οὔ ποθι ἔλπομαι οὕτω{l]
[l [n}13.310{]}δεύεσθαι πολέμοιο κάρη κομόωντας Ἀχαιούς.{l]{q]{para]
[para}[l [n}13.311{]}τὸν δʼ αὖτʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}13.312{]}νηυσὶ μὲν ἐν μέσσῃσιν ἀμύνειν εἰσὶ καὶ ἄλλοι{l]
[l [n}13.313{]}Αἴαντές τε δύω Τεῦκρός θʼ, ὃς ἄριστος Ἀχαιῶν{l]
[l [n}13.314{]}τοξοσύνῃ, ἀγαθὸς δὲ καὶ ἐν σταδίῃ ὑσμίνῃ·{l]
[l [n}13.315{]}οἵ μιν ἅδην ἐλόωσι καὶ ἐσσύμενον πολέμοιο{l]
[l [n}13.316{]}Ἕκτορα Πριαμίδην, καὶ εἰ μάλα καρτερός ἐστιν.{l]
[l [n}13.317{]}αἰπύ οἱ ἐσσεῖται μάλα περ μεμαῶτι μάχεσθαι{l]
[l [n}13.318{]}κείνων νικήσαντι μένος καὶ χεῖρας ἀάπτους{l]
[l [n}13.319{]}νῆας ἐνιπρῆσαι, ὅτε μὴ αὐτός γε Κρονίων{l]
[l [n}13.320{]}ἐμβάλοι αἰθόμενον δαλὸν νήεσσι θοῇσιν.{l]
[l [n}13.321{]}ἀνδρὶ δέ κʼ οὐκ εἴξειε μέγας Τελαμώνιος Αἴας,{l]
[l [n}13.322{]}ὃς θνητός τʼ εἴη καὶ ἔδοι Δημήτερος ἀκτὴν{l]
[l [n}13.323{]}χαλκῷ τε ῥηκτὸς μεγάλοισί τε χερμαδίοισιν.{l]
[l [n}13.324{]}οὐδʼ ἂν Ἀχιλλῆϊ ῥηξήνορι χωρήσειεν{l]
[l [n}13.325{]}ἔν γʼ αὐτοσταδίῃ· ποσὶ δʼ οὔ πως ἔστιν ἐρίζειν.{l]
[l [n}13.326{]}νῶϊν δʼ ὧδʼ ἐπʼ ἀριστέρʼ ἔχε στρατοῦ, ὄφρα τάχιστα{l]
[l [n}13.327{]}εἴδομεν ἠέ τῳ εὖχος ὀρέξομεν, ἦέ τις ἡμῖν.{l]{q]{para]
[para}[l [n}13.328{]}ὣς φάτο, Μηριόνης δὲ θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}13.329{]}ἦρχʼ ἴμεν, ὄφρʼ ἀφίκοντο κατὰ στρατὸν ᾗ μιν ἀνώγει,{l]{para]
[para}[l [n}13.330{]}οἳ δʼ ὡς Ἰδομενῆα ἴδον φλογὶ εἴκελον ἀλκὴν{l]
[l [n}13.331{]}αὐτὸν καὶ θεράποντα σὺν ἔντεσι δαιδαλέοισι,{l]
[l [n}13.332{]}κεκλόμενοι καθʼ ὅμιλον ἐπʼ αὐτῷ πάντες ἔβησαν·{l]
[l [n}13.333{]}τῶν δʼ ὁμὸν ἵστατο νεῖκος ἐπὶ πρυμνῇσι νέεσσιν.{l]
[l [n}13.334{]}ὡς δʼ ὅθʼ ὑπὸ λιγέων ἀνέμων σπέρχωσιν ἄελλαι{l]
[l [n}13.335{]}ἤματι τῷ ὅτε τε πλείστη κόνις ἀμφὶ κελεύθους,{l]
[l [n}13.336{]}οἵ τʼ ἄμυδις κονίης μεγάλην ἱστᾶσιν ὀμίχλην,{l]
[l [n}13.337{]}ὣς ἄρα τῶν ὁμόσʼ ἦλθε μάχη, μέμασαν δʼ ἐνὶ θυμῷ{l]
[l [n}13.338{]}ἀλλήλους καθʼ ὅμιλον ἐναιρέμεν ὀξέϊ χαλκῷ.{l]
[l [n}13.339{]}ἔφριξεν δὲ μάχη φθισίμβροτος ἐγχείῃσι{l]
[l [n}13.340{]}μακρῇς, ἃς εἶχον ταμεσίχροας· ὄσσε δʼ ἄμερδεν{l]
[l [n}13.341{]}αὐγὴ χαλκείη κορύθων ἄπο λαμπομενάων{l]
[l [n}13.342{]}θωρήκων τε νεοσμήκτων σακέων τε φαεινῶν{l]
[l [n}13.343{]}ἐρχομένων ἄμυδις· μάλα κεν θρασυκάρδιος εἴη{l]
[l [n}13.344{]}ὃς τότε γηθήσειεν ἰδὼν πόνον οὐδʼ ἀκάχοιτο.{l]{para]
[para}[l [n}13.345{]}τὼ δʼ ἀμφὶς φρονέοντε δύω Κρόνου υἷε κραταιὼ{l]
[l [n}13.346{]}ἀνδράσιν ἡρώεσσιν ἐτεύχετον ἄλγεα λυγρά.{l]
[l [n}13.347{]}Ζεὺς μέν ῥα Τρώεσσι καὶ Ἕκτορι βούλετο νίκην{l]
[l [n}13.348{]}κυδαίνων Ἀχιλῆα πόδας ταχύν· οὐδέ τι πάμπαν{l]
[l [n}13.349{]}ἤθελε λαὸν ὀλέσθαι Ἀχαιϊκὸν Ἰλιόθι πρό,{l]
[l [n}13.350{]}ἀλλὰ Θέτιν κύδαινε καὶ υἱέα καρτερόθυμον.{l]
[l [n}13.351{]}Ἀργείους δὲ Ποσειδάων ὀρόθυνε μετελθὼν{l]
[l [n}13.352{]}λάθρῃ ὑπεξαναδὺς πολιῆς ἁλός· ἤχθετο γάρ ῥα{l]
[l [n}13.353{]}Τρωσὶν δαμναμένους, Διὶ δὲ κρατερῶς ἐνεμέσσα.{l]
[l [n}13.354{]}ἦ μὰν ἀμφοτέροισιν ὁμὸν γένος ἠδʼ ἴα πάτρη,{l]
[l [n}13.355{]}ἀλλὰ Ζεὺς πρότερος γεγόνει καὶ πλείονα ᾔδη.{l]
[l [n}13.356{]}τώ ῥα καὶ ἀμφαδίην μὲν ἀλεξέμεναι ἀλέεινε,{l]
[l [n}13.357{]}λάθρῃ δʼ αἰὲν ἔγειρε κατὰ στρατὸν ἀνδρὶ ἐοικώς.{l]
[l [n}13.358{]}τοὶ δʼ ἔριδος κρατερῆς καὶ ὁμοιΐου πτολέμοιο{l]
[l [n}13.359{]}πεῖραρ ἐπαλλάξαντες ἐπʼ ἀμφοτέροισι τάνυσσαν{l]
[l [n}13.360{]}ἄρρηκτόν τʼ ἄλυτόν τε, τὸ πολλῶν γούνατʼ ἔλυσεν.{l]{para]
[para}[l [n}13.361{]}ἔνθα μεσαιπόλιός περ ἐὼν Δαναοῖσι κελεύσας{l]
[l [n}13.362{]}Ἰδομενεὺς Τρώεσσι μετάλμενος ἐν φόβον ὦρσε.{l]
[l [n}13.363{]}πέφνε γὰρ Ὀθρυονῆα Καβησόθεν ἔνδον ἐόντα,{l]
[l [n}13.364{]}ὅς ῥα νέον πολέμοιο μετὰ κλέος εἰληλούθει,{l]
[l [n}13.365{]}ᾔτεε δὲ Πριάμοιο θυγατρῶν εἶδος ἀρίστην{l]
[l [n}13.366{]}Κασσάνδρην ἀνάεδνον, ὑπέσχετο δὲ μέγα ἔργον,{l]
[l [n}13.367{]}ἐκ Τροίης ἀέκοντας ἀπωσέμεν υἷας Ἀχαιῶν.{l]
[l [n}13.368{]}τῷ δʼ ὁ γέρων Πρίαμος ὑπό τʼ ἔσχετο καὶ κατένευσε{l]
[l [n}13.369{]}δωσέμεναι· ὃ δὲ μάρναθʼ ὑποσχεσίῃσι πιθήσας.{l]
[l [n}13.370{]}Ἰδομενεὺς δʼ αὐτοῖο τιτύσκετο δουρὶ φαεινῷ,{l]
[l [n}13.371{]}καὶ βάλεν ὕψι βιβάντα τυχών· οὐδʼ ἤρκεσε θώρηξ{l]
[l [n}13.372{]}χάλκεος, ὃν φορέεσκε, μέσῃ δʼ ἐν γαστέρι πῆξε.{l]
[l [n}13.373{]}δούπησεν δὲ πεσών· ὃ δʼ ἐπεύξατο φώνησέν τε·{l]
[q}[l [n}13.374{]}Ὀθρυονεῦ περὶ δή σε βροτῶν αἰνίζομʼ ἁπάντων{l]
[l [n}13.375{]}εἰ ἐτεὸν δὴ πάντα τελευτήσεις ὅσʼ ὑπέστης{l]
[l [n}13.376{]}Δαρδανίδῃ Πριάμῳ· ὃ δʼ ὑπέσχετο θυγατέρα ἥν.{l]
[l [n}13.377{]}καί κέ τοι ἡμεῖς ταῦτά γʼ ὑποσχόμενοι τελέσαιμεν,{l]
[l [n}13.378{]}δοῖμεν δʼ Ἀτρεΐδαο θυγατρῶν εἶδος ἀρίστην{l]
[l [n}13.379{]}Ἄργεος ἐξαγαγόντες ὀπυιέμεν, εἴ κε σὺν ἄμμιν{l]
[l [n}13.380{]}Ἰλίου ἐκπέρσῃς εὖ ναιόμενον πτολίεθρον.{l]
[l [n}13.381{]}ἀλλʼ ἕπεʼ, ὄφρʼ ἐπὶ νηυσὶ συνώμεθα ποντοπόροισιν{l]
[l [n}13.382{]}ἀμφὶ γάμῳ, ἐπεὶ οὔ τοι ἐεδνωταὶ κακοί εἰμεν.{l]{q]{para]
[para}[l [n}13.383{]}ὣς εἰπὼν ποδὸς ἕλκε κατὰ κρατερὴν ὑσμίνην{l]
[l [n}13.384{]}ἥρως Ἰδομενεύς· τῷ δʼ Ἄσιος ἦλθʼ ἐπαμύντωρ{l]
[l [n}13.385{]}πεζὸς πρόσθʼ ἵππων· τὼ δὲ πνείοντε κατʼ ὤμων{l]
[l [n}13.386{]}αἰὲν ἔχʼ ἡνίοχος θεράπων· ὃ δὲ ἵετο θυμῷ{l]
[l [n}13.387{]}Ἰδομενῆα βαλεῖν· ὃ δέ μιν φθάμενος βάλε δουρὶ{l]
[l [n}13.388{]}λαιμὸν ὑπʼ ἀνθερεῶνα, διὰ πρὸ δὲ χαλκὸν ἔλασσεν.{l]
[l [n}13.389{]}ἤριπε δʼ ὡς ὅτε τις δρῦς ἤριπεν ἢ ἀχερωῒς{l]
[l [n}13.390{]}ἠὲ πίτυς βλωθρή, τήν τʼ οὔρεσι τέκτονες ἄνδρες{l]
[l [n}13.391{]}ἐξέταμον πελέκεσσι νεήκεσι νήϊον εἶναι·{l]
[l [n}13.392{]}ὣς ὃ πρόσθʼ ἵππων καὶ δίφρου κεῖτο τανυσθεὶς{l]
[l [n}13.393{]}βεβρυχὼς κόνιος δεδραγμένος αἱματοέσσης.{l]
[l [n}13.394{]}ἐκ δέ οἱ ἡνίοχος πλήγη φρένας ἃς πάρος εἶχεν,{l]
[l [n}13.395{]}οὐδʼ ὅ γʼ ἐτόλμησεν δηΐων ὑπὸ χεῖρας ἀλύξας{l]
[l [n}13.396{]}ἂψ ἵππους στρέψαι, τὸν δʼ Ἀντίλοχος μενεχάρμης{l]
[l [n}13.397{]}δουρὶ μέσον περόνησε τυχών· οὐδʼ ἤρκεσε θώρηξ{l]
[l [n}13.398{]}χάλκεος ὃν φορέεσκε, μέσῃ δʼ ἐν γαστέρι πῆξεν.{l]
[l [n}13.399{]}αὐτὰρ ὃ ἀσθμαίνων εὐεργέος ἔκπεσε δίφρου,{l]
[l [n}13.400{]}ἵππους δʼ Ἀντίλοχος μεγαθύμου Νέστορος υἱὸς{l]
[l [n}13.401{]}ἐξέλασε Τρώων μετʼ ἐϋκνήμιδας Ἀχαιούς.{l]{para]
[para}[l [n}13.402{]}Δηΐφοβος δὲ μάλα σχεδὸν ἤλυθεν Ἰδομενῆος{l]
[l [n}13.403{]}Ἀσίου ἀχνύμενος, καὶ ἀκόντισε δουρὶ φαεινῷ.{l]
[l [n}13.404{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος{l]
[l [n}13.405{]}Ἰδομενεύς· κρύφθη γὰρ ὑπʼ ἀσπίδι πάντοσʼ ἐΐσῃ,{l]
[l [n}13.406{]}τὴν ἄρʼ ὅ γε ῥινοῖσι βοῶν καὶ νώροπι χαλκῷ{l]
[l [n}13.407{]}δινωτὴν φορέεσκε, δύω κανόνεσσʼ ἀραρυῖαν·{l]
[l [n}13.408{]}τῇ ὕπο πᾶς ἐάλη, τὸ δʼ ὑπέρπτατο χάλκεον ἔγχος,{l]
[l [n}13.409{]}καρφαλέον δέ οἱ ἀσπὶς ἐπιθρέξαντος ἄϋσεν{l]
[l [n}13.410{]}ἔγχεος· οὐδʼ ἅλιόν ῥα βαρείης χειρὸς ἀφῆκεν,{l]
[l [n}13.411{]}ἀλλʼ ἔβαλʼ Ἱππασίδην Ὑψήνορα ποιμένα λαῶν{l]
[l [n}13.412{]}ἧπαρ ὑπὸ πραπίδων, εἶθαρ δʼ ὑπὸ γούνατʼ ἔλυσε.{l]
[l [n}13.413{]}Δηΐφοβος δʼ ἔκπαγλον ἐπεύξατο μακρὸν ἀΰσας·{l]
[q}[l [n}13.414{]}οὐ μὰν αὖτʼ ἄτιτος κεῖτʼ Ἄσιος, ἀλλά ἕ φημι{l]
[l [n}13.415{]}εἰς Ἄϊδός περ ἰόντα πυλάρταο κρατεροῖο{l]
[l [n}13.416{]}γηθήσειν κατὰ θυμόν, ἐπεί ῥά οἱ ὤπασα πομπόν.{l]{q]{para]
[para}[l [n}13.417{]}ὣς ἔφατʼ, Ἀργείοισι δʼ ἄχος γένετʼ εὐξαμένοιο,{l]
[l [n}13.418{]}Ἀντιλόχῳ δὲ μάλιστα δαΐφρονι θυμὸν ὄρινεν·{l]
[l [n}13.419{]}ἀλλʼ οὐδʼ ἀχνύμενός περ ἑοῦ ἀμέλησεν ἑταίρου,{l]
[l [n}13.420{]}ἀλλὰ θέων περίβη καί οἱ σάκος ἀμφεκάλυψε.{l]
[l [n}13.421{]}τὸν μὲν ἔπειθʼ ὑποδύντε δύω ἐρίηρες ἑταῖροι{l]
[l [n}13.422{]}Μηκιστεὺς Ἐχίοιο πάϊς καὶ δῖος Ἀλάστωρ,{l]
[l [n}13.423{]}νῆας ἔπι γλαφυρὰς φερέτην βαρέα στενάχοντα.{l]{para]
[para}[l [n}13.424{]}Ἰδομενεὺς δʼ οὐ λῆγε μένος μέγα, ἵετο δʼ αἰεὶ{l]
[l [n}13.425{]}ἠέ τινα Τρώων ἐρεβεννῇ νυκτὶ καλύψαι{l]
[l [n}13.426{]}ἢ αὐτὸς δουπῆσαι ἀμύνων λοιγὸν Ἀχαιοῖς.{l]
[l [n}13.427{]}ἔνθʼ Αἰσυήταο διοτρεφέος φίλον υἱὸν{l]
[l [n}13.428{]}ἥρωʼ Ἀλκάθοον, γαμβρὸς δʼ ἦν Ἀγχίσαο,{l]
[l [n}13.429{]}πρεσβυτάτην δʼ ὤπυιε θυγατρῶν Ἱπποδάμειαν{l]
[l [n}13.430{]}τὴν περὶ κῆρι φίλησε πατὴρ καὶ πότνια μήτηρ{l]
[l [n}13.431{]}ἐν μεγάρῳ· πᾶσαν γὰρ ὁμηλικίην ἐκέκαστο{l]
[l [n}13.432{]}κάλλεϊ καὶ ἔργοισιν ἰδὲ φρεσί· τοὔνεκα καί μιν{l]
[l [n}13.433{]}γῆμεν ἀνὴρ ὤριστος ἐνὶ Τροίῃ εὐρείῃ·{l]
[l [n}13.434{]}τὸν τόθʼ ὑπʼ Ἰδομενῆϊ Ποσειδάων ἐδάμασσε{l]
[l [n}13.435{]}θέλξας ὄσσε φαεινά, πέδησε δὲ φαίδιμα γυῖα·{l]
[l [n}13.436{]}οὔτε γὰρ ἐξοπίσω φυγέειν δύνατʼ οὔτʼ ἀλέασθαι,{l]
[l [n}13.437{]}ἀλλʼ ὥς τε στήλην ἢ δένδρεον ὑψιπέτηλον{l]
[l [n}13.438{]}ἀτρέμας ἑσταότα στῆθος μέσον οὔτασε δουρὶ{l]
[l [n}13.439{]}ἥρως Ἰδομενεύς, ῥῆξεν δέ οἱ ἀμφὶ χιτῶνα{l]
[l [n}13.440{]}χάλκεον, ὅς οἱ πρόσθεν ἀπὸ χροὸς ἤρκει ὄλεθρον·{l]
[l [n}13.441{]}δὴ τότε γʼ αὖον ἄϋσεν ἐρεικόμενος περὶ δουρί.{l]
[l [n}13.442{]}δούπησεν δὲ πεσών, δόρυ δʼ ἐν κραδίῃ ἐπεπήγει,{l]
[l [n}13.443{]}ἥ ῥά οἱ ἀσπαίρουσα καὶ οὐρίαχον πελέμιζεν{l]
[l [n}13.444{]}ἔγχεος· ἔνθα δʼ ἔπειτʼ ἀφίει μένος ὄβριμος Ἄρης·{l]
[l [n}13.445{]}Ἰδομενεὺς δʼ ἔκπαγλον ἐπεύξατο μακρὸν ἀΰσας{l]
[q}[l [n}13.446{]}Δηΐφοβʼ ἦ ἄρα δή τι ἐΐσκομεν ἄξιον εἶναι{l]
[l [n}13.447{]}τρεῖς ἑνὸς ἀντὶ πεφάσθαι; ἐπεὶ σύ περ εὔχεαι οὕτω.{l]
[l [n}13.448{]}δαιμόνιʼ ἀλλὰ καὶ αὐτὸς ἐναντίον ἵστασʼ ἐμεῖο,{l]
[l [n}13.449{]}ὄφρα ἴδῃ οἷος Ζηνὸς γόνος ἐνθάδʼ ἱκάνω,{l]
[l [n}13.450{]}ὃς πρῶτον Μίνωα τέκε Κρήτῃ ἐπίουρον·{l]
[l [n}13.451{]}Μίνως δʼ αὖ τέκεθʼ υἱὸν ἀμύμονα Δευκαλίωνα,{l]
[l [n}13.452{]}Δευκαλίων δʼ ἐμὲ τίκτε πολέσσʼ ἄνδρεσσιν ἄνακτα{l]
[l [n}13.453{]}Κρήτῃ ἐν εὐρείῃ· νῦν δʼ ἐνθάδε νῆες ἔνεικαν{l]
[l [n}13.454{]}σοί τε κακὸν καὶ πατρὶ καὶ ἄλλοισι Τρώεσσιν.{l]{q]{para]
[para}[l [n}13.455{]}ὣς φάτο, Δηΐφοβος δὲ διάνδιχα μερμήριξεν{l]
[l [n}13.456{]}ἤ τινά που Τρώων ἑταρίσσαιτο μεγαθύμων{l]
[l [n}13.457{]}ἂψ ἀναχωρήσας, ἦ πειρήσαιτο καὶ οἶος.{l]
[l [n}13.458{]}ὧδε δέ οἱ φρονέοντι δοάσσατο κέρδιον εἶναι{l]
[l [n}13.459{]}βῆναι ἐπʼ Αἰνείαν· τὸν δʼ ὕστατον εὗρεν ὁμίλου{l]
[l [n}13.460{]}ἑσταότʼ· αἰεὶ γὰρ Πριάμῳ ἐπεμήνιε δίῳ{l]
[l [n}13.461{]}οὕνεκʼ ἄρʼ ἐσθλὸν ἐόντα μετʼ ἀνδράσιν οὔ τι τίεσκεν.{l]
[l [n}13.462{]}ἀγχοῦ δʼ ἱστάμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}13.463{]}Αἰνεία Τρώων βουληφόρε νῦν σε μάλα χρὴ{l]
[l [n}13.464{]}γαμβρῷ ἀμυνέμεναι, εἴ πέρ τί σε κῆδος ἱκάνει.{l]
[l [n}13.465{]}ἀλλʼ ἕπευ Ἀλκαθόῳ ἐπαμύνομεν, ὅς σε πάρος γε{l]
[l [n}13.466{]}γαμβρὸς ἐὼν ἔθρεψε δόμοις ἔνι τυτθὸν ἐόντα·{l]
[l [n}13.467{]}τὸν δέ τοι Ἰδομενεὺς δουρικλυτὸς ἐξενάριξεν.{l]{q]{para]
[para}[l [n}13.468{]}ὣς φάτο, τῷ δʼ ἄρα θυμὸν ἐνὶ στήθεσσιν ὄρινε,{l]
[l [n}13.469{]}βῆ δὲ μετʼ Ἰδομενῆα μέγα πτολέμοιο μεμηλώς.{l]
[l [n}13.470{]}ἀλλʼ οὐκ Ἰδομενῆα φόβος λάβε τηλύγετον ὥς,{l]
[l [n}13.471{]}ἀλλʼ ἔμενʼ ὡς ὅτε τις σῦς οὔρεσιν ἀλκὶ πεποιθώς,{l]
[l [n}13.472{]}ὅς τε μένει κολοσυρτὸν ἐπερχόμενον πολὺν ἀνδρῶν{l]
[l [n}13.473{]}χώρῳ ἐν οἰοπόλῳ, φρίσσει δέ τε νῶτον ὕπερθεν·{l]
[l [n}13.474{]}ὀφθαλμὼ δʼ ἄρα οἱ πυρὶ λάμπετον· αὐτὰρ ὀδόντας{l]
[l [n}13.475{]}θήγει, ἀλέξασθαι μεμαὼς κύνας ἠδὲ καὶ ἄνδρας·{l]
[l [n}13.476{]}ὣς μένεν Ἰδομενεὺς δουρικλυτός, οὐδʼ ὑπεχώρει,{l]
[l [n}13.477{]}Αἰνείαν ἐπιόντα βοηθόον· αὖε δʼ ἑταίρους{l]
[l [n}13.478{]}Ἀσκάλαφόν τʼ ἐσορῶν Ἀφαρῆά τε Δηΐπυρόν τε{l]
[l [n}13.479{]}Μηριόνην τε καὶ Ἀντίλοχον μήστωρας ἀϋτῆς·{l]
[l [n}13.480{]}τοὺς ὅ γʼ ἐποτρύνων ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}13.481{]}δεῦτε φίλοι, καί μʼ οἴῳ ἀμύνετε· δείδια δʼ αἰνῶς{l]
[l [n}13.482{]}Αἰνείαν ἐπιόντα πόδας ταχύν, ὅς μοι ἔπεισιν,{l]
[l [n}13.483{]}ὃς μάλα καρτερός ἐστι μάχῃ ἔνι φῶτας ἐναίρειν·{l]
[l [n}13.484{]}καὶ δʼ ἔχει ἥβης ἄνθος, ὅ τε κράτος ἐστὶ μέγιστον.{l]
[l [n}13.485{]}εἰ γὰρ ὁμηλικίη γε γενοίμεθα τῷδʼ ἐπὶ θυμῷ{l]
[l [n}13.486{]}αἶψά κεν ἠὲ φέροιτο μέγα κράτος, ἠὲ φεροίμην.{l]{q]{para]
[para}[l [n}13.487{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἕνα φρεσὶ θυμὸν ἔχοντες{l]
[l [n}13.488{]}πλησίοι ἔστησαν, σάκεʼ ὤμοισι κλίναντες.{l]
[l [n}13.489{]}Αἰνείας δʼ ἑτέρωθεν ἐκέκλετο οἷς ἑτάροισι{l]
[l [n}13.490{]}Δηΐφοβόν τε Πάριν τʼ ἐσορῶν καὶ Ἀγήνορα δῖον,{l]
[l [n}13.491{]}οἵ οἱ ἅμʼ ἡγεμόνες Τρώων ἔσαν· αὐτὰρ ἔπειτα{l]
[l [n}13.492{]}λαοὶ ἕπονθʼ, ὡς εἴ τε μετὰ κτίλον ἕσπετο μῆλα{l]
[l [n}13.493{]}πιόμενʼ ἐκ βοτάνης· γάνυται δʼ ἄρα τε φρένα ποιμήν·{l]
[l [n}13.494{]}ὣς Αἰνείᾳ θυμὸς ἐνὶ στήθεσσι γεγήθει{l]
[l [n}13.495{]}ὡς ἴδε λαῶν ἔθνος ἐπισπόμενον ἑοῖ αὐτῷ.{l]{para]
[para}[l [n}13.496{]}οἳ δʼ ἀμφʼ Ἀλκαθόῳ αὐτοσχεδὸν ὁρμήθησαν{l]
[l [n}13.497{]}μακροῖσι ξυστοῖσι· περὶ στήθεσσι δὲ χαλκὸς{l]
[l [n}13.498{]}σμερδαλέον κονάβιζε τιτυσκομένων καθʼ ὅμιλον{l]
[l [n}13.499{]}ἀλλήλων· δύο δʼ ἄνδρες ἀρήϊοι ἔξοχον ἄλλων{l]
[l [n}13.500{]}Αἰνείας τε καὶ Ἰδομενεὺς ἀτάλαντοι Ἄρηϊ{l]
[l [n}13.501{]}ἵεντʼ ἀλλήλων ταμέειν χρόα νηλέϊ χαλκῷ.{l]
[l [n}13.502{]}Αἰνείας δὲ πρῶτος ἀκόντισεν Ἰδομενῆος·{l]
[l [n}13.503{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος,{l]
[l [n}13.504{]}αἰχμὴ δʼ Αἰνείαο κραδαινομένη κατὰ γαίης{l]
[l [n}13.505{]}ᾤχετʼ, ἐπεί ῥʼ ἅλιον στιβαρῆς ἀπὸ χειρὸς ὄρουσεν.{l]
[l [n}13.506{]}Ἰδομενεὺς δʼ ἄρα Οἰνόμαον βάλε γαστέρα μέσσην,{l]
[l [n}13.507{]}ῥῆξε δὲ θώρηκος γύαλον, διὰ δʼ ἔντερα χαλκὸς{l]
[l [n}13.508{]}ἤφυσʼ· ὃ δʼ ἐν κονίῃσι πεσὼν ἕλε γαῖαν ἀγοστῷ.{l]
[l [n}13.509{]}Ἰδομενεὺς δʼ ἐκ μὲν νέκυος δολιχόσκιον ἔγχος{l]
[l [n}13.510{]}ἐσπάσατʼ, οὐδʼ ἄρʼ ἔτʼ ἄλλα δυνήσατο τεύχεα καλὰ{l]
[l [n}13.511{]}ὤμοιιν ἀφελέσθαι· ἐπείγετο γὰρ βελέεσσιν.{l]
[l [n}13.512{]}οὐ γὰρ ἔτʼ ἔμπεδα γυῖα ποδῶν ἦν ὁρμηθέντι,{l]
[l [n}13.513{]}οὔτʼ ἄρʼ ἐπαΐξαι μεθʼ ἑὸν· βέλος οὔτʼ ἀλέασθαι.{l]
[l [n}13.514{]}τώ ῥα καὶ ἐν σταδίῃ μὲν ἀμύνετο νηλεὲς ἦμαρ,{l]
[l [n}13.515{]}τρέσσαι δʼ οὐκ ἔτι ῥίμφα πόδες φέρον ἐκ πολέμοιο.{l]
[l [n}13.516{]}τοῦ δὲ βάδην ἀπιόντος ἀκόντισε δουρὶ φαεινῷ{l]
[l [n}13.517{]}Δηΐφοβος· δὴ γάρ οἱ ἔχεν κότον ἐμμενὲς αἰεί.{l]
[l [n}13.518{]}ἀλλʼ ὅ γε καὶ τόθʼ ἅμαρτεν, ὃ δʼ Ἀσκάλαφον βάλε δουρὶ{l]
[l [n}13.519{]}υἱὸν Ἐνυαλίοιο· διʼ ὤμου δʼ ὄβριμον ἔγχος{l]
[l [n}13.520{]}ἔσχεν· ὃ δʼ ἐν κονίῃσι πεσὼν ἕλε γαῖαν ἀγοστῷ.{l]
[l [n}13.521{]}οὐδʼ ἄρα πώ τι πέπυστο βριήπυος ὄβριμος Ἄρης{l]
[l [n}13.522{]}υἷος ἑοῖο πεσόντος ἐνὶ κρατερῇ ὑσμίνῃ,{l]
[l [n}13.523{]}ἀλλʼ ὅ γʼ ἄρʼ ἄκρῳ Ὀλύμπῳ ὑπὸ χρυσέοισι νέφεσσιν{l]
[l [n}13.524{]}ἧστο Διὸς βουλῇσιν ἐελμένος, ἔνθά περ ἄλλοι{l]
[l [n}13.525{]}ἀθάνατοι θεοὶ ἦσαν ἐεργόμενοι πολέμοιο.{l]{para]
[para}[l [n}13.526{]}οἳ δʼ ἀμφʼ Ἀσκαλάφῳ αὐτοσχεδὸν ὁρμήθησαν·{l]
[l [n}13.527{]}Δηΐφοβος μὲν ἀπʼ Ἀσκαλάφου πήληκα φαεινὴν{l]
[l [n}13.528{]}ἥρπασε, Μηριόνης δὲ θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}13.529{]}δουρὶ βραχίονα τύψεν ἐπάλμενος, ἐκ δʼ ἄρα χειρὸς{l]
[l [n}13.530{]}αὐλῶπις τρυφάλεια χαμαὶ βόμβησε πεσοῦσα.{l]
[l [n}13.531{]}Μηριόνης δʼ ἐξ αὖτις ἐπάλμενος αἰγυπιὸς ὣς{l]
[l [n}13.532{]}ἐξέρυσε πρυμνοῖο βραχίονος ὄβριμον ἔγχος,{l]
[l [n}13.533{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο. τὸν δὲ Πολίτης{l]
[l [n}13.534{]}αὐτοκασίγνητος περὶ μέσσῳ χεῖρε τιτήνας{l]
[l [n}13.535{]}ἐξῆγεν πολέμοιο δυσηχέος, ὄφρʼ ἵκεθʼ ἵππους{l]
[l [n}13.536{]}ὠκέας, οἵ οἱ ὄπισθε μάχης ἠδὲ πτολέμοιο{l]
[l [n}13.537{]}ἕστασαν ἡνίοχόν τε καὶ ἅρματα ποικίλʼ ἔχοντες·{l]
[l [n}13.538{]}οἳ τόν γε προτὶ ἄστυ φέρον βαρέα στενάχοντα{l]
[l [n}13.539{]}τειρόμενον· κατὰ δʼ αἷμα νεουτάτου ἔρρεε χειρός.{l]{para]
[para}[l [n}13.540{]}οἳ δʼ ἄλλοι μάρναντο, βοὴ δʼ ἄσβεστος ὀρώρει.{l]
[l [n}13.541{]}ἔνθʼ Αἰνέας Ἀφαρῆα Καλητορίδην ἐπορούσας{l]
[l [n}13.542{]}λαιμὸν τύψʼ ἐπὶ οἷ τετραμμένον ὀξέϊ δουρί·{l]
[l [n}13.543{]}ἐκλίνθη δʼ ἑτέρωσε κάρη, ἐπὶ δʼ ἀσπὶς ἑάφθη{l]
[l [n}13.544{]}καὶ κόρυς, ἀμφὶ δέ οἱ θάνατος χύτο θυμοραϊστής.{l]
[l [n}13.545{]}Ἀντίλοχος δὲ Θόωνα μεταστρεφθέντα δοκεύσας{l]
[l [n}13.546{]}οὔτασʼ ἐπαΐξας, ἀπὸ δὲ φλέβα πᾶσαν ἔκερσεν,{l]
[l [n}13.547{]}ἥ τʼ ἀνὰ νῶτα θέουσα διαμπερὲς αὐχένʼ ἱκάνει·{l]
[l [n}13.548{]}τὴν ἀπὸ πᾶσαν ἔκερσεν· ὃ δʼ ὕπτιος ἐν κονίῃσι{l]
[l [n}13.549{]}κάππεσεν, ἄμφω χεῖρε φίλοις ἑτάροισι πετάσσας.{l]
[l [n}13.550{]}Ἀντίλοχος δʼ ἐπόρουσε, καὶ αἴνυτο τεύχεʼ ἀπʼ ὤμων{l]
[l [n}13.551{]}παπταίνων· Τρῶες δὲ περισταδὸν ἄλλοθεν ἄλλος{l]
[l [n}13.552{]}οὔταζον σάκος εὐρὺ παναίολον, οὐδὲ δύναντο{l]
[l [n}13.553{]}εἴσω ἐπιγράψαι τέρενα χρόα νηλέϊ χαλκῷ{l]
[l [n}13.554{]}Ἀντιλόχου· πέρι γάρ ῥα Ποσειδάων ἐνοσίχθων{l]
[l [n}13.555{]}Νέστορος υἱὸν ἔρυτο καὶ ἐν πολλοῖσι βέλεσσιν.{l]
[l [n}13.556{]}οὐ μὲν γάρ ποτʼ ἄνευ δηΐων ἦν, ἀλλὰ κατʼ αὐτοὺς{l]
[l [n}13.557{]}στρωφᾶτʼ· οὐδέ οἱ ἔγχος ἔχʼ ἀτρέμας, ἀλλὰ μάλʼ αἰεὶ{l]
[l [n}13.558{]}σειόμενον ἐλέλικτο· τιτύσκετο δὲ φρεσὶν ᾗσιν{l]
[l [n}13.559{]}ἤ τευ ἀκοντίσσαι, ἠὲ σχεδὸν ὁρμηθῆναι.{l]{para]
[para}[l [n}13.560{]}ἀλλʼ οὐ λῆθʼ Ἀδάμαντα τιτυσκόμενος καθʼ ὅμιλον{l]
[l [n}13.561{]}Ἀσιάδην, ὅ οἱ οὖτα μέσον σάκος ὀξέϊ χαλκῷ{l]
[l [n}13.562{]}ἐγγύθεν ὁρμηθείς· ἀμενήνωσεν δέ οἱ αἰχμὴν{l]
[l [n}13.563{]}κυανοχαῖτα Ποσειδάων βιότοιο μεγήρας.{l]
[l [n}13.564{]}καὶ τὸ μὲν αὐτοῦ μεῖνʼ ὥς τε σκῶλος πυρίκαυστος{l]
[l [n}13.565{]}ἐν σάκει Ἀντιλόχοιο, τὸ δʼ ἥμισυ κεῖτʼ ἐπὶ γαίης·{l]
[l [n}13.566{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων·{l]
[l [n}13.567{]}Μηριόνης δʼ ἀπιόντα μετασπόμενος βάλε δουρὶ{l]
[l [n}13.568{]}αἰδοίων τε μεσηγὺ καὶ ὀμφαλοῦ, ἔνθα μάλιστα{l]
[l [n}13.569{]}γίγνετʼ Ἄρης ἀλεγεινὸς ὀϊζυροῖσι βροτοῖσιν.{l]
[l [n}13.570{]}ἔνθά οἱ ἔγχος ἔπηξεν· ὃ δʼ ἑσπόμενος περὶ δουρὶ{l]
[l [n}13.571{]}ἤσπαιρʼ ὡς ὅτε βοῦς τόν τʼ οὔρεσι βουκόλοι ἄνδρες{l]
[l [n}13.572{]}ἰλλάσιν οὐκ ἐθέλοντα βίῃ δήσαντες ἄγουσιν·{l]
[l [n}13.573{]}ὣς ὃ τυπεὶς ἤσπαιρε μίνυνθά περ, οὔ τι μάλα δήν,{l]
[l [n}13.574{]}ὄφρά οἱ ἐκ χροὸς ἔγχος ἀνεσπάσατʼ ἐγγύθεν ἐλθὼν{l]
[l [n}13.575{]}ἥρως Μηριόνης· τὸν δὲ σκότος ὄσσε κάλυψε.{l]{para]
[para}[l [n}13.576{]}Δηΐπυρον δʼ Ἕλενος ξίφεϊ σχεδὸν ἤλασε κόρσην{l]
[l [n}13.577{]}Θρηϊκίῳ μεγάλῳ, ἀπὸ δὲ τρυφάλειαν ἄραξεν.{l]
[l [n}13.578{]}ἣ μὲν ἀποπλαγχθεῖσα χαμαὶ πέσε, καί τις Ἀχαιῶν{l]
[l [n}13.579{]}μαρναμένων μετὰ ποσσὶ κυλινδομένην ἐκόμισσε·{l]
[l [n}13.580{]}τὸν δὲ κατʼ ὀφθαλμῶν ἐρεβεννὴ νὺξ ἐκάλυψεν.{l]{para]
[para}[l [n}13.581{]}Ἀτρεΐδην δʼ ἄχος εἷλε βοὴν ἀγαθὸν Μενέλαον·{l]
[l [n}13.582{]}βῆ δʼ ἐπαπειλήσας Ἑλένῳ ἥρωϊ ἄνακτι{l]
[l [n}13.583{]}ὀξὺ δόρυ κραδάων· ὃ δὲ τόξου πῆχυν ἄνελκε.{l]
[l [n}13.584{]}τὼ δʼ ἄρʼ ὁμαρτήδην ὃ μὲν ἔγχεϊ ὀξυόεντι{l]
[l [n}13.585{]}ἵετʼ ἀκοντίσσαι, ὃ δʼ ἀπὸ νευρῆφιν ὀϊστῷ.{l]
[l [n}13.586{]}Πριαμίδης μὲν ἔπειτα κατὰ στῆθος βάλεν ἰῷ{l]
[l [n}13.587{]}θώρηκος γύαλον, ἀπὸ δʼ ἔπτατο πικρὸς ὀϊστός.{l]
[l [n}13.588{]}ὡς δʼ ὅτʼ ἀπὸ πλατέος πτυόφιν μεγάλην κατʼ ἀλωὴν{l]
[l [n}13.589{]}θρῴσκωσιν κύαμοι μελανόχροες ἢ ἐρέβινθοι{l]
[l [n}13.590{]}πνοιῇ ὕπο λιγυρῇ καὶ λικμητῆρος ἐρωῇ,{l]
[l [n}13.591{]}ὣς ἀπὸ θώρηκος Μενελάου κυδαλίμοιο{l]
[l [n}13.592{]}πολλὸν ἀποπλαγχθεὶς ἑκὰς ἔπτατο πικρὸς ὀϊστός.{l]
[l [n}13.593{]}Ἀτρεΐδης δʼ ἄρα χεῖρα βοὴν ἀγαθὸς Μενέλαος{l]
[l [n}13.594{]}τὴν βάλεν ᾗ ῥʼ ἔχε τόξον ἐΰξοον· ἐν δʼ ἄρα τόξῳ{l]
[l [n}13.595{]}ἀντικρὺ διὰ χειρὸς ἐλήλατο χάλκεον ἔγχος.{l]
[l [n}13.596{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων{l]
[l [n}13.597{]}χεῖρα παρακρεμάσας· τὸ δʼ ἐφέλκετο μείλινον ἔγχος.{l]
[l [n}13.598{]}καὶ τὸ μὲν ἐκ χειρὸς ἔρυσεν μεγάθυμος Ἀγήνωρ,{l]
[l [n}13.599{]}αὐτὴν δὲ ξυνέδησεν ἐϋστρεφεῖ οἰὸς ἀώτῳ{l]
[l [n}13.600{]}σφενδόνῃ, ἣν ἄρα οἱ θεράπων ἔχε ποιμένι λαῶν.{l]{para]
[para}[l [n}13.601{]}Πείσανδρος δʼ ἰθὺς Μενελάου κυδαλίμοιο{l]
[l [n}13.602{]}ἤϊε· τὸν δʼ ἄγε μοῖρα κακὴ θανάτοιο τέλος δὲ{l]
[l [n}13.603{]}σοὶ Μενέλαε δαμῆναι ἐν αἰνῇ δηϊοτῆτι.{l]
[l [n}13.604{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες{l]
[l [n}13.605{]}Ἀτρεΐδης μὲν ἅμαρτε, παραὶ δέ οἱ ἐτράπετʼ ἔγχος,{l]
[l [n}13.606{]}Πείσανδρος δὲ σάκος Μενελάου κυδαλίμοιο{l]
[l [n}13.607{]}οὔτασεν, οὐδὲ διὰ πρὸ δυνήσατο χαλκὸν ἐλάσσαι·{l]
[l [n}13.608{]}ἔσχεθε γὰρ σάκος εὐρύ, κατεκλάσθη δʼ ἐνὶ καυλῷ{l]
[l [n}13.609{]}ἔγχος· ὃ δὲ φρεσὶν ᾗσι χάρη καὶ ἐέλπετο νίκην.{l]
[l [n}13.610{]}Ἀτρεΐδης δὲ ἐρυσσάμενος ξίφος ἀργυρόηλον{l]
[l [n}13.611{]}ἆλτʼ ἐπὶ Πεισάνδρῳ· ὃ δʼ ὑπʼ ἀσπίδος εἵλετο καλὴν{l]
[l [n}13.612{]}ἀξίνην εὔχαλκον ἐλαΐνῳ ἀμφὶ πελέκκῳ{l]
[l [n}13.613{]}μακρῷ ἐϋξέστῳ· ἅμα δʼ ἀλλήλων ἐφίκοντο.{l]
[l [n}13.614{]}ἤτοι ὃ μὲν κόρυθος φάλον ἤλασεν ἱπποδασείης{l]
[l [n}13.615{]}ἄκρον ὑπὸ λόφον αὐτόν, ὃ δὲ προσιόντα μέτωπον{l]
[l [n}13.616{]}ῥινὸς ὕπερ πυμάτης· λάκε δʼ ὀστέα, τὼ δέ οἱ ὄσσε{l]
[l [n}13.617{]}πὰρ ποσὶν αἱματόεντα χαμαὶ πέσον ἐν κονίῃσιν,{l]
[l [n}13.618{]}ἰδνώθη δὲ πεσών· ὃ δὲ λὰξ ἐν στήθεσι βαίνων{l]
[l [n}13.619{]}τεύχεά τʼ ἐξενάριξε καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}13.620{]}λείψετέ θην οὕτω γε νέας Δαναῶν ταχυπώλων{l]
[l [n}13.621{]}Τρῶες ὑπερφίαλοι δεινῆς ἀκόρητοι ἀϋτῆς,{l]
[l [n}13.622{]}ἄλλης μὲν λώβης τε καὶ αἴσχεος οὐκ ἐπιδευεῖς{l]
[l [n}13.623{]}ἣν ἐμὲ λωβήσασθε κακαὶ κύνες, οὐδέ τι θυμῷ{l]
[l [n}13.624{]}Ζηνὸς ἐριβρεμέτεω χαλεπὴν ἐδείσατε μῆνιν{l]
[l [n}13.625{]}ξεινίου, ὅς τέ ποτʼ ὔμμι διαφθέρσει πόλιν αἰπήν·{l]
[l [n}13.626{]}οἵ μευ κουριδίην ἄλοχον καὶ κτήματα πολλὰ{l]
[l [n}13.627{]}μὰψ οἴχεσθʼ ἀνάγοντες, ἐπεὶ φιλέεσθε παρʼ αὐτῇ·{l]
[l [n}13.628{]}νῦν αὖτʼ ἐν νηυσὶν μενεαίνετε ποντοπόροισι{l]
[l [n}13.629{]}πῦρ ὀλοὸν βαλέειν, κτεῖναι δʼ ἥρωας Ἀχαιούς.{l]
[l [n}13.630{]}ἀλλά ποθι σχήσεσθε καὶ ἐσσύμενοί περ Ἄρηος.{l]
[l [n}13.631{]}Ζεῦ πάτερ ἦ τέ σέ φασι περὶ φρένας ἔμμεναι ἄλλων{l]
[l [n}13.632{]}ἀνδρῶν ἠδὲ θεῶν· σέο δʼ ἐκ τάδε πάντα πέλονται·{l]
[l [n}13.633{]}οἷον δὴ ἄνδρεσσι χαρίζεαι ὑβριστῇσι{l]
[l [n}13.634{]}Τρωσίν, τῶν μένος αἰὲν ἀτάσθαλον, οὐδὲ δύνανται{l]
[l [n}13.635{]}φυλόπιδος κορέσασθαι ὁμοιΐου πτολέμοιο.{l]
[l [n}13.636{]}πάντων μὲν κόρος ἐστὶ καὶ ὕπνου καὶ φιλότητος{l]
[l [n}13.637{]}μολπῆς τε γλυκερῆς καὶ ἀμύμονος ὀρχηθμοῖο,{l]
[l [n}13.638{]}τῶν πέρ τις καὶ μᾶλλον ἐέλδεται ἐξ ἔρον εἷναι{l]
[l [n}13.639{]}ἢ πολέμου· Τρῶες δὲ μάχης ἀκόρητοι ἔασιν.{l]{q]{para]
[para}[l [n}13.640{]}ὣς εἰπὼν τὰ μὲν ἔντεʼ ἀπὸ χροὸς αἱματόεντα{l]
[l [n}13.641{]}συλήσας ἑτάροισι δίδου Μενέλαος ἀμύμων,{l]
[l [n}13.642{]}αὐτὸς δʼ αὖτʼ ἐξ αὖτις ἰὼν προμάχοισιν ἐμίχθη.{l]{para]
[para}[l [n}13.643{]}ἔνθά οἱ υἱὸς ἐπᾶλτο Πυλαιμένεος βασιλῆος{l]
[l [n}13.644{]}Ἁρπαλίων, ὅ ῥα πατρὶ φίλῳ ἕπετο πτολεμίξων{l]
[l [n}13.645{]}ἐς τροίην, οὐδʼ αὖτις ἀφίκετο πατρίδα γαῖαν·{l]
[l [n}13.646{]}ὅς ῥα τότʼ Ἀτρεΐδαο μέσον σάκος οὔτασε δουρὶ{l]
[l [n}13.647{]}ἐγγύθεν, οὐδὲ διὰ πρὸ δυνήσατο χαλκὸν ἐλάσσαι{l]
[l [n}13.648{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων{l]
[l [n}13.649{]}πάντοσε παπταίνων μή τις χρόα χαλκῷ ἐπαύρῃ.{l]
[l [n}13.650{]}Μηριόνης δʼ ἀπιόντος ἵει χαλκήρεʼ ὀϊστόν,{l]
[l [n}13.651{]}καί ῥʼ ἔβαλε γλουτὸν κάτα δεξιόν· αὐτὰρ ὀϊστὸς{l]
[l [n}13.652{]}ἀντικρὺ κατὰ κύστιν ὑπʼ ὀστέον ἐξεπέρησεν.{l]
[l [n}13.653{]}ἑζόμενος δὲ κατʼ αὖθι φίλων ἐν χερσὶν ἑταίρων{l]
[l [n}13.654{]}θυμὸν ἀποπνείων, ὥς τε σκώληξ ἐπὶ γαίῃ{l]
[l [n}13.655{]}κεῖτο ταθείς· ἐκ δʼ αἷμα μέλαν ῥέε, δεῦε δὲ γαῖαν.{l]
[l [n}13.656{]}τὸν μὲν Παφλαγόνες μεγαλήτορες ἀμφεπένοντο,{l]
[l [n}13.657{]}ἐς δίφρον δʼ ἀνέσαντες ἄγον προτὶ Ἴλιον ἱρὴν{l]
[l [n}13.658{]}ἀχνύμενοι· μετὰ δέ σφι πατὴρ κίε δάκρυα λείβων,{l]
[l [n}13.659{]}ποινὴ δʼ οὔ τις παιδὸς ἐγίγνετο τεθνηῶτος.{l]{para]
[para}[l [n}13.660{]}τοῦ δὲ Πάρις μάλα θυμὸν ἀποκταμένοιο χολώθη·{l]
[l [n}13.661{]}ξεῖνος γάρ οἱ ἔην πολέσιν μετὰ Παφλαγόνεσσι·{l]
[l [n}13.662{]}τοῦ ὅ γε χωόμενος προΐει χαλκήρεʼ ὀϊστόν.{l]
[l [n}13.663{]}ἦν δέ τις Εὐχήνωρ Πολυΐδου μάντιος υἱὸς{l]
[l [n}13.664{]}ἀφνειός τʼ ἀγαθός τε Κορινθόθι οἰκία ναίων,{l]
[l [n}13.665{]}ὅς ῥʼ εὖ εἰδὼς κῆρʼ ὀλοὴν ἐπὶ νηὸς ἔβαινε·{l]
[l [n}13.666{]}πολλάκι γάρ οἱ ἔειπε γέρων ἀγαθὸς Πολύϊδος{l]
[q}[l [n}13.667{]}νούσῳ ὑπʼ ἀργαλέῃ φθίσθαι οἷς ἐν μεγάροισιν,{l]
[l [n}13.668{]}ἢ μετʼ Ἀχαιῶν νηυσὶν ὑπὸ Τρώεσσι δαμῆναι·{l]
[l [n}13.669{]}τώ ῥʼ ἅμα τʼ ἀργαλέην θωὴν ἀλέεινεν Ἀχαιῶν{l]
[l [n}13.670{]}νοῦσόν τε στυγερήν, ἵνα μὴ πάθοι ἄλγεα θυμῷ.{l]
[l [n}13.671{]}τὸν βάλʼ ὑπὸ γναθμοῖο. καὶ οὔατος· ὦκα δὲ θυμὸς{l]
[l [n}13.672{]}ᾤχετʼ ἀπὸ μελέων, στυγερὸς δʼ ἄρα μιν σκότος εἷλεν.{l]{q]{para]
[para}[l [n}13.673{]}ὣς οἳ μὲν μάρναντο δέμας πυρὸς αἰθομένοιο·{l]
[l [n}13.674{]}Ἕκτωρ δʼ οὐκ ἐπέπυστο Διῒ φίλος, οὐδέ τι ᾔδη{l]
[l [n}13.675{]}ὅττί ῥά οἱ νηῶν ἐπʼ ἀριστερὰ δηϊόωντο{l]
[l [n}13.676{]}λαοὶ ὑπʼ Ἀργείων. τάχα δʼ ἂν καὶ κῦδος Ἀχαιῶν{l]
[l [n}13.677{]}ἔπλετο· τοῖος γὰρ γαιήοχος ἐννοσίγαιος{l]
[l [n}13.678{]}ὄτρυνʼ Ἀργείους, πρὸς δὲ σθένει αὐτὸς ἄμυνεν·{l]
[l [n}13.679{]}ἀλλʼ ἔχεν ᾗ τὰ πρῶτα πύλας καὶ τεῖχος ἐσᾶλτο{l]
[l [n}13.680{]}ῥηξάμενος Δαναῶν πυκινὰς στίχας ἀσπιστάων,{l]
[l [n}13.681{]}ἔνθʼ ἔσαν Αἴαντός τε νέες καὶ Πρωτεσιλάου{l]
[l [n}13.682{]}θῖνʼ ἔφʼ ἁλὸς πολιῆς εἰρυμέναι· αὐτὰρ ὕπερθε{l]
[l [n}13.683{]}τεῖχος ἐδέδμητο χθαμαλώτατον, ἔνθα μάλιστα{l]
[l [n}13.684{]}ζαχρηεῖς γίγνοντο μάχῃ αὐτοί τε καὶ ἵπποι.{l]{para]
[para}[l [n}13.685{]}ἔνθα δὲ Βοιωτοὶ καὶ Ἰάονες ἑλκεχίτωνες{l]
[l [n}13.686{]}Λοκροὶ καὶ Φθῖοι καὶ φαιδιμόεντες Ἐπειοὶ{l]
[l [n}13.687{]}σπουδῇ ἐπαΐσσοντα νεῶν ἔχον, οὐδὲ δύναντο{l]
[l [n}13.688{]}ὦσαι ἀπὸ σφείων φλογὶ εἴκελον Ἕκτορα δῖον{l]
[l [n}13.689{]}οἳ μὲν Ἀθηναίων προλελεγμένοι· ἐν δʼ ἄρα τοῖσιν{l]
[l [n}13.690{]}ἦρχʼ υἱὸς Πετεῶο Μενεσθεύς, οἳ δʼ ἅμʼ ἕποντο{l]
[l [n}13.691{]}Φείδας τε Στιχίος τε Βίας τʼ ἐΰς· αὐτὰρ Ἐπειῶν{l]
[l [n}13.692{]}Φυλεΐδης τε Μέγης Ἀμφίων τε Δρακίος τε,{l]
[l [n}13.693{]}πρὸ Φθίων δὲ Μέδων τε μενεπτόλεμός τε Ποδάρκης.{l]
[l [n}13.694{]}ἤτοι ὃ μὲν νόθος υἱὸς Ὀϊλῆος θείοιο{l]
[l [n}13.695{]}ἔσκε Μέδων Αἴαντος ἀδελφεός· αὐτὰρ ἔναιεν{l]
[l [n}13.696{]}ἐν Φυλάκῃ γαίης ἄπο πατρίδος ἄνδρα κατακτὰς{l]
[l [n}13.697{]}γνωτὸν μητρυιῆς Ἐριώπιδος, ἣν ἔχʼ Ὀϊλεύς·{l]
[l [n}13.698{]}αὐτὰρ ὃ Ἰφίκλοιο πάϊς τοῦ Φυλακίδαο.{l]
[l [n}13.699{]}οἳ μὲν πρὸ Φθίων μεγαθύμων θωρηχθέντες{l]
[l [n}13.700{]}ναῦφιν ἀμυνόμενοι μετὰ Βοιωτῶν ἐμάχοντο·{l]
[l [n}13.701{]}Αἴας δʼ οὐκέτι πάμπαν Ὀϊλῆος ταχὺς υἱὸς{l]
[l [n}13.702{]}ἵστατʼ ἀπʼ Αἴαντος Τελαμωνίου οὐδʼ ἠβαιόν,{l]
[l [n}13.703{]}ἀλλʼ ὥς τʼ ἐν νειῷ βόε οἴνοπε πηκτὸν ἄροτρον{l]
[l [n}13.704{]}ἶσον θυμὸν ἔχοντε τιταίνετον· ἀμφὶ δʼ ἄρά σφι{l]
[l [n}13.705{]}πρυμνοῖσιν κεράεσσι πολὺς ἀνακηκίει ἱδρώς·{l]
[l [n}13.706{]}τὼ μέν τε ζυγὸν οἶον ἐΰξοον ἀμφὶς ἐέργει{l]
[l [n}13.707{]}ἱεμένω κατὰ ὦλκα· τέμει δέ τε τέλσον ἀρούρης·{l]
[l [n}13.708{]}ὣς τὼ παρβεβαῶτε μάλʼ ἕστασαν ἀλλήλοιιν.{l]
[l [n}13.709{]}ἀλλʼ ἤτοι Τελαμωνιάδῃ πολλοί τε καὶ ἐσθλοὶ{l]
[l [n}13.710{]}λαοὶ ἕπονθʼ ἕταροι, οἵ οἱ σάκος ἐξεδέχοντο{l]
[l [n}13.711{]}ὁππότε μιν κάματός τε καὶ ἱδρὼς γούναθʼ ἵκοιτο.{l]
[l [n}13.712{]}οὐδʼ ἄρʼ Ὀϊλιάδῃ μεγαλήτορι Λοκροὶ ἕποντο·{l]
[l [n}13.713{]}οὐ γάρ σφι σταδίῃ ὑσμίνῃ μίμνε φίλον κῆρ·{l]
[l [n}13.714{]}οὐ γὰρ ἔχον κόρυθας χαλκήρεας ἱπποδασείας,{l]
[l [n}13.715{]}οὐδʼ ἔχον ἀσπίδας εὐκύκλους καὶ μείλινα δοῦρα,{l]
[l [n}13.716{]}ἀλλʼ ἄρα τόξοισιν καὶ ἐϋστρεφεῖ οἶος ἀώτῳ{l]
[l [n}13.717{]}Ἴλιον εἰς ἅμʼ ἕποντο πεποιθότες, οἷσιν ἔπειτα{l]
[l [n}13.718{]}ταρφέα βάλλοντες Τρώων ῥήγνυντο φάλαγγας·{l]
[l [n}13.719{]}δή ῥα τόθʼ οἳ μὲν πρόσθε σὺν ἔντεσι δαιδαλέοισι{l]
[l [n}13.720{]}μάρναντο Τρωσίν τε καὶ Ἕκτορι χαλκοκορυστῇ,{l]
[l [n}13.721{]}οἳ δʼ ὄπιθεν βάλλοντες ἐλάνθανον· οὐδέ τι χάρμης{l]
[l [n}13.722{]}Τρῶες μιμνήσκοντο· συνεκλόνεον γὰρ ὀϊστοί.{l]{para]
[para}[l [n}13.723{]}ἔνθά κε λευγαλέως νηῶν ἄπο καὶ κλισιάων{l]
[l [n}13.724{]}Τρῶες ἐχώρησαν προτὶ Ἴλιον ἠνεμόεσσαν,{l]
[l [n}13.725{]}εἰ μὴ Πουλυδάμας θρασὺν Ἕκτορα εἶπε παραστάς·{l]
[q}[l [n}13.726{]}Ἕκτορ ἀμήχανός ἐσσι παραρρητοῖσι πιθέσθαι.{l]
[l [n}13.727{]}οὕνεκά τοι περὶ δῶκε θεὸς πολεμήϊα ἔργα{l]
[l [n}13.728{]}τοὔνεκα καὶ βουλῇ ἐθέλεις περιίδμεναι ἄλλων·{l]
[l [n}13.729{]}ἀλλʼ οὔ πως ἅμα πάντα δυνήσεαι αὐτὸς ἑλέσθαι.{l]
[l [n}13.730{]}ἄλλῳ μὲν γὰρ ἔδωκε θεὸς πολεμήϊα ἔργα,{l]
[l [n}13.731{]}ἄλλῳ δʼ ὀρχηστύν, ἑτέρῳ κίθαριν καὶ ἀοιδήν,{l]
[l [n}13.732{]}ἄλλῳ δʼ ἐν στήθεσσι τιθεῖ νόον εὐρύοπα Ζεὺς{l]
[l [n}13.733{]}ἐσθλόν, τοῦ δέ τε πολλοὶ ἐπαυρίσκοντʼ ἄνθρωποι,{l]
[l [n}13.734{]}καί τε πολέας ἐσάωσε, μάλιστα δὲ καὐτὸς ἀνέγνω.{l]
[l [n}13.735{]}αὐτὰρ ἐγὼν ἐρέω ὥς μοι δοκεῖ εἶναι ἄριστα·{l]
[l [n}13.736{]}πάντῃ γάρ σε περὶ στέφανος πολέμοιο δέδηε·{l]
[l [n}13.737{]}Τρῶες δὲ μεγάθυμοι ἐπεὶ κατὰ τεῖχος ἔβησαν{l]
[l [n}13.738{]}οἳ μὲν ἀφεστᾶσιν σὺν τεύχεσιν, οἳ δὲ μάχονται{l]
[l [n}13.739{]}παυρότεροι πλεόνεσσι κεδασθέντες κατὰ νῆας.{l]
[l [n}13.740{]}ἀλλʼ ἀναχασσάμενος κάλει ἐνθάδε πάντας ἀρίστους·{l]
[l [n}13.741{]}ἔνθεν δʼ ἂν μάλα πᾶσαν ἐπιφρασσαίμεθα βουλὴν{l]
[l [n}13.742{]}ἤ κεν ἐνὶ νήεσσι πολυκλήϊσι πέσωμεν{l]
[l [n}13.743{]}αἴ κʼ ἐθέλῃσι θεὸς δόμεναι κράτος, ἦ κεν ἔπειτα{l]
[l [n}13.744{]}πὰρ νηῶν ἔλθωμεν ἀπήμονες. ἦ γὰρ ἔγωγε{l]
[l [n}13.745{]}δείδω μὴ τὸ χθιζὸν ἀποστήσωνται Ἀχαιοὶ{l]
[l [n}13.746{]}χρεῖος, ἐπεὶ παρὰ νηυσὶν ἀνὴρ ἆτος πολέμοιο{l]
[l [n}13.747{]}μίμνει, ὃν οὐκέτι πάγχυ μάχης σχήσεσθαι ὀΐω.{l]{q]{para]
[para}[l [n}13.748{]}ὣς φάτο Πουλυδάμας, ἅδε δʼ Ἕκτορι μῦθος ἀπήμων,{l]
[l [n}13.749{]}αὐτίκα δʼ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε{l]
[l [n}13.750{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}13.751{]}Πουλυδάμα σὺ μὲν αὐτοῦ ἐρύκακε πάντας ἀρίστους,{l]
[l [n}13.752{]}αὐτὰρ ἐγὼ κεῖσʼ εἶμι καὶ ἀντιόω πολέμοιο·{l]
[l [n}13.753{]}αἶψα δʼ ἐλεύσομαι αὖτις ἐπὴν εὖ τοῖς ἐπιτείλω.{l]{q]{para]
[para}[l [n}13.754{]}ἦ ῥα, καὶ ὁρμήθη ὄρεϊ νιφόεντι ἐοικὼς{l]
[l [n}13.755{]}κεκλήγων, διὰ δὲ Τρώων πέτετʼ ἠδʼ ἐπικούρων.{l]
[l [n}13.756{]}οἳ δʼ ἐς Πανθοΐδην ἀγαπήνορα Πουλυδάμαντα{l]
[l [n}13.757{]}πάντες ἐπεσσεύοντʼ, ἐπεὶ Ἕκτορος ἔκλυον αὐδήν.{l]
[l [n}13.758{]}αὐτὰρ ὃ Δηΐφοβόν τε βίην θʼ Ἑλένοιο ἄνακτος{l]
[l [n}13.759{]}Ἀσιάδην τʼ Ἀδάμαντα καὶ Ἄσιον Ὑρτάκου υἱὸν{l]
[l [n}13.760{]}φοίτα ἀνὰ προμάχους διζήμενος, εἴ που ἐφεύροι.{l]
[l [n}13.761{]}τοὺς δʼ εὗρʼ οὐκέτι πάμπαν ἀπήμονας οὐδʼ ἀνολέθρους·{l]
[l [n}13.762{]}ἀλλʼ οἳ μὲν δὴ νηυσὶν ἔπι πρυμνῇσιν Ἀχαιῶν{l]
[l [n}13.763{]}χερσὶν ὑπʼ Ἀργείων κέατο ψυχὰς ὀλέσαντες,{l]
[l [n}13.764{]}οἳ δʼ ἐν τείχει ἔσαν βεβλημένοι οὐτάμενοί τε.{l]
[l [n}13.765{]}τὸν δὲ τάχʼ εὗρε μάχης ἐπʼ ἀριστερὰ δακρυοέσσης{l]
[l [n}13.766{]}δῖον Ἀλέξανδρον Ἑλένης πόσιν ἠϋκόμοιο{l]
[l [n}13.767{]}θαρσύνονθʼ ἑτάρους καὶ ἐποτρύνοντα μάχεσθαι,{l]
[l [n}13.768{]}ἀγχοῦ δʼ ἱστάμενος προσέφη αἰσχροῖς ἐπέεσσι·{l]
[q}[l [n}13.769{]}Δύσπαρι εἶδος ἄριστε γυναιμανὲς ἠπεροπευτὰ{l]
[l [n}13.770{]}ποῦ τοι Δηΐφοβός τε βίη θʼ Ἑλένοιο ἄνακτος{l]
[l [n}13.771{]}Ἀσιάδης τʼ Ἀδάμας ἠδʼ Ἄσιος Ὑρτάκου υἱός;{l]
[l [n}13.772{]}ποῦ δέ τοι Ὀθρυονεύς; νῦν ὤλετο πᾶσα κατʼ ἄκρης{l]
[l [n}13.773{]}Ἴλιος αἰπεινή· νῦν τοι σῶς αἰπὺς ὄλεθρος.{l]{q]{para]
[para}[l [n}13.774{]}τὸν δʼ αὖτε προσέειπεν Ἀλέξανδρος θεοειδής·{l]
[q}[l [n}13.775{]}Ἕκτορ ἐπεί τοι θυμὸς ἀναίτιον αἰτιάασθαι,{l]
[l [n}13.776{]}ἄλλοτε δή ποτε μᾶλλον ἐρωῆσαι πολέμοιο{l]
[l [n}13.777{]}μέλλω, ἐπεὶ οὐδʼ ἐμὲ πάμπαν ἀνάλκιδα γείνατο μήτηρ·{l]
[l [n}13.778{]}ἐξ οὗ γὰρ παρὰ νηυσὶ μάχην ἤγειρας ἑταίρων,{l]
[l [n}13.779{]}ἐκ τοῦ δʼ ἐνθάδʼ ἐόντες ὁμιλέομεν Δαναοῖσι{l]
[l [n}13.780{]}νωλεμέως· ἕταροι δὲ κατέκταθεν οὓς σὺ μεταλλᾷς.{l]
[l [n}13.781{]}οἴω Δηΐφοβός τε βίη θʼ Ἑλένοιο ἄνακτος{l]
[l [n}13.782{]}οἴχεσθον, μακρῇσι τετυμμένω ἐγχείῃσιν{l]
[l [n}13.783{]}ἀμφοτέρω κατὰ χεῖρα· φόνον δʼ ἤμυνε Κρονίων.{l]
[l [n}13.784{]}νῦν δʼ ἄρχʼ ὅππῃ σε κραδίη θυμός τε κελεύει·{l]
[l [n}13.785{]}ἡμεῖς δʼ ἐμμεμαῶτες ἅμʼ ἑψόμεθʼ, οὐδέ τί φημι{l]
[l [n}13.786{]}ἀλκῆς δευήσεσθαι, ὅση δύναμίς γε πάρεστι.{l]
[l [n}13.787{]}πὰρ δύναμιν δʼ οὐκ ἔστι καὶ ἐσσύμενον πολεμίζειν.{l]{q]{para]
[para}[l [n}13.788{]}ὣς εἰπὼν παρέπεισεν ἀδελφειοῦ φρένας ἥρως·{l]
[l [n}13.789{]}βὰν δʼ ἴμεν ἔνθα μάλιστα μάχη καὶ φύλοπις ἦεν{l]
[l [n}13.790{]}ἀμφί τε Κεβριόνην καὶ ἀμύμονα Πουλυδάμαντα{l]
[l [n}13.791{]}Φάλκην Ὀρθαῖόν τε καὶ ἀντίθεον Πολυφήτην{l]
[l [n}13.792{]}Πάλμύν τʼ Ἀσκάνιόν τε Μόρυν θʼ υἷʼ Ἱπποτίωνος,{l]
[l [n}13.793{]}οἵ ῥʼ ἐξ Ἀσκανίης ἐριβώλακος ἦλθον ἀμοιβοὶ{l]
[l [n}13.794{]}ἠοῖ τῇ προτέρῃ· τότε δὲ Ζεὺς ὦρσε μάχεσθαι.{l]
[l [n}13.795{]}οἳ δʼ ἴσαν ἀργαλέων ἀνέμων ἀτάλαντοι ἀέλλῃ,{l]
[l [n}13.796{]}ἥ ῥά θʼ ὑπὸ βροντῆς πατρὸς Διὸς εἶσι πέδον δέ,{l]
[l [n}13.797{]}θεσπεσίῳ δʼ ὁμάδῳ ἁλὶ μίσγεται, ἐν δέ τε πολλὰ{l]
[l [n}13.798{]}κύματα παφλάζοντα πολυφλοίσβοιο θαλάσσης{l]
[l [n}13.799{]}κυρτὰ φαληριόωντα, πρὸ μέν τʼ ἄλλʼ, αὐτὰρ ἐπʼ ἄλλα·{l]
[l [n}13.800{]}ὣς Τρῶες πρὸ μὲν ἄλλοι ἀρηρότες, αὐτὰρ ἐπʼ ἄλλοι,{l]
[l [n}13.801{]}χαλκῷ μαρμαίροντες ἅμʼ ἡγεμόνεσσιν ἕποντο.{l]
[l [n}13.802{]}Ἕκτωρ δʼ ἡγεῖτο βροτολοιγῷ ἶσος Ἄρηϊ{l]
[l [n}13.803{]}Πριαμίδης· πρόσθεν δʼ ἔχεν ἀσπίδα πάντοσʼ ἐΐσην{l]
[l [n}13.804{]}ῥινοῖσιν πυκινήν, πολλὸς δʼ ἐπελήλατο χαλκός·{l]
[l [n}13.805{]}ἀμφὶ δέ οἱ κροτάφοισι φαεινὴ σείετο πήληξ.{l]
[l [n}13.806{]}πάντῃ δʼ ἀμφὶ φάλαγγας ἐπειρᾶτο προποδίζων,{l]
[l [n}13.807{]}εἴ πώς οἱ εἴξειαν ὑπασπίδια προβιβῶντι·{l]
[l [n}13.808{]}ἀλλʼ οὐ σύγχει θυμὸν ἐνὶ στήθεσσιν Ἀχαιῶν.{l]
[l [n}13.809{]}Αἴας δὲ πρῶτος προκαλέσσατο μακρὰ βιβάσθων·{l]
[q}[l [n}13.810{]}δαιμόνιε σχεδὸν ἐλθέ· τί ἢ δειδίσσεαι αὔτως{l]
[l [n}13.811{]}Ἀργείους; οὔ τοί τι μάχης ἀδαήμονές εἰμεν,{l]
[l [n}13.812{]}ἀλλὰ Διὸς μάστιγι κακῇ ἐδάμημεν Ἀχαιοί.{l]
[l [n}13.813{]}ἦ θήν πού τοι θυμὸς ἐέλπεται ἐξαλαπάξειν{l]
[l [n}13.814{]}νῆας· ἄφαρ δέ τε χεῖρες ἀμύνειν εἰσὶ καὶ ἡμῖν.{l]
[l [n}13.815{]}ἦ κε πολὺ φθαίη εὖ ναιομένη πόλις ὑμὴ{l]
[l [n}13.816{]}χερσὶν ὑφʼ ἡμετέρῃσιν ἁλοῦσά τε περθομένη τε.{l]
[l [n}13.817{]}σοὶ δʼ αὐτῷ φημὶ σχεδὸν ἔμμεναι ὁππότε φεύγων{l]
[l [n}13.818{]}ἀρήσῃ Διὶ πατρὶ καὶ ἄλλοις ἀθανάτοισι{l]
[l [n}13.819{]}θάσσονας ἰρήκων ἔμεναι καλλίτριχας ἵππους,{l]
[l [n}13.820{]}οἵ σε πόλιν δʼ οἴσουσι κονίοντες πεδίοιο.{l]{q]{para]
[para}[l [n}13.821{]}ὣς ἄρα οἱ εἰπόντι ἐπέπτατο δεξιὸς ὄρνις{l]
[l [n}13.822{]}αἰετὸς ὑψιπέτης· ἐπὶ δʼ ἴαχε λαὸς Ἀχαιῶν{l]
[l [n}13.823{]}θάρσυνος οἰωνῷ· ὃ δʼ ἀμείβετο φαίδιμος Ἕκτωρ·{l]
[q}[l [n}13.824{]}Αἶαν ἁμαρτοεπὲς βουγάϊε ποῖον ἔειπες·{l]
[l [n}13.825{]}εἰ γὰρ ἐγὼν οὕτω γε Διὸς πάϊς αἰγιόχοιο{l]
[l [n}13.826{]}εἴην ἤματα πάντα, τέκοι δέ με πότνια Ἥρη,{l]
[l [n}13.827{]}τιοίμην δʼ ὡς τίετʼ Ἀθηναίη καὶ Ἀπόλλων,{l]
[l [n}13.828{]}ὡς νῦν ἡμέρη ἥδε κακὸν φέρει Ἀργείοισι{l]
[l [n}13.829{]}πᾶσι μάλʼ, ἐν δὲ σὺ τοῖσι πεφήσεαι, αἴ κε ταλάσσῃς{l]
[l [n}13.830{]}μεῖναι ἐμὸν δόρυ μακρόν, ὅ τοι χρόα λειριόεντα{l]
[l [n}13.831{]}δάψει· ἀτὰρ Τρώων κορέεις κύνας ἠδʼ οἰωνοὺς{l]
[l [n}13.832{]}δημῷ καὶ σάρκεσσι πεσὼν ἐπὶ νηυσὶν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}13.833{]}ὣς ἄρα φωνήσας ἡγήσατο· τοὶ δʼ ἅμʼ ἕποντο{l]
[l [n}13.834{]}ἠχῇ θεσπεσίῃ, ἐπὶ δʼ ἴαχε λαὸς ὄπισθεν.{l]
[l [n}13.835{]}Ἀργεῖοι δʼ ἑτέρωθεν ἐπίαχον, οὐδὲ λάθοντο{l]
[l [n}13.836{]}ἀλκῆς, ἀλλʼ ἔμενον Τρώων ἐπιόντας ἀρίστους.{l]
[l [n}13.837{]}ἠχὴ δʼ ἀμφοτέρων ἵκετʼ αἰθέρα καὶ Διὸς αὐγάς.{l]{para]
{book]
[book [n}14{]}
[para}[l [n}14.1{]}Νέστορα δʼ οὐκ ἔλαθεν ἰαχὴ πίνοντά περ ἔμπης,{l]
[l [n}14.2{]}ἀλλʼ Ἀσκληπιάδην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}14.3{]}φράζεο δῖε Μαχᾶον ὅπως ἔσται τάδε ἔργα·{l]
[l [n}14.4{]}μείζων δὴ παρὰ νηυσὶ βοὴ θαλερῶν αἰζηῶν.{l]
[l [n}14.5{]}ἀλλὰ σὺ μὲν νῦν πῖνε καθήμενος αἴθοπα οἶνον{l]
[l [n}14.6{]}εἰς ὅ κε θερμὰ λοετρὰ ἐϋπλόκαμος Ἑκαμήδη{l]
[l [n}14.7{]}θερμήνῃ καὶ λούσῃ ἄπο βρότον αἱματόεντα·{l]
[l [n}14.8{]}αὐτὰρ ἐγὼν ἐλθὼν τάχα εἴσομαι ἐς περιωπήν.{l]{q]{para]
[para}[l [n}14.9{]}ὣς εἰπὼν σάκος εἷλε τετυγμένον υἷος ἑοῖο{l]
[l [n}14.10{]}κείμενον ἐν κλισίῃ Θρασυμήδεος ἱπποδάμοιο{l]
[l [n}14.11{]}χαλκῷ παμφαῖνον· ὃ δʼ ἔχʼ ἀσπίδα πατρὸς ἑοῖο.{l]
[l [n}14.12{]}εἵλετο δʼ ἄλκιμον ἔγχος ἀκαχμένον ὀξέϊ χαλκῷ,{l]
[l [n}14.13{]}στῆ δʼ ἐκτὸς κλισίης, τάχα δʼ εἴσιδεν ἔργον ἀεικὲς{l]
[l [n}14.14{]}τοὺς μὲν ὀρινομένους, τοὺς δὲ κλονέοντας ὄπισθε{l]
[l [n}14.15{]}Τρῶας ὑπερθύμους· ἐρέριπτο δὲ τεῖχος Ἀχαιῶν.{l]
[l [n}14.16{]}ὡς δʼ ὅτε πορφύρῃ πέλαγος μέγα κύματι κωφῷ{l]
[l [n}14.17{]}ὀσσόμενον λιγέων ἀνέμων λαιψηρὰ κέλευθα{l]
[l [n}14.18{]}αὔτως, οὐδʼ ἄρα τε προκυλίνδεται οὐδετέρωσε,{l]
[l [n}14.19{]}πρίν τινα κεκριμένον καταβήμεναι ἐκ Διὸς οὖρον,{l]
[l [n}14.20{]}ὣς ὃ γέρων ὅρμαινε δαϊζόμενος κατὰ θυμὸν{l]
[l [n}14.21{]}διχθάδιʼ, ἢ μεθʼ ὅμιλον ἴοι Δαναῶν ταχυπώλων,{l]
[l [n}14.22{]}ἦε μετʼ Ἀτρεΐδην Ἀγαμέμνονα ποιμένα λαῶν.{l]
[l [n}14.23{]}ὧδε δέ οἱ φρονέοντι δοάσσατο κέρδιον εἶναι{l]
[l [n}14.24{]}βῆναι ἐπʼ Ἀτρεΐδην. οἳ δʼ ἀλλήλους ἐνάριζον{l]
[l [n}14.25{]}μαρνάμενοι· λάκε δέ σφι περὶ χροῒ χαλκὸς ἀτειρὴς{l]
[l [n}14.26{]}νυσσομένων ξίφεσίν τε καὶ ἔγχεσιν ἀμφιγύοισι.{l]{para]
[para}[l [n}14.27{]}Νέστορι δὲ ξύμβληντο διοτρεφέες βασιλῆες{l]
[l [n}14.28{]}πὰρ νηῶν ἀνιόντες ὅσοι βεβλήατο χαλκῷ{l]
[l [n}14.29{]}Τυδεΐδης Ὀδυσεύς τε καὶ Ἀτρεΐδης Ἀγαμέμνων.{l]
[l [n}14.30{]}πολλὸν γάρ ῥʼ ἀπάνευθε μάχης εἰρύατο νῆες{l]
[l [n}14.31{]}θῖνʼ ἔφʼ ἁλὸς πολιῆς· τὰς γὰρ πρώτας πεδίον δὲ{l]
[l [n}14.32{]}εἴρυσαν, αὐτὰρ τεῖχος ἐπὶ πρύμνῃσιν ἔδειμαν.{l]
[l [n}14.33{]}οὐδὲ γὰρ οὐδʼ εὐρύς περ ἐὼν ἐδυνήσατο πάσας{l]
[l [n}14.34{]}αἰγιαλὸς νῆας χαδέειν, στείνοντο δὲ λαοί·{l]
[l [n}14.35{]}τώ ῥα προκρόσσας ἔρυσαν, καὶ πλῆσαν ἁπάσης{l]
[l [n}14.36{]}ἠϊόνος στόμα μακρόν, ὅσον συνεέργαθον ἄκραι.{l]
[l [n}14.37{]}τώ ῥʼ οἵ γʼ ὀψείοντες ἀϋτῆς καὶ πολέμοιο{l]
[l [n}14.38{]}ἔγχει ἐρειδόμενοι κίον ἀθρόοι· ἄχνυτο δέ σφι{l]
[l [n}14.39{]}θυμὸς ἐνὶ στήθεσσιν. ὃ δὲ ξύμβλητο γεραιὸς{l]
[l [n}14.40{]}Νέστωρ, πτῆξε δὲ θυμὸν ἐνὶ στήθεσσιν Ἀχαιῶν.{l]
[l [n}14.41{]}τὸν καὶ φωνήσας προσέφη κρείων Ἀγαμέμνων·{l]
[q}[l [n}14.42{]}ὦ Νέστορ Νηληϊάδη μέγα κῦδος Ἀχαιῶν{l]
[l [n}14.43{]}τίπτε λιπὼν πόλεμον φθισήνορα δεῦρʼ ἀφικάνεις;{l]
[l [n}14.44{]}δείδω μὴ δή μοι τελέσῃ ἔπος ὄβριμος Ἕκτωρ,{l]
[l [n}14.45{]}ὥς ποτʼ ἐπηπείλησεν ἐνὶ Τρώεσσʼ ἀγορεύων{l]
[l [n}14.46{]}μὴ πρὶν πὰρ νηῶν προτὶ Ἴλιον ἀπονέεσθαι{l]
[l [n}14.47{]}πρὶν πυρὶ νῆας ἐνιπρῆσαι, κτεῖναι δὲ καὶ αὐτούς.{l]
[l [n}14.48{]}κεῖνος τὼς ἀγόρευε· τὰ δὴ νῦν πάντα τελεῖται.{l]
[l [n}14.49{]}ὢ πόποι ἦ ῥα καὶ ἄλλοι ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}14.50{]}ἐν θυμῷ βάλλονται ἐμοὶ χόλον ὥς περ Ἀχιλλεὺς{l]
[l [n}14.51{]}οὐδʼ ἐθέλουσι μάχεσθαι ἐπὶ πρυμνῇσι νέεσσι.{l]{q]{para]
[para}[l [n}14.52{]}τὸν δʼ ἠμείβετʼ ἔπειτα Γερήνιος ἱππότα Νέστωρ·{l]
[q}[l [n}14.53{]}ἦ δὴ ταῦτά γʼ ἑτοῖμα τετεύχαται, οὐδέ κεν ἄλλως{l]
[l [n}14.54{]}Ζεὺς ὑψιβρεμέτης αὐτὸς παρατεκτήναιτο.{l]
[l [n}14.55{]}τεῖχος μὲν γὰρ δὴ κατερήριπεν, ᾧ ἐπέπιθμεν{l]
[l [n}14.56{]}ἄρρηκτον νηῶν τε καὶ αὐτῶν εἶλαρ ἔσεσθαι·{l]
[l [n}14.57{]}οἳ δʼ ἐπὶ νηυσὶ θοῇσι μάχην ἀλίαστον ἔχουσι{l]
[l [n}14.58{]}νωλεμές· οὐδʼ ἂν ἔτι γνοίης μάλα περ σκοπιάζων{l]
[l [n}14.59{]}ὁπποτέρωθεν Ἀχαιοὶ ὀρινόμενοι κλονέονται,{l]
[l [n}14.60{]}ὡς ἐπιμὶξ κτείνονται, ἀϋτὴ δʼ οὐρανὸν ἵκει.{l]
[l [n}14.61{]}ἡμεῖς δὲ φραζώμεθʼ ὅπως ἔσται τάδε ἔργα{l]
[l [n}14.62{]}εἴ τι νόος ῥέξει· πόλεμον δʼ οὐκ ἄμμε κελεύω{l]
[l [n}14.63{]}δύμεναι· οὐ γάρ πως βεβλημένον ἐστὶ μάχεσθαι.{l]{q]{para]
[para}[l [n}14.64{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}14.65{]}Νέστορ ἐπεὶ δὴ νηυσὶν ἔπι πρυμνῇσι μάχονται,{l]
[l [n}14.66{]}τεῖχος δʼ οὐκ ἔχραισμε τετυγμένον, οὐδέ τι τάφρος,{l]
[l [n}14.67{]}ᾗ ἔπι πολλὰ πάθον Δαναοί, ἔλποντο δὲ θυμῷ{l]
[l [n}14.68{]}ἄρρηκτον νηῶν τε καὶ αὐτῶν εἶλαρ ἔσεσθαι·{l]
[l [n}14.69{]}οὕτω που Διὶ μέλλει ὑπερμενέϊ φίλον εἶναι{l]
[l [n}14.70{]}νωνύμνους ἀπολέσθαι ἀπʼ Ἄργεος ἐνθάδʼ Ἀχαιούς.{l]
[l [n}14.71{]}ᾔδεα μὲν γὰρ ὅτε πρόφρων Δαναοῖσιν ἄμυνεν,{l]
[l [n}14.72{]}οἶδα δὲ νῦν ὅτε τοὺς μὲν ὁμῶς μακάρεσσι θεοῖσι{l]
[l [n}14.73{]}κυδάνει, ἡμέτερον δὲ μένος καὶ χεῖρας ἔδησεν.{l]
[l [n}14.74{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼν εἴπω πειθώμεθα πάντες.{l]
[l [n}14.75{]}νῆες ὅσαι πρῶται εἰρύαται ἄγχι θαλάσσης{l]
[l [n}14.76{]}ἕλκωμεν, πάσας δὲ ἐρύσσομεν εἰς ἅλα δῖαν,{l]
[l [n}14.77{]}ὕψι δʼ ἐπʼ εὐνάων ὁρμίσσομεν, εἰς ὅ κεν ἔλθῃ{l]
[l [n}14.78{]}νὺξ ἀβρότη, ἢν καὶ τῇ ἀπόσχωνται πολέμοιο{l]
[l [n}14.79{]}Τρῶες· ἔπειτα δέ κεν ἐρυσαίμεθα νῆας ἁπάσας.{l]
[l [n}14.80{]}οὐ γάρ τις νέμεσις φυγέειν κακόν, οὐδʼ ἀνὰ νύκτα.{l]
[l [n}14.81{]}βέλτερον ὃς φεύγων προφύγῃ κακὸν ἠὲ ἁλώῃ.{l]{q]{para]
[para}[l [n}14.82{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}14.83{]}Ἀτρεΐδη ποῖόν σε ἔπος φύγεν ἕρκος ὀδόντων·{l]
[l [n}14.84{]}οὐλόμενʼ αἴθʼ ὤφελλες ἀεικελίου στρατοῦ ἄλλου{l]
[l [n}14.85{]}σημαίνειν, μὴ δʼ ἄμμιν ἀνασσέμεν, οἷσιν ἄρα Ζεὺς{l]
[l [n}14.86{]}ἐκ νεότητος ἔδωκε καὶ ἐς γῆρας τολυπεύειν{l]
[l [n}14.87{]}ἀργαλέους πολέμους, ὄφρα φθιόμεσθα ἕκαστος.{l]
[l [n}14.88{]}οὕτω δὴ μέμονας Τρώων πόλιν εὐρυάγυιαν{l]
[l [n}14.89{]}καλλείψειν, ἧς εἵνεκʼ ὀϊζύομεν κακὰ πολλά;{l]
[l [n}14.90{]}σίγα, μή τίς τʼ ἄλλος Ἀχαιῶν τοῦτον ἀκούσῃ{l]
[l [n}14.91{]}μῦθον, ὃν οὔ κεν ἀνήρ γε διὰ στόμα πάμπαν ἄγοιτο{l]
[l [n}14.92{]}ὅς τις ἐπίσταιτο ᾗσι φρεσὶν ἄρτια βάζειν{l]
[l [n}14.93{]}σκηπτοῦχός τʼ εἴη, καί οἱ πειθοίατο λαοὶ{l]
[l [n}14.94{]}τοσσοίδʼ ὅσσοισιν σὺ μετʼ Ἀργείοισιν ἀνάσσεις·{l]
[l [n}14.95{]}νῦν δέ σευ ὠνοσάμην πάγχυ φρένας, οἷον ἔειπες·{l]
[l [n}14.96{]}ὃς κέλεαι πολέμοιο συνεσταότος καὶ ἀϋτῆς{l]
[l [n}14.97{]}νῆας ἐϋσσέλμους ἅλαδʼ ἑλκέμεν, ὄφρʼ ἔτι μᾶλλον{l]
[l [n}14.98{]}Τρωσὶ μὲν εὐκτὰ γένηται ἐπικρατέουσί περ ἔμπης,{l]
[l [n}14.99{]}ἡμῖν δʼ αἰπὺς ὄλεθρος ἐπιρρέπῃ. οὐ γὰρ Ἀχαιοὶ{l]
[l [n}14.100{]}σχήσουσιν πόλεμον νηῶν ἅλα δʼ ἑλκομενάων,{l]
[l [n}14.101{]}ἀλλʼ ἀποπαπτανέουσιν, ἐρωήσουσι δὲ χάρμης.{l]
[l [n}14.102{]}ἔνθά κε σὴ βουλὴ δηλήσεται ὄρχαμε λαῶν.{l]{q]{para]
[para}[l [n}14.103{]}τὸν δʼ ἠμείβετʼ ἔπειτα ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}14.104{]}ὦ Ὀδυσεῦ μάλα πώς με καθίκεο θυμὸν ἐνιπῇ{l]
[l [n}14.105{]}ἀργαλέῃ· ἀτὰρ οὐ μὲν ἐγὼν ἀέκοντας ἄνωγα{l]
[l [n}14.106{]}νῆας ἐϋσσέλμους ἅλα δʼ ἑλκέμεν υἷας Ἀχαιῶν.{l]
[l [n}14.107{]}νῦν δʼ εἴη ὃς τῆσδέ γʼ ἀμείνονα μῆτιν ἐνίσποι{l]
[l [n}14.108{]}ἢ νέος ἠὲ παλαιός· ἐμοὶ δέ κεν ἀσμένῳ εἴη.{l]{q]{para]
[para}[l [n}14.109{]}τοῖσι δὲ καὶ μετέειπε βοὴν ἀγαθὸς Διομήδης·{l]
[q}[l [n}14.110{]}ἐγγὺς ἀνήρ· οὐ δηθὰ ματεύσομεν· αἴ κʼ ἐθέλητε{l]
[l [n}14.111{]}πείθεσθαι, καὶ μή τι κότῳ ἀγάσησθε ἕκαστος{l]
[l [n}14.112{]}οὕνεκα δὴ γενεῆφι νεώτατός εἰμι μεθʼ ὑμῖν·{l]
[l [n}14.113{]}πατρὸς δʼ ἐξ ἀγαθοῦ καὶ ἐγὼ γένος εὔχομαι εἶναι{l]
[l [n}14.114{]}Τυδέος, ὃν Θήβῃσι χυτὴ κατὰ γαῖα καλύπτει.{l]
[l [n}14.115{]}πορθεῖ γὰρ τρεῖς παῖδες ἀμύμονες ἐξεγένοντο,{l]
[l [n}14.116{]}οἴκεον δʼ ἐν Πλευρῶνι καὶ αἰπεινῇ Καλυδῶνι{l]
[l [n}14.117{]}Ἄγριος ἠδὲ Μέλας, τρίτατος δʼ ἦν ἱππότα Οἰνεὺς{l]
[l [n}14.118{]}πατρὸς ἐμοῖο πατήρ· ἀρετῇ δʼ ἦν ἔξοχος αὐτῶν.{l]
[l [n}14.119{]}ἀλλʼ ὃ μὲν αὐτόθι μεῖνε, πατὴρ δʼ ἐμὸς Ἄργεϊ νάσθη{l]
[l [n}14.120{]}πλαγχθείς· ὡς γάρ που Ζεὺς ἤθελε καὶ θεοὶ ἄλλοι.{l]
[l [n}14.121{]}Ἀδρήστοιο δʼ ἔγημε θυγατρῶν, ναῖε δὲ δῶμα{l]
[l [n}14.122{]}ἀφνειὸν βιότοιο, ἅλις δέ οἱ ἦσαν ἄρουραι{l]
[l [n}14.123{]}πυροφόροι, πολλοὶ δὲ φυτῶν ἔσαν ὄρχατοι ἀμφίς,{l]
[l [n}14.124{]}πολλὰ δέ οἱ πρόβατʼ ἔσκε· κέκαστο δὲ πάντας Ἀχαιοὺς{l]
[l [n}14.125{]}ἐγχείῃ· τὰ δὲ μέλλετʼ ἀκουέμεν, εἰ ἐτεόν περ.{l]
[l [n}14.126{]}τὼ οὐκ ἄν με γένος γε κακὸν καὶ ἀνάλκιδα φάντες{l]
[l [n}14.127{]}μῦθον ἀτιμήσαιτε πεφασμένον ὅν κʼ ἐῢ εἴπω.{l]
[l [n}14.128{]}δεῦτʼ ἴομεν πόλεμον δὲ καὶ οὐτάμενοί περ ἀνάγκῃ.{l]
[l [n}14.129{]}ἔνθα δʼ ἔπειτʼ αὐτοὶ μὲν ἐχώμεθα δηϊοτῆτος{l]
[l [n}14.130{]}ἐκ βελέων, μή πού τις ἐφʼ ἕλκεϊ ἕλκος ἄρηται·{l]
[l [n}14.131{]}ἄλλους δʼ ὀτρύνοντες ἐνήσομεν, οἳ τὸ πάρος περ{l]
[l [n}14.132{]}θυμῷ ἦρα φέροντες ἀφεστᾶσʼ οὐδὲ μάχονται.{l]{q]{para]
[para}[l [n}14.133{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο·{l]
[l [n}14.134{]}βὰν δʼ ἴμεν, ἦρχε δʼ ἄρά σφιν ἄναξ ἀνδρῶν Ἀγαμέμνων.{l]{para]
[para}[l [n}14.135{]}οὐδʼ ἀλαοσκοπιὴν εἶχε κλυτὸς ἐννοσίγαιος,{l]
[l [n}14.136{]}ἀλλὰ μετʼ αὐτοὺς ἦλθε παλαιῷ φωτὶ ἐοικώς,{l]
[l [n}14.137{]}δεξιτερὴν δʼ ἕλε χεῖρʼ Ἀγαμέμνονος Ἀτρεΐδαο,{l]
[l [n}14.138{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}14.139{]}Ἀτρεΐδη νῦν δή που Ἀχιλλῆος ὀλοὸν κῆρ{l]
[l [n}14.140{]}γηθεῖ ἐνὶ στήθεσσι φόνον καὶ φύζαν Ἀχαιῶν{l]
[l [n}14.141{]}δερκομένῳ, ἐπεὶ οὔ οἱ ἔνι φρένες οὐδʼ ἠβαιαί.{l]
[l [n}14.142{]}ἀλλʼ ὃ μὲν ὣς ἀπόλοιτο, θεὸς δέ ἑ σιφλώσειε·{l]
[l [n}14.143{]}σοὶ δʼ οὔ πω μάλα πάγχυ θεοὶ μάκαρες κοτέουσιν,{l]
[l [n}14.144{]}ἀλλʼ ἔτι που Τρώων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}14.145{]}εὐρὺ κονίσουσιν πεδίον, σὺ δʼ ἐπόψεαι αὐτὸς{l]
[l [n}14.146{]}φεύγοντας προτὶ ἄστυ νεῶν ἄπο καὶ κλισιάων.{l]{q]{para]
[para}[l [n}14.147{]}ὣς εἰπὼν μέγʼ ἄϋσεν ἐπεσσύμενος πεδίοιο.{l]
[l [n}14.148{]}ὅσσόν τʼ ἐννεάχιλοι ἐπίαχον ἢ δεκάχιλοι{l]
[l [n}14.149{]}ἀνέρες ἐν πολέμῳ ἔριδα ξυνάγοντες Ἄρηος,{l]
[l [n}14.150{]}τόσσην ἐκ στήθεσφιν ὄπα κρείων ἐνοσίχθων{l]
[l [n}14.151{]}ἧκεν· Ἀχαιοῖσιν δὲ μέγα σθένος ἔμβαλʼ ἑκάστῳ{l]
[l [n}14.152{]}καρδίῃ, ἄληκτον πολεμίζειν ἠδὲ μάχεσθαι.{l]{para]
[para}[l [n}14.153{]}Ἥρη δʼ εἰσεῖδε χρυσόθρονος ὀφθαλμοῖσι{l]
[l [n}14.154{]}στᾶσʼ ἐξ Οὐλύμποιο ἀπὸ ῥίου· αὐτίκα δʼ ἔγνω{l]
[l [n}14.155{]}τὸν μὲν ποιπνύοντα μάχην ἀνὰ κυδιάνειραν{l]
[l [n}14.156{]}αὐτοκασίγνητον καὶ δαέρα, χαῖρε δὲ θυμῷ·{l]
[l [n}14.157{]}Ζῆνα δʼ ἐπʼ ἀκροτάτης κορυφῆς πολυπίδακος Ἴδης{l]
[l [n}14.158{]}ἥμενον εἰσεῖδε, στυγερὸς δέ οἱ ἔπλετο θυμῷ.{l]
[l [n}14.159{]}μερμήριξε δʼ ἔπειτα βοῶπις πότνια Ἥρη{l]
[l [n}14.160{]}ὅππως ἐξαπάφοιτο Διὸς νόον αἰγιόχοιο·{l]
[l [n}14.161{]}ἥδε δέ οἱ κατὰ θυμὸν ἀρίστη φαίνετο βουλὴ{l]
[l [n}14.162{]}ἐλθεῖν εἰς Ἴδην εὖ ἐντύνασαν ἓ αὐτήν,{l]
[l [n}14.163{]}εἴ πως ἱμείραιτο παραδραθέειν φιλότητι{l]
[l [n}14.164{]}ᾗ χροιῇ, τῷ δʼ ὕπνον ἀπήμονά τε λιαρόν τε{l]
[l [n}14.165{]}χεύῃ ἐπὶ βλεφάροισιν ἰδὲ φρεσὶ πευκαλίμῃσι.{l]
[l [n}14.166{]}βῆ δʼ ἴμεν ἐς θάλαμον, τόν οἱ φίλος υἱὸς ἔτευξεν{l]
[l [n}14.167{]}Ἥφαιστος, πυκινὰς δὲ θύρας σταθμοῖσιν ἐπῆρσε{l]
[l [n}14.168{]}κληῗδι κρυπτῇ, τὴν δʼ οὐ θεὸς ἄλλος ἀνῷγεν·{l]
[l [n}14.169{]}ἔνθʼ ἥ γʼ εἰσελθοῦσα θύρας ἐπέθηκε φαεινάς.{l]
[l [n}14.170{]}ἀμβροσίῃ μὲν πρῶτον ἀπὸ χροὸς ἱμερόεντος{l]
[l [n}14.171{]}λύματα πάντα κάθηρεν, ἀλείψατο δὲ λίπʼ ἐλαίῳ{l]
[l [n}14.172{]}ἀμβροσίῳ ἑδανῷ, τό ῥά οἱ τεθυωμένον ἦεν·{l]
[l [n}14.173{]}τοῦ καὶ κινυμένοιο Διὸς κατὰ χαλκοβατὲς δῶ{l]
[l [n}14.174{]}ἔμπης ἐς γαῖάν τε καὶ οὐρανὸν ἵκετʼ ἀϋτμή.{l]
[l [n}14.175{]}τῷ ῥʼ ἥ γε χρόα καλὸν ἀλειψαμένη ἰδὲ χαίτας{l]
[l [n}14.176{]}πεξαμένη χερσὶ πλοκάμους ἔπλεξε φαεινοὺς{l]
[l [n}14.177{]}καλοὺς ἀμβροσίους ἐκ κράατος ἀθανάτοιο.{l]
[l [n}14.178{]}ἀμφὶ δʼ ἄρʼ ἀμβρόσιον ἑανὸν ἕσαθʼ, ὅν οἱ Ἀθήνη{l]
[l [n}14.179{]}ἔξυσʼ ἀσκήσασα, τίθει δʼ ἐνὶ δαίδαλα πολλά·{l]
[l [n}14.180{]}χρυσείῃς δʼ ἐνετῇσι κατὰ στῆθος περονᾶτο.{l]
[l [n}14.181{]}ζώσατο δὲ ζώνῃ ἑκατὸν θυσάνοις ἀραρυίῃ,{l]
[l [n}14.182{]}ἐν δʼ ἄρα ἕρματα ἧκεν ἐϋτρήτοισι λοβοῖσι{l]
[l [n}14.183{]}τρίγληνα μορόεντα· χάρις δʼ ἀπελάμπετο πολλή.{l]
[l [n}14.184{]}κρηδέμνῳ δʼ ἐφύπερθε καλύψατο δῖα θεάων{l]
[l [n}14.185{]}καλῷ νηγατέῳ· λευκὸν δʼ ἦν ἠέλιος ὥς·{l]
[l [n}14.186{]}ποσσὶ δʼ ὑπὸ λιπαροῖσιν ἐδήσατο καλὰ πέδιλα.{l]
[l [n}14.187{]}αὐτὰρ ἐπεὶ δὴ πάντα περὶ χροῒ θήκατο κόσμον{l]
[l [n}14.188{]}βῆ ῥʼ ἴμεν ἐκ θαλάμοιο, καλεσσαμένη δʼ Ἀφροδίτην{l]
[l [n}14.189{]}τῶν ἄλλων ἀπάνευθε θεῶν πρὸς μῦθον ἔειπε·{l]
[q}[l [n}14.190{]}ἦ ῥά νύ μοί τι πίθοιο φίλον τέκος ὅττί κεν εἴπω,{l]
[l [n}14.191{]}ἦέ κεν ἀρνήσαιο κοτεσσαμένη τό γε θυμῷ,{l]
[l [n}14.192{]}οὕνεκʼ ἐγὼ Δαναοῖσι, σὺ δὲ Τρώεσσιν ἀρήγεις;{l]{q]{para]
[para}[l [n}14.193{]}τὴν δʼ ἠμείβετʼ ἔπειτα Διὸς θυγάτηρ Ἀφροδίτη·{l]
[q}[l [n}14.194{]}Ἥρη πρέσβα θεὰ θύγατερ μεγάλοιο Κρόνοιο{l]
[l [n}14.195{]}αὔδα ὅ τι φρονέεις· τελέσαι δέ με θυμὸς ἄνωγεν,{l]
[l [n}14.196{]}εἰ δύναμαι τελέσαι γε καὶ εἰ τετελεσμένον ἐστίν.{l]{q]{para]
[para}[l [n}14.197{]}τὴν δὲ δολοφρονέουσα προσηύδα πότνια Ἥρη·{l]
[q}[l [n}14.198{]}δὸς νῦν μοι φιλότητα καὶ ἵμερον, ᾧ τε σὺ πάντας{l]
[l [n}14.199{]}δαμνᾷ ἀθανάτους ἠδὲ θνητοὺς ἀνθρώπους.{l]
[l [n}14.200{]}εἶμι γὰρ ὀψομένη πολυφόρβου πείρατα γαίης,{l]
[l [n}14.201{]}Ὠκεανόν τε θεῶν γένεσιν καὶ μητέρα Τηθύν,{l]
[l [n}14.202{]}οἵ μʼ ἐν σφοῖσι δόμοισιν ἐῢ τρέφον ἠδʼ ἀτίταλλον{l]
[l [n}14.203{]}δεξάμενοι Ῥείας, ὅτε τε Κρόνον εὐρύοπα Ζεὺς{l]
[l [n}14.204{]}γαίης νέρθε καθεῖσε καὶ ἀτρυγέτοιο θαλάσσης·{l]
[l [n}14.205{]}τοὺς εἶμʼ ὀψομένη, καί σφʼ ἄκριτα νείκεα λύσω·{l]
[l [n}14.206{]}ἤδη γὰρ δηρὸν χρόνον ἀλλήλων ἀπέχονται{l]
[l [n}14.207{]}εὐνῆς καὶ φιλότητος, ἐπεὶ χόλος ἔμπεσε θυμῷ.{l]
[l [n}14.208{]}εἰ κείνω ἐπέεσσι παραιπεπιθοῦσα φίλον κῆρ{l]
[l [n}14.209{]}εἰς εὐνὴν ἀνέσαιμι ὁμωθῆναι φιλότητι,{l]
[l [n}14.210{]}αἰεί κέ σφι φίλη τε καὶ αἰδοίη καλεοίμην.{l]{q]{para]
[para}[l [n}14.211{]}τὴν δʼ αὖτε προσέειπε φιλομειδὴς Ἀφροδίτη·{l]
[q}[l [n}14.212{]}οὐκ ἔστʼ οὐδὲ ἔοικε τεὸν ἔπος ἀρνήσασθαι·{l]
[l [n}14.213{]}Ζηνὸς γὰρ τοῦ ἀρίστου ἐν ἀγκοίνῃσιν ἰαύεις.{l]{q]{para]
[para}[l [n}14.214{]}ἦ, καὶ ἀπὸ στήθεσφιν ἐλύσατο κεστὸν ἱμάντα{l]
[l [n}14.215{]}ποικίλον, ἔνθα δέ οἱ θελκτήρια πάντα τέτυκτο·{l]
[l [n}14.216{]}ἔνθʼ ἔνι μὲν φιλότης, ἐν δʼ ἵμερος, ἐν δʼ ὀαριστὺς{l]
[l [n}14.217{]}πάρφασις, ἥ τʼ ἔκλεψε νόον πύκα περ φρονεόντων.{l]
[l [n}14.218{]}τόν ῥά οἱ ἔμβαλε χερσὶν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}14.219{]}τῆ νῦν τοῦτον ἱμάντα τεῷ ἐγκάτθεο κόλπῳ{l]
[l [n}14.220{]}ποικίλον, ᾧ ἔνι πάντα τετεύχαται· οὐδέ σέ φημι{l]
[l [n}14.221{]}ἄπρηκτόν γε νέεσθαι, ὅ τι φρεσὶ σῇσι μενοινᾷς.{l]{q]{para]
[para}[l [n}14.222{]}ὣς φάτο, μείδησεν δὲ βοῶπις πότνια Ἥρη,{l]
[l [n}14.223{]}μειδήσασα δʼ ἔπειτα ἑῷ ἐγκάτθετο κόλπῳ.{l]{para]
[para}[l [n}14.224{]}ἣ μὲν ἔβη πρὸς δῶμα Διὸς θυγάτηρ Ἀφροδίτη,{l]
[l [n}14.225{]}Ἥρη δʼ ἀΐξασα λίπεν ῥίον Οὐλύμποιο,{l]
[l [n}14.226{]}Πιερίην δʼ ἐπιβᾶσα καὶ Ἠμαθίην ἐρατεινὴν{l]
[l [n}14.227{]}σεύατʼ ἐφʼ ἱπποπόλων Θρῃκῶν ὄρεα νιφόεντα{l]
[l [n}14.228{]}ἀκροτάτας κορυφάς· οὐδὲ χθόνα μάρπτε ποδοῖιν·{l]
[l [n}14.229{]}ἐξ Ἀθόω δʼ ἐπὶ πόντον ἐβήσετο κυμαίνοντα,{l]
[l [n}14.230{]}Λῆμνον δʼ εἰσαφίκανε πόλιν θείοιο Θόαντος.{l]
[l [n}14.231{]}ἔνθʼ Ὕπνῳ ξύμβλητο κασιγνήτῳ Θανάτοιο,{l]
[l [n}14.232{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζεν·{l]
[q}[l [n}14.233{]}Ὕπνε ἄναξ πάντων τε θεῶν πάντων τʼ ἀνθρώπων,{l]
[l [n}14.234{]}ἠμὲν δή ποτʼ ἐμὸν ἔπος ἔκλυες, ἠδʼ ἔτι καὶ νῦν{l]
[l [n}14.235{]}πείθευ· ἐγὼ δέ κέ τοι ἰδέω χάριν ἤματα πάντα.{l]
[l [n}14.236{]}κοίμησόν μοι Ζηνὸς ὑπʼ ὀφρύσιν ὄσσε φαεινὼ{l]
[l [n}14.237{]}αὐτίκʼ ἐπεί κεν ἐγὼ παραλέξομαι ἐν φιλότητι.{l]
[l [n}14.238{]}δῶρα δέ τοι δώσω καλὸν θρόνον ἄφθιτον αἰεὶ{l]
[l [n}14.239{]}χρύσεον· Ἥφαιστος δέ κʼ ἐμὸς πάϊς ἀμφιγυήεις{l]
[l [n}14.240{]}τεύξειʼ ἀσκήσας, ὑπὸ δὲ θρῆνυν ποσὶν ἥσει,{l]
[l [n}14.241{]}τῷ κεν ἐπισχοίης λιπαροὺς πόδας εἰλαπινάζων.{l]{q]{para]
[para}[l [n}14.242{]}τὴν δʼ ἀπαμειβόμενος προσεφώνεε νήδυμος Ὕπνος·{l]
[q}[l [n}14.243{]}Ἥρη πρέσβα θεὰ θύγατερ μεγάλοιο Κρόνοιο{l]
[l [n}14.244{]}ἄλλον μέν κεν ἔγωγε θεῶν αἰειγενετάων{l]
[l [n}14.245{]}ῥεῖα κατευνήσαιμι, καὶ ἂν ποταμοῖο ῥέεθρα{l]
[l [n}14.246{]}Ὠκεανοῦ, ὅς περ γένεσις πάντεσσι τέτυκται·{l]
[l [n}14.247{]}Ζηνὸς δʼ οὐκ ἂν ἔγωγε Κρονίονος ἆσσον ἱκοίμην{l]
[l [n}14.248{]}οὐδὲ κατευνήσαιμʼ, ὅτε μὴ αὐτός γε κελεύοι.{l]
[l [n}14.249{]}ἤδη γάρ με καὶ ἄλλο τεὴ ἐπίνυσσεν ἐφετμὴ{l]
[l [n}14.250{]}ἤματι τῷ ὅτε κεῖνος ὑπέρθυμος Διὸς υἱὸς{l]
[l [n}14.251{]}ἔπλεεν Ἰλιόθεν Τρώων πόλιν ἐξαλαπάξας.{l]
[l [n}14.252{]}ἤτοι ἐγὼ μὲν ἔλεξα Διὸς νόον αἰγιόχοιο{l]
[l [n}14.253{]}νήδυμος ἀμφιχυθείς· σὺ δέ οἱ κακὰ μήσαο θυμῷ{l]
[l [n}14.254{]}ὄρσασʼ ἀργαλέων ἀνέμων ἐπὶ πόντον ἀήτας,{l]
[l [n}14.255{]}καί μιν ἔπειτα Κόων δʼ εὖ ναιομένην ἀπένεικας{l]
[l [n}14.256{]}νόσφι φίλων πάντων. ὃ δʼ ἐπεγρόμενος χαλέπαινε{l]
[l [n}14.257{]}ῥιπτάζων κατὰ δῶμα θεούς, ἐμὲ δʼ ἔξοχα πάντων{l]
[l [n}14.258{]}ζήτει· καί κέ μʼ ἄϊστον ἀπʼ αἰθέρος ἔμβαλε πόντῳ,{l]
[l [n}14.259{]}εἰ μὴ Νὺξ δμήτειρα θεῶν ἐσάωσε καὶ ἀνδρῶν·{l]
[l [n}14.260{]}τὴν ἱκόμην φεύγων, ὃ δʼ ἐπαύσατο χωόμενός περ.{l]
[l [n}14.261{]}ἅζετο γὰρ μὴ Νυκτὶ θοῇ ἀποθύμια ἕρδοι.{l]
[l [n}14.262{]}νῦν αὖ τοῦτό μʼ ἄνωγας ἀμήχανον ἄλλο τελέσσαι.{l]{q]{para]
[para}[l [n}14.263{]}τὸν δʼ αὖτε προσέειπε βοῶπις πότνια Ἥρη·{l]
[q}[l [n}14.264{]}Ὕπνε τί ἢ δὲ σὺ ταῦτα μετὰ φρεσὶ σῇσι μενοινᾷς;{l]
[l [n}14.265{]}ἦ φῂς ὣς Τρώεσσιν ἀρηξέμεν εὐρύοπα Ζῆν{l]
[l [n}14.266{]}ὡς Ἡρακλῆος περιχώσατο παῖδος ἑοῖο;{l]
[l [n}14.267{]}ἀλλʼ ἴθʼ, ἐγὼ δέ κέ τοι Χαρίτων μίαν ὁπλοτεράων{l]
[l [n}14.268{]}δώσω ὀπυιέμεναι καὶ σὴν κεκλῆσθαι ἄκοιτιν.{l]{q]{para]
[para}[l [n}14.270{]}ὣς φάτο, χήρατο δʼ Ὕπνος, ἀμειβόμενος δὲ προσηύδα·{l]
[q}[l [n}14.271{]}ἄγρει νῦν μοι ὄμοσσον ἀάατον Στυγὸς ὕδωρ,{l]
[l [n}14.272{]}χειρὶ δὲ τῇ ἑτέρῃ μὲν ἕλε χθόνα πουλυβότειραν,{l]
[l [n}14.273{]}τῇ δʼ ἑτέρῃ ἅλα μαρμαρέην, ἵνα νῶϊν ἅπαντες{l]
[l [n}14.274{]}μάρτυροι ὦσʼ οἳ ἔνερθε θεοὶ Κρόνον ἀμφὶς ἐόντες,{l]
[l [n}14.275{]}ἦ μὲν ἐμοὶ δώσειν Χαρίτων μίαν ὁπλοτεράων{l]
[l [n}14.276{]}Πασιθέην, ἧς τʼ αὐτὸς ἐέλδομαι ἤματα πάντα.{l]{q]{para]
[para}[l [n}14.277{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ λευκώλενος Ἥρη,{l]
[l [n}14.278{]}ὄμνυε δʼ ὡς ἐκέλευε, θεοὺς δʼ ὀνόμηνεν ἅπαντας{l]
[l [n}14.279{]}τοὺς ὑποταρταρίους οἳ Τιτῆνες καλέονται.{l]
[l [n}14.280{]}αὐτὰρ ἐπεί ῥʼ ὄμοσέν τε τελεύτησέν τε τὸν ὅρκον,{l]
[l [n}14.281{]}τὼ βήτην Λήμνου τε καὶ Ἴμβρου ἄστυ λιπόντε{l]
[l [n}14.282{]}ἠέρα ἑσσαμένω ῥίμφα πρήσσοντε κέλευθον.{l]
[l [n}14.283{]}Ἴδην δʼ ἱκέσθην πολυπίδακα μητέρα θηρῶν{l]
[l [n}14.284{]}Λεκτόν, ὅθι πρῶτον λιπέτην ἅλα· τὼ δʼ ἐπὶ χέρσου{l]
[l [n}14.285{]}βήτην, ἀκροτάτη δὲ ποδῶν ὕπο σείετο ὕλη.{l]
[l [n}14.286{]}ἔνθʼ Ὕπνος μὲν ἔμεινε πάρος Διὸς ὄσσε ἰδέσθαι{l]
[l [n}14.287{]}εἰς ἐλάτην ἀναβὰς περιμήκετον, ἣ τότʼ ἐν Ἴδῃ{l]
[l [n}14.288{]}μακροτάτη πεφυυῖα διʼ ἠέρος αἰθέρʼ ἵκανεν·{l]
[l [n}14.289{]}ἔνθʼ ἧστʼ ὄζοισιν πεπυκασμένος εἰλατίνοισιν{l]
[l [n}14.290{]}ὄρνιθι λιγυρῇ ἐναλίγκιος, ἥν τʼ ἐν ὄρεσσι{l]
[l [n}14.291{]}χαλκίδα κικλήσκουσι θεοί, ἄνδρες δὲ κύμινδιν.{l]{para]
[para}[l [n}14.292{]}Ἥρη δὲ κραιπνῶς προσεβήσετο Γάργαρον ἄκρον{l]
[l [n}14.293{]}Ἴδης ὑψηλῆς· ἴδε δὲ νεφεληγερέτα Ζεύς.{l]
[l [n}14.294{]}ὡς δʼ ἴδεν, ὥς μιν ἔρως πυκινὰς φρένας ἀμφεκάλυψεν,{l]
[l [n}14.295{]}οἷον ὅτε πρῶτόν περ ἐμισγέσθην φιλότητι{l]
[l [n}14.296{]}εἰς εὐνὴν φοιτῶντε, φίλους λήθοντε τοκῆας.{l]
[l [n}14.297{]}στῆ δʼ αὐτῆς προπάροιθεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζεν·{l]
[q}[l [n}14.298{]}Ἥρη πῇ μεμαυῖα κατʼ Οὐλύμπου τόδʼ ἱκάνεις;{l]
[l [n}14.299{]}ἵπποι δʼ οὐ παρέασι καὶ ἅρματα τῶν κʼ ἐπιβαίης.{l]{q]{para]
[para}[l [n}14.300{]}τὸν δὲ δολοφρονέουσα προσηύδα πότνια Ἥρη·{l]
[q}[l [n}14.301{]}ἔρχομαι ὀψομένη πολυφόρβου πείρατα γαίης,{l]
[l [n}14.302{]}Ὠκεανόν τε θεῶν γένεσιν καὶ μητέρα Τηθύν,{l]
[l [n}14.303{]}οἵ με σφοῖσι δόμοισιν ἐῢ τρέφον ἠδʼ ἀτίταλλον·{l]
[l [n}14.304{]}τοὺς εἶμʼ ὀψομένη, καί σφʼ ἄκριτα νείκεα λύσω·{l]
[l [n}14.305{]}ἤδη γὰρ δηρὸν χρόνον ἀλλήλων ἀπέχονται{l]
[l [n}14.306{]}εὐνῆς καὶ φιλότητος, ἐπεὶ χόλος ἔμπεσε θυμῷ.{l]
[l [n}14.307{]}ἵπποι δʼ ἐν πρυμνωρείῃ πολυπίδακος Ἴδης{l]
[l [n}14.308{]}ἑστᾶσʼ, οἵ μʼ οἴσουσιν ἐπὶ τραφερήν τε καὶ ὑγρήν.{l]
[l [n}14.309{]}νῦν δὲ σεῦ εἵνεκα δεῦρο κατʼ Οὐλύμπου τόδʼ ἱκάνω,{l]
[l [n}14.310{]}μή πώς μοι μετέπειτα χολώσεαι, αἴ κε σιωπῇ{l]
[l [n}14.311{]}οἴχωμαι πρὸς δῶμα βαθυρρόου Ὠκεανοῖο.{l]{q]{para]
[para}[l [n}14.312{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}14.313{]}Ἥρη κεῖσε μὲν ἔστι καὶ ὕστερον ὁρμηθῆναι,{l]
[l [n}14.314{]}νῶϊ δʼ ἄγʼ ἐν φιλότητι τραπείομεν εὐνηθέντε.{l]
[l [n}14.315{]}οὐ γάρ πώ ποτέ μʼ ὧδε θεᾶς ἔρος οὐδὲ γυναικὸς{l]
[l [n}14.316{]}θυμὸν ἐνὶ στήθεσσι περιπροχυθεὶς ἐδάμασσεν,{l]
[l [n}14.317{]}οὐδʼ ὁπότʼ ἠρασάμην Ἰξιονίης ἀλόχοιο,{l]
[l [n}14.318{]}ἣ τέκε Πειρίθοον θεόφιν μήστωρʼ ἀτάλαντον·{l]
[l [n}14.319{]}οὐδʼ ὅτε περ Δανάης καλλισφύρου Ἀκρισιώνης,{l]
[l [n}14.320{]}ἣ τέκε Περσῆα πάντων ἀριδείκετον ἀνδρῶν·{l]
[l [n}14.321{]}οὐδʼ ὅτε Φοίνικος κούρης τηλεκλειτοῖο,{l]
[l [n}14.322{]}ἣ τέκε μοι Μίνων τε καὶ ἀντίθεον Ῥαδάμανθυν·{l]
[l [n}14.323{]}οὐδʼ ὅτε περ Σεμέλης οὐδʼ Ἀλκμήνης ἐνὶ Θήβῃ,{l]
[l [n}14.324{]}ἥ ῥʼ Ἡρακλῆα κρατερόφρονα γείνατο παῖδα·{l]
[l [n}14.325{]}ἣ δὲ Διώνυσον Σεμέλη τέκε χάρμα βροτοῖσιν·{l]
[l [n}14.326{]}οὐδʼ ὅτε Δήμητρος καλλιπλοκάμοιο ἀνάσσης,{l]
[l [n}14.327{]}οὐδʼ ὁπότε Λητοῦς ἐρικυδέος, οὐδὲ σεῦ αὐτῆς,{l]
[l [n}14.328{]}ὡς σέο νῦν ἔραμαι καί με γλυκὺς ἵμερος αἱρεῖ.{l]{q]{para]
[para}[l [n}14.329{]}τὸν δὲ δολοφρονέουσα προσηύδα πότνια Ἥρη·{l]
[q}[l [n}14.330{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες.{l]
[l [n}14.331{]}εἰ νῦν ἐν φιλότητι λιλαίεαι εὐνηθῆναι{l]
[l [n}14.332{]}Ἴδης ἐν κορυφῇσι, τὰ δὲ προπέφανται ἅπαντα·{l]
[l [n}14.333{]}πῶς κʼ ἔοι εἴ τις νῶϊ θεῶν αἰειγενετάων{l]
[l [n}14.334{]}εὕδοντʼ ἀθρήσειε, θεοῖσι δὲ πᾶσι μετελθὼν{l]
[l [n}14.335{]}πεφράδοι; οὐκ ἂν ἔγωγε τεὸν πρὸς δῶμα νεοίμην{l]
[l [n}14.336{]}ἐξ εὐνῆς ἀνστᾶσα, νεμεσσητὸν δέ κεν εἴη.{l]
[l [n}14.337{]}ἀλλʼ εἰ δή ῥʼ ἐθέλεις καί τοι φίλον ἔπλετο θυμῷ,{l]
[l [n}14.338{]}ἔστιν τοι θάλαμος, τόν τοι φίλος υἱὸς ἔτευξεν{l]
[l [n}14.339{]}Ἥφαιστος, πυκινὰς δὲ θύρας σταθμοῖσιν ἐπῆρσεν·{l]
[l [n}14.340{]}ἔνθʼ ἴομεν κείοντες, ἐπεί νύ τοι εὔαδεν εὐνή.{l]{q]{para]
[para}[l [n}14.341{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}14.342{]}Ἥρη μήτε θεῶν τό γε δείδιθι μήτέ τινʼ ἀνδρῶν{l]
[l [n}14.343{]}ὄψεσθαι· τοῖόν τοι ἐγὼ νέφος ἀμφικαλύψω{l]
[l [n}14.344{]}χρύσεον· οὐδʼ ἂν νῶϊ διαδράκοι Ἠέλιός περ,{l]
[l [n}14.345{]}οὗ τε καὶ ὀξύτατον πέλεται φάος εἰσοράασθαι.{l]{q]{para]
[para}[l [n}14.346{]}ἦ ῥα καὶ ἀγκὰς ἔμαρπτε Κρόνου παῖς ἣν παράκοιτιν·{l]
[l [n}14.347{]}τοῖσι δʼ ὑπὸ χθὼν δῖα φύεν νεοθηλέα ποίην,{l]
[l [n}14.348{]}λωτόν θʼ ἑρσήεντα ἰδὲ κρόκον ἠδʼ ὑάκινθον{l]
[l [n}14.349{]}πυκνὸν καὶ μαλακόν, ὃς ἀπὸ χθονὸς ὑψόσʼ ἔεργε.{l]
[l [n}14.350{]}τῷ ἔνι λεξάσθην, ἐπὶ δὲ νεφέλην ἕσσαντο{l]
[l [n}14.351{]}καλὴν χρυσείην· στιλπναὶ δʼ ἀπέπιπτον ἔερσαι.{l]{para]
[para}[l [n}14.352{]}ὣς ὃ μὲν ἀτρέμας εὗδε πατὴρ ἀνὰ Γαργάρῳ ἄκρῳ,{l]
[l [n}14.353{]}ὕπνῳ καὶ φιλότητι δαμείς, ἔχε δʼ ἀγκὰς ἄκοιτιν·{l]
[l [n}14.354{]}βῆ δὲ θέειν ἐπὶ νῆας Ἀχαιῶν νήδυμος Ὕπνος{l]
[l [n}14.355{]}ἀγγελίην ἐρέων γαιηόχῳ ἐννοσιγαίῳ·{l]
[l [n}14.356{]}ἀγχοῦ δʼ ἱστάμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}14.357{]}πρόφρων νῦν Δαναοῖσι Ποσείδαον ἐπάμυνε,{l]
[l [n}14.358{]}καί σφιν κῦδος ὄπαζε μίνυνθά περ, ὄφρʼ ἔτι εὕδει{l]
[l [n}14.359{]}Ζεύς, ἐπεὶ αὐτῷ ἐγὼ μαλακὸν περὶ κῶμʼ ἐκάλυψα·{l]
[l [n}14.360{]}Ἥρη δʼ ἐν φιλότητι παρήπαφεν εὐνηθῆναι.{l]{q]{para]
[para}[l [n}14.361{]}ὣς εἰπὼν ὃ μὲν ᾤχετʼ ἐπὶ κλυτὰ φῦλʼ ἀνθρώπων,{l]
[l [n}14.362{]}τὸν δʼ ἔτι μᾶλλον ἀνῆκεν ἀμυνέμεναι Δαναοῖσιν.{l]
[l [n}14.363{]}αὐτίκα δʼ ἐν πρώτοισι μέγα προθορὼν ἐκέλευσεν·{l]
[q}[l [n}14.364{]}Ἀργεῖοι καὶ δʼ αὖτε μεθίεμεν Ἕκτορι νίκην{l]
[l [n}14.365{]}Πριαμίδῃ, ἵνα νῆας ἕλῃ καὶ κῦδος ἄρηται;{l]
[l [n}14.366{]}ἀλλʼ ὃ μὲν οὕτω φησὶ καὶ εὔχεται οὕνεκʼ Ἀχιλλεὺς{l]
[l [n}14.367{]}νηυσὶν ἔπι γλαφυρῇσι μένει κεχολωμένος ἦτορ·{l]
[l [n}14.368{]}κείνου δʼ οὔ τι λίην ποθὴ ἔσσεται, εἴ κεν οἳ ἄλλοι{l]
[l [n}14.369{]}ἡμεῖς ὀτρυνώμεθʼ ἀμυνέμεν ἀλλήλοισιν.{l]
[l [n}14.370{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω πειθώμεθα πάντες·{l]
[l [n}14.371{]}ἀσπίδες ὅσσαι ἄρισται ἐνὶ στρατῷ ἠδὲ μέγισται{l]
[l [n}14.372{]}ἑσσάμενοι, κεφαλὰς δὲ παναίθῃσιν κορύθεσσι{l]
[l [n}14.373{]}κρύψαντες, χερσίν τε τὰ μακρότατʼ ἔγχεʼ ἑλόντες{l]
[l [n}14.374{]}ἴομεν· αὐτὰρ ἐγὼν ἡγήσομαι, οὐδʼ ἔτι φημὶ{l]
[l [n}14.375{]}Ἕκτορα Πριαμίδην μενέειν μάλα περ μεμαῶτα.{l]
[l [n}14.376{]}ὃς δέ κʼ ἀνὴρ μενέχαρμος, ἔχει δʼ ὀλίγον σάκος ὤμῳ,{l]
[l [n}14.377{]}χείρονι φωτὶ δότω, ὃ δʼ ἐν ἀσπίδι μείζονι δύτω.{l]{q]{para]
[para}[l [n}14.378{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο·{l]
[l [n}14.379{]}τοὺς δʼ αὐτοὶ βασιλῆες ἐκόσμεον οὐτάμενοί περ{l]
[l [n}14.380{]}Τυδεΐδης Ὀδυσεύς τε καὶ Ἀτρεΐδης Ἀγαμέμνων·{l]
[l [n}14.381{]}οἰχόμενοι δʼ ἐπὶ πάντας ἀρήϊα τεύχεʼ ἄμειβον·{l]
[l [n}14.382{]}ἐσθλὰ μὲν ἐσθλὸς ἔδυνε, χέρεια δὲ χείρονι δόσκεν.{l]
[l [n}14.383{]}αὐτὰρ ἐπεί ῥʼ ἕσσαντο περὶ χροῒ νώροπα χαλκὸν{l]
[l [n}14.384{]}βάν ῥʼ ἴμεν· ἦρχε δʼ ἄρά σφι Ποσειδάων ἐνοσίχθων{l]
[l [n}14.385{]}δεινὸν ἄορ τανύηκες ἔχων ἐν χειρὶ παχείῃ{l]
[l [n}14.386{]}εἴκελον ἀστεροπῇ· τῷ δʼ οὐ θέμις ἐστὶ μιγῆναι{l]
[l [n}14.387{]}ἐν δαῒ λευγαλέῃ, ἀλλὰ δέος ἰσχάνει ἄνδρας.{l]{para]
[para}[l [n}14.388{]}Τρῶας δʼ αὖθʼ ἑτέρωθεν ἐκόσμει φαίδιμος Ἕκτωρ.{l]
[l [n}14.389{]}δή ῥα τότʼ αἰνοτάτην ἔριδα πτολέμοιο τάνυσσαν{l]
[l [n}14.390{]}κυανοχαῖτα Ποσειδάων καὶ φαίδιμος Ἕκτωρ,{l]
[l [n}14.391{]}ἤτοι ὃ μὲν Τρώεσσιν, ὃ δʼ Ἀργείοισιν ἀρήγων.{l]
[l [n}14.392{]}ἐκλύσθη δὲ θάλασσα ποτὶ κλισίας τε νέας τε{l]
[l [n}14.393{]}Ἀργείων· οἳ δὲ ξύνισαν μεγάλῳ ἀλαλητῷ.{l]
[l [n}14.394{]}οὔτε θαλάσσης κῦμα τόσον βοάᾳ ποτὶ χέρσον{l]
[l [n}14.395{]}ποντόθεν ὀρνύμενον πνοιῇ Βορέω ἀλεγεινῇ·{l]
[l [n}14.396{]}οὔτε πυρὸς τόσσός γε ποτὶ βρόμος αἰθομένοιο{l]
[l [n}14.397{]}οὔρεος ἐν βήσσῃς, ὅτε τʼ ὤρετο καιέμεν ὕλην·{l]
[l [n}14.398{]}οὔτʼ ἄνεμος τόσσόν γε περὶ δρυσὶν ὑψικόμοισι{l]
[l [n}14.399{]}ἠπύει, ὅς τε μάλιστα μέγα βρέμεται χαλεπαίνων,{l]
[l [n}14.400{]}ὅσση ἄρα Τρώων καὶ Ἀχαιῶν ἔπλετο φωνὴ{l]
[l [n}14.401{]}δεινὸν ἀϋσάντων, ὅτʼ ἐπʼ ἀλλήλοισιν ὄρουσαν.{l]{para]
[para}[l [n}14.402{]}Αἴαντος δὲ πρῶτος ἀκόντισε φαίδιμος Ἕκτωρ{l]
[l [n}14.403{]}ἔγχει, ἐπεὶ τέτραπτο πρὸς ἰθύ οἱ, οὐδʼ ἀφάμαρτε,{l]
[l [n}14.404{]}τῇ ῥα δύω τελαμῶνε περὶ στήθεσσι τετάσθην,{l]
[l [n}14.405{]}ἤτοι ὃ μὲν σάκεος, ὃ δὲ φασγάνου ἀργυροήλου·{l]
[l [n}14.406{]}τώ οἱ ῥυσάσθην τέρενα χρόα. χώσατο δʼ Ἕκτωρ,{l]
[l [n}14.407{]}ὅττί ῥά οἱ βέλος ὠκὺ ἐτώσιον ἔκφυγε χειρός,{l]
[l [n}14.408{]}ἂψ δʼ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων.{l]
[l [n}14.409{]}τὸν μὲν ἔπειτʼ ἀπιόντα μέγας Τελαμώνιος Αἴας{l]
[l [n}14.410{]}χερμαδίῳ, τά ῥα πολλὰ θοάων ἔχματα νηῶν{l]
[l [n}14.411{]}πὰρ ποσὶ μαρναμένων ἐκυλίνδετο, τῶν ἓν ἀείρας{l]
[l [n}14.412{]}στῆθος βεβλήκει ὑπὲρ ἄντυγος ἀγχόθι δειρῆς,{l]
[l [n}14.413{]}στρόμβον δʼ ὣς ἔσσευε βαλών, περὶ δʼ ἔδραμε πάντῃ.{l]
[l [n}14.414{]}ὡς δʼ ὅθʼ ὑπὸ πληγῆς πατρὸς Διὸς ἐξερίπῃ δρῦς{l]
[l [n}14.415{]}πρόρριζος, δεινὴ δὲ θεείου γίγνεται ὀδμὴ{l]
[l [n}14.416{]}ἐξ αὐτῆς, τὸν δʼ οὔ περ ἔχει θράσος ὅς κεν ἴδηται{l]
[l [n}14.417{]}ἐγγὺς ἐών, χαλεπὸς δὲ Διὸς μεγάλοιο κεραυνός,{l]
[l [n}14.418{]}ὣς ἔπεσʼ Ἕκτορος ὦκα χαμαὶ μένος ἐν κονίῃσι·{l]
[l [n}14.419{]}χειρὸς δʼ ἔκβαλεν ἔγχος, ἐπʼ αὐτῷ δʼ ἀσπὶς ἑάφθη{l]
[l [n}14.420{]}καὶ κόρυς, ἀμφὶ δέ οἱ βράχε τεύχεα ποικίλα χαλκῷ.{l]
[l [n}14.421{]}οἳ δὲ μέγα ἰάχοντες ἐπέδραμον υἷες Ἀχαιῶν{l]
[l [n}14.422{]}ἐλπόμενοι ἐρύεσθαι, ἀκόντιζον δὲ θαμειὰς{l]
[l [n}14.423{]}αἰχμάς· ἀλλʼ οὔ τις ἐδυνήσατο ποιμένα λαῶν{l]
[l [n}14.424{]}οὐτάσαι οὐδὲ βαλεῖν· πρὶν γὰρ περίβησαν ἄριστοι{l]
[l [n}14.425{]}Πουλυδάμας τε καὶ Αἰνείας καὶ δῖος Ἀγήνωρ{l]
[l [n}14.426{]}Σαρπηδών τʼ ἀρχὸς Λυκίων καὶ Γλαῦκος ἀμύμων.{l]
[l [n}14.427{]}τῶν δʼ ἄλλων οὔ τίς εὑ ἀκήδεσεν, ἀλλὰ πάροιθεν{l]
[l [n}14.428{]}ἀσπίδας εὐκύκλους σχέθον αὐτοῦ. τὸν δʼ ἄρʼ ἑταῖροι{l]
[l [n}14.429{]}χερσὶν ἀείραντες φέρον ἐκ πόνου, ὄφρʼ ἵκεθʼ ἵππους{l]
[l [n}14.430{]}ὠκέας, οἵ οἱ ὄπισθε μάχης ἠδὲ πτολέμοιο{l]
[l [n}14.431{]}ἕστασαν ἡνίοχόν τε καὶ ἅρματα ποικίλʼ ἔχοντες·{l]
[l [n}14.432{]}οἳ τόν γε προτὶ ἄστυ φέρον βαρέα στενάχοντα.{l]{para]
[para}[l [n}14.433{]}ἀλλʼ ὅτε δὴ πόρον ἷξον ἐϋρρεῖος ποταμοῖο{l]
[l [n}14.434{]}Ξάνθου δινήεντος, ὃν ἀθάνατος τέκετο Ζεύς,{l]
[l [n}14.435{]}ἔνθά μιν ἐξ ἵππων πέλασαν χθονί, κὰδ δέ οἱ ὕδωρ{l]
[l [n}14.436{]}χεῦαν· ὃ δʼ ἀμπνύνθη καὶ ἀνέδρακεν ὀφθαλμοῖσιν,{l]
[l [n}14.437{]}ἑζόμενος δʼ ἐπὶ γοῦνα κελαινεφὲς αἷμʼ ἀπέμεσσεν·{l]
[l [n}14.438{]}αὖτις δʼ ἐξοπίσω πλῆτο χθονί, τὼ δέ οἱ ὄσσε{l]
[l [n}14.439{]}νὺξ ἐκάλυψε μέλαινα· βέλος δʼ ἔτι θυμὸν ἐδάμνα.{l]{para]
[para}[l [n}14.440{]}Ἀργεῖοι δʼ ὡς οὖν ἴδον Ἕκτορα νόσφι κιόντα{l]
[l [n}14.441{]}μᾶλλον ἐπὶ Τρώεσσι θόρον, μνήσαντο δὲ χάρμης.{l]
[l [n}14.442{]}ἔνθα πολὺ πρώτιστος Ὀϊλῆος ταχὺς Αἴας{l]
[l [n}14.443{]}Σάτνιον οὔτασε δουρὶ μετάλμενος ὀξυόεντι{l]
[l [n}14.444{]}Ἠνοπίδην, ὃν ἄρα νύμφη τέκε νηῒς ἀμύμων{l]
[l [n}14.445{]}Ἤνοπι βουκολέοντι παρʼ ὄχθας Σατνιόεντος.{l]
[l [n}14.446{]}τὸν μὲν Ὀϊλιάδης δουρὶ κλυτὸς ἐγγύθεν ἐλθὼν{l]
[l [n}14.447{]}οὖτα κατὰ λαπάρην· ὃ δʼ ἀνετράπετʼ, ἀμφὶ δʼ ἄρʼ αὐτῷ{l]
[l [n}14.448{]}Τρῶες καὶ Δαναοὶ σύναγον κρατερὴν ὑσμίνην.{l]
[l [n}14.449{]}τῷ δʼ ἐπὶ Πουλυδάμας ἐγχέσπαλος ἦλθεν ἀμύντωρ{l]
[l [n}14.450{]}Πανθοΐδης, βάλε δὲ Προθοήνορα δεξιὸν ὦμον{l]
[l [n}14.451{]}υἱὸν Ἀρηϊλύκοιο, διʼ ὤμου δʼ ὄβριμον ἔγχος{l]
[l [n}14.452{]}ἔσχεν, ὃ δʼ ἐν κονίῃσι πεσὼν ἕλε γαῖαν ἀγοστῷ.{l]
[l [n}14.453{]}Πουλυδάμας δʼ ἔκπαγλον ἐπεύξατο μακρὸν ἀΰσας·{l]
[q}[l [n}14.454{]}οὐ μὰν αὖτʼ ὀΐω μεγαθύμου Πανθοΐδαο{l]
[l [n}14.455{]}χειρὸς ἄπο στιβαρῆς ἅλιον πηδῆσαι ἄκοντα,{l]
[l [n}14.456{]}ἀλλά τις Ἀργείων κόμισε χροΐ, καί μιν ὀΐω{l]
[l [n}14.457{]}αὐτῷ σκηπτόμενον κατίμεν δόμον Ἄϊδος εἴσω.{l]{q]{para]
[para}[l [n}14.458{]}ὣς ἔφατʼ, Ἀργείοισι δʼ ἄχος γένετʼ εὐξαμένοιο·{l]
[l [n}14.459{]}Αἴαντι δὲ μάλιστα δαΐφρονι θυμὸν ὄρινε{l]
[l [n}14.460{]}τῷ Τελαμωνιάδῃ· τοῦ γὰρ πέσεν ἄγχι μάλιστα.{l]
[l [n}14.461{]}καρπαλίμως δʼ ἀπιόντος ἀκόντισε δουρὶ φαεινῷ.{l]
[l [n}14.462{]}Πουλυδάμας δʼ αὐτὸς μὲν ἀλεύατο κῆρα μέλαιναν{l]
[l [n}14.463{]}λικριφὶς ἀΐξας, κόμισεν δʼ Ἀντήνορος υἱὸς{l]
[l [n}14.464{]}Ἀρχέλοχος· τῷ γάρ ῥα θεοὶ βούλευσαν ὄλεθρον.{l]
[l [n}14.465{]}τόν ῥʼ ἔβαλεν κεφαλῆς τε καὶ αὐχένος ἐν συνεοχμῷ,{l]
[l [n}14.466{]}νείατον ἀστράγαλον, ἀπὸ δʼ ἄμφω κέρσε τένοντε·{l]
[l [n}14.467{]}τοῦ δὲ πολὺ προτέρη κεφαλὴ στόμα τε ῥῖνές τε{l]
[l [n}14.468{]}οὔδεϊ πλῆντʼ ἤ περ κνῆμαι καὶ γοῦνα πεσόντος.{l]
[l [n}14.469{]}Αἴας δʼ αὖτʼ ἐγέγωνεν ἀμύμονι Πουλυδάμαντι·{l]
[q}[l [n}14.470{]}φράζεο Πουλυδάμα καί μοι νημερτὲς ἐνίσπες{l]
[l [n}14.471{]}ἦ ῥʼ οὐχ οὗτος ἀνὴρ Προθοήνορος ἀντὶ πεφάσθαι{l]
[l [n}14.472{]}ἄξιος; οὐ μέν μοι κακὸς εἴδεται οὐδὲ κακῶν ἔξ,{l]
[l [n}14.473{]}ἀλλὰ κασίγνητος Ἀντήνορος ἱπποδάμοιο{l]
[l [n}14.474{]}ἢ πάϊς· αὐτῷ γὰρ γενεὴν ἄγχιστα ἐῴκει.{l]{q]{para]
[para}[l [n}14.475{]}ἦ ῥʼ εὖ γιγνώσκων, Τρῶας δʼ ἄχος ἔλλαβε θυμόν.{l]
[l [n}14.476{]}ἔνθʼ Ἀκάμας Πρόμαχον Βοιώτιον οὔτασε δουρὶ{l]
[l [n}14.477{]}ἀμφὶ κασιγνήτῳ βεβαώς· ὃ δʼ ὕφελκε ποδοῖιν.{l]
[l [n}14.478{]}τῷ δʼ Ἀκάμας ἔκπαγλον ἐπεύξατο μακρὸν ἀΰσας·{l]
[q}[l [n}14.479{]}Ἀργεῖοι ἰόμωροι ἀπειλάων ἀκόρητοι{l]
[l [n}14.480{]}οὔ θην οἴοισίν γε πόνος τʼ ἔσεται καὶ ὀϊζὺς{l]
[l [n}14.481{]}ἡμῖν, ἀλλά ποθʼ ὧδε κατακτενέεσθε καὶ ὔμμες.{l]
[l [n}14.482{]}φράζεσθʼ ὡς ὑμῖν Πρόμαχος δεδμημένος εὕδει{l]
[l [n}14.483{]}ἔγχει ἐμῷ, ἵνα μή τι κασιγνήτοιό γε ποινὴ{l]
[l [n}14.484{]}δηρὸν ἄτιτος ἔῃ· τὼ καί κέ τις εὔχεται ἀνὴρ{l]
[l [n}14.485{]}γνωτὸν ἐνὶ μεγάροισιν ἀρῆς ἀλκτῆρα λιπέσθαι.{l]{q]{para]
[para}[l [n}14.486{]}ὣς ἔφατʼ, Ἀργείοισι δʼ ἄχος γένετʼ εὐξαμένοιο·{l]
[l [n}14.487{]}Πηνέλεῳ δὲ μάλιστα δαΐφρονι θυμὸν ὄρινεν·{l]
[l [n}14.488{]}ὁρμήθη δʼ Ἀκάμαντος· ὃ δʼ οὐχ ὑπέμεινεν ἐρωὴν{l]
[l [n}14.489{]}Πηνελέωο ἄνακτος· ὃ δʼ οὔτασεν Ἰλιονῆα{l]
[l [n}14.490{]}υἱὸν Φόρβαντος πολυμήλου, τόν ῥα μάλιστα{l]
[l [n}14.491{]}Ἑρμείας Τρώων ἐφίλει καὶ κτῆσιν ὄπασσε·{l]
[l [n}14.492{]}τῷ δʼ ἄρʼ ὑπὸ μήτηρ μοῦνον τέκεν Ἰλιονῆα.{l]
[l [n}14.493{]}τὸν τόθʼ ὑπʼ ὀφρύος οὖτα κατʼ ὀφθαλμοῖο θέμεθλα,{l]
[l [n}14.494{]}ἐκ δʼ ὦσε γλήνην· δόρυ δʼ ὀφθαλμοῖο διὰ πρὸ{l]
[l [n}14.495{]}καὶ διὰ ἰνίου ἦλθεν, ὃ δʼ ἕζετο χεῖρε πετάσσας{l]
[l [n}14.496{]}ἄμφω· Πηνέλεως δὲ ἐρυσσάμενος ξίφος ὀξὺ{l]
[l [n}14.497{]}αὐχένα μέσσον ἔλασσεν, ἀπήραξεν δὲ χαμᾶζε{l]
[l [n}14.498{]}αὐτῇ σὺν πήληκι κάρη· ἔτι δʼ ὄβριμον ἔγχος{l]
[l [n}14.499{]}ἦεν ἐν ὀφθαλμῷ· ὃ δὲ φὴ κώδειαν ἀνασχὼν{l]
[l [n}14.500{]}πέφραδέ τε Τρώεσσι καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}14.501{]}εἰπέμεναί μοι Τρῶες ἀγαυοῦ Ἰλιονῆος{l]
[l [n}14.502{]}πατρὶ φίλῳ καὶ μητρὶ γοήμεναι ἐν μεγάροισιν·{l]
[l [n}14.503{]}οὐδὲ γὰρ ἣ Προμάχοιο δάμαρ Ἀλεγηνορίδαο{l]
[l [n}14.504{]}ἀνδρὶ φίλῳ ἐλθόντι γανύσσεται, ὁππότε κεν δὴ{l]
[l [n}14.505{]}ἐκ Τροίης σὺν νηυσὶ νεώμεθα κοῦροι Ἀχαιῶν.{l]{q]{para]
[para}[l [n}14.506{]}ὣς φάτο, τοὺς δʼ ἄρα πάντας ὑπὸ τρόμος ἔλλαβε γυῖα,{l]
[l [n}14.507{]}πάπτηνεν δὲ ἕκαστος ὅπῃ φύγοι αἰπὺν ὄλεθρον.{l]{para]
[para}[l [n}14.508{]}ἔσπετε νῦν μοι Μοῦσαι Ὀλύμπια δώματʼ ἔχουσαι{l]
[l [n}14.509{]}ὅς τις δὴ πρῶτος βροτόεντʼ ἀνδράγριʼ Ἀχαιῶν{l]
[l [n}14.510{]}ἤρατʼ, ἐπεί ῥʼ ἔκλινε μάχην κλυτὸς ἐννοσίγαιος.{l]
[l [n}14.511{]}Αἴας ῥα πρῶτος Τελαμώνιος Ὕρτιον οὖτα{l]
[l [n}14.512{]}Γυρτιάδην Μυσῶν ἡγήτορα καρτεροθύμων·{l]
[l [n}14.513{]}Φάλκην δʼ Ἀντίλοχος καὶ Μέρμερον ἐξενάριξε·{l]
[l [n}14.514{]}Μηριόνης δὲ Μόρυν τε καὶ Ἱπποτίωνα κατέκτα,{l]
[l [n}14.515{]}Τεῦκρος δὲ Προθόωνά τʼ ἐνήρατο καὶ Περιφήτην·{l]
[l [n}14.516{]}Ἀτρεΐδης δʼ ἄρʼ ἔπειθʼ Ὑπερήνορα ποιμένα λαῶν{l]
[l [n}14.517{]}οὖτα κατὰ λαπάρην, διὰ δʼ ἔντερα χαλκὸς ἄφυσσε{l]
[l [n}14.518{]}δῃώσας· ψυχὴ δὲ κατʼ οὐταμένην ὠτειλὴν{l]
[l [n}14.519{]}ἔσσυτʼ ἐπειγομένη, τὸν δὲ σκότος ὄσσε κάλυψε.{l]
[l [n}14.520{]}πλείστους δʼ Αἴας εἷλεν Ὀϊλῆος ταχὺς υἱός·{l]
[l [n}14.521{]}οὐ γάρ οἵ τις ὁμοῖος ἐπισπέσθαι ποσὶν ἦεν{l]
[l [n}14.522{]}ἀνδρῶν τρεσσάντων, ὅτε τε Ζεὺς ἐν φόβον ὄρσῃ.{l]{para]
{book]
[book [n}15{]}
[para}[l [n}15.1{]}αὐτὰρ ἐπεὶ διά τε σκόλοπας καὶ τάφρον ἔβησαν{l]
[l [n}15.2{]}φεύγοντες, πολλοὶ δὲ δάμεν Δαναῶν ὑπὸ χερσίν,{l]
[l [n}15.3{]}οἳ μὲν δὴ παρʼ ὄχεσφιν ἐρητύοντο μένοντες{l]
[l [n}15.4{]}χλωροὶ ὑπαὶ δείους πεφοβημένοι· ἔγρετο δὲ Ζεὺς{l]
[l [n}15.5{]}Ἴδης ἐν κορυφῇσι παρὰ χρυσοθρόνου Ἥρης,{l]
[l [n}15.6{]}στῆ δʼ ἄρʼ ἀναΐξας, ἴδε δὲ Τρῶας καὶ Ἀχαιοὺς{l]
[l [n}15.7{]}τοὺς μὲν ὀρινομένους, τοὺς δὲ κλονέοντας ὄπισθεν{l]
[l [n}15.8{]}Ἀργείους, μετὰ δέ σφι Ποσειδάωνα ἄνακτα·{l]
[l [n}15.9{]}Ἕκτορα δʼ ἐν πεδίῳ ἴδε κείμενον, ἀμφὶ δʼ ἑταῖροι{l]
[l [n}15.10{]}εἵαθʼ, ὃ δʼ ἀργαλέῳ ἔχετʼ ἄσθματι κῆρ ἀπινύσσων{l]
[l [n}15.11{]}αἷμʼ ἐμέων, ἐπεὶ οὔ μιν ἀφαυρότατος βάλʼ Ἀχαιῶν.{l]
[l [n}15.12{]}τὸν δὲ ἰδὼν ἐλέησε πατὴρ ἀνδρῶν τε θεῶν τε,{l]
[l [n}15.13{]}δεινὰ δʼ ὑπόδρα ἰδὼν Ἥρην πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}15.14{]}ἦ μάλα δὴ κακότεχνος ἀμήχανε σὸς δόλος Ἥρη{l]
[l [n}15.15{]}Ἕκτορα δῖον ἔπαυσε μάχης, ἐφόβησε δὲ λαούς.{l]
[l [n}15.16{]}οὐ μὰν οἶδʼ εἰ αὖτε κακορραφίης ἀλεγεινῆς{l]
[l [n}15.17{]}πρώτη ἐπαύρηαι καί σε πληγῇσιν ἱμάσσω.{l]
[l [n}15.18{]}ἦ οὐ μέμνῃ ὅτε τʼ ἐκρέμω ὑψόθεν, ἐκ δὲ ποδοῖιν{l]
[l [n}15.19{]}ἄκμονας ἧκα δύω, περὶ χερσὶ δὲ δεσμὸν ἴηλα{l]
[l [n}15.20{]}χρύσεον ἄρρηκτον; σὺ δʼ ἐν αἰθέρι καὶ νεφέλῃσιν{l]
[l [n}15.21{]}ἐκρέμω· ἠλάστεον δὲ θεοὶ κατὰ μακρὸν Ὄλυμπον,{l]
[l [n}15.22{]}λῦσαι δʼ οὐκ ἐδύναντο παρασταδόν· ὃν δὲ λάβοιμι{l]
[l [n}15.23{]}ῥίπτασκον τεταγὼν ἀπὸ βηλοῦ ὄφρʼ ἂν ἵκηται{l]
[l [n}15.24{]}γῆν ὀλιγηπελέων· ἐμὲ δʼ οὐδʼ ὧς θυμὸν ἀνίει{l]
[l [n}15.25{]}ἀζηχὴς ὀδύνη Ἡρακλῆος θείοιο,{l]
[l [n}15.26{]}τὸν σὺ ξὺν Βορέῃ ἀνέμῳ πεπιθοῦσα θυέλλας{l]
[l [n}15.27{]}πέμψας ἐπʼ ἀτρύγετον πόντον κακὰ μητιόωσα,{l]
[l [n}15.28{]}καί μιν ἔπειτα Κόων δʼ εὖ ναιομένην ἀπένεικας.{l]
[l [n}15.29{]}τὸν μὲν ἐγὼν ἔνθεν ῥυσάμην καὶ ἀνήγαγον αὖτις{l]
[l [n}15.30{]}Ἄργος ἐς ἱππόβοτον καὶ πολλά περ ἀθλήσαντα.{l]
[l [n}15.31{]}τῶν σʼ αὖτις μνήσω ἵνʼ ἀπολλήξῃς ἀπατάων,{l]
[l [n}15.32{]}ὄφρα ἴδῃ ἤν τοι χραίσμῃ φιλότης τε καὶ εὐνή,{l]
[l [n}15.33{]}ἣν ἐμίγης ἐλθοῦσα θεῶν ἄπο καί μʼ ἀπάτησας.{l]{q]{para]
[para}[l [n}15.34{]}ὣς φάτο, ῥίγησεν δὲ βοῶπις πότνια Ἥρη,{l]
[l [n}15.35{]}καί μιν φωνήσασʼ ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}15.36{]}ἴστω νῦν τόδε Γαῖα καὶ Οὐρανὸς εὐρὺς ὕπερθε{l]
[l [n}15.37{]}καὶ τὸ κατειβόμενον Στυγὸς ὕδωρ, ὅς τε μέγιστος{l]
[l [n}15.38{]}ὅρκος δεινότατός τε πέλει μακάρεσσι θεοῖσι,{l]
[l [n}15.39{]}σή θʼ ἱερὴ κεφαλὴ καὶ νωΐτερον λέχος αὐτῶν{l]
[l [n}15.40{]}κουρίδιον, τὸ μὲν οὐκ ἂν ἐγώ ποτε μὰψ ὀμόσαιμι·{l]
[l [n}15.41{]}μὴ διʼ ἐμὴν ἰότητα Ποσειδάων ἐνοσίχθων{l]
[l [n}15.42{]}πημαίνει Τρῶάς τε καὶ Ἕκτορα, τοῖσι δʼ ἀρήγει,{l]
[l [n}15.43{]}ἀλλά που αὐτὸν θυμὸς ἐποτρύνει καὶ ἀνώγει,{l]
[l [n}15.44{]}τειρομένους δʼ ἐπὶ νηυσὶν ἰδὼν ἐλέησεν Ἀχαιούς.{l]
[l [n}15.45{]}αὐτάρ τοι καὶ κείνῳ ἐγὼ παραμυθησαίμην{l]
[l [n}15.46{]}τῇ ἴμεν ᾗ κεν δὴ σὺ κελαινεφὲς ἡγεμονεύῃς.{l]{q]{para]
[para}[l [n}15.47{]}ὣς φάτο, μείδησεν δὲ πατὴρ ἀνδρῶν τε θεῶν τε,{l]
[l [n}15.48{]}καί μιν ἀμειβόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}15.49{]}εἰ μὲν δὴ σύ γʼ ἔπειτα βοῶπις πότνια Ἥρη{l]
[l [n}15.50{]}ἶσον ἐμοὶ φρονέουσα μετʼ ἀθανάτοισι καθίζοις,{l]
[l [n}15.51{]}τώ κε Ποσειδάων γε, καὶ εἰ μάλα βούλεται ἄλλῃ,{l]
[l [n}15.52{]}αἶψα μεταστρέψειε νόον μετὰ σὸν καὶ ἐμὸν κῆρ.{l]
[l [n}15.53{]}ἀλλʼ εἰ δή ῥʼ ἐτεόν γε καὶ ἀτρεκέως ἀγορεύεις,{l]
[l [n}15.54{]}ἔρχεο νῦν μετὰ φῦλα θεῶν, καὶ δεῦρο κάλεσσον{l]
[l [n}15.55{]}Ἶρίν τʼ ἐλθέμεναι καὶ Ἀπόλλωνα κλυτότοξον,{l]
[l [n}15.56{]}ὄφρʼ ἣ μὲν μετὰ λαὸν Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}15.57{]}ἔλθῃ, καὶ εἴπῃσι Ποσειδάωνι ἄνακτι{l]
[l [n}15.58{]}παυσάμενον πολέμοιο τὰ ἃ πρὸς δώμαθʼ ἱκέσθαι,{l]
[l [n}15.59{]}Ἕκτορα δʼ ὀτρύνῃσι μάχην ἐς Φοῖβος Ἀπόλλων,{l]
[l [n}15.60{]}αὖτις δʼ ἐμπνεύσῃσι μένος, λελάθῃ δʼ ὀδυνάων{l]
[l [n}15.61{]}αἳ νῦν μιν τείρουσι κατὰ φρένας, αὐτὰρ Ἀχαιοὺς{l]
[l [n}15.62{]}αὖτις ἀποστρέψῃσιν ἀνάλκιδα φύζαν ἐνόρσας,{l]
[l [n}15.63{]}φεύγοντες δʼ ἐν νηυσὶ πολυκλήϊσι πέσωσι{l]
[l [n}15.64{]}Πηλεΐδεω Ἀχιλῆος· ὃ δʼ ἀνστήσει ὃν ἑταῖρον{l]
[l [n}15.65{]}Πάτροκλον· τὸν δὲ κτενεῖ ἔγχεϊ φαίδιμος Ἕκτωρ{l]
[l [n}15.66{]}Ἰλίου προπάροιθε πολέας ὀλέσαντʼ αἰζηοὺς{l]
[l [n}15.67{]}τοὺς ἄλλους, μετὰ δʼ υἱὸν ἐμὸν Σαρπηδόνα δῖον.{l]
[l [n}15.68{]}τοῦ δὲ χολωσάμενος κτενεῖ Ἕκτορα δῖος Ἀχιλλεύς.{l]
[l [n}15.69{]}ἐκ τοῦ δʼ ἄν τοι ἔπειτα παλίωξιν παρὰ νηῶν{l]
[l [n}15.70{]}αἰὲν ἐγὼ τεύχοιμι διαμπερὲς εἰς ὅ κʼ Ἀχαιοὶ{l]
[l [n}15.71{]}Ἴλιον αἰπὺ ἕλοιεν Ἀθηναίης διὰ βουλάς.{l]
[l [n}15.72{]}τὸ πρὶν δʼ οὔτʼ ἄρʼ ἐγὼ παύω χόλον οὔτέ τινʼ ἄλλον{l]
[l [n}15.73{]}ἀθανάτων Δαναοῖσιν ἀμυνέμεν ἐνθάδʼ ἐάσω{l]
[l [n}15.74{]}πρίν γε τὸ Πηλεΐδαο τελευτηθῆναι ἐέλδωρ,{l]
[l [n}15.75{]}ὥς οἱ ὑπέστην πρῶτον, ἐμῷ δʼ ἐπένευσα κάρητι,{l]
[l [n}15.76{]}ἤματι τῷ ὅτʼ ἐμεῖο θεὰ Θέτις ἥψατο γούνων,{l]
[l [n}15.77{]}λισσομένη τιμῆσαι Ἀχιλλῆα πτολίπορθον.{l]{q]{para]
[para}[l [n}15.78{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ λευκώλενος Ἥρη,{l]
[l [n}15.79{]}βῆ δʼ ἐξ Ἰδαίων ὀρέων ἐς μακρὸν Ὄλυμπον.{l]
[l [n}15.80{]}ὡς δʼ ὅτʼ ἂν ἀΐξῃ νόος ἀνέρος, ὅς τʼ ἐπὶ πολλὴν{l]
[l [n}15.81{]}γαῖαν ἐληλουθὼς φρεσὶ πευκαλίμῃσι νοήσῃ{l]
[l [n}15.82{]}
                  
[q}ἔνθʼ εἴην ἢ ἔνθα,{q] μενοινήῃσί τε πολλά,{l]
[l [n}15.83{]}ὣς κραιπνῶς μεμαυῖα διέπτατο πότνια Ἥρη·{l]
[l [n}15.84{]}ἵκετο δʼ αἰπὺν Ὄλυμπον, ὁμηγερέεσσι δʼ ἐπῆλθεν{l]
[l [n}15.85{]}ἀθανάτοισι θεοῖσι Διὸς δόμῳ· οἳ δὲ ἰδόντες{l]
[l [n}15.86{]}πάντες ἀνήϊξαν καὶ δεικανόωντο δέπασσιν.{l]
[l [n}15.87{]}ἣ δʼ ἄλλους μὲν ἔασε, Θέμιστι δὲ καλλιπαρῄῳ{l]
[l [n}15.88{]}δέκτο δέπας· πρώτη γὰρ ἐναντίη ἦλθε θέουσα,{l]
[l [n}15.89{]}καί μιν φωνήσασʼ ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}15.90{]}Ἥρη τίπτε βέβηκας; ἀτυζομένῃ δὲ ἔοικας·{l]
[l [n}15.91{]}ἦ μάλα δή σʼ ἐφόβησε Κρόνου πάϊς, ὅς τοι ἀκοίτης.{l]{q]{para]
[para}[l [n}15.92{]}τὴν δʼ ἠμείβετʼ ἔπειτα θεὰ λευκώλενος Ἥρη·{l]
[q}[l [n}15.93{]}μή με θεὰ Θέμι ταῦτα διείρεο· οἶσθα καὶ αὐτὴ{l]
[l [n}15.94{]}οἷος κείνου θυμὸς ὑπερφίαλος καὶ ἀπηνής.{l]
[l [n}15.95{]}ἀλλὰ σύ γʼ ἄρχε θεοῖσι δόμοις ἔνι δαιτὸς ἐΐσης·{l]
[l [n}15.96{]}ταῦτα δὲ καὶ μετὰ πᾶσιν ἀκούσεαι ἀθανάτοισιν{l]
[l [n}15.97{]}οἷα Ζεὺς κακὰ ἔργα πιφαύσκεται· οὐδέ τί φημι{l]
[l [n}15.98{]}πᾶσιν ὁμῶς θυμὸν κεχαρησέμεν, οὔτε βροτοῖσιν{l]
[l [n}15.99{]}οὔτε θεοῖς, εἴ πέρ τις ἔτι νῦν δαίνυται εὔφρων.{l]{q]{para]
[para}[l [n}15.100{]}ἣ μὲν ἄρʼ ὣς εἰποῦσα καθέζετο πότνια Ἥρη,{l]
[l [n}15.101{]}ὄχθησαν δʼ ἀνὰ δῶμα Διὸς θεοί· ἣ δʼ ἐγέλασσε{l]
[l [n}15.102{]}χείλεσιν, οὐδὲ μέτωπον ἐπʼ ὀφρύσι κυανέῃσιν{l]
[l [n}15.103{]}ἰάνθη· πᾶσιν δὲ νεμεσσηθεῖσα μετηύδα·{l]
[q}[l [n}15.104{]}νήπιοι οἳ Ζηνὶ μενεαίνομεν ἀφρονέοντες·{l]
[l [n}15.105{]}ἦ ἔτι μιν μέμαμεν καταπαυσέμεν ἆσσον ἰόντες{l]
[l [n}15.106{]}ἢ ἔπει ἠὲ βίῃ· ὃ δʼ ἀφήμενος οὐκ ἀλεγίζει{l]
[l [n}15.107{]}οὐδʼ ὄθεται· φησὶν γὰρ ἐν ἀθανάτοισι θεοῖσι{l]
[l [n}15.108{]}κάρτεΐ τε σθένεΐ τε διακριδὸν εἶναι ἄριστος.{l]
[l [n}15.109{]}τὼ ἔχεθʼ ὅττί κεν ὔμμι κακὸν πέμπῃσιν ἑκάστῳ.{l]
[l [n}15.110{]}ἤδη γὰρ νῦν ἔλπομʼ Ἄρηΐ γε πῆμα τετύχθαι·{l]
[l [n}15.111{]}υἱὸς γάρ οἱ ὄλωλε μάχῃ ἔνι φίλτατος ἀνδρῶν{l]
[l [n}15.112{]}Ἀσκάλαφος, τόν φησιν ὃν ἔμμεναι ὄβριμος Ἄρης.{l]{q]{para]
[para}[l [n}15.113{]}ὣς ἔφατʼ, αὐτὰρ Ἄρης θαλερὼ πεπλήγετο μηρὼ{l]
[l [n}15.114{]}χερσὶ καταπρηνέσσʼ, ὀλοφυρόμενος δʼ ἔπος ηὔδα·{l]
[q}[l [n}15.115{]}μὴ νῦν μοι νεμεσήσετʼ Ὀλύμπια δώματʼ ἔχοντες{l]
[l [n}15.116{]}τίσασθαι φόνον υἷος ἰόντʼ ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}15.117{]}εἴ πέρ μοι καὶ μοῖρα Διὸς πληγέντι κεραυνῷ{l]
[l [n}15.118{]}κεῖσθαι ὁμοῦ νεκύεσσι μεθʼ αἵματι καὶ κονίῃσιν.{l]{q]{para]
[para}[l [n}15.119{]}ὣς φάτο, καί ῥʼ ἵππους κέλετο Δεῖμόν τε Φόβον τε{l]
[l [n}15.120{]}ζευγνύμεν, αὐτὸς δʼ ἔντεʼ ἐδύσετο παμφανόωντα.{l]
[l [n}15.121{]}ἔνθά κʼ ἔτι μείζων τε καὶ ἀργαλεώτερος ἄλλος{l]
[l [n}15.122{]}πὰρ Διὸς ἀθανάτοισι χόλος καὶ μῆνις ἐτύχθη,{l]
[l [n}15.123{]}εἰ μὴ Ἀθήνη πᾶσι περιδείσασα θεοῖσιν{l]
[l [n}15.124{]}ὦρτο διὲκ προθύρου, λίπε δὲ θρόνον ἔνθα θάασσε,{l]
[l [n}15.125{]}τοῦ δʼ ἀπὸ μὲν κεφαλῆς κόρυθʼ εἵλετο καὶ σάκος ὤμων,{l]
[l [n}15.126{]}ἔγχος δʼ ἔστησε στιβαρῆς ἀπὸ χειρὸς ἑλοῦσα{l]
[l [n}15.127{]}χάλκεον· ἣ δʼ ἐπέεσσι καθάπτετο θοῦρον Ἄρηα·{l]
[q}[l [n}15.128{]}μαινόμενε φρένας ἠλὲ διέφθορας· ἦ νύ τοι αὔτως{l]
[l [n}15.129{]}οὔατʼ ἀκουέμεν ἐστί, νόος δʼ ἀπόλωλε καὶ αἰδώς.{l]
[l [n}15.130{]}οὐκ ἀΐεις ἅ τέ φησι θεὰ λευκώλενος Ἥρη{l]
[l [n}15.131{]}ἣ δὴ νῦν πὰρ Ζηνὸς Ὀλυμπίου εἰλήλουθεν;{l]
[l [n}15.132{]}ἦ ἐθέλεις αὐτὸς μὲν ἀναπλήσας κακὰ πολλὰ{l]
[l [n}15.133{]}ἂψ ἴμεν Οὔλυμπον δὲ καὶ ἀχνύμενός περ ἀνάγκῃ,{l]
[l [n}15.134{]}αὐτὰρ τοῖς ἄλλοισι κακὸν μέγα πᾶσι φυτεῦσαι;{l]
[l [n}15.135{]}αὐτίκα γὰρ Τρῶας μὲν ὑπερθύμους καὶ Ἀχαιοὺς{l]
[l [n}15.136{]}λείψει, ὃ δʼ ἡμέας εἶσι κυδοιμήσων ἐς Ὄλυμπον,{l]
[l [n}15.137{]}μάρψει δʼ ἑξείης ὅς τʼ αἴτιος ὅς τε καὶ οὐκί.{l]
[l [n}15.138{]}τώ σʼ αὖ νῦν κέλομαι μεθέμεν χόλον υἷος ἑῆος·{l]
[l [n}15.139{]}ἤδη γάρ τις τοῦ γε βίην καὶ χεῖρας ἀμείνων{l]
[l [n}15.140{]}ἢ πέφατʼ, ἢ καὶ ἔπειτα πεφήσεται· ἀργαλέον δὲ{l]
[l [n}15.141{]}πάντων ἀνθρώπων ῥῦσθαι γενεήν τε τόκον τε.{l]{q]{para]
[para}[l [n}15.142{]}ὣς εἰποῦσʼ ἵδρυσε θρόνῳ ἔνι θοῦρον Ἄρηα.{l]
[l [n}15.143{]}Ἥρη δʼ Ἀπόλλωνα καλέσσατο δώματος ἐκτὸς{l]
[l [n}15.144{]}Ἶρίν θʼ, ἥ τε θεοῖσι μετάγγελος ἀθανάτοισι,{l]
[l [n}15.145{]}καί σφεας φωνήσασʼ ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}15.146{]}Ζεὺς σφὼ εἰς Ἴδην κέλετʼ ἐλθέμεν ὅττι τάχιστα·{l]
[l [n}15.147{]}αὐτὰρ ἐπὴν ἔλθητε, Διός τʼ εἰς ὦπα ἴδησθε,{l]
[l [n}15.148{]}ἕρδειν ὅττί κε κεῖνος ἐποτρύνῃ καὶ ἀνώγῃ.{l]{q]{para]
[para}[l [n}15.149{]}ἣ μὲν ἄρʼ ὣς εἰποῦσα πάλιν κίε πότνια Ἥρη,{l]
[l [n}15.150{]}ἕζετο δʼ εἰνὶ θρόνῳ· τὼ δʼ ἀΐξαντε πετέσθην.{l]
[l [n}15.151{]}Ἴδην δʼ ἵκανον πολυπίδακα μητέρα θηρῶν,{l]
[l [n}15.152{]}εὗρον δʼ εὐρύοπα Κρονίδην ἀνὰ Γαργάρῳ ἄκρῳ{l]
[l [n}15.153{]}ἥμενον· ἀμφὶ δέ μιν θυόεν νέφος ἐστεφάνωτο.{l]
[l [n}15.154{]}τὼ δὲ πάροιθʼ ἐλθόντε Διὸς νεφεληγερέταο{l]
[l [n}15.155{]}στήτην· οὐδέ σφωϊν ἰδὼν ἐχολώσατο θυμῷ,{l]
[l [n}15.156{]}ὅττί οἱ ὦκʼ ἐπέεσσι φίλης ἀλόχοιο πιθέσθην.{l]
[l [n}15.157{]}Ἶριν δὲ προτέρην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}15.158{]}βάσκʼ ἴθι Ἶρι ταχεῖα, Ποσειδάωνι ἄνακτι{l]
[l [n}15.159{]}πάντα τάδʼ ἀγγεῖλαι, μὴ δὲ ψευδάγγελος εἶναι.{l]
[l [n}15.160{]}παυσάμενόν μιν ἄνωχθι μάχης ἠδὲ πτολέμοιο{l]
[l [n}15.161{]}ἔρχεσθαι μετὰ φῦλα θεῶν ἢ εἰς ἅλα δῖαν.{l]
[l [n}15.162{]}εἰ δέ μοι οὐκ ἐπέεσσʼ ἐπιπείσεται, ἀλλʼ ἀλογήσει,{l]
[l [n}15.163{]}φραζέσθω δὴ ἔπειτα κατὰ φρένα καὶ κατὰ θυμὸν{l]
[l [n}15.164{]}μή μʼ οὐδὲ κρατερός περ ἐὼν ἐπιόντα ταλάσσῃ{l]
[l [n}15.165{]}μεῖναι, ἐπεί εὑ φημὶ βίῃ πολὺ φέρτερος εἶναι{l]
[l [n}15.166{]}καὶ γενεῇ πρότερος· τοῦ δʼ οὐκ ὄθεται φίλον ἦτορ{l]
[l [n}15.167{]}ἶσον ἐμοὶ φάσθαι, τόν τε στυγέουσι καὶ ἄλλοι.{l]{q]{para]
[para}[l [n}15.168{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε ποδήνεμος ὠκέα Ἶρις,{l]
[l [n}15.169{]}βῆ δὲ κατʼ Ἰδαίων ὀρέων εἰς Ἴλιον ἱρήν.{l]
[l [n}15.170{]}ὡς δʼ ὅτʼ ἂν ἐκ νεφέων πτῆται νιφὰς ἠὲ χάλαζα{l]
[l [n}15.171{]}ψυχρὴ ὑπὸ ῥιπῆς αἰθρηγενέος Βορέαο,{l]
[l [n}15.172{]}ὣς κραιπνῶς μεμαυῖα διέπτατο ὠκέα Ἶρις,{l]
[l [n}15.173{]}ἀγχοῦ δʼ ἱσταμένη προσέφη κλυτὸν ἐννοσίγαιον·{l]
[q}[l [n}15.174{]}ἀγγελίην τινά τοι γαιήοχε κυανοχαῖτα{l]
[l [n}15.175{]}ἦλθον δεῦρο φέρουσα παραὶ Διὸς αἰγιόχοιο.{l]
[l [n}15.176{]}παυσάμενόν σʼ ἐκέλευσε μάχης ἠδὲ πτολέμοιο{l]
[l [n}15.177{]}ἔρχεσθαι μετὰ φῦλα θεῶν ἢ εἰς ἅλα δῖαν.{l]
[l [n}15.178{]}εἰ δέ οἱ οὐκ ἐπέεσσʼ ἐπιπείσεαι, ἀλλʼ ἀλογήσεις,{l]
[l [n}15.179{]}ἠπείλει καὶ κεῖνος ἐναντίβιον πολεμίξων{l]
[l [n}15.180{]}ἐνθάδʼ ἐλεύσεσθαι· σὲ δʼ ὑπεξαλέασθαι ἄνωγε{l]
[l [n}15.181{]}χεῖρας, ἐπεὶ σέο φησὶ βίῃ πολὺ φέρτερος εἶναι{l]
[l [n}15.182{]}καὶ γενεῇ πρότερος· σὸν δʼ οὐκ ὄθεται φίλον ἦτορ{l]
[l [n}15.183{]}ἶσόν οἱ φάσθαι, τόν τε στυγέουσι καὶ ἄλλοι.{l]{q]{para]
[para}[l [n}15.184{]}τὴν δὲ μέγʼ ὀχθήσας προσέφη κλυτὸς ἐννοσίγαιος·{l]
[q}[l [n}15.185{]}ὢ πόποι ἦ ῥʼ ἀγαθός περ ἐὼν ὑπέροπλον ἔειπεν{l]
[l [n}15.186{]}εἴ μʼ ὁμότιμον ἐόντα βίῃ ἀέκοντα καθέξει.{l]
[l [n}15.187{]}τρεῖς γάρ τʼ ἐκ Κρόνου εἰμὲν ἀδελφεοὶ οὓς τέκετο Ῥέα{l]
[l [n}15.188{]}Ζεὺς καὶ ἐγώ, τρίτατος δʼ Ἀΐδης ἐνέροισιν ἀνάσσων.{l]
[l [n}15.189{]}τριχθὰ δὲ πάντα δέδασται, ἕκαστος δʼ ἔμμορε τιμῆς·{l]
[l [n}15.190{]}ἤτοι ἐγὼν ἔλαχον πολιὴν ἅλα ναιέμεν αἰεὶ{l]
[l [n}15.191{]}παλλομένων, Ἀΐδης δʼ ἔλαχε ζόφον ἠερόεντα,{l]
[l [n}15.192{]}Ζεὺς δʼ ἔλαχʼ οὐρανὸν εὐρὺν ἐν αἰθέρι καὶ νεφέλῃσι·{l]
[l [n}15.193{]}γαῖα δʼ ἔτι ξυνὴ πάντων καὶ μακρὸς Ὄλυμπος.{l]
[l [n}15.194{]}τώ ῥα καὶ οὔ τι Διὸς βέομαι φρεσίν, ἀλλὰ ἕκηλος{l]
[l [n}15.195{]}καὶ κρατερός περ ἐὼν μενέτω τριτάτῃ ἐνὶ μοίρῃ.{l]
[l [n}15.196{]}χερσὶ δὲ μή τί με πάγχυ κακὸν ὣς δειδισσέσθω·{l]
[l [n}15.197{]}θυγατέρεσσιν γάρ τε καὶ υἱάσι βέλτερον εἴη{l]
[l [n}15.198{]}ἐκπάγλοις ἐπέεσσιν ἐνισσέμεν οὓς τέκεν αὐτός,{l]
[l [n}15.199{]}οἵ ἑθεν ὀτρύνοντος ἀκούσονται καὶ ἀνάγκῃ.{l]{q]{para]
[para}[l [n}15.200{]}τὸν δʼ ἠμείβετʼ ἔπειτα ποδήνεμος ὠκέα Ἶρις·{l]
[q}[l [n}15.201{]}οὕτω γὰρ δή τοι γαιήοχε κυανοχαῖτα{l]
[l [n}15.202{]}τόνδε φέρω Διὶ μῦθον ἀπηνέα τε κρατερόν τε,{l]
[l [n}15.203{]}ἦ τι μεταστρέψεις; στρεπταὶ μέν τε φρένες ἐσθλῶν.{l]
[l [n}15.204{]}οἶσθʼ ὡς πρεσβυτέροισιν Ἐρινύες αἰὲν ἕπονται.{l]{q]{para]
[para}[l [n}15.205{]}τὴν δʼ αὖτε προσέειπε Ποσειδάων ἐνοσίχθων·{l]
[q}[l [n}15.206{]}Ἶρι θεὰ μάλα τοῦτο ἔπος κατὰ μοῖραν ἔειπες·{l]
[l [n}15.207{]}ἐσθλὸν καὶ τὸ τέτυκται ὅτʼ ἄγγελος αἴσιμα εἰδῇ.{l]
[l [n}15.208{]}ἀλλὰ τόδʼ αἰνὸν ἄχος κραδίην καὶ θυμὸν ἱκάνει{l]
[l [n}15.209{]}ὁππότʼ ἂν ἰσόμορον καὶ ὁμῇ πεπρωμένον αἴσῃ{l]
[l [n}15.210{]}νεικείειν ἐθέλῃσι χολωτοῖσιν ἐπέεσσιν.{l]
[l [n}15.211{]}ἀλλʼ ἤτοι νῦν μέν κε νεμεσσηθεὶς ὑποείξω·{l]
[l [n}15.212{]}ἄλλο δέ τοι ἐρέω, καὶ ἀπειλήσω τό γε θυμῷ·{l]
[l [n}15.213{]}αἴ κεν ἄνευ ἐμέθεν καὶ Ἀθηναίης ἀγελείης{l]
[l [n}15.214{]}Ἥρης Ἑρμείω τε καὶ Ἡφαίστοιο ἄνακτος{l]
[l [n}15.215{]}Ἰλίου αἰπεινῆς πεφιδήσεται, οὐδʼ ἐθελήσει{l]
[l [n}15.216{]}ἐκπέρσαι, δοῦναι δὲ μέγα κράτος Ἀργείοισιν,{l]
[l [n}15.217{]}ἴστω τοῦθʼ ὅτι νῶϊν ἀνήκεστος χόλος ἔσται.{l]{q]{para]
[para}[l [n}15.218{]}ὣς εἰπὼν λίπε λαὸν Ἀχαιϊκὸν ἐννοσίγαιος,{l]
[l [n}15.219{]}δῦνε δὲ πόντον ἰών, πόθεσαν δʼ ἥρωες Ἀχαιοί.{l]{para]
[para}[l [n}15.220{]}καὶ τότʼ Ἀπόλλωνα προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}15.221{]}ἔρχεο νῦν φίλε Φοῖβε μεθʼ Ἕκτορα χαλκοκορυστήν·{l]
[l [n}15.222{]}ἤδη μὲν γάρ τοι γαιήοχος ἐννοσίγαιος{l]
[l [n}15.223{]}οἴχεται εἰς ἅλα δῖαν ἀλευάμενος χόλον αἰπὺν{l]
[l [n}15.224{]}ἡμέτερον· μάλα γάρ κε μάχης ἐπύθοντο καὶ ἄλλοι,{l]
[l [n}15.225{]}οἵ περ ἐνέρτεροί εἰσι θεοὶ Κρόνον ἀμφὶς ἐόντες.{l]
[l [n}15.226{]}ἀλλὰ τόδʼ ἠμὲν ἐμοὶ πολὺ κέρδιον ἠδέ οἱ αὐτῷ{l]
[l [n}15.227{]}ἔπλετο, ὅττι πάροιθε νεμεσσηθεὶς ὑπόειξε{l]
[l [n}15.228{]}χεῖρας ἐμάς, ἐπεὶ οὔ κεν ἀνιδρωτί γʼ ἐτελέσθη.{l]
[l [n}15.229{]}ἀλλὰ σύ γʼ ἐν χείρεσσι λάβʼ αἰγίδα θυσσανόεσσαν,{l]
[l [n}15.230{]}τῇ μάλʼ ἐπισσείων φοβέειν ἥρωας Ἀχαιούς·{l]
[l [n}15.231{]}σοὶ δʼ αὐτῷ μελέτω ἑκατηβόλε φαίδιμος Ἕκτωρ·{l]
[l [n}15.232{]}τόφρα γὰρ οὖν οἱ ἔγειρε μένος μέγα, ὄφρʼ ἂν Ἀχαιοὶ{l]
[l [n}15.233{]}φεύγοντες νῆάς τε καὶ Ἑλλήσποντον ἵκωνται.{l]
[l [n}15.234{]}κεῖθεν δʼ αὐτὸς ἐγὼ φράσομαι ἔργον τε ἔπος τε,{l]
[l [n}15.235{]}ὥς κε καὶ αὖτις Ἀχαιοὶ ἀναπνεύσωσι πόνοιο.{l]{q]{para]
[para}[l [n}15.236{]}ὣς ἔφατʼ, οὐδʼ ἄρα πατρὸς ἀνηκούστησεν Ἀπόλλων,{l]
[l [n}15.237{]}βῆ δὲ κατʼ Ἰδαίων ὀρέων ἴρηκι ἐοικὼς{l]
[l [n}15.238{]}ὠκέϊ φασσοφόνῳ, ὅς τʼ ὤκιστος πετεηνῶν.{l]
[l [n}15.239{]}εὗρʼ υἱὸν Πριάμοιο δαΐφρονος Ἕκτορα δῖον{l]
[l [n}15.240{]}ἥμενον, οὐδʼ ἔτι κεῖτο, νέον δʼ ἐσαγείρετο θυμόν,{l]
[l [n}15.241{]}ἀμφὶ ἓ γιγνώσκων ἑτάρους· ἀτὰρ ἆσθμα καὶ ἱδρὼς{l]
[l [n}15.242{]}παύετʼ, ἐπεί μιν ἔγειρε Διὸς νόος αἰγιόχοιο.{l]
[l [n}15.243{]}ἀγχοῦ δʼ ἱστάμενος προσέφη ἑκάεργος Ἀπόλλων·{l]
[q}[l [n}15.244{]}Ἕκτορ υἱὲ Πριάμοιο, τί ἢ δὲ σὺ νόσφιν ἀπʼ ἄλλων{l]
[l [n}15.245{]}ἧσʼ ὀλιγηπελέων; ἦ πού τί σε κῆδος ἱκάνει;{l]{q]{para]
[para}[l [n}15.246{]}τὸν δʼ ὀλιγοδρανέων προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}15.247{]}τίς δὲ σύ ἐσσι φέριστε θεῶν ὅς μʼ εἴρεαι ἄντην;{l]
[l [n}15.248{]}οὐκ ἀΐεις ὅ με νηυσὶν ἔπι πρυμνῇσιν Ἀχαιῶν{l]
[l [n}15.249{]}οὓς ἑτάρους ὀλέκοντα βοὴν ἀγαθὸς βάλεν Αἴας{l]
[l [n}15.250{]}χερμαδίῳ πρὸς στῆθος, ἔπαυσε δὲ θούριδος ἀλκῆς;{l]
[l [n}15.251{]}καὶ δὴ ἔγωγʼ ἐφάμην νέκυας καὶ δῶμʼ Ἀΐδαο{l]
[l [n}15.252{]}ἤματι τῷδʼ ἵξεσθαι, ἐπεὶ φίλον ἄϊον ἦτορ.{l]{q]{para]
[para}[l [n}15.253{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἑκάεργος Ἀπόλλων·{l]
[q}[l [n}15.254{]}θάρσει νῦν· τοῖόν τοι ἀοσσητῆρα Κρονίων{l]
[l [n}15.255{]}ἐξ Ἴδης προέηκε παρεστάμεναι καὶ ἀμύνειν{l]
[l [n}15.256{]}Φοῖβον Ἀπόλλωνα χρυσάορον, ὅς σε πάρος περ{l]
[l [n}15.257{]}ῥύομʼ, ὁμῶς αὐτόν τε καὶ αἰπεινὸν πτολίεθρον.{l]
[l [n}15.258{]}ἀλλʼ ἄγε νῦν ἱππεῦσιν ἐπότρυνον πολέεσσι{l]
[l [n}15.259{]}νηυσὶν ἔπι γλαφυρῇσιν ἐλαυνέμεν ὠκέας ἵππους·{l]
[l [n}15.260{]}αὐτὰρ ἐγὼ προπάροιθε κιὼν ἵπποισι κέλευθον{l]
[l [n}15.261{]}πᾶσαν λειανέω, τρέψω δʼ ἥρωας Ἀχαιούς.{l]{q]{para]
[para}[l [n}15.262{]}ὣς εἰπὼν ἔμπνευσε μένος μέγα ποιμένι λαῶν.{l]
[l [n}15.263{]}ὡς δʼ ὅτε τις στατὸς ἵππος ἀκοστήσας ἐπὶ φάτνῃ{l]
[l [n}15.264{]}δεσμὸν ἀπορρήξας θείῃ πεδίοιο κροαίνων{l]
[l [n}15.265{]}εἰωθὼς λούεσθαι ἐϋρρεῖος ποταμοῖο{l]
[l [n}15.266{]}κυδιόων· ὑψοῦ δὲ κάρη ἔχει, ἀμφὶ δὲ χαῖται{l]
[l [n}15.267{]}ὤμοις ἀΐσσονται· ὃ δʼ ἀγλαΐηφι πεποιθὼς{l]
[l [n}15.268{]}ῥίμφά ἑ γοῦνα φέρει μετά τʼ ἤθεα καὶ νομὸν ἵππων·{l]
[l [n}15.269{]}ὣς Ἕκτωρ λαιψηρὰ πόδας καὶ γούνατʼ ἐνώμα{l]
[l [n}15.270{]}ὀτρύνων ἱππῆας, ἐπεὶ θεοῦ ἔκλυεν αὐδήν.{l]
[l [n}15.271{]}οἳ δʼ ὥς τʼ ἢ ἔλαφον κεραὸν ἢ ἄγριον αἶγα{l]
[l [n}15.272{]}ἐσσεύαντο κύνες τε καὶ ἀνέρες ἀγροιῶται·{l]
[l [n}15.273{]}τὸν μέν τʼ ἠλίβατος πέτρη καὶ δάσκιος ὕλη{l]
[l [n}15.274{]}εἰρύσατʼ, οὐδʼ ἄρα τέ σφι κιχήμεναι αἴσιμον ἦεν·{l]
[l [n}15.275{]}τῶν δέ θʼ ὑπὸ ἰαχῆς ἐφάνη λὶς ἠϋγένειος{l]
[l [n}15.276{]}εἰς ὁδόν, αἶψα δὲ πάντας ἀπέτραπε καὶ μεμαῶτας·{l]
[l [n}15.277{]}ὣς Δαναοὶ εἷος μὲν ὁμιλαδὸν αἰὲν ἕποντο{l]
[l [n}15.278{]}νύσσοντες ξίφεσίν τε καὶ ἔγχεσιν ἀμφιγύοισιν·{l]
[l [n}15.279{]}αὐτὰρ ἐπεὶ ἴδον Ἕκτορʼ ἐποιχόμενον στίχας ἀνδρῶν{l]
[l [n}15.280{]}τάρβησαν, πᾶσιν δὲ παραὶ ποσὶ κάππεσε θυμός.{l]{para]
[para}[l [n}15.281{]}τοῖσι δʼ ἔπειτʼ ἀγόρευε Θόας Ἀνδραίμονος υἱός,{l]
[l [n}15.282{]}Αἰτωλῶν ὄχʼ ἄριστος ἐπιστάμενος μὲν ἄκοντι{l]
[l [n}15.283{]}ἐσθλὸς δʼ ἐν σταδίῃ· ἀγορῇ δέ ἑ παῦροι Ἀχαιῶν{l]
[l [n}15.284{]}νίκων, ὁππότε κοῦροι ἐρίσσειαν περὶ μύθων·{l]
[l [n}15.285{]}ὅ σφιν ἐϋφρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}15.286{]}ὢ πόποι ἦ μέγα θαῦμα τόδʼ ὀφθαλμοῖσιν ὁρῶμαι,{l]
[l [n}15.287{]}οἷον δʼ αὖτʼ ἐξαῦτις ἀνέστη κῆρας ἀλύξας{l]
[l [n}15.288{]}Ἕκτωρ· ἦ θήν μιν μάλα ἔλπετο θυμὸς ἑκάστου{l]
[l [n}15.289{]}χερσὶν ὑπʼ Αἴαντος θανέειν Τελαμωνιάδαο.{l]
[l [n}15.290{]}ἀλλά τις αὖτε θεῶν ἐρρύσατο καὶ ἐσάωσεν{l]
[l [n}15.291{]}Ἕκτορʼ, ὃ δὴ πολλῶν Δαναῶν ὑπὸ γούνατʼ ἔλυσεν,{l]
[l [n}15.292{]}ὡς καὶ νῦν ἔσσεσθαι ὀΐομαι· οὐ γὰρ ἄτερ γε{l]
[l [n}15.293{]}Ζηνὸς ἐριγδούπου πρόμος ἵσταται ὧδε μενοινῶν.{l]
[l [n}15.294{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼν εἴπω πειθώμεθα πάντες.{l]
[l [n}15.295{]}πληθὺν μὲν ποτὶ νῆας ἀνώξομεν ἀπονέεσθαι·{l]
[l [n}15.296{]}αὐτοὶ δʼ, ὅσσοι ἄριστοι ἐνὶ στρατῷ εὐχόμεθʼ εἶναι,{l]
[l [n}15.297{]}στήομεν, εἴ κεν πρῶτον ἐρύξομεν ἀντιάσαντες{l]
[l [n}15.298{]}δούρατʼ ἀνασχόμενοι· τὸν δʼ οἴω καὶ μεμαῶτα{l]
[l [n}15.299{]}θυμῷ δείσεσθαι Δαναῶν καταδῦναι ὅμιλον.{l]{q]{para]
[para}[l [n}15.300{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο·{l]
[l [n}15.301{]}οἳ μὲν ἄρʼ ἀμφʼ Αἴαντα καὶ Ἰδομενῆα ἄνακτα{l]
[l [n}15.302{]}Τεῦκρον Μηριόνην τε Μέγην τʼ ἀτάλαντον Ἄρηϊ{l]
[l [n}15.303{]}ὑσμίνην ἤρτυνον ἀριστῆας καλέσαντες{l]
[l [n}15.304{]}Ἕκτορι καὶ Τρώεσσιν ἐναντίον· αὐτὰρ ὀπίσσω{l]
[l [n}15.305{]}ἣ πληθὺς ἐπὶ νῆας Ἀχαιῶν ἀπονέοντο.{l]{para]
[para}[l [n}15.306{]}Τρῶες δὲ προὔτυψαν ἀολλέες, ἦρχε δʼ ἄρʼ Ἕκτωρ{l]
[l [n}15.307{]}μακρὰ βιβάς· πρόσθεν δὲ κίʼ αὐτοῦ Φοῖβος Ἀπόλλων{l]
[l [n}15.308{]}εἱμένος ὤμοιιν νεφέλην, ἔχε δʼ αἰγίδα θοῦριν{l]
[l [n}15.309{]}δεινὴν ἀμφιδάσειαν ἀριπρεπέʼ, ἣν ἄρα χαλκεὺς{l]
[l [n}15.310{]}Ἥφαιστος Διὶ δῶκε φορήμεναι ἐς φόβον ἀνδρῶν·{l]
[l [n}15.311{]}τὴν ἄρʼ ὅ γʼ ἐν χείρεσσιν ἔχων ἡγήσατο λαῶν.{l]{para]
[para}[l [n}15.312{]}Ἀργεῖοι δʼ ὑπέμειναν ἀολλέες, ὦρτο δʼ ἀϋτὴ{l]
[l [n}15.313{]}ὀξεῖʼ ἀμφοτέρωθεν, ἀπὸ νευρῆφι δʼ ὀϊστοὶ{l]
[l [n}15.314{]}θρῷσκον· πολλὰ δὲ δοῦρα θρασειάων ἀπὸ χειρῶν{l]
[l [n}15.315{]}ἄλλα μὲν ἐν χροῒ πήγνυτʼ ἀρηϊθόων αἰζηῶν,{l]
[l [n}15.316{]}πολλὰ δὲ καὶ μεσσηγὺ πάρος χρόα λευκὸν ἐπαυρεῖν{l]
[l [n}15.317{]}ἐν γαίῃ ἵσταντο λιλαιόμενα χροὸς ἆσαι.{l]
[l [n}15.318{]}ὄφρα μὲν αἰγίδα χερσὶν ἔχʼ ἀτρέμα Φοῖβος Ἀπόλλων,{l]
[l [n}15.319{]}τόφρα μάλʼ ἀμφοτέρων βέλεʼ ἥπτετο, πῖπτε δὲ λαός.{l]
[l [n}15.320{]}αὐτὰρ ἐπεὶ κατʼ ἐνῶπα ἰδὼν Δαναῶν ταχυπώλων{l]
[l [n}15.321{]}σεῖσʼ, ἐπὶ δʼ αὐτὸς ἄϋσε μάλα μέγα, τοῖσι δὲ θυμὸν{l]
[l [n}15.322{]}ἐν στήθεσσιν ἔθελξε, λάθοντο δὲ θούριδος ἀλκῆς.{l]
[l [n}15.323{]}οἳ δʼ ὥς τʼ ἠὲ βοῶν ἀγέλην ἢ πῶϋ μέγʼ οἰῶν{l]
[l [n}15.324{]}θῆρε δύω κλονέωσι μελαίνης νυκτὸς ἀμολγῷ{l]
[l [n}15.325{]}ἐλθόντʼ ἐξαπίνης σημάντορος οὐ παρεόντος,{l]
[l [n}15.326{]}ὣς ἐφόβηθεν Ἀχαιοὶ ἀνάλκιδες· ἐν γὰρ Ἀπόλλων{l]
[l [n}15.327{]}ἧκε φόβον, Τρωσὶν δὲ καὶ Ἕκτορι κῦδος ὄπαζεν.{l]{para]
[para}[l [n}15.328{]}ἔνθα δʼ ἀνὴρ ἕλεν ἄνδρα κεδασθείσης ὑσμίνης.{l]
[l [n}15.329{]}Ἕκτωρ μὲν Στιχίον τε καὶ Ἀρκεσίλαον ἔπεφνε,{l]
[l [n}15.330{]}τὸν μὲν Βοιωτῶν ἡγήτορα χαλκοχιτώνων,{l]
[l [n}15.331{]}τὸν δὲ Μενεσθῆος μεγαθύμου πιστὸν ἑταῖρον·{l]
[l [n}15.332{]}Αἰνείας δὲ Μέδοντα καὶ Ἴασον ἐξενάριξεν.{l]
[l [n}15.333{]}ἤτοι ὃ μὲν νόθος υἱὸς Ὀϊλῆος θείοιο{l]
[l [n}15.334{]}ἔσκε Μέδων Αἴαντος ἀδελφεός· αὐτὰρ ἔναιεν{l]
[l [n}15.335{]}ἐν Φυλάκῃ γαίης ἄπο πατρίδος ἄνδρα κατακτὰς{l]
[l [n}15.336{]}γνωτὸν μητρυιῆς Ἐριώπιδος, ἣν ἔχʼ Ὀϊλεύς·{l]
[l [n}15.337{]}Ἴασος αὖτʼ ἀρχὸς μὲν Ἀθηναίων ἐτέτυκτο,{l]
[l [n}15.338{]}υἱὸς δὲ Σφήλοιο καλέσκετο Βουκολίδαο.{l]
[l [n}15.339{]}Μηκιστῆ δʼ ἕλε Πουλυδάμας, Ἐχίον δὲ Πολίτης{l]
[l [n}15.340{]}πρώτῃ ἐν ὑσμίνῃ, Κλονίον δʼ ἕλε δῖος Ἀγήνωρ.{l]
[l [n}15.341{]}Δηΐοχον δὲ Πάρις βάλε νείατον ὦμον ὄπισθε{l]
[l [n}15.342{]}φεύγοντʼ ἐν προμάχοισι, διὰ πρὸ δὲ χαλκὸν ἔλασσεν.{l]{para]
[para}[l [n}15.343{]}ὄφρʼ οἳ τοὺς ἐνάριζον ἀπʼ ἔντεα, τόφρα δʼ Ἀχαιοὶ{l]
[l [n}15.344{]}τάφρῳ καὶ σκολόπεσσιν ἐνιπλήξαντες ὀρυκτῇ{l]
[l [n}15.345{]}ἔνθα καὶ ἔνθα φέβοντο, δύοντο δὲ τεῖχος ἀνάγκῃ.{l]
[l [n}15.346{]}Ἕκτωρ δὲ Τρώεσσιν ἐκέκλετο μακρὸν ἀΰσας{l]
[q}[l [n}15.347{]}νηυσὶν ἐπισσεύεσθαι, ἐᾶν δʼ ἔναρα βροτόεντα·{l]
[l [n}15.348{]}ὃν δʼ ἂν ἐγὼν ἀπάνευθε νεῶν ἑτέρωθι νοήσω,{l]
[l [n}15.349{]}αὐτοῦ οἱ θάνατον μητίσομαι, οὐδέ νυ τόν γε{l]
[l [n}15.350{]}γνωτοί τε γνωταί τε πυρὸς λελάχωσι θανόντα,{l]
[l [n}15.351{]}ἀλλὰ κύνες ἐρύουσι πρὸ ἄστεος ἡμετέροιο.{l]{q]{para]
[para}[l [n}15.352{]}ὣς εἰπὼν μάστιγι κατωμαδὸν ἤλασεν ἵππους{l]
[l [n}15.353{]}κεκλόμενος Τρώεσσι κατὰ στίχας· οἳ δὲ σὺν αὐτῷ{l]
[l [n}15.354{]}πάντες ὁμοκλήσαντες ἔχον ἐρυσάρματας ἵππους{l]
[l [n}15.355{]}ἠχῇ θεσπεσίῃ· προπάροιθε δὲ Φοῖβος Ἀπόλλων{l]
[l [n}15.356{]}ῥεῖʼ ὄχθας καπέτοιο βαθείης ποσσὶν ἐρείπων{l]
[l [n}15.357{]}ἐς μέσσον κατέβαλλε, γεφύρωσεν δὲ κέλευθον{l]
[l [n}15.358{]}μακρὴν ἠδʼ εὐρεῖαν, ὅσον τʼ ἐπὶ δουρὸς ἐρωὴ{l]
[l [n}15.359{]}γίγνεται, ὁππότʼ ἀνὴρ σθένεος πειρώμενος ᾗσι.{l]
[l [n}15.360{]}τῇ ῥʼ οἵ γε προχέοντο φαλαγγηδόν, πρὸ δʼ Ἀπόλλων{l]
[l [n}15.361{]}αἰγίδʼ ἔχων ἐρίτιμον· ἔρειπε δὲ τεῖχος Ἀχαιῶν{l]
[l [n}15.362{]}ῥεῖα μάλʼ, ὡς ὅτε τις ψάμαθον πάϊς ἄγχι θαλάσσης,{l]
[l [n}15.363{]}ὅς τʼ ἐπεὶ οὖν ποιήσῃ ἀθύρματα νηπιέῃσιν{l]
[l [n}15.364{]}ἂψ αὖτις συνέχευε ποσὶν καὶ χερσὶν ἀθύρων.{l]
[l [n}15.365{]}ὥς ῥα σὺ ἤϊε Φοῖβε πολὺν κάματον καὶ ὀϊζὺν{l]
[l [n}15.366{]}σύγχεας Ἀργείων, αὐτοῖσι δὲ φύζαν ἐνῶρσας.{l]{para]
[para}[l [n}15.367{]}ὣς οἳ μὲν παρὰ νηυσὶν ἐρητύοντο μένοντες,{l]
[l [n}15.368{]}ἀλλήλοισί τε κεκλόμενοι καὶ πᾶσι θεοῖσι{l]
[l [n}15.369{]}χεῖρας ἀνίσχοντες μεγάλʼ εὐχετόωντο ἕκαστος·{l]
[l [n}15.370{]}Νέστωρ αὖτε μάλιστα Γερήνιος οὖρος Ἀχαιῶν{l]
[l [n}15.371{]}εὔχετο χεῖρʼ ὀρέγων εἰς οὐρανὸν ἀστερόεντα·{l]
[q}[l [n}15.372{]}Ζεῦ πάτερ εἴ ποτέ τίς τοι ἐν Ἄργεΐ περ πολυπύρῳ{l]
[l [n}15.373{]}ἢ βοὸς ἢ οἰὸς κατὰ πίονα μηρία καίων{l]
[l [n}15.374{]}εὔχετο νοστῆσαι, σὺ δʼ ὑπέσχεο καὶ κατένευσας,{l]
[l [n}15.375{]}τῶν μνῆσαι καὶ ἄμυνον Ὀλύμπιε νηλεὲς ἦμαρ,{l]
[l [n}15.376{]}μηδʼ οὕτω Τρώεσσιν ἔα δάμνασθαι Ἀχαιούς.{l]{q]{para]
[para}[l [n}15.377{]}ὣς ἔφατʼ εὐχόμενος, μέγα δʼ ἔκτυπε μητίετα Ζεύς,{l]
[l [n}15.378{]}ἀράων ἀΐων Νηληϊάδαο γέροντος.{l]{para]
[para}[l [n}15.379{]}Τρῶες δʼ ὡς ἐπύθοντο Διὸς κτύπον αἰγιόχοιο,{l]
[l [n}15.380{]}μᾶλλον ἐπʼ Ἀργείοισι θόρον, μνήσαντο δὲ χάρμης.{l]
[l [n}15.381{]}οἳ δʼ ὥς τε μέγα κῦμα θαλάσσης εὐρυπόροιο{l]
[l [n}15.382{]}νηὸς ὑπὲρ τοίχων καταβήσεται, ὁππότʼ ἐπείγῃ{l]
[l [n}15.383{]}ἲς ἀνέμου· ἣ γάρ τε μάλιστά γε κύματʼ ὀφέλλει·{l]
[l [n}15.384{]}ὣς Τρῶες μεγάλῃ ἰαχῇ κατὰ τεῖχος ἔβαινον,{l]
[l [n}15.385{]}ἵππους δʼ εἰσελάσαντες ἐπὶ πρύμνῃσι μάχοντο{l]
[l [n}15.386{]}ἔγχεσιν ἀμφιγύοις αὐτοσχεδόν, οἳ μὲν ἀφʼ ἵππων,{l]
[l [n}15.387{]}οἳ δʼ ἀπὸ νηῶν ὕψι μελαινάων ἐπιβάντες{l]
[l [n}15.388{]}μακροῖσι ξυστοῖσι, τά ῥά σφʼ ἐπὶ νηυσὶν ἔκειτο{l]
[l [n}15.389{]}ναύμαχα κολλήεντα, κατὰ στόμα εἱμένα χαλκῷ.{l]{para]
[para}[l [n}15.390{]}Πάτροκλος δʼ εἷος μὲν Ἀχαιοί τε Τρῶές τε{l]
[l [n}15.391{]}τείχεος ἀμφεμάχοντο θοάων ἔκτοθι νηῶν,{l]
[l [n}15.392{]}τόφρʼ ὅ γʼ ἐνὶ κλισίῃ ἀγαπήνορος Εὐρυπύλοιο{l]
[l [n}15.393{]}ἧστό τε καὶ τὸν ἔτερπε λόγοις, ἐπὶ δʼ ἕλκεϊ λυγρῷ{l]
[l [n}15.394{]}φάρμακʼ ἀκέσματʼ ἔπασσε μελαινάων ὀδυνάων.{l]
[l [n}15.395{]}αὐτὰρ ἐπεὶ δὴ τεῖχος ἐπεσσυμένους ἐνόησε{l]
[l [n}15.396{]}Τρῶας, ἀτὰρ Δαναῶν γένετο ἰαχή τε φόβος τε,{l]
[l [n}15.397{]}ᾤμωξέν τʼ ἄρʼ ἔπειτα καὶ ὣ πεπλήγετο μηρὼ{l]
[l [n}15.398{]}χερσὶ καταπρηνέσσʼ, ὀλοφυρόμενος δʼ ἔπος ηὔδα·{l]
[q}[l [n}15.399{]}Εὐρύπυλʼ οὐκ ἔτι τοι δύναμαι χατέοντί περʼ ἔμπης{l]
[l [n}15.400{]}ἐνθάδε παρμενέμεν· δὴ γὰρ μέγα νεῖκος ὄρωρεν·{l]
[l [n}15.401{]}ἀλλὰ σὲ μὲν θεράπων ποτιτερπέτω, αὐτὰρ ἔγωγε{l]
[l [n}15.402{]}σπεύσομαι εἰς Ἀχιλῆα, ἵνʼ ὀτρύνω πολεμίζειν.{l]
[l [n}15.403{]}τίς δʼ οἶδʼ εἴ κέν οἱ σὺν δαίμονι θυμὸν ὀρίνω{l]
[l [n}15.404{]}παρειπών; ἀγαθὴ δὲ παραίφασίς ἐστιν ἑταίρου.{l]{q]{para]
[para}[l [n}15.405{]}τὸν μὲν ἄρʼ ὣς εἰπόντα πόδες φέρον· αὐτὰρ Ἀχαιοὶ{l]
[l [n}15.406{]}Τρῶας ἐπερχομένους μένον ἔμπεδον, οὐδʼ ἐδύναντο{l]
[l [n}15.407{]}παυροτέρους περ ἐόντας ἀπώσασθαι παρὰ νηῶν·{l]
[l [n}15.408{]}οὐδέ ποτε Τρῶες Δαναῶν ἐδύναντο φάλαγγας{l]
[l [n}15.409{]}ῥηξάμενοι κλισίῃσι μιγήμεναι ἠδὲ νέεσσιν.{l]
[l [n}15.410{]}ἀλλʼ ὥς τε στάθμη δόρυ νήϊον ἐξιθύνει{l]
[l [n}15.411{]}τέκτονος ἐν παλάμῃσι δαήμονος, ὅς ῥά τε πάσης{l]
[l [n}15.412{]}εὖ εἰδῇ σοφίης ὑποθημοσύνῃσιν Ἀθήνης,{l]
[l [n}15.413{]}ὣς μὲν τῶν ἐπὶ ἶσα μάχη τέτατο πτόλεμός τε·{l]
[l [n}15.414{]}ἄλλοι δʼ ἀμφʼ ἄλλῃσι μάχην ἐμάχοντο νέεσσιν,{l]
[l [n}15.415{]}Ἕκτωρ δʼ ἄντʼ Αἴαντος ἐείσατο κυδαλίμοιο.{l]
[l [n}15.416{]}τὼ δὲ μιῆς περὶ νηὸς ἔχον πόνον, οὐδὲ δύναντο{l]
[l [n}15.417{]}οὔθʼ ὃ τὸν ἐξελάσαι καὶ ἐνιπρῆσαι πυρὶ νῆα{l]
[l [n}15.418{]}οὔθʼ ὃ τὸν ἂψ ὤσασθαι, ἐπεί ῥʼ ἐπέλασσέ γε δαίμων.{l]
[l [n}15.419{]}ἔνθʼ υἷα Κλυτίοιο Καλήτορα φαίδιμος Αἴας{l]
[l [n}15.420{]}πῦρ ἐς νῆα φέροντα κατὰ στῆθος βάλε δουρί.{l]
[l [n}15.421{]}δούπησεν δὲ πεσών, δαλὸς δέ οἱ ἔκπεσε χειρός.{l]
[l [n}15.422{]}Ἕκτωρ δʼ ὡς ἐνόησεν ἀνεψιὸν ὀφθαλμοῖσιν{l]
[l [n}15.423{]}ἐν κονίῃσι πεσόντα νεὸς προπάροιθε μελαίνης,{l]
[l [n}15.424{]}Τρωσί τε καὶ Λυκίοισιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}15.425{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταὶ{l]
[l [n}15.426{]}μὴ δή πω χάζεσθε μάχης ἐν στείνεϊ τῷδε,{l]
[l [n}15.427{]}ἀλλʼ υἷα Κλυτίοιο σαώσατε, μή μιν Ἀχαιοὶ{l]
[l [n}15.428{]}τεύχεα συλήσωσι νεῶν ἐν ἀγῶνι πεσόντα.{l]{q]{para]
[para}[l [n}15.429{]}ὣς εἰπὼν Αἴαντος ἀκόντισε δουρὶ φαεινῷ.{l]
[l [n}15.430{]}τοῦ μὲν ἅμαρθʼ, ὃ δʼ ἔπειτα Λυκόφρονα Μάστορος υἱὸν{l]
[l [n}15.431{]}Αἴαντος θεράποντα Κυθήριον, ὅς ῥα παρʼ αὐτῷ{l]
[l [n}15.432{]}ναῖʼ, ἐπεὶ ἄνδρα κατέκτα Κυθήροισι ζαθέοισι,{l]
[l [n}15.433{]}τόν ῥʼ ἔβαλεν κεφαλὴν ὑπὲρ οὔατος ὀξέϊ χαλκῷ{l]
[l [n}15.434{]}ἑσταότʼ ἄγχʼ Αἴαντος· ὃ δʼ ὕπτιος ἐν κονίῃσι{l]
[l [n}15.435{]}νηὸς ἄπο πρυμνῆς χαμάδις πέσε, λύντο δὲ γυῖα.{l]
[l [n}15.436{]}Αἴας δʼ ἐρρίγησε, κασίγνητον δὲ προσηύδα·{l]
[q}[l [n}15.437{]}Τεῦκρε πέπον δὴ νῶϊν ἀπέκτατο πιστὸς ἑταῖρος{l]
[l [n}15.438{]}Μαστορίδης, ὃν νῶϊ Κυθηρόθεν ἔνδον ἐόντα{l]
[l [n}15.439{]}ἶσα φίλοισι τοκεῦσιν ἐτίομεν ἐν μεγάροισι·{l]
[l [n}15.440{]}τὸν δʼ Ἕκτωρ μεγάθυμος ἀπέκτανε. ποῦ νύ τοι ἰοὶ{l]
[l [n}15.441{]}ὠκύμοροι καὶ τόξον ὅ τοι πόρε Φοῖβος Ἀπόλλων;{l]{q]{para]
[para}[l [n}15.442{]}ὣς φάθʼ, ὃ δὲ ξυνέηκε, θέων δέ οἱ ἄγχι παρέστη,{l]
[l [n}15.443{]}τόξον ἔχων ἐν χειρὶ παλίντονον ἠδὲ φαρέτρην{l]
[l [n}15.444{]}ἰοδόκον· μάλα δʼ ὦκα βέλεα Τρώεσσιν ἐφίει.{l]
[l [n}15.445{]}καί ῥʼ ἔβαλε Κλεῖτον Πεισήνορος ἀγλαὸν υἱὸν{l]
[l [n}15.446{]}Πουλυδάμαντος ἑταῖρον ἀγαυοῦ Πανθοΐδαο{l]
[l [n}15.447{]}ἡνία χερσὶν ἔχοντα· ὃ μὲν πεπόνητο καθʼ ἵππους·{l]
[l [n}15.448{]}τῇ γὰρ ἔχʼ ᾗ ῥα πολὺ πλεῖσται κλονέοντο φάλαγγες{l]
[l [n}15.449{]}Ἕκτορι καὶ Τρώεσσι χαριζόμενος· τάχα δʼ αὐτῷ{l]
[l [n}15.450{]}ἦλθε κακόν, τό οἱ οὔ τις ἐρύκακεν ἱεμένων περ.{l]
[l [n}15.451{]}αὐχένι γάρ οἱ ὄπισθε πολύστονος ἔμπεσεν ἰός·{l]
[l [n}15.452{]}ἤριπε δʼ ἐξ ὀχέων, ὑπερώησαν δέ οἱ ἵπποι{l]
[l [n}15.453{]}κείνʼ ὄχεα κροτέοντες. ἄναξ δʼ ἐνόησε τάχιστα{l]
[l [n}15.454{]}Πουλυδάμας, καὶ πρῶτος ἐναντίος ἤλυθεν ἵππων.{l]
[l [n}15.455{]}τοὺς μὲν ὅ γʼ Ἀστυνόῳ Προτιάονος υἱέϊ δῶκε,{l]
[l [n}15.456{]}πολλὰ δʼ ἐπότρυνε σχεδὸν ἴσχειν εἰσορόωντα{l]
[l [n}15.457{]}ἵππους· αὐτὸς δʼ αὖτις ἰὼν προμάχοισιν ἐμίχθη.{l]{para]
[para}[l [n}15.458{]}Τεῦκρος δʼ ἄλλον ὀϊστὸν ἐφʼ Ἕκτορι χαλκοκορυστῇ{l]
[l [n}15.459{]}αἴνυτο, καί κεν ἔπαυσε μάχης ἐπὶ νηυσὶν Ἀχαιῶν,{l]
[l [n}15.460{]}εἴ μιν ἀριστεύοντα βαλὼν ἐξείλετο θυμόν.{l]
[l [n}15.461{]}ἀλλʼ οὐ λῆθε Διὸς πυκινὸν νόον, ὅς ῥʼ ἐφύλασσεν{l]
[l [n}15.462{]}Ἕκτορʼ, ἀτὰρ Τεῦκρον Τελαμώνιον εὖχος ἀπηύρα,{l]
[l [n}15.463{]}ὅς οἱ ἐϋστρεφέα νευρὴν ἐν ἀμύμονι τόξῳ{l]
[l [n}15.464{]}ῥῆξʼ ἐπὶ τῷ ἐρύοντι· παρεπλάγχθη δέ οἱ ἄλλῃ{l]
[l [n}15.465{]}ἰὸς χαλκοβαρής, τόξον δέ οἱ ἔκπεσε χειρός.{l]
[l [n}15.466{]}Τεῦκρος δʼ ἐρρίγησε, κασίγνητον δὲ προσηύδα·{l]
[q}[l [n}15.467{]}ὢ πόποι ἦ δὴ πάγχυ μάχης ἐπὶ μήδεα κείρει{l]
[l [n}15.468{]}δαίμων ἡμετέρης, ὅ τέ μοι βιὸν ἔκβαλε χειρός,{l]
[l [n}15.469{]}νευρὴν δʼ ἐξέρρηξε νεόστροφον, ἣν ἐνέδησα{l]
[l [n}15.470{]}πρώϊον, ὄφρʼ ἀνέχοιτο θαμὰ θρῴσκοντας ὀϊστούς.{l]{q]{para]
[para}[l [n}15.471{]}τὸν δʼ ἠμείβετʼ ἔπειτα μέγας Τελαμώνιος Αἴας·{l]
[q}[l [n}15.472{]}ὦ πέπον ἀλλὰ βιὸν μὲν ἔα καὶ ταρφέας ἰοὺς{l]
[l [n}15.473{]}κεῖσθαι, ἐπεὶ συνέχευε θεὸς Δαναοῖσι μεγήρας·{l]
[l [n}15.474{]}αὐτὰρ χερσὶν ἑλὼν δολιχὸν δόρυ καὶ σάκος ὤμῳ{l]
[l [n}15.475{]}μάρναό τε Τρώεσσι καὶ ἄλλους ὄρνυθι λαούς.{l]
[l [n}15.476{]}μὴ μὰν ἀσπουδί γε δαμασσάμενοί περ ἕλοιεν{l]
[l [n}15.477{]}νῆας ἐϋσσέλμους, ἀλλὰ μνησώμεθα χάρμης.{l]{q]{para]
[para}[l [n}15.478{]}ὣς φάθʼ, ὃ δὲ τόξον μὲν ἐνὶ κλισίῃσιν ἔθηκεν,{l]
[l [n}15.479{]}αὐτὰρ ὅ γʼ ἀμφʼ ὤμοισι σάκος θέτο τετραθέλυμνον,{l]
[l [n}15.480{]}κρατὶ δʼ ἐπʼ ἰφθίμῳ κυνέην εὔτυκτον ἔθηκεν{l]
[l [n}15.481{]}ἵππουριν, δεινὸν δὲ λόφος καθύπερθεν ἔνευεν·{l]
[l [n}15.482{]}εἵλετο δʼ ἄλκιμον ἔγχος ἀκαχμένον ὀξέϊ χαλκῷ,{l]
[l [n}15.483{]}βῆ δʼ ἰέναι, μάλα δʼ ὦκα θέων Αἴαντι παρέστη.{l]{para]
[para}[l [n}15.484{]}Ἕκτωρ δʼ ὡς εἶδεν Τεύκρου βλαφθέντα βέλεμνα,{l]
[l [n}15.485{]}Τρωσί τε καὶ Λυκίοισιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}15.486{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταὶ{l]
[l [n}15.487{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς{l]
[l [n}15.488{]}νῆας ἀνὰ γλαφυράς· δὴ γὰρ ἴδον ὀφθαλμοῖσιν{l]
[l [n}15.489{]}ἀνδρὸς ἀριστῆος Διόθεν βλαφθέντα βέλεμνα.{l]
[l [n}15.490{]}ῥεῖα δʼ ἀρίγνωτος Διὸς ἀνδράσι γίγνεται ἀλκή,{l]
[l [n}15.491{]}ἠμὲν ὁτέοισιν κῦδος ὑπέρτερον ἐγγυαλίξῃ,{l]
[l [n}15.492{]}ἠδʼ ὅτινας μινύθῃ τε καὶ οὐκ ἐθέλῃσιν ἀμύνειν,{l]
[l [n}15.493{]}ὡς νῦν Ἀργείων μινύθει μένος, ἄμμι δʼ ἀρήγει.{l]
[l [n}15.494{]}ἀλλὰ μάχεσθʼ ἐπὶ νηυσὶν ἀολλέες· ὃς δέ κεν ὑμέων{l]
[l [n}15.495{]}βλήμενος ἠὲ τυπεὶς θάνατον καὶ πότμον ἐπίσπῃ{l]
[l [n}15.496{]}τεθνάτω· οὔ οἱ ἀεικὲς ἀμυνομένῳ περὶ πάτρης{l]
[l [n}15.497{]}τεθνάμεν· ἀλλʼ ἄλοχός τε σόη καὶ παῖδες ὀπίσσω,{l]
[l [n}15.498{]}καὶ οἶκος καὶ κλῆρος ἀκήρατος, εἴ κεν Ἀχαιοὶ{l]
[l [n}15.499{]}οἴχωνται σὺν νηυσὶ φίλην ἐς πατρίδα γαῖαν.{l]{q]{para]
[para}[l [n}15.500{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}15.501{]}Αἴας δʼ αὖθʼ ἑτέρωθεν ἐκέκλετο οἷς ἑτάροισιν·{l]
[q}[l [n}15.502{]}αἰδὼς Ἀργεῖοι· νῦν ἄρκιον ἢ ἀπολέσθαι{l]
[l [n}15.503{]}ἠὲ σαωθῆναι καὶ ἀπώσασθαι κακὰ νηῶν.{l]
[l [n}15.504{]}ἦ ἔλπεσθʼ ἢν νῆας ἕλῃ κορυθαίολος Ἕκτωρ{l]
[l [n}15.505{]}ἐμβαδὸν ἵξεσθαι ἣν πατρίδα γαῖαν ἕκαστος;{l]
[l [n}15.506{]}ἦ οὐκ ὀτρύνοντος ἀκούετε λαὸν ἅπαντα{l]
[l [n}15.507{]}Ἕκτορος, ὃς δὴ νῆας ἐνιπρῆσαι μενεαίνει;{l]
[l [n}15.508{]}οὐ μὰν ἔς γε χορὸν κέλετʼ ἐλθέμεν, ἀλλὰ μάχεσθαι.{l]
[l [n}15.509{]}ἡμῖν δʼ οὔ τις τοῦδε νόος καὶ μῆτις ἀμείνων{l]
[l [n}15.510{]}ἢ αὐτοσχεδίῃ μῖξαι χεῖράς τε μένος τε.{l]
[l [n}15.511{]}βέλτερον ἢ ἀπολέσθαι ἕνα χρόνον ἠὲ βιῶναι{l]
[l [n}15.512{]}ἢ δηθὰ στρεύγεσθαι ἐν αἰνῇ δηϊοτῆτι{l]
[l [n}15.513{]}ὧδʼ αὔτως παρὰ νηυσὶν ὑπʼ ἀνδράσι χειροτέροισιν.{l]{q]{para]
[para}[l [n}15.514{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}15.515{]}ἔνθʼ Ἕκτωρ μὲν ἕλε Σχεδίον Περιμήδεος υἱὸν{l]
[l [n}15.516{]}ἀρχὸν Φωκήων, Αἴας δʼ ἕλε Λαοδάμαντα{l]
[l [n}15.517{]}ἡγεμόνα πρυλέων Ἀντήνορος ἀγλαὸν υἱόν·{l]
[l [n}15.518{]}Πουλυδάμας δʼ Ὦτον Κυλλήνιον ἐξενάριξε{l]
[l [n}15.519{]}Φυλεΐδεω ἕταρον, μεγαθύμων ἀρχὸν Ἐπειῶν.{l]
[l [n}15.520{]}τῷ δὲ Μέγης ἐπόρουσεν ἰδών· ὃ δʼ ὕπαιθα λιάσθη{l]
[l [n}15.521{]}Πουλυδάμας· καὶ τοῦ μὲν ἀπήμβροτεν· οὐ γὰρ Ἀπόλλων{l]
[l [n}15.522{]}εἴα Πάνθου υἱὸν ἐνὶ προμάχοισι δαμῆναι·{l]
[l [n}15.523{]}αὐτὰρ ὅ γε Κροίσμου στῆθος μέσον οὔτασε δουρί.{l]
[l [n}15.524{]}δούπησεν δὲ πεσών· ὃ δʼ ἀπʼ ὤμων τεύχεʼ ἐσύλα.{l]
[l [n}15.525{]}τόφρα δὲ τῷ ἐπόρουσε Δόλοψ αἰχμῆς ἐῢ εἰδὼς{l]
[l [n}15.526{]}Λαμπετίδης, ὃν Λάμπος ἐγείνατο φέρτατον υἱὸν{l]
[l [n}15.527{]}Λαομεδοντιάδης εὖ εἰδότα θούριδος ἀλκῆς,{l]
[l [n}15.528{]}ὃς τότε Φυλεΐδαο μέσον σάκος οὔτασε δουρὶ{l]
[l [n}15.529{]}ἐγγύθεν ὁρμηθείς· πυκινὸς δέ οἱ ἤρκεσε θώρηξ,{l]
[l [n}15.530{]}τόν ῥʼ ἐφόρει γυάλοισιν ἀρηρότα· τόν ποτε Φυλεὺς{l]
[l [n}15.531{]}ἤγαγεν ἐξ Ἐφύρης, ποταμοῦ ἄπο Σελλήεντος.{l]
[l [n}15.532{]}ξεῖνος γάρ οἱ ἔδωκεν ἄναξ ἀνδρῶν Εὐφήτης{l]
[l [n}15.533{]}ἐς πόλεμον φορέειν δηΐων ἀνδρῶν ἀλεωρήν·{l]
[l [n}15.534{]}ὅς οἱ καὶ τότε παιδὸς ἀπὸ χροὸς ἤρκεσʼ ὄλεθρον.{l]
[l [n}15.535{]}τοῦ δὲ Μέγης κόρυθος χαλκήρεος ἱπποδασείης{l]
[l [n}15.536{]}κύμβαχον ἀκρότατον νύξʼ ἔγχεϊ ὀξυόεντι,{l]
[l [n}15.537{]}ῥῆξε δʼ ἀφʼ ἵππειον λόφον αὐτοῦ· πᾶς δὲ χαμᾶζε{l]
[l [n}15.538{]}κάππεσεν ἐν κονίῃσι νέον φοίνικι φαεινός.{l]
[l [n}15.539{]}εἷος ὃ τῷ πολέμιζε μένων, ἔτι δʼ ἔλπετο νίκην,{l]
[l [n}15.540{]}τόφρα δέ οἱ Μενέλαος ἀρήϊος ἦλθεν ἀμύντωρ,{l]
[l [n}15.541{]}στῆ δʼ εὐρὰξ σὺν δουρὶ λαθών, βάλε δʼ ὦμον ὄπισθεν·{l]
[l [n}15.542{]}αἰχμὴ δὲ στέρνοιο διέσσυτο μαιμώωσα{l]
[l [n}15.543{]}πρόσσω ἱεμένη· ὃ δʼ ἄρα πρηνὴς ἐλιάσθη.{l]
[l [n}15.544{]}τὼ μὲν ἐεισάσθην χαλκήρεα τεύχεʼ ἀπʼ ὤμων{l]
[l [n}15.545{]}συλήσειν· Ἕκτωρ δὲ κασιγνήτοισι κέλευσε{l]
[l [n}15.546{]}πᾶσι μάλα, πρῶτον δʼ Ἱκεταονίδην ἐνένιπεν{l]
[l [n}15.547{]}ἴφθιμον Μελάνιππον. ὃ δʼ ὄφρα μὲν εἰλίποδας βοῦς{l]
[l [n}15.548{]}βόσκʼ ἐν Περκώτῃ δηΐων ἀπὸ νόσφιν ἐόντων·{l]
[l [n}15.549{]}αὐτὰρ ἐπεὶ Δαναῶν νέες ἤλυθον ἀμφιέλισσαι,{l]
[l [n}15.550{]}ἂψ εἰς Ἴλιον ἦλθε, μετέπρεπε δὲ Τρώεσσι,{l]
[l [n}15.551{]}ναῖε δὲ πὰρ Πριάμῳ, ὃ δέ μιν τίεν ἶσα τέκεσσι·{l]
[l [n}15.552{]}τόν ῥʼ Ἕκτωρ ἐνένιπεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζεν·{l]
[q}[l [n}15.553{]}οὕτω δὴ Μελάνιππε μεθήσομεν; οὐδέ νυ σοί περ{l]
[l [n}15.554{]}ἐντρέπεται φίλον ἦτορ ἀνεψιοῦ κταμένοιο;{l]
[l [n}15.555{]}οὐχ ὁράᾳς οἷον Δόλοπος περὶ τεύχεʼ ἕπουσιν;{l]
[l [n}15.556{]}ἀλλʼ ἕπευ· οὐ γὰρ ἔτʼ ἔστιν ἀποσταδὸν Ἀργείοισι{l]
[l [n}15.557{]}μάρνασθαι, πρίν γʼ ἠὲ κατακτάμεν ἠὲ κατʼ ἄκρης{l]
[l [n}15.558{]}Ἴλιον αἰπεινὴν ἑλέειν κτάσθαι τε πολίτας.{l]{q]{para]
[para}[l [n}15.559{]}ὣς εἰπὼν ὃ μὲν ἦρχʼ, ὃ δʼ ἅμʼ ἕσπετο ἰσόθεος φώς·{l]
[l [n}15.560{]}Ἀργείους δʼ ὄτρυνε μέγας Τελαμώνιος Αἴας·{l]
[q}[l [n}15.561{]}ὦ φίλοι ἀνέρες ἔστε, καὶ αἰδῶ θέσθʼ ἐνὶ θυμῷ,{l]
[l [n}15.562{]}ἀλλήλους τʼ αἰδεῖσθε κατὰ κρατερὰς ὑσμίνας.{l]
[l [n}15.563{]}αἰδομένων δʼ ἀνδρῶν πλέονες σόοι ἠὲ πέφανται·{l]
[l [n}15.564{]}φευγόντων δʼ οὔτʼ ἂρ κλέος ὄρνυται οὔτέ τις ἀλκή.{l]{q]{para]
[para}[l [n}15.565{]}ὣς ἔφαθʼ, οἳ δὲ καὶ αὐτοὶ ἀλέξασθαι μενέαινον,{l]
[l [n}15.566{]}ἐν θυμῷ δʼ ἐβάλοντο ἔπος, φράξαντο δὲ νῆας{l]
[l [n}15.567{]}ἕρκεϊ χαλκείῳ· ἐπὶ δὲ Ζεὺς Τρῶας ἔγειρεν.{l]
[l [n}15.568{]}Ἀντίλοχον δʼ ὄτρυνε βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}15.569{]}Ἀντίλοχʼ οὔ τις σεῖο νεώτερος ἄλλος Ἀχαιῶν,{l]
[l [n}15.570{]}οὔτε ποσὶν θάσσων οὔτʼ ἄλκιμος ὡς σὺ μάχεσθαι·{l]
[l [n}15.571{]}εἴ τινά που Τρώων ἐξάλμενος ἄνδρα βάλοισθα.{l]{q]{para]
[para}[l [n}15.572{]}ὣς εἰπὼν ὃ μὲν αὖτις ἀπέσσυτο, τὸν δʼ ὀρόθυνεν·{l]
[l [n}15.573{]}ἐκ δʼ ἔθορε προμάχων, καὶ ἀκόντισε δουρὶ φαεινῷ{l]
[l [n}15.574{]}ἀμφὶ ἓ παπτήνας· ὑπὸ δὲ Τρῶες κεκάδοντο{l]
[l [n}15.575{]}ἀνδρὸς ἀκοντίσσαντος· ὃ δʼ οὐχ ἅλιον βέλος ἧκεν,{l]
[l [n}15.576{]}ἀλλʼ Ἱκετάονος υἱὸν ὑπέρθυμον Μελάνιππον{l]
[l [n}15.577{]}νισόμενον πόλεμον δὲ βάλε στῆθος παρὰ μαζόν.{l]
[l [n}15.578{]}δούπησεν δὲ πεσών, τὸν δὲ σκότος ὄσσε κάλυψεν.{l]
[l [n}15.579{]}Ἀντίλοχος δʼ ἐπόρουσε κύων ὥς, ὅς τʼ ἐπὶ νεβρῷ{l]
[l [n}15.580{]}βλημένῳ ἀΐξῃ, τόν τʼ ἐξ εὐνῆφι θορόντα{l]
[l [n}15.581{]}θηρητὴρ ἐτύχησε βαλών, ὑπέλυσε δὲ γυῖα·{l]
[l [n}15.582{]}ὣς ἐπὶ σοὶ Μελάνιππε θόρʼ Ἀντίλοχος μενεχάρμης{l]
[l [n}15.583{]}τεύχεα συλήσων· ἀλλʼ οὐ λάθεν Ἕκτορα δῖον,{l]
[l [n}15.584{]}ὅς ῥά οἱ ἀντίος ἦλθε θέων ἀνὰ δηϊοτῆτα.{l]
[l [n}15.585{]}Ἀντίλοχος δʼ οὐ μεῖνε θοός περ ἐὼν πολεμιστής,{l]
[l [n}15.586{]}ἀλλʼ ὅ γʼ ἄρʼ ἔτρεσε θηρὶ κακὸν ῥέξαντι ἐοικώς,{l]
[l [n}15.587{]}ὅς τε κύνα κτείνας ἢ βουκόλον ἀμφὶ βόεσσι{l]
[l [n}15.588{]}φεύγει πρίν περ ὅμιλον ἀολλισθήμεναι ἀνδρῶν·{l]
[l [n}15.589{]}ὣς τρέσε Νεστορίδης, ἐπὶ δὲ Τρῶές τε καὶ Ἕκτωρ{l]
[l [n}15.590{]}ἠχῇ θεσπεσίῃ βέλεα στονόεντα χέοντο·{l]
[l [n}15.591{]}στῆ δὲ μεταστρεφθείς, ἐπεὶ ἵκετο ἔθνος ἑταίρων.{l]{para]
[para}[l [n}15.592{]}Τρῶες δὲ λείουσιν ἐοικότες ὠμοφάγοισι{l]
[l [n}15.593{]}νηυσὶν ἐπεσσεύοντο, Διὸς δʼ ἐτέλειον ἐφετμάς,{l]
[l [n}15.594{]}ὅ σφισιν αἰὲν ἔγειρε μένος μέγα, θέλγε δὲ θυμὸν{l]
[l [n}15.595{]}Ἀργείων καὶ κῦδος ἀπαίνυτο, τοὺς δʼ ὀρόθυνεν.{l]
[l [n}15.596{]}Ἕκτορι γάρ οἱ θυμὸς ἐβούλετο κῦδος ὀρέξαι{l]
[l [n}15.597{]}Πριαμίδῃ, ἵνα νηυσὶ κορωνίσι θεσπιδαὲς πῦρ{l]
[l [n}15.598{]}ἐμβάλοι ἀκάματον, Θέτιδος δʼ ἐξαίσιον ἀρὴν{l]
[l [n}15.599{]}πᾶσαν ἐπικρήνειε· τὸ γὰρ μένε μητίετα Ζεὺς{l]
[l [n}15.600{]}νηὸς καιομένης σέλας ὀφθαλμοῖσιν ἰδέσθαι.{l]
[l [n}15.601{]}ἐκ γὰρ δὴ τοῦ μέλλε παλίωξιν παρὰ νηῶν{l]
[l [n}15.602{]}θησέμεναι Τρώων, Δαναοῖσι δὲ κῦδος ὀρέξειν.{l]
[l [n}15.603{]}τὰ φρονέων νήεσσιν ἔπι γλαφυρῇσιν ἔγειρεν{l]
[l [n}15.604{]}Ἕκτορα Πριαμίδην μάλα περ μεμαῶτα καὶ αὐτόν.{l]
[l [n}15.605{]}μαίνετο δʼ ὡς ὅτʼ Ἄρης ἐγχέσπαλος ἢ ὀλοὸν πῦρ{l]
[l [n}15.606{]}οὔρεσι μαίνηται βαθέης ἐν τάρφεσιν ὕλης·{l]
[l [n}15.607{]}ἀφλοισμὸς δὲ περὶ στόμα γίγνετο, τὼ δέ οἱ ὄσσε{l]
[l [n}15.608{]}λαμπέσθην βλοσυρῇσιν ὑπʼ ὀφρύσιν, ἀμφὶ δὲ πήληξ{l]
[l [n}15.609{]}σμερδαλέον κροτάφοισι τινάσσετο μαρναμένοιο{l]
[l [n}15.610{]}Ἕκτορος· αὐτὸς γάρ οἱ ἀπʼ αἰθέρος ἦεν ἀμύντωρ{l]
[l [n}15.611{]}Ζεύς, ὅς μιν πλεόνεσσι μετʼ ἀνδράσι μοῦνον ἐόντα{l]
[l [n}15.612{]}τίμα καὶ κύδαινε. μινυνθάδιος γὰρ ἔμελλεν{l]
[l [n}15.613{]}ἔσσεσθʼ· ἤδη γάρ οἱ ἐπόρνυε μόρσιμον ἦμαρ{l]
[l [n}15.614{]}Παλλὰς Ἀθηναίη ὑπὸ Πηλεΐδαο βίηφιν.{l]
[l [n}15.615{]}καί ῥʼ ἔθελεν ῥῆξαι στίχας ἀνδρῶν πειρητίζων,{l]
[l [n}15.616{]}ᾗ δὴ πλεῖστον ὅμιλον ὅρα καὶ τεύχεʼ ἄριστα·{l]
[l [n}15.617{]}ἀλλʼ οὐδʼ ὧς δύνατο ῥῆξαι μάλα περ μενεαίνων·{l]
[l [n}15.618{]}ἴσχον γὰρ πυργηδὸν ἀρηρότες, ἠΰτε πέτρη{l]
[l [n}15.619{]}ἠλίβατος μεγάλη πολιῆς ἁλὸς ἐγγὺς ἐοῦσα,{l]
[l [n}15.620{]}ἥ τε μένει λιγέων ἀνέμων λαιψηρὰ κέλευθα{l]
[l [n}15.621{]}κύματά τε τροφόεντα, τά τε προσερεύγεται αὐτήν·{l]
[l [n}15.622{]}ὣς Δαναοὶ Τρῶας μένον ἔμπεδον οὐδὲ φέβοντο.{l]
[l [n}15.623{]}αὐτὰρ ὃ λαμπόμενος πυρὶ πάντοθεν ἔνθορʼ ὁμίλῳ,{l]
[l [n}15.624{]}ἐν δʼ ἔπεσʼ ὡς ὅτε κῦμα θοῇ ἐν νηῒ πέσῃσι{l]
[l [n}15.625{]}λάβρον ὑπαὶ νεφέων ἀνεμοτρεφές· ἣ δέ τε πᾶσα{l]
[l [n}15.626{]}ἄχνῃ ὑπεκρύφθη, ἀνέμοιο δὲ δεινὸς ἀήτη{l]
[l [n}15.627{]}ἱστίῳ ἐμβρέμεται, τρομέουσι δέ τε φρένα ναῦται{l]
[l [n}15.628{]}δειδιότες· τυτθὸν γὰρ ὑπʼ ἐκ θανάτοιο φέρονται·{l]
[l [n}15.629{]}ὣς ἐδαΐζετο θυμὸς ἐνὶ στήθεσσιν Ἀχαιῶν.{l]
[l [n}15.630{]}αὐτὰρ ὅ γʼ ὥς τε λέων ὀλοόφρων βουσὶν ἐπελθών,{l]
[l [n}15.631{]}αἵ ῥά τʼ ἐν εἱαμενῇ ἕλεος μεγάλοιο νέμονται{l]
[l [n}15.632{]}μυρίαι, ἐν δέ τε τῇσι νομεὺς οὔ πω σάφα εἰδὼς{l]
[l [n}15.633{]}θηρὶ μαχέσσασθαι ἕλικος βοὸς ἀμφὶ φονῇσιν·{l]
[l [n}15.634{]}ἤτοι ὃ μὲν πρώτῃσι καὶ ὑστατίῃσι βόεσσιν{l]
[l [n}15.635{]}αἰὲν ὁμοστιχάει, ὃ δέ τʼ ἐν μέσσῃσιν ὀρούσας{l]
[l [n}15.636{]}βοῦν ἔδει, αἳ δέ τε πᾶσαι ὑπέτρεσαν· ὣς τότʼ Ἀχαιοὶ{l]
[l [n}15.637{]}θεσπεσίως ἐφόβηθεν ὑφʼ Ἕκτορι καὶ Διὶ πατρὶ{l]
[l [n}15.638{]}πάντες, ὃ δʼ οἶον ἔπεφνε Μυκηναῖον Περιφήτην,{l]
[l [n}15.639{]}Κοπρῆος φίλον υἱόν, ὃς Εὐρυσθῆος ἄνακτος{l]
[l [n}15.640{]}ἀγγελίης οἴχνεσκε βίῃ Ἡρακληείῃ.{l]
[l [n}15.641{]}τοῦ γένετʼ ἐκ πατρὸς πολὺ χείρονος υἱὸς ἀμείνων{l]
[l [n}15.642{]}παντοίας ἀρετάς, ἠμὲν πόδας ἠδὲ μάχεσθαι,{l]
[l [n}15.643{]}καὶ νόον ἐν πρώτοισι Μυκηναίων ἐτέτυκτο·{l]
[l [n}15.644{]}ὅς ῥα τόθʼ Ἕκτορι κῦδος ὑπέρτερον ἐγγυάλιξε.{l]
[l [n}15.645{]}στρεφθεὶς γὰρ μετόπισθεν ἐν ἀσπίδος ἄντυγι πάλτο,{l]
[l [n}15.646{]}τὴν αὐτὸς φορέεσκε ποδηνεκέʼ ἕρκος ἀκόντων·{l]
[l [n}15.647{]}τῇ ὅ γʼ ἐνὶ βλαφθεὶς πέσεν ὕπτιος, ἀμφὶ δὲ πήληξ{l]
[l [n}15.648{]}σμερδαλέον κονάβησε περὶ κροτάφοισι πεσόντος.{l]
[l [n}15.649{]}Ἕκτωρ δʼ ὀξὺ νόησε, θέων δέ οἱ ἄγχι παρέστη,{l]
[l [n}15.650{]}στήθεϊ δʼ ἐν δόρυ πῆξε, φίλων δέ μιν ἐγγὺς ἑταίρων{l]
[l [n}15.651{]}κτεῖνʼ· οἳ δʼ οὐκ ἐδύναντο καὶ ἀχνύμενοί περ ἑταίρου{l]
[l [n}15.652{]}χραισμεῖν· αὐτοὶ γὰρ μάλα δείδισαν Ἕκτορα δῖον.{l]{para]
[para}[l [n}15.653{]}εἰσωποὶ δʼ ἐγένοντο νεῶν, περὶ δʼ ἔσχεθον ἄκραι{l]
[l [n}15.654{]}νῆες ὅσαι πρῶται εἰρύατο· τοὶ δʼ ἐπέχυντο.{l]
[l [n}15.655{]}Ἀργεῖοι δὲ νεῶν μὲν ἐχώρησαν καὶ ἀνάγκῃ{l]
[l [n}15.656{]}τῶν πρωτέων, αὐτοῦ δὲ παρὰ κλισίῃσιν ἔμειναν{l]
[l [n}15.657{]}ἁθρόοι, οὐδὲ κέδασθεν ἀνὰ στρατόν· ἴσχε γὰρ αἰδὼς{l]
[l [n}15.658{]}καὶ δέος· ἀζηχὲς γὰρ ὁμόκλεον ἀλλήλοισι.{l]
[l [n}15.659{]}Νέστωρ αὖτε μάλιστα Γερήνιος οὖρος Ἀχαιῶν{l]
[l [n}15.660{]}λίσσεθʼ ὑπὲρ τοκέων γουνούμενος ἄνδρα ἕκαστον·{l]
[q}[l [n}15.661{]}ὦ φίλοι ἀνέρες ἔστε καὶ αἰδῶ θέσθʼ ἐνὶ θυμῷ{l]
[l [n}15.662{]}ἄλλων ἀνθρώπων, ἐπὶ δὲ μνήσασθε ἕκαστος{l]
[l [n}15.663{]}παίδων ἠδʼ ἀλόχων καὶ κτήσιος ἠδὲ τοκήων,{l]
[l [n}15.664{]}ἠμὲν ὅτεῳ ζώουσι καὶ ᾧ κατατεθνήκασι·{l]
[l [n}15.665{]}τῶν ὕπερ ἐνθάδʼ ἐγὼ γουνάζομαι οὐ παρεόντων{l]
[l [n}15.666{]}ἑστάμεναι κρατερῶς, μὴ δὲ τρωπᾶσθε φόβον δέ.{l]{q]{para]
[para}[l [n}15.667{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}15.668{]}τοῖσι δʼ ἀπʼ ὀφθαλμῶν νέφος ἀχλύος ὦσεν Ἀθήνη{l]
[l [n}15.669{]}θεσπέσιον· μάλα δέ σφι φόως γένετʼ ἀμφοτέρωθεν{l]
[l [n}15.670{]}ἠμὲν πρὸς νηῶν καὶ ὁμοιΐου πολέμοιο.{l]
[l [n}15.671{]}Ἕκτορα δὲ φράσσαντο βοὴν ἀγαθὸν καὶ ἑταίρους,{l]
[l [n}15.672{]}ἠμὲν ὅσοι μετόπισθεν ἀφέστασαν οὐδὲ μάχοντο,{l]
[l [n}15.673{]}ἠδʼ ὅσσοι παρὰ νηυσὶ μάχην ἐμάχοντο θοῇσιν.{l]{para]
[para}[l [n}15.674{]}οὐδʼ ἄρʼ ἔτʼ Αἴαντι μεγαλήτορι ἥνδανε θυμῷ{l]
[l [n}15.675{]}ἑστάμεν ἔνθά περ ἄλλοι ἀφέστασαν υἷες Ἀχαιῶν·{l]
[l [n}15.676{]}ἀλλʼ ὅ γε νηῶν ἴκριʼ ἐπῴχετο μακρὰ βιβάσθων,{l]
[l [n}15.677{]}νώμα δὲ ξυστὸν μέγα ναύμαχον ἐν παλάμῃσι{l]
[l [n}15.678{]}κολλητὸν βλήτροισι δυωκαιεικοσίπηχυ.{l]
[l [n}15.679{]}ὡς δʼ ὅτʼ ἀνὴρ ἵπποισι κελητίζειν ἐῢ εἰδώς,{l]
[l [n}15.680{]}ὅς τʼ ἐπεὶ ἐκ πολέων πίσυρας συναείρεται ἵππους,{l]
[l [n}15.681{]}σεύας ἐκ πεδίοιο μέγα προτὶ ἄστυ δίηται{l]
[l [n}15.682{]}λαοφόρον καθʼ ὁδόν· πολέες τέ ἑ θηήσαντο{l]
[l [n}15.683{]}ἀνέρες ἠδὲ γυναῖκες· ὃ δʼ ἔμπεδον ἀσφαλὲς αἰεὶ{l]
[l [n}15.684{]}θρῴσκων ἄλλοτʼ ἐπʼ ἄλλον ἀμείβεται, οἳ δὲ πέτονται·{l]
[l [n}15.685{]}ὣς Αἴας ἐπὶ πολλὰ θοάων ἴκρια νηῶν{l]
[l [n}15.686{]}φοίτα μακρὰ βιβάς, φωνὴ δέ οἱ αἰθέρʼ ἵκανεν,{l]
[l [n}15.687{]}αἰεὶ δὲ σμερδνὸν βοόων Δαναοῖσι κέλευε{l]
[l [n}15.688{]}νηυσί τε καὶ κλισίῃσιν ἀμυνέμεν. οὐδὲ μὲν Ἕκτωρ{l]
[l [n}15.689{]}μίμνεν ἐνὶ Τρώων ὁμάδῳ πύκα θωρηκτάων·{l]
[l [n}15.690{]}ἀλλʼ ὥς τʼ ὀρνίθων πετεηνῶν αἰετὸς αἴθων{l]
[l [n}15.691{]}ἔθνος ἐφορμᾶται ποταμὸν πάρα βοσκομενάων{l]
[l [n}15.692{]}χηνῶν ἢ γεράνων ἢ κύκνων δουλιχοδείρων,{l]
[l [n}15.693{]}ὣς Ἕκτωρ ἴθυσε νεὸς κυανοπρῴροιο{l]
[l [n}15.694{]}ἀντίος ἀΐξας· τὸν δὲ Ζεὺς ὦσεν ὄπισθε{l]
[l [n}15.695{]}χειρὶ μάλα μεγάλῃ, ὄτρυνε δὲ λαὸν ἅμʼ αὐτῷ.{l]{para]
[para}[l [n}15.696{]}αὖτις δὲ δριμεῖα μάχη παρὰ νηυσὶν ἐτύχθη·{l]
[l [n}15.697{]}φαίης κʼ ἀκμῆτας καὶ ἀτειρέας ἀλλήλοισιν{l]
[l [n}15.698{]}ἄντεσθʼ ἐν πολέμῳ, ὡς ἐσσυμένως ἐμάχοντο.{l]
[l [n}15.699{]}τοῖσι δὲ μαρναμένοισιν ὅδʼ ἦν νόος· ἤτοι Ἀχαιοὶ{l]
[l [n}15.700{]}οὐκ ἔφασαν φεύξεσθαι ὑπʼ ἐκ κακοῦ, ἀλλʼ ὀλέεσθαι,{l]
[l [n}15.701{]}Τρωσὶν δʼ ἔλπετο θυμὸς ἐνὶ στήθεσσιν ἑκάστου{l]
[l [n}15.702{]}νῆας ἐνιπρήσειν κτενέειν θʼ ἥρωας Ἀχαιούς.{l]
[l [n}15.703{]}οἳ μὲν τὰ φρονέοντες ἐφέστασαν ἀλλήλοισιν·{l]
[l [n}15.704{]}Ἕκτωρ δὲ πρυμνῆς νεὸς ἥψατο ποντοπόροιο{l]
[l [n}15.705{]}καλῆς ὠκυάλου, ἣ Πρωτεσίλαον ἔνεικεν{l]
[l [n}15.706{]}ἐς Τροίην, οὐδʼ αὖτις ἀπήγαγε πατρίδα γαῖαν.{l]
[l [n}15.707{]}τοῦ περ δὴ περὶ νηὸς Ἀχαιοί τε Τρῶές τε{l]
[l [n}15.708{]}δῄουν ἀλλήλους αὐτοσχεδόν· οὐδʼ ἄρα τοί γε{l]
[l [n}15.709{]}τόξων ἀϊκὰς ἀμφὶς μένον οὐδʼ ἔτʼ ἀκόντων,{l]
[l [n}15.710{]}ἀλλʼ οἵ γʼ ἐγγύθεν ἱστάμενοι ἕνα θυμὸν ἔχοντες{l]
[l [n}15.711{]}ὀξέσι δὴ πελέκεσσι καὶ ἀξίνῃσι μάχοντο{l]
[l [n}15.712{]}καὶ ξίφεσιν μεγάλοισι καὶ ἔγχεσιν ἀμφιγύοισι.{l]
[l [n}15.713{]}πολλὰ δὲ φάσγανα καλὰ μελάνδετα κωπήεντα{l]
[l [n}15.714{]}ἄλλα μὲν ἐκ χειρῶν χαμάδις πέσον, ἄλλα δʼ ἀπʼ ὤμων{l]
[l [n}15.715{]}ἀνδρῶν μαρναμένων· ῥέε δʼ αἵματι γαῖα μέλαινα.{l]
[l [n}15.716{]}Ἕκτωρ δὲ πρύμνηθεν ἐπεὶ λάβεν οὐχὶ μεθίει{l]
[l [n}15.717{]}ἄφλαστον μετὰ χερσὶν ἔχων, Τρωσὶν δὲ κέλευεν·{l]
[q}[l [n}15.718{]}οἴσετε πῦρ, ἅμα δʼ αὐτοὶ ἀολλέες ὄρνυτʼ ἀϋτήν·{l]
[l [n}15.719{]}νῦν ἡμῖν πάντων Ζεὺς ἄξιον ἦμαρ ἔδωκε{l]
[l [n}15.720{]}νῆας ἑλεῖν, αἳ δεῦρο θεῶν ἀέκητι μολοῦσαι{l]
[l [n}15.721{]}ἡμῖν πήματα πολλὰ θέσαν, κακότητι γερόντων,{l]
[l [n}15.722{]}οἵ μʼ ἐθέλοντα μάχεσθαι ἐπὶ πρυμνῇσι νέεσσιν{l]
[l [n}15.723{]}αὐτόν τʼ ἰσχανάασκον ἐρητύοντό τε λαόν·{l]
[l [n}15.724{]}ἀλλʼ εἰ δή ῥα τότε βλάπτε φρένας εὐρύοπα Ζεὺς{l]
[l [n}15.725{]}ἡμετέρας, νῦν αὐτὸς ἐποτρύνει καὶ ἀνώγει.{l]{q]{para]
[para}[l [n}15.726{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα μᾶλλον ἐπʼ Ἀργείοισιν ὄρουσαν.{l]
[l [n}15.727{]}Αἴας δʼ οὐκέτʼ ἔμιμνε· βιάζετο γὰρ βελέεσσιν·{l]
[l [n}15.728{]}ἀλλʼ ἀνεχάζετο τυτθόν, ὀϊόμενος θανέεσθαι{l]
[l [n}15.729{]}θρῆνυν ἐφʼ ἑπταπόδην, λίπε δʼ ἴκρια νηὸς ἐΐσης.{l]
[l [n}15.730{]}ἔνθʼ ἄρʼ ὅ γʼ ἑστήκει δεδοκημένος, ἔγχεϊ δʼ αἰεὶ{l]
[l [n}15.731{]}Τρῶας ἄμυνε νεῶν, ὅς τις φέροι ἀκάματον πῦρ·{l]
[l [n}15.732{]}αἰεὶ δὲ σμερδνὸν βοόων Δαναοῖσι κέλευε·{l]
[q}[l [n}15.733{]}ὦ φίλοι ἥρωες Δαναοὶ θεράποντες Ἄρηος{l]
[l [n}15.734{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς.{l]
[l [n}15.735{]}ἠέ τινάς φαμεν εἶναι ἀοσσητῆρας ὀπίσσω,{l]
[l [n}15.736{]}ἦέ τι τεῖχος ἄρειον, ὅ κʼ ἀνδράσι λοιγὸν ἀμύναι;{l]
[l [n}15.737{]}οὐ μέν τι σχεδόν ἐστι πόλις πύργοις ἀραρυῖα,{l]
[l [n}15.738{]}ᾗ κʼ ἀπαμυναίμεσθʼ ἑτεραλκέα δῆμον ἔχοντες·{l]
[l [n}15.739{]}ἀλλʼ ἐν γὰρ Τρώων πεδίῳ πύκα θωρηκτάων{l]
[l [n}15.740{]}πόντῳ κεκλιμένοι ἑκὰς ἥμεθα πατρίδος αἴης·{l]
[l [n}15.741{]}τὼ ἐν χερσὶ φόως, οὐ μειλιχίῃ πολέμοιο.{l]{q]{para]
[para}[l [n}15.742{]}ἦ, καὶ μαιμώων ἔφεπʼ ἔγχεϊ ὀξυόεντι.{l]
[l [n}15.743{]}ὅς τις δὲ Τρώων κοίλῃς ἐπὶ νηυσὶ φέροιτο{l]
[l [n}15.744{]}σὺν πυρὶ κηλείῳ, χάριν Ἕκτορος ὀτρύναντος,{l]
[l [n}15.745{]}τὸν δʼ Αἴας οὔτασκε δεδεγμένος ἔγχεϊ μακρῷ·{l]
[l [n}15.746{]}δώδεκα δὲ προπάροιθε νεῶν αὐτοσχεδὸν οὖτα.{l]{para]
{book]
[book [n}16{]}
[para}[l [n}16.1{]}ὣς οἳ μὲν περὶ νηὸς ἐϋσσέλμοιο μάχοντο·{l]
[l [n}16.2{]}Πάτροκλος δʼ Ἀχιλῆϊ παρίστατο ποιμένι λαῶν{l]
[l [n}16.3{]}δάκρυα θερμὰ χέων ὥς τε κρήνη μελάνυδρος,{l]
[l [n}16.4{]}ἥ τε κατʼ αἰγίλιπος πέτρης δνοφερὸν χέει ὕδωρ.{l]
[l [n}16.5{]}τὸν δὲ ἰδὼν ᾤκτιρε ποδάρκης δῖος Ἀχιλλεύς,{l]
[l [n}16.6{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}16.7{]}τίπτε δεδάκρυσαι Πατρόκλεες, ἠΰτε κούρη{l]
[l [n}16.8{]}νηπίη, ἥ θʼ ἅμα μητρὶ θέουσʼ ἀνελέσθαι ἀνώγει{l]
[l [n}16.9{]}εἱανοῦ ἁπτομένη, καί τʼ ἐσσυμένην κατερύκει,{l]
[l [n}16.10{]}δακρυόεσσα δέ μιν ποτιδέρκεται, ὄφρʼ ἀνέληται·{l]
[l [n}16.11{]}τῇ ἴκελος Πάτροκλε τέρεν κατὰ δάκρυον εἴβεις.{l]
[l [n}16.12{]}ἠέ τι Μυρμιδόνεσσι πιφαύσκεαι, ἢ ἐμοὶ αὐτῷ,{l]
[l [n}16.13{]}ἦέ τινʼ ἀγγελίην Φθίης ἐξέκλυες οἶος;{l]
[l [n}16.14{]}ζώειν μὰν ἔτι φασὶ Μενοίτιον Ἄκτορος υἱόν,{l]
[l [n}16.15{]}ζώει δʼ Αἰακίδης Πηλεὺς μετὰ Μυρμιδόνεσσι;{l]
[l [n}16.16{]}τῶν κε μάλʼ ἀμφοτέρων ἀκαχοίμεθα τεθνηώτων.{l]
[l [n}16.17{]}ἦε σύ γʼ Ἀργείων ὀλοφύρεαι, ὡς ὀλέκονται{l]
[l [n}16.18{]}νηυσὶν ἔπι γλαφυρῇσιν ὑπερβασίης ἕνεκα σφῆς;{l]
[l [n}16.19{]}ἐξαύδα, μὴ κεῦθε νόῳ, ἵνα εἴδομεν ἄμφω.{l]{q]{para]
[para}[l [n}16.20{]}τὸν δὲ βαρὺ στενάχων προσέφης Πατρόκλεες ἱππεῦ·{l]
[q}[l [n}16.21{]}ὦ Ἀχιλεῦ Πηλῆος υἱὲ μέγα φέρτατʼ Ἀχαιῶν{l]
[l [n}16.22{]}μὴ νεμέσα· τοῖον γὰρ ἄχος βεβίηκεν Ἀχαιούς.{l]
[l [n}16.23{]}οἳ μὲν γὰρ δὴ πάντες, ὅσοι πάρος ἦσαν ἄριστοι,{l]
[l [n}16.24{]}ἐν νηυσὶν κέαται βεβλημένοι οὐτάμενοί τε.{l]
[l [n}16.25{]}βέβληται μὲν ὃ Τυδεΐδης κρατερὸς Διομήδης,{l]
[l [n}16.26{]}οὔτασται δʼ Ὀδυσεὺς δουρικλυτὸς ἠδʼ Ἀγαμέμνων,{l]
[l [n}16.27{]}βέβληται δὲ καὶ Εὐρύπυλος κατὰ μηρὸν ὀϊστῷ.{l]
[l [n}16.28{]}τοὺς μέν τʼ ἰητροὶ πολυφάρμακοι ἀμφιπένονται{l]
[l [n}16.29{]}ἕλκεʼ ἀκειόμενοι· σὺ δʼ ἀμήχανος ἔπλευ Ἀχιλλεῦ.{l]
[l [n}16.30{]}μὴ ἐμέ γʼ οὖν οὗτός γε λάβοι χόλος, ὃν σὺ φυλάσσεις{l]
[l [n}16.31{]}αἰναρέτη· τί σευ ἄλλος ὀνήσεται ὀψίγονός περ{l]
[l [n}16.32{]}αἴ κε μὴ Ἀργείοισιν ἀεικέα λοιγὸν ἀμύνῃς;{l]
[l [n}16.33{]}νηλεές, οὐκ ἄρα σοί γε πατὴρ ἦν ἱππότα Πηλεύς,{l]
[l [n}16.34{]}οὐδὲ Θέτις μήτηρ· γλαυκὴ δέ σε τίκτε θάλασσα{l]
[l [n}16.35{]}πέτραι τʼ ἠλίβατοι, ὅτι τοι νόος ἐστὶν ἀπηνής.{l]
[l [n}16.36{]}εἰ δέ τινα φρεσὶ σῇσι θεοπροπίην ἀλεείνεις{l]
[l [n}16.37{]}καί τινά τοι πὰρ Ζηνὸς ἐπέφραδε πότνια μήτηρ,{l]
[l [n}16.38{]}ἀλλʼ ἐμέ περ πρόες ὦχʼ, ἃμα δʼ ἄλλον λαὸν ὄπασσον{l]
[l [n}16.39{]}Μυρμιδόνων, ἤν πού τι φόως Δαναοῖσι γένωμαι.{l]
[l [n}16.40{]}δὸς δέ μοι ὤμοιιν τὰ σὰ τεύχεα θωρηχθῆναι,{l]
[l [n}16.41{]}αἴ κʼ ἐμὲ σοὶ ἴσκοντες ἀπόσχωνται πολέμοιο{l]
[l [n}16.42{]}Τρῶες, ἀναπνεύσωσι δʼ Ἀρήϊοι υἷες Ἀχαιῶν{l]
[l [n}16.43{]}τειρόμενοι· ὀλίγη δέ τʼ ἀνάπνευσις πολέμοιο.{l]
[l [n}16.44{]}ῥεῖα δέ κʼ ἀκμῆτες κεκμηότας ἄνδρας ἀϋτῇ{l]
[l [n}16.45{]}ὤσαιμεν προτὶ ἄστυ νεῶν ἄπο καὶ κλισιάων.{l]{q]{para]
[para}[l [n}16.46{]}ὣς φάτο λισσόμενος μέγα νήπιος· ἦ γὰρ ἔμελλεν{l]
[l [n}16.47{]}οἷ αὐτῷ θάνατόν τε κακὸν καὶ κῆρα λιτέσθαι.{l]
[l [n}16.48{]}τὸν δὲ μέγʼ ὀχθήσας προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}16.49{]}ὤ μοι διογενὲς Πατρόκλεες οἷον ἔειπες·{l]
[l [n}16.50{]}οὔτε θεοπροπίης ἐμπάζομαι ἥν τινα οἶδα,{l]
[l [n}16.51{]}οὔτέ τί μοι πὰρ Ζηνὸς ἐπέφραδε πότνια μήτηρ·{l]
[l [n}16.52{]}ἀλλὰ τόδʼ αἰνὸν ἄχος κραδίην καὶ θυμὸν ἱκάνει,{l]
[l [n}16.53{]}ὁππότε δὴ τὸν ὁμοῖον ἀνὴρ ἐθέλῃσιν ἀμέρσαι{l]
[l [n}16.54{]}καὶ γέρας ἂψ ἀφελέσθαι, ὅ τε κράτεϊ προβεβήκῃ·{l]
[l [n}16.55{]}αἰνὸν ἄχος τό μοί ἐστιν, ἐπεὶ πάθον ἄλγεα θυμῷ.{l]
[l [n}16.56{]}κούρην ἣν ἄρα μοι γέρας ἔξελον υἷες Ἀχαιῶν,{l]
[l [n}16.57{]}δουρὶ δʼ ἐμῷ κτεάτισσα πόλιν εὐτείχεα πέρσας,{l]
[l [n}16.58{]}τὴν ἂψ ἐκ χειρῶν ἕλετο κρείων Ἀγαμέμνων{l]
[l [n}16.59{]}Ἀτρεΐδης ὡς εἴ τινʼ ἀτίμητον μετανάστην.{l]
[l [n}16.60{]}ἀλλὰ τὰ μὲν προτετύχθαι ἐάσομεν· οὐδʼ ἄρα πως ἦν{l]
[l [n}16.61{]}ἀσπερχὲς κεχολῶσθαι ἐνὶ φρεσίν· ἤτοι ἔφην γε{l]
[l [n}16.62{]}οὐ πρὶν μηνιθμὸν καταπαυσέμεν, ἀλλʼ ὁπότʼ ἂν δὴ{l]
[l [n}16.63{]}νῆας ἐμὰς ἀφίκηται ἀϋτή τε πτόλεμός τε.{l]
[l [n}16.64{]}τύνη δʼ ὤμοιιν μὲν ἐμὰ κλυτὰ τεύχεα δῦθι,{l]
[l [n}16.65{]}ἄρχε δὲ Μυρμιδόνεσσι φιλοπτολέμοισι μάχεσθαι,{l]
[l [n}16.66{]}εἰ δὴ κυάνεον Τρώων νέφος ἀμφιβέβηκε{l]
[l [n}16.67{]}νηυσὶν ἐπικρατέως, οἳ δὲ ῥηγμῖνι θαλάσσης{l]
[l [n}16.68{]}κεκλίαται, χώρης ὀλίγην ἔτι μοῖραν ἔχοντες{l]
[l [n}16.69{]}Ἀργεῖοι, Τρώων δὲ πόλις ἐπὶ πᾶσα βέβηκε{l]
[l [n}16.70{]}θάρσυνος· οὐ γὰρ ἐμῆς κόρυθος λεύσσουσι μέτωπον{l]
[l [n}16.71{]}ἐγγύθι λαμπομένης· τάχα κεν φεύγοντες ἐναύλους{l]
[l [n}16.72{]}πλήσειαν νεκύων, εἴ μοι κρείων Ἀγαμέμνων{l]
[l [n}16.73{]}ἤπια εἰδείη· νῦν δὲ στρατὸν ἀμφιμάχονται.{l]
[l [n}16.74{]}οὐ γὰρ Τυδεΐδεω Διομήδεος ἐν παλάμῃσι{l]
[l [n}16.75{]}μαίνεται ἐγχείη Δαναῶν ἀπὸ λοιγὸν ἀμῦναι·{l]
[l [n}16.76{]}οὐδέ πω Ἀτρεΐδεω ὀπὸς ἔκλυον αὐδήσαντος{l]
[l [n}16.77{]}ἐχθρῆς ἐκ κεφαλῆς· ἀλλʼ Ἕκτορος ἀνδροφόνοιο{l]
[l [n}16.78{]}Τρωσὶ κελεύοντος περιάγνυται, οἳ δʼ ἀλαλητῷ{l]
[l [n}16.79{]}πᾶν πεδίον κατέχουσι μάχῃ νικῶντες Ἀχαιούς.{l]
[l [n}16.80{]}ἀλλὰ καὶ ὧς Πάτροκλε νεῶν ἄπο λοιγὸν ἀμύνων{l]
[l [n}16.81{]}ἔμπεσʼ ἐπικρατέως, μὴ δὴ πυρὸς αἰθομένοιο{l]
[l [n}16.82{]}νῆας ἐνιπρήσωσι, φίλον δʼ ἀπὸ νόστον ἕλωνται.{l]
[l [n}16.83{]}πείθεο δʼ ὥς τοι ἐγὼ μύθου τέλος ἐν φρεσὶ θείω,{l]
[l [n}16.84{]}ὡς ἄν μοι τιμὴν μεγάλην καὶ κῦδος ἄρηαι{l]
[l [n}16.85{]}πρὸς πάντων Δαναῶν, ἀτὰρ οἳ περικαλλέα κούρην{l]
[l [n}16.86{]}ἂψ ἀπονάσσωσιν, ποτὶ δʼ ἀγλαὰ δῶρα πόρωσιν.{l]
[l [n}16.87{]}ἐκ νηῶν ἐλάσας ἰέναι πάλιν· εἰ δέ κεν αὖ τοι{l]
[l [n}16.88{]}δώῃ κῦδος ἀρέσθαι ἐρίγδουπος πόσις Ἥρης,{l]
[l [n}16.89{]}μὴ σύ γʼ ἄνευθεν ἐμεῖο λιλαίεσθαι πολεμίζειν{l]
[l [n}16.90{]}Τρωσὶ φιλοπτολέμοισιν· ἀτιμότερον δέ με θήσεις·{l]
[l [n}16.91{]}μὴ δʼ ἐπαγαλλόμενος πολέμῳ καὶ δηϊοτῆτι{l]
[l [n}16.92{]}Τρῶας ἐναιρόμενος προτὶ Ἴλιον ἡγεμονεύειν,{l]
[l [n}16.93{]}μή τις ἀπʼ Οὐλύμποιο θεῶν αἰειγενετάων{l]
[l [n}16.94{]}ἐμβήῃ· μάλα τούς γε φιλεῖ ἑκάεργος Ἀπόλλων·{l]
[l [n}16.95{]}ἀλλὰ πάλιν τρωπᾶσθαι, ἐπὴν φάος ἐν νήεσσι{l]
[l [n}16.96{]}θήῃς, τοὺς δʼ ἔτʼ ἐᾶν πεδίον κάτα δηριάασθαι.{l]
[l [n}16.97{]}αἲ γὰρ Ζεῦ τε πάτερ καὶ Ἀθηναίη καὶ Ἄπολλον{l]
[l [n}16.98{]}μήτέ τις οὖν Τρώων θάνατον φύγοι ὅσσοι ἔασι,{l]
[l [n}16.99{]}μήτέ τις Ἀργείων, νῶϊν δʼ ἐκδῦμεν ὄλεθρον,{l]
[l [n}16.100{]}ὄφρʼ οἶοι Τροίης ἱερὰ κρήδεμνα λύωμεν.{l]{q]{para]
[para}[l [n}16.101{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον,{l]
[l [n}16.102{]}Αἴας δʼ οὐκ ἔτʼ ἔμιμνε· βιάζετο γὰρ βελέεσσι·{l]
[l [n}16.103{]}δάμνα μιν Ζηνός τε νόος καὶ Τρῶες ἀγαυοὶ{l]
[l [n}16.104{]}βάλλοντες· δεινὴν δὲ περὶ κροτάφοισι φαεινὴ{l]
[l [n}16.105{]}πήληξ βαλλομένη καναχὴν ἔχε, βάλλετο δʼ αἰεὶ{l]
[l [n}16.106{]}κὰπ φάλαρʼ εὐποίηθʼ· ὃ δʼ ἀριστερὸν ὦμον ἔκαμνεν{l]
[l [n}16.107{]}ἔμπεδον αἰὲν ἔχων σάκος αἰόλον· οὐδὲ δύναντο{l]
[l [n}16.108{]}ἀμφʼ αὐτῷ πελεμίξαι ἐρείδοντες βελέεσσιν.{l]
[l [n}16.109{]}αἰεὶ δʼ ἀργαλέῳ ἔχετʼ ἄσθματι, κὰδ δέ οἱ ἱδρὼς{l]
[l [n}16.110{]}πάντοθεν ἐκ μελέων πολὺς ἔρρεεν, οὐδέ πῃ εἶχεν{l]
[l [n}16.111{]}ἀμπνεῦσαι· πάντῃ δὲ κακὸν κακῷ ἐστήρικτο.{l]{para]
[para}[l [n}16.112{]}ἔσπετε νῦν μοι Μοῦσαι Ὀλύμπια δώματʼ ἔχουσαι,{l]
[l [n}16.113{]}ὅππως δὴ πρῶτον πῦρ ἔμπεσε νηυσὶν Ἀχαιῶν.{l]{para]
[para}[l [n}16.114{]}Ἕκτωρ Αἴαντος δόρυ μείλινον ἄγχι παραστὰς{l]
[l [n}16.115{]}πλῆξʼ ἄορι μεγάλῳ αἰχμῆς παρὰ καυλὸν ὄπισθεν,{l]
[l [n}16.116{]}ἀντικρὺ δʼ ἀπάραξε· τὸ μὲν Τελαμώνιος Αἴας{l]
[l [n}16.117{]}πῆλʼ αὔτως ἐν χειρὶ κόλον δόρυ, τῆλε δʼ ἀπʼ αὐτοῦ{l]
[l [n}16.118{]}αἰχμὴ χαλκείη χαμάδις βόμβησε πεσοῦσα.{l]
[l [n}16.119{]}γνῶ δʼ Αἴας κατὰ θυμὸν ἀμύμονα ῥίγησέν τε{l]
[l [n}16.120{]}ἔργα θεῶν, ὅ ῥα πάγχυ μάχης ἐπὶ μήδεα κεῖρε{l]
[l [n}16.121{]}Ζεὺς ὑψιβρεμέτης, Τρώεσσι δὲ βούλετο νίκην·{l]
[l [n}16.122{]}χάζετο δʼ ἐκ βελέων. τοὶ δʼ ἔμβαλον ἀκάματον πῦρ{l]
[l [n}16.123{]}νηῒ θοῇ· τῆς δʼ αἶψα κατʼ ἀσβέστη κέχυτο φλόξ.{l]
[l [n}16.124{]}ὣς τὴν μὲν πρυμνὴν πῦρ ἄμφεπεν· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}16.125{]}μηρὼ πληξάμενος Πατροκλῆα προσέειπεν·{l]
[q}[l [n}16.126{]}ὄρσεο διογενὲς Πατρόκλεες ἱπποκέλευθε·{l]
[l [n}16.127{]}λεύσσω δὴ παρὰ νηυσὶ πυρὸς δηΐοιο ἰωήν·{l]
[l [n}16.128{]}μὴ δὴ νῆας ἕλωσι καὶ οὐκέτι φυκτὰ πέλωνται·{l]
[l [n}16.129{]}δύσεο τεύχεα θᾶσσον, ἐγὼ δέ κε λαὸν ἀγείρω.{l]{q]{para]
[para}[l [n}16.130{]}ὣς φάτο, Πάτροκλος δὲ κορύσσετο νώροπι χαλκῷ.{l]
[l [n}16.131{]}κνημῖδας μὲν πρῶτα περὶ κνήμῃσιν ἔθηκε{l]
[l [n}16.132{]}καλάς, ἀργυρέοισιν ἐπισφυρίοις ἀραρυίας·{l]
[l [n}16.133{]}δεύτερον αὖ θώρηκα περὶ στήθεσσιν ἔδυνε{l]
[l [n}16.134{]}ποικίλον ἀστερόεντα ποδώκεος Αἰακίδαο.{l]
[l [n}16.135{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον{l]
[l [n}16.136{]}χάλκεον, αὐτὰρ ἔπειτα σάκος μέγα τε στιβαρόν τε·{l]
[l [n}16.137{]}κρατὶ δʼ ἐπʼ ἰφθίμῳ κυνέην εὔτυκτον ἔθηκεν{l]
[l [n}16.138{]}ἵππουριν· δεινὸν δὲ λόφος καθύπερθεν ἔνευεν.{l]
[l [n}16.139{]}εἵλετο δʼ ἄλκιμα δοῦρε, τά οἱ παλάμηφιν ἀρήρει.{l]
[l [n}16.140{]}ἔγχος δʼ οὐχ ἕλετʼ οἶον ἀμύμονος Αἰακίδαο{l]
[l [n}16.141{]}βριθὺ μέγα στιβαρόν· τὸ μὲν οὐ δύνατʼ ἄλλος Ἀχαιῶν{l]
[l [n}16.142{]}πάλλειν, ἀλλά μιν οἶος ἐπίστατο πῆλαι Ἀχιλλεὺς{l]
[l [n}16.143{]}Πηλιάδα μελίην, τὴν πατρὶ φίλῳ πόρε Χείρων{l]
[l [n}16.144{]}Πηλίου ἐκ κορυφῆς, φόνον ἔμμεναι ἡρώεσσιν.{l]
[l [n}16.145{]}ἵππους δʼ Αὐτομέδοντα θοῶς ζευγνῦμεν ἄνωγε,{l]
[l [n}16.146{]}τὸν μετʼ Ἀχιλλῆα ῥηξήνορα τῖε μάλιστα,{l]
[l [n}16.147{]}πιστότατος δέ οἱ ἔσκε μάχῃ ἔνι μεῖναι ὁμοκλήν.{l]
[l [n}16.148{]}τῷ δὲ καὶ Αὐτομέδων ὕπαγε ζυγὸν ὠκέας ἵππους{l]
[l [n}16.149{]}Ξάνθον καὶ Βαλίον, τὼ ἅμα πνοιῇσι πετέσθην,{l]
[l [n}16.150{]}τοὺς ἔτεκε Ζεφύρῳ ἀνέμῳ Ἅρπυια Ποδάργη{l]
[l [n}16.151{]}βοσκομένη λειμῶνι παρὰ ῥόον Ὠκεανοῖο.{l]
[l [n}16.152{]}ἐν δὲ παρηορίῃσιν ἀμύμονα Πήδασον ἵει,{l]
[l [n}16.153{]}τόν ῥά ποτʼ Ἠετίωνος ἑλὼν πόλιν ἤγαγʼ Ἀχιλλεύς,{l]
[l [n}16.154{]}ὃς καὶ θνητὸς ἐὼν ἕπεθʼ ἵπποις ἀθανάτοισι.{l]{para]
[para}[l [n}16.155{]}Μυρμιδόνας δʼ ἄρʼ ἐποιχόμενος θώρηξεν Ἀχιλλεὺς{l]
[l [n}16.156{]}πάντας ἀνὰ κλισίας σὺν τεύχεσιν· οἳ δὲ λύκοι ὣς{l]
[l [n}16.157{]}ὠμοφάγοι, τοῖσίν τε περὶ φρεσὶν ἄσπετος ἀλκή,{l]
[l [n}16.158{]}οἵ τʼ ἔλαφον κεραὸν μέγαν οὔρεσι δῃώσαντες{l]
[l [n}16.159{]}δάπτουσιν· πᾶσιν δὲ παρήϊον αἵματι φοινόν·{l]
[l [n}16.160{]}καί τʼ ἀγεληδὸν ἴασιν ἀπὸ κρήνης μελανύδρου{l]
[l [n}16.161{]}λάψοντες γλώσσῃσιν ἀραιῇσιν μέλαν ὕδωρ{l]
[l [n}16.162{]}ἄκρον ἐρευγόμενοι φόνον αἵματος· ἐν δέ τε θυμὸς{l]
[l [n}16.163{]}στήθεσιν ἄτρομός ἐστι, περιστένεται δέ τε γαστήρ·{l]
[l [n}16.164{]}τοῖοι Μυρμιδόνων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}16.165{]}ἀμφʼ ἀγαθὸν θεράποντα ποδώκεος Αἰακίδαο{l]
[l [n}16.166{]}ῥώοντʼ· ἐν δʼ ἄρα τοῖσιν ἀρήϊος ἵστατʼ Ἀχιλλεύς,{l]
[l [n}16.167{]}ὀτρύνων ἵππους τε καὶ ἀνέρας ἀσπιδιώτας.{l]{para]
[para}[l [n}16.168{]}πεντήκοντʼ ἦσαν νῆες θοαί, ᾗσιν Ἀχιλλεὺς{l]
[l [n}16.169{]}ἐς Τροίην ἡγεῖτο Διῒ φίλος· ἐν δὲ ἑκάστῃ{l]
[l [n}16.170{]}πεντήκοντʼ ἔσαν ἄνδρες ἐπὶ κληῗσιν ἑταῖροι·{l]
[l [n}16.171{]}πέντε δʼ ἄρʼ ἡγεμόνας ποιήσατο τοῖς ἐπεποίθει{l]
[l [n}16.172{]}σημαίνειν· αὐτὸς δὲ μέγα κρατέων ἤνασσε.{l]
[l [n}16.173{]}τῆς μὲν ἰῆς στιχὸς ἦρχε Μενέσθιος αἰολοθώρηξ{l]
[l [n}16.174{]}υἱὸς Σπερχειοῖο διιπετέος ποταμοῖο·{l]
[l [n}16.175{]}ὃν τέκε Πηλῆος θυγάτηρ καλὴ Πολυδώρη{l]
[l [n}16.176{]}Σπερχειῷ ἀκάμαντι γυνὴ θεῷ εὐνηθεῖσα,{l]
[l [n}16.177{]}αὐτὰρ ἐπίκλησιν Βώρῳ Περιήρεος υἷι,{l]
[l [n}16.178{]}ὅς ῥʼ ἀναφανδὸν ὄπυιε πορὼν ἀπερείσια ἕδνα.{l]
[l [n}16.179{]}τῆς δʼ ἑτέρης Εὔδωρος ἀρήϊος ἡγεμόνευε{l]
[l [n}16.180{]}παρθένιος, τὸν ἔτικτε χορῷ καλὴ Πολυμήλη{l]
[l [n}16.181{]}Φύλαντος θυγάτηρ· τῆς δὲ κρατὺς ἀργεϊφόντης{l]
[l [n}16.182{]}ἠράσατʼ, ὀφθαλμοῖσιν ἰδὼν μετὰ μελπομένῃσιν{l]
[l [n}16.183{]}ἐν χορῷ Ἀρτέμιδος χρυσηλακάτου κελαδεινῆς.{l]
[l [n}16.184{]}αὐτίκα δʼ εἰς ὑπερῷʼ ἀναβὰς παρελέξατο λάθρῃ{l]
[l [n}16.185{]}Ἑρμείας ἀκάκητα, πόρεν δέ οἱ ἀγλαὸν υἱὸν{l]
[l [n}16.186{]}Εὔδωρον πέρι μὲν θείειν ταχὺν ἠδὲ μαχητήν.{l]
[l [n}16.187{]}αὐτὰρ ἐπεὶ δὴ τόν γε μογοστόκος Εἰλείθυια{l]
[l [n}16.188{]}ἐξάγαγε πρὸ φόως δὲ καὶ ἠελίου ἴδεν αὐγάς,{l]
[l [n}16.189{]}τὴν μὲν Ἐχεκλῆος κρατερὸν μένος Ἀκτορίδαο{l]
[l [n}16.190{]}ἠγάγετο πρὸς δώματʼ, ἐπεὶ πόρε μυρία ἕδνα,{l]
[l [n}16.191{]}τὸν δʼ ὃ γέρων Φύλας εὖ ἔτρεφεν ἠδʼ ἀτίταλλεν{l]
[l [n}16.192{]}ἀμφαγαπαζόμενος ὡς εἴ θʼ ἑὸν υἱὸν ἐόντα.{l]
[l [n}16.193{]}τῆς δὲ τρίτης Πείσανδρος ἀρήϊος ἡγεμόνευε{l]
[l [n}16.194{]}Μαιμαλίδης, ὃς πᾶσι μετέπρεπε Μυρμιδόνεσσιν{l]
[l [n}16.195{]}ἔγχεϊ μάρνασθαι μετὰ Πηλεΐωνος ἑταῖρον.{l]
[l [n}16.196{]}τῆς δὲ τετάρτης ἦρχε γέρων ἱππηλάτα Φοῖνιξ,{l]
[l [n}16.197{]}πέμπτης δʼ Ἀλκιμέδων Λαέρκεος υἱὸς ἀμύμων.{l]
[l [n}16.198{]}αὐτὰρ ἐπεὶ δὴ πάντας ἅμʼ ἡγεμόνεσσιν Ἀχιλλεὺς{l]
[l [n}16.199{]}στῆσεν ἐῢ κρίνας, κρατερὸν δʼ ἐπὶ μῦθον ἔτελλε·{l]
[q}[l [n}16.200{]}Μυρμιδόνες μή τίς μοι ἀπειλάων λελαθέσθω,{l]
[l [n}16.201{]}ἃς ἐπὶ νηυσὶ θοῇσιν ἀπειλεῖτε Τρώεσσι{l]
[l [n}16.202{]}πάνθʼ ὑπὸ μηνιθμόν, καί μʼ ᾐτιάασθε ἕκαστος·{l]
[l [n}16.203{]}σχέτλιε Πηλέος υἱὲ χόλῳ ἄρα σʼ ἔτρεφε μήτηρ,{l]
[l [n}16.204{]}νηλεές, ὃς παρὰ νηυσὶν ἔχεις ἀέκοντας ἑταίρους·{l]
[l [n}16.205{]}οἴκαδέ περ σὺν νηυσὶ νεώμεθα ποντοπόροισιν{l]
[l [n}16.206{]}αὖτις, ἐπεί ῥά τοι ὧδε κακὸς χόλος ἔμπεσε θυμῷ.{l]
[l [n}16.207{]}ταῦτά μʼ ἀγειρόμενοι θάμʼ ἐβάζετε· νῦν δὲ πέφανται{l]
[l [n}16.208{]}φυλόπιδος μέγα ἔργον, ἕης τὸ πρίν γʼ ἐράασθε.{l]
[l [n}16.209{]}ἔνθά τις ἄλκιμον ἦτορ ἔχων Τρώεσσι μαχέσθω.{l]{q]{para]
[para}[l [n}16.210{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου.{l]
[l [n}16.211{]}μᾶλλον δὲ στίχες ἄρθεν, ἐπεὶ βασιλῆος ἄκουσαν.{l]
[l [n}16.212{]}ὡς δʼ ὅτε τοῖχον ἀνὴρ ἀράρῃ πυκινοῖσι λίθοισι{l]
[l [n}16.213{]}δώματος ὑψηλοῖο βίας ἀνέμων ἀλεείνων,{l]
[l [n}16.214{]}ὣς ἄραρον κόρυθές τε καὶ ἀσπίδες ὀμφαλόεσσαι.{l]
[l [n}16.215{]}ἀσπὶς ἄρʼ ἀσπίδʼ ἔρειδε, κόρυς κόρυν, ἀνέρα δʼ ἀνήρ·{l]
[l [n}16.216{]}ψαῦον δʼ ἱππόκομοι κόρυθες λαμπροῖσι φάλοισι{l]
[l [n}16.217{]}νευόντων, ὡς πυκνοὶ ἐφέστασαν ἀλλήλοισι.{l]
[l [n}16.218{]}πάντων δὲ προπάροιθε δύʼ ἀνέρε θωρήσσοντο{l]
[l [n}16.219{]}Πάτροκλός τε καὶ Αὐτομέδων ἕνα θυμὸν ἔχοντες{l]
[l [n}16.220{]}πρόσθεν Μυρμιδόνων πολεμιζέμεν. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}16.221{]}βῆ ῥʼ ἴμεν ἐς κλισίην, χηλοῦ δʼ ἀπὸ πῶμʼ ἀνέῳγε{l]
[l [n}16.222{]}καλῆς δαιδαλέης, τήν οἱ Θέτις ἀργυρόπεζα{l]
[l [n}16.223{]}θῆκʼ ἐπὶ νηὸς ἄγεσθαι ἐῢ πλήσασα χιτώνων{l]
[l [n}16.224{]}χλαινάων τʼ ἀνεμοσκεπέων οὔλων τε ταπήτων.{l]
[l [n}16.225{]}ἔνθα δέ οἱ δέπας ἔσκε τετυγμένον, οὐδέ τις ἄλλος{l]
[l [n}16.226{]}οὔτʼ ἀνδρῶν πίνεσκεν ἀπʼ αὐτοῦ αἴθοπα οἶνον,{l]
[l [n}16.227{]}οὔτέ τεῳ σπένδεσκε θεῶν, ὅτε μὴ Διὶ πατρί.{l]
[l [n}16.228{]}τό ῥα τότʼ ἐκ χηλοῖο λαβὼν ἐκάθηρε θεείῳ{l]
[l [n}16.229{]}πρῶτον, ἔπειτα δʼ ἔνιψʼ ὕδατος καλῇσι ῥοῇσι,{l]
[l [n}16.230{]}νίψατο δʼ αὐτὸς χεῖρας, ἀφύσσατο δʼ αἴθοπα οἶνον.{l]
[l [n}16.231{]}εὔχετʼ ἔπειτα στὰς μέσῳ ἕρκεϊ, λεῖβε δὲ οἶνον{l]
[l [n}16.232{]}οὐρανὸν εἰσανιδών· Δία δʼ οὐ λάθε τερπικέραυνον·{l]
[q}[l [n}16.233{]}Ζεῦ ἄνα Δωδωναῖε Πελασγικὲ τηλόθι ναίων{l]
[l [n}16.234{]}Δωδώνης μεδέων δυσχειμέρου, ἀμφὶ δὲ Σελλοὶ{l]
[l [n}16.235{]}σοὶ ναίουσʼ ὑποφῆται ἀνιπτόποδες χαμαιεῦναι,{l]
[l [n}16.236{]}ἠμὲν δή ποτʼ ἐμὸν ἔπος ἔκλυες εὐξαμένοιο,{l]
[l [n}16.237{]}τίμησας μὲν ἐμέ, μέγα δʼ ἴψαο λαὸν Ἀχαιῶν,{l]
[l [n}16.238{]}ἠδʼ ἔτι καὶ νῦν μοι τόδʼ ἐπικρήηνον ἐέλδωρ·{l]
[l [n}16.239{]}αὐτὸς μὲν γὰρ ἐγὼ μενέω νηῶν ἐν ἀγῶνι,{l]
[l [n}16.240{]}ἀλλʼ ἕταρον πέμπω πολέσιν μετὰ Μυρμιδόνεσσι{l]
[l [n}16.241{]}μάρνασθαι· τῷ κῦδος ἅμα πρόες εὐρύοπα Ζεῦ,{l]
[l [n}16.242{]}θάρσυνον δέ οἱ ἦτορ ἐνὶ φρεσίν, ὄφρα καὶ Ἕκτωρ{l]
[l [n}16.243{]}εἴσεται ἤ ῥα καὶ οἶος ἐπίστηται πολεμίζειν{l]
[l [n}16.244{]}ἡμέτερος θεράπων, ἦ οἱ τότε χεῖρες ἄαπτοι{l]
[l [n}16.245{]}μαίνονθʼ, ὁππότʼ ἐγώ περ ἴω μετὰ μῶλον Ἄρηος.{l]
[l [n}16.246{]}αὐτὰρ ἐπεί κʼ ἀπὸ ναῦφι μάχην ἐνοπήν τε δίηται,{l]
[l [n}16.247{]}ἀσκηθής μοι ἔπειτα θοὰς ἐπὶ νῆας ἵκοιτο{l]
[l [n}16.248{]}τεύχεσί τε ξὺν πᾶσι καὶ ἀγχεμάχοις ἑτάροισιν.{l]{q]{para]
[para}[l [n}16.249{]}ὣς ἔφατʼ εὐχόμενος, τοῦ δʼ ἔκλυε μητίετα Ζεύς.{l]
[l [n}16.250{]}τῷ δʼ ἕτερον μὲν ἔδωκε πατήρ, ἕτερον δʼ ἀνένευσε·{l]
[l [n}16.251{]}νηῶν μέν οἱ ἀπώσασθαι πόλεμόν τε μάχην τε{l]
[l [n}16.252{]}δῶκε, σόον δʼ ἀνένευσε μάχης ἐξαπονέεσθαι.{l]
[l [n}16.253{]}ἤτοι ὃ μὲν σπείσας τε καὶ εὐξάμενος Διὶ πατρὶ{l]
[l [n}16.254{]}ἂψ κλισίην εἰσῆλθε, δέπας δʼ ἀπέθηκʼ ἐνὶ χηλῷ,{l]
[l [n}16.255{]}στῆ δὲ πάροιθʼ ἐλθὼν κλισίης, ἔτι δʼ ἤθελε θυμῷ{l]
[l [n}16.256{]}εἰσιδέειν Τρώων καὶ Ἀχαιῶν φύλοπιν αἰνήν.{l]{para]
[para}[l [n}16.257{]}οἳ δʼ ἅμα Πατρόκλῳ μεγαλήτορι θωρηχθέντες{l]
[l [n}16.258{]}ἔστιχον, ὄφρʼ ἐν Τρωσὶ μέγα φρονέοντες ὄρουσαν.{l]
[l [n}16.259{]}αὐτίκα δὲ σφήκεσσιν ἐοικότες ἐξεχέοντο{l]
[l [n}16.260{]}εἰνοδίοις, οὓς παῖδες ἐριδμαίνωσιν ἔθοντες{l]
[l [n}16.261{]}αἰεὶ κερτομέοντες ὁδῷ ἔπι οἰκίʼ ἔχοντας{l]
[l [n}16.262{]}νηπίαχοι· ξυνὸν δὲ κακὸν πολέεσσι τιθεῖσι.{l]
[l [n}16.263{]}τοὺς δʼ εἴ περ παρά τίς τε κιὼν ἄνθρωπος ὁδίτης{l]
[l [n}16.264{]}κινήσῃ ἀέκων, οἳ δʼ ἄλκιμον ἦτορ ἔχοντες{l]
[l [n}16.265{]}πρόσσω πᾶς πέτεται καὶ ἀμύνει οἷσι τέκεσσι.{l]
[l [n}16.266{]}τῶν τότε Μυρμιδόνες κραδίην καὶ θυμὸν ἔχοντες{l]
[l [n}16.267{]}ἐκ νηῶν ἐχέοντο· βοὴ δʼ ἄσβεστος ὀρώρει.{l]
[l [n}16.268{]}Πάτροκλος δʼ ἑτάροισιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}16.269{]}Μυρμιδόνες ἕταροι Πηληϊάδεω Ἀχιλῆος{l]
[l [n}16.270{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς,{l]
[l [n}16.271{]}ὡς ἂν Πηλεΐδην τιμήσομεν, ὃς μέγʼ ἄριστος{l]
[l [n}16.272{]}Ἀργείων παρὰ νηυσὶ καὶ ἀγχέμαχοι θεράποντες,{l]
[l [n}16.273{]}γνῷ δὲ καὶ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων{l]
[l [n}16.274{]}ἣν ἄτην, ὅ τʼ ἄριστον Ἀχαιῶν οὐδὲν ἔτισεν.{l]{q]{para]
[para}[l [n}16.275{]}ὣς εἰπὼν ὄτρυνε μένος καὶ θυμὸν ἑκάστου,{l]
[l [n}16.276{]}ἐν δʼ ἔπεσον Τρώεσσιν ἀολλέες· ἀμφὶ δὲ νῆες{l]
[l [n}16.277{]}σμερδαλέον κονάβησαν ἀϋσάντων ὑπʼ Ἀχαιῶν.{l]{para]
[para}[l [n}16.278{]}Τρῶες δʼ ὡς εἴδοντο Μενοιτίου ἄλκιμον υἱὸν{l]
[l [n}16.279{]}αὐτὸν καὶ θεράποντα σὺν ἔντεσι μαρμαίροντας,{l]
[l [n}16.280{]}πᾶσιν ὀρίνθη θυμός, ἐκίνηθεν δὲ φάλαγγες{l]
[l [n}16.281{]}ἐλπόμενοι παρὰ ναῦφι ποδώκεα Πηλεΐωνα{l]
[l [n}16.282{]}μηνιθμὸν μὲν ἀπορρῖψαι, φιλότητα δʼ ἑλέσθαι·{l]
[l [n}16.283{]}πάπτηνεν δὲ ἕκαστος ὅπῃ φύγοι αἰπὺν ὄλεθρον.{l]{para]
[para}[l [n}16.284{]}Πάτροκλος δὲ πρῶτος ἀκόντισε δουρὶ φαεινῷ{l]
[l [n}16.285{]}ἀντικρὺ κατὰ μέσσον, ὅθι πλεῖστοι κλονέοντο,{l]
[l [n}16.286{]}νηῒ πάρα πρυμνῇ μεγαθύμου Πρωτεσιλάου,{l]
[l [n}16.287{]}καὶ βάλε Πυραίχμην, ὃς Παίονας ἱπποκορυστὰς{l]
[l [n}16.288{]}ἤγαγεν ἐξ Ἀμυδῶνος ἀπʼ Ἀξιοῦ εὐρὺ ῥέοντος·{l]
[l [n}16.289{]}τὸν βάλε δεξιὸν ὦμον· ὃ δʼ ὕπτιος ἐν κονίῃσι{l]
[l [n}16.290{]}κάππεσεν οἰμώξας, ἕταροι δέ μιν ἀμφεφόβηθεν{l]
[l [n}16.291{]}Παίονες· ἐν γὰρ Πάτροκλος φόβον ἧκεν ἅπασιν{l]
[l [n}16.292{]}ἡγεμόνα κτείνας, ὃς ἀριστεύεσκε μάχεσθαι.{l]
[l [n}16.293{]}ἐκ νηῶν δʼ ἔλασεν, κατὰ δʼ ἔσβεσεν αἰθόμενον πῦρ.{l]
[l [n}16.294{]}ἡμιδαὴς δʼ ἄρα νηῦς λίπετʼ αὐτόθι· τοὶ δὲ φόβηθεν{l]
[l [n}16.295{]}Τρῶες θεσπεσίῳ ὁμάδῳ· Δαναοὶ δʼ ἐπέχυντο{l]
[l [n}16.296{]}νῆας ἀνὰ γλαφυράς· ὅμαδος δʼ ἀλίαστος ἐτύχθη.{l]
[l [n}16.297{]}ὡς δʼ ὅτʼ ἀφʼ ὑψηλῆς κορυφῆς ὄρεος μεγάλοιο{l]
[l [n}16.298{]}κινήσῃ πυκινὴν νεφέλην στεροπηγερέτα Ζεύς,{l]
[l [n}16.299{]}ἔκ τʼ ἔφανεν πᾶσαι σκοπιαὶ καὶ πρώονες ἄκροι{l]
[l [n}16.300{]}καὶ νάπαι, οὐρανόθεν δʼ ἄρʼ ὑπερράγη ἄσπετος αἰθήρ,{l]
[l [n}16.301{]}ὣς Δαναοὶ νηῶν μὲν ἀπωσάμενοι δήϊον πῦρ{l]
[l [n}16.302{]}τυτθὸν ἀνέπνευσαν, πολέμου δʼ οὐ γίγνετʼ ἐρωή·{l]
[l [n}16.303{]}οὐ γάρ πώ τι Τρῶες ἀρηϊφίλων ὑπʼ Ἀχαιῶν{l]
[l [n}16.304{]}προτροπάδην φοβέοντο μελαινάων ἀπὸ νηῶν,{l]
[l [n}16.305{]}ἀλλʼ ἔτʼ ἄρʼ ἀνθίσταντο, νεῶν δʼ ὑπόεικον ἀνάγκῃ.{l]{para]
[para}[l [n}16.306{]}ἔνθα δʼ ἀνὴρ ἕλεν ἄνδρα κεδασθείσης ὑσμίνης{l]
[l [n}16.307{]}ἡγεμόνων. πρῶτος δὲ Μενοιτίου ἄλκιμος υἱὸς{l]
[l [n}16.308{]}αὐτίκʼ ἄρα στρεφθέντος Ἀρηϊλύκου βάλε μηρὸν{l]
[l [n}16.309{]}ἔγχεϊ ὀξυόεντι, διὰ πρὸ δὲ χαλκὸν ἔλασσε·{l]
[l [n}16.310{]}ῥῆξεν δʼ ὀστέον ἔγχος, ὃ δὲ πρηνὴς ἐπὶ γαίῃ{l]
[l [n}16.311{]}κάππεσʼ· ἀτὰρ Μενέλαος ἀρήϊος οὖτα Θόαντα{l]
[l [n}16.312{]}στέρνον γυμνωθέντα παρʼ ἀσπίδα, λῦσε δὲ γυῖα.{l]
[l [n}16.313{]}Φυλεΐδης δʼ Ἄμφικλον ἐφορμηθέντα δοκεύσας{l]
[l [n}16.314{]}ἔφθη ὀρεξάμενος πρυμνὸν σκέλος, ἔνθα πάχιστος{l]
[l [n}16.315{]}μυὼν ἀνθρώπου πέλεται· περὶ δʼ ἔγχεος αἰχμῇ{l]
[l [n}16.316{]}νεῦρα διεσχίσθη· τὸν δὲ σκότος ὄσσε κάλυψε.{l]
[l [n}16.317{]}Νεστορίδαι δʼ ὃ μὲν οὔτασʼ Ἀτύμνιον ὀξέϊ δουρὶ{l]
[l [n}16.318{]}Ἀντίλοχος, λαπάρης δὲ διήλασε χάλκεον ἔγχος·{l]
[l [n}16.319{]}ἤριπε δὲ προπάροιθε. Μάρις δʼ αὐτοσχεδὰ δουρὶ{l]
[l [n}16.320{]}Ἀντιλόχῳ ἐπόρουσε κασιγνήτοιο χολωθεὶς{l]
[l [n}16.321{]}στὰς πρόσθεν νέκυος· τοῦ δʼ ἀντίθεος Θρασυμήδης{l]
[l [n}16.322{]}ἔφθη ὀρεξάμενος πρὶν οὐτάσαι, οὐδʼ ἀφάμαρτεν,{l]
[l [n}16.323{]}ὦμον ἄφαρ· πρυμνὸν δὲ βραχίονα δουρὸς ἀκωκὴ{l]
[l [n}16.324{]}δρύψʼ ἀπὸ μυώνων, ἀπὸ δʼ ὀστέον ἄχρις ἄραξε·{l]
[l [n}16.325{]}δούπησεν δὲ πεσών, κατὰ δὲ σκότος ὄσσε κάλυψεν.{l]
[l [n}16.326{]}ὣς τὼ μὲν δοιοῖσι κασιγνήτοισι δαμέντε{l]
[l [n}16.327{]}βήτην εἰς Ἔρεβος Σαρπηδόνος ἐσθλοὶ ἑταῖροι{l]
[l [n}16.328{]}υἷες ἀκοντισταὶ Ἀμισωδάρου, ὅς ῥα Χίμαιραν{l]
[l [n}16.329{]}θρέψεν ἀμαιμακέτην πολέσιν κακὸν ἀνθρώποισιν.{l]
[l [n}16.330{]}Αἴας δὲ Κλεόβουλον Ὀϊλιάδης ἐπορούσας{l]
[l [n}16.331{]}ζωὸν ἕλε βλαφθέντα κατὰ κλόνον· ἀλλά οἱ αὖθι{l]
[l [n}16.332{]}λῦσε μένος πλήξας ξίφει αὐχένα κωπήεντι.{l]
[l [n}16.333{]}πᾶν δʼ ὑπεθερμάνθη ξίφος αἵματι· τὸν δὲ κατʼ ὄσσε{l]
[l [n}16.334{]}ἔλλαβε πορφύρεος θάνατος καὶ μοῖρα κραταιή.{l]
[l [n}16.335{]}Πηνέλεως δὲ Λύκων τε συνέδραμον· ἔγχεσι μὲν γὰρ{l]
[l [n}16.336{]}ἤμβροτον ἀλλήλων, μέλεον δʼ ἠκόντισαν ἄμφω·{l]
[l [n}16.337{]}τὼ δʼ αὖτις ξιφέεσσι συνέδραμον. ἔνθα Λύκων μὲν{l]
[l [n}16.338{]}ἱπποκόμου κόρυθος φάλον ἤλασεν, ἀμφὶ δὲ καυλὸν{l]
[l [n}16.339{]}φάσγανον ἐρραίσθη· ὃ δʼ ὑπʼ οὔατος αὐχένα θεῖνε{l]
[l [n}16.340{]}Πηνέλεως, πᾶν δʼ εἴσω ἔδυ ξίφος, ἔσχεθε δʼ οἶον{l]
[l [n}16.341{]}δέρμα, παρηέρθη δὲ κάρη, ὑπέλυντο δὲ γυῖα.{l]
[l [n}16.342{]}Μηριόνης δʼ Ἀκάμαντα κιχεὶς ποσὶ καρπαλίμοισι{l]
[l [n}16.343{]}νύξʼ ἵππων ἐπιβησόμενον κατὰ δεξιὸν ὦμον·{l]
[l [n}16.344{]}ἤριπε δʼ ἐξ ὀχέων, κατὰ δʼ ὀφθαλμῶν κέχυτʼ ἀχλύς.{l]
[l [n}16.345{]}Ἰδομενεὺς δʼ Ἐρύμαντα κατὰ στόμα νηλέϊ χαλκῷ{l]
[l [n}16.346{]}νύξε· τὸ δʼ ἀντικρὺ δόρυ χάλκεον ἐξεπέρησε{l]
[l [n}16.347{]}νέρθεν ὑπʼ ἐγκεφάλοιο, κέασσε δʼ ἄρʼ ὀστέα λευκά·{l]
[l [n}16.348{]}ἐκ δʼ ἐτίναχθεν ὀδόντες, ἐνέπλησθεν δέ οἱ ἄμφω{l]
[l [n}16.349{]}αἵματος ὀφθαλμοί· τὸ δʼ ἀνὰ στόμα καὶ κατὰ ῥῖνας{l]
[l [n}16.350{]}πρῆσε χανών· θανάτου δὲ μέλαν νέφος ἀμφεκάλυψεν.{l]{para]
[para}[l [n}16.351{]}οὗτοι ἄρʼ ἡγεμόνες Δαναῶν ἕλον ἄνδρα ἕκαστος.{l]
[l [n}16.352{]}ὡς δὲ λύκοι ἄρνεσσιν ἐπέχραον ἢ ἐρίφοισι{l]
[l [n}16.353{]}σίνται ὑπʼ ἐκ μήλων αἱρεύμενοι, αἵ τʼ ἐν ὄρεσσι{l]
[l [n}16.354{]}ποιμένος ἀφραδίῃσι διέτμαγεν· οἳ δὲ ἰδόντες{l]
[l [n}16.355{]}αἶψα διαρπάζουσιν ἀνάλκιδα θυμὸν ἐχούσας·{l]
[l [n}16.356{]}ὣς Δαναοὶ Τρώεσσιν ἐπέχραον· οἳ δὲ φόβοιο{l]
[l [n}16.357{]}δυσκελάδου μνήσαντο, λάθοντο δὲ θούριδος ἀλκῆς.{l]{para]
[para}[l [n}16.358{]}Αἴας δʼ ὃ μέγας αἰὲν ἐφʼ Ἕκτορι χαλκοκορυστῇ{l]
[l [n}16.359{]}ἵετʼ ἀκοντίσσαι· ὃ δὲ ἰδρείῃ πολέμοιο{l]
[l [n}16.360{]}ἀσπίδι ταυρείῃ κεκαλυμμένος εὐρέας ὤμους{l]
[l [n}16.361{]}σκέπτετʼ ὀϊστῶν τε ῥοῖζον καὶ δοῦπον ἀκόντων.{l]
[l [n}16.362{]}ἦ μὲν δὴ γίγνωσκε μάχης ἑτεραλκέα νίκην·{l]
[l [n}16.363{]}ἀλλὰ καὶ ὧς ἀνέμιμνε, σάω δʼ ἐρίηρας ἑταίρους.{l]{para]
[para}[l [n}16.364{]}ὡς δʼ ὅτʼ ἀπʼ Οὐλύμπου νέφος ἔρχεται οὐρανὸν εἴσω{l]
[l [n}16.365{]}αἰθέρος ἐκ δίης, ὅτε τε Ζεὺς λαίλαπα τείνῃ,{l]
[l [n}16.366{]}ὣς τῶν ἐκ νηῶν γένετο ἰαχή τε φόβος τε,{l]
[l [n}16.367{]}οὐδὲ κατὰ μοῖραν πέραον πάλιν. Ἕκτορα δʼ ἵπποι{l]
[l [n}16.368{]}ἔκφερον ὠκύποδες σὺν τεύχεσι, λεῖπε δὲ λαὸν{l]
[l [n}16.369{]}Τρωϊκόν, οὓς ἀέκοντας ὀρυκτὴ τάφρος ἔρυκε.{l]
[l [n}16.370{]}πολλοὶ δʼ ἐν τάφρῳ ἐρυσάρματες ὠκέες ἵπποι{l]
[l [n}16.371{]}ἄξαντʼ ἐν πρώτῳ ῥυμῷ λίπον ἅρματʼ ἀνάκτων,{l]
[l [n}16.372{]}Πάτροκλος δʼ ἕπετο σφεδανὸν Δαναοῖσι κελεύων{l]
[l [n}16.373{]}Τρωσὶ κακὰ φρονέων· οἳ δὲ ἰαχῇ τε φόβῳ τε{l]
[l [n}16.374{]}πάσας πλῆσαν ὁδούς, ἐπεὶ ἂρ τμάγεν· ὕψι δʼ ἀέλλη{l]
[l [n}16.375{]}σκίδναθʼ ὑπὸ νεφέων, τανύοντο δὲ μώνυχες ἵπποι{l]
[l [n}16.376{]}ἄψορρον προτὶ ἄστυ νεῶν ἄπο καὶ κλισιάων.{l]
[l [n}16.377{]}Πάτροκλος δʼ ᾗ πλεῖστον ὀρινόμενον ἴδε λαόν,{l]
[l [n}16.378{]}τῇ ῥʼ ἔχʼ ὁμοκλήσας· ὑπὸ δʼ ἄξοσι φῶτες ἔπιπτον{l]
[l [n}16.379{]}πρηνέες ἐξ ὀχέων, δίφροι δʼ ἀνακυμβαλίαζον.{l]
[l [n}16.380{]}ἀντικρὺ δʼ ἄρα τάφρον ὑπέρθορον ὠκέες ἵπποι{l]
[l [n}16.381{]}ἄμβροτοι, οὓς Πηλῆϊ θεοὶ δόσαν ἀγλαὰ δῶρα,{l]
[l [n}16.382{]}πρόσσω ἱέμενοι, ἐπὶ δʼ Ἕκτορι κέκλετο θυμός·{l]
[l [n}16.383{]}ἵετο γὰρ βαλέειν· τὸν δʼ ἔκφερον ὠκέες ἵπποι.{l]
[l [n}16.384{]}ὡς δʼ ὑπὸ λαίλαπι πᾶσα κελαινὴ βέβριθε χθὼν{l]
[l [n}16.385{]}ἤματʼ ὀπωρινῷ, ὅτε λαβρότατον χέει ὕδωρ{l]
[l [n}16.386{]}Ζεύς, ὅτε δή ῥʼ ἄνδρεσσι κοτεσσάμενος χαλεπήνῃ,{l]
[l [n}16.387{]}οἳ βίῃ εἰν ἀγορῇ σκολιὰς κρίνωσι θέμιστας,{l]
[l [n}16.388{]}ἐκ δὲ δίκην ἐλάσωσι θεῶν ὄπιν οὐκ ἀλέγοντες·{l]
[l [n}16.389{]}τῶν δέ τε πάντες μὲν ποταμοὶ πλήθουσι ῥέοντες,{l]
[l [n}16.390{]}πολλὰς δὲ κλιτῦς τότʼ ἀποτμήγουσι χαράδραι,{l]
[l [n}16.391{]}ἐς δʼ ἅλα πορφυρέην μεγάλα στενάχουσι ῥέουσαι{l]
[l [n}16.392{]}ἐξ ὀρέων ἐπικάρ, μινύθει δέ τε ἔργʼ ἀνθρώπων·{l]
[l [n}16.393{]}ὣς ἵπποι Τρῳαὶ μεγάλα στενάχοντο θέουσαι.{l]{para]
[para}[l [n}16.394{]}Πάτροκλος δʼ ἐπεὶ οὖν πρώτας ἐπέκερσε φάλαγγας,{l]
[l [n}16.395{]}ἂψ ἐπὶ νῆας ἔεργε παλιμπετές, οὐδὲ πόληος{l]
[l [n}16.396{]}εἴα ἱεμένους ἐπιβαινέμεν, ἀλλὰ μεσηγὺ{l]
[l [n}16.397{]}νηῶν καὶ ποταμοῦ καὶ τείχεος ὑψηλοῖο{l]
[l [n}16.398{]}κτεῖνε μεταΐσσων, πολέων δʼ ἀπετίνυτο ποινήν.{l]
[l [n}16.399{]}ἔνθʼ ἤτοι Πρόνοον πρῶτον βάλε δουρὶ φαεινῷ{l]
[l [n}16.400{]}στέρνον γυμνωθέντα παρʼ ἀσπίδα, λῦσε δὲ γυῖα·{l]
[l [n}16.401{]}δούπησεν δὲ πεσών· ὃ δὲ Θέστορα Ἤνοπος υἱὸν{l]
[l [n}16.402{]}δεύτερον ὁρμηθείς· ὃ μὲν εὐξέστῳ ἐνὶ δίφρῳ{l]
[l [n}16.403{]}ἧστο ἀλείς· ἐκ γὰρ πλήγη φρένας, ἐκ δʼ ἄρα χειρῶν{l]
[l [n}16.404{]}ἡνία ἠΐχθησαν· ὃ δʼ ἔγχεϊ νύξε παραστὰς{l]
[l [n}16.405{]}γναθμὸν δεξιτερόν, διὰ δʼ αὐτοῦ πεῖρεν ὀδόντων,{l]
[l [n}16.406{]}ἕλκε δὲ δουρὸς ἑλὼν ὑπὲρ ἄντυγος, ὡς ὅτε τις φὼς{l]
[l [n}16.407{]}πέτρῃ ἔπι προβλῆτι καθήμενος ἱερὸν ἰχθὺν{l]
[l [n}16.408{]}ἐκ πόντοιο θύραζε λίνῳ καὶ ἤνοπι χαλκῷ·{l]
[l [n}16.409{]}ὣς ἕλκʼ ἐκ δίφροιο κεχηνότα δουρὶ φαεινῷ,{l]
[l [n}16.410{]}κὰδ δʼ ἄρʼ ἐπὶ στόμʼ ἔωσε· πεσόντα δέ μιν λίπε θυμός.{l]
[l [n}16.411{]}αὐτὰρ ἔπειτʼ Ἐρύλαον ἐπεσσύμενον βάλε πέτρῳ{l]
[l [n}16.412{]}μέσσην κὰκ κεφαλήν· ἣ δʼ ἄνδιχα πᾶσα κεάσθη{l]
[l [n}16.413{]}ἐν κόρυθι βριαρῇ· ὃ δʼ ἄρα πρηνὴς ἐπὶ γαίῃ{l]
[l [n}16.414{]}κάππεσεν, ἀμφὶ δέ μιν θάνατος χύτο θυμοραϊστής.{l]
[l [n}16.415{]}αὐτὰρ ἔπειτʼ Ἐρύμαντα καὶ Ἀμφοτερὸν καὶ Ἐπάλτην{l]
[l [n}16.416{]}Τληπόλεμόν τε Δαμαστορίδην Ἐχίον τε Πύριν τε{l]
[l [n}16.417{]}Ἰφέα τʼ Εὔιππόν τε καὶ Ἀργεάδην Πολύμηλον{l]
[l [n}16.418{]}πάντας ἐπασσυτέρους πέλασε χθονὶ πουλυβοτείρῃ.{l]{para]
[para}[l [n}16.419{]}Σαρπηδὼν δʼ ὡς οὖν ἴδʼ ἀμιτροχίτωνας ἑταίρους{l]
[l [n}16.420{]}χέρσʼ ὕπο Πατρόκλοιο Μενοιτιάδαο δαμέντας,{l]
[l [n}16.421{]}κέκλετʼ ἄρʼ ἀντιθέοισι καθαπτόμενος Λυκίοισιν·{l]
[q}[l [n}16.422{]}αἰδὼς ὦ Λύκιοι· πόσε φεύγετε; νῦν θοοὶ ἔστε.{l]
[l [n}16.423{]}ἀντήσω γὰρ ἐγὼ τοῦδʼ ἀνέρος, ὄφρα δαείω{l]
[l [n}16.424{]}ὅς τις ὅδε κρατέει καὶ δὴ κακὰ πολλὰ ἔοργε{l]
[l [n}16.425{]}Τρῶας, ἐπεὶ πολλῶν τε καὶ ἐσθλῶν γούνατʼ ἔλυσεν.{l]{q]{para]
[para}[l [n}16.426{]}ἦ ῥα, καὶ ἐξ ὀχέων σὺν τεύχεσιν ἆλτο χαμᾶζε.{l]
[l [n}16.427{]}Πάτροκλος δʼ ἑτέρωθεν ἐπεὶ ἴδεν ἔκθορε δίφρου.{l]
[l [n}16.428{]}οἳ δʼ ὥς τʼ αἰγυπιοὶ γαμψώνυχες ἀγκυλοχεῖλαι{l]
[l [n}16.429{]}πέτρῃ ἐφʼ ὑψηλῇ μεγάλα κλάζοντε μάχωνται,{l]
[l [n}16.430{]}ὣς οἳ κεκλήγοντες ἐπʼ ἀλλήλοισιν ὄρουσαν.{l]
[l [n}16.431{]}τοὺς δὲ ἰδὼν ἐλέησε Κρόνου πάϊς ἀγκυλομήτεω,{l]
[l [n}16.432{]}Ἥρην δὲ προσέειπε κασιγνήτην ἄλοχόν τε·{l]
[q}[l [n}16.433{]}ὤ μοι ἐγών, ὅ τέ μοι Σαρπηδόνα φίλτατον ἀνδρῶν{l]
[l [n}16.434{]}μοῖρʼ ὑπὸ Πατρόκλοιο Μενοιτιάδαο δαμῆναι.{l]
[l [n}16.435{]}διχθὰ δέ μοι κραδίη μέμονε φρεσὶν ὁρμαίνοντι,{l]
[l [n}16.436{]}ἤ μιν ζωὸν ἐόντα μάχης ἄπο δακρυοέσσης{l]
[l [n}16.437{]}θείω ἀναρπάξας Λυκίης ἐν πίονι δήμῳ,{l]
[l [n}16.438{]}ἦ ἤδη ὑπὸ χερσὶ Μενοιτιάδαο δαμάσσω.{l]{q]{para]
[para}[l [n}16.439{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοῶπις πότνια Ἥρη·{l]
[q}[l [n}16.440{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες.{l]
[l [n}16.441{]}ἄνδρα θνητὸν ἐόντα πάλαι πεπρωμένον αἴσῃ{l]
[l [n}16.442{]}ἂψ ἐθέλεις θανάτοιο δυσηχέος ἐξαναλῦσαι;{l]
[l [n}16.443{]}ἔρδʼ· ἀτὰρ οὔ τοι πάντες ἐπαινέομεν θεοὶ ἄλλοι.{l]
[l [n}16.444{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσιν·{l]
[l [n}16.445{]}αἴ κε ζὼν πέμψῃς Σαρπηδόνα ὃν δὲ δόμον δέ,{l]
[l [n}16.446{]}φράζεο μή τις ἔπειτα θεῶν ἐθέλῃσι καὶ ἄλλος{l]
[l [n}16.447{]}πέμπειν ὃν φίλον υἱὸν ἀπὸ κρατερῆς ὑσμίνης·{l]
[l [n}16.448{]}πολλοὶ γὰρ περὶ ἄστυ μέγα Πριάμοιο μάχονται{l]
[l [n}16.449{]}υἱέες ἀθανάτων, τοῖσιν κότον αἰνὸν ἐνήσεις.{l]
[l [n}16.450{]}ἀλλʼ εἴ τοι φίλος ἐστί, τεὸν δʼ ὀλοφύρεται ἦτορ,{l]
[l [n}16.451{]}ἤτοι μέν μιν ἔασον ἐνὶ κρατερῇ ὑσμίνῃ{l]
[l [n}16.452{]}χέρσʼ ὕπο Πατρόκλοιο Μενοιτιάδαο δαμῆναι·{l]
[l [n}16.453{]}αὐτὰρ ἐπὴν δὴ τόν γε λίπῃ ψυχή τε καὶ αἰών,{l]
[l [n}16.454{]}πέμπειν μιν θάνατόν τε φέρειν καὶ νήδυμον ὕπνον{l]
[l [n}16.455{]}εἰς ὅ κε δὴ Λυκίης εὐρείης δῆμον ἵκωνται,{l]
[l [n}16.456{]}ἔνθά ἑ ταρχύσουσι κασίγνητοί τε ἔται τε{l]
[l [n}16.457{]}τύμβῳ τε στήλῃ τε· τὸ γὰρ γέρας ἐστὶ θανόντων.{l]{q]{para]
[para}[l [n}16.458{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[l [n}16.459{]}αἱματοέσσας δὲ ψιάδας κατέχευεν ἔραζε{l]
[l [n}16.460{]}παῖδα φίλον τιμῶν, τόν οἱ Πάτροκλος ἔμελλε{l]
[l [n}16.461{]}φθίσειν ἐν Τροίῃ ἐριβώλακι τηλόθι πάτρης.{l]{para]
[para}[l [n}16.462{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}16.463{]}ἔνθʼ ἤτοι Πάτροκλος ἀγακλειτὸν Θρασύμηλον,{l]
[l [n}16.464{]}ὅς ῥʼ ἠῢς θεράπων Σαρπηδόνος ἦεν ἄνακτος,{l]
[l [n}16.465{]}τὸν βάλε νείαιραν κατὰ γαστέρα, λῦσε δὲ γυῖα.{l]
[l [n}16.466{]}Σαρπηδὼν δʼ αὐτοῦ μὲν ἀπήμβροτε δουρὶ φαεινῷ{l]
[l [n}16.467{]}δεύτερον ὁρμηθείς, ὃ δὲ Πήδασον οὔτασεν ἵππον{l]
[l [n}16.468{]}ἔγχεϊ δεξιὸν ὦμον· ὃ δʼ ἔβραχε θυμὸν ἀΐσθων,{l]
[l [n}16.469{]}κὰδ δʼ ἔπεσʼ ἐν κονίῃσι μακών, ἀπὸ δʼ ἔπτατο θυμός.{l]
[l [n}16.470{]}τὼ δὲ διαστήτην, κρίκε δὲ ζυγόν, ἡνία δέ σφι{l]
[l [n}16.471{]}σύγχυτʼ, ἐπεὶ δὴ κεῖτο παρήορος ἐν κονίῃσι.{l]
[l [n}16.472{]}τοῖο μὲν Αὐτομέδων δουρικλυτὸς εὕρετο τέκμωρ·{l]
[l [n}16.473{]}σπασσάμενος τανύηκες ἄορ παχέος παρὰ μηροῦ{l]
[l [n}16.474{]}ἀΐξας ἀπέκοψε παρήορον οὐδʼ ἐμάτησε·{l]
[l [n}16.475{]}τὼ δʼ ἰθυνθήτην, ἐν δὲ ῥυτῆρσι τάνυσθεν·{l]
[l [n}16.476{]}τὼ δʼ αὖτις συνίτην ἔριδος πέρι θυμοβόροιο.{l]{para]
[para}[l [n}16.477{]}ἔνθʼ αὖ Σαρπηδὼν μὲν ἀπήμβροτε δουρὶ φαεινῷ,{l]
[l [n}16.478{]}Πατρόκλου δʼ ὑπὲρ ὦμον ἀριστερὸν ἤλυθʼ ἀκωκὴ{l]
[l [n}16.479{]}ἔγχεος, οὐδʼ ἔβαλʼ αὐτόν· ὃ δʼ ὕστερος ὄρνυτο χαλκῷ{l]
[l [n}16.480{]}Πάτροκλος· τοῦ δʼ οὐχ ἅλιον βέλος ἔκφυγε χειρός,{l]
[l [n}16.481{]}ἀλλʼ ἔβαλʼ ἔνθʼ ἄρα τε φρένες ἔρχαται ἀμφʼ ἁδινὸν κῆρ.{l]
[l [n}16.482{]}ἤριπε δʼ ὡς ὅτε τις δρῦς ἤριπεν ἢ ἀχερωῒς{l]
[l [n}16.483{]}ἠὲ πίτυς βλωθρή, τήν τʼ οὔρεσι τέκτονες ἄνδρες{l]
[l [n}16.484{]}ἐξέταμον πελέκεσσι νεήκεσι νήϊον εἶναι·{l]
[l [n}16.485{]}ὣς ὃ πρόσθʼ ἵππων καὶ δίφρου κεῖτο τανυσθεὶς{l]
[l [n}16.486{]}βεβρυχὼς κόνιος δεδραγμένος αἱματοέσσης.{l]
[l [n}16.487{]}ἠΰτε ταῦρον ἔπεφνε λέων ἀγέληφι μετελθὼν{l]
[l [n}16.488{]}αἴθωνα μεγάθυμον ἐν εἰλιπόδεσσι βόεσσι,{l]
[l [n}16.489{]}ὤλετό τε στενάχων ὑπὸ γαμφηλῇσι λέοντος,{l]
[l [n}16.490{]}ὣς ὑπὸ Πατρόκλῳ Λυκίων ἀγὸς ἀσπιστάων{l]
[l [n}16.491{]}κτεινόμενος μενέαινε, φίλον δʼ ὀνόμηνεν ἑταῖρον·{l]
[q}[l [n}16.492{]}Γλαῦκε πέπον πολεμιστὰ μετʼ ἀνδράσι νῦν σε μάλα χρὴ{l]
[l [n}16.493{]}αἰχμητήν τʼ ἔμεναι καὶ θαρσαλέον πολεμιστήν·{l]
[l [n}16.494{]}νῦν τοι ἐελδέσθω πόλεμος κακός, εἰ θοός ἐσσι.{l]
[l [n}16.495{]}πρῶτα μὲν ὄτρυνον Λυκίων ἡγήτορας ἄνδρας{l]
[l [n}16.496{]}πάντῃ ἐποιχόμενος Σαρπηδόνος ἀμφιμάχεσθαι·{l]
[l [n}16.497{]}αὐτὰρ ἔπειτα καὶ αὐτὸς ἐμεῦ πέρι μάρναο χαλκῷ.{l]
[l [n}16.498{]}σοὶ γὰρ ἐγὼ καὶ ἔπειτα κατηφείη καὶ ὄνειδος{l]
[l [n}16.499{]}ἔσσομαι ἤματα πάντα διαμπερές, εἴ κέ μʼ Ἀχαιοὶ{l]
[l [n}16.500{]}τεύχεα συλήσωσι νεῶν ἐν ἀγῶνι πεσόντα.{l]
[l [n}16.501{]}ἀλλʼ ἔχεο κρατερῶς, ὄτρυνε δὲ λαὸν ἅπαντα.{l]{q]{para]
[para}[l [n}16.502{]}ὣς ἄρα μιν εἰπόντα τέλος θανάτοιο κάλυψεν{l]
[l [n}16.503{]}ὀφθαλμοὺς ῥῖνάς θʼ· ὃ δὲ λὰξ ἐν στήθεσι βαίνων{l]
[l [n}16.504{]}ἐκ χροὸς ἕλκε δόρυ, προτὶ δὲ φρένες αὐτῷ ἕποντο·{l]
[l [n}16.505{]}τοῖο δʼ ἅμα ψυχήν τε καὶ ἔγχεος ἐξέρυσʼ αἰχμήν.{l]
[l [n}16.506{]}Μυρμιδόνες δʼ αὐτοῦ σχέθον ἵππους φυσιόωντας{l]
[l [n}16.507{]}ἱεμένους φοβέεσθαι, ἐπεὶ λίπον ἅρματʼ ἀνάκτων.{l]{para]
[para}[l [n}16.508{]}Γλαύκῳ δʼ αἰνὸν ἄχος γένετο φθογγῆς ἀΐοντι·{l]
[l [n}16.509{]}ὠρίνθη δέ οἱ ἦτορ ὅ τʼ οὐ δύνατο προσαμῦναι.{l]
[l [n}16.510{]}χειρὶ δʼ ἑλὼν ἐπίεζε βραχίονα· τεῖρε γὰρ αὐτὸν{l]
[l [n}16.511{]}ἕλκος, ὃ δή μιν Τεῦκρος ἐπεσσύμενον βάλεν ἰῷ{l]
[l [n}16.512{]}τείχεος ὑψηλοῖο, ἀρὴν ἑτάροισιν ἀμύνων.{l]
[l [n}16.513{]}εὐχόμενος δʼ ἄρα εἶπεν ἑκηβόλῳ Ἀπόλλωνι·{l]
[q}[l [n}16.514{]}κλῦθι ἄναξ ὅς που Λυκίης ἐν πίονι δήμῳ{l]
[l [n}16.515{]}εἲς ἢ ἐνὶ Τροίῃ· δύνασαι δὲ σὺ πάντοσʼ ἀκούειν{l]
[l [n}16.516{]}ἀνέρι κηδομένῳ, ὡς νῦν ἐμὲ κῆδος ἱκάνει.{l]
[l [n}16.517{]}ἕλκος μὲν γὰρ ἔχω τόδε καρτερόν, ἀμφὶ δέ μοι χεὶρ{l]
[l [n}16.518{]}ὀξείῃς ὀδύνῃσιν ἐλήλαται, οὐδέ μοι αἷμα{l]
[l [n}16.519{]}τερσῆναι δύναται, βαρύθει δέ μοι ὦμος ὑπʼ αὐτοῦ·{l]
[l [n}16.520{]}ἔγχος δʼ οὐ δύναμαι σχεῖν ἔμπεδον, οὐδὲ μάχεσθαι{l]
[l [n}16.521{]}ἐλθὼν δυσμενέεσσιν. ἀνὴρ δʼ ὤριστος ὄλωλε{l]
[l [n}16.522{]}Σαρπηδὼν Διὸς υἱός· ὃ δʼ οὐ οὗ παιδὸς ἀμύνει.{l]
[l [n}16.523{]}ἀλλὰ σύ πέρ μοι ἄναξ τόδε καρτερὸν ἕλκος ἄκεσσαι,{l]
[l [n}16.524{]}κοίμησον δʼ ὀδύνας, δὸς δὲ κράτος, ὄφρʼ ἑτάροισι{l]
[l [n}16.525{]}κεκλόμενος Λυκίοισιν ἐποτρύνω πολεμίζειν,{l]
[l [n}16.526{]}αὐτός τʼ ἀμφὶ νέκυι κατατεθνηῶτι μάχωμαι.{l]{q]{para]
[para}[l [n}16.527{]}ὣς ἔφατʼ εὐχόμενος, τοῦ δʼ ἔκλυε Φοῖβος Ἀπόλλων.{l]
[l [n}16.528{]}αὐτίκα παῦσʼ ὀδύνας ἀπὸ δʼ ἕλκεος ἀργαλέοιο{l]
[l [n}16.529{]}αἷμα μέλαν τέρσηνε, μένος δέ οἱ ἔμβαλε θυμῷ.{l]
[l [n}16.530{]}Γλαῦκος δʼ ἔγνω ᾗσιν ἐνὶ φρεσὶ γήθησέν τε{l]
[l [n}16.531{]}ὅττί οἱ ὦκʼ ἤκουσε μέγας θεὸς εὐξαμένοιο.{l]
[l [n}16.532{]}πρῶτα μὲν ὄτρυνεν Λυκίων ἡγήτορας ἄνδρας{l]
[l [n}16.533{]}πάντῃ ἐποιχόμενος Σαρπηδόνος ἀμφιμάχεσθαι·{l]
[l [n}16.534{]}αὐτὰρ ἔπειτα μετὰ Τρῶας κίε μακρὰ βιβάσθων{l]
[l [n}16.535{]}Πουλυδάμαντʼ ἔπι Πανθοΐδην καὶ Ἀγήνορα δῖον,{l]
[l [n}16.536{]}βῆ δὲ μετʼ Αἰνείαν τε καὶ Ἕκτορα χαλκοκορυστήν,{l]
[l [n}16.537{]}ἀγχοῦ δʼ ἱστάμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}16.538{]}Ἕκτορ νῦν δὴ πάγχυ λελασμένος εἰς ἐπικούρων,{l]
[l [n}16.539{]}οἳ σέθεν εἵνεκα τῆλε φίλων καὶ πατρίδος αἴης{l]
[l [n}16.540{]}θυμὸν ἀποφθινύθουσι· σὺ δʼ οὐκ ἐθέλεις ἐπαμύνειν.{l]
[l [n}16.541{]}κεῖται Σαρπηδὼν Λυκίων ἀγὸς ἀσπιστάων,{l]
[l [n}16.542{]}ὃς Λυκίην εἴρυτο δίκῃσί τε καὶ σθένεϊ ᾧ·{l]
[l [n}16.543{]}τὸν δʼ ὑπὸ Πατρόκλῳ δάμασʼ ἔγχεϊ χάλκεος Ἄρης.{l]
[l [n}16.544{]}ἀλλὰ φίλοι πάρστητε, νεμεσσήθητε δὲ θυμῷ,{l]
[l [n}16.545{]}μὴ ἀπὸ τεύχεʼ ἕλωνται, ἀεικίσσωσι δὲ νεκρὸν{l]
[l [n}16.546{]}Μυρμιδόνες, Δαναῶν κεχολωμένοι ὅσσοι ὄλοντο,{l]
[l [n}16.547{]}τοὺς ἐπὶ νηυσὶ θοῇσιν ἐπέφνομεν ἐγχείῃσιν.{l]{q]{para]
[para}[l [n}16.548{]}ὣς ἔφατο, Τρῶας δὲ κατὰ κρῆθεν λάβε πένθος{l]
[l [n}16.549{]}ἄσχετον, οὐκ ἐπιεικτόν, ἐπεί σφισιν ἕρμα πόληος{l]
[l [n}16.550{]}ἔσκε καὶ ἀλλοδαπός περ ἐών· πολέες γὰρ ἅμʼ αὐτῷ{l]
[l [n}16.551{]}λαοὶ ἕποντʼ, ἐν δʼ αὐτὸς ἀριστεύεσκε μάχεσθαι·{l]
[l [n}16.552{]}βὰν δʼ ἰθὺς Δαναῶν λελιημένοι· ἦρχε δʼ ἄρά σφιν{l]
[l [n}16.553{]}Ἕκτωρ χωόμενος Σαρπηδόνος. αὐτὰρ Ἀχαιοὺς{l]
[l [n}16.554{]}ὦρσε Μενοιτιάδεω Πατροκλῆος λάσιον κῆρ·{l]
[l [n}16.555{]}Αἴαντε πρώτω προσέφη μεμαῶτε καὶ αὐτώ·{l]
[q}[l [n}16.556{]}Αἴαντε νῦν σφῶϊν ἀμύνεσθαι φίλον ἔστω,{l]
[l [n}16.557{]}οἷοί περ πάρος ἦτε μετʼ ἀνδράσιν ἢ καὶ ἀρείους.{l]
[l [n}16.558{]}κεῖται ἀνὴρ ὃς πρῶτος ἐσήλατο τεῖχος Ἀχαιῶν{l]
[l [n}16.559{]}Σαρπηδών· ἀλλʼ εἴ μιν ἀεικισσαίμεθʼ ἑλόντες,{l]
[l [n}16.560{]}τεύχεά τʼ ὤμοιιν ἀφελοίμεθα, καί τινʼ ἑταίρων{l]
[l [n}16.561{]}αὐτοῦ ἀμυνομένων δαμασαίμεθα νηλέϊ χαλκῷ.{l]{q]{para]
[para}[l [n}16.562{]}ὣς ἔφαθʼ, οἳ δὲ καὶ αὐτοὶ ἀλέξασθαι μενέαινον.{l]
[l [n}16.563{]}οἳ δʼ ἐπεὶ ἀμφοτέρωθεν ἐκαρτύναντο φάλαγγας{l]
[l [n}16.564{]}Τρῶες καὶ Λύκιοι καὶ Μυρμιδόνες καὶ Ἀχαιοί,{l]
[l [n}16.565{]}σύμβαλον ἀμφὶ νέκυι κατατεθνηῶτι μάχεσθαι{l]
[l [n}16.566{]}δεινὸν ἀΰσαντες· μέγα δʼ ἔβραχε τεύχεα φωτῶν.{l]
[l [n}16.567{]}Ζεὺς δʼ ἐπὶ νύκτʼ ὀλοὴν τάνυσε κρατερῇ ὑσμίνῃ,{l]
[l [n}16.568{]}ὄφρα φίλῳ περὶ παιδὶ μάχης ὀλοὸς πόνος εἴη.{l]{para]
[para}[l [n}16.569{]}ὦσαν δὲ πρότεροι Τρῶες ἑλίκωπας Ἀχαιούς·{l]
[l [n}16.570{]}βλῆτο γὰρ οὔ τι κάκιστος ἀνὴρ μετὰ Μυρμιδόνεσσιν{l]
[l [n}16.571{]}υἱὸς Ἀγακλῆος μεγαθύμου δῖος Ἐπειγεύς,{l]
[l [n}16.572{]}ὅς ῥʼ ἐν Βουδείῳ εὖ ναιομένῳ ἤνασσε{l]
[l [n}16.573{]}τὸ πρίν· ἀτὰρ τότε γʼ ἐσθλὸν ἀνεψιὸν ἐξεναρίξας{l]
[l [n}16.574{]}ἐς Πηλῆʼ ἱκέτευσε καὶ ἐς Θέτιν ἀργυρόπεζαν·{l]
[l [n}16.575{]}οἳ δʼ ἅμʼ Ἀχιλλῆϊ ῥηξήνορι πέμπον ἕπεσθαι{l]
[l [n}16.576{]}Ἴλιον εἰς εὔπωλον, ἵνα Τρώεσσι μάχοιτο.{l]
[l [n}16.577{]}τόν ῥα τόθʼ ἁπτόμενον νέκυος βάλε φαίδιμος Ἕκτωρ{l]
[l [n}16.578{]}χερμαδίῳ κεφαλήν· ἣ δʼ ἄνδιχα πᾶσα κεάσθη{l]
[l [n}16.579{]}ἐν κόρυθι βριαρῇ· ὃ δʼ ἄρα πρηνὴς ἐπὶ νεκρῷ{l]
[l [n}16.580{]}κάππεσεν, ἀμφὶ δέ μιν θάνατος χύτο θυμοραϊστής.{l]
[l [n}16.581{]}Πατρόκλῳ δʼ ἄρʼ ἄχος γένετο φθιμένου ἑτάροιο,{l]
[l [n}16.582{]}ἴθυσεν δὲ διὰ προμάχων ἴρηκι ἐοικὼς{l]
[l [n}16.583{]}ὠκέϊ, ὅς τʼ ἐφόβησε κολοιούς τε ψῆράς τε·{l]
[l [n}16.584{]}ὣς ἰθὺς Λυκίων Πατρόκλεες ἱπποκέλευθε{l]
[l [n}16.585{]}ἔσσυο καὶ Τρώων, κεχόλωσο δὲ κῆρ ἑτάροιο.{l]
[l [n}16.586{]}καί ῥʼ ἔβαλε Σθενέλαον Ἰθαιμένεος φίλον υἱὸν{l]
[l [n}16.587{]}αὐχένα χερμαδίῳ, ῥῆξεν δʼ ἀπὸ τοῖο τένοντας.{l]
[l [n}16.588{]}χώρησαν δʼ ὑπό τε πρόμαχοι καὶ φαίδιμος Ἕκτωρ.{l]
[l [n}16.589{]}ὅσση δʼ αἰγανέης ῥιπὴ ταναοῖο τέτυκται,{l]
[l [n}16.590{]}ἥν ῥά τʼ ἀνὴρ ἀφέῃ πειρώμενος ἢ ἐν ἀέθλῳ{l]
[l [n}16.591{]}ἠὲ καὶ ἐν πολέμῳ δηΐων ὕπο θυμοραϊστέων,{l]
[l [n}16.592{]}τόσσον ἐχώρησαν Τρῶες, ὤσαντο δʼ Ἀχαιοί.{l]
[l [n}16.593{]}Γλαῦκος δὲ πρῶτος Λυκίων ἀγὸς ἀσπιστάων{l]
[l [n}16.594{]}ἐτράπετʼ, ἔκτεινεν δὲ Βαθυκλῆα μεγάθυμον{l]
[l [n}16.595{]}Χάλκωνος φίλον υἱόν, ὃς Ἑλλάδι οἰκία ναίων{l]
[l [n}16.596{]}ὄλβῳ τε πλούτῳ τε μετέπρεπε Μυρμιδόνεσσι.{l]
[l [n}16.597{]}τὸν μὲν ἄρα Γλαῦκος στῆθος μέσον οὔτασε δουρὶ{l]
[l [n}16.598{]}στρεφθεὶς ἐξαπίνης, ὅτε μιν κατέμαρπτε διώκων·{l]
[l [n}16.599{]}δούπησεν δὲ πεσών· πυκινὸν δʼ ἄχος ἔλλαβʼ Ἀχαιούς,{l]
[l [n}16.600{]}ὡς ἔπεσʼ ἐσθλὸς ἀνήρ· μέγα δὲ Τρῶες κεχάροντο,{l]
[l [n}16.601{]}στὰν δʼ ἀμφʼ αὐτὸν ἰόντες ἀολλέες· οὐδʼ ἄρʼ Ἀχαιοὶ{l]
[l [n}16.602{]}ἀλκῆς ἐξελάθοντο, μένος δʼ ἰθὺς φέρον αὐτῶν.{l]
[l [n}16.603{]}ἔνθʼ αὖ Μηριόνης Τρώων ἕλεν ἄνδρα κορυστὴν{l]
[l [n}16.604{]}Λαόγονον θρασὺν υἱὸν Ὀνήτορος, ὃς Διὸς ἱρεὺς{l]
[l [n}16.605{]}Ἰδαίου ἐτέτυκτο, θεὸς δʼ ὣς τίετο δήμῳ.{l]
[l [n}16.606{]}τὸν βάλʼ ὑπὸ γναθμοῖο καὶ οὔατος· ὦκα δὲ θυμὸς{l]
[l [n}16.607{]}ᾤχετʼ ἀπὸ μελέων, στυγερὸς δʼ ἄρα μιν σκότος εἷλεν.{l]
[l [n}16.608{]}Αἰνείας δʼ ἐπὶ Μηριόνῃ δόρυ χάλκεον ἧκεν·{l]
[l [n}16.609{]}ἔλπετο γὰρ τεύξεσθαι ὑπασπίδια προβιβῶντος.{l]
[l [n}16.610{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος·{l]
[l [n}16.611{]}πρόσσω γὰρ κατέκυψε, τὸ δʼ ἐξόπιθεν δόρυ μακρὸν{l]
[l [n}16.612{]}οὔδει ἐνισκίμφθη, ἐπὶ δʼ οὐρίαχος πελεμίχθη{l]
[l [n}16.613{]}ἔγχεος· ἔνθα δʼ ἔπειτʼ ἀφίει μένος ὄβριμος Ἄρης.{l]
[l [n}16.614{]}αἰχμὴ δʼ Αἰνείαο κραδαινομένη κατὰ γαίης{l]
[l [n}16.615{]}ᾤχετʼ, ἐπεί ῥʼ ἅλιον στιβαρῆς ἀπὸ χειρὸς ὄρουσεν.{l]
[l [n}16.616{]}Αἰνείας δʼ ἄρα θυμὸν ἐχώσατο φώνησέν τε·{l]
[q}[l [n}16.617{]}Μηριόνη τάχα κέν σε καὶ ὀρχηστήν περ ἐόντα{l]
[l [n}16.618{]}ἔγχος ἐμὸν κατέπαυσε διαμπερές, εἴ σʼ ἔβαλόν περ.{l]{q]{para]
[para}[l [n}16.619{]}τὸν δʼ αὖ Μηριόνης δουρικλυτὸς ἀντίον ηὔδα·{l]
[q}[l [n}16.620{]}Αἰνεία χαλεπόν σε καὶ ἴφθιμόν περ ἐόντα{l]
[l [n}16.621{]}πάντων ἀνθρώπων σβέσσαι μένος, ὅς κέ σευ ἄντα{l]
[l [n}16.622{]}ἔλθῃ ἀμυνόμενος· θνητὸς δέ νυ καὶ σὺ τέτυξαι.{l]
[l [n}16.623{]}εἰ καὶ ἐγώ σε βάλοιμι τυχὼν μέσον ὀξέϊ χαλκῷ,{l]
[l [n}16.624{]}αἶψά κε καὶ κρατερός περ ἐὼν καὶ χερσὶ πεποιθὼς{l]
[l [n}16.625{]}εὖχος ἐμοὶ δοίης, ψυχὴν δʼ Ἄϊδι κλυτοπώλῳ.{l]{q]{para]
[para}[l [n}16.626{]}ὣς φάτο, τὸν δʼ ἐνένιπε Μενοιτίου ἄλκιμος υἱός·{l]
[q}[l [n}16.627{]}Μηριόνη τί σὺ ταῦτα καὶ ἐσθλὸς ἐὼν ἀγορεύεις;{l]
[l [n}16.628{]}ὦ πέπον οὔ τοι Τρῶες ὀνειδείοις ἐπέεσσι{l]
[l [n}16.629{]}νεκροῦ χωρήσουσι· πάρος τινὰ γαῖα καθέξει.{l]
[l [n}16.630{]}ἐν γὰρ χερσὶ τέλος πολέμου, ἐπέων δʼ ἐνὶ βουλῇ·{l]
[l [n}16.631{]}τὼ οὔ τι χρὴ μῦθον ὀφέλλειν, ἀλλὰ μάχεσθαι.{l]{q]{para]
[para}[l [n}16.632{]}ὣς εἰπὼν ὃ μὲν ἦρχʼ, ὃ δʼ ἅμʼ ἕσπετο ἰσόθεος φώς.{l]
[l [n}16.633{]}τῶν δʼ ὥς τε δρυτόμων ἀνδρῶν ὀρυμαγδὸς ὀρώρει{l]
[l [n}16.634{]}οὔρεος ἐν βήσσῃς, ἕκαθεν δέ τε γίγνετʼ ἀκουή,{l]
[l [n}16.635{]}ὣς τῶν ὄρνυτο δοῦπος ἀπὸ χθονὸς εὐρυοδείης{l]
[l [n}16.636{]}χαλκοῦ τε ῥινοῦ τε βοῶν τʼ εὐποιητάων,{l]
[l [n}16.637{]}νυσσομένων ξίφεσίν τε καὶ ἔγχεσιν ἀμφιγύοισιν.{l]
[l [n}16.638{]}οὐδʼ ἂν ἔτι φράδμων περ ἀνὴρ Σαρπηδόνα δῖον{l]
[l [n}16.639{]}ἔγνω, ἐπεὶ βελέεσσι καὶ αἵματι καὶ κονίῃσιν{l]
[l [n}16.640{]}ἐκ κεφαλῆς εἴλυτο διαμπερὲς ἐς πόδας ἄκρους.{l]
[l [n}16.641{]}οἳ δʼ αἰεὶ περὶ νεκρὸν ὁμίλεον, ὡς ὅτε μυῖαι{l]
[l [n}16.642{]}σταθμῷ ἔνι βρομέωσι περιγλαγέας κατὰ πέλλας{l]
[l [n}16.643{]}ὥρῃ ἐν εἰαρινῇ, ὅτε τε γλάγος ἄγγεα δεύει·{l]
[l [n}16.644{]}ὣς ἄρα τοὶ περὶ νεκρὸν ὁμίλεον, οὐδέ ποτε Ζεὺς{l]
[l [n}16.645{]}τρέψεν ἀπὸ κρατερῆς ὑσμίνης ὄσσε φαεινώ,{l]
[l [n}16.646{]}ἀλλὰ κατʼ αὐτοὺς αἰὲν ὅρα καὶ φράζετο θυμῷ,{l]
[l [n}16.647{]}πολλὰ μάλʼ ἀμφὶ φόνῳ Πατρόκλου μερμηρίζων,{l]
[l [n}16.648{]}ἢ ἤδη καὶ κεῖνον ἐνὶ κρατερῇ ὑσμίνῃ{l]
[l [n}16.649{]}αὐτοῦ ἐπʼ ἀντιθέῳ Σαρπηδόνι φαίδιμος Ἕκτωρ{l]
[l [n}16.650{]}χαλκῷ δῃώσῃ, ἀπό τʼ ὤμων τεύχεʼ ἕληται,{l]
[l [n}16.651{]}ἦ ἔτι καὶ πλεόνεσσιν ὀφέλλειεν πόνον αἰπύν.{l]
[l [n}16.652{]}ὧδε δέ οἱ φρονέοντι δοάσσατο κέρδιον εἶναι{l]
[l [n}16.653{]}ὄφρʼ ἠῢς θεράπων Πηληϊάδεω Ἀχιλῆος{l]
[l [n}16.654{]}ἐξαῦτις Τρῶάς τε καὶ Ἕκτορα χαλκοκορυστὴν{l]
[l [n}16.655{]}ὤσαιτο προτὶ ἄστυ, πολέων δʼ ἀπὸ θυμὸν ἕλοιτο.{l]
[l [n}16.656{]}Ἕκτορι δὲ πρωτίστῳ ἀνάλκιδα θυμὸν ἐνῆκεν·{l]
[l [n}16.657{]}ἐς δίφρον δʼ ἀναβὰς φύγαδʼ ἔτραπε, κέκλετο δʼ ἄλλους{l]
[l [n}16.658{]}Τρῶας φευγέμεναι· γνῶ γὰρ Διὸς ἱρὰ τάλαντα.{l]
[l [n}16.659{]}ἔνθʼ οὐδʼ ἴφθιμοι Λύκιοι μένον, ἀλλὰ φόβηθεν{l]
[l [n}16.660{]}πάντες, ἐπεὶ βασιλῆα ἴδον βεβλαμμένον ἦτορ{l]
[l [n}16.661{]}κείμενον ἐν νεκύων ἀγύρει· πολέες γὰρ ἐπʼ αὐτῷ{l]
[l [n}16.662{]}κάππεσον, εὖτʼ ἔριδα κρατερὴν ἐτάνυσσε Κρονίων.{l]
[l [n}16.663{]}οἳ δʼ ἄρʼ ἀπʼ ὤμοιιν Σαρπηδόνος ἔντεʼ ἕλοντο{l]
[l [n}16.664{]}χάλκεα μαρμαίροντα, τὰ μὲν κοίλας ἐπὶ νῆας{l]
[l [n}16.665{]}δῶκε φέρειν ἑτάροισι Μενοιτίου ἄλκιμος υἱός.{l]
[l [n}16.666{]}καὶ τότʼ Ἀπόλλωνα προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}16.667{]}εἰ δʼ ἄγε νῦν φίλε Φοῖβε, κελαινεφὲς αἷμα κάθηρον{l]
[l [n}16.668{]}ἐλθὼν ἐκ βελέων Σαρπηδόνα, καί μιν ἔπειτα{l]
[l [n}16.669{]}πολλὸν ἀπὸ πρὸ φέρων λοῦσον ποταμοῖο ῥοῇσι{l]
[l [n}16.670{]}χρῖσόν τʼ ἀμβροσίῃ, περὶ δʼ ἄμβροτα εἵματα ἕσσον·{l]
[l [n}16.671{]}πέμπε δέ μιν πομποῖσιν ἅμα κραιπνοῖσι φέρεσθαι{l]
[l [n}16.672{]}ὕπνῳ καὶ θανάτῳ διδυμάοσιν, οἵ ῥά μιν ὦκα{l]
[l [n}16.673{]}θήσουσʼ ἐν Λυκίης εὐρείης πίονι δήμῳ,{l]
[l [n}16.674{]}ἔνθά ἑ ταρχύσουσι κασίγνητοί τε ἔται τε{l]
[l [n}16.675{]}τύμβῳ τε στήλῃ τε· τὸ γὰρ γέρας ἐστὶ θανόντων.{l]{q]{para]
[para}[l [n}16.676{]}ὣς ἔφατʼ, οὐδʼ ἄρα πατρὸς ἀνηκούστησεν Ἀπόλλων.{l]
[l [n}16.677{]}βῆ δὲ κατʼ Ἰδαίων ὀρέων ἐς φύλοπιν αἰνήν,{l]
[l [n}16.678{]}αὐτίκα δʼ ἐκ βελέων Σαρπηδόνα δῖον ἀείρας{l]
[l [n}16.679{]}πολλὸν ἀπὸ πρὸ φέρων λοῦσεν ποταμοῖο ῥοῇσι{l]
[l [n}16.680{]}χρῖσέν τʼ ἀμβροσίῃ, περὶ δʼ ἄμβροτα εἵματα ἕσσε·{l]
[l [n}16.681{]}πέμπε δέ μιν πομποῖσιν ἅμα κραιπνοῖσι φέρεσθαι,{l]
[l [n}16.682{]}ὕπνῳ καὶ θανάτῳ διδυμάοσιν, οἵ ῥά μιν ὦκα{l]
[l [n}16.683{]}κάτθεσαν ἐν Λυκίης εὐρείης πίονι δήμῳ.{l]{para]
[para}[l [n}16.684{]}Πάτροκλος δʼ ἵπποισι καὶ Αὐτομέδοντι κελεύσας{l]
[l [n}16.685{]}Τρῶας καὶ Λυκίους μετεκίαθε, καὶ μέγʼ ἀάσθη{l]
[l [n}16.686{]}νήπιος· εἰ δὲ ἔπος Πηληϊάδαο φύλαξεν{l]
[l [n}16.687{]}ἦ τʼ ἂν ὑπέκφυγε κῆρα κακὴν μέλανος θανάτοιο.{l]
[l [n}16.688{]}ἀλλʼ αἰεί τε Διὸς κρείσσων νόος ἠέ περ ἀνδρῶν·{l]
[l [n}16.689{]}ὅς τε καὶ ἄλκιμον ἄνδρα φοβεῖ καὶ ἀφείλετο νίκην{l]
[l [n}16.690{]}ῥηϊδίως, ὅτε δʼ αὐτὸς ἐποτρύνῃσι μάχεσθαι·{l]
[l [n}16.691{]}ὅς οἱ καὶ τότε θυμὸν ἐνὶ στήθεσσιν ἀνῆκεν.{l]{para]
[para}[l [n}16.692{]}ἔνθα τίνα πρῶτον τίνα δʼ ὕστατον ἐξενάριξας{l]
[l [n}16.693{]}Πατρόκλεις, ὅτε δή σε θεοὶ θάνατον δὲ κάλεσσαν;{l]
[l [n}16.694{]}Ἄδρηστον μὲν πρῶτα καὶ Αὐτόνοον καὶ Ἔχεκλον{l]
[l [n}16.695{]}καὶ Πέριμον Μεγάδην καὶ Ἐπίστορα καὶ Μελάνιππον,{l]
[l [n}16.696{]}αὐτὰρ ἔπειτʼ Ἔλασον καὶ Μούλιον ἠδὲ Πυλάρτην·{l]
[l [n}16.697{]}τοὺς ἕλεν· οἳ δʼ ἄλλοι φύγαδε μνώοντο ἕκαστος.{l]{para]
[para}[l [n}16.698{]}ἔνθά κεν ὑψίπυλον Τροίην ἕλον υἷες Ἀχαιῶν{l]
[l [n}16.699{]}Πατρόκλου ὑπὸ χερσί, περὶ πρὸ γὰρ ἔγχεϊ θῦεν,{l]
[l [n}16.700{]}εἰ μὴ Ἀπόλλων Φοῖβος ἐϋδμήτου ἐπὶ πύργου{l]
[l [n}16.701{]}ἔστη τῷ ὀλοὰ φρονέων, Τρώεσσι δʼ ἀρήγων.{l]
[l [n}16.702{]}τρὶς μὲν ἐπʼ ἀγκῶνος βῆ τείχεος ὑψηλοῖο{l]
[l [n}16.703{]}Πάτροκλος, τρὶς δʼ αὐτὸν ἀπεστυφέλιξεν Ἀπόλλων{l]
[l [n}16.704{]}χείρεσσʼ ἀθανάτῃσι φαεινὴν ἀσπίδα νύσσων.{l]
[l [n}16.705{]}ἀλλʼ ὅτε δὴ τὸ τέταρτον ἐπέσσυτο δαίμονι ἶσος,{l]
[l [n}16.706{]}δεινὰ δʼ ὁμοκλήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}16.707{]}χάζεο διογενὲς Πατρόκλεες· οὔ νύ τοι αἶσα{l]
[l [n}16.708{]}σῷ ὑπὸ δουρὶ πόλιν πέρθαι Τρώων ἀγερώχων,{l]
[l [n}16.709{]}οὐδʼ ὑπʼ Ἀχιλλῆος, ὅς περ σέο πολλὸν ἀμείνων.{l]{q]{para]
[para}[l [n}16.710{]}ὣς φάτο, Πάτροκλος δʼ ἀνεχάζετο πολλὸν ὀπίσσω{l]
[l [n}16.711{]}μῆνιν ἀλευάμενος ἑκατηβόλου Ἀπόλλωνος.{l]{para]
[para}[l [n}16.712{]}Ἕκτωρ δʼ ἐν Σκαιῇσι πύλῃς ἔχε μώνυχας ἵππους·{l]
[l [n}16.713{]}δίζε γὰρ ἠὲ μάχοιτο κατὰ κλόνον αὖτις ἐλάσσας,{l]
[l [n}16.714{]}ἦ λαοὺς ἐς τεῖχος ὁμοκλήσειεν ἀλῆναι.{l]
[l [n}16.715{]}ταῦτʼ ἄρα οἱ φρονέοντι παρίστατο Φοῖβος Ἀπόλλων{l]
[l [n}16.716{]}ἀνέρι εἰσάμενος αἰζηῷ τε κρατερῷ τε{l]
[l [n}16.717{]}Ἀσίῳ, ὃς μήτρως ἦν Ἕκτορος ἱπποδάμοιο{l]
[l [n}16.718{]}αὐτοκασίγνητος Ἑκάβης, υἱὸς δὲ Δύμαντος,{l]
[l [n}16.719{]}ὃς Φρυγίῃ ναίεσκε ῥοῇς ἔπι Σαγγαρίοιο·{l]
[l [n}16.720{]}τῷ μιν ἐεισάμενος προσέφη Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}16.721{]}Ἕκτορ τίπτε μάχης ἀποπαύεαι; οὐδέ τί σε χρή.{l]
[l [n}16.722{]}αἴθʼ ὅσον ἥσσων εἰμί, τόσον σέο φέρτερος εἴην·{l]
[l [n}16.723{]}τώ κε τάχα στυγερῶς πολέμου ἀπερωήσειας.{l]
[l [n}16.724{]}ἀλλʼ ἄγε Πατρόκλῳ ἔφεπε κρατερώνυχας ἵππους,{l]
[l [n}16.725{]}αἴ κέν πώς μιν ἕλῃς, δώῃ δέ τοι εὖχος Ἀπόλλων.{l]{q]{para]
[para}[l [n}16.726{]}ὣς εἰπὼν ὃ μὲν αὖτις ἔβη θεὸς ἂμ πόνον ἀνδρῶν,{l]
[l [n}16.727{]}Κεβριόνῃ δʼ ἐκέλευσε δαΐφρονι φαίδιμος Ἕκτωρ{l]
[l [n}16.728{]}ἵππους ἐς πόλεμον πεπληγέμεν. αὐτὰρ Ἀπόλλων{l]
[l [n}16.729{]}δύσεθʼ ὅμιλον ἰών, ἐν δὲ κλόνον Ἀργείοισιν{l]
[l [n}16.730{]}ἧκε κακόν, Τρωσὶν δὲ καὶ Ἕκτορι κῦδος ὄπαζεν.{l]
[l [n}16.731{]}Ἕκτωρ δʼ ἄλλους μὲν Δαναοὺς ἔα οὐδʼ ἐνάριζεν·{l]
[l [n}16.732{]}αὐτὰρ ὃ Πατρόκλῳ ἔφεπε κρατερώνυχας ἵππους.{l]
[l [n}16.733{]}Πάτροκλος δʼ ἑτέρωθεν ἀφʼ ἵππων ἆλτο χαμᾶζε{l]
[l [n}16.734{]}σκαιῇ ἔγχος ἔχων· ἑτέρηφι δὲ λάζετο πέτρον{l]
[l [n}16.735{]}μάρμαρον ὀκριόεντα τόν οἱ περὶ χεὶρ ἐκάλυψεν,{l]
[l [n}16.736{]}ἧκε δʼ ἐρεισάμενος, οὐδὲ δὴν χάζετο φωτός,{l]
[l [n}16.737{]}οὐδʼ ἁλίωσε βέλος, βάλε δʼ Ἕκτορος ἡνιοχῆα{l]
[l [n}16.738{]}Κεβριόνην νόθον υἱὸν ἀγακλῆος Πριάμοιο{l]
[l [n}16.739{]}ἵππων ἡνίʼ ἔχοντα μετώπιον ὀξέϊ λᾶϊ.{l]
[l [n}16.740{]}ἀμφοτέρας δʼ ὀφρῦς σύνελεν λίθος, οὐδέ οἱ ἔσχεν{l]
[l [n}16.741{]}ὀστέον, ὀφθαλμοὶ δὲ χαμαὶ πέσον ἐν κονίῃσιν{l]
[l [n}16.742{]}αὐτοῦ πρόσθε ποδῶν· ὃ δʼ ἄρʼ ἀρνευτῆρι ἐοικὼς{l]
[l [n}16.743{]}κάππεσʼ ἀπʼ εὐεργέος δίφρου, λίπε δʼ ὀστέα θυμός.{l]
[l [n}16.744{]}τὸν δʼ ἐπικερτομέων προσέφης Πατρόκλεες ἱππεῦ·{l]
[q}[l [n}16.745{]}ὢ πόποι ἦ μάλʼ ἐλαφρὸς ἀνήρ, ὡς ῥεῖα κυβιστᾷ.{l]
[l [n}16.746{]}εἰ δή που καὶ πόντῳ ἐν ἰχθυόεντι γένοιτο,{l]
[l [n}16.747{]}πολλοὺς ἂν κορέσειεν ἀνὴρ ὅδε τήθεα διφῶν{l]
[l [n}16.748{]}νηὸς ἀποθρῴσκων, εἰ καὶ δυσπέμφελος εἴη,{l]
[l [n}16.749{]}ὡς νῦν ἐν πεδίῳ ἐξ ἵππων ῥεῖα κυβιστᾷ.{l]
[l [n}16.750{]}ἦ ῥα καὶ ἐν Τρώεσσι κυβιστητῆρες ἔασιν.{l]{q]{para]
[para}[l [n}16.751{]}ὣς εἰπὼν ἐπὶ Κεβριόνῃ ἥρωϊ βεβήκει{l]
[l [n}16.752{]}οἶμα λέοντος ἔχων, ὅς τε σταθμοὺς κεραΐζων{l]
[l [n}16.753{]}ἔβλητο πρὸς στῆθος, ἑή τέ μιν ὤλεσεν ἀλκή·{l]
[l [n}16.754{]}ὣς ἐπὶ Κεβριόνῃ Πατρόκλεες ἆλσο μεμαώς.{l]
[l [n}16.755{]}Ἕκτωρ δʼ αὖθʼ ἑτέρωθεν ἀφʼ ἵππων ἆλτο χαμᾶζε.{l]
[l [n}16.756{]}τὼ περὶ Κεβριόναο λέονθʼ ὣς δηρινθήτην,{l]
[l [n}16.757{]}ὥ τʼ ὄρεος κορυφῇσι περὶ κταμένης ἐλάφοιο{l]
[l [n}16.758{]}ἄμφω πεινάοντε μέγα φρονέοντε μάχεσθον·{l]
[l [n}16.759{]}ὣς περὶ Κεβριόναο δύω μήστωρες ἀϋτῆς{l]
[l [n}16.760{]}Πάτροκλός τε Μενοιτιάδης καὶ φαίδιμος Ἕκτωρ{l]
[l [n}16.761{]}ἵεντʼ ἀλλήλων ταμέειν χρόα νηλέϊ χαλκῷ.{l]
[l [n}16.762{]}Ἕκτωρ μὲν κεφαλῆφιν ἐπεὶ λάβεν οὐχὶ μεθίει·{l]
[l [n}16.763{]}Πάτροκλος δʼ ἑτέρωθεν ἔχεν ποδός· οἳ δὲ δὴ ἄλλοι{l]
[l [n}16.764{]}Τρῶες καὶ Δαναοὶ σύναγον κρατερὴν ὑσμίνην.{l]{para]
[para}[l [n}16.765{]}ὡς δʼ Εὖρός τε Νότος τʼ ἐριδαίνετον ἀλλήλοιιν{l]
[l [n}16.766{]}οὔρεος ἐν βήσσῃς βαθέην πελεμιζέμεν ὕλην{l]
[l [n}16.767{]}φηγόν τε μελίην τε τανύφλοιόν τε κράνειαν,{l]
[l [n}16.768{]}αἵ τε πρὸς ἀλλήλας ἔβαλον τανυήκεας ὄζους{l]
[l [n}16.769{]}ἠχῇ θεσπεσίῃ, πάταγος δέ τε ἀγνυμενάων,{l]
[l [n}16.770{]}ὣς Τρῶες καὶ Ἀχαιοὶ ἐπʼ ἀλλήλοισι θορόντες{l]
[l [n}16.771{]}δῄουν, οὐδʼ ἕτεροι μνώοντʼ ὀλοοῖο φόβοιο.{l]
[l [n}16.772{]}πολλὰ δὲ Κεβριόνην ἀμφʼ ὀξέα δοῦρα πεπήγει{l]
[l [n}16.773{]}ἰοί τε πτερόεντες ἀπὸ νευρῆφι θορόντες,{l]
[l [n}16.774{]}πολλὰ δὲ χερμάδια μεγάλʼ ἀσπίδας ἐστυφέλιξαν{l]
[l [n}16.775{]}μαρναμένων ἀμφʼ αὐτόν· ὃ δʼ ἐν στροφάλιγγι κονίης{l]
[l [n}16.776{]}κεῖτο μέγας μεγαλωστί, λελασμένος ἱπποσυνάων.{l]{para]
[para}[l [n}16.777{]}ὄφρα μὲν Ἠέλιος μέσον οὐρανὸν ἀμφιβεβήκει,{l]
[l [n}16.778{]}τόφρα μάλʼ ἀμφοτέρων βέλεʼ ἥπτετο, πῖπτε δὲ λαός·{l]
[l [n}16.779{]}ἦμος δʼ Ἠέλιος μετενίσετο βουλυτὸν δέ,{l]
[l [n}16.780{]}καὶ τότε δή ῥʼ ὑπὲρ αἶσαν Ἀχαιοὶ φέρτεροι ἦσαν.{l]
[l [n}16.781{]}ἐκ μὲν Κεβριόνην βελέων ἥρωα ἔρυσσαν{l]
[l [n}16.782{]}Τρώων ἐξ ἐνοπῆς, καὶ ἀπʼ ὤμων τεύχεʼ ἕλοντο,{l]
[l [n}16.783{]}Πάτροκλος δὲ Τρωσὶ κακὰ φρονέων ἐνόρουσε.{l]
[l [n}16.784{]}τρὶς μὲν ἔπειτʼ ἐπόρουσε θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}16.785{]}σμερδαλέα ἰάχων, τρὶς δʼ ἐννέα φῶτας ἔπεφνεν.{l]
[l [n}16.786{]}ἀλλʼ ὅτε δὴ τὸ τέταρτον ἐπέσσυτο δαίμονι ἶσος,{l]
[l [n}16.787{]}ἔνθʼ ἄρα τοι Πάτροκλε φάνη βιότοιο τελευτή·{l]
[l [n}16.788{]}ἤντετο γάρ τοι Φοῖβος ἐνὶ κρατερῇ ὑσμίνῃ{l]
[l [n}16.789{]}δεινός· ὃ μὲν τὸν ἰόντα κατὰ κλόνον οὐκ ἐνόησεν,{l]
[l [n}16.790{]}ἠέρι γὰρ πολλῇ κεκαλυμμένος ἀντεβόλησε·{l]
[l [n}16.791{]}στῆ δʼ ὄπιθεν, πλῆξεν δὲ μετάφρενον εὐρέε τʼ ὤμω{l]
[l [n}16.792{]}χειρὶ καταπρηνεῖ, στρεφεδίνηθεν δέ οἱ ὄσσε.{l]
[l [n}16.793{]}τοῦ δʼ ἀπὸ μὲν κρατὸς κυνέην βάλε Φοῖβος Ἀπόλλων·{l]
[l [n}16.794{]}ἣ δὲ κυλινδομένη καναχὴν ἔχε ποσσὶν ὑφʼ ἵππων{l]
[l [n}16.795{]}αὐλῶπις τρυφάλεια, μιάνθησαν δὲ ἔθειραι{l]
[l [n}16.796{]}αἵματι καὶ κονίῃσι· πάρος γε μὲν οὐ θέμις ἦεν{l]
[l [n}16.797{]}ἱππόκομον πήληκα μιαίνεσθαι κονίῃσιν,{l]
[l [n}16.798{]}ἀλλʼ ἀνδρὸς θείοιο κάρη χαρίεν τε μέτωπον{l]
[l [n}16.799{]}ῥύετʼ Ἀχιλλῆος· τότε δὲ Ζεὺς Ἕκτορι δῶκεν{l]
[l [n}16.800{]}ᾗ κεφαλῇ φορέειν, σχεδόθεν δέ οἱ ἦεν ὄλεθρος.{l]
[l [n}16.801{]}πᾶν δέ οἱ ἐν χείρεσσιν ἄγη δολιχόσκιον ἔγχος{l]
[l [n}16.802{]}βριθὺ μέγα στιβαρὸν κεκορυθμένον· αὐτὰρ ἀπʼ ὤμων{l]
[l [n}16.803{]}ἀσπὶς σὺν τελαμῶνι χαμαὶ πέσε τερμιόεσσα.{l]
[l [n}16.804{]}λῦσε δέ οἱ θώρηκα ἄναξ Διὸς υἱὸς Ἀπόλλων.{l]
[l [n}16.805{]}τὸν δʼ ἄτη φρένας εἷλε, λύθεν δʼ ὑπὸ φαίδιμα γυῖα,{l]
[l [n}16.806{]}στῆ δὲ ταφών· ὄπιθεν δὲ μετάφρενον ὀξέϊ δουρὶ{l]
[l [n}16.807{]}ὤμων μεσσηγὺς σχεδόθεν βάλε Δάρδανος ἀνὴρ{l]
[l [n}16.808{]}Πανθοΐδης Εὔφορβος, ὃς ἡλικίην ἐκέκαστο{l]
[l [n}16.809{]}ἔγχεΐ θʼ ἱπποσύνῃ τε πόδεσσί τε καρπαλίμοισι·{l]
[l [n}16.810{]}καὶ γὰρ δὴ τότε φῶτας ἐείκοσι βῆσεν ἀφʼ ἵππων{l]
[l [n}16.811{]}πρῶτʼ ἐλθὼν σὺν ὄχεσφι διδασκόμενος πολέμοιο·{l]
[l [n}16.812{]}ὅς τοι πρῶτος ἐφῆκε βέλος Πατρόκλεες ἱππεῦ{l]
[l [n}16.813{]}οὐδὲ δάμασσʼ· ὃ μὲν αὖτις ἀνέδραμε, μίκτο δʼ ὁμίλῳ,{l]
[l [n}16.814{]}ἐκ χροὸς ἁρπάξας δόρυ μείλινον, οὐδʼ ὑπέμεινε{l]
[l [n}16.815{]}Πάτροκλον γυμνόν περ ἐόντʼ ἐν δηϊοτῆτι.{l]
[l [n}16.816{]}Πάτροκλος δὲ θεοῦ πληγῇ καὶ δουρὶ δαμασθεὶς{l]
[l [n}16.817{]}ἂψ ἑτάρων εἰς ἔθνος ἐχάζετο κῆρʼ ἀλεείνων.{l]{para]
[para}[l [n}16.818{]}Ἕκτωρ δʼ ὡς εἶδεν Πατροκλῆα μεγάθυμον{l]
[l [n}16.819{]}ἂψ ἀναχαζόμενον βεβλημένον ὀξέϊ χαλκῷ,{l]
[l [n}16.820{]}ἀγχίμολόν ῥά οἱ ἦλθε κατὰ στίχας, οὖτα δὲ δουρὶ{l]
[l [n}16.821{]}νείατον ἐς κενεῶνα, διὰ πρὸ δὲ χαλκὸν ἔλασσε·{l]
[l [n}16.822{]}δούπησεν δὲ πεσών, μέγα δʼ ἤκαχε λαὸν Ἀχαιῶν·{l]
[l [n}16.823{]}ὡς δʼ ὅτε σῦν ἀκάμαντα λέων ἐβιήσατο χάρμῃ,{l]
[l [n}16.824{]}ὥ τʼ ὄρεος κορυφῇσι μέγα φρονέοντε μάχεσθον{l]
[l [n}16.825{]}πίδακος ἀμφʼ ὀλίγης· ἐθέλουσι δὲ πιέμεν ἄμφω·{l]
[l [n}16.826{]}πολλὰ δέ τʼ ἀσθμαίνοντα λέων ἐδάμασσε βίηφιν·{l]
[l [n}16.827{]}ὣς πολέας πεφνόντα Μενοιτίου ἄλκιμον υἱὸν{l]
[l [n}16.828{]}Ἕκτωρ Πριαμίδης σχεδὸν ἔγχεϊ θυμὸν ἀπηύρα,{l]
[l [n}16.829{]}καί οἱ ἐπευχόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}16.830{]}Πάτροκλʼ ἦ που ἔφησθα πόλιν κεραϊξέμεν ἁμήν,{l]
[l [n}16.831{]}Τρωϊάδας δὲ γυναῖκας ἐλεύθερον ἦμαρ ἀπούρας{l]
[l [n}16.832{]}ἄξειν ἐν νήεσσι φίλην ἐς πατρίδα γαῖαν{l]
[l [n}16.833{]}νήπιε· τάων δὲ πρόσθʼ Ἕκτορος ὠκέες ἵπποι{l]
[l [n}16.834{]}ποσσὶν ὀρωρέχαται πολεμίζειν· ἔγχεϊ δʼ αὐτὸς{l]
[l [n}16.835{]}Τρωσὶ φιλοπτολέμοισι μεταπρέπω, ὅ σφιν ἀμύνω{l]
[l [n}16.836{]}ἦμαρ ἀναγκαῖον· σὲ δέ τʼ ἐνθάδε γῦπες ἔδονται.{l]
[l [n}16.837{]}ἆ δείλʼ, οὐδέ τοι ἐσθλὸς ἐὼν χραίσμησεν Ἀχιλλεύς,{l]
[l [n}16.838{]}ὅς πού τοι μάλα πολλὰ μένων ἐπετέλλετʼ ἰόντι·{l]
[q}[l [n}16.839{]}μή μοι πρὶν ἰέναι Πατρόκλεες ἱπποκέλευθε{l]
[l [n}16.840{]}νῆας ἔπι γλαφυρὰς πρὶν Ἕκτορος ἀνδροφόνοιο{l]
[l [n}16.841{]}αἱματόεντα χιτῶνα περὶ στήθεσσι δαΐξαι.{l]{q][l [n}16.842{]}ὥς πού σε προσέφη, σοὶ δὲ φρένας ἄφρονι πεῖθε.{l]{q]{para]
[para}[l [n}16.843{]}τὸν δʼ ὀλιγοδρανέων προσέφης Πατρόκλεες ἱππεῦ·{l]
[q}[l [n}16.844{]}ἤδη νῦν Ἕκτορ μεγάλʼ εὔχεο· σοὶ γὰρ ἔδωκε{l]
[l [n}16.845{]}νίκην Ζεὺς Κρονίδης καὶ Ἀπόλλων, οἵ με δάμασσαν{l]
[l [n}16.846{]}ῥηιδίως· αὐτοὶ γὰρ ἀπʼ ὤμων τεύχεʼ ἕλοντο.{l]
[l [n}16.847{]}τοιοῦτοι δʼ εἴ πέρ μοι ἐείκοσιν ἀντεβόλησαν,{l]
[l [n}16.848{]}πάντές κʼ αὐτόθʼ ὄλοντο ἐμῷ ὑπὸ δουρὶ δαμέντες.{l]
[l [n}16.849{]}ἀλλά με μοῖρʼ ὀλοὴ καὶ Λητοῦς ἔκτανεν υἱός,{l]
[l [n}16.850{]}ἀνδρῶν δʼ Εὔφορβος· σὺ δέ με τρίτος ἐξεναρίζεις.{l]
[l [n}16.851{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσιν·{l]
[l [n}16.852{]}οὔ θην οὐδʼ αὐτὸς δηρὸν βέῃ, ἀλλά τοι ἤδη{l]
[l [n}16.853{]}ἄγχι παρέστηκεν θάνατος καὶ μοῖρα κραταιὴ{l]
[l [n}16.854{]}χερσὶ δαμέντʼ Ἀχιλῆος ἀμύμονος Αἰακίδαο.{l]{q]{para]
[para}[l [n}16.855{]}ὣς ἄρα μιν εἰπόντα τέλος θανάτοιο κάλυψε·{l]
[l [n}16.856{]}ψυχὴ δʼ ἐκ ῥεθέων πταμένη Ἄϊδος δὲ βεβήκει{l]
[l [n}16.857{]}ὃν πότμον γοόωσα λιποῦσʼ ἀνδροτῆτα καὶ ἥβην.{l]
[l [n}16.858{]}τὸν καὶ τεθνηῶτα προσηύδα φαίδιμος Ἕκτωρ·{l]
[q}[l [n}16.859{]}Πατρόκλεις τί νύ μοι μαντεύεαι αἰπὺν ὄλεθρον;{l]
[l [n}16.860{]}τίς δʼ οἶδʼ εἴ κʼ Ἀχιλεὺς Θέτιδος πάϊς ἠϋκόμοιο{l]
[l [n}16.861{]}φθήῃ ἐμῷ ὑπὸ δουρὶ τυπεὶς ἀπὸ θυμὸν ὀλέσσαι;{l]{q]{para]
[para}[l [n}16.862{]}ὣς ἄρα φωνήσας δόρυ χάλκεον ἐξ ὠτειλῆς{l]
[l [n}16.863{]}εἴρυσε λὰξ προσβάς, τὸν δʼ ὕπτιον ὦσʼ ἀπὸ δουρός.{l]
[l [n}16.864{]}αὐτίκα δὲ ξὺν δουρὶ μετʼ Αὐτομέδοντα βεβήκει{l]
[l [n}16.865{]}ἀντίθεον θεράποντα ποδώκεος Αἰακίδαο·{l]
[l [n}16.866{]}ἵετο γὰρ βαλέειν· τὸν δʼ ἔκφερον ὠκέες ἵπποι{l]
[l [n}16.867{]}ἄμβροτοι, οὓς Πηλῆϊ θεοὶ δόσαν ἀγλαὰ δῶρα.{l]{para]
{book]
[book [n}17{]}
[para}[l [n}17.1{]}οὐδʼ ἔλαθʼ Ἀτρέος υἱὸν ἀρηΐφιλον Μενέλαον{l]
[l [n}17.2{]}Πάτροκλος Τρώεσσι δαμεὶς ἐν δηϊοτῆτι.{l]
[l [n}17.3{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ,{l]
[l [n}17.4{]}ἀμφὶ δʼ ἄρʼ αὐτῷ βαῖνʼ ὥς τις περὶ πόρτακι μήτηρ{l]
[l [n}17.5{]}πρωτοτόκος κινυρὴ οὐ πρὶν εἰδυῖα τόκοιο·{l]
[l [n}17.6{]}ὣς περὶ Πατρόκλῳ βαῖνε ξανθὸς Μενέλαος.{l]
[l [n}17.7{]}πρόσθε δέ οἱ δόρυ τʼ ἔσχε καὶ ἀσπίδα πάντοσʼ ἐΐσην,{l]
[l [n}17.8{]}τὸν κτάμεναι μεμαὼς ὅς τις τοῦ γʼ ἀντίος ἔλθοι.{l]
[l [n}17.9{]}οὐδʼ ἄρα Πάνθου υἱὸς ἐϋμμελίης ἀμέλησε{l]
[l [n}17.10{]}Πατρόκλοιο πεσόντος ἀμύμονος· ἄγχι δʼ ἄρʼ αὐτοῦ{l]
[l [n}17.11{]}ἔστη, καὶ προσέειπεν ἀρηΐφιλον Μενέλαον·{l]
[q}[l [n}17.12{]}Ἀτρεΐδη Μενέλαε διοτρεφὲς ὄρχαμε λαῶν{l]
[l [n}17.13{]}χάζεο, λεῖπε δὲ νεκρόν, ἔα δʼ ἔναρα βροτόεντα·{l]
[l [n}17.14{]}οὐ γάρ τις πρότερος Τρώων κλειτῶν τʼ ἐπικούρων{l]
[l [n}17.15{]}Πάτροκλον βάλε δουρὶ κατὰ κρατερὴν ὑσμίνην·{l]
[l [n}17.16{]}τώ με ἔα κλέος ἐσθλὸν ἐνὶ Τρώεσσιν ἀρέσθαι,{l]
[l [n}17.17{]}μή σε βάλω, ἀπὸ δὲ μελιηδέα θυμὸν ἕλωμαι.{l]{q]{para]
[para}[l [n}17.18{]}τὸν δὲ μέγʼ ὀχθήσας προσέφη ξανθὸς Μενέλαος·{l]
[q}[l [n}17.19{]}Ζεῦ πάτερ οὐ μὲν καλὸν ὑπέρβιον εὐχετάασθαι.{l]
[l [n}17.20{]}οὔτʼ οὖν παρδάλιος τόσσον μένος οὔτε λέοντος{l]
[l [n}17.21{]}οὔτε συὸς κάπρου ὀλοόφρονος, οὗ τε μέγιστος{l]
[l [n}17.22{]}θυμὸς ἐνὶ στήθεσσι περὶ σθένεϊ βλεμεαίνει,{l]
[l [n}17.23{]}ὅσσον Πάνθου υἷες ἐϋμμελίαι φρονέουσιν.{l]
[l [n}17.24{]}οὐδὲ μὲν οὐδὲ βίη Ὑπερήνορος ἱπποδάμοιο{l]
[l [n}17.25{]}ἧς ἥβης ἀπόνηθʼ, ὅτε μʼ ὤνατο καί μʼ ὑπέμεινε{l]
[l [n}17.26{]}καί μʼ ἔφατʼ ἐν Δαναοῖσιν ἐλέγχιστον πολεμιστὴν{l]
[l [n}17.27{]}ἔμμεναι· οὐδέ ἕ φημι πόδεσσί γε οἷσι κιόντα{l]
[l [n}17.28{]}εὐφρῆναι ἄλοχόν τε φίλην κεδνούς τε τοκῆας.{l]
[l [n}17.29{]}ὥς θην καὶ σὸν ἐγὼ λύσω μένος εἴ κέ μευ ἄντα{l]
[l [n}17.30{]}στήῃς· ἀλλά σʼ ἔγωγʼ ἀναχωρήσαντα κελεύω{l]
[l [n}17.31{]}ἐς πληθὺν ἰέναι, μηδʼ ἀντίος ἵστασʼ ἐμεῖο{l]
[l [n}17.32{]}πρίν τι κακὸν παθέειν· ῥεχθὲν δέ τε νήπιος ἔγνω.{l]{q]{para]
[para}[l [n}17.33{]}ὣς φάτο, τὸν δʼ οὐ πεῖθεν· ἀμειβόμενος δὲ προσηύδα·{l]
[q}[l [n}17.34{]}νῦν μὲν δὴ Μενέλαε διοτρεφὲς ἦ μάλα τείσεις{l]
[l [n}17.35{]}γνωτὸν ἐμὸν τὸν ἔπεφνες, ἐπευχόμενος δʼ ἀγορεύεις,{l]
[l [n}17.36{]}χήρωσας δὲ γυναῖκα μυχῷ θαλάμοιο νέοιο,{l]
[l [n}17.37{]}ἀρητὸν δὲ τοκεῦσι γόον καὶ πένθος ἔθηκας.{l]
[l [n}17.38{]}ἦ κέ σφιν δειλοῖσι γόου κατάπαυμα γενοίμην{l]
[l [n}17.39{]}εἴ κεν ἐγὼ κεφαλήν τε τεὴν καὶ τεύχεʼ ἐνείκας{l]
[l [n}17.40{]}Πάνθῳ ἐν χείρεσσι βάλω καὶ Φρόντιδι δίῃ.{l]
[l [n}17.41{]}ἀλλʼ οὐ μὰν ἔτι δηρὸν ἀπείρητος πόνος ἔσται{l]
[l [n}17.42{]}οὐδʼ ἔτʼ ἀδήριτος ἤτʼ ἀλκῆς ἤτε φόβοιο.{l]{q]{para]
[para}[l [n}17.43{]}ὣς εἰπὼν οὔτησε κατʼ ἀσπίδα πάντοσʼ ἐΐσην·{l]
[l [n}17.44{]}οὐδʼ ἔρρηξεν χαλκός, ἀνεγνάμφθη δέ οἱ αἰχμὴ{l]
[l [n}17.45{]}ἀσπίδʼ ἐνὶ κρατερῇ· ὃ δὲ δεύτερος ὄρνυτο χαλκῷ{l]
[l [n}17.46{]}Ἀτρεΐδης Μενέλαος ἐπευξάμενος Διὶ πατρί·{l]
[l [n}17.47{]}ἂψ δʼ ἀναχαζομένοιο κατὰ στομάχοιο θέμεθλα{l]
[l [n}17.48{]}νύξʼ, ἐπὶ δʼ αὐτὸς ἔρεισε βαρείῃ χειρὶ πιθήσας·{l]
[l [n}17.49{]}ἀντικρὺ δʼ ἁπαλοῖο διʼ αὐχένος ἤλυθʼ ἀκωκή,{l]
[l [n}17.50{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]
[l [n}17.51{]}αἵματί οἱ δεύοντο κόμαι Χαρίτεσσιν ὁμοῖαι{l]
[l [n}17.52{]}πλοχμοί θʼ, οἳ χρυσῷ τε καὶ ἀργύρῳ ἐσφήκωντο.{l]
[l [n}17.53{]}οἷον δὲ τρέφει ἔρνος ἀνὴρ ἐριθηλὲς ἐλαίης{l]
[l [n}17.54{]}χώρῳ ἐν οἰοπόλῳ, ὅθʼ ἅλις ἀναβέβροχεν ὕδωρ,{l]
[l [n}17.55{]}καλὸν τηλεθάον· τὸ δέ τε πνοιαὶ δονέουσι{l]
[l [n}17.56{]}παντοίων ἀνέμων, καί τε βρύει ἄνθεϊ λευκῷ·{l]
[l [n}17.57{]}ἐλθὼν δʼ ἐξαπίνης ἄνεμος σὺν λαίλαπι πολλῇ{l]
[l [n}17.58{]}βόθρου τʼ ἐξέστρεψε καὶ ἐξετάνυσσʼ ἐπὶ γαίῃ·{l]
[l [n}17.59{]}τοῖον Πάνθου υἱὸν ἐϋμμελίην Εὔφορβον{l]
[l [n}17.60{]}Ἀτρεΐδης Μενέλαος ἐπεὶ κτάνε τεύχεʼ ἐσύλα.{l]{para]
[para}[l [n}17.61{]}ὡς δʼ ὅτε τίς τε λέων ὀρεσίτροφος ἀλκὶ πεποιθὼς{l]
[l [n}17.62{]}βοσκομένης ἀγέλης βοῦν ἁρπάσῃ ἥ τις ἀρίστη·{l]
[l [n}17.63{]}τῆς δʼ ἐξ αὐχένʼ ἔαξε λαβὼν κρατεροῖσιν ὀδοῦσι{l]
[l [n}17.64{]}πρῶτον, ἔπειτα δέ θʼ αἷμα καὶ ἔγκατα πάντα λαφύσσει{l]
[l [n}17.65{]}δῃῶν· ἀμφὶ δὲ τόν γε κύνες τʼ ἄνδρές τε νομῆες{l]
[l [n}17.66{]}πολλὰ μάλʼ ἰύζουσιν ἀπόπροθεν οὐδʼ ἐθέλουσιν{l]
[l [n}17.67{]}ἀντίον ἐλθέμεναι· μάλα γὰρ χλωρὸν δέος αἱρεῖ·{l]
[l [n}17.68{]}ὣς τῶν οὔ τινι θυμὸς ἐνὶ στήθεσσιν ἐτόλμα{l]
[l [n}17.69{]}ἀντίον ἐλθέμεναι Μενελάου κυδαλίμοιο.{l]
[l [n}17.70{]}ἔνθά κε ῥεῖα φέροι κλυτὰ τεύχεα Πανθοΐδαο{l]
[l [n}17.71{]}Ἀτρεΐδης, εἰ μή οἱ ἀγάσσατο Φοῖβος Ἀπόλλων,{l]
[l [n}17.72{]}ὅς ῥά οἱ Ἕκτορʼ ἐπῶρσε θοῷ ἀτάλαντον Ἄρηϊ{l]
[l [n}17.73{]}ἀνέρι εἰσάμενος Κικόνων ἡγήτορι Μέντῃ·{l]
[l [n}17.74{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}17.75{]}Ἕκτορ νῦν σὺ μὲν ὧδε θέεις ἀκίχητα διώκων{l]
[l [n}17.76{]}ἵππους Αἰακίδαο δαΐφρονος· οἳ δʼ ἀλεγεινοὶ{l]
[l [n}17.77{]}ἀνδράσι γε θνητοῖσι δαμήμεναι ἠδʼ ὀχέεσθαι{l]
[l [n}17.78{]}ἄλλῳ γʼ ἢ Ἀχιλῆϊ, τὸν ἀθανάτη τέκε μήτηρ.{l]
[l [n}17.79{]}τόφρα δέ τοι Μενέλαος ἀρήϊος Ἀτρέος υἱὸς{l]
[l [n}17.80{]}Πατρόκλῳ περιβὰς Τρώων τὸν ἄριστον ἔπεφνε{l]
[l [n}17.81{]}Πανθοΐδην Εὔφορβον, ἔπαυσε δὲ θούριδος ἀλκῆς.{l]{q]{para]
[para}[l [n}17.82{]}ὣς εἰπὼν ὃ μὲν αὖτις ἔβη θεὸς ἂμ πόνον ἀνδρῶν,{l]
[l [n}17.83{]}Ἕκτορα δʼ αἰνὸν ἄχος πύκασε φρένας ἀμφὶ μελαίνας·{l]
[l [n}17.84{]}πάπτηνεν δʼ ἄρʼ ἔπειτα κατὰ στίχας, αὐτίκα δʼ ἔγνω{l]
[l [n}17.85{]}τὸν μὲν ἀπαινύμενον κλυτὰ τεύχεα, τὸν δʼ ἐπὶ γαίῃ{l]
[l [n}17.86{]}κείμενον· ἔρρει δʼ αἷμα κατʼ οὐταμένην ὠτειλήν.{l]
[l [n}17.87{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ{l]
[l [n}17.88{]}ὀξέα κεκλήγων φλογὶ εἴκελος Ἡφαίστοιο{l]
[l [n}17.89{]}ἀσβέστῳ· οὐδʼ υἱὸν λάθεν Ἀτρέος ὀξὺ βοήσας·{l]
[l [n}17.90{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}17.91{]}ὤ μοι ἐγὼν εἰ μέν κε λίπω κάτα τεύχεα καλὰ{l]
[l [n}17.92{]}Πάτροκλόν θʼ, ὃς κεῖται ἐμῆς ἕνεκʼ ἐνθάδε τιμῆς,{l]
[l [n}17.93{]}μή τίς μοι Δαναῶν νεμεσήσεται ὅς κεν ἴδηται.{l]
[l [n}17.94{]}εἰ δέ κεν Ἕκτορι μοῦνος ἐὼν καὶ Τρωσὶ μάχωμαι{l]
[l [n}17.95{]}αἰδεσθείς, μή πώς με περιστήωσʼ ἕνα πολλοί·{l]
[l [n}17.96{]}Τρῶας δʼ ἐνθάδε πάντας ἄγει κορυθαίολος Ἕκτωρ.{l]
[l [n}17.97{]}ἀλλὰ τί ἤ μοι ταῦτα φίλος διελέξατο θυμός;{l]
[l [n}17.98{]}ὁππότʼ ἀνὴρ ἐθέλῃ πρὸς δαίμονα φωτὶ μάχεσθαι{l]
[l [n}17.99{]}ὅν κε θεὸς τιμᾷ, τάχα οἱ μέγα πῆμα κυλίσθη.{l]
[l [n}17.100{]}τώ μʼ οὔ τις Δαναῶν νεμεσήσεται ὅς κεν ἴδηται{l]
[l [n}17.101{]}Ἕκτορι χωρήσαντʼ, ἐπεὶ ἐκ θεόφιν πολεμίζει.{l]
[l [n}17.102{]}εἰ δέ που Αἴαντός γε βοὴν ἀγαθοῖο πυθοίμην,{l]
[l [n}17.103{]}ἄμφω κʼ αὖτις ἰόντες ἐπιμνησαίμεθα χάρμης{l]
[l [n}17.104{]}καὶ πρὸς δαίμονά περ, εἴ πως ἐρυσαίμεθα νεκρὸν{l]
[l [n}17.105{]}Πηλεΐδῃ Ἀχιλῆϊ· κακῶν δέ κε φέρτατον εἴη.{l]{q]{para]
[para}[l [n}17.106{]}εἷος ὁ ταῦθʼ ὅρμαινε κατὰ φρένα καὶ κατὰ θυμὸν{l]
[l [n}17.107{]}τόφρα δʼ ἐπὶ Τρώων στίχες ἤλυθον· ἦρχε δʼ ἄρʼ Ἕκτωρ.{l]
[l [n}17.108{]}αὐτὰρ ὅ γʼ ἐξοπίσω ἀνεχάζετο, λεῖπε δὲ νεκρὸν{l]
[l [n}17.109{]}ἐντροπαλιζόμενος ὥς τε λὶς ἠϋγένειος,{l]
[l [n}17.110{]}ὅν ῥα κύνες τε καὶ ἄνδρες ἀπὸ σταθμοῖο δίωνται{l]
[l [n}17.111{]}ἔγχεσι καὶ φωνῇ· τοῦ δʼ ἐν φρεσὶν ἄλκιμον ἦτορ{l]
[l [n}17.112{]}παχνοῦται, ἀέκων δέ τʼ ἔβη ἀπὸ μεσσαύλοιο·{l]
[l [n}17.113{]}ὣς ἀπὸ Πατρόκλοιο κίε ξανθὸς Μενέλαος.{l]
[l [n}17.114{]}στῆ δὲ μεταστρεφθεὶς ἐπεὶ ἵκετο ἔθνος ἑταίρων{l]
[l [n}17.115{]}παπταίνων Αἴαντα μέγαν Τελαμώνιον υἱόν.{l]
[l [n}17.116{]}τὸν δὲ μάλʼ αἶψʼ ἐνόησε μάχης ἐπʼ ἀριστερὰ πάσης{l]
[l [n}17.117{]}θαρσύνονθʼ ἑτάρους καὶ ἐποτρύνοντα μάχεσθαι·{l]
[l [n}17.118{]}θεσπέσιον γάρ σφιν φόβον ἔμβαλε Φοῖβος Ἀπόλλων·{l]
[l [n}17.119{]}βῆ δὲ θέειν, εἶθαρ δὲ παριστάμενος ἔπος ηὔδα.{l]
[q}[l [n}17.120{]}Αἶαν δεῦρο πέπον, περὶ Πατρόκλοιο θανόντος{l]
[l [n}17.121{]}σπεύσομεν, αἴ κε νέκυν περ Ἀχιλλῆϊ προφέρωμεν{l]
[l [n}17.122{]}γυμνόν· ἀτὰρ τά γε τεύχεʼ ἔχει κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}17.123{]}ὣς ἔφατʼ, Αἴαντι δὲ δαΐφρονι θυμὸν ὄρινε·{l]
[l [n}17.124{]}βῆ δὲ διὰ προμάχων, ἅμα δὲ ξανθὸς Μενέλαος.{l]
[l [n}17.125{]}Ἕκτωρ μὲν Πάτροκλον ἐπεὶ κλυτὰ τεύχεʼ ἀπηύρα,{l]
[l [n}17.126{]}ἕλχʼ ἵνʼ ἀπʼ ὤμοιιν κεφαλὴν τάμοι ὀξέϊ χαλκῷ,{l]
[l [n}17.127{]}τὸν δὲ νέκυν Τρῳῇσιν ἐρυσσάμενος κυσὶ δοίη.{l]
[l [n}17.128{]}Αἴας δʼ ἐγγύθεν ἦλθε φέρων σάκος ἠΰτε πύργον·{l]
[l [n}17.129{]}Ἕκτωρ δʼ ἂψ ἐς ὅμιλον ἰὼν ἀνεχάζεθʼ ἑταίρων,{l]
[l [n}17.130{]}ἐς δίφρον δʼ ἀνόρουσε· δίδου δʼ ὅ γε τεύχεα καλὰ{l]
[l [n}17.131{]}Τρωσὶ φέρειν προτὶ ἄστυ, μέγα κλέος ἔμμεναι αὐτῷ.{l]
[l [n}17.132{]}Αἴας δʼ ἀμφὶ Μενοιτιάδῃ σάκος εὐρὺ καλύψας{l]
[l [n}17.133{]}ἑστήκει ὥς τίς τε λέων περὶ οἷσι τέκεσσιν,{l]
[l [n}17.134{]}ᾧ ῥά τε νήπιʼ ἄγοντι συναντήσωνται ἐν ὕλῃ{l]
[l [n}17.135{]}ἄνδρες ἐπακτῆρες· ὃ δέ τε σθένεϊ βλεμεαίνει,{l]
[l [n}17.136{]}πᾶν δέ τʼ ἐπισκύνιον κάτω ἕλκεται ὄσσε καλύπτων·{l]
[l [n}17.137{]}ὣς Αἴας περὶ Πατρόκλῳ ἥρωϊ βεβήκει.{l]
[l [n}17.138{]}Ἀτρεΐδης δʼ ἑτέρωθεν ἀρηΐφιλος Μενέλαος{l]
[l [n}17.139{]}ἑστήκει, μέγα πένθος ἐνὶ στήθεσσιν ἀέξων.{l]{para]
[para}[l [n}17.140{]}Γλαῦκος δʼ Ἱππολόχοιο πάϊς Λυκίων ἀγὸς ἀνδρῶν{l]
[l [n}17.141{]}Ἕκτορʼ ὑπόδρα ἰδὼν χαλεπῷ ἠνίπαπε μύθῳ·{l]
[q}[l [n}17.142{]}Ἕκτορ εἶδος ἄριστε μάχης ἄρα πολλὸν ἐδεύεο.{l]
[l [n}17.143{]}ἦ σʼ αὔτως κλέος ἐσθλὸν ἔχει φύξηλιν ἐόντα.{l]
[l [n}17.144{]}φράζεο νῦν ὅππως κε πόλιν καὶ ἄστυ σαώσῃς{l]
[l [n}17.145{]}οἶος σὺν λαοῖς τοὶ Ἰλίῳ ἐγγεγάασιν·{l]
[l [n}17.146{]}οὐ γάρ τις Λυκίων γε μαχησόμενος Δαναοῖσιν{l]
[l [n}17.147{]}εἶσι περὶ πτόλιος, ἐπεὶ οὐκ ἄρα τις χάρις ἦεν{l]
[l [n}17.148{]}μάρνασθαι δηΐοισιν ἐπʼ ἀνδράσι νωλεμὲς αἰεί.{l]
[l [n}17.149{]}πῶς κε σὺ χείρονα φῶτα σαώσειας μεθʼ ὅμιλον{l]
[l [n}17.150{]}σχέτλιʼ, ἐπεὶ Σαρπηδόνʼ ἅμα ξεῖνον καὶ ἑταῖρον{l]
[l [n}17.151{]}κάλλιπες Ἀργείοισιν ἕλωρ καὶ κύρμα γενέσθαι,{l]
[l [n}17.152{]}ὅς τοι πόλλʼ ὄφελος γένετο πτόλεΐ τε καὶ αὐτῷ{l]
[l [n}17.153{]}ζωὸς ἐών· νῦν δʼ οὔ οἱ ἀλαλκέμεναι κύνας ἔτλης.{l]
[l [n}17.154{]}τὼ νῦν εἴ τις ἐμοὶ Λυκίων ἐπιπείσεται ἀνδρῶν{l]
[l [n}17.155{]}οἴκαδʼ ἴμεν, Τροίῃ δὲ πεφήσεται αἰπὺς ὄλεθρος.{l]
[l [n}17.156{]}εἰ γὰρ νῦν Τρώεσσι μένος πολυθαρσὲς ἐνείη{l]
[l [n}17.157{]}ἄτρομον, οἷόν τʼ ἄνδρας ἐσέρχεται οἳ περὶ πάτρης{l]
[l [n}17.158{]}ἀνδράσι δυσμενέεσσι πόνον καὶ δῆριν ἔθεντο,{l]
[l [n}17.159{]}αἶψά κε Πάτροκλον ἐρυσαίμεθα Ἴλιον εἴσω.{l]
[l [n}17.160{]}εἰ δʼ οὗτος προτὶ ἄστυ μέγα Πριάμοιο ἄνακτος{l]
[l [n}17.161{]}ἔλθοι τεθνηὼς καί μιν ἐρυσαίμεθα χάρμης,{l]
[l [n}17.162{]}αἶψά κεν Ἀργεῖοι Σαρπηδόνος ἔντεα καλὰ{l]
[l [n}17.163{]}λύσειαν, καί κʼ αὐτὸν ἀγοίμεθα Ἴλιον εἴσω·{l]
[l [n}17.164{]}τοίου γὰρ θεράπων πέφατʼ ἀνέρος, ὃς μέγʼ ἄριστος{l]
[l [n}17.165{]}Ἀργείων παρὰ νηυσὶ καὶ ἀγχέμαχοι θεράποντες.{l]
[l [n}17.166{]}ἀλλὰ σύ γʼ Αἴαντος μεγαλήτορος οὐκ ἐτάλασσας{l]
[l [n}17.167{]}στήμεναι ἄντα κατʼ ὄσσε ἰδὼν δηΐων ἐν ἀϋτῇ,{l]
[l [n}17.168{]}οὐδʼ ἰθὺς μαχέσασθαι, ἐπεὶ σέο φέρτερός ἐστι.{l]{q]{para]
[para}[l [n}17.169{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}17.170{]}Γλαῦκε τί ἢ δὲ σὺ τοῖος ἐὼν ὑπέροπλον ἔειπες;{l]
[l [n}17.171{]}ὢ πόποι ἦ τʼ ἐφάμην σὲ περὶ φρένας ἔμμεναι ἄλλων{l]
[l [n}17.172{]}τῶν ὅσσοι Λυκίην ἐριβώλακα ναιετάουσι·{l]
[l [n}17.173{]}νῦν δέ σευ ὠνοσάμην πάγχυ φρένας οἷον ἔειπες,{l]
[l [n}17.174{]}ὅς τέ με φῂς Αἴαντα πελώριον οὐχ ὑπομεῖναι.{l]
[l [n}17.175{]}οὔ τοι ἐγὼν ἔρριγα μάχην οὐδὲ κτύπον ἵππων·{l]
[l [n}17.176{]}ἀλλʼ αἰεί τε Διὸς κρείσσων νόος αἰγιόχοιο,{l]
[l [n}17.177{]}ὅς τε καὶ ἄλκιμον ἄνδρα φοβεῖ καὶ ἀφείλετο νίκην{l]
[l [n}17.178{]}ῥηϊδίως, ὁτὲ δʼ αὐτὸς ἐποτρύνει μαχέσασθαι.{l]
[l [n}17.179{]}ἀλλʼ ἄγε δεῦρο πέπον, παρʼ ἔμʼ ἵστασο καὶ ἴδε ἔργον,{l]
[l [n}17.180{]}ἠὲ πανημέριος κακὸς ἔσσομαι, ὡς ἀγορεύεις,{l]
[l [n}17.181{]}ἦ τινα καὶ Δαναῶν ἀλκῆς μάλα περ μεμαῶτα{l]
[l [n}17.182{]}σχήσω ἀμυνέμεναι περὶ Πατρόκλοιο θανόντος.{l]{q]{para]
[para}[l [n}17.183{]}ὣς εἰπὼν Τρώεσσιν ἐκέκλετο μακρὸν ἀΰσας·{l]
[q}[l [n}17.184{]}Τρῶες καὶ Λύκιοι καὶ Δάρδανοι ἀγχιμαχηταί,{l]
[l [n}17.185{]}ἀνέρες ἔστε φίλοι, μνήσασθε δὲ θούριδος ἀλκῆς,{l]
[l [n}17.186{]}ὄφρʼ ἂν ἐγὼν Ἀχιλῆος ἀμύμονος ἔντεα δύω{l]
[l [n}17.187{]}καλά, τὰ Πατρόκλοιο βίην ἐνάριξα κατακτάς.{l]{q]{para]
[para}[l [n}17.188{]}ὣς ἄρα φωνήσας ἀπέβη κορυθαίολος Ἕκτωρ{l]
[l [n}17.189{]}δηΐου ἐκ πολέμοιο· θέων δʼ ἐκίχανεν ἑταίρους{l]
[l [n}17.190{]}ὦκα μάλʼ οὔ πω τῆλε ποσὶ κραιπνοῖσι μετασπών,{l]
[l [n}17.191{]}οἳ προτὶ ἄστυ φέρον κλυτὰ τεύχεα Πηλεΐωνος.{l]
[l [n}17.192{]}στὰς δʼ ἀπάνευθε μάχης πολυδακρύου ἔντεʼ ἄμειβεν·{l]
[l [n}17.193{]}ἤτοι ὃ μὲν τὰ ἃ δῶκε φέρειν προτὶ Ἴλιον ἱρὴν{l]
[l [n}17.194{]}Τρωσὶ φιλοπτολέμοισιν, ὃ δʼ ἄμβροτα τεύχεα δῦνε{l]
[l [n}17.195{]}Πηλεΐδεω Ἀχιλῆος ἅ οἱ θεοὶ Οὐρανίωνες{l]
[l [n}17.196{]}πατρὶ φίλῳ ἔπορον· ὃ δʼ ἄρα ᾧ παιδὶ ὄπασσε{l]
[l [n}17.197{]}γηράς· ἀλλʼ οὐχ υἱὸς ἐν ἔντεσι πατρὸς ἐγήρα.{l]{para]
[para}[l [n}17.198{]}τὸν δʼ ὡς οὖν ἀπάνευθεν ἴδεν νεφεληγερέτα Ζεὺς{l]
[l [n}17.199{]}τεύχεσι Πηλεΐδαο κορυσσόμενον θείοιο,{l]
[l [n}17.200{]}κινήσας ῥα κάρη προτὶ ὃν μυθήσατο θυμόν·{l]
[q}[l [n}17.201{]}ἆ δείλʼ οὐδέ τί τοι θάνατος καταθύμιός ἐστιν{l]
[l [n}17.202{]}ὃς δή τοι σχεδὸν εἶσι· σὺ δʼ ἄμβροτα τεύχεα δύνεις{l]
[l [n}17.203{]}ἀνδρὸς ἀριστῆος, τόν τε τρομέουσι καὶ ἄλλοι·{l]
[l [n}17.204{]}τοῦ δὴ ἑταῖρον ἔπεφνες ἐνηέα τε κρατερόν τε,{l]
[l [n}17.205{]}τεύχεα δʼ οὐ κατὰ κόσμον ἀπὸ κρατός τε καὶ ὤμων{l]
[l [n}17.206{]}εἵλευ· ἀτάρ τοι νῦν γε μέγα κράτος ἐγγυαλίξω,{l]
[l [n}17.207{]}τῶν ποινὴν ὅ τοι οὔ τι μάχης ἐκνοστήσαντι{l]
[l [n}17.208{]}δέξεται Ἀνδρομάχη κλυτὰ τεύχεα Πηλεΐωνος.{l]{q]{para]
[para}[l [n}17.209{]}ἦ καὶ κυανέῃσιν ἐπʼ ὀφρύσι νεῦσε Κρονίων.{l]
[l [n}17.210{]}Ἕκτορι δʼ ἥρμοσε τεύχεʼ ἐπὶ χροΐ, δῦ δέ μιν Ἄρης{l]
[l [n}17.211{]}δεινὸς ἐνυάλιος, πλῆσθεν δʼ ἄρα οἱ μέλεʼ ἐντὸς{l]
[l [n}17.212{]}ἀλκῆς καὶ σθένεος· μετὰ δὲ κλειτοὺς ἐπικούρους{l]
[l [n}17.213{]}βῆ ῥα μέγα ἰάχων· ἰνδάλλετο δέ σφισι πᾶσι{l]
[l [n}17.214{]}τεύχεσι λαμπόμενος μεγαθύμου Πηλεΐωνος.{l]
[l [n}17.215{]}ὄτρυνεν δὲ ἕκαστον ἐποιχόμενος ἐπέεσσι{l]
[l [n}17.216{]}Μέσθλην τε Γλαῦκόν τε Μέδοντά τε Θερσίλοχόν τε{l]
[l [n}17.217{]}Ἀστεροπαῖόν τε Δεισήνορά θʼ Ἱππόθοόν τε{l]
[l [n}17.218{]}Φόρκυν τε Χρομίον τε καὶ Ἔννομον οἰωνιστήν·{l]
[l [n}17.219{]}τοὺς ὅ γʼ ἐποτρύνων ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}17.220{]}κέκλυτε μυρία φῦλα περικτιόνων ἐπικούρων·{l]
[l [n}17.221{]}οὐ γὰρ ἐγὼ πληθὺν διζήμενος οὐδὲ χατίζων{l]
[l [n}17.222{]}ἐνθάδʼ ἀφʼ ὑμετέρων πολίων ἤγειρα ἕκαστον,{l]
[l [n}17.223{]}ἀλλʼ ἵνα μοι Τρώων ἀλόχους καὶ νήπια τέκνα{l]
[l [n}17.224{]}προφρονέως ῥύοισθε φιλοπτολέμων ὑπʼ Ἀχαιῶν.{l]
[l [n}17.225{]}τὰ φρονέων δώροισι κατατρύχω καὶ ἐδωδῇ{l]
[l [n}17.226{]}λαούς, ὑμέτερον δὲ ἑκάστου θυμὸν ἀέξω.{l]
[l [n}17.227{]}τώ τις νῦν ἰθὺς τετραμμένος ἢ ἀπολέσθω{l]
[l [n}17.228{]}ἠὲ σαωθήτω· ἣ γὰρ πολέμου ὀαριστύς.{l]
[l [n}17.229{]}ὃς δέ κε Πάτροκλον καὶ τεθνηῶτά περ ἔμπης{l]
[l [n}17.230{]}Τρῶας ἐς ἱπποδάμους ἐρύσῃ, εἴξῃ δέ οἱ Αἴας,{l]
[l [n}17.231{]}ἥμισυ τῷ ἐνάρων ἀποδάσσομαι, ἥμισυ δʼ αὐτὸς{l]
[l [n}17.232{]}ἕξω ἐγώ· τὸ δέ οἱ κλέος ἔσσεται ὅσσον ἐμοί περ.{l]{q]{para]
[para}[l [n}17.233{]}ὣς ἔφαθʼ, οἳ δʼ ἰθὺς Δαναῶν βρίσαντες ἔβησαν{l]
[l [n}17.234{]}δούρατʼ ἀνασχόμενοι· μάλα δέ σφισιν ἔλπετο θυμὸς{l]
[l [n}17.235{]}νεκρὸν ὑπʼ Αἴαντος ἐρύειν Τελαμωνιάδαο{l]
[l [n}17.236{]}νήπιοι· ἦ τε πολέσσιν ἐπʼ αὐτῷ θυμὸν ἀπηύρα.{l]
[l [n}17.237{]}καὶ τότʼ ἄρʼ Αἴας εἶπε βοὴν ἀγαθὸν Μενέλαον·{l]
[q}[l [n}17.238{]}ὦ πέπον ὦ Μενέλαε διοτρεφὲς οὐκέτι νῶϊ{l]
[l [n}17.239{]}ἔλπομαι αὐτώ περ νοστησέμεν ἐκ πολέμοιο.{l]
[l [n}17.240{]}οὔ τι τόσον νέκυος περιδείδια Πατρόκλοιο,{l]
[l [n}17.241{]}ὅς κε τάχα Τρώων κορέει κύνας ἠδʼ οἰωνούς,{l]
[l [n}17.242{]}ὅσσον ἐμῇ κεφαλῇ περιδείδια μή τι πάθῃσι,{l]
[l [n}17.243{]}καὶ σῇ, ἐπεὶ πολέμοιο νέφος περὶ πάντα καλύπτει{l]
[l [n}17.244{]}Ἕκτωρ, ἡμῖν δʼ αὖτʼ ἀναφαίνεται αἰπὺς ὄλεθρος.{l]
[l [n}17.245{]}ἀλλʼ ἄγʼ ἀριστῆας Δαναῶν κάλει, ἤν τις ἀκούσῃ.{l]{q]{para]
[para}[l [n}17.246{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε βοὴν ἀγαθὸς Μενέλαος,{l]
[l [n}17.247{]}ἤϋσεν δὲ διαπρύσιον Δαναοῖσι γεγωνώς·{l]
[q}[l [n}17.248{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}17.249{]}οἵ τε παρʼ Ἀτρεΐδῃς Ἀγαμέμνονι καὶ Μενελάῳ{l]
[l [n}17.250{]}δήμια πίνουσιν καὶ σημαίνουσιν ἕκαστος{l]
[l [n}17.251{]}λαοῖς· ἐκ δὲ Διὸς τιμὴ καὶ κῦδος ὀπηδεῖ.{l]
[l [n}17.252{]}ἀργαλέον δέ μοί ἐστι διασκοπιᾶσθαι ἕκαστον{l]
[l [n}17.253{]}ἡγεμόνων· τόσση γὰρ ἔρις πολέμοιο δέδηεν·{l]
[l [n}17.254{]}ἀλλά τις αὐτὸς ἴτω, νεμεσιζέσθω δʼ ἐνὶ θυμῷ{l]
[l [n}17.255{]}Πάτροκλον Τρῳῇσι κυσὶν μέλπηθρα γενέσθαι.{l]{q]{para]
[para}[l [n}17.256{]}ὣς ἔφατʼ, ὀξὺ δʼ ἄκουσεν Ὀϊλῆος ταχὺς Αἴας·{l]
[l [n}17.257{]}πρῶτος δʼ ἀντίος ἦλθε θέων ἀνὰ δηϊοτῆτα,{l]
[l [n}17.258{]}τὸν δὲ μετʼ Ἰδομενεὺς καὶ ὀπάων Ἰδομενῆος{l]
[l [n}17.259{]}Μηριόνης ἀτάλαντος Ἐνυαλίῳ ἀνδρειφόντῃ.{l]
[l [n}17.260{]}τῶν δʼ ἄλλων τίς κεν ᾗσι φρεσὶν οὐνόματʼ εἴποι,{l]
[l [n}17.261{]}ὅσσοι δὴ μετόπισθε μάχην ἤγειραν Ἀχαιῶν;{l]{para]
[para}[l [n}17.262{]}Τρῶες δὲ προὔτυψαν ἀολλέες· ἦρχε δʼ ἄρʼ Ἕκτωρ.{l]
[l [n}17.263{]}ὡς δʼ ὅτʼ ἐπὶ προχοῇσι διιπετέος ποταμοῖο{l]
[l [n}17.264{]}βέβρυχεν μέγα κῦμα ποτὶ ῥόον, ἀμφὶ δέ τʼ ἄκραι{l]
[l [n}17.265{]}ἠϊόνες βοόωσιν ἐρευγομένης ἁλὸς ἔξω,{l]
[l [n}17.266{]}τόσσῃ ἄρα Τρῶες ἰαχῇ ἴσαν. αὐτὰρ Ἀχαιοὶ{l]
[l [n}17.267{]}ἕστασαν ἀμφὶ Μενοιτιάδῃ ἕνα θυμὸν ἔχοντες{l]
[l [n}17.268{]}φραχθέντες σάκεσιν χαλκήρεσιν· ἀμφὶ δʼ ἄρά σφι{l]
[l [n}17.269{]}λαμπρῇσιν κορύθεσσι Κρονίων ἠέρα πολλὴν{l]
[l [n}17.270{]}χεῦʼ, ἐπεὶ οὐδὲ Μενοιτιάδην ἔχθαιρε πάρος γε,{l]
[l [n}17.271{]}ὄφρα ζωὸς ἐὼν θεράπων ἦν Αἰακίδαο·{l]
[l [n}17.272{]}μίσησεν δʼ ἄρα μιν δηΐων κυσὶ κύρμα γενέσθαι{l]
[l [n}17.273{]}Τρῳῇσιν· τὼ καί οἱ ἀμυνέμεν ὦρσεν ἑταίρους.{l]{para]
[para}[l [n}17.274{]}ὦσαν δὲ πρότεροι Τρῶες ἑλίκωπας Ἀχαιούς·{l]
[l [n}17.275{]}νεκρὸν δὲ προλιπόντες ὑπέτρεσαν, οὐδέ τινʼ αὐτῶν{l]
[l [n}17.276{]}Τρῶες ὑπέρθυμοι ἕλον ἔγχεσιν ἱέμενοί περ,{l]
[l [n}17.277{]}ἀλλὰ νέκυν ἐρύοντο· μίνυνθα δὲ καὶ τοῦ Ἀχαιοὶ{l]
[l [n}17.278{]}μέλλον ἀπέσσεσθαι· μάλα γάρ σφεας ὦκʼ ἐλέλιξεν{l]
[l [n}17.279{]}Αἴας, ὃς περὶ μὲν εἶδος, περὶ δʼ ἔργα τέτυκτο{l]
[l [n}17.280{]}τῶν ἄλλων Δαναῶν μετʼ ἀμύμονα Πηλεΐωνα.{l]
[l [n}17.281{]}ἴθυσεν δὲ διὰ προμάχων συῒ εἴκελος ἀλκὴν{l]
[l [n}17.282{]}καπρίῳ, ὅς τʼ ἐν ὄρεσσι κύνας θαλερούς τʼ αἰζηοὺς{l]
[l [n}17.283{]}ῥηϊδίως ἐκέδασσεν, ἑλιξάμενος διὰ βήσσας·{l]
[l [n}17.284{]}ὣς υἱὸς Τελαμῶνος ἀγαυοῦ φαίδιμος Αἴας{l]
[l [n}17.285{]}ῥεῖα μετεισάμενος Τρώων ἐκέδασσε φάλαγγας{l]
[l [n}17.286{]}οἳ περὶ Πατρόκλῳ βέβασαν, φρόνεον δὲ μάλιστα{l]
[l [n}17.287{]}ἄστυ πότι σφέτερον ἐρύειν καὶ κῦδος ἀρέσθαι.{l]{para]
[para}[l [n}17.288{]}ἤτοι τὸν Λήθοιο Πελασγοῦ φαίδιμος υἱὸς{l]
[l [n}17.289{]}Ἱππόθοος ποδὸς ἕλκε κατὰ κρατερὴν ὑσμίνην{l]
[l [n}17.290{]}δησάμενος τελαμῶνι παρὰ σφυρὸν ἀμφὶ τένοντας{l]
[l [n}17.291{]}Ἕκτορι καὶ Τρώεσσι χαριζόμενος· τάχα δʼ αὐτῷ{l]
[l [n}17.292{]}ἦλθε κακόν, τό οἱ οὔ τις ἐρύκακεν ἱεμένων περ.{l]
[l [n}17.293{]}τὸν δʼ υἱὸς Τελαμῶνος ἐπαΐξας διʼ ὁμίλου{l]
[l [n}17.294{]}πλῆξʼ αὐτοσχεδίην κυνέης διὰ χαλκοπαρῄου·{l]
[l [n}17.295{]}ἤρικε δʼ ἱπποδάσεια κόρυς περὶ δουρὸς ἀκωκῇ{l]
[l [n}17.296{]}πληγεῖσʼ ἔγχεΐ τε μεγάλῳ καὶ χειρὶ παχείῃ,{l]
[l [n}17.297{]}ἐγκέφαλος δὲ παρʼ αὐλὸν ἀνέδραμεν ἐξ ὠτειλῆς{l]
[l [n}17.298{]}αἱματόεις· τοῦ δʼ αὖθι λύθη μένος, ἐκ δʼ ἄρα χειρῶν{l]
[l [n}17.299{]}Πατρόκλοιο πόδα μεγαλήτορος ἧκε χαμᾶζε{l]
[l [n}17.300{]}κεῖσθαι· ὃ δʼ ἄγχʼ αὐτοῖο πέσε πρηνὴς ἐπὶ νεκρῷ{l]
[l [n}17.301{]}τῆλʼ ἀπὸ Λαρίσης ἐριβώλακος, οὐδὲ τοκεῦσι{l]
[l [n}17.302{]}θρέπτρα φίλοις ἀπέδωκε, μινυνθάδιος δέ οἱ αἰὼν{l]
[l [n}17.303{]}ἔπλεθʼ ὑπʼ Αἴαντος μεγαθύμου δουρὶ δαμέντι.{l]{para]
[para}[l [n}17.304{]}Ἕκτωρ δʼ αὖτʼ Αἴαντος ἀκόντισε δουρὶ φαεινῷ·{l]
[l [n}17.305{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος{l]
[l [n}17.306{]}τυτθόν· ὃ δὲ Σχεδίον μεγαθύμου Ἰφίτου υἱὸν{l]
[l [n}17.307{]}Φωκήων ὄχʼ ἄριστον, ὃς ἐν κλειτῷ Πανοπῆϊ{l]
[l [n}17.308{]}οἰκία ναιετάασκε πολέσσʼ ἄνδρεσσιν ἀνάσσων,{l]
[l [n}17.309{]}τὸν βάλʼ ὑπὸ κληῗδα μέσην· διὰ δʼ ἀμπερὲς ἄκρη{l]
[l [n}17.310{]}αἰχμὴ χαλκείη παρὰ νείατον ὦμον ἀνέσχε·{l]
[l [n}17.311{]}δούπησεν δὲ πεσών, ἀράβησε δὲ τεύχεʼ ἐπʼ αὐτῷ.{l]{para]
[para}[l [n}17.312{]}Αἴας δʼ αὖ Φόρκυνα δαΐφρονα Φαίνοπος υἱὸν{l]
[l [n}17.313{]}Ἱπποθόῳ περιβάντα μέσην κατὰ γαστέρα τύψε·{l]
[l [n}17.314{]}ῥῆξε δὲ θώρηκος γύαλον, διὰ δʼ ἔντερα χαλκὸς{l]
[l [n}17.315{]}ἤφυσʼ· ὃ δʼ ἐν κονίῃσι πεσὼν ἕλε γαῖαν ἀγοστῷ.{l]
[l [n}17.316{]}χώρησαν δʼ ὑπό τε πρόμαχοι καὶ φαίδιμος Ἕκτωρ·{l]
[l [n}17.317{]}Ἀργεῖοι δὲ μέγα ἴαχον, ἐρύσαντο δὲ νεκροὺς{l]
[l [n}17.318{]}Φόρκυν θʼ Ἱππόθοόν τε, λύοντο δὲ τεύχεʼ ἀπʼ ὤμων.{l]{para]
[para}[l [n}17.319{]}ἔνθά κεν αὖτε Τρῶες ἀρηϊφίλων ὑπʼ Ἀχαιῶν{l]
[l [n}17.320{]}Ἴλιον εἰσανέβησαν ἀναλκείῃσι δαμέντες,{l]
[l [n}17.321{]}Ἀργεῖοι δέ κε κῦδος ἕλον καὶ ὑπὲρ Διὸς αἶσαν{l]
[l [n}17.322{]}κάρτεϊ καὶ σθένεϊ σφετέρῳ· ἀλλʼ αὐτὸς Ἀπόλλων{l]
[l [n}17.323{]}Αἰνείαν ὄτρυνε δέμας Περίφαντι ἐοικὼς{l]
[l [n}17.324{]}κήρυκι Ἠπυτίδῃ, ὅς οἱ παρὰ πατρὶ γέροντι{l]
[l [n}17.325{]}κηρύσσων γήρασκε φίλα φρεσὶ μήδεα εἰδώς·{l]
[l [n}17.326{]}τῷ μιν ἐεισάμενος προσέφη Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}17.327{]}Αἰνεία πῶς ἂν καὶ ὑπὲρ θεὸν εἰρύσσαισθε{l]
[l [n}17.328{]}Ἴλιον αἰπεινήν; ὡς δὴ ἴδον ἀνέρας ἄλλους{l]
[l [n}17.329{]}κάρτεΐ τε σθένεΐ τε πεποιθότας ἠνορέῃ τε{l]
[l [n}17.330{]}πλήθεΐ τε σφετέρῳ καὶ ὑπερδέα δῆμον ἔχοντας·{l]
[l [n}17.331{]}ἡμῖν δὲ Ζεὺς μὲν πολὺ βούλεται ἢ Δαναοῖσι{l]
[l [n}17.332{]}νίκην· ἀλλʼ αὐτοὶ τρεῖτʼ ἄσπετον οὐδὲ μάχεσθε.{l]{q]{para]
[para}[l [n}17.333{]}ὣς ἔφατʼ, Αἰνείας δʼ ἑκατηβόλον Ἀπόλλωνα{l]
[l [n}17.334{]}ἔγνω ἐς ἄντα ἰδών, μέγα δʼ Ἕκτορα εἶπε βοήσας·{l]
[q}[l [n}17.335{]}Ἕκτόρ τʼ ἠδʼ ἄλλοι Τρώων ἀγοὶ ἠδʼ ἐπικούρων{l]
[l [n}17.336{]}αἰδὼς μὲν νῦν ἥδε γʼ ἀρηϊφίλων ὑπʼ Ἀχαιῶν{l]
[l [n}17.337{]}Ἴλιον εἰσαναβῆναι ἀναλκείῃσι δαμέντας.{l]
[l [n}17.338{]}ἀλλʼ ἔτι γάρ τίς φησι θεῶν ἐμοὶ ἄγχι παραστὰς{l]
[l [n}17.339{]}Ζῆνʼ ὕπατον μήστωρα μάχης ἐπιτάρροθον εἶναι·{l]
[l [n}17.340{]}τώ ῥʼ ἰθὺς Δαναῶν ἴομεν, μηδʼ οἵ γε ἕκηλοι{l]
[l [n}17.341{]}Πάτροκλον νηυσὶν πελασαίατο τεθνηῶτα.{l]{q]{para]
[para}[l [n}17.342{]}ὣς φάτο, καί ῥα πολὺ προμάχων ἐξάλμενος ἔστη·{l]
[l [n}17.343{]}οἳ δʼ ἐλελίχθησαν καὶ ἐναντίοι ἔσταν Ἀχαιῶν.{l]
[l [n}17.344{]}ἔνθʼ αὖτʼ Αἰνείας Λειώκριτον οὔτασε δουρὶ{l]
[l [n}17.345{]}υἱὸν Ἀρίσβαντος Λυκομήδεος ἐσθλὸν ἑταῖρον.{l]
[l [n}17.346{]}τὸν δὲ πεσόντʼ ἐλέησεν ἀρηΐφιλος Λυκομήδης,{l]
[l [n}17.347{]}στῆ δὲ μάλʼ ἐγγὺς ἰών, καὶ ἀκόντισε δουρὶ φαεινῷ,{l]
[l [n}17.348{]}καὶ βάλεν Ἱππασίδην Ἀπισάονα ποιμένα λαῶν{l]
[l [n}17.349{]}ἧπαρ ὑπὸ πραπίδων, εἶθαρ δʼ ὑπὸ γούνατʼ ἔλυσεν,{l]
[l [n}17.350{]}ὅς ῥʼ ἐκ Παιονίης ἐριβώλακος εἰληλούθει,{l]
[l [n}17.351{]}καὶ δὲ μετʼ Ἀστεροπαῖον ἀριστεύεσκε μάχεσθαι.{l]{para]
[para}[l [n}17.352{]}τὸν δὲ πεσόντʼ ἐλέησεν ἀρήϊος Ἀστεροπαῖος,{l]
[l [n}17.353{]}ἴθυσεν δὲ καὶ ὃ πρόφρων Δαναοῖσι μάχεσθαι·{l]
[l [n}17.354{]}ἀλλʼ οὔ πως ἔτι εἶχε· σάκεσσι γὰρ ἔρχατο πάντῃ{l]
[l [n}17.355{]}ἑσταότες περὶ Πατρόκλῳ, πρὸ δὲ δούρατʼ ἔχοντο.{l]
[l [n}17.356{]}Αἴας γὰρ μάλα πάντας ἐπῴχετο πολλὰ κελεύων·{l]
[l [n}17.357{]}οὔτέ τινʼ ἐξοπίσω νεκροῦ χάζεσθαι ἀνώγει{l]
[l [n}17.358{]}οὔτέ τινα προμάχεσθαι Ἀχαιῶν ἔξοχον ἄλλων,{l]
[l [n}17.359{]}ἀλλὰ μάλʼ ἀμφʼ αὐτῷ βεβάμεν, σχεδόθεν δὲ μάχεσθαι.{l]
[l [n}17.360{]}ὣς Αἴας ἐπέτελλε πελώριος, αἵματι δὲ χθὼν{l]
[l [n}17.361{]}δεύετο πορφυρέῳ, τοὶ δʼ ἀγχιστῖνοι ἔπιπτον{l]
[l [n}17.362{]}νεκροὶ ὁμοῦ Τρώων καὶ ὑπερμενέων ἐπικούρων{l]
[l [n}17.363{]}καὶ Δαναῶν· οὐδʼ οἳ γὰρ ἀναιμωτί γε μάχοντο,{l]
[l [n}17.364{]}παυρότεροι δὲ πολὺ φθίνυθον· μέμνηντο γὰρ αἰεὶ{l]
[l [n}17.365{]}ἀλλήλοις ἀνʼ ὅμιλον ἀλεξέμεναι φόνον αἰπύν.{l]{para]
[para}[l [n}17.366{]}ὣς οἳ μὲν μάρναντο δέμας πυρός, οὐδέ κε φαίης{l]
[l [n}17.367{]}οὔτέ ποτʼ ἠέλιον σῶν ἔμμεναι οὔτε σελήνην·{l]
[l [n}17.368{]}ἠέρι γὰρ κατέχοντο μάχης ἐπί θʼ ὅσσον ἄριστοι{l]
[l [n}17.369{]}ἕστασαν ἀμφὶ Μενοιτιάδῃ κατατεθνηῶτι.{l]
[l [n}17.370{]}οἳ δʼ ἄλλοι Τρῶες καὶ ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}17.371{]}εὔκηλοι πολέμιζον ὑπʼ αἰθέρι, πέπτατο δʼ αὐγὴ{l]
[l [n}17.372{]}ἠελίου ὀξεῖα, νέφος δʼ οὐ φαίνετο πάσης{l]
[l [n}17.373{]}γαίης οὐδʼ ὀρέων· μεταπαυόμενοι δὲ μάχοντο{l]
[l [n}17.374{]}ἀλλήλων ἀλεείνοντες βέλεα στονόεντα{l]
[l [n}17.375{]}πολλὸν ἀφεσταότες. τοὶ δʼ ἐν μέσῳ ἄλγεʼ ἔπασχον{l]
[l [n}17.376{]}ἠέρι καὶ πολέμῳ, τείροντο δὲ νηλέϊ χαλκῷ{l]
[l [n}17.377{]}ὅσσοι ἄριστοι ἔσαν· δύο δʼ οὔ πω φῶτε πεπύσθην{l]
[l [n}17.378{]}ἀνέρε κυδαλίμω Θρασυμήδης Ἀντίλοχός τε{l]
[l [n}17.379{]}Πατρόκλοιο θανόντος ἀμύμονος, ἀλλʼ ἔτʼ ἔφαντο{l]
[l [n}17.380{]}ζωὸν ἐνὶ πρώτῳ ὁμάδῳ Τρώεσσι μάχεσθαι.{l]
[l [n}17.381{]}τὼ δʼ ἐπιοσσομένω θάνατον καὶ φύζαν ἑταίρων{l]
[l [n}17.382{]}νόσφιν ἐμαρνάσθην, ἐπεὶ ὣς ἐπετέλλετο Νέστωρ{l]
[l [n}17.383{]}ὀτρύνων πόλεμον δὲ μελαινάων ἀπὸ νηῶν.{l]{para]
[para}[l [n}17.384{]}τοῖς δὲ πανημερίοις ἔριδος μέγα νεῖκος ὀρώρει{l]
[l [n}17.385{]}ἀργαλέης· καμάτῳ δὲ καὶ ἱδρῷ νωλεμὲς αἰεὶ{l]
[l [n}17.386{]}γούνατά τε κνῆμαί τε πόδες θʼ ὑπένερθεν ἑκάστου{l]
[l [n}17.387{]}χεῖρές τʼ ὀφθαλμοί τε παλάσσετο μαρναμένοιιν{l]
[l [n}17.388{]}ἀμφʼ ἀγαθὸν θεράποντα ποδώκεος Αἰακίδαο.{l]
[l [n}17.389{]}ὡς δʼ ὅτʼ ἀνὴρ ταύροιο βοὸς μεγάλοιο βοείην{l]
[l [n}17.390{]}λαοῖσιν δώῃ τανύειν μεθύουσαν ἀλοιφῇ·{l]
[l [n}17.391{]}δεξάμενοι δʼ ἄρα τοί γε διαστάντες τανύουσι{l]
[l [n}17.392{]}κυκλόσʼ, ἄφαρ δέ τε ἰκμὰς ἔβη, δύνει δέ τʼ ἀλοιφὴ{l]
[l [n}17.393{]}πολλῶν ἑλκόντων, τάνυται δέ τε πᾶσα διὰ πρό·{l]
[l [n}17.394{]}ὣς οἵ γʼ ἔνθα καὶ ἔνθα νέκυν ὀλίγῃ ἐνὶ χώρῃ{l]
[l [n}17.395{]}εἵλκεον ἀμφότεροι· μάλα δέ σφισιν ἔλπετο θυμὸς{l]
[l [n}17.396{]}Τρωσὶν μὲν ἐρύειν προτὶ Ἴλιον, αὐτὰρ Ἀχαιοῖς{l]
[l [n}17.397{]}νῆας ἔπι γλαφυράς· περὶ δʼ αὐτοῦ μῶλος ὀρώρει{l]
[l [n}17.398{]}ἄγριος· οὐδέ κʼ Ἄρης λαοσσόος οὐδέ κʼ Ἀθήνη{l]
[l [n}17.399{]}τόν γε ἰδοῦσʼ ὀνόσαιτʼ, οὐδʼ εἰ μάλα μιν χόλος ἵκοι·{l]
[l [n}17.400{]}τοῖον Ζεὺς ἐπὶ Πατρόκλῳ ἀνδρῶν τε καὶ ἵππων{l]
[l [n}17.401{]}ἤματι τῷ ἐτάνυσσε κακὸν πόνον· οὐδʼ ἄρα πώ τι{l]
[l [n}17.402{]}ᾔδεε Πάτροκλον τεθνηότα δῖος Ἀχιλλεύς·{l]
[l [n}17.403{]}πολλὸν γὰρ ῥʼ ἀπάνευθε νεῶν μάρναντο θοάων{l]
[l [n}17.404{]}τείχει ὕπο Τρώων· τό μιν οὔ ποτε ἔλπετο θυμῷ{l]
[l [n}17.405{]}τεθνάμεν, ἀλλὰ ζωὸν ἐνιχριμφθέντα πύλῃσιν{l]
[l [n}17.406{]}ἂψ ἀπονοστήσειν, ἐπεὶ οὐδὲ τὸ ἔλπετο πάμπαν{l]
[l [n}17.407{]}ἐκπέρσειν πτολίεθρον ἄνευ ἕθεν, οὐδὲ σὺν αὐτῷ·{l]
[l [n}17.408{]}πολλάκι γὰρ τό γε μητρὸς ἐπεύθετο νόσφιν ἀκούων,{l]
[l [n}17.409{]}ἥ οἱ ἀπαγγέλλεσκε Διὸς μεγάλοιο νόημα.{l]
[l [n}17.410{]}δὴ τότε γʼ οὔ οἱ ἔειπε κακὸν τόσον ὅσσον ἐτύχθη{l]
[l [n}17.411{]}μήτηρ, ὅττί ῥά οἱ πολὺ φίλτατος ὤλεθʼ ἑταῖρος.{l]{para]
[para}[l [n}17.412{]}οἳ δʼ αἰεὶ περὶ νεκρὸν ἀκαχμένα δούρατʼ ἔχοντες{l]
[l [n}17.413{]}νωλεμὲς ἐγχρίμπτοντο καὶ ἀλλήλους ἐνάριζον·{l]
[l [n}17.414{]}ὧδε δέ τις εἴπεσκεν Ἀχαιῶν χαλκοχιτώνων·{l]
[q}[l [n}17.415{]}ὦ φίλοι οὐ μὰν ἧμιν ἐϋκλεὲς ἀπονέεσθαι{l]
[l [n}17.416{]}νῆας ἔπι γλαφυράς, ἀλλʼ αὐτοῦ γαῖα μέλαινα{l]
[l [n}17.417{]}πᾶσι χάνοι· τό κεν ἧμιν ἄφαρ πολὺ κέρδιον εἴη{l]
[l [n}17.418{]}εἰ τοῦτον Τρώεσσι μεθήσομεν ἱπποδάμοισιν{l]
[l [n}17.419{]}ἄστυ πότι σφέτερον ἐρύσαι καὶ κῦδος ἀρέσθαι.{l]{q]{para]
[para}[l [n}17.420{]}ὣς δέ τις αὖ Τρώων μεγαθύμων αὐδήσασκεν·{l]
[q}[l [n}17.421{]}ὦ φίλοι, εἰ καὶ μοῖρα παρʼ ἀνέρι τῷδε δαμῆναι{l]
[l [n}17.422{]}πάντας ὁμῶς, μή πώ τις ἐρωείτω πολέμοιο.{l]{q]{para]
[para}[l [n}17.423{]}ὣς ἄρα τις εἴπεσκε, μένος δʼ ὄρσασκεν ἑκάστου.{l]
[l [n}17.424{]}ὣς οἳ μὲν μάρναντο, σιδήρειος δʼ ὀρυμαγδὸς{l]
[l [n}17.425{]}χάλκεον οὐρανὸν ἷκε διʼ αἰθέρος ἀτρυγέτοιο·{l]
[l [n}17.426{]}ἵπποι δʼ Αἰακίδαο μάχης ἀπάνευθεν ἐόντες{l]
[l [n}17.427{]}κλαῖον, ἐπεὶ δὴ πρῶτα πυθέσθην ἡνιόχοιο{l]
[l [n}17.428{]}ἐν κονίῃσι πεσόντος ὑφʼ Ἕκτορος ἀνδροφόνοιο.{l]
[l [n}17.429{]}ἦ μὰν Αὐτομέδων Διώρεος ἄλκιμος υἱὸς{l]
[l [n}17.430{]}πολλὰ μὲν ἂρ μάστιγι θοῇ ἐπεμαίετο θείνων,{l]
[l [n}17.431{]}πολλὰ δὲ μειλιχίοισι προσηύδα, πολλὰ δʼ ἀρειῇ·{l]
[l [n}17.432{]}τὼ δʼ οὔτʼ ἂψ ἐπὶ νῆας ἐπὶ πλατὺν Ἑλλήσποντον{l]
[l [n}17.433{]}ἠθελέτην ἰέναι οὔτʼ ἐς πόλεμον μετʼ Ἀχαιούς,{l]
[l [n}17.434{]}ἀλλʼ ὥς τε στήλη μένει ἔμπεδον, ἥ τʼ ἐπὶ τύμβῳ{l]
[l [n}17.435{]}ἀνέρος ἑστήκῃ τεθνηότος ἠὲ γυναικός,{l]
[l [n}17.436{]}ὣς μένον ἀσφαλέως περικαλλέα δίφρον ἔχοντες{l]
[l [n}17.437{]}οὔδει ἐνισκίμψαντε καρήατα· δάκρυα δέ σφι{l]
[l [n}17.438{]}θερμὰ κατὰ βλεφάρων χαμάδις ῥέε μυρομένοισιν{l]
[l [n}17.439{]}ἡνιόχοιο πόθῳ· θαλερὴ δʼ ἐμιαίνετο χαίτη{l]
[l [n}17.440{]}ζεύγλης ἐξεριποῦσα παρὰ ζυγὸν ἀμφοτέρωθεν.{l]{para]
[para}[l [n}17.441{]}μυρομένω δʼ ἄρα τώ γε ἰδὼν ἐλέησε Κρονίων,{l]
[l [n}17.442{]}κινήσας δὲ κάρη προτὶ ὃν μυθήσατο θυμόν·{l]
[q}
[para}[l [n}17.443{]}ἆ δειλώ, τί σφῶϊ δόμεν Πηλῆϊ ἄνακτι{l]
[l [n}17.444{]}θνητῷ, ὑμεῖς δʼ ἐστὸν ἀγήρω τʼ ἀθανάτω τε;{l]
[l [n}17.445{]}ἦ ἵνα δυστήνοισι μετʼ ἀνδράσιν ἄλγεʼ ἔχητον;{l]
[l [n}17.446{]}οὐ μὲν γάρ τί πού ἐστιν ὀϊζυρώτερον ἀνδρὸς{l]
[l [n}17.447{]}πάντων, ὅσσά τε γαῖαν ἔπι πνείει τε καὶ ἕρπει.{l]
[l [n}17.448{]}ἀλλʼ οὐ μὰν ὑμῖν γε καὶ ἅρμασι δαιδαλέοισιν{l]
[l [n}17.449{]}Ἕκτωρ Πριαμίδης ἐποχήσεται· οὐ γὰρ ἐάσω.{l]
[l [n}17.450{]}ἦ οὐχ ἅλις ὡς καὶ τεύχεʼ ἔχει καὶ ἐπεύχεται αὔτως;{l]
[l [n}17.451{]}σφῶϊν δʼ ἐν γούνεσσι βαλῶ μένος ἠδʼ ἐνὶ θυμῷ,{l]
[l [n}17.452{]}ὄφρα καὶ Αὐτομέδοντα σαώσετον ἐκ πολέμοιο{l]
[l [n}17.453{]}νῆας ἔπι γλαφυράς· ἔτι γάρ σφισι κῦδος ὀρέξω{l]
[l [n}17.454{]}κτείνειν, εἰς ὅ κε νῆας ἐϋσσέλμους ἀφίκωνται{l]
[l [n}17.455{]}δύῃ τʼ ἠέλιος καὶ ἐπὶ κνέφας ἱερὸν ἔλθῃ·{l]{q]{para]
[para}[l [n}17.456{]}ὣς εἰπὼν ἵπποισιν ἐνέπνευσεν μένος ἠΰ.{l]
[l [n}17.457{]}τὼ δʼ ἀπὸ χαιτάων κονίην οὖδας δὲ βαλόντε{l]
[l [n}17.458{]}ῥίμφα φέρον θοὸν ἅρμα μετὰ Τρῶας καὶ Ἀχαιούς.{l]
[l [n}17.459{]}τοῖσι δʼ ἐπʼ Αὐτομέδων μάχετʼ ἀχνύμενός περ ἑταίρου{l]
[l [n}17.460{]}ἵπποις ἀΐσσων ὥς τʼ αἰγυπιὸς μετὰ χῆνας·{l]
[l [n}17.461{]}ῥέα μὲν γὰρ φεύγεσκεν ὑπʼ ἐκ Τρώων ὀρυμαγδοῦ,{l]
[l [n}17.462{]}ῥεῖα δʼ ἐπαΐξασκε πολὺν καθʼ ὅμιλον ὀπάζων.{l]
[l [n}17.463{]}ἀλλʼ οὐχ ᾕρει φῶτας ὅτε σεύαιτο διώκειν·{l]
[l [n}17.464{]}οὐ γάρ πως ἦν οἶον ἐόνθʼ ἱερῷ ἐνὶ δίφρῳ{l]
[l [n}17.465{]}ἔγχει ἐφορμᾶσθαι καὶ ἐπίσχειν ὠκέας ἵππους.{l]
[l [n}17.466{]}ὀψὲ δὲ δή μιν ἑταῖρος ἀνὴρ ἴδεν ὀφθαλμοῖσιν{l]
[l [n}17.467{]}Ἀλκιμέδων υἱὸς Λαέρκεος Αἱμονίδαο·{l]
[l [n}17.468{]}στῆ δʼ ὄπιθεν δίφροιο καὶ Αὐτομέδοντα προσηύδα·{l]
[q}[l [n}17.469{]}Αὐτόμεδον, τίς τοί νυ θεῶν νηκερδέα βουλὴν{l]
[l [n}17.470{]}ἐν στήθεσσιν ἔθηκε, καὶ ἐξέλετο φρένας ἐσθλάς;{l]
[l [n}17.471{]}οἷον πρὸς Τρῶας μάχεαι πρώτῳ ἐν ὁμίλῳ{l]
[l [n}17.472{]}μοῦνος· ἀτάρ τοι ἑταῖρος ἀπέκτατο, τεύχεα δʼ Ἕκτωρ{l]
[l [n}17.473{]}αὐτὸς ἔχων ὤμοισιν ἀγάλλεται Αἰακίδαο.{l]{q]{para]
[para}[l [n}17.474{]}τὸν δʼ αὖτʼ Αὐτομέδων προσέφη Διώρεος υἱός·{l]
[q}[l [n}17.475{]}Ἀλκίμεδον τίς γάρ τοι Ἀχαιῶν ἄλλος ὁμοῖος{l]
[l [n}17.476{]}ἵππων ἀθανάτων ἐχέμεν δμῆσίν τε μένος τε,{l]
[l [n}17.477{]}εἰ μὴ Πάτροκλος θεόφιν μήστωρ ἀτάλαντος{l]
[l [n}17.478{]}ζωὸς ἐών; νῦν αὖ θάνατος καὶ μοῖρα κιχάνει.{l]
[l [n}17.479{]}ἀλλὰ σὺ μὲν μάστιγα καὶ ἡνία σιγαλόεντα{l]
[l [n}17.480{]}δέξαι, ἐγὼ δʼ ἵππων ἀποβήσομαι, ὄφρα μάχωμαι.{l]{q]{para]
[para}[l [n}17.481{]}ὣς ἔφατʼ, Ἀλκιμέδων δὲ βοηθόον ἅρμʼ ἐπορούσας{l]
[l [n}17.482{]}καρπαλίμως μάστιγα καὶ ἡνία λάζετο χερσίν,{l]
[l [n}17.483{]}Αὐτομέδων δʼ ἀπόρουσε· νόησε δὲ φαίδιμος Ἕκτωρ,{l]
[l [n}17.484{]}αὐτίκα δʼ Αἰνείαν προσεφώνεεν ἐγγὺς ἐόντα·{l]
[q}[l [n}17.485{]}Αἰνεία Τρώων βουληφόρε χαλκοχιτώνων{l]
[l [n}17.486{]}ἵππω τώδʼ ἐνόησα ποδώκεος Αἰακίδαο{l]
[l [n}17.487{]}ἐς πόλεμον προφανέντε σὺν ἡνιόχοισι κακοῖσι·{l]
[l [n}17.488{]}τώ κεν ἐελποίμην αἱρησέμεν, εἰ σύ γε θυμῷ{l]
[l [n}17.489{]}σῷ ἐθέλεις, ἐπεὶ οὐκ ἂν ἐφορμηθέντε γε νῶϊ{l]
[l [n}17.490{]}τλαῖεν ἐναντίβιον στάντες μαχέσασθαι Ἄρηϊ.{l]{q]{para]
[para}[l [n}17.491{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησεν ἐῢς πάϊς Ἀγχίσαο.{l]
[l [n}17.492{]}τὼ δʼ ἰθὺς βήτην βοέῃς εἰλυμένω ὤμους{l]
[l [n}17.493{]}αὔῃσι στερεῇσι· πολὺς δʼ ἐπελήλατο χαλκός.{l]
[l [n}17.494{]}τοῖσι δʼ ἅμα Χρομίος τε καὶ Ἄρητος θεοειδὴς{l]
[l [n}17.495{]}ἤϊσαν ἀμφότεροι· μάλα δέ σφισιν ἔλπετο θυμὸς{l]
[l [n}17.496{]}αὐτώ τε κτενέειν ἐλάαν τʼ ἐριαύχενας ἵππους{l]
[l [n}17.497{]}νήπιοι, οὐδʼ ἄρʼ ἔμελλον ἀναιμωτί γε νέεσθαι{l]
[l [n}17.498{]}αὖτις ἀπʼ Αὐτομέδοντος. ὃ δʼ εὐξάμενος Διὶ πατρὶ{l]
[l [n}17.499{]}ἀλκῆς καὶ σθένεος πλῆτο φρένας ἀμφὶ μελαίνας·{l]
[l [n}17.500{]}αὐτίκα δʼ Ἀλκιμέδοντα προσηύδα πιστὸν ἑταῖρον·{l]
[q}[l [n}17.501{]}Ἀλκίμεδον μὴ δή μοι ἀπόπροθεν ἰσχέμεν ἵππους,{l]
[l [n}17.502{]}ἀλλὰ μάλʼ ἐμπνείοντε μεταφρένῳ· οὐ γὰρ ἔγωγε{l]
[l [n}17.503{]}Ἕκτορα Πριαμίδην μένεος σχήσεσθαι ὀΐω,{l]
[l [n}17.504{]}πρίν γʼ ἐπʼ Ἀχιλλῆος καλλίτριχε βήμεναι ἵππω{l]
[l [n}17.505{]}νῶϊ κατακτείναντα, φοβῆσαί τε στίχας ἀνδρῶν{l]
[l [n}17.506{]}Ἀργείων, ἤ κʼ αὐτὸς ἐνὶ πρώτοισιν ἁλοίη.{l]{q]{para]
[para}[l [n}17.507{]}ὣς εἰπὼν Αἴαντε καλέσσατο καὶ Μενέλαον·{l]
[q}[l [n}17.508{]}Αἴαντʼ Ἀργείων ἡγήτορε καὶ Μενέλαε{l]
[l [n}17.509{]}ἤτοι μὲν τὸν νεκρὸν ἐπιτράπεθʼ οἵ περ ἄριστοι{l]
[l [n}17.510{]}ἀμφʼ αὐτῷ βεβάμεν καὶ ἀμύνεσθαι στίχας ἀνδρῶν,{l]
[l [n}17.511{]}νῶϊν δὲ ζωοῖσιν ἀμύνετε νηλεὲς ἦμαρ·{l]
[l [n}17.512{]}τῇδε γὰρ ἔβρισαν πόλεμον κάτα δακρυόεντα{l]
[l [n}17.513{]}Ἕκτωρ Αἰνείας θʼ, οἳ Τρώων εἰσὶν ἄριστοι.{l]
[l [n}17.514{]}ἀλλʼ ἤτοι μὲν ταῦτα θεῶν ἐν γούνασι κεῖται·{l]
[l [n}17.515{]}ἥσω γὰρ καὶ ἐγώ, τὰ δέ κεν Διὶ πάντα μελήσει.{l]{q]{para]
[para}[l [n}17.516{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος,{l]
[l [n}17.517{]}καὶ βάλεν Ἀρήτοιο κατʼ ἀσπίδα πάντοσʼ ἐΐσην·{l]
[l [n}17.518{]}ἣ δʼ οὐκ ἔγχος ἔρυτο, διὰ πρὸ δὲ εἴσατο χαλκός,{l]
[l [n}17.519{]}νειαίρῃ δʼ ἐν γαστρὶ διὰ ζωστῆρος ἔλασσεν.{l]
[l [n}17.520{]}ὡς δʼ ὅτʼ ἂν ὀξὺν ἔχων πέλεκυν αἰζήϊος ἀνὴρ{l]
[l [n}17.521{]}κόψας ἐξόπιθεν κεράων βοὸς ἀγραύλοιο{l]
[l [n}17.522{]}ἶνα τάμῃ διὰ πᾶσαν, ὃ δὲ προθορὼν ἐρίπῃσιν,{l]
[l [n}17.523{]}ὣς ἄρʼ ὅ γε προθορὼν πέσεν ὕπτιος· ἐν δέ οἱ ἔγχος{l]
[l [n}17.524{]}νηδυίοισι μάλʼ ὀξὺ κραδαινόμενον λύε γυῖα.{l]
[l [n}17.525{]}Ἕκτωρ δʼ Αὐτομέδοντος ἀκόντισε δουρὶ φαεινῷ·{l]
[l [n}17.526{]}ἀλλʼ ὃ μὲν ἄντα ἰδὼν ἠλεύατο χάλκεον ἔγχος·{l]
[l [n}17.527{]}πρόσσω γὰρ κατέκυψε, τὸ δʼ ἐξόπιθεν δόρυ μακρὸν{l]
[l [n}17.528{]}οὔδει ἐνισκίμφθη, ἐπὶ δʼ οὐρίαχος πελεμίχθη{l]
[l [n}17.529{]}ἔγχεος· ἔνθα δʼ ἔπειτʼ ἀφίει μένος ὄβριμος Ἄρης.{l]
[l [n}17.530{]}καί νύ κε δὴ ξιφέεσσʼ αὐτοσχεδὸν ὁρμηθήτην{l]
[l [n}17.531{]}εἰ μή σφωʼ Αἴαντε διέκριναν μεμαῶτε,{l]
[l [n}17.532{]}οἵ ῥʼ ἦλθον καθʼ ὅμιλον ἑταίρου κικλήσκοντος·{l]
[l [n}17.533{]}τοὺς ὑποταρβήσαντες ἐχώρησαν πάλιν αὖτις{l]
[l [n}17.534{]}Ἕκτωρ Αἰνείας τʼ ἠδὲ Χρομίος θεοειδής,{l]
[l [n}17.535{]}Ἄρητον δὲ κατʼ αὖθι λίπον δεδαϊγμένον ἦτορ{l]
[l [n}17.536{]}κείμενον· Αὐτομέδων δὲ θοῷ ἀτάλαντος Ἄρηϊ{l]
[l [n}17.537{]}τεύχεά τʼ ἐξενάριξε καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}17.538{]}ἦ δὴ μὰν ὀλίγον γε Μενοιτιάδαο θανόντος{l]
[l [n}17.539{]}κῆρ ἄχεος μεθέηκα χερείονά περ καταπέφνων.{l]{q]{para]
[para}[l [n}17.540{]}ὣς εἰπὼν ἐς δίφρον ἑλὼν ἔναρα βροτόεντα{l]
[l [n}17.541{]}θῆκʼ, ἂν δʼ αὐτὸς ἔβαινε πόδας καὶ χεῖρας ὕπερθεν{l]
[l [n}17.542{]}αἱματόεις ὥς τίς τε λέων κατὰ ταῦρον ἐδηδώς.{l]{para]
[para}[l [n}17.543{]}ἂψ δʼ ἐπὶ Πατρόκλῳ τέτατο κρατερὴ ὑσμίνη{l]
[l [n}17.544{]}ἀργαλέη πολύδακρυς, ἔγειρε δὲ νεῖκος Ἀθήνη{l]
[l [n}17.545{]}οὐρανόθεν καταβᾶσα· προῆκε γὰρ εὐρύοπα Ζεὺς{l]
[l [n}17.546{]}ὀρνύμεναι Δαναούς· δὴ γὰρ νόος ἐτράπετʼ αὐτοῦ.{l]
[l [n}17.547{]}ἠΰτε πορφυρέην ἶριν θνητοῖσι τανύσσῃ{l]
[l [n}17.548{]}Ζεὺς ἐξ οὐρανόθεν τέρας ἔμμεναι ἢ πολέμοιο{l]
[l [n}17.549{]}ἢ καὶ χειμῶνος δυσθαλπέος, ὅς ῥά τε ἔργων{l]
[l [n}17.550{]}ἀνθρώπους ἀνέπαυσεν ἐπὶ χθονί, μῆλα δὲ κήδει,{l]
[l [n}17.551{]}ὣς ἣ πορφυρέῃ νεφέλῃ πυκάσασα ἓ αὐτὴν{l]
[l [n}17.552{]}δύσετʼ Ἀχαιῶν ἔθνος, ἔγειρε δὲ φῶτα ἕκαστον.{l]
[l [n}17.553{]}πρῶτον δʼ Ἀτρέος υἱὸν ἐποτρύνουσα προσηύδα{l]
[l [n}17.554{]}ἴφθιμον Μενέλαον· ὃ γάρ ῥά οἱ ἐγγύθεν ἦεν·{l]
[l [n}17.555{]}εἰσαμένη Φοίνικι δέμας καὶ ἀτειρέα φωνήν·{l]
[q}[l [n}17.556{]}σοὶ μὲν δὴ Μενέλαε κατηφείη καὶ ὄνειδος{l]
[l [n}17.557{]}ἔσσεται εἴ κʼ Ἀχιλῆος ἀγαυοῦ πιστὸν ἑταῖρον{l]
[l [n}17.558{]}τείχει ὕπο Τρώων ταχέες κύνες ἑλκήσουσιν.{l]
[l [n}17.559{]}ἀλλʼ ἔχεο κρατερῶς, ὄτρυνε δὲ λαὸν ἅπαντα.{l]{q]{para]
[para}[l [n}17.560{]}τὴν δʼ αὖτε προσέειπε βοὴν ἀγαθὸς Μενέλαος·{l]
[q}[l [n}17.561{]}Φοῖνιξ ἄττα γεραιὲ παλαιγενές, εἰ γὰρ Ἀθήνη{l]
[l [n}17.562{]}δοίη κάρτος ἐμοί, βελέων δʼ ἀπερύκοι ἐρωήν·{l]
[l [n}17.563{]}τώ κεν ἔγωγʼ ἐθέλοιμι παρεστάμεναι καὶ ἀμύνειν{l]
[l [n}17.564{]}Πατρόκλῳ· μάλα γάρ με θανὼν ἐσεμάσσατο θυμόν.{l]
[l [n}17.565{]}ἀλλʼ Ἕκτωρ πυρὸς αἰνὸν ἔχει μένος, οὐδʼ ἀπολήγει{l]
[l [n}17.566{]}χαλκῷ δηϊόων· τῷ γὰρ Ζεὺς κῦδος ὀπάζει.{l]{q]{para]
[para}[l [n}17.567{]}ὣς φάτο, γήθησεν δὲ θεὰ γλαυκῶπις Ἀθήνη,{l]
[l [n}17.568{]}ὅττί ῥά οἱ πάμπρωτα θεῶν ἠρήσατο πάντων.{l]
[l [n}17.569{]}ἐν δὲ βίην ὤμοισι καὶ ἐν γούνεσσιν ἔθηκε,{l]
[l [n}17.570{]}καί οἱ μυίης θάρσος ἐνὶ στήθεσσιν ἐνῆκεν,{l]
[l [n}17.571{]}ἥ τε καὶ ἐργομένη μάλα περ χροὸς ἀνδρομέοιο{l]
[l [n}17.572{]}ἰσχανάᾳ δακέειν, λαρόν τέ οἱ αἷμʼ ἀνθρώπου·{l]
[l [n}17.573{]}τοίου μιν θάρσευς πλῆσε φρένας ἀμφὶ μελαίνας,{l]
[l [n}17.574{]}βῆ δʼ ἐπὶ Πατρόκλῳ, καὶ ἀκόντισε δουρὶ φαεινῷ.{l]
[l [n}17.575{]}ἔσκε δʼ ἐνὶ Τρώεσσι Ποδῆς υἱὸς Ἠετίωνος{l]
[l [n}17.576{]}ἀφνειός τʼ ἀγαθός τε· μάλιστα δέ μιν τίεν Ἕκτωρ{l]
[l [n}17.577{]}δήμου, ἐπεί οἱ ἑταῖρος ἔην φίλος εἰλαπιναστής·{l]
[l [n}17.578{]}τόν ῥα κατὰ ζωστῆρα βάλε ξανθὸς Μενέλαος{l]
[l [n}17.579{]}ἀΐξαντα φόβον δέ, διὰ πρὸ δὲ χαλκὸν ἔλασσε·{l]
[l [n}17.580{]}δούπησεν δὲ πεσών· ἀτὰρ Ἀτρεΐδης Μενέλαος{l]
[l [n}17.581{]}νεκρὸν ὑπʼ ἐκ Τρώων ἔρυσεν μετὰ ἔθνος ἑταίρων.{l]{para]
[para}[l [n}17.582{]}Ἕκτορα δʼ ἐγγύθεν ἱστάμενος ὄτρυνεν Ἀπόλλων{l]
[l [n}17.583{]}Φαίνοπι Ἀσιάδῃ ἐναλίγκιος, ὅς οἱ ἁπάντων{l]
[l [n}17.584{]}ξείνων φίλτατος ἔσκεν Ἀβυδόθι οἰκία ναίων·{l]
[l [n}17.585{]}τῷ μιν ἐεισάμενος προσέφη ἑκάεργος Ἀπόλλων·{l]
[q}[l [n}17.586{]}Ἕκτορ τίς κέ σʼ ἔτʼ ἄλλος Ἀχαιῶν ταρβήσειεν;{l]
[l [n}17.587{]}οἷον δὴ Μενέλαον ὑπέτρεσας, ὃς τὸ πάρος γε{l]
[l [n}17.588{]}μαλθακὸς αἰχμητής· νῦν δʼ οἴχεται οἶος ἀείρας{l]
[l [n}17.589{]}νεκρὸν ὑπʼ ἐκ Τρώων, σὸν δʼ ἔκτανε πιστὸν ἑταῖρον{l]
[l [n}17.590{]}ἐσθλὸν ἐνὶ προμάχοισι Ποδῆν υἱὸν Ἠετίωνος.{l]{q]{para]
[para}[l [n}17.591{]}ὣς φάτο, τὸν δʼ ἄχεος νεφέλη ἐκάλυψε μέλαινα,{l]
[l [n}17.592{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ.{l]
[l [n}17.593{]}καὶ τότʼ ἄρα Κρονίδης ἕλετʼ αἰγίδα θυσσανόεσσαν{l]
[l [n}17.594{]}μαρμαρέην, Ἴδην δὲ κατὰ νεφέεσσι κάλυψεν,{l]
[l [n}17.595{]}ἀστράψας δὲ μάλα μεγάλʼ ἔκτυπε, τὴν δὲ τίναξε,{l]
[l [n}17.596{]}νίκην δὲ Τρώεσσι δίδου, ἐφόβησε δʼ Ἀχαιούς.{l]{para]
[para}[l [n}17.597{]}πρῶτος Πηνέλεως Βοιώτιος ἦρχε φόβοιο.{l]
[l [n}17.598{]}βλῆτο γὰρ ὦμον δουρὶ πρόσω τετραμμένος αἰεὶ{l]
[l [n}17.599{]}ἄκρον ἐπιλίγδην· γράψεν δέ οἱ ὀστέον ἄχρις{l]
[l [n}17.600{]}αἰχμὴ Πουλυδάμαντος· ὃ γάρ ῥʼ ἔβαλε σχεδὸν ἐλθών.{l]
[l [n}17.601{]}Λήϊτον αὖθʼ Ἕκτωρ σχεδὸν οὔτασε χεῖρʼ ἐπὶ καρπῷ{l]
[l [n}17.602{]}υἱὸν Ἀλεκτρυόνος μεγαθύμου, παῦσε δὲ χάρμης·{l]
[l [n}17.603{]}τρέσσε δὲ παπτήνας, ἐπεὶ οὐκέτι ἔλπετο θυμῷ{l]
[l [n}17.604{]}ἔγχος ἔχων ἐν χειρὶ μαχήσεσθαι Τρώεσσιν.{l]
[l [n}17.605{]}Ἕκτορα δʼ Ἰδομενεὺς μετὰ Λήϊτον ὁρμηθέντα{l]
[l [n}17.606{]}βεβλήκει θώρηκα κατὰ στῆθος παρὰ μαζόν·{l]
[l [n}17.607{]}ἐν καυλῷ δʼ ἐάγη δολιχὸν δόρυ, τοὶ δὲ βόησαν{l]
[l [n}17.608{]}Τρῶες· ὃ δʼ Ἰδομενῆος ἀκόντισε Δευκαλίδαο{l]
[l [n}17.609{]}δίφρῳ ἐφεσταότος· τοῦ μέν ῥʼ ἀπὸ τυτθὸν ἅμαρτεν·{l]
[l [n}17.610{]}αὐτὰρ ὃ Μηριόναο ὀπάονά θʼ ἡνίοχόν τε{l]
[l [n}17.611{]}Κοίρανον, ὅς ῥʼ ἐκ Λύκτου ἐϋκτιμένης ἕπετʼ αὐτῷ·{l]
[l [n}17.612{]}πεζὸς γὰρ τὰ πρῶτα λιπὼν νέας ἀμφιελίσσας{l]
[l [n}17.613{]}ἤλυθε, καί κε Τρωσὶ μέγα κράτος ἐγγυάλιξεν,{l]
[l [n}17.614{]}εἰ μὴ Κοίρανος ὦκα ποδώκεας ἤλασεν ἵππους·{l]
[l [n}17.615{]}καὶ τῷ μὲν φάος ἦλθεν, ἄμυνε δὲ νηλεὲς ἦμαρ,{l]
[l [n}17.616{]}αὐτὸς δʼ ὤλεσε θυμὸν ὑφʼ Ἕκτορος ἀνδροφόνοιο·{l]
[l [n}17.617{]}τὸν βάλʼ ὑπὸ γναθμοῖο καὶ οὔατος, ἐκ δʼ ἄρʼ ὀδόντας{l]
[l [n}17.618{]}ὦσε δόρυ πρυμνόν, διὰ δὲ γλῶσσαν τάμε μέσσην.{l]
[l [n}17.619{]}ἤριπε δʼ ἐξ ὀχέων, κατὰ δʼ ἡνία χεῦεν ἔραζε.{l]
[l [n}17.620{]}καὶ τά γε Μηριόνης ἔλαβεν χείρεσσι φίλῃσι{l]
[l [n}17.621{]}κύψας ἐκ πεδίοιο, καὶ Ἰδομενῆα προσηύδα·{l]
[q}[l [n}17.622{]}μάστιε νῦν εἷός κε θοὰς ἐπὶ νῆας ἵκηαι·{l]
[l [n}17.623{]}γιγνώσκεις δὲ καὶ αὐτὸς ὅ τʼ οὐκέτι κάρτος Ἀχαιῶν.{l]{q]{para]
[para}[l [n}17.624{]}ὣς ἔφατʼ, Ἰδομενεὺς δʼ ἵμασεν καλλίτριχας ἵππους{l]
[l [n}17.625{]}νῆας ἔπι γλαφυράς· δὴ γὰρ δέος ἔμπεσε θυμῷ.{l]{para]
[para}[l [n}17.626{]}οὐδʼ ἔλαθʼ Αἴαντα μεγαλήτορα καὶ Μενέλαον{l]
[l [n}17.627{]}Ζεύς, ὅτε δὴ Τρώεσσι δίδου ἑτεραλκέα νίκην.{l]
[l [n}17.628{]}τοῖσι δὲ μύθων ἦρχε μέγας Τελαμώνιος Αἴας·{l]
[q}[l [n}17.629{]}ὢ πόποι ἤδη μέν κε καὶ ὃς μάλα νήπιός ἐστι{l]
[l [n}17.630{]}γνοίη ὅτι Τρώεσσι πατὴρ Ζεὺς αὐτὸς ἀρήγει.{l]
[l [n}17.631{]}τῶν μὲν γὰρ πάντων βέλεʼ ἅπτεται ὅς τις ἀφήῃ{l]
[l [n}17.632{]}ἢ κακὸς ἢ ἀγαθός· Ζεὺς δʼ ἔμπης πάντʼ ἰθύνει·{l]
[l [n}17.633{]}ἡμῖν δʼ αὔτως πᾶσιν ἐτώσια πίπτει ἔραζε.{l]
[l [n}17.634{]}ἀλλʼ ἄγετʼ αὐτοί περ φραζώμεθα μῆτιν ἀρίστην,{l]
[l [n}17.635{]}ἠμὲν ὅπως τὸν νεκρὸν ἐρύσσομεν, ἠδὲ καὶ αὐτοὶ{l]
[l [n}17.636{]}χάρμα φίλοις ἑτάροισι γενώμεθα νοστήσαντες,{l]
[l [n}17.637{]}οἵ που δεῦρʼ ὁρόωντες ἀκηχέδατʼ, οὐδʼ ἔτι φασὶν{l]
[l [n}17.638{]}Ἕκτορος ἀνδροφόνοιο μένος καὶ χεῖρας ἀάπτους{l]
[l [n}17.639{]}σχήσεσθʼ, ἀλλʼ ἐν νηυσὶ μελαίνῃσιν πεσέεσθαι.{l]
[l [n}17.640{]}εἴη δʼ ὅς τις ἑταῖρος ἀπαγγείλειε τάχιστα{l]
[l [n}17.641{]}Πηλεΐδῃ, ἐπεὶ οὔ μιν ὀΐομαι οὐδὲ πεπύσθαι{l]
[l [n}17.642{]}λυγρῆς ἀγγελίης, ὅτι οἱ φίλος ὤλεθʼ ἑταῖρος.{l]
[l [n}17.643{]}ἀλλʼ οὔ πῃ δύναμαι ἰδέειν τοιοῦτον Ἀχαιῶν·{l]
[l [n}17.644{]}ἠέρι γὰρ κατέχονται ὁμῶς αὐτοί τε καὶ ἵπποι.{l]
[l [n}17.645{]}Ζεῦ πάτερ ἀλλὰ σὺ ῥῦσαι ὑπʼ ἠέρος υἷας Ἀχαιῶν,{l]
[l [n}17.646{]}ποίησον δʼ αἴθρην, δὸς δʼ ὀφθαλμοῖσιν ἰδέσθαι·{l]
[l [n}17.647{]}ἐν δὲ φάει καὶ ὄλεσσον, ἐπεί νύ τοι εὔαδεν οὕτως.{l]{q]{para]
[para}[l [n}17.648{]}ὣς φάτο, τὸν δὲ πατὴρ ὀλοφύρατο δάκρυ χέοντα·{l]
[l [n}17.649{]}αὐτίκα δʼ ἠέρα μὲν σκέδασεν καὶ ἀπῶσεν ὀμίχλην,{l]
[l [n}17.650{]}ἠέλιος δʼ ἐπέλαμψε, μάχη δʼ ἐπὶ πᾶσα φαάνθη·{l]
[l [n}17.651{]}καὶ τότʼ ἄρʼ Αἴας εἶπε βοὴν ἀγαθὸν Μενέλαον·{l]
[q}[l [n}17.652{]}σκέπτεο νῦν Μενέλαε διοτρεφὲς αἴ κεν ἴδηαι{l]
[l [n}17.653{]}ζωὸν ἔτʼ Ἀντίλοχον μεγαθύμου Νέστορος υἱόν,{l]
[l [n}17.654{]}ὄτρυνον δʼ Ἀχιλῆϊ δαΐφρονι θᾶσσον ἰόντα{l]
[l [n}17.655{]}εἰπεῖν ὅττι ῥά οἱ πολὺ φίλτατος ὤλεθʼ ἑταῖρος.{l]{q]{para]
[para}[l [n}17.656{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε βοὴν ἀγαθὸς Μενέλαος,{l]
[l [n}17.657{]}βῆ δʼ ἰέναι ὥς τίς τε λέων ἀπὸ μεσσαύλοιο,{l]
[l [n}17.658{]}ὅς τʼ ἐπεὶ ἄρ κε κάμῃσι κύνας τʼ ἄνδρας τʼ ἐρεθίζων,{l]
[l [n}17.659{]}οἵ τέ μιν οὐκ εἰῶσι βοῶν ἐκ πῖαρ ἑλέσθαι{l]
[l [n}17.660{]}πάννυχοι ἐγρήσσοντες· ὃ δὲ κρειῶν ἐρατίζων{l]
[l [n}17.661{]}ἰθύει, ἀλλʼ οὔ τι πρήσσει· θαμέες γὰρ ἄκοντες{l]
[l [n}17.662{]}ἀντίον ἀΐσσουσι θρασειάων ἀπὸ χειρῶν,{l]
[l [n}17.663{]}καιόμεναί τε δεταί, τάς τε τρεῖ ἐσσύμενός περ·{l]
[l [n}17.664{]}ἠῶθεν δʼ ἀπονόσφιν ἔβη τετιηότι θυμῷ·{l]
[l [n}17.665{]}ὣς ἀπὸ Πατρόκλοιο βοὴν ἀγαθὸς Μενέλαος{l]
[l [n}17.666{]}ἤϊε πόλλʼ ἀέκων· περὶ γὰρ δίε μή μιν Ἀχαιοὶ{l]
[l [n}17.667{]}ἀργαλέου πρὸ φόβοιο ἕλωρ δηΐοισι λίποιεν.{l]
[l [n}17.668{]}πολλὰ δὲ Μηριόνῃ τε καὶ Αἰάντεσσʼ ἐπέτελλεν·{l]
[q}[l [n}17.669{]}Αἴαντʼ Ἀργείων ἡγήτορε Μηριόνη τε{l]
[l [n}17.670{]}νῦν τις ἐνηείης Πατροκλῆος δειλοῖο{l]
[l [n}17.671{]}μνησάσθω· πᾶσιν γὰρ ἐπίστατο μείλιχος εἶναι{l]
[l [n}17.672{]}ζωὸς ἐών· νῦν αὖ θάνατος καὶ μοῖρα κιχάνει.{l]{q]{para]
[para}[l [n}17.673{]}ὣς ἄρα φωνήσας ἀπέβη ξανθὸς Μενέλαος,{l]
[l [n}17.674{]}πάντοσε παπταίνων ὥς τʼ αἰετός, ὅν ῥά τέ φασιν{l]
[l [n}17.675{]}ὀξύτατον δέρκεσθαι ὑπουρανίων πετεηνῶν,{l]
[l [n}17.676{]}ὅν τε καὶ ὑψόθʼ ἐόντα πόδας ταχὺς οὐκ ἔλαθε πτὼξ{l]
[l [n}17.677{]}θάμνῳ ὑπʼ ἀμφικόμῳ κατακείμενος, ἀλλά τʼ ἐπʼ αὐτῷ{l]
[l [n}17.678{]}ἔσσυτο, καί τέ μιν ὦκα λαβὼν ἐξείλετο θυμόν.{l]
[l [n}17.679{]}ὣς τότε σοὶ Μενέλαε διοτρεφὲς ὄσσε φαεινὼ{l]
[l [n}17.680{]}πάντοσε δινείσθην πολέων κατὰ ἔθνος ἑταίρων,{l]
[l [n}17.681{]}εἴ που Νέστορος υἱὸν ἔτι ζώοντα ἴδοιτο.{l]
[l [n}17.682{]}τὸν δὲ μάλʼ αἶψʼ ἐνόησε μάχης ἐπʼ ἀριστερὰ πάσης{l]
[l [n}17.683{]}θαρσύνονθʼ ἑτάρους καὶ ἐποτρύνοντα μάχεσθαι,{l]
[l [n}17.684{]}ἀγχοῦ δʼ ἱστάμενος προσέφη ξανθὸς Μενέλαος·{l]
[q}[l [n}17.685{]}Ἀντίλοχʼ εἰ δʼ ἄγε δεῦρο διοτρεφὲς ὄφρα πύθηαι{l]
[l [n}17.686{]}λυγρῆς ἀγγελίης, ἣ μὴ ὤφελλε γενέσθαι.{l]
[l [n}17.687{]}ἤδη μὲν σὲ καὶ αὐτὸν ὀΐομαι εἰσορόωντα{l]
[l [n}17.688{]}γιγνώσκειν ὅτι πῆμα θεὸς Δαναοῖσι κυλίνδει,{l]
[l [n}17.689{]}νίκη δὲ Τρώων· πέφαται δʼ ὤριστος Ἀχαιῶν{l]
[l [n}17.690{]}Πάτροκλος, μεγάλη δὲ ποθὴ Δαναοῖσι τέτυκται.{l]
[l [n}17.691{]}ἀλλὰ σύ γʼ αἶψʼ Ἀχιλῆϊ θέων ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}17.692{]}εἰπεῖν, αἴ κε τάχιστα νέκυν ἐπὶ νῆα σαώσῃ{l]
[l [n}17.693{]}γυμνόν· ἀτὰρ τά γε τεύχεʼ ἔχει κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}17.694{]}ὣς ἔφατʼ, Ἀντίλοχος δὲ κατέστυγε μῦθον ἀκούσας·{l]
[l [n}17.695{]}δὴν δέ μιν ἀμφασίη ἐπέων λάβε, τὼ δέ οἱ ὄσσε{l]
[l [n}17.696{]}δακρυόφι πλῆσθεν, θαλερὴ δέ οἱ ἔσχετο φωνή.{l]
[l [n}17.697{]}ἀλλʼ οὐδʼ ὧς Μενελάου ἐφημοσύνης ἀμέλησε,{l]
[l [n}17.698{]}βῆ δὲ θέειν, τὰ δὲ τεύχεʼ ἀμύμονι δῶκεν ἑταίρῳ{l]
[l [n}17.699{]}Λαοδόκῳ, ὅς οἱ σχεδὸν ἔστρεφε μώνυχας ἵππους.{l]{para]
[para}[l [n}17.700{]}τὸν μὲν δάκρυ χέοντα πόδες φέρον ἐκ πολέμοιο{l]
[l [n}17.701{]}Πηλεΐδῃ Ἀχιλῆϊ κακὸν ἔπος ἀγγελέοντα.{l]
[l [n}17.702{]}οὐδʼ ἄρα σοὶ Μενέλαε διοτρεφὲς ἤθελε θυμὸς{l]
[l [n}17.703{]}τειρομένοις ἑτάροισιν ἀμυνέμεν, ἔνθεν ἀπῆλθεν{l]
[l [n}17.704{]}Ἀντίλοχος, μεγάλη δὲ ποθὴ Πυλίοισιν ἐτύχθη·{l]
[l [n}17.705{]}ἀλλʼ ὅ γε τοῖσιν μὲν Θρασυμήδεα δῖον ἀνῆκεν,{l]
[l [n}17.706{]}αὐτὸς δʼ αὖτʼ ἐπὶ Πατρόκλῳ ἥρωϊ βεβήκει,{l]
[l [n}17.707{]}στῆ δὲ παρʼ Αἰάντεσσι θέων, εἶθαρ δὲ προσηύδα·{l]
[q}[l [n}17.708{]}κεῖνον μὲν δὴ νηυσὶν ἐπιπροέηκα θοῇσιν{l]
[l [n}17.709{]}ἐλθεῖν εἰς Ἀχιλῆα πόδας ταχύν· οὐδέ μιν οἴω{l]
[l [n}17.710{]}νῦν ἰέναι μάλα περ κεχολωμένον Ἕκτορι δίῳ·{l]
[l [n}17.711{]}οὐ γάρ πως ἂν γυμνὸς ἐὼν Τρώεσσι μάχοιτο.{l]
[l [n}17.712{]}ἡμεῖς δʼ αὐτοί περ φραζώμεθα μῆτιν ἀρίστην,{l]
[l [n}17.713{]}ἠμὲν ὅπως τὸν νεκρὸν ἐρύσσομεν, ἠδὲ καὶ αὐτοὶ{l]
[l [n}17.714{]}Τρώων ἐξ ἐνοπῆς θάνατον καὶ κῆρα φύγωμεν.{l]{q]{para]
[para}[l [n}17.715{]}τὸν δʼ ἠμείβετʼ ἔπειτα μέγας Τελαμώνιος Αἴας·{l]
[q}[l [n}17.716{]}πάντα κατʼ αἶσαν ἔειπες ἀγακλεὲς ὦ Μενέλαε·{l]
[l [n}17.717{]}ἀλλὰ σὺ μὲν καὶ Μηριόνης ὑποδύντε μάλʼ ὦκα{l]
[l [n}17.718{]}νεκρὸν ἀείραντες φέρετʼ ἐκ πόνου· αὐτὰρ ὄπισθε{l]
[l [n}17.719{]}νῶϊ μαχησόμεθα Τρωσίν τε καὶ Ἕκτορι δίῳ{l]
[l [n}17.720{]}ἶσον θυμὸν ἔχοντες ὁμώνυμοι, οἳ τὸ πάρος περ{l]
[l [n}17.721{]}μίμνομεν ὀξὺν Ἄρηα παρʼ ἀλλήλοισι μένοντες.{l]{q]{para]
[para}[l [n}17.722{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα νεκρὸν ἀπὸ χθονὸς ἀγκάζοντο{l]
[l [n}17.723{]}ὕψι μάλα μεγάλως· ἐπὶ δʼ ἴαχε λαὸς ὄπισθε{l]
[l [n}17.724{]}Τρωϊκός, ὡς εἴδοντο νέκυν αἴροντας Ἀχαιούς.{l]
[l [n}17.725{]}ἴθυσαν δὲ κύνεσσιν ἐοικότες, οἵ τʼ ἐπὶ κάπρῳ{l]
[l [n}17.726{]}βλημένῳ ἀΐξωσι πρὸ κούρων θηρητήρων·{l]
[l [n}17.727{]}ἕως μὲν γάρ τε θέουσι διαρραῖσαι μεμαῶτες,{l]
[l [n}17.728{]}ἀλλʼ ὅτε δή ῥʼ ἐν τοῖσιν ἑλίξεται ἀλκὶ πεποιθώς,{l]
[l [n}17.729{]}ἄψ τʼ ἀνεχώρησαν διά τʼ ἔτρεσαν ἄλλυδις ἄλλος.{l]
[l [n}17.730{]}ὣς Τρῶες εἷος μὲν ὁμιλαδὸν αἰὲν ἕποντο{l]
[l [n}17.731{]}νύσσοντες ξίφεσίν τε καὶ ἔγχεσιν ἀμφιγύοισιν·{l]
[l [n}17.732{]}ἀλλʼ ὅτε δή ῥʼ Αἴαντε μεταστρεφθέντε κατʼ αὐτοὺς{l]
[l [n}17.733{]}σταίησαν, τῶν δὲ τράπετο χρώς, οὐδέ τις ἔτλη{l]
[l [n}17.734{]}πρόσσω ἀΐξας περὶ νεκροῦ δηριάασθαι.{l]{para]
[para}[l [n}17.735{]}ὣς οἵ γʼ ἐμμεμαῶτε νέκυν φέρον ἐκ πολέμοιο{l]
[l [n}17.736{]}νῆας ἔπι γλαφυράς· ἐπὶ δὲ πτόλεμος τέτατό σφιν{l]
[l [n}17.737{]}ἄγριος ἠΰτε πῦρ, τό τʼ ἐπεσσύμενον πόλιν ἀνδρῶν{l]
[l [n}17.738{]}ὄρμενον ἐξαίφνης φλεγέθει, μινύθουσι δὲ οἶκοι{l]
[l [n}17.739{]}ἐν σέλαϊ μεγάλῳ· τὸ δʼ ἐπιβρέμει ἲς ἀνέμοιο.{l]
[l [n}17.740{]}ὣς μὲν τοῖς ἵππων τε καὶ ἀνδρῶν αἰχμητάων{l]
[l [n}17.741{]}ἀζηχὴς ὀρυμαγδὸς ἐπήϊεν ἐρχομένοισιν·{l]
[l [n}17.742{]}οἳ δʼ ὥς θʼ ἡμίονοι κρατερὸν μένος ἀμφιβαλόντες{l]
[l [n}17.743{]}ἕλκωσʼ ἐξ ὄρεος κατὰ παιπαλόεσσαν ἀταρπὸν{l]
[l [n}17.744{]}ἢ δοκὸν ἠὲ δόρυ μέγα νήϊον· ἐν δέ τε θυμὸς{l]
[l [n}17.745{]}τείρεθʼ ὁμοῦ καμάτῳ τε καὶ ἱδρῷ σπευδόντεσσιν·{l]
[l [n}17.746{]}ὣς οἵ γʼ ἐμμεμαῶτε νέκυν φέρον. αὐτὰρ ὄπισθεν{l]
[l [n}17.747{]}Αἴαντʼ ἰσχανέτην, ὥς τε πρὼν ἰσχάνει ὕδωρ{l]
[l [n}17.748{]}ὑλήεις πεδίοιο διαπρύσιον τετυχηκώς,{l]
[l [n}17.749{]}ὅς τε καὶ ἰφθίμων ποταμῶν ἀλεγεινὰ ῥέεθρα{l]
[l [n}17.750{]}ἴσχει, ἄφαρ δέ τε πᾶσι ῥόον πεδίον δὲ τίθησι{l]
[l [n}17.751{]}πλάζων· οὐδέ τί μιν σθένεϊ ῥηγνῦσι ῥέοντες·{l]
[l [n}17.752{]}ὣς αἰεὶ Αἴαντε μάχην ἀνέεργον ὀπίσσω{l]
[l [n}17.753{]}Τρώων· οἳ δʼ ἅμʼ ἕποντο, δύω δʼ ἐν τοῖσι μάλιστα{l]
[l [n}17.754{]}Αἰνείας τʼ Ἀγχισιάδης καὶ φαίδιμος Ἕκτωρ.{l]
[l [n}17.755{]}τῶν δʼ ὥς τε ψαρῶν νέφος ἔρχεται ἠὲ κολοιῶν{l]
[l [n}17.756{]}οὖλον κεκλήγοντες, ὅτε προΐδωσιν ἰόντα{l]
[l [n}17.757{]}κίρκον, ὅ τε σμικρῇσι φόνον φέρει ὀρνίθεσσιν,{l]
[l [n}17.758{]}ὣς ἄρʼ ὑπʼ Αἰνείᾳ τε καὶ Ἕκτορι κοῦροι Ἀχαιῶν{l]
[l [n}17.759{]}οὖλον κεκλήγοντες ἴσαν, λήθοντο δὲ χάρμης.{l]
[l [n}17.760{]}πολλὰ δὲ τεύχεα καλὰ πέσον περί τʼ ἀμφί τε τάφρον{l]
[l [n}17.761{]}φευγόντων Δαναῶν· πολέμου δʼ οὐ γίγνετʼ ἐρωή.{l]{para]
{book]
[book [n}18{]}[l [n}18.1{]}ὣς οἳ μὲν μάρναντο δέμας πυρὸς αἰθομένοιο,{l]
[l [n}18.2{]}Ἀντίλοχος δʼ Ἀχιλῆϊ πόδας ταχὺς ἄγγελος ἦλθε.{l]
[l [n}18.3{]}τὸν δʼ εὗρε προπάροιθε νεῶν ὀρθοκραιράων{l]
[l [n}18.4{]}τὰ φρονέοντʼ ἀνὰ θυμὸν ἃ δὴ τετελεσμένα ἦεν·{l]
[l [n}18.5{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}18.6{]}ὤ μοι ἐγώ, τί τʼ ἄρʼ αὖτε κάρη κομόωντες Ἀχαιοὶ{l]
[l [n}18.7{]}νηυσὶν ἔπι κλονέονται ἀτυζόμενοι πεδίοιο;{l]
[l [n}18.8{]}μὴ δή μοι τελέσωσι θεοὶ κακὰ κήδεα θυμῷ,{l]
[l [n}18.9{]}ὥς ποτέ μοι μήτηρ διεπέφραδε καί μοι ἔειπε{l]
[l [n}18.10{]}Μυρμιδόνων τὸν ἄριστον ἔτι ζώοντος ἐμεῖο{l]
[l [n}18.11{]}χερσὶν ὕπο Τρώων λείψειν φάος ἠελίοιο.{l]
[l [n}18.12{]}ἦ μάλα δὴ τέθνηκε Μενοιτίου ἄλκιμος υἱὸς{l]
[l [n}18.13{]}σχέτλιος· ἦ τʼ ἐκέλευον ἀπωσάμενον δήϊον πῦρ{l]
[l [n}18.14{]}ἂψ ἐπὶ νῆας ἴμεν, μηδʼ Ἕκτορι ἶφι μάχεσθαι.{l]{q]
[para}[l [n}18.15{]}εἷος ὃ ταῦθʼ ὥρμαινε κατὰ φρένα καὶ κατὰ θυμόν,{l]
[l [n}18.16{]}τόφρά οἱ ἐγγύθεν ἦλθεν ἀγαυοῦ Νέστορος υἱὸς{l]
[l [n}18.17{]}δάκρυα θερμὰ χέων, φάτο δʼ ἀγγελίην ἀλεγεινήν·{l]
[q}[l [n}18.18{]}ὤ μοι Πηλέος υἱὲ δαΐφρονος ἦ μάλα λυγρῆς{l]
[l [n}18.19{]}πεύσεαι ἀγγελίης, ἣ μὴ ὤφελλε γενέσθαι.{l]
[l [n}18.20{]}κεῖται Πάτροκλος, νέκυος δὲ δὴ ἀμφιμάχονται{l]
[l [n}18.21{]}γυμνοῦ· ἀτὰρ τά γε τεύχεʼ ἔχει κορυθαίολος Ἕκτωρ.{l]{q]{para]
[para}[l [n}18.22{]}ὣς φάτο, τὸν δʼ ἄχεος νεφέλη ἐκάλυψε μέλαινα·{l]
[l [n}18.23{]}ἀμφοτέρῃσι δὲ χερσὶν ἑλὼν κόνιν αἰθαλόεσσαν{l]
[l [n}18.24{]}χεύατο κὰκ κεφαλῆς, χαρίεν δʼ ᾔσχυνε πρόσωπον·{l]
[l [n}18.25{]}νεκταρέῳ δὲ χιτῶνι μέλαινʼ ἀμφίζανε τέφρη.{l]
[l [n}18.26{]}αὐτὸς δʼ ἐν κονίῃσι μέγας μεγαλωστὶ τανυσθεὶς{l]
[l [n}18.27{]}κεῖτο, φίλῃσι δὲ χερσὶ κόμην ᾔσχυνε δαΐζων.{l]
[l [n}18.28{]}δμῳαὶ δʼ ἃς Ἀχιλεὺς ληΐσσατο Πάτροκλός τε{l]
[l [n}18.29{]}θυμὸν ἀκηχέμεναι μεγάλʼ ἴαχον, ἐκ δὲ θύραζε{l]
[l [n}18.30{]}ἔδραμον ἀμφʼ Ἀχιλῆα δαΐφρονα, χερσὶ δὲ πᾶσαι{l]
[l [n}18.31{]}στήθεα πεπλήγοντο, λύθεν δʼ ὑπὸ γυῖα ἑκάστης.{l]
[l [n}18.32{]}Ἀντίλοχος δʼ ἑτέρωθεν ὀδύρετο δάκρυα λείβων{l]
[l [n}18.33{]}χεῖρας ἔχων Ἀχιλῆος· ὃ δʼ ἔστενε κυδάλιμον κῆρ·{l]
[l [n}18.34{]}δείδιε γὰρ μὴ λαιμὸν ἀπαμήσειε σιδήρῳ.{l]
[l [n}18.35{]}σμερδαλέον δʼ ᾤμωξεν· ἄκουσε δὲ πότνια μήτηρ{l]
[l [n}18.36{]}ἡμένη ἐν βένθεσσιν ἁλὸς παρὰ πατρὶ γέροντι,{l]
[l [n}18.37{]}κώκυσέν τʼ ἄρʼ ἔπειτα· θεαὶ δέ μιν ἀμφαγέροντο{l]
[l [n}18.38{]}πᾶσαι ὅσαι κατὰ βένθος ἁλὸς Νηρηΐδες ἦσαν.{l]
[l [n}18.39{]}ἔνθʼ ἄρʼ ἔην Γλαύκη τε Θάλειά τε Κυμοδόκη τε{l]
[l [n}18.40{]}Νησαίη Σπειώ τε Θόη θʼ Ἁλίη τε βοῶπις{l]
[l [n}18.41{]}Κυμοθόη τε καὶ Ἀκταίη καὶ Λιμνώρεια{l]
[l [n}18.42{]}καὶ Μελίτη καὶ Ἴαιρα καὶ Ἀμφιθόη καὶ Ἀγαυὴ{l]
[l [n}18.43{]}Δωτώ τε Πρωτώ τε Φέρουσά τε Δυναμένη τε{l]
[l [n}18.44{]}Δεξαμένη τε καὶ Ἀμφινόμη καὶ Καλλιάνειρα{l]
[l [n}18.45{]}Δωρὶς καὶ Πανόπη καὶ ἀγακλειτὴ Γαλάτεια{l]
[l [n}18.46{]}Νημερτής τε καὶ Ἀψευδὴς καὶ Καλλιάνασσα·{l]
[l [n}18.47{]}ἔνθα δʼ ἔην Κλυμένη Ἰάνειρά τε καὶ Ἰάνασσα{l]
[l [n}18.48{]}Μαῖρα καὶ Ὠρείθυια ἐϋπλόκαμός τʼ Ἀμάθεια{l]
[l [n}18.49{]}ἄλλαι θʼ αἳ κατὰ βένθος ἁλὸς Νηρηΐδες ἦσαν.{l]
[l [n}18.50{]}τῶν δὲ καὶ ἀργύφεον πλῆτο σπέος· αἳ δʼ ἅμα πᾶσαι{l]
[l [n}18.51{]}στήθεα πεπλήγοντο, Θέτις δʼ ἐξῆρχε γόοιο·{l]
[q}[l [n}18.52{]}κλῦτε κασίγνηται Νηρηΐδες, ὄφρʼ ἐῢ πᾶσαι{l]
[l [n}18.53{]}εἴδετʼ ἀκούουσαι ὅσʼ ἐμῷ ἔνι κήδεα θυμῷ.{l]
[l [n}18.54{]}ὤ μοι ἐγὼ δειλή, ὤ μοι δυσαριστοτόκεια,{l]
[l [n}18.55{]}ἥ τʼ ἐπεὶ ἂρ τέκον υἱὸν ἀμύμονά τε κρατερόν τε{l]
[l [n}18.56{]}ἔξοχον ἡρώων· ὃ δʼ ἀνέδραμεν ἔρνεϊ ἶσος·{l]
[l [n}18.57{]}τὸν μὲν ἐγὼ θρέψασα φυτὸν ὣς γουνῷ ἀλωῆς{l]
[l [n}18.58{]}νηυσὶν ἐπιπροέηκα κορωνίσιν Ἴλιον εἴσω{l]
[l [n}18.59{]}Τρωσὶ μαχησόμενον· τὸν δʼ οὐχ ὑποδέξομαι αὖτις{l]
[l [n}18.60{]}οἴκαδε νοστήσαντα δόμον Πηλήϊον εἴσω.{l]
[l [n}18.61{]}ὄφρα δέ μοι ζώει καὶ ὁρᾷ φάος ἠελίοιο{l]
[l [n}18.62{]}ἄχνυται, οὐδέ τί οἱ δύναμαι χραισμῆσαι ἰοῦσα.{l]
[l [n}18.63{]}ἀλλʼ εἶμʼ, ὄφρα ἴδωμι φίλον τέκος, ἠδʼ ἐπακούσω{l]
[l [n}18.64{]}ὅττί μιν ἵκετο πένθος ἀπὸ πτολέμοιο μένοντα.{l]{q]{para]
[para}[l [n}18.65{]}ὣς ἄρα φωνήσασα λίπε σπέος· αἳ δὲ σὺν αὐτῇ{l]
[l [n}18.66{]}δακρυόεσσαι ἴσαν, περὶ δέ σφισι κῦμα θαλάσσης{l]
[l [n}18.67{]}ῥήγνυτο· ταὶ δʼ ὅτε δὴ Τροίην ἐρίβωλον ἵκοντο{l]
[l [n}18.68{]}ἀκτὴν εἰσανέβαινον ἐπισχερώ, ἔνθα θαμειαὶ{l]
[l [n}18.69{]}Μυρμιδόνων εἴρυντο νέες ταχὺν ἀμφʼ Ἀχιλῆα.{l]
[l [n}18.70{]}τῷ δὲ βαρὺ στενάχοντι παρίστατο πότνια μήτηρ,{l]
[l [n}18.71{]}ὀξὺ δὲ κωκύσασα κάρη λάβε παιδὸς ἑοῖο,{l]
[l [n}18.72{]}καί ῥʼ ὀλοφυρομένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}18.73{]}τέκνον τί κλαίεις; τί δέ σε φρένας ἵκετο πένθος;{l]
[l [n}18.74{]}ἐξαύδα, μὴ κεῦθε· τὰ μὲν δή τοι τετέλεσται{l]
[l [n}18.75{]}ἐκ Διός, ὡς ἄρα δὴ πρίν γʼ εὔχεο χεῖρας ἀνασχὼν{l]
[l [n}18.76{]}πάντας ἐπὶ πρύμνῃσιν ἀλήμεναι υἷας Ἀχαιῶν{l]
[l [n}18.77{]}σεῦ ἐπιδευομένους, παθέειν τʼ ἀεκήλια ἔργα.{l]{q]{para]
[para}[l [n}18.78{]}τὴν δὲ βαρὺ στενάχων προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}18.79{]}μῆτερ ἐμή, τὰ μὲν ἄρ μοι Ὀλύμπιος ἐξετέλεσσεν·{l]
[l [n}18.80{]}ἀλλὰ τί μοι τῶν ἦδος ἐπεὶ φίλος ὤλεθʼ ἑταῖρος{l]
[l [n}18.81{]}Πάτροκλος, τὸν ἐγὼ περὶ πάντων τῖον ἑταίρων{l]
[l [n}18.82{]}ἶσον ἐμῇ κεφαλῇ; τὸν ἀπώλεσα, τεύχεα δʼ Ἕκτωρ{l]
[l [n}18.83{]}δῃώσας ἀπέδυσε πελώρια θαῦμα ἰδέσθαι{l]
[l [n}18.84{]}καλά· τὰ μὲν Πηλῆϊ θεοὶ δόσαν ἀγλαὰ δῶρα{l]
[l [n}18.85{]}ἤματι τῷ ὅτε σε βροτοῦ ἀνέρος ἔμβαλον εὐνῇ.{l]
[l [n}18.86{]}αἴθʼ ὄφελες σὺ μὲν αὖθι μετʼ ἀθανάτῃς ἁλίῃσι{l]
[l [n}18.87{]}ναίειν, Πηλεὺς δὲ θνητὴν ἀγαγέσθαι ἄκοιτιν.{l]
[l [n}18.88{]}νῦν δʼ ἵνα καὶ σοὶ πένθος ἐνὶ φρεσὶ μυρίον εἴη{l]
[l [n}18.89{]}παιδὸς ἀποφθιμένοιο, τὸν οὐχ ὑποδέξεαι αὖτις{l]
[l [n}18.90{]}οἴκαδε νοστήσαντʼ, ἐπεὶ οὐδʼ ἐμὲ θυμὸς ἄνωγε{l]
[l [n}18.91{]}ζώειν οὐδʼ ἄνδρεσσι μετέμμεναι, αἴ κε μὴ Ἕκτωρ{l]
[l [n}18.92{]}πρῶτος ἐμῷ ὑπὸ δουρὶ τυπεὶς ἀπὸ θυμὸν ὀλέσσῃ,{l]
[l [n}18.93{]}Πατρόκλοιο δʼ ἕλωρα Μενοιτιάδεω ἀποτίσῃ.{l]{q]{para]
[para}[l [n}18.94{]}τὸν δʼ αὖτε προσέειπε Θέτις κατὰ δάκρυ χέουσα·{l]
[q}[l [n}18.95{]}ὠκύμορος δή μοι τέκος ἔσσεαι, οἷʼ ἀγορεύεις·{l]
[l [n}18.96{]}αὐτίκα γάρ τοι ἔπειτα μεθʼ Ἕκτορα πότμος ἑτοῖμος.{l]{q]{para]
[para}[l [n}18.97{]}τὴν δὲ μέγʼ ὀχθήσας προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}18.98{]}αὐτίκα τεθναίην, ἐπεὶ οὐκ ἄρʼ ἔμελλον ἑταίρῳ{l]
[l [n}18.99{]}κτεινομένῳ ἐπαμῦναι· ὃ μὲν μάλα τηλόθι πάτρης{l]
[l [n}18.100{]}ἔφθιτʼ, ἐμεῖο δὲ δῆσεν ἀρῆς ἀλκτῆρα γενέσθαι.{l]
[l [n}18.101{]}νῦν δʼ ἐπεὶ οὐ νέομαί γε φίλην ἐς πατρίδα γαῖαν,{l]
[l [n}18.102{]}οὐδέ τι Πατρόκλῳ γενόμην φάος οὐδʼ ἑτάροισι{l]
[l [n}18.103{]}τοῖς ἄλλοις, οἳ δὴ πολέες δάμεν Ἕκτορι δίῳ,{l]
[l [n}18.104{]}ἀλλʼ ἧμαι παρὰ νηυσὶν ἐτώσιον ἄχθος ἀρούρης,{l]
[l [n}18.105{]}τοῖος ἐὼν οἷος οὔ τις Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}18.106{]}ἐν πολέμῳ· ἀγορῇ δέ τʼ ἀμείνονές εἰσι καὶ ἄλλοι.{l]
[l [n}18.107{]}ὡς ἔρις ἔκ τε θεῶν ἔκ τʼ ἀνθρώπων ἀπόλοιτο{l]
[l [n}18.108{]}καὶ χόλος, ὅς τʼ ἐφέηκε πολύφρονά περ χαλεπῆναι,{l]
[l [n}18.109{]}ὅς τε πολὺ γλυκίων μέλιτος καταλειβομένοιο{l]
[l [n}18.110{]}ἀνδρῶν ἐν στήθεσσιν ἀέξεται ἠΰτε καπνός·{l]
[l [n}18.111{]}ὡς ἐμὲ νῦν ἐχόλωσεν ἄναξ ἀνδρῶν Ἀγαμέμνων.{l]
[l [n}18.112{]}ἀλλὰ τὰ μὲν προτετύχθαι ἐάσομεν ἀχνύμενοί περ,{l]
[l [n}18.113{]}θυμὸν ἐνὶ στήθεσσι φίλον δαμάσαντες ἀνάγκῃ·{l]
[l [n}18.114{]}νῦν δʼ εἶμʼ ὄφρα φίλης κεφαλῆς ὀλετῆρα κιχείω{l]
[l [n}18.115{]}Ἕκτορα· κῆρα δʼ ἐγὼ τότε δέξομαι ὁππότε κεν δὴ{l]
[l [n}18.116{]}Ζεὺς ἐθέλῃ τελέσαι ἠδʼ ἀθάνατοι θεοὶ ἄλλοι.{l]
[l [n}18.117{]}οὐδὲ γὰρ οὐδὲ βίη Ἡρακλῆος φύγε κῆρα,{l]
[l [n}18.118{]}ὅς περ φίλτατος ἔσκε Διὶ Κρονίωνι ἄνακτι·{l]
[l [n}18.119{]}ἀλλά ἑ μοῖρα δάμασσε καὶ ἀργαλέος χόλος Ἥρης.{l]
[l [n}18.120{]}ὣς καὶ ἐγών, εἰ δή μοι ὁμοίη μοῖρα τέτυκται,{l]
[l [n}18.121{]}κείσομʼ ἐπεί κε θάνω· νῦν δὲ κλέος ἐσθλὸν ἀροίμην,{l]
[l [n}18.122{]}καί τινα Τρωϊάδων καὶ Δαρδανίδων βαθυκόλπων{l]
[l [n}18.123{]}ἀμφοτέρῃσιν χερσὶ παρειάων ἁπαλάων{l]
[l [n}18.124{]}δάκρυʼ ὀμορξαμένην ἁδινὸν στοναχῆσαι ἐφείην,{l]
[l [n}18.125{]}γνοῖεν δʼ ὡς δὴ δηρὸν ἐγὼ πολέμοιο πέπαυμαι·{l]
[l [n}18.126{]}μὴ δέ μʼ ἔρυκε μάχης φιλέουσά περ· οὐδέ με πείσεις.{l]{q]{para]
[para}[l [n}18.127{]}τὸν δʼ ἠμείβετʼ ἔπειτα θεὰ Θέτις ἀργυρόπεζα·{l]
[q}[l [n}18.128{]}ναὶ δὴ ταῦτά γε τέκνον ἐτήτυμον οὐ κακόν ἐστι{l]
[l [n}18.129{]}τειρομένοις ἑτάροισιν ἀμυνέμεν αἰπὺν ὄλεθρον.{l]
[l [n}18.130{]}ἀλλά τοι ἔντεα καλὰ μετὰ Τρώεσσιν ἔχονται{l]
[l [n}18.131{]}χάλκεα μαρμαίροντα· τὰ μὲν κορυθαίολος Ἕκτωρ{l]
[l [n}18.132{]}αὐτὸς ἔχων ὤμοισιν ἀγάλλεται· οὐδέ ἕ φημι{l]
[l [n}18.133{]}δηρὸν ἐπαγλαϊεῖσθαι, ἐπεὶ φόνος ἐγγύθεν αὐτῷ.{l]
[l [n}18.134{]}ἀλλὰ σὺ μὲν μή πω καταδύσεο μῶλον Ἄρηος{l]
[l [n}18.135{]}πρίν γʼ ἐμὲ δεῦρʼ ἐλθοῦσαν ἐν ὀφθαλμοῖσιν ἴδηαι·{l]
[l [n}18.136{]}ἠῶθεν γὰρ νεῦμαι ἅμʼ ἠελίῳ ἀνιόντι{l]
[l [n}18.137{]}τεύχεα καλὰ φέρουσα παρʼ Ἡφαίστοιο ἄνακτος.{l]{q]{para]
[para}[l [n}18.138{]}ὣς ἄρα φωνήσασα πάλιν τράπεθʼ υἷος ἑοῖο,{l]
[l [n}18.139{]}καὶ στρεφθεῖσʼ ἁλίῃσι κασιγνήτῃσι μετηύδα·{l]
[q}[l [n}18.140{]}ὑμεῖς μὲν νῦν δῦτε θαλάσσης εὐρέα κόλπον{l]
[l [n}18.141{]}ὀψόμεναί τε γέρονθʼ ἅλιον καὶ δώματα πατρός,{l]
[l [n}18.142{]}καί οἱ πάντʼ ἀγορεύσατʼ· ἐγὼ δʼ ἐς μακρὸν Ὄλυμπον{l]
[l [n}18.143{]}εἶμι παρʼ Ἥφαιστον κλυτοτέχνην, αἴ κʼ ἐθέλῃσιν{l]
[l [n}18.144{]}υἱεῖ ἐμῷ δόμεναι κλυτὰ τεύχεα παμφανόωντα.{l]{q]{para]
[para}[l [n}18.145{]}ὣς ἔφαθʼ, αἳ δʼ ὑπὸ κῦμα θαλάσσης αὐτίκʼ ἔδυσαν·{l]
[l [n}18.146{]}ἣ δʼ αὖτʼ Οὔλυμπον δὲ θεὰ Θέτις ἀργυρόπεζα{l]
[l [n}18.147{]}ἤϊεν ὄφρα φίλῳ παιδὶ κλυτὰ τεύχεʼ ἐνείκαι.{l]{para]
[para}[l [n}18.148{]}τὴν μὲν ἄρʼ Οὔλυμπον δὲ πόδες φέρον· αὐτὰρ Ἀχαιοὶ{l]
[l [n}18.149{]}θεσπεσίῳ ἀλαλητῷ ὑφʼ Ἕκτορος ἀνδροφόνοιο{l]
[l [n}18.150{]}φεύγοντες νῆάς τε καὶ Ἑλλήσποντον ἵκοντο.{l]
[l [n}18.151{]}οὐδέ κε Πάτροκλόν περ ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}18.152{]}ἐκ βελέων ἐρύσαντο νέκυν θεράποντʼ Ἀχιλῆος·{l]
[l [n}18.153{]}αὖτις γὰρ δὴ τόν γε κίχον λαός τε καὶ ἵπποι{l]
[l [n}18.154{]}Ἕκτωρ τε Πριάμοιο πάϊς φλογὶ εἴκελος ἀλκήν.{l]
[l [n}18.155{]}τρὶς μέν μιν μετόπισθε ποδῶν λάβε φαίδιμος Ἕκτωρ{l]
[l [n}18.156{]}ἑλκέμεναι μεμαώς, μέγα δὲ Τρώεσσιν ὁμόκλα·{l]
[l [n}18.157{]}τρὶς δὲ δύʼ Αἴαντες θοῦριν ἐπιειμένοι ἀλκὴν{l]
[l [n}18.158{]}νεκροῦ ἀπεστυφέλιξαν· ὃ δʼ ἔμπεδον ἀλκὶ πεποιθὼς{l]
[l [n}18.159{]}ἄλλοτʼ ἐπαΐξασκε κατὰ μόθον, ἄλλοτε δʼ αὖτε{l]
[l [n}18.160{]}στάσκε μέγα ἰάχων· ὀπίσω δʼ οὐ χάζετο πάμπαν.{l]
[l [n}18.161{]}ὡς δʼ ἀπὸ σώματος οὔ τι λέοντʼ αἴθωνα δύνανται{l]
[l [n}18.162{]}ποιμένες ἄγραυλοι μέγα πεινάοντα δίεσθαι,{l]
[l [n}18.163{]}ὥς ῥα τὸν οὐκ ἐδύναντο δύω Αἴαντε κορυστὰ{l]
[l [n}18.164{]}Ἕκτορα Πριαμίδην ἀπὸ νεκροῦ δειδίξασθαι.{l]
[l [n}18.165{]}καί νύ κεν εἴρυσσέν τε καὶ ἄσπετον ἤρατο κῦδος,{l]
[l [n}18.166{]}εἰ μὴ Πηλεΐωνι ποδήνεμος ὠκέα Ἶρις{l]
[l [n}18.167{]}ἄγγελος ἦλθε θέουσʼ ἀπʼ Ὀλύμπου θωρήσσεσθαι{l]
[l [n}18.168{]}κρύβδα Διὸς ἄλλων τε θεῶν· πρὸ γὰρ ἧκέ μιν Ἥρη.{l]
[l [n}18.169{]}ἀγχοῦ δʼ ἱσταμένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}18.170{]}ὄρσεο Πηλεΐδη, πάντων ἐκπαγλότατʼ ἀνδρῶν·{l]
[l [n}18.171{]}Πατρόκλῳ ἐπάμυνον, οὗ εἵνεκα φύλοπις αἰνὴ{l]
[l [n}18.172{]}ἕστηκε πρὸ νεῶν· οἳ δʼ ἀλλήλους ὀλέκουσιν{l]
[l [n}18.173{]}οἳ μὲν ἀμυνόμενοι νέκυος πέρι τεθνηῶτος,{l]
[l [n}18.174{]}οἳ δὲ ἐρύσσασθαι ποτὶ Ἴλιον ἠνεμόεσσαν{l]
[l [n}18.175{]}Τρῶες ἐπιθύουσι· μάλιστα δὲ φαίδιμος Ἕκτωρ{l]
[l [n}18.176{]}ἑλκέμεναι μέμονεν· κεφαλὴν δέ ἑ θυμὸς ἄνωγε{l]
[l [n}18.177{]}πῆξαι ἀνὰ σκολόπεσσι ταμόνθʼ ἁπαλῆς ἀπὸ δειρῆς.{l]
[l [n}18.178{]}ἀλλʼ ἄνα μηδʼ ἔτι κεῖσο· σέβας δέ σε θυμὸν ἱκέσθω{l]
[l [n}18.179{]}Πάτροκλον Τρῳῇσι κυσὶν μέλπηθρα γενέσθαι·{l]
[l [n}18.180{]}σοὶ λώβη, αἴ κέν τι νέκυς ᾐσχυμμένος ἔλθῃ.{l]{q]{para]
[para}[l [n}18.181{]}τὴν δʼ ἠμείβετʼ ἔπειτα ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}18.182{]}Ἶρι θεὰ τίς γάρ σε θεῶν ἐμοὶ ἄγγελον ἧκε;{l]{q]{para]
[para}[l [n}18.183{]}τὸν δʼ αὖτε προσέειπε ποδήνεμος ὠκέα Ἶρις·{l]
[q}[l [n}18.184{]}Ἥρη με προέηκε Διὸς κυδρὴ παράκοιτις·{l]
[l [n}18.185{]}οὐδʼ οἶδε Κρονίδης ὑψίζυγος οὐδέ τις ἄλλος{l]
[l [n}18.186{]}ἀθανάτων, οἳ Ὄλυμπον ἀγάννιφον ἀμφινέμονται.{l]{q]{para]
[para}[l [n}18.187{]}τὴν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}18.188{]}πῶς τὰρ ἴω μετὰ μῶλον; ἔχουσι δὲ τεύχεʼ ἐκεῖνοι·{l]
[l [n}18.189{]}μήτηρ δʼ οὔ με φίλη πρίν γʼ εἴα θωρήσσεσθαι{l]
[l [n}18.190{]}πρίν γʼ αὐτὴν ἐλθοῦσαν ἐν ὀφθαλμοῖσιν ἴδωμαι·{l]
[l [n}18.191{]}στεῦτο γὰρ Ἡφαίστοιο πάρʼ οἰσέμεν ἔντεα καλά.{l]
[l [n}18.192{]}ἄλλου δʼ οὔ τευ οἶδα τεῦ ἂν κλυτὰ τεύχεα δύω,{l]
[l [n}18.193{]}εἰ μὴ Αἴαντός γε σάκος Τελαμωνιάδαο.{l]
[l [n}18.194{]}ἀλλὰ καὶ αὐτὸς ὅ γʼ ἔλπομʼ ἐνὶ πρώτοισιν ὁμιλεῖ{l]
[l [n}18.195{]}ἔγχεϊ δηϊόων περὶ Πατρόκλοιο θανόντος.{l]{q]{para]
[para}[l [n}18.196{]}τὸν δʼ αὖτε προσέειπε ποδήνεμος ὠκέα Ἶρις·{l]
[q}[l [n}18.197{]}εὖ νυ καὶ ἡμεῖς ἴδμεν ὅ τοι κλυτὰ τεύχεʼ ἔχονται·{l]
[l [n}18.198{]}ἀλλʼ αὔτως ἐπὶ τάφρον ἰὼν Τρώεσσι φάνηθι,{l]
[l [n}18.199{]}αἴ κέ σʼ ὑποδείσαντες ἀπόσχωνται πολέμοιο{l]
[l [n}18.200{]}Τρῶες, ἀναπνεύσωσι δʼ ἀρήϊοι υἷες Ἀχαιῶν{l]
[l [n}18.201{]}τειρόμενοι· ὀλίγη δέ τʼ ἀνάπνευσις πολέμοιο.{l]{q]{para]
[para}[l [n}18.202{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπέβη πόδας ὠκέα Ἶρις,{l]
[l [n}18.203{]}αὐτὰρ Ἀχιλλεὺς ὦρτο Διῒ φίλος· ἀμφὶ δʼ Ἀθήνη{l]
[l [n}18.204{]}ὤμοις ἰφθίμοισι βάλʼ αἰγίδα θυσσανόεσσαν,{l]
[l [n}18.205{]}ἀμφὶ δέ οἱ κεφαλῇ νέφος ἔστεφε δῖα θεάων{l]
[l [n}18.206{]}χρύσεον, ἐκ δʼ αὐτοῦ δαῖε φλόγα παμφανόωσαν.{l]
[l [n}18.207{]}ὡς δʼ ὅτε καπνὸς ἰὼν ἐξ ἄστεος αἰθέρʼ ἵκηται{l]
[l [n}18.208{]}τηλόθεν ἐκ νήσου, τὴν δήϊοι ἀμφιμάχωνται,{l]
[l [n}18.209{]}οἵ τε πανημέριοι στυγερῷ κρίνονται Ἄρηϊ{l]
[l [n}18.210{]}ἄστεος ἐκ σφετέρου· ἅμα δʼ ἠελίῳ καταδύντι{l]
[l [n}18.211{]}πυρσοί τε φλεγέθουσιν ἐπήτριμοι, ὑψόσε δʼ αὐγὴ{l]
[l [n}18.212{]}γίγνεται ἀΐσσουσα περικτιόνεσσιν ἰδέσθαι,{l]
[l [n}18.213{]}αἴ κέν πως σὺν νηυσὶν ἄρεω ἀλκτῆρες ἵκωνται·{l]
[l [n}18.214{]}ὣς ἀπʼ Ἀχιλλῆος κεφαλῆς σέλας αἰθέρʼ ἵκανε·{l]
[l [n}18.215{]}στῆ δʼ ἐπὶ τάφρον ἰὼν ἀπὸ τείχεος, οὐδʼ ἐς Ἀχαιοὺς{l]
[l [n}18.216{]}μίσγετο· μητρὸς γὰρ πυκινὴν ὠπίζετʼ ἐφετμήν.{l]
[l [n}18.217{]}ἔνθα στὰς ἤϋσʼ, ἀπάτερθε δὲ Παλλὰς Ἀθήνη{l]
[l [n}18.218{]}φθέγξατʼ· ἀτὰρ Τρώεσσιν ἐν ἄσπετον ὦρσε κυδοιμόν.{l]
[l [n}18.219{]}ὡς δʼ ὅτʼ ἀριζήλη φωνή, ὅτε τʼ ἴαχε σάλπιγξ{l]
[l [n}18.220{]}ἄστυ περιπλομένων δηΐων ὕπο θυμοραϊστέων,{l]
[l [n}18.221{]}ὣς τότʼ ἀριζήλη φωνὴ γένετʼ Αἰακίδαο.{l]
[l [n}18.222{]}οἳ δʼ ὡς οὖν ἄϊον ὄπα χάλκεον Αἰακίδαο,{l]
[l [n}18.223{]}πᾶσιν ὀρίνθη θυμός· ἀτὰρ καλλίτριχες ἵπποι{l]
[l [n}18.224{]}ἂψ ὄχεα τρόπεον· ὄσσοντο γὰρ ἄλγεα θυμῷ.{l]
[l [n}18.225{]}ἡνίοχοι δʼ ἔκπληγεν, ἐπεὶ ἴδον ἀκάματον πῦρ{l]
[l [n}18.226{]}δεινὸν ὑπὲρ κεφαλῆς μεγαθύμου Πηλεΐωνος{l]
[l [n}18.227{]}δαιόμενον· τὸ δὲ δαῖε θεὰ γλαυκῶπις Ἀθήνη.{l]
[l [n}18.228{]}τρὶς μὲν ὑπὲρ τάφρου μεγάλʼ ἴαχε δῖος Ἀχιλλεύς,{l]
[l [n}18.229{]}τρὶς δὲ κυκήθησαν Τρῶες κλειτοί τʼ ἐπίκουροι.{l]
[l [n}18.230{]}ἔνθα δὲ καὶ τότʼ ὄλοντο δυώδεκα φῶτες ἄριστοι{l]
[l [n}18.231{]}ἀμφὶ σφοῖς ὀχέεσσι καὶ ἔγχεσιν. αὐτὰρ Ἀχαιοὶ{l]
[l [n}18.232{]}ἀσπασίως Πάτροκλον ὑπʼ ἐκ βελέων ἐρύσαντες{l]
[l [n}18.233{]}κάτθεσαν ἐν λεχέεσσι· φίλοι δʼ ἀμφέσταν ἑταῖροι{l]
[l [n}18.234{]}μυρόμενοι· μετὰ δέ σφι ποδώκης εἵπετʼ Ἀχιλλεὺς{l]
[l [n}18.235{]}δάκρυα θερμὰ χέων, ἐπεὶ εἴσιδε πιστὸν ἑταῖρον{l]
[l [n}18.236{]}κείμενον ἐν φέρτρῳ δεδαϊγμένον ὀξέϊ χαλκῷ,{l]
[l [n}18.237{]}τόν ῥʼ ἤτοι μὲν ἔπεμπε σὺν ἵπποισιν καὶ ὄχεσφιν{l]
[l [n}18.238{]}ἐς πόλεμον, οὐδʼ αὖτις ἐδέξατο νοστήσαντα.{l]{para]
[para}[l [n}18.239{]}Ἠέλιον δʼ ἀκάμαντα βοῶπις πότνια Ἥρη{l]
[l [n}18.240{]}πέμψεν ἐπʼ Ὠκεανοῖο ῥοὰς ἀέκοντα νέεσθαι·{l]
[l [n}18.241{]}ἠέλιος μὲν ἔδυ, παύσαντο δὲ δῖοι Ἀχαιοὶ{l]
[l [n}18.242{]}φυλόπιδος κρατερῆς καὶ ὁμοιΐου πολέμοιο.{l]{para]
[para}[l [n}18.243{]}Τρῶες δʼ αὖθʼ ἑτέρωθεν ἀπὸ κρατερῆς ὑσμίνης{l]
[l [n}18.244{]}χωρήσαντες ἔλυσαν ὑφʼ ἅρμασιν ὠκέας ἵππους,{l]
[l [n}18.245{]}ἐς δʼ ἀγορὴν ἀγέροντο πάρος δόρποιο μέδεσθαι.{l]
[l [n}18.246{]}ὀρθῶν δʼ ἑσταότων ἀγορὴ γένετʼ, οὐδέ τις ἔτλη{l]
[l [n}18.247{]}ἕζεσθαι· πάντας γὰρ ἔχε τρόμος, οὕνεκʼ Ἀχιλλεὺς{l]
[l [n}18.248{]}ἐξεφάνη, δηρὸν δὲ μάχης ἐπέπαυτʼ ἀλεγεινῆς.{l]
[l [n}18.249{]}τοῖσι δὲ Πουλυδάμας πεπνυμένος ἦρχʼ ἀγορεύειν{l]
[l [n}18.250{]}Πανθοΐδης· ὃ γὰρ οἶος ὅρα πρόσσω καὶ ὀπίσσω·{l]
[l [n}18.251{]}Ἕκτορι δʼ ἦεν ἑταῖρος, ἰῇ δʼ ἐν νυκτὶ γένοντο,{l]
[l [n}18.252{]}ἀλλʼ ὃ μὲν ἂρ μύθοισιν, ὃ δʼ ἔγχεϊ πολλὸν ἐνίκα·{l]
[l [n}18.253{]}ὅ σφιν ἐϋφρονέων ἀγορήσατο καὶ μετέειπεν·{l]
[q}[l [n}18.254{]}ἀμφὶ μάλα φράζεσθε φίλοι· κέλομαι γὰρ ἔγωγε{l]
[l [n}18.255{]}ἄστυδε νῦν ἰέναι, μὴ μίμνειν ἠῶ δῖαν{l]
[l [n}18.256{]}ἐν πεδίῳ παρὰ νηυσίν· ἑκὰς δʼ ἀπὸ τείχεός εἰμεν.{l]
[l [n}18.257{]}ὄφρα μὲν οὗτος ἀνὴρ Ἀγαμέμνονι μήνιε δίῳ{l]
[l [n}18.258{]}τόφρα δὲ ῥηΐτεροι πολεμίζειν ἦσαν Ἀχαιοί·{l]
[l [n}18.259{]}χαίρεσκον γὰρ ἔγωγε θοῇς ἐπὶ νηυσὶν ἰαύων{l]
[l [n}18.260{]}ἐλπόμενος νῆας αἱρησέμεν ἀμφιελίσσας.{l]
[l [n}18.261{]}νῦν δʼ αἰνῶς δείδοικα ποδώκεα Πηλεΐωνα·{l]
[l [n}18.262{]}οἷος κείνου θυμὸς ὑπέρβιος, οὐκ ἐθελήσει{l]
[l [n}18.263{]}μίμνειν ἐν πεδίῳ, ὅθι περ Τρῶες καὶ Ἀχαιοὶ{l]
[l [n}18.264{]}ἐν μέσῳ ἀμφότεροι μένος Ἄρηος δατέονται,{l]
[l [n}18.265{]}ἀλλὰ περὶ πτόλιός τε μαχήσεται ἠδὲ γυναικῶν.{l]
[l [n}18.266{]}ἀλλʼ ἴομεν προτὶ ἄστυ, πίθεσθέ μοι· ὧδε γὰρ ἔσται·{l]
[l [n}18.267{]}νῦν μὲν νὺξ ἀπέπαυσε ποδώκεα Πηλεΐωνα{l]
[l [n}18.268{]}ἀμβροσίη· εἰ δʼ ἄμμε κιχήσεται ἐνθάδʼ ἐόντας{l]
[l [n}18.269{]}αὔριον ὁρμηθεὶς σὺν τεύχεσιν, εὖ νύ τις αὐτὸν{l]
[l [n}18.270{]}γνώσεται· ἀσπασίως γὰρ ἀφίξεται Ἴλιον ἱρὴν{l]
[l [n}18.271{]}ὅς κε φύγῃ, πολλοὺς δὲ κύνες καὶ γῦπες ἔδονται{l]
[l [n}18.272{]}Τρώων· αἲ γὰρ δή μοι ἀπʼ οὔατος ὧδε γένοιτο.{l]
[l [n}18.273{]}εἰ δʼ ἂν ἐμοῖς ἐπέεσσι πιθώμεθα κηδόμενοί περ,{l]
[l [n}18.274{]}νύκτα μὲν εἰν ἀγορῇ σθένος ἕξομεν, ἄστυ δὲ πύργοι{l]
[l [n}18.275{]}ὑψηλαί τε πύλαι σανίδες τʼ ἐπὶ τῇς ἀραρυῖαι{l]
[l [n}18.276{]}μακραὶ ἐΰξεστοι ἐζευγμέναι εἰρύσσονται·{l]
[l [n}18.277{]}πρῶϊ δʼ ὑπηοῖοι σὺν τεύχεσι θωρηχθέντες{l]
[l [n}18.278{]}στησόμεθʼ ἂμ πύργους· τῷ δʼ ἄλγιον, αἴ κʼ ἐθέλῃσιν{l]
[l [n}18.279{]}ἐλθὼν ἐκ νηῶν περὶ τείχεος ἄμμι μάχεσθαι.{l]
[l [n}18.280{]}ἂψ πάλιν εἶσʼ ἐπὶ νῆας, ἐπεί κʼ ἐριαύχενας ἵππους{l]
[l [n}18.281{]}παντοίου δρόμου ἄσῃ ὑπὸ πτόλιν ἠλασκάζων·{l]
[l [n}18.282{]}εἴσω δʼ οὔ μιν θυμὸς ἐφορμηθῆναι ἐάσει,{l]
[l [n}18.283{]}οὐδέ ποτʼ ἐκπέρσει· πρίν μιν κύνες ἀργοὶ ἔδονται.{l]{q]{para]
[para}[l [n}18.284{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}18.285{]}Πουλυδάμα σὺ μὲν οὐκέτʼ ἐμοὶ φίλα ταῦτʼ ἀγορεύεις,{l]
[l [n}18.286{]}ὃς κέλεαι κατὰ ἄστυ ἀλήμεναι αὖτις ἰόντας.{l]
[l [n}18.287{]}ἦ οὔ πω κεκόρησθε ἐελμένοι ἔνδοθι πύργων;{l]
[l [n}18.288{]}πρὶν μὲν γὰρ Πριάμοιο πόλιν μέροπες ἄνθρωποι{l]
[l [n}18.289{]}πάντες μυθέσκοντο πολύχρυσον πολύχαλκον·{l]
[l [n}18.290{]}νῦν δὲ δὴ ἐξαπόλωλε δόμων κειμήλια καλά,{l]
[l [n}18.291{]}πολλὰ δὲ δὴ Φρυγίην καὶ Μῃονίην ἐρατεινὴν{l]
[l [n}18.292{]}κτήματα περνάμενʼ ἵκει, ἐπεὶ μέγας ὠδύσατο Ζεύς.{l]
[l [n}18.293{]}νῦν δʼ ὅτε πέρ μοι ἔδωκε Κρόνου πάϊς ἀγκυλομήτεω{l]
[l [n}18.294{]}κῦδος ἀρέσθʼ ἐπὶ νηυσί, θαλάσσῃ τʼ ἔλσαι Ἀχαιούς,{l]
[l [n}18.295{]}νήπιε μηκέτι ταῦτα νοήματα φαῖνʼ ἐνὶ δήμῳ·{l]
[l [n}18.296{]}οὐ γάρ τις Τρώων ἐπιπείσεται· οὐ γὰρ ἐάσω.{l]
[l [n}18.297{]}ἀλλʼ ἄγεθʼ ὡς ἂν ἐγὼ εἴπω, πειθώμεθα πάντες.{l]
[l [n}18.298{]}νῦν μὲν δόρπον ἕλεσθε κατὰ στρατὸν ἐν τελέεσσι,{l]
[l [n}18.299{]}καὶ φυλακῆς μνήσασθε, καὶ ἐγρήγορθε ἕκαστος·{l]
[l [n}18.300{]}Τρώων δʼ ὃς κτεάτεσσιν ὑπερφιάλως ἀνιάζει,{l]
[l [n}18.301{]}συλλέξας λαοῖσι δότω καταδημοβορῆσαι·{l]
[l [n}18.302{]}τῶν τινὰ βέλτερόν ἐστιν ἐπαυρέμεν ἤ περ Ἀχαιούς.{l]
[l [n}18.303{]}πρῶϊ δʼ ὑπηοῖοι σὺν τεύχεσι θωρηχθέντες{l]
[l [n}18.304{]}νηυσὶν ἔπι γλαφυρῇσιν ἐγείρομεν ὀξὺν Ἄρηα.{l]
[l [n}18.305{]}εἰ δʼ ἐτεὸν παρὰ ναῦφιν ἀνέστη δῖος Ἀχιλλεύς,{l]
[l [n}18.306{]}ἄλγιον αἴ κʼ ἐθέλῃσι τῷ ἔσσεται· οὔ μιν ἔγωγε{l]
[l [n}18.307{]}φεύξομαι ἐκ πολέμοιο δυσηχέος, ἀλλὰ μάλʼ ἄντην{l]
[l [n}18.308{]}στήσομαι, ἤ κε φέρῃσι μέγα κράτος, ἦ κε φεροίμην.{l]
[l [n}18.309{]}ξυνὸς Ἐνυάλιος, καί τε κτανέοντα κατέκτα.{l]{q]{para]
[para}[l [n}18.310{]}ὣς Ἕκτωρ ἀγόρευʼ, ἐπὶ δὲ Τρῶες κελάδησαν{l]
[l [n}18.311{]}νήπιοι· ἐκ γάρ σφεων φρένας εἵλετο Παλλὰς Ἀθήνη.{l]
[l [n}18.312{]}Ἕκτορι μὲν γὰρ ἐπῄνησαν κακὰ μητιόωντι,{l]
[l [n}18.313{]}Πουλυδάμαντι δʼ ἄρʼ οὔ τις ὃς ἐσθλὴν φράζετο βουλήν.{l]
[l [n}18.314{]}δόρπον ἔπειθʼ εἵλοντο κατὰ στρατόν· αὐτὰρ Ἀχαιοὶ{l]
[l [n}18.315{]}παννύχιοι Πάτροκλον ἀνεστενάχοντο γοῶντες.{l]
[l [n}18.316{]}τοῖσι δὲ Πηλεΐδης ἁδινοῦ ἐξῆρχε γόοιο{l]
[l [n}18.317{]}χεῖρας ἐπʼ ἀνδροφόνους θέμενος στήθεσσιν ἑταίρου{l]
[l [n}18.318{]}πυκνὰ μάλα στενάχων ὥς τε λὶς ἠϋγένειος,{l]
[l [n}18.319{]}ᾧ ῥά θʼ ὑπὸ σκύμνους ἐλαφηβόλος ἁρπάσῃ ἀνὴρ{l]
[l [n}18.320{]}ὕλης ἐκ πυκινῆς· ὃ δέ τʼ ἄχνυται ὕστερος ἐλθών,{l]
[l [n}18.321{]}πολλὰ δέ τʼ ἄγκεʼ ἐπῆλθε μετʼ ἀνέρος ἴχνιʼ ἐρευνῶν{l]
[l [n}18.322{]}εἴ ποθεν ἐξεύροι· μάλα γὰρ δριμὺς χόλος αἱρεῖ·{l]
[l [n}18.323{]}ὣς ὃ βαρὺ στενάχων μετεφώνεε Μυρμιδόνεσσιν·{l]
[q}
[para}[l [n}18.324{]}ὢ πόποι ἦ ῥʼ ἅλιον ἔπος ἔκβαλον ἤματι κείνῳ{l]
[l [n}18.325{]}θαρσύνων ἥρωα Μενοίτιον ἐν μεγάροισι·{l]
[l [n}18.326{]}φῆν δέ οἱ εἰς Ὀπόεντα περικλυτὸν υἱὸν ἀπάξειν{l]
[l [n}18.327{]}Ἴλιον ἐκπέρσαντα, λαχόντα τε ληΐδος αἶσαν.{l]
[l [n}18.328{]}ἀλλʼ οὐ Ζεὺς ἄνδρεσσι νοήματα πάντα τελευτᾷ·{l]
[l [n}18.329{]}ἄμφω γὰρ πέπρωται ὁμοίην γαῖαν ἐρεῦσαι{l]
[l [n}18.330{]}αὐτοῦ ἐνὶ Τροίῃ, ἐπεὶ οὐδʼ ἐμὲ νοστήσαντα{l]
[l [n}18.331{]}δέξεται ἐν μεγάροισι γέρων ἱππηλάτα Πηλεὺς{l]
[l [n}18.332{]}οὐδὲ Θέτις μήτηρ, ἀλλʼ αὐτοῦ γαῖα καθέξει.{l]
[l [n}18.333{]}νῦν δʼ ἐπεὶ οὖν Πάτροκλε σεῦ ὕστερος εἶμʼ ὑπὸ γαῖαν,{l]
[l [n}18.334{]}οὔ σε πρὶν κτεριῶ πρίν γʼ Ἕκτορος ἐνθάδʼ ἐνεῖκαι{l]
[l [n}18.335{]}τεύχεα καὶ κεφαλὴν μεγαθύμου σοῖο φονῆος·{l]
[l [n}18.336{]}δώδεκα δὲ προπάροιθε πυρῆς ἀποδειροτομήσω{l]
[l [n}18.337{]}Τρώων ἀγλαὰ τέκνα σέθεν κταμένοιο χολωθείς.{l]
[l [n}18.338{]}τόφρα δέ μοι παρὰ νηυσὶ κορωνίσι κείσεαι αὔτως,{l]
[l [n}18.339{]}ἀμφὶ δὲ σὲ Τρῳαὶ καὶ Δαρδανίδες βαθύκολποι{l]
[l [n}18.340{]}κλαύσονται νύκτάς τε καὶ ἤματα δάκρυ χέουσαι,{l]
[l [n}18.341{]}τὰς αὐτοὶ καμόμεσθα βίηφί τε δουρί τε μακρῷ{l]
[l [n}18.342{]}πιείρας πέρθοντε πόλεις μερόπων ἀνθρώπων.{l]{q]{para]
[para}[l [n}18.343{]}ὣς εἰπὼν ἑτάροισιν ἐκέκλετο δῖος Ἀχιλλεὺς{l]
[l [n}18.344{]}ἀμφὶ πυρὶ στῆσαι τρίποδα μέγαν, ὄφρα τάχιστα{l]
[l [n}18.345{]}Πάτροκλον λούσειαν ἄπο βρότον αἱματόεντα.{l]
[l [n}18.346{]}οἳ δὲ λοετροχόον τρίποδʼ ἵστασαν ἐν πυρὶ κηλέῳ,{l]
[l [n}18.347{]}ἐν δʼ ἄρʼ ὕδωρ ἔχεαν, ὑπὸ δὲ ξύλα δαῖον ἑλόντες.{l]
[l [n}18.348{]}γάστρην μὲν τρίποδος πῦρ ἄμφεπε, θέρμετο δʼ ὕδωρ·{l]
[l [n}18.349{]}αὐτὰρ ἐπεὶ δὴ ζέσσεν ὕδωρ ἐνὶ ἤνοπι χαλκῷ,{l]
[l [n}18.350{]}καὶ τότε δὴ λοῦσάν τε καὶ ἤλειψαν λίπʼ ἐλαίῳ,{l]
[l [n}18.351{]}ἐν δʼ ὠτειλὰς πλῆσαν ἀλείφατος ἐννεώροιο·{l]
[l [n}18.352{]}ἐν λεχέεσσι δὲ θέντες ἑανῷ λιτὶ κάλυψαν{l]
[l [n}18.353{]}ἐς πόδας ἐκ κεφαλῆς, καθύπερθε δὲ φάρεϊ λευκῷ.{l]
[l [n}18.354{]}παννύχιοι μὲν ἔπειτα πόδας ταχὺν ἀμφʼ Ἀχιλῆα{l]
[l [n}18.355{]}Μυρμιδόνες Πάτροκλον ἀνεστενάχοντο γοῶντες·{l]
[l [n}18.356{]}Ζεὺς δʼ Ἥρην προσέειπε κασιγνήτην ἄλοχόν τε·{l]
[q}[l [n}18.357{]}ἔπρηξας καὶ ἔπειτα βοῶπις πότνια Ἥρη{l]
[l [n}18.358{]}ἀνστήσασʼ Ἀχιλῆα πόδας ταχύν· ἦ ῥά νυ σεῖο{l]
[l [n}18.359{]}ἐξ αὐτῆς ἐγένοντο κάρη κομόωντες Ἀχαιοί.{l]{q]{para]
[para}[l [n}18.360{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοῶπις πότνια Ἥρη·{l]
[q}[l [n}18.361{]}αἰνότατε Κρονίδη ποῖον τὸν μῦθον ἔειπες.{l]
[l [n}18.362{]}καὶ μὲν δή πού τις μέλλει βροτὸς ἀνδρὶ τελέσσαι,{l]
[l [n}18.363{]}ὅς περ θνητός τʼ ἐστὶ καὶ οὐ τόσα μήδεα οἶδε·{l]
[l [n}18.364{]}πῶς δὴ ἔγωγʼ, ἥ φημι θεάων ἔμμεν ἀρίστη,{l]
[l [n}18.365{]}ἀμφότερον γενεῇ τε καὶ οὕνεκα σὴ παράκοιτις{l]
[l [n}18.366{]}κέκλημαι, σὺ δὲ πᾶσι μετʼ ἀθανάτοισιν ἀνάσσεις,{l]
[l [n}18.367{]}οὐκ ὄφελον Τρώεσσι κοτεσσαμένη κακὰ ῥάψαι;{l]{q]{para]
[para}[l [n}18.368{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον·{l]
[l [n}18.369{]}Ἡφαίστου δʼ ἵκανε δόμον Θέτις ἀργυρόπεζα{l]
[l [n}18.370{]}ἄφθιτον ἀστερόεντα μεταπρεπέʼ ἀθανάτοισι{l]
[l [n}18.371{]}χάλκεον, ὅν ῥʼ αὐτὸς ποιήσατο κυλλοποδίων.{l]
[l [n}18.372{]}τὸν δʼ εὗρʼ ἱδρώοντα ἑλισσόμενον περὶ φύσας{l]
[l [n}18.373{]}σπεύδοντα· τρίποδας γὰρ ἐείκοσι πάντας ἔτευχεν{l]
[l [n}18.374{]}ἑστάμεναι περὶ τοῖχον ἐϋσταθέος μεγάροιο,{l]
[l [n}18.375{]}χρύσεα δέ σφʼ ὑπὸ κύκλα ἑκάστῳ πυθμένι θῆκεν,{l]
[l [n}18.376{]}ὄφρά οἱ αὐτόματοι θεῖον δυσαίατʼ ἀγῶνα{l]
[l [n}18.377{]}ἠδʼ αὖτις πρὸς δῶμα νεοίατο θαῦμα ἰδέσθαι.{l]
[l [n}18.378{]}οἳ δʼ ἤτοι τόσσον μὲν ἔχον τέλος, οὔατα δʼ οὔ πω{l]
[l [n}18.379{]}δαιδάλεα προσέκειτο· τά ῥʼ ἤρτυε, κόπτε δὲ δεσμούς.{l]
[l [n}18.380{]}ὄφρʼ ὅ γε ταῦτʼ ἐπονεῖτο ἰδυίῃσι πραπίδεσσι,{l]
[l [n}18.381{]}τόφρά οἱ ἐγγύθεν ἦλθε θεὰ Θέτις ἀργυρόπεζα.{l]
[l [n}18.382{]}τὴν δὲ ἴδε προμολοῦσα Χάρις λιπαροκρήδεμνος{l]
[l [n}18.383{]}καλή, τὴν ὤπυιε περικλυτὸς ἀμφιγυήεις·{l]
[l [n}18.384{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}18.385{]}τίπτε Θέτι τανύπεπλε ἱκάνεις ἡμέτερον δῶ{l]
[l [n}18.386{]}αἰδοίη τε φίλη τε; πάρος γε μὲν οὔ τι θαμίζεις.{l]
[l [n}18.387{]}ἀλλʼ ἕπεο προτέρω, ἵνα τοι πὰρ ξείνια θείω.{l]{q]{para]
[para}[l [n}18.388{]}ὣς ἄρα φωνήσασα πρόσω ἄγε δῖα θεάων.{l]
[l [n}18.389{]}τὴν μὲν ἔπειτα καθεῖσεν ἐπὶ θρόνου ἀργυροήλου{l]
[l [n}18.390{]}καλοῦ δαιδαλέου· ὑπὸ δὲ θρῆνυς ποσὶν ἦεν·{l]
[l [n}18.391{]}κέκλετο δʼ Ἥφαιστον κλυτοτέχνην εἶπέ τε μῦθον·{l]
[q}[l [n}18.392{]}Ἥφαιστε πρόμολʼ ὧδε· Θέτις νύ τι σεῖο χατίζει.{l]{q][l [n}18.393{]}τὴν δʼ ἠμείβετʼ ἔπειτα περικλυτὸς ἀμφιγυήεις·{l]
[q}[l [n}18.394{]}ἦ ῥά νύ μοι δεινή τε καὶ αἰδοίη θεὸς ἔνδον,{l]
[l [n}18.395{]}ἥ μʼ ἐσάωσʼ ὅτε μʼ ἄλγος ἀφίκετο τῆλε πεσόντα{l]
[l [n}18.396{]}μητρὸς ἐμῆς ἰότητι κυνώπιδος, ἥ μʼ ἐθέλησε{l]
[l [n}18.397{]}κρύψαι χωλὸν ἐόντα· τότʼ ἂν πάθον ἄλγεα θυμῷ,{l]
[l [n}18.398{]}εἰ μή μʼ Εὐρυνόμη τε Θέτις θʼ ὑπεδέξατο κόλπῳ{l]
[l [n}18.399{]}Εὐρυνόμη θυγάτηρ ἀψορρόου Ὠκεανοῖο.{l]
[l [n}18.400{]}τῇσι παρʼ εἰνάετες χάλκευον δαίδαλα πολλά,{l]
[l [n}18.401{]}πόρπας τε γναμπτάς θʼ ἕλικας κάλυκάς τε καὶ ὅρμους{l]
[l [n}18.402{]}ἐν σπῆϊ γλαφυρῷ· περὶ δὲ ῥόος Ὠκεανοῖο{l]
[l [n}18.403{]}ἀφρῷ μορμύρων ῥέεν ἄσπετος· οὐδέ τις ἄλλος{l]
[l [n}18.404{]}ᾔδεεν οὔτε θεῶν οὔτε θνητῶν ἀνθρώπων,{l]
[l [n}18.405{]}ἀλλὰ Θέτις τε καὶ Εὐρυνόμη ἴσαν, αἵ μʼ ἐσάωσαν.{l]
[l [n}18.406{]}ἣ νῦν ἡμέτερον δόμον ἵκει· τώ με μάλα χρεὼ{l]
[l [n}18.407{]}πάντα Θέτι καλλιπλοκάμῳ ζῳάγρια τίνειν.{l]
[l [n}18.408{]}ἀλλὰ σὺ μὲν νῦν οἱ παράθες ξεινήϊα καλά,{l]
[l [n}18.409{]}ὄφρʼ ἂν ἐγὼ φύσας ἀποθείομαι ὅπλά τε πάντα.{l]{q]{para]
[para}[l [n}18.410{]}ἦ, καὶ ἀπʼ ἀκμοθέτοιο πέλωρ αἴητον ἀνέστη{l]
[l [n}18.411{]}χωλεύων· ὑπὸ δὲ κνῆμαι ῥώοντο ἀραιαί.{l]
[l [n}18.412{]}φύσας μέν ῥʼ ἀπάνευθε τίθει πυρός, ὅπλά τε πάντα{l]
[l [n}18.413{]}λάρνακʼ ἐς ἀργυρέην συλλέξατο, τοῖς ἐπονεῖτο·{l]
[l [n}18.414{]}σπόγγῳ δʼ ἀμφὶ πρόσωπα καὶ ἄμφω χεῖρʼ ἀπομόργνυ{l]
[l [n}18.415{]}αὐχένα τε στιβαρὸν καὶ στήθεα λαχνήεντα,{l]
[l [n}18.416{]}δῦ δὲ χιτῶνʼ, ἕλε δὲ σκῆπτρον παχύ, βῆ δὲ θύραζε{l]
[l [n}18.417{]}χωλεύων· ὑπὸ δʼ ἀμφίπολοι ῥώοντο ἄνακτι{l]
[l [n}18.418{]}χρύσειαι ζωῇσι νεήνισιν εἰοικυῖαι.{l]
[l [n}18.419{]}τῇς ἐν μὲν νόος ἐστὶ μετὰ φρεσίν, ἐν δὲ καὶ αὐδὴ{l]
[l [n}18.420{]}καὶ σθένος, ἀθανάτων δὲ θεῶν ἄπο ἔργα ἴσασιν.{l]
[l [n}18.421{]}αἳ μὲν ὕπαιθα ἄνακτος ἐποίπνυον· αὐτὰρ ὃ ἔρρων{l]
[l [n}18.422{]}πλησίον, ἔνθα Θέτις περ, ἐπὶ θρόνου ἷζε φαεινοῦ,{l]
[l [n}18.423{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}18.424{]}τίπτε Θέτι τανύπεπλε ἱκάνεις ἡμέτερον δῶ{l]
[l [n}18.425{]}αἰδοίη τε φίλη τε; πάρος γε μὲν οὔ τι θαμίζεις.{l]
[l [n}18.426{]}αὔδα ὅ τι φρονέεις· τελέσαι δέ με θυμὸς ἄνωγεν,{l]
[l [n}18.427{]}εἰ δύναμαι τελέσαι γε καὶ εἰ τετελεσμένον ἐστίν.{l]{q]{para]
[para}[l [n}18.428{]}τὸν δʼ ἠμείβετʼ ἔπειτα Θέτις κατὰ δάκρυ χέουσα·{l]
[q}[l [n}18.429{]}Ἥφαιστʼ, ἦ ἄρα δή τις, ὅσαι θεαί εἰσʼ ἐν Ὀλύμπῳ,{l]
[l [n}18.430{]}τοσσάδʼ ἐνὶ φρεσὶν ᾗσιν ἀνέσχετο κήδεα λυγρὰ{l]
[l [n}18.431{]}ὅσσʼ ἐμοὶ ἐκ πασέων Κρονίδης Ζεὺς ἄλγεʼ ἔδωκεν;{l]
[l [n}18.432{]}ἐκ μέν μʼ ἀλλάων ἁλιάων ἀνδρὶ δάμασσεν{l]
[l [n}18.433{]}Αἰακίδῃ Πηλῆϊ, καὶ ἔτλην ἀνέρος εὐνὴν{l]
[l [n}18.434{]}πολλὰ μάλʼ οὐκ ἐθέλουσα. ὃ μὲν δὴ γήραϊ λυγρῷ{l]
[l [n}18.435{]}κεῖται ἐνὶ μεγάροις ἀρημένος, ἄλλα δέ μοι νῦν·{l]
[l [n}18.436{]}υἱὸν ἐπεί μοι δῶκε γενέσθαί τε τραφέμεν τε{l]
[l [n}18.437{]}ἔξοχον ἡρώων· ὃ δʼ ἀνέδραμεν ἔρνεϊ ἶσος·{l]
[l [n}18.438{]}τὸν μὲν ἐγὼ θρέψασα φυτὸν ὣς γουνῷ ἀλωῆς{l]
[l [n}18.439{]}νηυσὶν ἐπιπροέηκα κορωνίσιν Ἴλιον εἴσω{l]
[l [n}18.440{]}Τρωσὶ μαχησόμενον· τὸν δʼ οὐχ ὑποδέξομαι αὖτις{l]
[l [n}18.441{]}οἴκαδε νοστήσαντα δόμον Πηλήϊον εἴσω.{l]
[l [n}18.442{]}ὄφρα δέ μοι ζώει καὶ ὁρᾷ φάος ἠελίοιο{l]
[l [n}18.443{]}ἄχνυται, οὐδέ τί οἱ δύναμαι χραισμῆσαι ἰοῦσα.{l]
[l [n}18.444{]}κούρην ἣν ἄρα οἱ γέρας ἔξελον υἷες Ἀχαιῶν,{l]
[l [n}18.445{]}τὴν ἂψ ἐκ χειρῶν ἕλετο κρείων Ἀγαμέμνων.{l]
[l [n}18.446{]}ἤτοι ὃ τῆς ἀχέων φρένας ἔφθιεν· αὐτὰρ Ἀχαιοὺς{l]
[l [n}18.447{]}Τρῶες ἐπὶ πρύμνῃσιν ἐείλεον, οὐδὲ θύραζε{l]
[l [n}18.448{]}εἴων ἐξιέναι· τὸν δὲ λίσσοντο γέροντες{l]
[l [n}18.449{]}Ἀργείων, καὶ πολλὰ περικλυτὰ δῶρʼ ὀνόμαζον.{l]
[l [n}18.450{]}ἔνθʼ αὐτὸς μὲν ἔπειτʼ ἠναίνετο λοιγὸν ἀμῦναι,{l]
[l [n}18.451{]}αὐτὰρ ὃ Πάτροκλον περὶ μὲν τὰ ἃ τεύχεα ἕσσε,{l]
[l [n}18.452{]}πέμπε δέ μιν πόλεμον δέ, πολὺν δʼ ἅμα λαὸν ὄπασσε.{l]
[l [n}18.453{]}πᾶν δʼ ἦμαρ μάρναντο περὶ Σκαιῇσι πύλῃσι·{l]
[l [n}18.454{]}καί νύ κεν αὐτῆμαρ πόλιν ἔπραθον, εἰ μὴ Ἀπόλλων{l]
[l [n}18.455{]}πολλὰ κακὰ ῥέξαντα Μενοιτίου ἄλκιμον υἱὸν{l]
[l [n}18.456{]}ἔκτανʼ ἐνὶ προμάχοισι καὶ Ἕκτορι κῦδος ἔδωκε.{l]
[l [n}18.457{]}τοὔνεκα νῦν τὰ σὰ γούναθʼ ἱκάνομαι, αἴ κʼ ἐθέλῃσθα{l]
[l [n}18.458{]}υἱεῖ ἐμῷ ὠκυμόρῳ δόμεν ἀσπίδα καὶ τρυφάλειαν{l]
[l [n}18.459{]}καὶ καλὰς κνημῖδας ἐπισφυρίοις ἀραρυίας{l]
[l [n}18.460{]}καὶ θώρηχʼ· ὃ γὰρ ἦν οἱ ἀπώλεσε πιστὸς ἑταῖρος{l]
[l [n}18.461{]}Τρωσὶ δαμείς· ὃ δὲ κεῖται ἐπὶ χθονὶ θυμὸν ἀχεύων.{l]{q]{para]
[para}[l [n}18.462{]}τὴν δʼ ἠμείβετʼ ἔπειτα περικλυτὸς ἀμφιγυήεις·{l]
[q}[l [n}18.463{]}θάρσει· μή τοι ταῦτα μετὰ φρεσὶ σῇσι μελόντων.{l]
[l [n}18.464{]}αἲ γάρ μιν θανάτοιο δυσηχέος ὧδε δυναίμην{l]
[l [n}18.465{]}νόσφιν ἀποκρύψαι, ὅτε μιν μόρος αἰνὸς ἱκάνοι,{l]
[l [n}18.466{]}ὥς οἱ τεύχεα καλὰ παρέσσεται, οἷά τις αὖτε{l]
[l [n}18.467{]}ἀνθρώπων πολέων θαυμάσσεται, ὅς κεν ἴδηται.{l]{q]{para]
[para}[l [n}18.468{]}ὣς εἰπὼν τὴν μὲν λίπεν αὐτοῦ, βῆ δʼ ἐπὶ φύσας·{l]
[l [n}18.469{]}τὰς δʼ ἐς πῦρ ἔτρεψε κέλευσέ τε ἐργάζεσθαι.{l]
[l [n}18.470{]}φῦσαι δʼ ἐν χοάνοισιν ἐείκοσι πᾶσαι ἐφύσων{l]
[l [n}18.471{]}παντοίην εὔπρηστον ἀϋτμὴν ἐξανιεῖσαι,{l]
[l [n}18.472{]}ἄλλοτε μὲν σπεύδοντι παρέμμεναι, ἄλλοτε δʼ αὖτε,{l]
[l [n}18.473{]}ὅππως Ἥφαιστός τʼ ἐθέλοι καὶ ἔργον ἄνοιτο.{l]
[l [n}18.474{]}χαλκὸν δʼ ἐν πυρὶ βάλλεν ἀτειρέα κασσίτερόν τε{l]
[l [n}18.475{]}καὶ χρυσὸν τιμῆντα καὶ ἄργυρον· αὐτὰρ ἔπειτα{l]
[l [n}18.476{]}θῆκεν ἐν ἀκμοθέτῳ μέγαν ἄκμονα, γέντο δὲ χειρὶ{l]
[l [n}18.477{]}ῥαιστῆρα κρατερήν, ἑτέρηφι δὲ γέντο πυράγρην.{l]{para]
[para}[l [n}18.478{]}ποίει δὲ πρώτιστα σάκος μέγα τε στιβαρόν τε{l]
[l [n}18.479{]}πάντοσε δαιδάλλων, περὶ δʼ ἄντυγα βάλλε φαεινὴν{l]
[l [n}18.480{]}τρίπλακα μαρμαρέην, ἐκ δʼ ἀργύρεον τελαμῶνα.{l]
[l [n}18.481{]}πέντε δʼ ἄρʼ αὐτοῦ ἔσαν σάκεος πτύχες· αὐτὰρ ἐν αὐτῷ{l]
[l [n}18.482{]}ποίει δαίδαλα πολλὰ ἰδυίῃσι πραπίδεσσιν.{l]{para]
[para}[l [n}18.483{]}ἐν μὲν γαῖαν ἔτευξʼ, ἐν δʼ οὐρανόν, ἐν δὲ θάλασσαν,{l]
[l [n}18.484{]}ἠέλιόν τʼ ἀκάμαντα σελήνην τε πλήθουσαν,{l]
[l [n}18.485{]}ἐν δὲ τὰ τείρεα πάντα, τά τʼ οὐρανὸς ἐστεφάνωται,{l]
[l [n}18.486{]}Πληϊάδας θʼ Ὑάδας τε τό τε σθένος Ὠρίωνος{l]
[l [n}18.487{]}Ἄρκτόν θʼ, ἣν καὶ Ἄμαξαν ἐπίκλησιν καλέουσιν,{l]
[l [n}18.488{]}ἥ τʼ αὐτοῦ στρέφεται καί τʼ Ὠρίωνα δοκεύει,{l]
[l [n}18.489{]}οἴη δʼ ἄμμορός ἐστι λοετρῶν Ὠκεανοῖο.{l]{para]
[para}[l [n}18.490{]}ἐν δὲ δύω ποίησε πόλεις μερόπων ἀνθρώπων{l]
[l [n}18.491{]}καλάς. ἐν τῇ μέν ῥα γάμοι τʼ ἔσαν εἰλαπίναι τε,{l]
[l [n}18.492{]}νύμφας δʼ ἐκ θαλάμων δαΐδων ὕπο λαμπομενάων{l]
[l [n}18.493{]}ἠγίνεον ἀνὰ ἄστυ, πολὺς δʼ ὑμέναιος ὀρώρει·{l]
[l [n}18.494{]}κοῦροι δʼ ὀρχηστῆρες ἐδίνεον, ἐν δʼ ἄρα τοῖσιν{l]
[l [n}18.495{]}αὐλοὶ φόρμιγγές τε βοὴν ἔχον· αἳ δὲ γυναῖκες{l]
[l [n}18.496{]}ἱστάμεναι θαύμαζον ἐπὶ προθύροισιν ἑκάστη.{l]
[l [n}18.497{]}λαοὶ δʼ εἰν ἀγορῇ ἔσαν ἀθρόοι· ἔνθα δὲ νεῖκος{l]
[l [n}18.498{]}ὠρώρει, δύο δʼ ἄνδρες ἐνείκεον εἵνεκα ποινῆς{l]
[l [n}18.499{]}ἀνδρὸς ἀποφθιμένου· ὃ μὲν εὔχετο πάντʼ ἀποδοῦναι{l]
[l [n}18.500{]}δήμῳ πιφαύσκων, ὃ δʼ ἀναίνετο μηδὲν ἑλέσθαι·{l]
[l [n}18.501{]}ἄμφω δʼ ἱέσθην ἐπὶ ἴστορι πεῖραρ ἑλέσθαι.{l]
[l [n}18.502{]}λαοὶ δʼ ἀμφοτέροισιν ἐπήπυον ἀμφὶς ἀρωγοί·{l]
[l [n}18.503{]}κήρυκες δʼ ἄρα λαὸν ἐρήτυον· οἳ δὲ γέροντες{l]
[l [n}18.504{]}εἵατʼ ἐπὶ ξεστοῖσι λίθοις ἱερῷ ἐνὶ κύκλῳ,{l]
[l [n}18.505{]}σκῆπτρα δὲ κηρύκων ἐν χέρσʼ ἔχον ἠεροφώνων·{l]
[l [n}18.506{]}τοῖσιν ἔπειτʼ ἤϊσσον, ἀμοιβηδὶς δὲ δίκαζον.{l]
[l [n}18.507{]}κεῖτο δʼ ἄρʼ ἐν μέσσοισι δύω χρυσοῖο τάλαντα,{l]
[l [n}18.508{]}τῷ δόμεν ὃς μετὰ τοῖσι δίκην ἰθύντατα εἴποι.{l]{para]
[para}[l [n}18.509{]}τὴν δʼ ἑτέρην πόλιν ἀμφὶ δύω στρατοὶ ἥατο λαῶν{l]
[l [n}18.510{]}τεύχεσι λαμπόμενοι· δίχα δέ σφισιν ἥνδανε βουλή,{l]
[l [n}18.511{]}ἠὲ διαπραθέειν ἢ ἄνδιχα πάντα δάσασθαι{l]
[l [n}18.512{]}κτῆσιν ὅσην πτολίεθρον ἐπήρατον ἐντὸς ἔεργεν·{l]
[l [n}18.513{]}οἳ δʼ οὔ πω πείθοντο, λόχῳ δʼ ὑπεθωρήσσοντο.{l]
[l [n}18.514{]}τεῖχος μέν ῥʼ ἄλοχοί τε φίλαι καὶ νήπια τέκνα{l]
[l [n}18.515{]}ῥύατʼ ἐφεσταότες, μετὰ δʼ ἀνέρες οὓς ἔχε γῆρας·{l]
[l [n}18.516{]}οἳ δʼ ἴσαν· ἦρχε δʼ ἄρά σφιν Ἄρης καὶ Παλλὰς Ἀθήνη{l]
[l [n}18.517{]}ἄμφω χρυσείω, χρύσεια δὲ εἵματα ἕσθην,{l]
[l [n}18.518{]}καλὼ καὶ μεγάλω σὺν τεύχεσιν, ὥς τε θεώ περ{l]
[l [n}18.519{]}ἀμφὶς ἀριζήλω· λαοὶ δʼ ὑπολίζονες ἦσαν.{l]
[l [n}18.520{]}οἳ δʼ ὅτε δή ῥʼ ἵκανον ὅθι σφίσιν εἶκε λοχῆσαι{l]
[l [n}18.521{]}ἐν ποταμῷ, ὅθι τʼ ἀρδμὸς ἔην πάντεσσι βοτοῖσιν,{l]
[l [n}18.522{]}ἔνθʼ ἄρα τοί γʼ ἵζοντʼ εἰλυμένοι αἴθοπι χαλκῷ.{l]
[l [n}18.523{]}τοῖσι δʼ ἔπειτʼ ἀπάνευθε δύω σκοποὶ εἵατο λαῶν{l]
[l [n}18.524{]}δέγμενοι ὁππότε μῆλα ἰδοίατο καὶ ἕλικας βοῦς.{l]
[l [n}18.525{]}οἳ δὲ τάχα προγένοντο, δύω δʼ ἅμʼ ἕποντο νομῆες{l]
[l [n}18.526{]}τερπόμενοι σύριγξι· δόλον δʼ οὔ τι προνόησαν.{l]
[l [n}18.527{]}οἳ μὲν τὰ προϊδόντες ἐπέδραμον, ὦκα δʼ ἔπειτα{l]
[l [n}18.528{]}τάμνοντʼ ἀμφὶ βοῶν ἀγέλας καὶ πώεα καλὰ{l]
[l [n}18.529{]}ἀργεννέων οἰῶν, κτεῖνον δʼ ἐπὶ μηλοβοτῆρας.{l]
[l [n}18.530{]}οἳ δʼ ὡς οὖν ἐπύθοντο πολὺν κέλαδον παρὰ βουσὶν{l]
[l [n}18.531{]}εἰράων προπάροιθε καθήμενοι, αὐτίκʼ ἐφʼ ἵππων{l]
[l [n}18.532{]}βάντες ἀερσιπόδων μετεκίαθον, αἶψα δʼ ἵκοντο.{l]
[l [n}18.533{]}στησάμενοι δʼ ἐμάχοντο μάχην ποταμοῖο παρʼ ὄχθας,{l]
[l [n}18.534{]}βάλλον δʼ ἀλλήλους χαλκήρεσιν ἐγχείῃσιν.{l]
[l [n}18.535{]}ἐν δʼ Ἔρις ἐν δὲ Κυδοιμὸς ὁμίλεον, ἐν δʼ ὀλοὴ Κήρ,{l]
[l [n}18.536{]}ἄλλον ζωὸν ἔχουσα νεούτατον, ἄλλον ἄουτον,{l]
[l [n}18.537{]}ἄλλον τεθνηῶτα κατὰ μόθον ἕλκε ποδοῖιν·{l]
[l [n}18.538{]}εἷμα δʼ ἔχʼ ἀμφʼ ὤμοισι δαφοινεὸν αἵματι φωτῶν.{l]
[l [n}18.539{]}ὡμίλευν δʼ ὥς τε ζωοὶ βροτοὶ ἠδʼ ἐμάχοντο,{l]
[l [n}18.540{]}νεκρούς τʼ ἀλλήλων ἔρυον κατατεθνηῶτας.{l]{para]
[para}[l [n}18.541{]}ἐν δʼ ἐτίθει νειὸν μαλακὴν πίειραν ἄρουραν{l]
[l [n}18.542{]}εὐρεῖαν τρίπολον· πολλοὶ δʼ ἀροτῆρες ἐν αὐτῇ{l]
[l [n}18.543{]}ζεύγεα δινεύοντες ἐλάστρεον ἔνθα καὶ ἔνθα.{l]
[l [n}18.544{]}οἳ δʼ ὁπότε στρέψαντες ἱκοίατο τέλσον ἀρούρης,{l]
[l [n}18.545{]}τοῖσι δʼ ἔπειτʼ ἐν χερσὶ δέπας μελιηδέος οἴνου{l]
[l [n}18.546{]}δόσκεν ἀνὴρ ἐπιών· τοὶ δὲ στρέψασκον ἀνʼ ὄγμους,{l]
[l [n}18.547{]}ἱέμενοι νειοῖο βαθείης τέλσον ἱκέσθαι.{l]
[l [n}18.548{]}ἣ δὲ μελαίνετʼ ὄπισθεν, ἀρηρομένῃ δὲ ἐῴκει,{l]
[l [n}18.549{]}χρυσείη περ ἐοῦσα· τὸ δὴ περὶ θαῦμα τέτυκτο.{l]{para]
[para}[l [n}18.550{]}ἐν δʼ ἐτίθει τέμενος βασιλήϊον· ἔνθα δʼ ἔριθοι{l]
[l [n}18.551{]}ἤμων ὀξείας δρεπάνας ἐν χερσὶν ἔχοντες.{l]
[l [n}18.552{]}δράγματα δʼ ἄλλα μετʼ ὄγμον ἐπήτριμα πῖπτον ἔραζε,{l]
[l [n}18.553{]}ἄλλα δʼ ἀμαλλοδετῆρες ἐν ἐλλεδανοῖσι δέοντο.{l]
[l [n}18.554{]}τρεῖς δʼ ἄρʼ ἀμαλλοδετῆρες ἐφέστασαν· αὐτὰρ ὄπισθε{l]
[l [n}18.555{]}παῖδες δραγμεύοντες ἐν ἀγκαλίδεσσι φέροντες{l]
[l [n}18.556{]}ἀσπερχὲς πάρεχον· βασιλεὺς δʼ ἐν τοῖσι σιωπῇ{l]
[l [n}18.557{]}σκῆπτρον ἔχων ἑστήκει ἐπʼ ὄγμου γηθόσυνος κῆρ.{l]
[l [n}18.558{]}κήρυκες δʼ ἀπάνευθεν ὑπὸ δρυῒ δαῖτα πένοντο,{l]
[l [n}18.559{]}βοῦν δʼ ἱερεύσαντες μέγαν ἄμφεπον· αἳ δὲ γυναῖκες{l]
[l [n}18.560{]}δεῖπνον ἐρίθοισιν λεύκʼ ἄλφιτα πολλὰ πάλυνον.{l]{para]
[para}[l [n}18.561{]}ἐν δʼ ἐτίθει σταφυλῇσι μέγα βρίθουσαν ἀλωὴν{l]
[l [n}18.562{]}καλὴν χρυσείην· μέλανες δʼ ἀνὰ βότρυες ἦσαν,{l]
[l [n}18.563{]}ἑστήκει δὲ κάμαξι διαμπερὲς ἀργυρέῃσιν.{l]
[l [n}18.564{]}ἀμφὶ δὲ κυανέην κάπετον, περὶ δʼ ἕρκος ἔλασσε{l]
[l [n}18.565{]}κασσιτέρου· μία δʼ οἴη ἀταρπιτὸς ἦεν ἐπʼ αὐτήν,{l]
[l [n}18.566{]}τῇ νίσοντο φορῆες ὅτε τρυγόῳεν ἀλωήν.{l]
[l [n}18.567{]}παρθενικαὶ δὲ καὶ ἠΐθεοι ἀταλὰ φρονέοντες{l]
[l [n}18.568{]}πλεκτοῖς ἐν ταλάροισι φέρον μελιηδέα καρπόν.{l]
[l [n}18.569{]}τοῖσιν δʼ ἐν μέσσοισι πάϊς φόρμιγγι λιγείῃ{l]
[l [n}18.570{]}ἱμερόεν κιθάριζε, λίνον δʼ ὑπὸ καλὸν ἄειδε{l]
[l [n}18.571{]}λεπταλέῃ φωνῇ· τοὶ δὲ ῥήσσοντες ἁμαρτῇ{l]
[l [n}18.572{]}μολπῇ τʼ ἰυγμῷ τε ποσὶ σκαίροντες ἕποντο.{l]{para]
[para}[l [n}18.573{]}ἐν δʼ ἀγέλην ποίησε βοῶν ὀρθοκραιράων·{l]
[l [n}18.574{]}αἳ δὲ βόες χρυσοῖο τετεύχατο κασσιτέρου τε,{l]
[l [n}18.575{]}μυκηθμῷ δʼ ἀπὸ κόπρου ἐπεσσεύοντο νομὸν δὲ{l]
[l [n}18.576{]}πὰρ ποταμὸν κελάδοντα, παρὰ ῥοδανὸν δονακῆα.{l]
[l [n}18.577{]}χρύσειοι δὲ νομῆες ἅμʼ ἐστιχόωντο βόεσσι{l]
[l [n}18.578{]}τέσσαρες, ἐννέα δέ σφι κύνες πόδας ἀργοὶ ἕποντο.{l]
[l [n}18.579{]}σμερδαλέω δὲ λέοντε δύʼ ἐν πρώτῃσι βόεσσι{l]
[l [n}18.580{]}ταῦρον ἐρύγμηλον ἐχέτην· ὃ δὲ μακρὰ μεμυκὼς{l]
[l [n}18.581{]}ἕλκετο· τὸν δὲ κύνες μετεκίαθον ἠδʼ αἰζηοί.{l]
[l [n}18.582{]}τὼ μὲν ἀναρρήξαντε βοὸς μεγάλοιο βοείην{l]
[l [n}18.583{]}ἔγκατα καὶ μέλαν αἷμα λαφύσσετον· οἳ δὲ νομῆες{l]
[l [n}18.584{]}αὔτως ἐνδίεσαν ταχέας κύνας ὀτρύνοντες.{l]
[l [n}18.585{]}οἳ δʼ ἤτοι δακέειν μὲν ἀπετρωπῶντο λεόντων,{l]
[l [n}18.586{]}ἱστάμενοι δὲ μάλʼ ἐγγὺς ὑλάκτεον ἔκ τʼ ἀλέοντο.{l]{para]
[para}[l [n}18.587{]}ἐν δὲ νομὸν ποίησε περικλυτὸς ἀμφιγυήεις{l]
[l [n}18.588{]}ἐν καλῇ βήσσῃ μέγαν οἰῶν ἀργεννάων,{l]
[l [n}18.589{]}σταθμούς τε κλισίας τε κατηρεφέας ἰδὲ σηκούς.{l]{para]
[para}[l [n}18.590{]}ἐν δὲ χορὸν ποίκιλλε περικλυτὸς ἀμφιγυήεις,{l]
[l [n}18.591{]}τῷ ἴκελον οἷόν ποτʼ ἐνὶ Κνωσῷ εὐρείῃ{l]
[l [n}18.592{]}Δαίδαλος ἤσκησεν καλλιπλοκάμῳ Ἀριάδνῃ.{l]
[l [n}18.593{]}ἔνθα μὲν ἠΐθεοι καὶ παρθένοι ἀλφεσίβοιαι{l]
[l [n}18.594{]}ὀρχεῦντʼ ἀλλήλων ἐπὶ καρπῷ χεῖρας ἔχοντες.{l]
[l [n}18.595{]}τῶν δʼ αἳ μὲν λεπτὰς ὀθόνας ἔχον, οἳ δὲ χιτῶνας{l]
[l [n}18.596{]}εἵατʼ ἐϋννήτους, ἦκα στίλβοντας ἐλαίῳ·{l]
[l [n}18.597{]}καί ῥʼ αἳ μὲν καλὰς στεφάνας ἔχον, οἳ δὲ μαχαίρας{l]
[l [n}18.598{]}εἶχον χρυσείας ἐξ ἀργυρέων τελαμώνων.{l]
[l [n}18.599{]}οἳ δʼ ὁτὲ μὲν θρέξασκον ἐπισταμένοισι πόδεσσι{l]
[l [n}18.600{]}ῥεῖα μάλʼ, ὡς ὅτε τις τροχὸν ἄρμενον ἐν παλάμῃσιν{l]
[l [n}18.601{]}ἑζόμενος κεραμεὺς πειρήσεται, αἴ κε θέῃσιν·{l]
[l [n}18.602{]}ἄλλοτε δʼ αὖ θρέξασκον ἐπὶ στίχας ἀλλήλοισι.{l]
[l [n}18.603{]}πολλὸς δʼ ἱμερόεντα χορὸν περιίσταθʼ ὅμιλος{l]
[l [n}18.604{]}τερπόμενοι· μετὰ δέ σφιν ἐμέλπετο θεῖος ἀοιδὸς{l]
[l [n}18.605{]}φορμίζων· δοιὼ δὲ κυβιστητῆρε κατ' αὐτοὺς{l]
[l [n}18.606{]}μολπῆς ἐξάρχοντες ἐδίνευον κατὰ μέσσους.{l]{para]
[para}[l [n}18.607{]}ἐν δʼ ἐτίθει ποταμοῖο μέγα σθένος Ὠκεανοῖο{l]
[l [n}18.608{]}ἄντυγα πὰρ πυμάτην σάκεος πύκα ποιητοῖο.{l]{para]
[para}[l [n}18.609{]}αὐτὰρ ἐπεὶ δὴ τεῦξε σάκος μέγα τε στιβαρόν τε,{l]
[l [n}18.610{]}τεῦξʼ ἄρα οἱ θώρηκα φαεινότερον πυρὸς αὐγῆς,{l]
[l [n}18.611{]}τεῦξε δέ οἱ κόρυθα βριαρὴν κροτάφοις ἀραρυῖαν{l]
[l [n}18.612{]}καλὴν δαιδαλέην, ἐπὶ δὲ χρύσεον λόφον ἧκε,{l]
[l [n}18.613{]}τεῦξε δέ οἱ κνημῖδας ἑανοῦ κασσιτέροιο.{l]{para]
[para}[l [n}18.614{]}αὐτὰρ ἐπεὶ πάνθʼ ὅπλα κάμε κλυτὸς ἀμφιγυήεις,{l]
[l [n}18.615{]}μητρὸς Ἀχιλλῆος θῆκε προπάροιθεν ἀείρας.{l]
[l [n}18.616{]}ἣ δʼ ἴρηξ ὣς ἆλτο κατʼ Οὐλύμπου νιφόεντος{l]
[l [n}18.617{]}τεύχεα μαρμαίροντα παρʼ Ἡφαίστοιο φέρουσα.{l]{para]
{book]
[book [n}19{]}[l [n}19.1{]}Ἠὼς μὲν κροκόπεπλος ἀπʼ Ὠκεανοῖο ῥοάων{l]
[l [n}19.2{]}ὄρνυθʼ, ἵνʼ ἀθανάτοισι φόως φέροι ἠδὲ βροτοῖσιν·{l]
[l [n}19.3{]}ἣ δʼ ἐς νῆας ἵκανε θεοῦ πάρα δῶρα φέρουσα.{l]
[l [n}19.4{]}εὗρε δὲ Πατρόκλῳ περικείμενον ὃν φίλον υἱὸν{l]
[l [n}19.5{]}κλαίοντα λιγέως· πολέες δʼ ἀμφʼ αὐτὸν ἑταῖροι{l]
[l [n}19.6{]}μύρονθʼ· ἣ δʼ ἐν τοῖσι παρίστατο δῖα θεάων,{l]
[l [n}19.7{]}ἔν τʼ ἄρα οἱ φῦ χειρὶ ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}19.8{]}τέκνον ἐμὸν τοῦτον μὲν ἐάσομεν ἀχνύμενοί περ{l]
[l [n}19.9{]}κεῖσθαι, ἐπεὶ δὴ πρῶτα θεῶν ἰότητι δαμάσθη·{l]
[l [n}19.10{]}τύνη δʼ Ἡφαίστοιο πάρα κλυτὰ τεύχεα δέξο{l]
[l [n}19.11{]}καλὰ μάλʼ, οἷʼ οὔ πώ τις ἀνὴρ ὤμοισι φόρησεν.{l]{q]
[para}[l [n}19.12{]}ὡς ἄρα φωνήσασα θεὰ κατὰ τεύχεʼ ἔθηκε{l]
[l [n}19.13{]}πρόσθεν Ἀχιλλῆος· τὰ δʼ ἀνέβραχε δαίδαλα πάντα.{l]
[l [n}19.14{]}Μυρμιδόνας δʼ ἄρα πάντας ἕλε τρόμος, οὐδέ τις ἔτλη{l]
[l [n}19.15{]}ἄντην εἰσιδέειν, ἀλλʼ ἔτρεσαν. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}19.16{]}ὡς εἶδʼ, ὥς μιν μᾶλλον ἔδυ χόλος, ἐν δέ οἱ ὄσσε{l]
[l [n}19.17{]}δεινὸν ὑπὸ βλεφάρων ὡς εἰ σέλας ἐξεφάανθεν·{l]
[l [n}19.18{]}τέρπετο δʼ ἐν χείρεσσιν ἔχων θεοῦ ἀγλαὰ δῶρα.{l]
[l [n}19.19{]}αὐτὰρ ἐπεὶ φρεσὶν ᾗσι τετάρπετο δαίδαλα λεύσσων{l]
[l [n}19.20{]}αὐτίκα μητέρα ἣν ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}19.21{]}μῆτερ ἐμὴ τὰ μὲν ὅπλα θεὸς πόρεν οἷʼ ἐπιεικὲς{l]
[l [n}19.22{]}ἔργʼ ἔμεν ἀθανάτων, μὴ δὲ βροτὸν ἄνδρα τελέσσαι.{l]
[l [n}19.23{]}νῦν δʼ ἤτοι μὲν ἐγὼ θωρήξομαι· ἀλλὰ μάλʼ αἰνῶς{l]
[l [n}19.24{]}δείδω μή μοι τόφρα Μενοιτίου ἄλκιμον υἱὸν{l]
[l [n}19.25{]}μυῖαι καδδῦσαι κατὰ χαλκοτύπους ὠτειλὰς{l]
[l [n}19.26{]}εὐλὰς ἐγγείνωνται, ἀεικίσσωσι δὲ νεκρόν,{l]
[l [n}19.27{]}ἐκ δʼ αἰὼν πέφαται, κατὰ δὲ χρόα πάντα σαπήῃ.{l]{q]{para]
[para}[l [n}19.28{]}τὸν δʼ ἠμείβετʼ ἔπειτα θεὰ Θέτις ἀργυρόπεζα·{l]
[q}[l [n}19.29{]}τέκνον μή τοι ταῦτα μετὰ φρεσὶ σῇσι μελόντων.{l]
[l [n}19.30{]}τῷ μὲν ἐγὼ πειρήσω ἀλαλκεῖν ἄγρια φῦλα{l]
[l [n}19.31{]}μυίας, αἵ ῥά τε φῶτας ἀρηϊφάτους κατέδουσιν·{l]
[l [n}19.32{]}ἤν περ γὰρ κεῖταί γε τελεσφόρον εἰς ἐνιαυτόν,{l]
[l [n}19.33{]}αἰεὶ τῷ γʼ ἔσται χρὼς ἔμπεδος, ἢ καὶ ἀρείων.{l]
[l [n}19.34{]}ἀλλὰ σύ γʼ εἰς ἀγορὴν καλέσας ἥρωας Ἀχαιοὺς{l]
[l [n}19.35{]}μῆνιν ἀποειπὼν Ἀγαμέμνονι ποιμένι λαῶν{l]
[l [n}19.36{]}αἶψα μάλʼ ἐς πόλεμον θωρήσσεο, δύσεο δʼ ἀλκήν.{l]{q]{para]
[para}[l [n}19.37{]}ὣς ἄρα φωνήσασα μένος πολυθαρσὲς ἐνῆκε,{l]
[l [n}19.38{]}Πατρόκλῳ δʼ αὖτʼ ἀμβροσίην καὶ νέκταρ ἐρυθρὸν{l]
[l [n}19.39{]}στάξε κατὰ ῥινῶν, ἵνα οἱ χρὼς ἔμπεδος εἴη.{l]{para]
[para}[l [n}19.40{]}αὐτὰρ ὃ βῆ παρὰ θῖνα θαλάσσης δῖος Ἀχιλλεὺς{l]
[l [n}19.41{]}σμερδαλέα ἰάχων, ὦρσεν δʼ ἥρωας Ἀχαιούς.{l]
[l [n}19.42{]}καί ῥʼ οἵ περ τὸ πάρος γε νεῶν ἐν ἀγῶνι μένεσκον{l]
[l [n}19.43{]}οἵ τε κυβερνῆται καὶ ἔχον οἰήϊα νηῶν{l]
[l [n}19.44{]}καὶ ταμίαι παρὰ νηυσὶν ἔσαν σίτοιο δοτῆρες,{l]
[l [n}19.45{]}καὶ μὴν οἳ τότε γʼ εἰς ἀγορὴν ἴσαν, οὕνεκʼ Ἀχιλλεὺς{l]
[l [n}19.46{]}ἐξεφάνη, δηρὸν δὲ μάχης ἐπέπαυτʼ ἀλεγεινῆς.{l]
[l [n}19.47{]}τὼ δὲ δύω σκάζοντε βάτην Ἄρεος θεράποντε{l]
[l [n}19.48{]}Τυδεΐδης τε μενεπτόλεμος καὶ δῖος Ὀδυσσεὺς{l]
[l [n}19.49{]}ἔγχει ἐρειδομένω· ἔτι γὰρ ἔχον ἕλκεα λυγρά·{l]
[l [n}19.50{]}κὰδ δὲ μετὰ πρώτῃ ἀγορῇ ἵζοντο κιόντες.{l]
[l [n}19.51{]}αὐτὰρ ὃ δεύτατος ἦλθεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}19.52{]}ἕλκος ἔχων· καὶ γὰρ τὸν ἐνὶ κρατερῇ ὑσμίνῃ{l]
[l [n}19.53{]}οὖτα Κόων Ἀντηνορίδης χαλκήρεϊ δουρί.{l]
[l [n}19.54{]}αὐτὰρ ἐπεὶ δὴ πάντες ἀολλίσθησαν Ἀχαιοί,{l]
[l [n}19.55{]}τοῖσι δʼ ἀνιστάμενος μετέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}19.56{]}Ἀτρεΐδη ἦ ἄρ τι τόδʼ ἀμφοτέροισιν ἄρειον{l]
[l [n}19.57{]}ἔπλετο σοὶ καὶ ἐμοί, ὅ τε νῶΐ περ ἀχνυμένω κῆρ{l]
[l [n}19.58{]}θυμοβόρῳ ἔριδι μενεήναμεν εἵνεκα κούρης;{l]
[l [n}19.59{]}τὴν ὄφελʼ ἐν νήεσσι κατακτάμεν Ἄρτεμις ἰῷ{l]
[l [n}19.60{]}ἤματι τῷ ὅτʼ ἐγὼν ἑλόμην Λυρνησσὸν ὀλέσσας·{l]
[l [n}19.61{]}τώ κʼ οὐ τόσσοι Ἀχαιοὶ ὀδὰξ ἕλον ἄσπετον οὖδας{l]
[l [n}19.62{]}δυσμενέων ὑπὸ χερσὶν ἐμεῦ ἀπομηνίσαντος.{l]
[l [n}19.63{]}Ἕκτορι μὲν καὶ Τρωσὶ τὸ κέρδιον· αὐτὰρ Ἀχαιοὺς{l]
[l [n}19.64{]}δηρὸν ἐμῆς καὶ σῆς ἔριδος μνήσεσθαι ὀΐω.{l]
[l [n}19.65{]}ἀλλὰ τὰ μὲν προτετύχθαι ἐάσομεν ἀχνύμενοί περ{l]
[l [n}19.66{]}θυμὸν ἐνὶ στήθεσσι φίλον δαμάσαντες ἀνάγκῃ·{l]
[l [n}19.67{]}νῦν δʼ ἤτοι μὲν ἐγὼ παύω χόλον, οὐδέ τί με χρὴ{l]
[l [n}19.68{]}ἀσκελέως αἰεὶ μενεαινέμεν· ἀλλʼ ἄγε θᾶσσον{l]
[l [n}19.69{]}ὄτρυνον πόλεμον δὲ κάρη κομόωντας Ἀχαιούς,{l]
[l [n}19.70{]}ὄφρʼ ἔτι καὶ Τρώων πειρήσομαι ἀντίον ἐλθὼν{l]
[l [n}19.71{]}αἴ κʼ ἐθέλωσʼ ἐπὶ νηυσὶν ἰαύειν· ἀλλά τινʼ οἴω{l]
[l [n}19.72{]}ἀσπασίως αὐτῶν γόνυ κάμψειν, ὅς κε φύγῃσι{l]
[l [n}19.73{]}δηΐου ἐκ πολέμοιο ὑπʼ ἔγχεος ἡμετέροιο.{l]{q]{para]
[para}[l [n}19.74{]}ὣς ἔφαθʼ, οἳ δʼ ἐχάρησαν ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}19.75{]}μῆνιν ἀπειπόντος μεγαθύμου Πηλεΐωνος.{l]
[l [n}19.76{]}τοῖσι δὲ καὶ μετέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}19.77{]}αὐτόθεν ἐξ ἕδρης, οὐδʼ ἐν μέσσοισιν ἀναστάς·{l]
[q}[l [n}19.78{]}ὦ φίλοι ἥρωες Δαναοὶ θεράποντες Ἄρηος{l]
[l [n}19.79{]}ἑσταότος μὲν καλὸν ἀκούειν, οὐδὲ ἔοικεν{l]
[l [n}19.80{]}ὑββάλλειν· χαλεπὸν γὰρ ἐπισταμένῳ περ ἐόντι.{l]
[l [n}19.81{]}ἀνδρῶν δʼ ἐν πολλῷ ὁμάδῳ πῶς κέν τις ἀκούσαι{l]
[l [n}19.82{]}ἢ εἴποι; βλάβεται δὲ λιγύς περ ἐὼν ἀγορητής.{l]
[l [n}19.83{]}Πηλεΐδῃ μὲν ἐγὼν ἐνδείξομαι· αὐτὰρ οἱ ἄλλοι{l]
[l [n}19.84{]}σύνθεσθʼ Ἀργεῖοι, μῦθόν τʼ εὖ γνῶτε ἕκαστος.{l]
[l [n}19.85{]}πολλάκι δή μοι τοῦτον Ἀχαιοὶ μῦθον ἔειπον{l]
[l [n}19.86{]}καί τέ με νεικείεσκον· ἐγὼ δʼ οὐκ αἴτιός εἰμι,{l]
[l [n}19.87{]}ἀλλὰ Ζεὺς καὶ Μοῖρα καὶ ἠεροφοῖτις Ἐρινύς,{l]
[l [n}19.88{]}οἵ τέ μοι εἰν ἀγορῇ φρεσὶν ἔμβαλον ἄγριον ἄτην,{l]
[l [n}19.89{]}ἤματι τῷ ὅτʼ Ἀχιλλῆος γέρας αὐτὸς ἀπηύρων.{l]
[l [n}19.90{]}ἀλλὰ τί κεν ῥέξαιμι; θεὸς διὰ πάντα τελευτᾷ.{l]
[l [n}19.91{]}πρέσβα Διὸς θυγάτηρ Ἄτη, ἣ πάντας ἀᾶται,{l]
[l [n}19.92{]}οὐλομένη· τῇ μέν θʼ ἁπαλοὶ πόδες· οὐ γὰρ ἐπʼ οὔδει{l]
[l [n}19.93{]}πίλναται, ἀλλʼ ἄρα ἥ γε κατʼ ἀνδρῶν κράατα βαίνει{l]
[l [n}19.94{]}βλάπτουσʼ ἀνθρώπους· κατὰ δʼ οὖν ἕτερόν γε πέδησε.{l]
[l [n}19.95{]}καὶ γὰρ δή νύ ποτε Ζεὺς ἄσατο, τόν περ ἄριστον{l]
[l [n}19.96{]}ἀνδρῶν ἠδὲ θεῶν φασʼ ἔμμεναι· ἀλλʼ ἄρα καὶ τὸν{l]
[l [n}19.97{]}Ἥρη θῆλυς ἐοῦσα δολοφροσύνῃς ἀπάτησεν,{l]
[l [n}19.98{]}ἤματι τῷ ὅτʼ ἔμελλε βίην Ἡρακληείην{l]
[l [n}19.99{]}Ἀλκμήνη τέξεσθαι ἐϋστεφάνῳ ἐνὶ Θήβῃ.{l]
[l [n}19.100{]}ἤτοι ὅ γʼ εὐχόμενος μετέφη πάντεσσι θεοῖσι·{l]
[q}[l [n}19.101{]}κέκλυτέ μευ πάντές τε θεοὶ πᾶσαί τε θέαιναι,{l]
[l [n}19.102{]}ὄφρʼ εἴπω τά με θυμὸς ἐνὶ στήθεσσιν ἀνώγει.{l]
[l [n}19.103{]}σήμερον ἄνδρα φόως δὲ μογοστόκος Εἰλείθυια{l]
[l [n}19.104{]}ἐκφανεῖ, ὃς πάντεσσι περικτιόνεσσιν ἀνάξει,{l]
[l [n}19.105{]}τῶν ἀνδρῶν γενεῆς οἵ θʼ αἵματος ἐξ ἐμεῦ εἰσί.{l]{q][l [n}19.106{]}τὸν δὲ δολοφρονέουσα προσηύδα πότνια Ἥρη·{l]
[q}[l [n}19.107{]}ψευστήσεις, οὐδʼ αὖτε τέλος μύθῳ ἐπιθήσεις.{l]
[l [n}19.108{]}εἰ δʼ ἄγε νῦν μοι ὄμοσσον Ὀλύμπιε καρτερὸν ὅρκον,{l]
[l [n}19.109{]}ἦ μὲν τὸν πάντεσσι περικτιόνεσσιν ἀνάξειν{l]
[l [n}19.110{]}ὅς κεν ἐπʼ ἤματι τῷδε πέσῃ μετὰ ποσσὶ γυναικὸς{l]
[l [n}19.111{]}τῶν ἀνδρῶν οἳ σῆς ἐξ αἵματός εἰσι γενέθλης.{l]{q][l [n}19.112{]}ὣς ἔφατο· Ζεὺς δʼ οὔ τι δολοφροσύνην ἐνόησεν,{l]
[l [n}19.113{]}ἀλλʼ ὄμοσεν μέγαν ὅρκον, ἔπειτα δὲ πολλὸν ἀάσθη.{l]
[l [n}19.114{]}Ἥρη δʼ ἀΐξασα λίπεν ῥίον Οὐλύμποιο,{l]
[l [n}19.115{]}καρπαλίμως δʼ ἵκετʼ Ἄργος Ἀχαιικόν, ἔνθʼ ἄρα ᾔδη{l]
[l [n}19.116{]}ἰφθίμην ἄλοχον Σθενέλου Περσηϊάδαο.{l]
[l [n}19.117{]}ἣ δʼ ἐκύει φίλον υἱόν, ὃ δʼ ἕβδομος ἑστήκει μείς·{l]
[l [n}19.118{]}ἐκ δʼ ἄγαγε πρὸ φόως δὲ καὶ ἠλιτόμηνον ἐόντα,{l]
[l [n}19.119{]}Ἀλκμήνης δʼ ἀπέπαυσε τόκον, σχέθε δʼ Εἰλειθυίας.{l]
[l [n}19.120{]}αὐτὴ δʼ ἀγγελέουσα Δία Κρονίωνα προσηύδα·{l]
[q}[l [n}19.121{]}Ζεῦ πάτερ ἀργικέραυνε ἔπος τί τοι ἐν φρεσὶ θήσω·{l]
[l [n}19.122{]}ἤδη ἀνὴρ γέγονʼ ἐσθλὸς ὃς Ἀργείοισιν ἀνάξει{l]
[l [n}19.123{]}Εὐρυσθεὺς Σθενέλοιο πάϊς Περσηϊάδαο{l]
[l [n}19.124{]}σὸν γένος· οὔ οἱ ἀεικὲς ἀνασσέμεν Ἀργείοισιν.{l]{q][l [n}19.125{]}ὣς φάτο, τὸν δʼ ἄχος ὀξὺ κατὰ φρένα τύψε βαθεῖαν·{l]
[l [n}19.126{]}αὐτίκα δʼ εἷλʼ Ἄτην κεφαλῆς λιπαροπλοκάμοιο{l]
[l [n}19.127{]}χωόμενος φρεσὶν ᾗσι, καὶ ὤμοσε καρτερὸν ὅρκον{l]
[l [n}19.128{]}μή ποτʼ ἐς Οὔλυμπόν τε καὶ οὐρανὸν ἀστερόεντα{l]
[l [n}19.129{]}αὖτις ἐλεύσεσθαι Ἄτην, ἣ πάντας ἀᾶται.{l]
[l [n}19.130{]}ὣς εἰπὼν ἔρριψεν ἀπʼ οὐρανοῦ ἀστερόεντος{l]
[l [n}19.131{]}χειρὶ περιστρέψας· τάχα δʼ ἵκετο ἔργʼ ἀνθρώπων.{l]
[l [n}19.132{]}τὴν αἰεὶ στενάχεσχʼ ὅθʼ ἑὸν φίλον υἱὸν ὁρῷτο{l]
[l [n}19.133{]}ἔργον ἀεικὲς ἔχοντα ὑπʼ Εὐρυσθῆος ἀέθλων.{l]
[l [n}19.134{]}ὣς καὶ ἐγών, ὅτε δʼ αὖτε μέγας κορυθαίολος Ἕκτωρ{l]
[l [n}19.135{]}Ἀργείους ὀλέκεσκεν ἐπὶ πρυμνῇσι νέεσσιν,{l]
[l [n}19.136{]}οὐ δυνάμην λελαθέσθʼ Ἄτης ᾗ πρῶτον ἀάσθην.{l]
[l [n}19.137{]}ἀλλʼ ἐπεὶ ἀασάμην καί μευ φρένας ἐξέλετο Ζεύς,{l]
[l [n}19.138{]}ἂψ ἐθέλω ἀρέσαι, δόμεναί τʼ ἀπερείσιʼ ἄποινα·{l]
[l [n}19.139{]}ἀλλʼ ὄρσευ πόλεμον δὲ καὶ ἄλλους ὄρνυθι λαούς.{l]
[l [n}19.140{]}δῶρα δʼ ἐγὼν ὅδε πάντα παρασχέμεν ὅσσά τοι ἐλθὼν{l]
[l [n}19.141{]}χθιζὸς ἐνὶ κλισίῃσιν ὑπέσχετο δῖος Ὀδυσσεύς.{l]
[l [n}19.142{]}εἰ δʼ ἐθέλεις, ἐπίμεινον ἐπειγόμενός περ Ἄρηος,{l]
[l [n}19.143{]}δῶρα δέ τοι θεράποντες ἐμῆς παρὰ νηὸς ἑλόντες{l]
[l [n}19.144{]}οἴσουσʼ, ὄφρα ἴδηαι ὅ τοι μενοεικέα δώσω.{l]{q]{para]
[para}[l [n}19.145{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}19.146{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}19.147{]}δῶρα μὲν αἴ κʼ ἐθέλῃσθα παρασχέμεν, ὡς ἐπιεικές,{l]
[l [n}19.148{]}ἤ τʼ ἐχέμεν παρὰ σοί· νῦν δὲ μνησώμεθα χάρμης{l]
[l [n}19.149{]}αἶψα μάλʼ· οὐ γὰρ χρὴ κλοτοπεύειν ἐνθάδʼ ἐόντας{l]
[l [n}19.150{]}οὐδὲ διατρίβειν· ἔτι γὰρ μέγα ἔργον ἄρεκτον·{l]
[l [n}19.151{]}ὥς κέ τις αὖτʼ Ἀχιλῆα μετὰ πρώτοισιν ἴδηται{l]
[l [n}19.152{]}ἔγχεϊ χαλκείῳ Τρώων ὀλέκοντα φάλαγγας.{l]
[l [n}19.153{]}ὧδέ τις ὑμείων μεμνημένος ἀνδρὶ μαχέσθω.{l]{q]{para]
[para}[l [n}19.154{]}τὸν δʼ ἀπαμειβόμενος προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}19.155{]}μὴ δʼ οὕτως, ἀγαθός περ ἐών, θεοείκελʼ Ἀχιλλεῦ{l]
[l [n}19.156{]}νήστιας ὄτρυνε προτὶ Ἴλιον υἷας Ἀχαιῶν{l]
[l [n}19.157{]}Τρωσὶ μαχησομένους, ἐπεὶ οὐκ ὀλίγον χρόνον ἔσται{l]
[l [n}19.158{]}φύλοπις, εὖτʼ ἂν πρῶτον ὁμιλήσωσι φάλαγγες{l]
[l [n}19.159{]}ἀνδρῶν, ἐν δὲ θεὸς πνεύσῃ μένος ἀμφοτέροισιν.{l]
[l [n}19.160{]}ἀλλὰ πάσασθαι ἄνωχθι θοῇς ἐπὶ νηυσὶν Ἀχαιοὺς{l]
[l [n}19.161{]}σίτου καὶ οἴνοιο· τὸ γὰρ μένος ἐστὶ καὶ ἀλκή.{l]
[l [n}19.162{]}οὐ γὰρ ἀνὴρ πρόπαν ἦμαρ ἐς ἠέλιον καταδύντα{l]
[l [n}19.163{]}ἄκμηνος σίτοιο δυνήσεται ἄντα μάχεσθαι·{l]
[l [n}19.164{]}εἴ περ γὰρ θυμῷ γε μενοινάᾳ πολεμίζειν,{l]
[l [n}19.165{]}ἀλλά τε λάθρῃ γυῖα βαρύνεται, ἠδὲ κιχάνει{l]
[l [n}19.166{]}δίψά τε καὶ λιμός, βλάβεται δέ τε γούνατʼ ἰόντι.{l]
[l [n}19.167{]}ὃς δέ κʼ ἀνὴρ οἴνοιο κορεσσάμενος καὶ ἐδωδῆς{l]
[l [n}19.168{]}ἀνδράσι δυσμενέεσσι πανημέριος πολεμίζῃ,{l]
[l [n}19.169{]}θαρσαλέον νύ οἱ ἦτορ ἐνὶ φρεσίν, οὐδέ τι γυῖα{l]
[l [n}19.170{]}πρὶν κάμνει πρὶν πάντας ἐρωῆσαι πολέμοιο.{l]
[l [n}19.171{]}ἀλλʼ ἄγε λαὸν μὲν σκέδασον καὶ δεῖπνον ἄνωχθι{l]
[l [n}19.172{]}ὅπλεσθαι· τὰ δὲ δῶρα ἄναξ ἀνδρῶν Ἀγαμέμνων{l]
[l [n}19.173{]}οἰσέτω ἐς μέσσην ἀγορήν, ἵνα πάντες Ἀχαιοὶ{l]
[l [n}19.174{]}ὀφθαλμοῖσιν ἴδωσι, σὺ δὲ φρεσὶ σῇσιν ἰανθῇς.{l]
[l [n}19.175{]}ὀμνυέτω δέ τοι ὅρκον ἐν Ἀργείοισιν ἀναστὰς{l]
[l [n}19.176{]}μή ποτε τῆς εὐνῆς ἐπιβήμεναι ἠδὲ μιγῆναι·{l]
[l [n}19.177{]}ἣ θέμις ἐστὶν ἄναξ ἤ τʼ ἀνδρῶν ἤ τε γυναικῶν·{l]
[l [n}19.178{]}καὶ δὲ σοὶ αὐτῷ θυμὸς ἐνὶ φρεσὶν ἵλαος ἔστω.{l]
[l [n}19.179{]}αὐτὰρ ἔπειτά σε δαιτὶ ἐνὶ κλισίῃς ἀρεσάσθω{l]
[l [n}19.180{]}πιείρῃ, ἵνα μή τι δίκης ἐπιδευὲς ἔχῃσθα.{l]
[l [n}19.181{]}Ἀτρεΐδη σὺ δʼ ἔπειτα δικαιότερος καὶ ἐπʼ ἄλλῳ{l]
[l [n}19.182{]}ἔσσεαι. οὐ μὲν γάρ τι νεμεσσητὸν βασιλῆα{l]
[l [n}19.183{]}ἄνδρʼ ἀπαρέσσασθαι ὅτε τις πρότερος χαλεπήνῃ.{l]{q]{para]
[para}[l [n}19.184{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[q}[l [n}19.185{]}χαίρω σεῦ Λαερτιάδη τὸν μῦθον ἀκούσας·{l]
[l [n}19.186{]}ἐν μοίρῃ γὰρ πάντα διίκεο καὶ κατέλεξας.{l]
[l [n}19.187{]}ταῦτα δʼ ἐγὼν ἐθέλω ὀμόσαι, κέλεται δέ με θυμός,{l]
[l [n}19.188{]}οὐδʼ ἐπιορκήσω πρὸς δαίμονος. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}19.189{]}μιμνέτω αὐτόθι τεῖος ἐπειγόμενός περ Ἄρηος·{l]
[l [n}19.190{]}μίμνετε δʼ ἄλλοι πάντες ἀολλέες, ὄφρά κε δῶρα{l]
[l [n}19.191{]}ἐκ κλισίης ἔλθῃσι καὶ ὅρκια πιστὰ τάμωμεν.{l]
[l [n}19.192{]}σοὶ δʼ αὐτῷ τόδʼ ἐγὼν ἐπιτέλλομαι ἠδὲ κελεύω·{l]
[l [n}19.193{]}κρινάμενος κούρητας ἀριστῆας Παναχαιῶν{l]
[l [n}19.194{]}δῶρα ἐμῆς παρὰ νηὸς ἐνεικέμεν, ὅσσʼ Ἀχιλῆϊ{l]
[l [n}19.195{]}χθιζὸν ὑπέστημεν δώσειν, ἀγέμεν τε γυναῖκας.{l]
[l [n}19.196{]}Ταλθύβιος δέ μοι ὦκα κατὰ στρατὸν εὐρὺν Ἀχαιῶν{l]
[l [n}19.197{]}κάπρον ἑτοιμασάτω ταμέειν Διί τʼ Ἠελίῳ τε.{l]{q]{para]
[para}[l [n}19.198{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}19.199{]}Ἀτρεΐδη κύδιστε ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}19.200{]}ἄλλοτέ περ καὶ μᾶλλον ὀφέλλετε ταῦτα πένεσθαι,{l]
[l [n}19.201{]}ὁππότε τις μεταπαυσωλὴ πολέμοιο γένηται{l]
[l [n}19.202{]}καὶ μένος οὐ τόσον ᾖσιν ἐνὶ στήθεσσιν ἐμοῖσι.{l]
[l [n}19.203{]}νῦν δʼ οἳ μὲν κέαται δεδαϊγμένοι, οὓς ἐδάμασσεν{l]
[l [n}19.204{]}Ἕκτωρ Πριαμίδης, ὅτε οἱ Ζεὺς κῦδος ἔδωκεν,{l]
[l [n}19.205{]}ὑμεῖς δʼ ἐς βρωτὺν ὀτρύνετον· ἦ τʼ ἂν ἔγωγε{l]
[l [n}19.206{]}νῦν μὲν ἀνώγοιμι πτολεμίζειν υἷας Ἀχαιῶν{l]
[l [n}19.207{]}νήστιας ἀκμήνους, ἅμα δʼ ἠελίῳ καταδύντι{l]
[l [n}19.208{]}τεύξεσθαι μέγα δόρπον, ἐπὴν τεισαίμεθα λώβην.{l]
[l [n}19.209{]}πρὶν δʼ οὔ πως ἂν ἔμοιγε φίλον κατὰ λαιμὸν ἰείη{l]
[l [n}19.210{]}οὐ πόσις οὐδὲ βρῶσις ἑταίρου τεθνηῶτος{l]
[l [n}19.211{]}ὅς μοι ἐνὶ κλισίῃ δεδαϊγμένος ὀξέϊ χαλκῷ{l]
[l [n}19.212{]}κεῖται ἀνὰ πρόθυρον τετραμμένος, ἀμφὶ δʼ ἑταῖροι{l]
[l [n}19.213{]}μύρονται· τό μοι οὔ τι μετὰ φρεσὶ ταῦτα μέμηλεν,{l]
[l [n}19.214{]}ἀλλὰ φόνος τε καὶ αἷμα καὶ ἀργαλέος στόνος ἀνδρῶν.{l]{q]{para]
[para}[l [n}19.215{]}τὸν δʼ ἀπαμειβόμενος προσέφη πολύμητις Ὀδυσσεύς·{l]
[q}[l [n}19.216{]}ὦ Ἀχιλεῦ Πηλῆος υἱὲ μέγα φέρτατʼ Ἀχαιῶν,{l]
[l [n}19.217{]}κρείσσων εἰς ἐμέθεν καὶ φέρτερος οὐκ ὀλίγον περ{l]
[l [n}19.218{]}ἔγχει, ἐγὼ δέ κε σεῖο νοήματί γε προβαλοίμην{l]
[l [n}19.219{]}πολλόν, ἐπεὶ πρότερος γενόμην καὶ πλείονα οἶδα.{l]
[l [n}19.220{]}τώ τοι ἐπιτλήτω κραδίη μύθοισιν ἐμοῖσιν.{l]
[l [n}19.221{]}αἶψά τε φυλόπιδος πέλεται κόρος ἀνθρώποισιν,{l]
[l [n}19.222{]}ἧς τε πλείστην μὲν καλάμην χθονὶ χαλκὸς ἔχευεν,{l]
[l [n}19.223{]}ἄμητος δʼ ὀλίγιστος, ἐπὴν κλίνῃσι τάλαντα{l]
[l [n}19.224{]}Ζεύς, ὅς τʼ ἀνθρώπων ταμίης πολέμοιο τέτυκται.{l]
[l [n}19.225{]}γαστέρι δʼ οὔ πως ἔστι νέκυν πενθῆσαι Ἀχαιούς·{l]
[l [n}19.226{]}λίην γὰρ πολλοὶ καὶ ἐπήτριμοι ἤματα πάντα{l]
[l [n}19.227{]}πίπτουσιν· πότε κέν τις ἀναπνεύσειε πόνοιο;{l]
[l [n}19.228{]}ἀλλὰ χρὴ τὸν μὲν καταθάπτειν ὅς κε θάνῃσι{l]
[l [n}19.229{]}νηλέα θυμὸν ἔχοντας ἐπʼ ἤματι δακρύσαντας·{l]
[l [n}19.230{]}ὅσσοι δʼ ἂν πολέμοιο περὶ στυγεροῖο λίπωνται{l]
[l [n}19.231{]}μεμνῆσθαι πόσιος καὶ ἐδητύος, ὄφρʼ ἔτι μᾶλλον{l]
[l [n}19.232{]}ἀνδράσι δυσμενέεσσι μαχώμεθα νωλεμὲς αἰεὶ{l]
[l [n}19.233{]}ἑσσάμενοι χροῒ χαλκὸν ἀτειρέα. μηδέ τις ἄλλην{l]
[l [n}19.234{]}λαῶν ὀτρυντὺν ποτιδέγμενος ἰσχαναάσθω·{l]
[l [n}19.235{]}ἥδε γὰρ ὀτρυντὺς κακὸν ἔσσεται ὅς κε λίπηται{l]
[l [n}19.236{]}νηυσὶν ἐπʼ Ἀργείων· ἀλλʼ ἀθρόοι ὁρμηθέντες{l]
[l [n}19.237{]}Τρωσὶν ἐφʼ ἱπποδάμοισιν ἐγείρομεν ὀξὺν Ἄρηα.{l]{q]{para]
[para}[l [n}19.238{]}ἦ, καὶ Νέστορος υἷας ὀπάσσατο κυδαλίμοιο{l]
[l [n}19.239{]}Φυλεΐδην τε Μέγητα Θόαντά τε Μηριόνην τε{l]
[l [n}19.240{]}καὶ Κρειοντιάδην Λυκομήδεα καὶ Μελάνιππον·{l]
[l [n}19.241{]}βὰν δʼ ἴμεν ἐς κλισίην Ἀγαμέμνονος Ἀτρεΐδαο.{l]
[l [n}19.242{]}αὐτίκʼ ἔπειθʼ ἅμα μῦθος ἔην, τετέλεστο δὲ ἔργον·{l]
[l [n}19.243{]}ἑπτὰ μὲν ἐκ κλισίης τρίποδας φέρον, οὕς οἱ ὑπέστη,{l]
[l [n}19.244{]}αἴθωνας δὲ λέβητας ἐείκοσι, δώδεκα δʼ ἵππους·{l]
[l [n}19.245{]}ἐκ δʼ ἄγον αἶψα γυναῖκας ἀμύμονα ἔργα ἰδυίας{l]
[l [n}19.246{]}ἕπτʼ, ἀτὰρ ὀγδοάτην Βρισηΐδα καλλιπάρῃον.{l]
[l [n}19.247{]}χρυσοῦ δὲ στήσας Ὀδυσεὺς δέκα πάντα τάλαντα{l]
[l [n}19.248{]}ἦρχʼ, ἅμα δʼ ἄλλοι δῶρα φέρον κούρητες Ἀχαιῶν.{l]
[l [n}19.249{]}καὶ τὰ μὲν ἐν μέσσῃ ἀγορῇ θέσαν, ἂν δʼ Ἀγαμέμνων{l]
[l [n}19.250{]}ἵστατο· Ταλθύβιος δὲ θεῷ ἐναλίγκιος αὐδὴν{l]
[l [n}19.251{]}κάπρον ἔχων ἐν χερσὶ παρίστατο ποιμένι λαῶν.{l]
[l [n}19.252{]}Ἀτρεΐδης δὲ ἐρυσσάμενος χείρεσσι μάχαιραν,{l]
[l [n}19.253{]}ἥ οἱ πὰρ ξίφεος μέγα κουλεὸν αἰὲν ἄωρτο,{l]
[l [n}19.254{]}κάπρου ἀπὸ τρίχας ἀρξάμενος Διὶ χεῖρας ἀνασχὼν{l]
[l [n}19.255{]}εὔχετο· τοὶ δʼ ἄρα πάντες ἐπʼ αὐτόφιν εἵατο σιγῇ{l]
[l [n}19.256{]}Ἀργεῖοι κατὰ μοῖραν ἀκούοντες βασιλῆος.{l]
[l [n}19.257{]}εὐξάμενος δʼ ἄρα εἶπεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}19.258{]}ἴστω νῦν Ζεὺς πρῶτα θεῶν ὕπατος καὶ ἄριστος{l]
[l [n}19.259{]}Γῆ τε καὶ Ἠέλιος καὶ Ἐρινύες, αἵ θʼ ὑπὸ γαῖαν{l]
[l [n}19.260{]}ἀνθρώπους τίνυνται, ὅτις κʼ ἐπίορκον ὀμόσσῃ,{l]
[l [n}19.261{]}μὴ μὲν ἐγὼ κούρῃ Βρισηΐδι χεῖρʼ ἐπένεικα,{l]
[l [n}19.262{]}οὔτʼ εὐνῆς πρόφασιν κεχρημένος οὔτέ τευ ἄλλου.{l]
[l [n}19.263{]}ἀλλʼ ἔμενʼ ἀπροτίμαστος ἐνὶ κλισίῃσιν ἐμῇσιν.{l]
[l [n}19.264{]}εἰ δέ τι τῶνδʼ ἐπίορκον ἐμοὶ θεοὶ ἄλγεα δοῖεν{l]
[l [n}19.265{]}πολλὰ μάλʼ, ὅσσα διδοῦσιν ὅτίς σφʼ ἀλίτηται ὀμόσσας.{l]{q]{para]
[para}[l [n}19.266{]}ἦ, καὶ ἀπὸ στόμαχον κάπρου τάμε νηλέϊ χαλκῷ.{l]
[l [n}19.267{]}τὸν μὲν Ταλθύβιος πολιῆς ἁλὸς ἐς μέγα λαῖτμα{l]
[l [n}19.268{]}ῥῖψʼ ἐπιδινήσας βόσιν ἰχθύσιν· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}19.269{]}ἀνστὰς Ἀργείοισι φιλοπτολέμοισι μετηύδα·{l]
[q}[l [n}19.270{]}Ζεῦ πάτερ ἦ μεγάλας ἄτας ἄνδρεσσι διδοῖσθα·{l]
[l [n}19.271{]}οὐκ ἂν δή ποτε θυμὸν ἐνὶ στήθεσσιν ἐμοῖσιν{l]
[l [n}19.272{]}Ἀτρεΐδης ὤρινε διαμπερές, οὐδέ κε κούρην{l]
[l [n}19.273{]}ἦγεν ἐμεῦ ἀέκοντος ἀμήχανος· ἀλλά ποθι Ζεὺς{l]
[l [n}19.274{]}ἤθελʼ Ἀχαιοῖσιν θάνατον πολέεσσι γενέσθαι.{l]
[l [n}19.275{]}νῦν δʼ ἔρχεσθʼ ἐπὶ δεῖπνον, ἵνα ξυνάγωμεν Ἄρηα.{l]{q]{para]
[para}[l [n}19.276{]}ὣς ἄρʼ ἐφώνησεν, λῦσεν δʼ ἀγορὴν αἰψηρήν.{l]
[l [n}19.277{]}οἳ μὲν ἄρʼ ἐσκίδναντο ἑὴν ἐπὶ νῆα ἕκαστος,{l]
[l [n}19.278{]}δῶρα δὲ Μυρμιδόνες μεγαλήτορες ἀμφεπένοντο,{l]
[l [n}19.279{]}βὰν δʼ ἐπὶ νῆα φέροντες Ἀχιλλῆος θείοιο.{l]
[l [n}19.280{]}καὶ τὰ μὲν ἐν κλισίῃσι θέσαν, κάθισαν δὲ γυναῖκας,{l]
[l [n}19.281{]}ἵππους δʼ εἰς ἀγέλην ἔλασαν θεράποντες ἀγαυοί.{l]{para]
[para}[l [n}19.282{]}Βρισηῒς δʼ ἄρʼ ἔπειτʼ ἰκέλη χρυσέῃ Ἀφροδίτῃ{l]
[l [n}19.283{]}ὡς ἴδε Πάτροκλον δεδαϊγμένον ὀξέϊ χαλκῷ,{l]
[l [n}19.284{]}ἀμφʼ αὐτῷ χυμένη λίγʼ ἐκώκυε, χερσὶ δʼ ἄμυσσε{l]
[l [n}19.285{]}στήθεά τʼ ἠδʼ ἁπαλὴν δειρὴν ἰδὲ καλὰ πρόσωπα.{l]
[l [n}19.286{]}εἶπε δʼ ἄρα κλαίουσα γυνὴ ἐϊκυῖα θεῇσι·{l]
[q}[l [n}19.287{]}Πάτροκλέ μοι δειλῇ πλεῖστον κεχαρισμένε θυμῷ{l]
[l [n}19.288{]}ζωὸν μέν σε ἔλειπον ἐγὼ κλισίηθεν ἰοῦσα,{l]
[l [n}19.289{]}νῦν δέ σε τεθνηῶτα κιχάνομαι ὄρχαμε λαῶν{l]
[l [n}19.290{]}ἂψ ἀνιοῦσʼ· ὥς μοι δέχεται κακὸν ἐκ κακοῦ αἰεί.{l]
[l [n}19.291{]}ἄνδρα μὲν ᾧ ἔδοσάν με πατὴρ καὶ πότνια μήτηρ{l]
[l [n}19.292{]}εἶδον πρὸ πτόλιος δεδαϊγμένον ὀξέϊ χαλκῷ,{l]
[l [n}19.293{]}τρεῖς τε κασιγνήτους, τούς μοι μία γείνατο μήτηρ,{l]
[l [n}19.294{]}κηδείους, οἳ πάντες ὀλέθριον ἦμαρ ἐπέσπον.{l]
[l [n}19.295{]}οὐδὲ μὲν οὐδέ μʼ ἔασκες, ὅτʼ ἄνδρʼ ἐμὸν ὠκὺς Ἀχιλλεὺς{l]
[l [n}19.296{]}ἔκτεινεν, πέρσεν δὲ πόλιν θείοιο Μύνητος,{l]
[l [n}19.297{]}κλαίειν, ἀλλά μʼ ἔφασκες Ἀχιλλῆος θείοιο{l]
[l [n}19.298{]}κουριδίην ἄλοχον θήσειν, ἄξειν τʼ ἐνὶ νηυσὶν{l]
[l [n}19.299{]}ἐς Φθίην, δαίσειν δὲ γάμον μετὰ Μυρμιδόνεσσι.{l]
[l [n}19.300{]}τώ σʼ ἄμοτον κλαίω τεθνηότα μείλιχον αἰεί.{l]{q]{para]
[para}[l [n}19.301{]}ὣς ἔφατο κλαίουσʼ, ἐπὶ δὲ στενάχοντο γυναῖκες{l]
[l [n}19.302{]}Πάτροκλον πρόφασιν, σφῶν δʼ αὐτῶν κήδεʼ ἑκάστη.{l]
[l [n}19.303{]}αὐτὸν δʼ ἀμφὶ γέροντες Ἀχαιῶν ἠγερέθοντο{l]
[l [n}19.304{]}λισσόμενοι δειπνῆσαι· ὃ δʼ ἠρνεῖτο στεναχίζων·{l]
[q}[l [n}19.305{]}λίσσομαι, εἴ τις ἔμοιγε φίλων ἐπιπείθεθʼ ἑταίρων,{l]
[l [n}19.306{]}μή με πρὶν σίτοιο κελεύετε μηδὲ ποτῆτος{l]
[l [n}19.307{]}ἄσασθαι φίλον ἦτορ, ἐπεί μʼ ἄχος αἰνὸν ἱκάνει·{l]
[l [n}19.308{]}δύντα δʼ ἐς ἠέλιον μενέω καὶ τλήσομαι ἔμπης.{l]{q]{para]
[para}[l [n}19.309{]}ὣς εἰπὼν ἄλλους μὲν ἀπεσκέδασεν βασιλῆας,{l]
[l [n}19.310{]}δοιὼ δʼ Ἀτρεΐδα μενέτην καὶ δῖος Ὀδυσσεὺς{l]
[l [n}19.311{]}Νέστωρ Ἰδομενεύς τε γέρων θʼ ἱππηλάτα Φοῖνιξ{l]
[l [n}19.312{]}τέρποντες πυκινῶς ἀκαχήμενον· οὐδέ τι θυμῷ{l]
[l [n}19.313{]}τέρπετο, πρὶν πολέμου στόμα δύμεναι αἱματόεντος.{l]
[l [n}19.314{]}μνησάμενος δʼ ἁδινῶς ἀνενείκατο φώνησέν τε·{l]
[q}[l [n}19.315{]}ἦ ῥά νύ μοί ποτε καὶ σὺ δυσάμμορε φίλταθʼ ἑταίρων{l]
[l [n}19.316{]}αὐτὸς ἐνὶ κλισίῃ λαρὸν παρὰ δεῖπνον ἔθηκας{l]
[l [n}19.317{]}αἶψα καὶ ὀτραλέως, ὁπότε σπερχοίατʼ Ἀχαιοὶ{l]
[l [n}19.318{]}Τρωσὶν ἐφʼ ἱπποδάμοισι φέρειν πολύδακρυν Ἄρηα.{l]
[l [n}19.319{]}νῦν δὲ σὺ μὲν κεῖσαι δεδαϊγμένος, αὐτὰρ ἐμὸν κῆρ{l]
[l [n}19.320{]}ἄκμηνον πόσιος καὶ ἐδητύος, ἔνδον ἐόντων,{l]
[l [n}19.321{]}σῇ ποθῇ· οὐ μὲν γάρ τι κακώτερον ἄλλο πάθοιμι,{l]
[l [n}19.322{]}οὐδʼ εἴ κεν τοῦ πατρὸς ἀποφθιμένοιο πυθοίμην,{l]
[l [n}19.323{]}ὅς που νῦν Φθίηφι τέρεν κατὰ δάκρυον εἴβει{l]
[l [n}19.324{]}χήτεϊ τοιοῦδʼ υἷος· ὃ δʼ ἀλλοδαπῷ ἐνὶ δήμῳ{l]
[l [n}19.325{]}εἵνεκα ῥιγεδανῆς Ἑλένης Τρωσὶν πολεμίζω·{l]
[l [n}19.326{]}ἠὲ τὸν ὃς Σκύρῳ μοι ἔνι τρέφεται φίλος υἱός,{l]
[l [n}19.327{]}εἴ που ἔτι ζώει γε Νεοπτόλεμος θεοειδής.{l]
[l [n}19.328{]}πρὶν μὲν γάρ μοι θυμὸς ἐνὶ στήθεσσιν ἐώλπει{l]
[l [n}19.329{]}οἶον ἐμὲ φθίσεσθαι ἀπʼ Ἄργεος ἱπποβότοιο{l]
[l [n}19.330{]}αὐτοῦ ἐνὶ Τροίῃ, σὲ δέ τε Φθίην δὲ νέεσθαι,{l]
[l [n}19.331{]}ὡς ἄν μοι τὸν παῖδα θοῇ ἐνὶ νηῒ μελαίνῃ{l]
[l [n}19.332{]}Σκυρόθεν ἐξαγάγοις καί οἱ δείξειας ἕκαστα{l]
[l [n}19.333{]}κτῆσιν ἐμὴν δμῶάς τε καὶ ὑψερεφὲς μέγα δῶμα.{l]
[l [n}19.334{]}ἤδη γὰρ Πηλῆά γʼ ὀΐομαι ἢ κατὰ πάμπαν{l]
[l [n}19.335{]}τεθνάμεν, ἤ που τυτθὸν ἔτι ζώοντʼ ἀκάχησθαι{l]
[l [n}19.336{]}γήραΐ τε στυγερῷ καὶ ἐμὴν ποτιδέγμενον αἰεὶ{l]
[l [n}19.337{]}λυγρὴν ἀγγελίην, ὅτʼ ἀποφθιμένοιο πύθηται.{l]{q]{para]
[para}[l [n}19.338{]}ὣς ἔφατο κλαίων, ἐπὶ δὲ στενάχοντο γέροντες,{l]
[l [n}19.339{]}μνησάμενοι τὰ ἕκαστος ἐνὶ μεγάροισιν ἔλειπον·{l]
[l [n}19.340{]}μυρομένους δʼ ἄρα τούς γε ἰδὼν ἐλέησε Κρονίων,{l]
[l [n}19.341{]}αἶψα δʼ Ἀθηναίην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}19.342{]}τέκνον ἐμόν, δὴ πάμπαν ἀποίχεαι ἀνδρὸς ἑῆος.{l]
[l [n}19.343{]}ἦ νύ τοι οὐκέτι πάγχυ μετὰ φρεσὶ μέμβλετʼ Ἀχιλλεύς;{l]
[l [n}19.344{]}κεῖνος ὅ γε προπάροιθε νεῶν ὀρθοκραιράων{l]
[l [n}19.345{]}ἧσται ὀδυρόμενος ἕταρον φίλον· οἳ δὲ δὴ ἄλλοι{l]
[l [n}19.346{]}οἴχονται μετὰ δεῖπνον, ὃ δʼ ἄκμηνος καὶ ἄπαστος.{l]
[l [n}19.347{]}ἀλλʼ ἴθι οἱ νέκτάρ τε καὶ ἀμβροσίην ἐρατεινὴν{l]
[l [n}19.348{]}στάξον ἐνὶ στήθεσσʼ, ἵνα μή μιν λιμὸς ἵκηται.{l]{q]{para]
[para}[l [n}19.349{]}ὣς εἰπὼν ὄτρυνε πάρος μεμαυῖαν Ἀθήνην·{l]
[l [n}19.350{]}ἣ δʼ ἅρπῃ ἐϊκυῖα τανυπτέρυγι λιγυφώνῳ{l]
[l [n}19.351{]}οὐρανοῦ ἐκκατεπᾶλτο διʼ αἰθέρος. αὐτὰρ Ἀχαιοὶ{l]
[l [n}19.352{]}αὐτίκα θωρήσσοντο κατὰ στρατόν· ἣ δʼ Ἀχιλῆϊ{l]
[l [n}19.353{]}νέκταρ ἐνὶ στήθεσσι καὶ ἀμβροσίην ἐρατεινὴν{l]
[l [n}19.354{]}στάξʼ, ἵνα μή μιν λιμὸς ἀτερπὴς γούναθʼ ἵκοιτο·{l]
[l [n}19.355{]}αὐτὴ δὲ πρὸς πατρὸς ἐρισθενέος πυκινὸν δῶ{l]
[l [n}19.356{]}ᾤχετο, τοὶ δʼ ἀπάνευθε νεῶν ἐχέοντο θοάων.{l]
[l [n}19.357{]}ὡς δʼ ὅτε ταρφειαὶ νιφάδες Διὸς ἐκποτέονται{l]
[l [n}19.358{]}ψυχραὶ ὑπὸ ῥιπῆς αἰθρηγενέος Βορέαο,{l]
[l [n}19.359{]}ὣς τότε ταρφειαὶ κόρυθες λαμπρὸν γανόωσαι{l]
[l [n}19.360{]}νηῶν ἐκφορέοντο καὶ ἀσπίδες ὀμφαλόεσσαι{l]
[l [n}19.361{]}θώρηκές τε κραταιγύαλοι καὶ μείλινα δοῦρα.{l]
[l [n}19.362{]}αἴγλη δʼ οὐρανὸν ἷκε, γέλασσε δὲ πᾶσα περὶ χθὼν{l]
[l [n}19.363{]}χαλκοῦ ὑπὸ στεροπῆς· ὑπὸ δὲ κτύπος ὄρνυτο ποσσὶν{l]
[l [n}19.364{]}ἀνδρῶν· ἐν δὲ μέσοισι κορύσσετο δῖος Ἀχιλλεύς.{l]
[l [n}19.365{]}τοῦ καὶ ὀδόντων μὲν καναχὴ πέλε, τὼ δέ οἱ ὄσσε{l]
[l [n}19.366{]}λαμπέσθην ὡς εἴ τε πυρὸς σέλας, ἐν δέ οἱ ἦτορ{l]
[l [n}19.367{]}δῦνʼ ἄχος ἄτλητον· ὃ δʼ ἄρα Τρωσὶν μενεαίνων{l]
[l [n}19.368{]}δύσετο δῶρα θεοῦ, τά οἱ Ἥφαιστος κάμε τεύχων.{l]
[l [n}19.369{]}κνημῖδας μὲν πρῶτα περὶ κνήμῃσιν ἔθηκε{l]
[l [n}19.370{]}καλὰς ἀργυρέοισιν ἐπισφυρίοις ἀραρυίας·{l]
[l [n}19.371{]}δεύτερον αὖ θώρηκα περὶ στήθεσσιν ἔδυνεν.{l]
[l [n}19.372{]}ἀμφὶ δʼ ἄρʼ ὤμοισιν βάλετο ξίφος ἀργυρόηλον{l]
[l [n}19.373{]}χάλκεον· αὐτὰρ ἔπειτα σάκος μέγα τε στιβαρόν τε{l]
[l [n}19.374{]}εἵλετο, τοῦ δʼ ἀπάνευθε σέλας γένετʼ ἠΰτε μήνης.{l]
[l [n}19.375{]}ὡς δʼ ὅτʼ ἂν ἐκ πόντοιο σέλας ναύτῃσι φανήῃ{l]
[l [n}19.376{]}καιομένοιο πυρός, τό τε καίεται ὑψόθʼ ὄρεσφι{l]
[l [n}19.377{]}σταθμῷ ἐν οἰοπόλῳ· τοὺς δʼ οὐκ ἐθέλοντας ἄελλαι{l]
[l [n}19.378{]}πόντον ἐπʼ ἰχθυόεντα φίλων ἀπάνευθε φέρουσιν·{l]
[l [n}19.379{]}ὣς ἀπʼ Ἀχιλλῆος σάκεος σέλας αἰθέρʼ ἵκανε{l]
[l [n}19.380{]}καλοῦ δαιδαλέου· περὶ δὲ τρυφάλειαν ἀείρας{l]
[l [n}19.381{]}κρατὶ θέτο βριαρήν· ἣ δʼ ἀστὴρ ὣς ἀπέλαμπεν{l]
[l [n}19.382{]}ἵππουρις τρυφάλεια, περισσείοντο δʼ ἔθειραι{l]
[l [n}19.383{]}χρύσεαι, ἃς Ἥφαιστος ἵει λόφον ἀμφὶ θαμειάς.{l]
[l [n}19.384{]}πειρήθη δʼ ἕο αὐτοῦ ἐν ἔντεσι δῖος Ἀχιλλεύς,{l]
[l [n}19.385{]}εἰ οἷ ἐφαρμόσσειε καὶ ἐντρέχοι ἀγλαὰ γυῖα·{l]
[l [n}19.386{]}τῷ δʼ εὖτε πτερὰ γίγνετʼ, ἄειρε δὲ ποιμένα λαῶν.{l]
[l [n}19.387{]}ἐκ δʼ ἄρα σύριγγος πατρώϊον ἐσπάσατʼ ἔγχος{l]
[l [n}19.388{]}βριθὺ μέγα στιβαρόν· τὸ μὲν οὐ δύνατʼ ἄλλος Ἀχαιῶν{l]
[l [n}19.389{]}πάλλειν, ἀλλά μιν οἶος ἐπίστατο πῆλαι Ἀχιλλεύς,{l]
[l [n}19.390{]}Πηλιάδα μελίην, τὴν πατρὶ φίλῳ πόρε Χείρων{l]
[l [n}19.391{]}Πηλίου ἐκ κορυφῆς φόνον ἔμμεναι ἡρώεσσιν·{l]
[l [n}19.392{]}ἵππους δʼ Αὐτομέδων τε καὶ Ἄλκιμος ἀμφιέποντες{l]
[l [n}19.393{]}ζεύγνυον· ἀμφὶ δὲ καλὰ λέπαδνʼ ἕσαν, ἐν δὲ χαλινοὺς{l]
[l [n}19.394{]}γαμφηλῇς ἔβαλον, κατὰ δʼ ἡνία τεῖναν ὀπίσσω{l]
[l [n}19.395{]}κολλητὸν ποτὶ δίφρον. ὃ δὲ μάστιγα φαεινὴν{l]
[l [n}19.396{]}χειρὶ λαβὼν ἀραρυῖαν ἐφʼ ἵπποιιν ἀνόρουσεν{l]
[l [n}19.397{]}Αὐτομέδων· ὄπιθεν δὲ κορυσσάμενος βῆ Ἀχιλλεὺς{l]
[l [n}19.398{]}τεύχεσι παμφαίνων ὥς τʼ ἠλέκτωρ Ὑπερίων,{l]
[l [n}19.399{]}σμερδαλέον δʼ ἵπποισιν ἐκέκλετο πατρὸς ἑοῖο·{l]
[q}[l [n}19.400{]}Ξάνθέ τε καὶ Βαλίε τηλεκλυτὰ τέκνα Ποδάργης{l]
[l [n}19.401{]}ἄλλως δὴ φράζεσθε σαωσέμεν ἡνιοχῆα{l]
[l [n}19.402{]}ἂψ Δαναῶν ἐς ὅμιλον ἐπεί χʼ ἕωμεν πολέμοιο,{l]
[l [n}19.403{]}μηδʼ ὡς Πάτροκλον λίπετʼ αὐτόθι τεθνηῶτα.{l]{q]{para]
[para}[l [n}19.404{]}τὸν δʼ ἄρʼ ὑπὸ ζυγόφι προσέφη πόδας αἰόλος ἵππος{l]
[l [n}19.405{]}Ξάνθος, ἄφαρ δʼ ἤμυσε καρήατι· πᾶσα δὲ χαίτη{l]
[l [n}19.406{]}ζεύγλης ἐξεριποῦσα παρὰ ζυγὸν οὖδας ἵκανεν·{l]
[l [n}19.407{]}αὐδήεντα δʼ ἔθηκε θεὰ λευκώλενος Ἥρη·{l]
[q}[l [n}19.408{]}καὶ λίην σʼ ἔτι νῦν γε σαώσομεν ὄβριμʼ Ἀχιλλεῦ·{l]
[l [n}19.409{]}ἀλλά τοι ἐγγύθεν ἦμαρ ὀλέθριον· οὐδέ τοι ἡμεῖς{l]
[l [n}19.410{]}αἴτιοι, ἀλλὰ θεός τε μέγας καὶ Μοῖρα κραταιή.{l]
[l [n}19.411{]}οὐδὲ γὰρ ἡμετέρῃ βραδυτῆτί τε νωχελίῃ τε{l]
[l [n}19.412{]}Τρῶες ἀπʼ ὤμοιιν Πατρόκλου τεύχεʼ ἕλοντο·{l]
[l [n}19.413{]}ἀλλὰ θεῶν ὤριστος, ὃν ἠΰκομος τέκε Λητώ,{l]
[l [n}19.414{]}ἔκτανʼ ἐνὶ προμάχοισι καὶ Ἕκτορι κῦδος ἔδωκε.{l]
[l [n}19.415{]}νῶϊ δὲ καί κεν ἅμα πνοιῇ Ζεφύροιο θέοιμεν,{l]
[l [n}19.416{]}ἥν περ ἐλαφροτάτην φάσʼ ἔμμεναι· ἀλλὰ σοὶ αὐτῷ{l]
[l [n}19.417{]}μόρσιμόν ἐστι θεῷ τε καὶ ἀνέρι ἶφι δαμῆναι.{l]{q]{para]
[para}[l [n}19.418{]}ὣς ἄρα φωνήσαντος Ἐρινύες ἔσχεθον αὐδήν.{l]
[l [n}19.419{]}τὸν δὲ μέγʼ ὀχθήσας προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}19.420{]}Ξάνθε τί μοι θάνατον μαντεύεαι; οὐδέ τί σε χρή.{l]
[l [n}19.421{]}εὖ νυ τὸ οἶδα καὶ αὐτὸς ὅ μοι μόρος ἐνθάδʼ ὀλέσθαι{l]
[l [n}19.422{]}νόσφι φίλου πατρὸς καὶ μητέρος· ἀλλὰ καὶ ἔμπης{l]
[l [n}19.423{]}οὐ λήξω πρὶν Τρῶας ἅδην ἐλάσαι πολέμοιο.{l]{q]{para]
[para}[l [n}19.424{]}ἦ ῥα, καὶ ἐν πρώτοις ἰάχων ἔχε μώνυχας ἵππους.{l]{para]
{book]
[book [n}20{]}[l [n}20.1{]}ὣς οἳ μὲν παρὰ νηυσὶ κορωνίσι θωρήσσοντο{l]
[l [n}20.2{]}ἀμφὶ σὲ Πηλέος υἱὲ μάχης ἀκόρητον Ἀχαιοί,{l]
[l [n}20.3{]}Τρῶες δʼ αὖθʼ ἑτέρωθεν ἐπὶ θρωσμῷ πεδίοιο·{l]
[l [n}20.4{]}Ζεὺς δὲ Θέμιστα κέλευσε θεοὺς ἀγορὴν δὲ καλέσσαι{l]
[l [n}20.5{]}κρατὸς ἀπʼ Οὐλύμποιο πολυπτύχου· ἣ δʼ ἄρα πάντῃ{l]
[l [n}20.6{]}φοιτήσασα κέλευσε Διὸς πρὸς δῶμα νέεσθαι.{l]
[l [n}20.7{]}οὔτέ τις οὖν ποταμῶν ἀπέην νόσφʼ Ὠκεανοῖο,{l]
[l [n}20.8{]}οὔτʼ ἄρα νυμφάων αἵ τʼ ἄλσεα καλὰ νέμονται{l]
[l [n}20.9{]}καὶ πηγὰς ποταμῶν καὶ πίσεα ποιήεντα.{l]
[l [n}20.10{]}ἐλθόντες δʼ ἐς δῶμα Διὸς νεφεληγερέταο{l]
[l [n}20.11{]}ξεστῇς αἰθούσῃσιν ἐνίζανον, ἃς Διὶ πατρὶ{l]
[l [n}20.12{]}Ἥφαιστος ποίησεν ἰδυίῃσι πραπίδεσσιν.{l]
[para}[l [n}20.13{]}ὣς οἳ μὲν Διὸς ἔνδον ἀγηγέρατʼ· οὐδʼ ἐνοσίχθων{l]
[l [n}20.14{]}νηκούστησε θεᾶς, ἀλλʼ ἐξ ἁλὸς ἦλθε μετʼ αὐτούς,{l]
[l [n}20.15{]}ἷζε δʼ ἄρʼ ἐν μέσσοισι, Διὸς δʼ ἐξείρετο βουλήν·{l]
[q}[l [n}20.16{]}τίπτʼ αὖτʼ ἀργικέραυνε θεοὺς ἀγορὴν δὲ κάλεσσας;{l]
[l [n}20.17{]}ἦ τι περὶ Τρώων καὶ Ἀχαιῶν μερμηρίζεις;{l]
[l [n}20.18{]}τῶν γὰρ νῦν ἄγχιστα μάχη πόλεμός τε δέδηε.{l]{q]{para]
[para}[l [n}20.19{]}τὸν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}20.20{]}ἔγνως ἐννοσίγαιε ἐμὴν ἐν στήθεσι βουλὴν{l]
[l [n}20.21{]}ὧν ἕνεκα ξυνάγειρα· μέλουσί μοι ὀλλύμενοί περ.{l]
[l [n}20.22{]}ἀλλʼ ἤτοι μὲν ἐγὼ μενέω πτυχὶ Οὐλύμποιο{l]
[l [n}20.23{]}ἥμενος, ἔνθʼ ὁρόων φρένα τέρψομαι· οἳ δὲ δὴ ἄλλοι{l]
[l [n}20.24{]}ἔρχεσθʼ ὄφρʼ ἂν ἵκησθε μετὰ Τρῶας καὶ Ἀχαιούς,{l]
[l [n}20.25{]}ἀμφοτέροισι δʼ ἀρήγεθʼ ὅπῃ νόος ἐστὶν ἑκάστου.{l]
[l [n}20.26{]}εἰ γὰρ Ἀχιλλεὺς οἶος ἐπὶ Τρώεσσι μαχεῖται{l]
[l [n}20.27{]}οὐδὲ μίνυνθʼ ἕξουσι ποδώκεα Πηλεΐωνα.{l]
[l [n}20.28{]}καὶ δέ τί μιν καὶ πρόσθεν ὑποτρομέεσκον ὁρῶντες·{l]
[l [n}20.29{]}νῦν δʼ ὅτε δὴ καὶ θυμὸν ἑταίρου χώεται αἰνῶς{l]
[l [n}20.30{]}δείδω μὴ καὶ τεῖχος ὑπέρμορον ἐξαλαπάξῃ.{l]{q]{para]
[para}[l [n}20.31{]}ὣς ἔφατο Κρονίδης, πόλεμον δʼ ἀλίαστον ἔγειρε.{l]
[l [n}20.32{]}βὰν δʼ ἴμεναι πόλεμον δὲ θεοὶ δίχα θυμὸν ἔχοντες·{l]
[l [n}20.33{]}Ἥρη μὲν μετʼ ἀγῶνα νεῶν καὶ Παλλὰς Ἀθήνη{l]
[l [n}20.34{]}ἠδὲ Ποσειδάων γαιήοχος ἠδʼ ἐριούνης{l]
[l [n}20.35{]}Ἑρμείας, ὃς ἐπὶ φρεσὶ πευκαλίμῃσι κέκασται·{l]
[l [n}20.36{]}Ἥφαιστος δʼ ἅμα τοῖσι κίε σθένεϊ βλεμεαίνων{l]
[l [n}20.37{]}χωλεύων, ὑπὸ δὲ κνῆμαι ῥώοντο ἀραιαί.{l]
[l [n}20.38{]}ἐς δὲ Τρῶας Ἄρης κορυθαίολος, αὐτὰρ ἅμʼ αὐτῷ{l]
[l [n}20.39{]}Φοῖβος ἀκερσεκόμης ἠδʼ Ἄρτεμις ἰοχέαιρα{l]
[l [n}20.40{]}Λητώ τε Ξάνθός τε φιλομειδής τʼ Ἀφροδίτη.{l]{para]
[para}[l [n}20.41{]}εἷος μέν ῥʼ ἀπάνευθε θεοὶ θνητῶν ἔσαν ἀνδρῶν,{l]
[l [n}20.42{]}τεῖος Ἀχαιοὶ μὲν μέγα κύδανον, οὕνεκʼ Ἀχιλλεὺς{l]
[l [n}20.43{]}ἐξεφάνη, δηρὸν δὲ μάχης ἐπέπαυτʼ ἀλεγεινῆς·{l]
[l [n}20.44{]}Τρῶας δὲ τρόμος αἰνὸς ὑπήλυθε γυῖα ἕκαστον{l]
[l [n}20.45{]}δειδιότας, ὅθʼ ὁρῶντο ποδώκεα Πηλεΐωνα{l]
[l [n}20.46{]}τεύχεσι λαμπόμενον βροτολοιγῷ ἶσον Ἄρηϊ.{l]
[l [n}20.47{]}αὐτὰρ ἐπεὶ μεθʼ ὅμιλον Ὀλύμπιοι ἤλυθον ἀνδρῶν,{l]
[l [n}20.48{]}ὦρτο δʼ Ἔρις κρατερὴ λαοσσόος, αὖε δʼ Ἀθήνη{l]
[l [n}20.49{]}στᾶσʼ ὁτὲ μὲν παρὰ τάφρον ὀρυκτὴν τείχεος ἐκτός,{l]
[l [n}20.50{]}ἄλλοτʼ ἐπʼ ἀκτάων ἐριδούπων μακρὸν ἀΰτει.{l]
[l [n}20.51{]}αὖε δʼ Ἄρης ἑτέρωθεν ἐρεμνῇ λαίλαπι ἶσος{l]
[l [n}20.52{]}ὀξὺ κατʼ ἀκροτάτης πόλιος Τρώεσσι κελεύων,{l]
[l [n}20.53{]}ἄλλοτε πὰρ Σιμόεντι θέων ἐπὶ Καλλικολώνῃ.{l]{para]
[para}[l [n}20.54{]}ὣς τοὺς ἀμφοτέρους μάκαρες θεοὶ ὀτρύνοντες{l]
[l [n}20.55{]}σύμβαλον, ἐν δʼ αὐτοῖς ἔριδα ῥήγνυντο βαρεῖαν·{l]
[l [n}20.56{]}δεινὸν δὲ βρόντησε πατὴρ ἀνδρῶν τε θεῶν τε{l]
[l [n}20.57{]}ὑψόθεν· αὐτὰρ νέρθε Ποσειδάων ἐτίναξε{l]
[l [n}20.58{]}γαῖαν ἀπειρεσίην ὀρέων τʼ αἰπεινὰ κάρηνα.{l]
[l [n}20.59{]}πάντες δʼ ἐσσείοντο πόδες πολυπίδακος Ἴδης{l]
[l [n}20.60{]}καὶ κορυφαί, Τρώων τε πόλις καὶ νῆες Ἀχαιῶν.{l]
[l [n}20.61{]}ἔδεισεν δʼ ὑπένερθεν ἄναξ ἐνέρων Ἀϊδωνεύς,{l]
[l [n}20.62{]}δείσας δʼ ἐκ θρόνου ἆλτο καὶ ἴαχε, μή οἱ ὕπερθε{l]
[l [n}20.63{]}γαῖαν ἀναρρήξειε Ποσειδάων ἐνοσίχθων,{l]
[l [n}20.64{]}οἰκία δὲ θνητοῖσι καὶ ἀθανάτοισι φανείη{l]
[l [n}20.65{]}σμερδαλέʼ εὐρώεντα, τά τε στυγέουσι θεοί περ·{l]
[l [n}20.66{]}τόσσος ἄρα κτύπος ὦρτο θεῶν ἔριδι ξυνιόντων.{l]
[l [n}20.67{]}ἤτοι μὲν γὰρ ἔναντα Ποσειδάωνος ἄνακτος{l]
[l [n}20.68{]}ἵστατʼ Ἀπόλλων Φοῖβος ἔχων ἰὰ πτερόεντα,{l]
[l [n}20.69{]}ἄντα δʼ Ἐνυαλίοιο θεὰ γλαυκῶπις Ἀθήνη·{l]
[l [n}20.70{]}Ἥρῃ δʼ ἀντέστη χρυσηλάκατος κελαδεινὴ{l]
[l [n}20.71{]}Ἄρτεμις ἰοχέαιρα κασιγνήτη ἑκάτοιο·{l]
[l [n}20.72{]}Λητοῖ δʼ ἀντέστη σῶκος ἐριούνιος Ἑρμῆς,{l]
[l [n}20.73{]}ἄντα δʼ ἄρʼ Ἡφαίστοιο μέγας ποταμὸς βαθυδίνης,{l]
[l [n}20.74{]}ὃν Ξάνθον καλέουσι θεοί, ἄνδρες δὲ Σκάμανδρον.{l]{para]
[para}[l [n}20.75{]}ὣς οἳ μὲν θεοὶ ἄντα θεῶν ἴσαν· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}20.76{]}Ἕκτορος ἄντα μάλιστα λιλαίετο δῦναι ὅμιλον{l]
[l [n}20.77{]}Πριαμίδεω· τοῦ γάρ ῥα μάλιστά ἑ θυμὸς ἀνώγει{l]
[l [n}20.78{]}αἵματος ἆσαι Ἄρηα ταλαύρινον πολεμιστήν.{l]
[l [n}20.79{]}Αἰνείαν δʼ ἰθὺς λαοσσόος ὦρσεν Ἀπόλλων{l]
[l [n}20.80{]}ἀντία Πηλεΐωνος, ἐνῆκε δέ οἱ μένος ἠΰ·{l]
[l [n}20.81{]}υἱέϊ δὲ Πριάμοιο Λυκάονι εἴσατο φωνήν·{l]
[l [n}20.82{]}τῷ μιν ἐεισάμενος προσέφη Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}20.83{]}Αἰνεία Τρώων βουληφόρε ποῦ τοι ἀπειλαὶ{l]
[l [n}20.84{]}ἃς Τρώων βασιλεῦσιν ὑπίσχεο οἰνοποτάζων{l]
[l [n}20.85{]}Πηλεΐδεω Ἀχιλῆος ἐναντίβιον πολεμίξειν;{l]{q]{para]
[para}[l [n}20.86{]}τὸν δʼ αὖτʼ Αἰνείας ἀπαμειβόμενος προσέειπε·{l]
[q}[l [n}20.87{]}Πριαμίδη τί με ταῦτα καὶ οὐκ ἐθέλοντα κελεύεις{l]
[l [n}20.88{]}ἀντία Πηλεΐωνος ὑπερθύμοιο μάχεσθαι;{l]
[l [n}20.89{]}οὐ μὲν γὰρ νῦν πρῶτα ποδώκεος ἄντʼ Ἀχιλῆος{l]
[l [n}20.90{]}στήσομαι, ἀλλʼ ἤδη με καὶ ἄλλοτε δουρὶ φόβησεν{l]
[l [n}20.91{]}ἐξ Ἴδης, ὅτε βουσὶν ἐπήλυθεν ἡμετέρῃσι,{l]
[l [n}20.92{]}πέρσε δὲ Λυρνησσὸν καὶ Πήδασον· αὐτὰρ ἐμὲ Ζεὺς{l]
[l [n}20.93{]}εἰρύσαθʼ, ὅς μοι ἐπῶρσε μένος λαιψηρά τε γοῦνα.{l]
[l [n}20.94{]}ἦ κʼ ἐδάμην ὑπὸ χερσὶν Ἀχιλλῆος καὶ Ἀθήνης,{l]
[l [n}20.95{]}ἥ οἱ πρόσθεν ἰοῦσα τίθει φάος ἠδʼ ἐκέλευεν{l]
[l [n}20.96{]}ἔγχεϊ χαλκείῳ Λέλεγας καὶ Τρῶας ἐναίρειν.{l]
[l [n}20.97{]}τὼ οὐκ ἔστʼ Ἀχιλῆος ἐναντίον ἄνδρα μάχεσθαι·{l]
[l [n}20.98{]}αἰεὶ γὰρ πάρα εἷς γε θεῶν ὃς λοιγὸν ἀμύνει.{l]
[l [n}20.99{]}καὶ δʼ ἄλλως τοῦ γʼ ἰθὺ βέλος πέτετʼ, οὐδʼ ἀπολήγει{l]
[l [n}20.100{]}πρὶν χροὸς ἀνδρομέοιο διελθέμεν. εἰ δὲ θεός περ{l]
[l [n}20.101{]}ἶσον τείνειεν πολέμου τέλος, οὔ κε μάλα ῥέα{l]
[l [n}20.102{]}νικήσειʼ, οὐδʼ εἰ παγχάλκεος εὔχεται εἶναι.{l]{q]{para]
[para}[l [n}20.103{]}τὸν δʼ αὖτε προσέειπεν ἄναξ Διὸς υἱὸς Ἀπόλλων·{l]
[q}[l [n}20.104{]}ἥρως ἀλλʼ ἄγε καὶ σὺ θεοῖς αἰειγενέτῃσιν{l]
[l [n}20.105{]}εὔχεο· καὶ δὲ σέ φασι Διὸς κούρης Ἀφροδίτης{l]
[l [n}20.106{]}ἐκγεγάμεν, κεῖνος δὲ χερείονος ἐκ θεοῦ ἐστίν·{l]
[l [n}20.107{]}ἣ μὲν γὰρ Διός ἐσθʼ, ἣ δʼ ἐξ ἁλίοιο γέροντος.{l]
[l [n}20.108{]}ἀλλʼ ἰθὺς φέρε χαλκὸν ἀτειρέα, μηδέ σε πάμπαν{l]
[l [n}20.109{]}λευγαλέοις ἐπέεσσιν ἀποτρεπέτω καὶ ἀρειῇ.{l]{q]{para]
[para}[l [n}20.110{]}ὣς εἰπὼν ἔμπνευσε μένος μέγα ποιμένι λαῶν,{l]
[l [n}20.111{]}βῆ δὲ διὰ προμάχων κεκορυθμένος αἴθοπι χαλκῷ.{l]
[l [n}20.112{]}οὐδʼ ἔλαθʼ Ἀγχίσαο πάϊς λευκώλενον Ἥρην{l]
[l [n}20.113{]}ἀντία Πηλεΐωνος ἰὼν ἀνὰ οὐλαμὸν ἀνδρῶν·{l]
[l [n}20.114{]}ἣ δʼ ἄμυδις στήσασα θεοὺς μετὰ μῦθον ἔειπε·{l]
[q}[l [n}20.115{]}φράζεσθον δὴ σφῶϊ Ποσείδαον καὶ Ἀθήνη{l]
[l [n}20.116{]}ἐν φρεσὶν ὑμετέρῃσιν, ὅπως ἔσται τάδε ἔργα.{l]
[l [n}20.117{]}Αἰνείας ὅδʼ ἔβη κεκορυθμένος αἴθοπι χαλκῷ{l]
[l [n}20.118{]}ἀντία Πηλεΐωνος, ἀνῆκε δὲ Φοῖβος Ἀπόλλων.{l]
[l [n}20.119{]}ἀλλʼ ἄγεθʼ, ἡμεῖς πέρ μιν ἀποτρωπῶμεν ὀπίσσω{l]
[l [n}20.120{]}αὐτόθεν· ἤ τις ἔπειτα καὶ ἡμείων Ἀχιλῆϊ{l]
[l [n}20.121{]}παρσταίη, δοίη δὲ κράτος μέγα, μηδέ τι θυμῷ{l]
[l [n}20.122{]}δευέσθω, ἵνα εἰδῇ ὅ μιν φιλέουσιν ἄριστοι{l]
[l [n}20.123{]}ἀθανάτων, οἳ δʼ αὖτʼ ἀνεμώλιοι οἳ τὸ πάρος περ{l]
[l [n}20.124{]}Τρωσὶν ἀμύνουσιν πόλεμον καὶ δηϊοτῆτα.{l]
[l [n}20.125{]}πάντες δʼ Οὐλύμποιο κατήλθομεν ἀντιόωντες{l]
[l [n}20.126{]}τῆσδε μάχης, ἵνα μή τι μετὰ Τρώεσσι πάθῃσι{l]
[l [n}20.127{]}σήμερον· ὕστερον αὖτε τὰ πείσεται ἅσσά οἱ αἶσα{l]
[l [n}20.128{]}γιγνομένῳ ἐπένησε λίνῳ ὅτε μιν τέκε μήτηρ.{l]
[l [n}20.129{]}εἰ δʼ Ἀχιλεὺς οὐ ταῦτα θεῶν ἐκ πεύσεται ὀμφῆς{l]
[l [n}20.130{]}δείσετʼ ἔπειθʼ, ὅτε κέν τις ἐναντίβιον θεὸς ἔλθῃ{l]
[l [n}20.131{]}ἐν πολέμῳ· χαλεποὶ δὲ θεοὶ φαίνεσθαι ἐναργεῖς.{l]{q]{para]
[para}[l [n}20.132{]}τὴν δʼ ἠμείβετʼ ἔπειτα Ποσειδάων ἐνοσίχθων·{l]
[q}[l [n}20.133{]}Ἥρη μὴ χαλέπαινε παρʼ ἐκ νόον· οὐδέ τί σε χρή.{l]
[l [n}20.134{]}οὐκ ἂν ἔγωγʼ ἐθέλοιμι θεοὺς ἔριδι ξυνελάσσαι{l]
[l [n}20.135{]}ἡμέας τοὺς ἄλλους, ἐπεὶ ἦ πολὺ φέρτεροί εἰμεν·{l]
[l [n}20.136{]}ἀλλʼ ἡμεῖς μὲν ἔπειτα καθεζώμεσθα κιόντες{l]
[l [n}20.137{]}ἐκ πάτου ἐς σκοπιήν, πόλεμος δʼ ἄνδρεσσι μελήσει.{l]
[l [n}20.138{]}εἰ δέ κʼ Ἄρης ἄρχωσι μάχης ἢ Φοῖβος Ἀπόλλων,{l]
[l [n}20.139{]}ἢ Ἀχιλῆʼ ἴσχωσι καὶ οὐκ εἰῶσι μάχεσθαι,{l]
[l [n}20.140{]}αὐτίκʼ ἔπειτα καὶ ἄμμι παρʼ αὐτόθι νεῖκος ὀρεῖται{l]
[l [n}20.141{]}φυλόπιδος· μάλα δʼ ὦκα διακρινθέντας ὀΐω{l]
[l [n}20.142{]}ἂψ ἴμεν Οὔλυμπον δὲ θεῶν μεθʼ ὁμήγυριν ἄλλων{l]
[l [n}20.143{]}ἡμετέρῃς ὑπὸ χερσὶν ἀναγκαίηφι δαμέντας.{l]{q]{para]
[para}[l [n}20.144{]}ὣς ἄρα φωνήσας ἡγήσατο κυανοχαίτης{l]
[l [n}20.145{]}τεῖχος ἐς ἀμφίχυτον Ἡρακλῆος θείοιο{l]
[l [n}20.146{]}ὑψηλόν, τό ῥά οἱ Τρῶες καὶ Παλλὰς Ἀθήνη{l]
[l [n}20.147{]}ποίεον, ὄφρα τὸ κῆτος ὑπεκπροφυγὼν ἀλέαιτο,{l]
[l [n}20.148{]}ὁππότε μιν σεύαιτο ἀπʼ ἠϊόνος πεδίον δέ.{l]
[l [n}20.149{]}ἔνθα Ποσειδάων κατʼ ἄρʼ ἕζετο καὶ θεοὶ ἄλλοι,{l]
[l [n}20.150{]}ἀμφὶ δʼ ἄρʼ ἄρρηκτον νεφέλην ὤμοισιν ἕσαντο·{l]
[l [n}20.151{]}οἳ δʼ ἑτέρωσε καθῖζον ἐπʼ ὀφρύσι Καλλικολώνης{l]
[l [n}20.152{]}ἀμφὶ σὲ ἤϊε Φοῖβε καὶ Ἄρηα πτολίπορθον.{l]{para]
[para}[l [n}20.153{]}ὣς οἳ μέν ῥʼ ἑκάτερθε καθήατο μητιόωντες{l]
[l [n}20.154{]}βουλάς· ἀρχέμεναι δὲ δυσηλεγέος πολέμοιο{l]
[l [n}20.155{]}ὄκνεον ἀμφότεροι, Ζεὺς δʼ ἥμενος ὕψι κέλευε.{l]{para]
[para}[l [n}20.156{]}τῶν δʼ ἅπαν ἐπλήσθη πεδίον καὶ λάμπετο χαλκῷ{l]
[l [n}20.157{]}ἀνδρῶν ἠδʼ ἵππων· κάρκαιρε δὲ γαῖα πόδεσσιν{l]
[l [n}20.158{]}ὀρνυμένων ἄμυδις. δύο δʼ ἀνέρες ἔξοχʼ ἄριστοι{l]
[l [n}20.159{]}ἐς μέσον ἀμφοτέρων συνίτην μεμαῶτε μάχεσθαι{l]
[l [n}20.160{]}Αἰνείας τʼ Ἀγχισιάδης καὶ δῖος Ἀχιλλεύς.{l]
[l [n}20.161{]}Αἰνείας δὲ πρῶτος ἀπειλήσας ἐβεβήκει{l]
[l [n}20.162{]}νευστάζων κόρυθι βριαρῇ· ἀτὰρ ἀσπίδα θοῦριν{l]
[l [n}20.163{]}πρόσθεν ἔχε στέρνοιο, τίνασσε δὲ χάλκεον ἔγχος.{l]
[l [n}20.164{]}Πηλεΐδης δʼ ἑτέρωθεν ἐναντίον ὦρτο λέων ὣς{l]
[l [n}20.165{]}σίντης, ὅν τε καὶ ἄνδρες ἀποκτάμεναι μεμάασιν{l]
[l [n}20.166{]}ἀγρόμενοι πᾶς δῆμος· ὃ δὲ πρῶτον μὲν ἀτίζων{l]
[l [n}20.167{]}ἔρχεται, ἀλλʼ ὅτε κέν τις ἀρηϊθόων αἰζηῶν{l]
[l [n}20.168{]}δουρὶ βάλῃ ἐάλη τε χανών, περί τʼ ἀφρὸς ὀδόντας{l]
[l [n}20.169{]}γίγνεται, ἐν δέ τέ οἱ κραδίῃ στένει ἄλκιμον ἦτορ,{l]
[l [n}20.170{]}οὐρῇ δὲ πλευράς τε καὶ ἰσχία ἀμφοτέρωθεν{l]
[l [n}20.171{]}μαστίεται, ἑὲ δʼ αὐτὸν ἐποτρύνει μαχέσασθαι,{l]
[l [n}20.172{]}γλαυκιόων δʼ ἰθὺς φέρεται μένει, ἤν τινα πέφνῃ{l]
[l [n}20.173{]}ἀνδρῶν, ἢ αὐτὸς φθίεται πρώτῳ ἐν ὁμίλῳ·{l]
[l [n}20.174{]}ὣς Ἀχιλῆʼ ὄτρυνε μένος καὶ θυμὸς ἀγήνωρ{l]
[l [n}20.175{]}ἀντίον ἐλθέμεναι μεγαλήτορος Αἰνείαο.{l]
[l [n}20.176{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}20.177{]}τὸν πρότερος προσέειπε ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}20.178{]}Αἰνεία τί σὺ τόσσον ὁμίλου πολλὸν ἐπελθὼν{l]
[l [n}20.179{]}ἔστης; ἦ σέ γε θυμὸς ἐμοὶ μαχέσασθαι ἀνώγει{l]
[l [n}20.180{]}ἐλπόμενον Τρώεσσιν ἀνάξειν ἱπποδάμοισι{l]
[l [n}20.181{]}τιμῆς τῆς Πριάμου; ἀτὰρ εἴ κεν ἔμʼ ἐξεναρίξῃς,{l]
[l [n}20.182{]}οὔ τοι τοὔνεκά γε Πρίαμος γέρας ἐν χερὶ θήσει·{l]
[l [n}20.183{]}εἰσὶν γάρ οἱ παῖδες, ὃ δʼ ἔμπεδος οὐδʼ ἀεσίφρων.{l]
[l [n}20.184{]}ἦ νύ τί τοι Τρῶες τέμενος τάμον ἔξοχον ἄλλων{l]
[l [n}20.185{]}καλὸν φυταλιῆς καὶ ἀρούρης, ὄφρα νέμηαι{l]
[l [n}20.186{]}αἴ κεν ἐμὲ κτείνῃς; χαλεπῶς δέ σʼ ἔολπα τὸ ῥέξειν.{l]
[l [n}20.187{]}ἤδη μὲν σέ γέ φημι καὶ ἄλλοτε δουρὶ φοβῆσαι.{l]
[l [n}20.188{]}ἦ οὐ μέμνῃ ὅτε πέρ σε βοῶν ἄπο μοῦνον ἐόντα{l]
[l [n}20.189{]}σεῦα κατʼ Ἰδαίων ὀρέων ταχέεσσι πόδεσσι{l]
[l [n}20.190{]}καρπαλίμως; τότε δʼ οὔ τι μετατροπαλίζεο φεύγων.{l]
[l [n}20.191{]}ἔνθεν δʼ ἐς Λυρνησσὸν ὑπέκφυγες· αὐτὰρ ἐγὼ τὴν{l]
[l [n}20.192{]}πέρσα μεθορμηθεὶς σὺν Ἀθήνῃ καὶ Διὶ πατρί,{l]
[l [n}20.193{]}ληϊάδας δὲ γυναῖκας ἐλεύθερον ἦμαρ ἀπούρας{l]
[l [n}20.194{]}ἦγον· ἀτὰρ σὲ Ζεὺς ἐρρύσατο καὶ θεοὶ ἄλλοι.{l]
[l [n}20.195{]}ἀλλʼ οὐ νῦν ἐρύεσθαι ὀΐομαι, ὡς ἐνὶ θυμῷ{l]
[l [n}20.196{]}βάλλεαι· ἀλλά σʼ ἔγωγʼ ἀναχωρήσαντα κελεύω{l]
[l [n}20.197{]}ἐς πληθὺν ἰέναι, μηδʼ ἀντίος ἵστασʼ ἐμεῖο,{l]
[l [n}20.198{]}πρίν τι κακὸν παθέειν· ῥεχθὲν δέ τε νήπιος ἔγνω.{l]{q]{para]
[para}[l [n}20.199{]}τὸν δʼ αὖτʼ Αἰνείας ἀπαμείβετο φώνησέν τε·{l]
[q}[l [n}20.200{]}Πηλεΐδη μὴ δὴ ἐπέεσσί με νηπύτιον ὣς{l]
[l [n}20.201{]}ἔλπεο δειδίξεσθαι, ἐπεὶ σάφα οἶδα καὶ αὐτὸς{l]
[l [n}20.202{]}ἠμὲν κερτομίας ἠδʼ αἴσυλα μυθήσασθαι.{l]
[l [n}20.203{]}ἴδμεν δʼ ἀλλήλων γενεήν, ἴδμεν δὲ τοκῆας{l]
[l [n}20.204{]}πρόκλυτʼ ἀκούοντες ἔπεα θνητῶν ἀνθρώπων·{l]
[l [n}20.205{]}ὄψει δʼ οὔτʼ ἄρ πω σὺ ἐμοὺς ἴδες οὔτʼ ἄρʼ ἐγὼ σούς.{l]
[l [n}20.206{]}φασὶ σὲ μὲν Πηλῆος ἀμύμονος ἔκγονον εἶναι,{l]
[l [n}20.207{]}μητρὸς δʼ ἐκ Θέτιδος καλλιπλοκάμου ἁλοσύδνης·{l]
[l [n}20.208{]}αὐτὰρ ἐγὼν υἱὸς μεγαλήτορος Ἀγχίσαο{l]
[l [n}20.209{]}εὔχομαι ἐκγεγάμεν, μήτηρ δέ μοί ἐστʼ Ἀφροδίτη·{l]
[l [n}20.210{]}τῶν δὴ νῦν ἕτεροί γε φίλον παῖδα κλαύσονται{l]
[l [n}20.211{]}σήμερον· οὐ γάρ φημʼ ἐπέεσσί γε νηπυτίοισιν{l]
[l [n}20.212{]}ὧδε διακρινθέντε μάχης ἐξαπονέεσθαι.{l]
[l [n}20.213{]}εἰ δʼ ἐθέλεις καὶ ταῦτα δαήμεναι, ὄφρʼ ἐῢ εἰδῇς{l]
[l [n}20.214{]}ἡμετέρην γενεήν, πολλοὶ δέ μιν ἄνδρες ἴσασι·{l]
[l [n}20.215{]}Δάρδανον αὖ πρῶτον τέκετο νεφεληγερέτα Ζεύς,{l]
[l [n}20.216{]}κτίσσε δὲ Δαρδανίην, ἐπεὶ οὔ πω Ἴλιος ἱρὴ{l]
[l [n}20.217{]}ἐν πεδίῳ πεπόλιστο πόλις μερόπων ἀνθρώπων,{l]
[l [n}20.218{]}ἀλλʼ ἔθʼ ὑπωρείας ᾤκεον πολυπίδακος Ἴδης.{l]
[l [n}20.219{]}Δάρδανος αὖ τέκεθʼ υἱὸν Ἐριχθόνιον βασιλῆα,{l]
[l [n}20.220{]}ὃς δὴ ἀφνειότατος γένετο θνητῶν ἀνθρώπων·{l]
[l [n}20.221{]}τοῦ τρισχίλιαι ἵπποι ἕλος κάτα βουκολέοντο{l]
[l [n}20.222{]}θήλειαι, πώλοισιν ἀγαλλόμεναι ἀταλῇσι.{l]
[l [n}20.223{]}τάων καὶ Βορέης ἠράσσατο βοσκομενάων,{l]
[l [n}20.224{]}ἵππῳ δʼ εἰσάμενος παρελέξατο κυανοχαίτῃ·{l]
[l [n}20.225{]}αἳ δʼ ὑποκυσάμεναι ἔτεκον δυοκαίδεκα πώλους.{l]
[l [n}20.226{]}αἳ δʼ ὅτε μὲν σκιρτῷεν ἐπὶ ζείδωρον ἄρουραν,{l]
[l [n}20.227{]}ἄκρον ἐπʼ ἀνθερίκων καρπὸν θέον οὐδὲ κατέκλων·{l]
[l [n}20.228{]}ἀλλʼ ὅτε δὴ σκιρτῷεν ἐπʼ εὐρέα νῶτα θαλάσσης,{l]
[l [n}20.229{]}ἄκρον ἐπὶ ῥηγμῖνος ἁλὸς πολιοῖο θέεσκον.{l]
[l [n}20.230{]}Τρῶα δʼ Ἐριχθόνιος τέκετο Τρώεσσιν ἄνακτα·{l]
[l [n}20.231{]}Τρωὸς δʼ αὖ τρεῖς παῖδες ἀμύμονες ἐξεγένοντο{l]
[l [n}20.232{]}Ἶλός τʼ Ἀσσάρακός τε καὶ ἀντίθεος Γανυμήδης,{l]
[l [n}20.233{]}ὃς δὴ κάλλιστος γένετο θνητῶν ἀνθρώπων·{l]
[l [n}20.234{]}τὸν καὶ ἀνηρείψαντο θεοὶ Διὶ οἰνοχοεύειν{l]
[l [n}20.235{]}κάλλεος εἵνεκα οἷο ἵνʼ ἀθανάτοισι μετείη.{l]
[l [n}20.236{]}Ἶλος δʼ αὖ τέκεθʼ υἱὸν ἀμύμονα Λαομέδοντα·{l]
[l [n}20.237{]}Λαομέδων δʼ ἄρα Τιθωνὸν τέκετο Πρίαμόν τε{l]
[l [n}20.238{]}Λάμπόν τε Κλυτίον θʼ Ἱκετάονά τʼ ὄζον Ἄρηος·{l]
[l [n}20.239{]}Ἀσσάρακος δὲ Κάπυν, ὃ δʼ ἄρʼ Ἀγχίσην τέκε παῖδα·{l]
[l [n}20.240{]}αὐτὰρ ἔμʼ Ἀγχίσης, Πρίαμος δʼ ἔτεχʼ Ἕκτορα δῖον.{l]
[l [n}20.241{]}ταύτης τοι γενεῆς τε καὶ αἵματος εὔχομαι εἶναι.{l]
[l [n}20.242{]}Ζεὺς δʼ ἀρετὴν ἄνδρεσσιν ὀφέλλει τε μινύθει τε{l]
[l [n}20.243{]}ὅππως κεν ἐθέλῃσιν· ὃ γὰρ κάρτιστος ἁπάντων.{l]
[l [n}20.244{]}ἀλλʼ ἄγε μηκέτι ταῦτα λεγώμεθα νηπύτιοι ὣς{l]
[l [n}20.245{]}ἑσταότʼ ἐν μέσσῃ ὑσμίνῃ δηϊοτῆτος.{l]
[l [n}20.246{]}ἔστι γὰρ ἀμφοτέροισιν ὀνείδεα μυθήσασθαι{l]
[l [n}20.247{]}πολλὰ μάλʼ, οὐδʼ ἂν νηῦς ἑκατόζυγος ἄχθος ἄροιτο.{l]
[l [n}20.248{]}στρεπτὴ δὲ γλῶσσʼ ἐστὶ βροτῶν, πολέες δʼ ἔνι μῦθοι{l]
[l [n}20.249{]}παντοῖοι, ἐπέων δὲ πολὺς νομὸς ἔνθα καὶ ἔνθα.{l]
[l [n}20.250{]}ὁπποῖόν κʼ εἴπῃσθα ἔπος, τοῖόν κʼ ἐπακούσαις.{l]
[l [n}20.251{]}ἀλλὰ τί ἢ ἔριδας καὶ νείκεα νῶϊν ἀνάγκη{l]
[l [n}20.252{]}νεικεῖν ἀλλήλοισιν ἐναντίον ὥς τε γυναῖκας,{l]
[l [n}20.253{]}αἵ τε χολωσάμεναι ἔριδος πέρι θυμοβόροιο{l]
[l [n}20.254{]}νεικεῦσʼ ἀλλήλῃσι μέσην ἐς ἄγυιαν ἰοῦσαι{l]
[l [n}20.255{]}πόλλʼ ἐτεά τε καὶ οὐκί· χόλος δέ τε καὶ τὰ κελεύει.{l]
[l [n}20.256{]}ἀλκῆς δʼ οὔ μʼ ἐπέεσσιν ἀποτρέψεις μεμαῶτα{l]
[l [n}20.257{]}πρὶν χαλκῷ μαχέσασθαι ἐναντίον· ἀλλʼ ἄγε θᾶσσον{l]
[l [n}20.258{]}γευσόμεθʼ ἀλλήλων χαλκήρεσιν ἐγχείῃσιν.{l]{q]{para]
[para}[l [n}20.259{]}ἦ ῥα καὶ ἐν δεινῷ σάκει ἤλασεν ὄβριμον ἔγχος{l]
[l [n}20.260{]}σμερδαλέῳ· μέγα δʼ ἀμφὶ σάκος μύκε δουρὸς ἀκωκῇ.{l]
[l [n}20.261{]}Πηλεΐδης δὲ σάκος μὲν ἀπὸ ἕο χειρὶ παχείῃ{l]
[l [n}20.262{]}ἔσχετο ταρβήσας· φάτο γὰρ δολιχόσκιον ἔγχος{l]
[l [n}20.263{]}ῥέα διελεύσεσθαι μεγαλήτορος Αἰνείαο{l]
[l [n}20.264{]}νήπιος, οὐδʼ ἐνόησε κατὰ φρένα καὶ κατὰ θυμὸν{l]
[l [n}20.265{]}ὡς οὐ ῥηΐδιʼ ἐστὶ θεῶν ἐρικυδέα δῶρα{l]
[l [n}20.266{]}ἀνδράσι γε θνητοῖσι δαμήμεναι οὐδʼ ὑποείκειν.{l]
[l [n}20.267{]}οὐδὲ τότʼ Αἰνείαο δαΐφρονος ὄβριμον ἔγχος{l]
[l [n}20.268{]}ῥῆξε σάκος· χρυσὸς γὰρ ἐρύκακε, δῶρα θεοῖο·{l]
[l [n}20.269{]}ἀλλὰ δύω μὲν ἔλασσε διὰ πτύχας, αἳ δʼ ἄρʼ ἔτι τρεῖς{l]
[l [n}20.270{]}ἦσαν, ἐπεὶ πέντε πτύχας ἤλασε κυλλοποδίων,{l]
[l [n}20.271{]}τὰς δύο χαλκείας, δύο δʼ ἔνδοθι κασσιτέροιο,{l]
[l [n}20.272{]}τὴν δὲ μίαν χρυσῆν, τῇ ῥʼ ἔσχετο μείλινον ἔγχος.{l]{para]
[para}[l [n}20.273{]}δεύτερος αὖτʼ Ἀχιλεὺς προΐει δολιχόσκιον ἔγχος,{l]
[l [n}20.274{]}καὶ βάλεν Αἰνείαο κατʼ ἀσπίδα πάντοσʼ ἐΐσην{l]
[l [n}20.275{]}ἄντυγʼ ὕπο πρώτην, ᾗ λεπτότατος θέε χαλκός,{l]
[l [n}20.276{]}λεπτοτάτη δʼ ἐπέην ῥινὸς βοός· ἣ δὲ διὰ πρὸ{l]
[l [n}20.277{]}Πηλιὰς ἤϊξεν μελίη, λάκε δʼ ἀσπὶς ὑπʼ αὐτῆς.{l]
[l [n}20.278{]}Αἰνείας δʼ ἐάλη καὶ ἀπὸ ἕθεν ἀσπίδʼ ἀνέσχε{l]
[l [n}20.279{]}δείσας· ἐγχείη δʼ ἄρʼ ὑπὲρ νώτου ἐνὶ γαίῃ{l]
[l [n}20.280{]}ἔστη ἱεμένη, διὰ δʼ ἀμφοτέρους ἕλε κύκλους{l]
[l [n}20.281{]}ἀσπίδος ἀμφιβρότης· ὃ δʼ ἀλευάμενος δόρυ μακρὸν{l]
[l [n}20.282{]}ἔστη, κὰδ δʼ ἄχος οἱ χύτο μυρίον ὀφθαλμοῖσι,{l]
[l [n}20.283{]}ταρβήσας ὅ οἱ ἄγχι πάγη βέλος. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}20.284{]}ἐμμεμαὼς ἐπόρουσεν ἐρυσσάμενος ξίφος ὀξὺ{l]
[l [n}20.285{]}σμερδαλέα ἰάχων· ὃ δὲ χερμάδιον λάβε χειρὶ{l]
[l [n}20.286{]}Αἰνείας, μέγα ἔργον, ὃ οὐ δύο γʼ ἄνδρε φέροιεν,{l]
[l [n}20.287{]}οἷοι νῦν βροτοί εἰσʼ· ὃ δέ μιν ῥέα πάλλε καὶ οἶος.{l]
[l [n}20.288{]}ἔνθά κεν Αἰνείας μὲν ἐπεσσύμενον βάλε πέτρῳ{l]
[l [n}20.289{]}ἢ κόρυθʼ ἠὲ σάκος, τό οἱ ἤρκεσε λυγρὸν ὄλεθρον,{l]
[l [n}20.290{]}τὸν δέ κε Πηλεΐδης σχεδὸν ἄορι θυμὸν ἀπηύρα,{l]
[l [n}20.291{]}εἰ μὴ ἄρʼ ὀξὺ νόησε Ποσειδάων ἐνοσίχθων·{l]
[l [n}20.292{]}αὐτίκα δʼ ἀθανάτοισι θεοῖς μετὰ μῦθον ἔειπεν·{l]
[q}[l [n}20.293{]}ὢ πόποι ἦ μοι ἄχος μεγαλήτορος Αἰνείαο,{l]
[l [n}20.294{]}ὃς τάχα Πηλεΐωνι δαμεὶς Ἄϊδος δὲ κάτεισι{l]
[l [n}20.295{]}πειθόμενος μύθοισιν Ἀπόλλωνος ἑκάτοιο{l]
[l [n}20.296{]}νήπιος, οὐδέ τί οἱ χραισμήσει λυγρὸν ὄλεθρον.{l]
[l [n}20.297{]}ἀλλὰ τί ἢ νῦν οὗτος ἀναίτιος ἄλγεα πάσχει{l]
[l [n}20.298{]}μὰψ ἕνεκʼ ἀλλοτρίων ἀχέων, κεχαρισμένα δʼ αἰεὶ{l]
[l [n}20.299{]}δῶρα θεοῖσι δίδωσι τοὶ οὐρανὸν εὐρὺν ἔχουσιν;{l]
[l [n}20.300{]}ἀλλʼ ἄγεθʼ ἡμεῖς πέρ μιν ὑπὲκ θανάτου ἀγάγωμεν,{l]
[l [n}20.301{]}μή πως καὶ Κρονίδης κεχολώσεται, αἴ κεν Ἀχιλλεὺς{l]
[l [n}20.302{]}τόνδε κατακτείνῃ· μόριμον δέ οἵ ἐστʼ ἀλέασθαι,{l]
[l [n}20.303{]}ὄφρα μὴ ἄσπερμος γενεὴ καὶ ἄφαντος ὄληται{l]
[l [n}20.304{]}Δαρδάνου, ὃν Κρονίδης περὶ πάντων φίλατο παίδων{l]
[l [n}20.305{]}οἳ ἕθεν ἐξεγένοντο γυναικῶν τε θνητάων.{l]
[l [n}20.306{]}ἤδη γὰρ Πριάμου γενεὴν ἔχθηρε Κρονίων·{l]
[l [n}20.307{]}νῦν δὲ δὴ Αἰνείαο βίη Τρώεσσιν ἀνάξει{l]
[l [n}20.308{]}καὶ παίδων παῖδες, τοί κεν μετόπισθε γένωνται.{l]{q]{para]
[para}[l [n}20.309{]}τὸν δʼ ἠμείβετʼ ἔπειτα βοῶπις πότνια Ἥρη·{l]
[q}[l [n}20.310{]}ἐννοσίγαιʼ, αὐτὸς σὺ μετὰ φρεσὶ σῇσι νόησον{l]
[l [n}20.311{]}Αἰνείαν ἤ κέν μιν ἐρύσσεαι ἦ κεν ἐάσῃς{l]
[l [n}20.312{]}Πηλεΐδῃ Ἀχιλῆϊ δαμήμεναι, ἐσθλὸν ἐόντα.{l]
[l [n}20.313{]}ἤτοι μὲν γὰρ νῶϊ πολέας ὠμόσσαμεν ὅρκους{l]
[l [n}20.314{]}πᾶσι μετʼ ἀθανάτοισιν ἐγὼ καὶ Παλλὰς Ἀθήνη{l]
[l [n}20.315{]}μή ποτʼ ἐπὶ Τρώεσσιν ἀλεξήσειν κακὸν ἦμαρ,{l]
[l [n}20.316{]}μηδʼ ὁπότʼ ἂν Τροίη μαλερῷ πυρὶ πᾶσα δάηται{l]
[l [n}20.317{]}καιομένη, καίωσι δʼ ἀρήϊοι υἷες Ἀχαιῶν.{l]{q]{para]
[para}[l [n}20.318{]}αὐτὰρ ἐπεὶ τό γʼ ἄκουσε Ποσειδάων ἐνοσίχθων,{l]
[l [n}20.319{]}βῆ ῥʼ ἴμεν ἄν τε μάχην καὶ ἀνὰ κλόνον ἐγχειάων,{l]
[l [n}20.320{]}ἷξε δʼ ὅθʼ Αἰνείας ἠδʼ ὃ κλυτὸς ἦεν Ἀχιλλεύς.{l]
[l [n}20.321{]}αὐτίκα τῷ μὲν ἔπειτα κατʼ ὀφθαλμῶν χέεν ἀχλὺν{l]
[l [n}20.322{]}Πηλεΐδῃ Ἀχιλῆϊ· ὃ δὲ μελίην εὔχαλκον{l]
[l [n}20.323{]}ἀσπίδος ἐξέρυσεν μεγαλήτορος Αἰνείαο·{l]
[l [n}20.324{]}καὶ τὴν μὲν προπάροιθε ποδῶν Ἀχιλῆος ἔθηκεν,{l]
[l [n}20.325{]}Αἰνείαν δʼ ἔσσευεν ἀπὸ χθονὸς ὑψόσʼ ἀείρας.{l]
[l [n}20.326{]}πολλὰς δὲ στίχας ἡρώων, πολλὰς δὲ καὶ ἵππων{l]
[l [n}20.327{]}Αἰνείας ὑπερᾶλτο θεοῦ ἀπὸ χειρὸς ὀρούσας,{l]
[l [n}20.328{]}ἷξε δʼ ἐπʼ ἐσχατιὴν πολυάϊκος πολέμοιο,{l]
[l [n}20.329{]}ἔνθά τε Καύκωνες πόλεμον μέτα θωρήσσοντο.{l]
[l [n}20.330{]}τῷ δὲ μάλʼ ἐγγύθεν ἦλθε Ποσειδάων ἐνοσίχθων,{l]
[l [n}20.331{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}20.332{]}Αἰνεία, τίς σʼ ὧδε θεῶν ἀτέοντα κελεύει{l]
[l [n}20.333{]}ἀντία Πηλεΐωνος ὑπερθύμοιο μάχεσθαι,{l]
[l [n}20.334{]}ὃς σεῦ ἅμα κρείσσων καὶ φίλτερος ἀθανάτοισιν;{l]
[l [n}20.335{]}ἀλλʼ ἀναχωρῆσαι ὅτε κεν συμβλήσεαι αὐτῷ,{l]
[l [n}20.336{]}μὴ καὶ ὑπὲρ μοῖραν δόμον Ἄϊδος εἰσαφίκηαι.{l]
[l [n}20.337{]}αὐτὰρ ἐπεί κʼ Ἀχιλεὺς θάνατον καὶ πότμον ἐπίσπῃ,{l]
[l [n}20.338{]}θαρσήσας δὴ ἔπειτα μετὰ πρώτοισι μάχεσθαι·{l]
[l [n}20.339{]}οὐ μὲν γάρ τίς σʼ ἄλλος Ἀχαιῶν ἐξεναρίξει.{l]{q]{para]
[para}[l [n}20.340{]}ὣς εἰπὼν λίπεν αὐτόθʼ, ἐπεὶ διεπέφραδε πάντα.{l]
[l [n}20.341{]}αἶψα δʼ ἔπειτʼ Ἀχιλῆος ἀπʼ ὀφθαλμῶν σκέδασʼ ἀχλὺν{l]
[l [n}20.342{]}θεσπεσίην· ὃ δʼ ἔπειτα μέγʼ ἔξιδεν ὀφθαλμοῖσιν,{l]
[l [n}20.343{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}20.344{]}ὢ πόποι ἦ μέγα θαῦμα τόδʼ ὀφθαλμοῖσιν ὁρῶμαι·{l]
[l [n}20.345{]}ἔγχος μὲν τόδε κεῖται ἐπὶ χθονός, οὐδέ τι φῶτα{l]
[l [n}20.346{]}λεύσσω, τῷ ἐφέηκα κατακτάμεναι μενεαίνων.{l]
[l [n}20.347{]}ἦ ῥα καὶ Αἰνείας φίλος ἀθανάτοισι θεοῖσιν{l]
[l [n}20.348{]}ἦεν· ἀτάρ μιν ἔφην μὰψ αὔτως εὐχετάασθαι.{l]
[l [n}20.349{]}ἐρρέτω· οὔ οἱ θυμὸς ἐμεῦ ἔτι πειρηθῆναι{l]
[l [n}20.350{]}ἔσσεται, ὃς καὶ νῦν φύγεν ἄσμενος ἐκ θανάτοιο.{l]
[l [n}20.351{]}ἀλλʼ ἄγε δὴ Δαναοῖσι φιλοπτολέμοισι κελεύσας{l]
[l [n}20.352{]}τῶν ἄλλων Τρώων πειρήσομαι ἀντίος ἐλθών.{l]{q]{para]
[para}[l [n}20.353{]}ἦ, καὶ ἐπὶ στίχας ἆλτο, κέλευε δὲ φωτὶ ἑκάστῳ·{l]
[q}[l [n}20.354{]}μηκέτι νῦν Τρώων ἑκὰς ἕστατε δῖοι Ἀχαιοί,{l]
[l [n}20.355{]}ἀλλʼ ἄγʼ ἀνὴρ ἄντʼ ἀνδρὸς ἴτω, μεμάτω δὲ μάχεσθαι.{l]
[l [n}20.356{]}ἀργαλέον δέ μοί ἐστι καὶ ἰφθίμῳ περ ἐόντι{l]
[l [n}20.357{]}τοσσούσδʼ ἀνθρώπους ἐφέπειν καὶ πᾶσι μάχεσθαι·{l]
[l [n}20.358{]}οὐδέ κʼ Ἄρης, ὅς περ θεὸς ἄμβροτος, οὐδέ κʼ Ἀθήνη{l]
[l [n}20.359{]}τοσσῆσδʼ ὑσμίνης ἐφέποι στόμα καὶ πονέοιτο·{l]
[l [n}20.360{]}ἀλλʼ ὅσσον μὲν ἐγὼ δύναμαι χερσίν τε ποσίν τε{l]
[l [n}20.361{]}καὶ σθένει, οὔ μʼ ἔτι φημὶ μεθησέμεν οὐδʼ ἠβαιόν,{l]
[l [n}20.362{]}ἀλλὰ μάλα στιχὸς εἶμι διαμπερές, οὐδέ τινʼ οἴω{l]
[l [n}20.363{]}Τρώων χαιρήσειν, ὅς τις σχεδὸν ἔγχεος ἔλθῃ.{l]{q]{para]
[para}[l [n}20.364{]}ὣς φάτʼ ἐποτρύνων· Τρώεσσι δὲ φαίδιμος Ἕκτωρ{l]
[l [n}20.365{]}κέκλεθʼ ὁμοκλήσας, φάτο δʼ ἴμεναι ἄντʼ Ἀχιλῆος·{l]
[q}[l [n}20.366{]}Τρῶες ὑπέρθυμοι μὴ δείδιτε Πηλεΐωνα.{l]
[l [n}20.367{]}καί κεν ἐγὼ ἐπέεσσι καὶ ἀθανάτοισι μαχοίμην,{l]
[l [n}20.368{]}ἔγχεϊ δʼ ἀργαλέον, ἐπεὶ ἦ πολὺ φέρτεροί εἰσιν.{l]
[l [n}20.369{]}οὐδʼ Ἀχιλεὺς πάντεσσι τέλος μύθοις ἐπιθήσει,{l]
[l [n}20.370{]}ἀλλὰ τὸ μὲν τελέει, τὸ δὲ καὶ μεσσηγὺ κολούει.{l]
[l [n}20.371{]}τοῦ δʼ ἐγὼ ἀντίος εἶμι καὶ εἰ πυρὶ χεῖρας ἔοικεν,{l]
[l [n}20.372{]}εἰ πυρὶ χεῖρας ἔοικε, μένος δʼ αἴθωνι σιδήρῳ.{l]{q]{para]
[para}[l [n}20.373{]}ὣς φάτʼ ἐποτρύνων, οἳ δʼ ἀντίοι ἔγχεʼ ἄειραν{l]
[l [n}20.374{]}Τρῶες· τῶν δʼ ἄμυδις μίχθη μένος, ὦρτο δʼ ἀϋτή.{l]
[l [n}20.375{]}καὶ τότʼ ἄρʼ Ἕκτορα εἶπε παραστὰς Φοῖβος Ἀπόλλων·{l]
[q}[l [n}20.376{]}Ἕκτορ μηκέτι πάμπαν Ἀχιλλῆϊ προμάχιζε,{l]
[l [n}20.377{]}ἀλλὰ κατὰ πληθύν τε καὶ ἐκ φλοίσβοιο δέδεξο,{l]
[l [n}20.378{]}μή πώς σʼ ἠὲ βάλῃ ἠὲ σχεδὸν ἄορι τύψῃ.{l]{q]{para]
[para}[l [n}20.379{]}ὣς ἔφαθʼ, Ἕκτωρ δʼ αὖτις ἐδύσετο οὐλαμὸν ἀνδρῶν{l]
[l [n}20.380{]}ταρβήσας, ὅτʼ ἄκουσε θεοῦ ὄπα φωνήσαντος.{l]
[l [n}20.381{]}ἐν δʼ Ἀχιλεὺς Τρώεσσι θόρε φρεσὶν εἱμένος ἀλκὴν{l]
[l [n}20.382{]}σμερδαλέα ἰάχων, πρῶτον δʼ ἕλεν Ἰφιτίωνα{l]
[l [n}20.383{]}ἐσθλὸν Ὀτρυντεΐδην πολέων ἡγήτορα λαῶν,{l]
[l [n}20.384{]}ὃν νύμφη τέκε νηῒς Ὀτρυντῆϊ πτολιπόρθῳ{l]
[l [n}20.385{]}Τμώλῳ ὕπο νιφόεντι Ὕδης ἐν πίονι δήμῳ·{l]
[l [n}20.386{]}τὸν δʼ ἰθὺς μεμαῶτα βάλʼ ἔγχεϊ δῖος Ἀχιλλεὺς{l]
[l [n}20.387{]}μέσσην κὰκ κεφαλήν· ἣ δʼ ἄνδιχα πᾶσα κεάσθη,{l]
[l [n}20.388{]}δούπησεν δὲ πεσών, ὃ δʼ ἐπεύξατο δῖος Ἀχιλλεύς·{l]
[q}[l [n}20.389{]}κεῖσαι Ὀτρυντεΐδη πάντων ἐκπαγλότατʼ ἀνδρῶν·{l]
[l [n}20.390{]}ἐνθάδε τοι θάνατος, γενεὴ δέ τοί ἐστʼ ἐπὶ λίμνῃ{l]
[l [n}20.391{]}Γυγαίῃ, ὅθι τοι τέμενος πατρώϊόν ἐστιν{l]
[l [n}20.392{]}Ὕλλῳ ἐπʼ ἰχθυόεντι καὶ Ἕρμῳ δινήεντι.{l]{q]{para]
[para}[l [n}20.393{]}ὣς ἔφατʼ εὐχόμενος, τὸν δὲ σκότος ὄσσε κάλυψε.{l]
[l [n}20.394{]}τὸν μὲν Ἀχαιῶν ἵπποι ἐπισσώτροις δατέοντο{l]
[l [n}20.395{]}πρώτῃ ἐν ὑσμίνῃ· ὃ δʼ ἐπʼ αὐτῷ Δημολέοντα{l]
[l [n}20.396{]}ἐσθλὸν ἀλεξητῆρα μάχης Ἀντήνορος υἱὸν{l]
[l [n}20.397{]}νύξε κατὰ κρόταφον, κυνέης διὰ χαλκοπαρῄου.{l]
[l [n}20.398{]}οὐδʼ ἄρα χαλκείη κόρυς ἔσχεθεν, ἀλλὰ διʼ αὐτῆς{l]
[l [n}20.399{]}αἰχμὴ ἱεμένη ῥῆξʼ ὀστέον, ἐγκέφαλος δὲ{l]
[l [n}20.400{]}ἔνδον ἅπας πεπάλακτο· δάμασσε δέ μιν μεμαῶτα.{l]
[l [n}20.401{]}Ἱπποδάμαντα δʼ ἔπειτα καθʼ ἵππων ἀΐξαντα{l]
[l [n}20.402{]}πρόσθεν ἕθεν φεύγοντα μετάφρενον οὔτασε δουρί.{l]
[l [n}20.403{]}αὐτὰρ ὃ θυμὸν ἄϊσθε καὶ ἤρυγεν, ὡς ὅτε ταῦρος{l]
[l [n}20.404{]}ἤρυγεν ἑλκόμενος Ἑλικώνιον ἀμφὶ ἄνακτα{l]
[l [n}20.405{]}κούρων ἑλκόντων· γάνυται δέ τε τοῖς ἐνοσίχθων·{l]
[l [n}20.406{]}ὣς ἄρα τόν γʼ ἐρυγόντα λίπʼ ὀστέα θυμὸς ἀγήνωρ·{l]
[l [n}20.407{]}αὐτὰρ ὃ βῆ σὺν δουρὶ μετʼ ἀντίθεον Πολύδωρον{l]
[l [n}20.408{]}Πριαμίδην. τὸν δʼ οὔ τι πατὴρ εἴασκε μάχεσθαι,{l]
[l [n}20.409{]}οὕνεκά οἱ μετὰ παισὶ νεώτατος ἔσκε γόνοιο,{l]
[l [n}20.410{]}καί οἱ φίλτατος ἔσκε, πόδεσσι δὲ πάντας ἐνίκα{l]
[l [n}20.411{]}δὴ τότε νηπιέῃσι ποδῶν ἀρετὴν ἀναφαίνων{l]
[l [n}20.412{]}θῦνε διὰ προμάχων, εἷος φίλον ὤλεσε θυμόν.{l]
[l [n}20.413{]}τὸν βάλε μέσσον ἄκοντι ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}20.414{]}νῶτα παραΐσσοντος, ὅθι ζωστῆρος ὀχῆες{l]
[l [n}20.415{]}χρύσειοι σύνεχον καὶ διπλόος ἤντετο θώρηξ·{l]
[l [n}20.416{]}ἀντικρὺ δὲ διέσχε παρʼ ὀμφαλὸν ἔγχεος αἰχμή,{l]
[l [n}20.417{]}γνὺξ δʼ ἔριπʼ οἰμώξας, νεφέλη δέ μιν ἀμφεκάλυψε{l]
[l [n}20.418{]}κυανέη, προτὶ οἷ δʼ ἔλαβʼ ἔντερα χερσὶ λιασθείς.{l]{para]
[para}[l [n}20.419{]}Ἕκτωρ δʼ ὡς ἐνόησε κασίγνητον Πολύδωρον{l]
[l [n}20.420{]}ἔντερα χερσὶν ἔχοντα λιαζόμενον ποτὶ γαίη{l]
[l [n}20.421{]}κάρ ῥά οἱ ὀφθαλμῶν κέχυτʼ ἀχλύς· οὐδʼ ἄρʼ ἔτʼ ἔτλη{l]
[l [n}20.422{]}δηρὸν ἑκὰς στρωφᾶσθʼ, ἀλλʼ ἀντίος ἦλθʼ Ἀχιλῆϊ{l]
[l [n}20.423{]}ὀξὺ δόρυ κραδάων φλογὶ εἴκελος· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}20.424{]}ὡς εἶδʼ, ὣς ἀνεπᾶλτο, καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}20.425{]}ἐγγὺς ἀνὴρ ὃς ἐμόν γε μάλιστʼ ἐσεμάσσατο θυμόν,{l]
[l [n}20.426{]}ὅς μοι ἑταῖρον ἔπεφνε τετιμένον· οὐδʼ ἂν ἔτι δὴν{l]
[l [n}20.427{]}ἀλλήλους πτώσσοιμεν ἀνὰ πτολέμοιο γεφύρας.{l]{q]{para]
[para}[l [n}20.428{]}ἦ, καὶ ὑπόδρα ἰδὼν προσεφώνεεν Ἕκτορα δῖον·{l]
[q}[l [n}20.429{]}ἆσσον ἴθʼ ὥς κεν θᾶσσον ὀλέθρου πείραθʼ ἵκηαι.{l]{q]{para]
[para}[l [n}20.430{]}τὸν δʼ οὐ ταρβήσας προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}20.431{]}Πηλεΐδη μὴ δὴ ἐπέεσσί με νηπύτιον ὣς{l]
[l [n}20.432{]}ἔλπεο δειδίξεσθαι, ἐπεὶ σάφα οἶδα καὶ αὐτὸς{l]
[l [n}20.433{]}ἠμὲν κερτομίας ἠδʼ αἴσυλα μυθήσασθαι.{l]
[l [n}20.434{]}οἶδα δʼ ὅτι σὺ μὲν ἐσθλός, ἐγὼ δὲ σέθεν πολὺ χείρων.{l]
[l [n}20.435{]}ἀλλʼ ἤτοι μὲν ταῦτα θεῶν ἐν γούνασι κεῖται,{l]
[l [n}20.436{]}αἴ κέ σε χειρότερός περ ἐὼν ἀπὸ θυμὸν ἕλωμαι{l]
[l [n}20.437{]}δουρὶ βαλών, ἐπεὶ ἦ καὶ ἐμὸν βέλος ὀξὺ πάροιθεν.{l]{q]{para]
[para}[l [n}20.438{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δόρυ, καὶ τό γʼ Ἀθήνη{l]
[l [n}20.439{]}πνοιῇ Ἀχιλλῆος πάλιν ἔτραπε κυδαλίμοιο{l]
[l [n}20.440{]}ἦκα μάλα ψύξασα· τὸ δʼ ἂψ ἵκεθʼ Ἕκτορα δῖον,{l]
[l [n}20.441{]}αὐτοῦ δὲ προπάροιθε ποδῶν πέσεν. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}20.442{]}ἐμμεμαὼς ἐπόρουσε κατακτάμεναι μενεαίνων,{l]
[l [n}20.443{]}σμερδαλέα ἰάχων· τὸν δʼ ἐξήρπαξεν Ἀπόλλων{l]
[l [n}20.444{]}ῥεῖα μάλʼ ὥς τε θεός, ἐκάλυψε δʼ ἄρʼ ἠέρι πολλῇ.{l]
[l [n}20.445{]}τρὶς μὲν ἔπειτʼ ἐπόρουσε ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}20.446{]}ἔγχεϊ χαλκείῳ, τρὶς δʼ ἠέρα τύψε βαθεῖαν.{l]
[l [n}20.447{]}ἀλλʼ ὅτε δὴ τὸ τέταρτον ἐπέσσυτο δαίμονι ἶσος,{l]
[l [n}20.448{]}δεινὰ δʼ ὁμοκλήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}20.449{]}ἐξ αὖ νῦν ἔφυγες θάνατον κύον· ἦ τέ τοι ἄγχι{l]
[l [n}20.450{]}ἦλθε κακόν· νῦν αὖτέ σʼ ἐρύσατο Φοῖβος Ἀπόλλων,{l]
[l [n}20.451{]}ᾧ μέλλεις εὔχεσθαι ἰὼν ἐς δοῦπον ἀκόντων.{l]
[l [n}20.452{]}ἦ θήν σʼ ἐξανύω γε καὶ ὕστερον ἀντιβολήσας,{l]
[l [n}20.453{]}εἴ πού τις καὶ ἔμοιγε θεῶν ἐπιτάρροθός ἐστι.{l]
[l [n}20.454{]}νῦν αὖ τοὺς ἄλλους ἐπιείσομαι, ὅν κε κιχείω.{l]{q]{para]
[para}[l [n}20.455{]}ὣς εἰπὼν Δρύοπʼ οὖτα κατʼ αὐχένα μέσσον ἄκοντι·{l]
[l [n}20.456{]}ἤριπε δὲ προπάροιθε ποδῶν· ὃ δὲ τὸν μὲν ἔασε,{l]
[l [n}20.457{]}Δημοῦχον δὲ Φιλητορίδην ἠΰν τε μέγαν τε{l]
[l [n}20.458{]}κὰγ γόνυ δουρὶ βαλὼν ἠρύκακε. τὸν μὲν ἔπειτα{l]
[l [n}20.459{]}οὐτάζων ξίφεϊ μεγάλῳ ἐξαίνυτο θυμόν·{l]
[l [n}20.460{]}αὐτὰρ ὃ Λαόγονον καὶ Δάρδανον υἷε Βίαντος{l]
[l [n}20.461{]}ἄμφω ἐφορμηθεὶς ἐξ ἵππων ὦσε χαμᾶζε,{l]
[l [n}20.462{]}τὸν μὲν δουρὶ βαλών, τὸν δὲ σχεδὸν ἄορι τύψας.{l]
[l [n}20.463{]}Τρῶα δʼ Ἀλαστορίδην, ὃ μὲν ἀντίος ἤλυθε γούνων,{l]
[l [n}20.464{]}εἴ πώς εὑ πεφίδοιτο λαβὼν καὶ ζωὸν ἀφείη{l]
[l [n}20.465{]}μηδὲ κατακτείνειεν ὁμηλικίην ἐλεήσας,{l]
[l [n}20.466{]}νήπιος, οὐδὲ τὸ ᾔδη ὃ οὐ πείσεσθαι ἔμελλεν·{l]
[l [n}20.467{]}οὐ γάρ τι γλυκύθυμος ἀνὴρ ἦν οὐδʼ ἀγανόφρων,{l]
[l [n}20.468{]}ἀλλὰ μάλʼ ἐμμεμαώς· ὃ μὲν ἥπτετο χείρεσι γούνων{l]
[l [n}20.469{]}ἱέμενος λίσσεσθʼ, ὃ δὲ φασγάνῳ οὖτα καθʼ ἧπαρ·{l]
[l [n}20.470{]}ἐκ δέ οἱ ἧπαρ ὄλισθεν, ἀτὰρ μέλαν αἷμα κατʼ αὐτοῦ{l]
[l [n}20.471{]}κόλπον ἐνέπλησεν· τὸν δὲ σκότος ὄσσε κάλυψε{l]
[l [n}20.472{]}θυμοῦ δευόμενον· ὃ δὲ Μούλιον οὖτα παραστὰς{l]
[l [n}20.473{]}δουρὶ κατʼ οὖς· εἶθαρ δὲ διʼ οὔατος ἦλθʼ ἑτέροιο{l]
[l [n}20.474{]}αἰχμὴ χαλκείη· ὃ δʼ Ἀγήνορος υἱὸν Ἔχεκλον{l]
[l [n}20.475{]}μέσσην κὰκ κεφαλὴν ξίφει ἤλασε κωπήεντι,{l]
[l [n}20.476{]}πᾶν δʼ ὑπεθερμάνθη ξίφος αἵματι· τὸν δὲ κατʼ ὄσσε{l]
[l [n}20.477{]}ἔλλαβε πορφύρεος θάνατος καὶ μοῖρα κραταιή.{l]
[l [n}20.478{]}Δευκαλίωνα δʼ ἔπειθʼ, ἵνα τε ξυνέχουσι τένοντες{l]
[l [n}20.479{]}ἀγκῶνος, τῇ τόν γε φίλης διὰ χειρὸς ἔπειρεν{l]
[l [n}20.480{]}αἰχμῇ χαλκείῃ· ὃ δέ μιν μένε χεῖρα βαρυνθεὶς{l]
[l [n}20.481{]}πρόσθʼ ὁρόων θάνατον· ὃ δὲ φασγάνῳ αὐχένα θείνας{l]
[l [n}20.482{]}τῆλʼ αὐτῇ πήληκι κάρη βάλε· μυελὸς αὖτε{l]
[l [n}20.483{]}σφονδυλίων ἔκπαλθʼ, ὃ δʼ ἐπὶ χθονὶ κεῖτο τανυσθείς.{l]
[l [n}20.484{]}αὐτὰρ ὃ βῆ ῥʼ ἰέναι μετʼ ἀμύμονα Πείρεω υἱὸν{l]
[l [n}20.485{]}Ῥίγμον, ὃς ἐκ Θρῄκης ἐριβώλακος εἰληλούθει·{l]
[l [n}20.486{]}τὸν βάλε μέσσον ἄκοντι, πάγη δʼ ἐν νηδύϊ χαλκός,{l]
[l [n}20.487{]}ἤριπε δʼ ἐξ ὀχέων· ὃ δʼ Ἀρηΐθοον θεράποντα{l]
[l [n}20.488{]}ἂψ ἵππους στρέψαντα μετάφρενον ὀξέϊ δουρὶ{l]
[l [n}20.489{]}νύξʼ, ἀπὸ δʼ ἅρματος ὦσε· κυκήθησαν δέ οἱ ἵπποι.{l]{para]
[para}[l [n}20.490{]}ὡς δʼ ἀναμαιμάει βαθέʼ ἄγκεα θεσπιδαὲς πῦρ{l]
[l [n}20.491{]}οὔρεος ἀζαλέοιο, βαθεῖα δὲ καίεται ὕλη,{l]
[l [n}20.492{]}πάντῃ τε κλονέων ἄνεμος φλόγα εἰλυφάζει,{l]
[l [n}20.493{]}ὣς ὅ γε πάντῃ θῦνε σὺν ἔγχεϊ δαίμονι ἶσος{l]
[l [n}20.494{]}κτεινομένους ἐφέπων· ῥέε δʼ αἵματι γαῖα μέλαινα.{l]
[l [n}20.495{]}ὡς δʼ ὅτε τις ζεύξῃ βόας ἄρσενας εὐρυμετώπους{l]
[l [n}20.496{]}τριβέμεναι κρῖ λευκὸν ἐϋκτιμένῃ ἐν ἀλωῇ,{l]
[l [n}20.497{]}ῥίμφά τε λέπτʼ ἐγένοντο βοῶν ὑπὸ πόσσʼ ἐριμύκων,{l]
[l [n}20.498{]}ὣς ὑπʼ Ἀχιλλῆος μεγαθύμου μώνυχες ἵπποι{l]
[l [n}20.499{]}στεῖβον ὁμοῦ νέκυάς τε καὶ ἀσπίδας· αἵματι δʼ ἄξων{l]
[l [n}20.500{]}νέρθεν ἅπας πεπάλακτο καὶ ἄντυγες αἳ περὶ δίφρον,{l]
[l [n}20.501{]}ἃς ἄρʼ ἀφʼ ἱππείων ὁπλέων ῥαθάμιγγες ἔβαλλον{l]
[l [n}20.502{]}αἵ τʼ ἀπʼ ἐπισσώτρων· ὃ δὲ ἵετο κῦδος ἀρέσθαι{l]
[l [n}20.503{]}Πηλεΐδης, λύθρῳ δὲ παλάσσετο χεῖρας ἀάπτους.{l]{para]
{book]
[book [n}21{]}[l [n}21.1{]}ἀλλʼ ὅτε δὴ πόρον ἷξον ἐϋρρεῖος ποταμοῖο{l]
[l [n}21.2{]}Ξάνθου δινήεντος, ὃν ἀθάνατος τέκετο Ζεύς,{l]
[l [n}21.3{]}ἔνθα διατμήξας τοὺς μὲν πεδίον δὲ δίωκε{l]
[l [n}21.4{]}πρὸς πόλιν, ᾗ περ Ἀχαιοὶ ἀτυζόμενοι φοβέοντο{l]
[l [n}21.5{]}ἤματι τῷ προτέρῳ, ὅτε μαίνετο φαίδιμος Ἕκτωρ·{l]
[l [n}21.6{]}τῇ ῥʼ οἵ γε προχέοντο πεφυζότες, ἠέρα δʼ Ἥρη{l]
[l [n}21.7{]}πίτνα πρόσθε βαθεῖαν ἐρυκέμεν· ἡμίσεες δὲ{l]
[l [n}21.8{]}ἐς ποταμὸν εἰλεῦντο βαθύρροον ἀργυροδίνην,{l]
[l [n}21.9{]}ἐν δʼ ἔπεσον μεγάλῳ πατάγῳ, βράχε δʼ αἰπὰ ῥέεθρα,{l]
[l [n}21.10{]}ὄχθαι δʼ ἀμφὶ περὶ μεγάλʼ ἴαχον· οἳ δʼ ἀλαλητῷ{l]
[l [n}21.11{]}ἔννεον ἔνθα καὶ ἔνθα ἑλισσόμενοι περὶ δίνας.{l]
[l [n}21.12{]}ὡς δʼ ὅθʼ ὑπὸ ῥιπῆς πυρὸς ἀκρίδες ἠερέθονται{l]
[l [n}21.13{]}φευγέμεναι ποταμὸν δέ· τὸ δὲ φλέγει ἀκάματον πῦρ{l]
[l [n}21.14{]}ὄρμενον ἐξαίφνης, ταὶ δὲ πτώσσουσι καθʼ ὕδωρ·{l]
[l [n}21.15{]}ὣς ὑπʼ Ἀχιλλῆος Ξάνθου βαθυδινήεντος{l]
[l [n}21.16{]}πλῆτο ῥόος κελάδων ἐπιμὶξ ἵππων τε καὶ ἀνδρῶν.{l]
[para}[l [n}21.17{]}αὐτὰρ ὃ διογενὴς δόρυ μὲν λίπεν αὐτοῦ ἐπʼ ὄχθῃ{l]
[l [n}21.18{]}κεκλιμένον μυρίκῃσιν, ὃ δʼ ἔσθορε δαίμονι ἶσος{l]
[l [n}21.19{]}φάσγανον οἶον ἔχων, κακὰ δὲ φρεσὶ μήδετο ἔργα,{l]
[l [n}21.20{]}τύπτε δʼ ἐπιστροφάδην· τῶν δὲ στόνος ὄρνυτʼ ἀεικὴς{l]
[l [n}21.21{]}ἄορι θεινομένων, ἐρυθαίνετο δʼ αἵματι ὕδωρ.{l]
[l [n}21.22{]}ὡς δʼ ὑπὸ δελφῖνος μεγακήτεος ἰχθύες ἄλλοι{l]
[l [n}21.23{]}φεύγοντες πιμπλᾶσι μυχοὺς λιμένος εὐόρμου{l]
[l [n}21.24{]}δειδιότες· μάλα γάρ τε κατεσθίει ὅν κε λάβῃσιν·{l]
[l [n}21.25{]}ὣς Τρῶες ποταμοῖο κατὰ δεινοῖο ῥέεθρα{l]
[l [n}21.26{]}πτῶσσον ὑπὸ κρημνούς. ὃ δʼ ἐπεὶ κάμε χεῖρας ἐναίρων,{l]
[l [n}21.27{]}ζωοὺς ἐκ ποταμοῖο δυώδεκα λέξατο κούρους{l]
[l [n}21.28{]}ποινὴν Πατρόκλοιο Μενοιτιάδαο θανόντος·{l]
[l [n}21.29{]}τοὺς ἐξῆγε θύραζε τεθηπότας ἠΰτε νεβρούς,{l]
[l [n}21.30{]}δῆσε δʼ ὀπίσσω χεῖρας ἐϋτμήτοισιν ἱμᾶσι,{l]
[l [n}21.31{]}τοὺς αὐτοὶ φορέεσκον ἐπὶ στρεπτοῖσι χιτῶσι,{l]
[l [n}21.32{]}δῶκε δʼ ἑταίροισιν κατάγειν κοίλας ἐπὶ νῆας.{l]
[l [n}21.33{]}αὐτὰρ ὃ ἂψ ἐπόρουσε δαϊζέμεναι μενεαίνων.{l]{para]
[para}[l [n}21.34{]}ἔνθʼ υἷι Πριάμοιο συνήντετο Δαρδανίδαο{l]
[l [n}21.35{]}ἐκ ποταμοῦ φεύγοντι Λυκάονι, τόν ῥά ποτʼ αὐτὸς{l]
[l [n}21.36{]}ἦγε λαβὼν ἐκ πατρὸς ἀλωῆς οὐκ ἐθέλοντα{l]
[l [n}21.37{]}ἐννύχιος προμολών· ὃ δʼ ἐρινεὸν ὀξέϊ χαλκῷ{l]
[l [n}21.38{]}τάμνε νέους ὄρπηκας, ἵνʼ ἅρματος ἄντυγες εἶεν·{l]
[l [n}21.39{]}τῷ δʼ ἄρʼ ἀνώϊστον κακὸν ἤλυθε δῖος Ἀχιλλεύς.{l]
[l [n}21.40{]}καὶ τότε μέν μιν Λῆμνον ἐϋκτιμένην ἐπέρασσε{l]
[l [n}21.41{]}νηυσὶν ἄγων, ἀτὰρ υἱὸς Ἰήσονος ὦνον ἔδωκε·{l]
[l [n}21.42{]}κεῖθεν δὲ ξεῖνός μιν ἐλύσατο πολλὰ δʼ ἔδωκεν{l]
[l [n}21.43{]}Ἴμβριος Ἠετίων, πέμψεν δʼ ἐς δῖαν Ἀρίσβην·{l]
[l [n}21.44{]}ἔνθεν ὑπεκπροφυγὼν πατρώϊον ἵκετο δῶμα.{l]
[l [n}21.45{]}ἕνδεκα δʼ ἤματα θυμὸν ἐτέρπετο οἷσι φίλοισιν{l]
[l [n}21.46{]}ἐλθὼν ἐκ Λήμνοιο· δυωδεκάτῃ δέ μιν αὖτις{l]
[l [n}21.47{]}χερσὶν Ἀχιλλῆος θεὸς ἔμβαλεν, ὅς μιν ἔμελλε{l]
[l [n}21.48{]}πέμψειν εἰς Ἀΐδαο καὶ οὐκ ἐθέλοντα νέεσθαι.{l]
[l [n}21.49{]}τὸν δʼ ὡς οὖν ἐνόησε ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}21.50{]}γυμνὸν ἄτερ κόρυθός τε καὶ ἀσπίδος, οὐδʼ ἔχεν ἔγχος,{l]
[l [n}21.51{]}ἀλλὰ τὰ μέν ῥʼ ἀπὸ πάντα χαμαὶ βάλε· τεῖρε γὰρ ἱδρὼς{l]
[l [n}21.52{]}φεύγοντʼ ἐκ ποταμοῦ, κάματος δʼ ὑπὸ γούνατʼ ἐδάμνα·{l]
[l [n}21.53{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}21.54{]}ὢ πόποι ἦ μέγα θαῦμα τόδʼ ὀφθαλμοῖσιν ὁρῶμαι·{l]
[l [n}21.55{]}ἦ μάλα δὴ Τρῶες μεγαλήτορες οὕς περ ἔπεφνον{l]
[l [n}21.56{]}αὖτις ἀναστήσονται ὑπὸ ζόφου ἠερόεντος,{l]
[l [n}21.57{]}οἷον δὴ καὶ ὅδʼ ἦλθε φυγὼν ὕπο νηλεὲς ἦμαρ{l]
[l [n}21.58{]}Λῆμνον ἐς ἠγαθέην πεπερημένος· οὐδέ μιν ἔσχε{l]
[l [n}21.59{]}πόντος ἁλὸς πολιῆς, ὃ πολέας ἀέκοντας ἐρύκει.{l]
[l [n}21.60{]}ἀλλʼ ἄγε δὴ καὶ δουρὸς ἀκωκῆς ἡμετέροιο{l]
[l [n}21.61{]}γεύσεται, ὄφρα ἴδωμαι ἐνὶ φρεσὶν ἠδὲ δαείω{l]
[l [n}21.62{]}ἢ ἄρʼ ὁμῶς καὶ κεῖθεν ἐλεύσεται, ἦ μιν ἐρύξει{l]
[l [n}21.63{]}γῆ φυσίζοος, ἥ τε κατὰ κρατερόν περ ἐρύκει.{l]{q]{para]
[para}[l [n}21.64{]}ὣς ὅρμαινε μένων· ὃ δέ οἱ σχεδὸν ἦλθε τεθηπὼς{l]
[l [n}21.65{]}γούνων ἅψασθαι μεμαώς, περὶ δʼ ἤθελε θυμῷ{l]
[l [n}21.66{]}ἐκφυγέειν θάνατόν τε κακὸν καὶ κῆρα μέλαιναν.{l]
[l [n}21.67{]}ἤτοι ὃ μὲν δόρυ μακρὸν ἀνέσχετο δῖος Ἀχιλλεὺς{l]
[l [n}21.68{]}οὐτάμεναι μεμαώς, ὃ δʼ ὑπέδραμε καὶ λάβε γούνων{l]
[l [n}21.69{]}κύψας· ἐγχείη δʼ ἄρʼ ὑπὲρ νώτου ἐνὶ γαίῃ{l]
[l [n}21.70{]}ἔστη ἱεμένη χροὸς ἄμεναι ἀνδρομέοιο.{l]
[l [n}21.71{]}αὐτὰρ ὃ τῇ ἑτέρῃ μὲν ἑλὼν ἐλλίσσετο γούνων,{l]
[l [n}21.72{]}τῇ δʼ ἑτέρῃ ἔχεν ἔγχος ἀκαχμένον οὐδὲ μεθίει·{l]
[l [n}21.73{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}21.74{]}γουνοῦμαι σʼ Ἀχιλεῦ· σὺ δέ μʼ αἴδεο καί μʼ ἐλέησον·{l]
[l [n}21.75{]}ἀντί τοί εἰμʼ ἱκέταο διοτρεφὲς αἰδοίοιο·{l]
[l [n}21.76{]}πὰρ γὰρ σοὶ πρώτῳ πασάμην Δημήτερος ἀκτὴν{l]
[l [n}21.77{]}ἤματι τῷ ὅτε μʼ εἷλες ἐϋκτιμένῃ ἐν ἀλωῇ,{l]
[l [n}21.78{]}καί μʼ ἐπέρασσας ἄνευθεν ἄγων πατρός τε φίλων τε{l]
[l [n}21.79{]}Λῆμνον ἐς ἠγαθέην, ἑκατόμβοιον δέ τοι ἦλφον.{l]
[l [n}21.80{]}νῦν δὲ λύμην τρὶς τόσσα πορών· ἠὼς δέ μοί ἐστιν{l]
[l [n}21.81{]}ἥδε δυωδεκάτη, ὅτʼ ἐς Ἴλιον εἰλήλουθα{l]
[l [n}21.82{]}πολλὰ παθών· νῦν αὖ με τεῇς ἐν χερσὶν ἔθηκε{l]
[l [n}21.83{]}μοῖρʼ ὀλοή· μέλλω που ἀπεχθέσθαι Διὶ πατρί,{l]
[l [n}21.84{]}ὅς με σοὶ αὖτις δῶκε· μινυνθάδιον δέ με μήτηρ{l]
[l [n}21.85{]}γείνατο Λαοθόη θυγάτηρ Ἄλταο γέροντος{l]
[l [n}21.86{]}Ἄλτεω, ὃς Λελέγεσσι φιλοπτολέμοισιν ἀνάσσει{l]
[l [n}21.87{]}Πήδασον αἰπήεσσαν ἔχων ἐπὶ Σατνιόεντι.{l]
[l [n}21.88{]}τοῦ δʼ ἔχε θυγατέρα Πρίαμος, πολλὰς δὲ καὶ ἄλλας·{l]
[l [n}21.89{]}τῆς δὲ δύω γενόμεσθα, σὺ δʼ ἄμφω δειροτομήσεις,{l]
[l [n}21.90{]}ἤτοι τὸν πρώτοισι μετὰ πρυλέεσσι δάμασσας{l]
[l [n}21.91{]}ἀντίθεον Πολύδωρον, ἐπεὶ βάλες ὀξέϊ δουρί·{l]
[l [n}21.92{]}νῦν δὲ δὴ ἐνθάδʼ ἐμοὶ κακὸν ἔσσεται· οὐ γὰρ ὀΐω{l]
[l [n}21.93{]}σὰς χεῖρας φεύξεσθαι, ἐπεί ῥʼ ἐπέλασσέ γε δαίμων.{l]
[l [n}21.94{]}ἄλλο δέ τοι ἐρέω, σὺ δʼ ἐνὶ φρεσὶ βάλλεο σῇσι·{l]
[l [n}21.95{]}μή με κτεῖνʼ, ἐπεὶ οὐχ ὁμογάστριος Ἕκτορός εἰμι,{l]
[l [n}21.96{]}ὅς τοι ἑταῖρον ἔπεφνεν ἐνηέα τε κρατερόν τε.{l]{q]{para]
[para}[l [n}21.97{]}ὣς ἄρα μιν Πριάμοιο προσηύδα φαίδιμος υἱὸς{l]
[l [n}21.98{]}λισσόμενος ἐπέεσσιν, ἀμείλικτον δʼ ὄπʼ ἄκουσε·{l]
[q}[l [n}21.99{]}νήπιε μή μοι ἄποινα πιφαύσκεο μηδʼ ἀγόρευε·{l]
[l [n}21.100{]}πρὶν μὲν γὰρ Πάτροκλον ἐπισπεῖν αἴσιμον ἦμαρ{l]
[l [n}21.101{]}τόφρά τί μοι πεφιδέσθαι ἐνὶ φρεσὶ φίλτερον ἦεν{l]
[l [n}21.102{]}Τρώων, καὶ πολλοὺς ζωοὺς ἕλον ἠδʼ ἐπέρασσα·{l]
[l [n}21.103{]}νῦν δʼ οὐκ ἔσθʼ ὅς τις θάνατον φύγῃ ὅν κε θεός γε{l]
[l [n}21.104{]}Ἰλίου προπάροιθεν ἐμῇς ἐν χερσὶ βάλῃσι{l]
[l [n}21.105{]}καὶ πάντων Τρώων, περὶ δʼ αὖ Πριάμοιό γε παίδων.{l]
[l [n}21.106{]}ἀλλὰ φίλος θάνε καὶ σύ· τί ἦ ὀλοφύρεαι οὕτως;{l]
[l [n}21.107{]}κάτθανε καὶ Πάτροκλος, ὅ περ σέο πολλὸν ἀμείνων.{l]
[l [n}21.108{]}οὐχ ὁράᾳς οἷος καὶ ἐγὼ καλός τε μέγας τε;{l]
[l [n}21.109{]}πατρὸς δʼ εἴμʼ ἀγαθοῖο, θεὰ δέ με γείνατο μήτηρ·{l]
[l [n}21.110{]}ἀλλʼ ἔπι τοι καὶ ἐμοὶ θάνατος καὶ μοῖρα κραταιή·{l]
[l [n}21.111{]}ἔσσεται ἢ ἠὼς ἢ δείλη ἢ μέσον ἦμαρ{l]
[l [n}21.112{]}ὁππότε τις καὶ ἐμεῖο Ἄρῃ ἐκ θυμὸν ἕληται{l]
[l [n}21.113{]}ἢ ὅ γε δουρὶ βαλὼν ἢ ἀπὸ νευρῆφιν ὀϊστῷ.{l]{q]{para]
[para}[l [n}21.114{]}ὣς φάτο, τοῦ δʼ αὐτοῦ λύτο γούνατα καὶ φίλον ἦτορ·{l]
[l [n}21.115{]}ἔγχος μέν ῥʼ ἀφέηκεν, ὃ δʼ ἕζετο χεῖρε πετάσσας{l]
[l [n}21.116{]}ἀμφοτέρας· Ἀχιλεὺς δὲ ἐρυσσάμενος ξίφος ὀξὺ{l]
[l [n}21.117{]}τύψε κατὰ κληῗδα παρʼ αὐχένα, πᾶν δέ οἱ εἴσω{l]
[l [n}21.118{]}δῦ ξίφος ἄμφηκες· ὃ δʼ ἄρα πρηνὴς ἐπὶ γαίῃ{l]
[l [n}21.119{]}κεῖτο ταθείς, ἐκ δʼ αἷμα μέλαν ῥέε, δεῦε δὲ γαῖαν.{l]
[l [n}21.120{]}τὸν δʼ Ἀχιλεὺς ποταμὸν δὲ λαβὼν ποδὸς ἧκε φέρεσθαι,{l]
[l [n}21.121{]}καί οἱ ἐπευχόμενος ἔπεα πτερόεντʼ ἀγόρευεν·{l]
[q}[l [n}21.122{]}ἐνταυθοῖ νῦν κεῖσο μετʼ ἰχθύσιν, οἵ σʼ ὠτειλὴν{l]
[l [n}21.123{]}αἷμʼ ἀπολιχμήσονται ἀκηδέες· οὐδέ σε μήτηρ{l]
[l [n}21.124{]}ἐνθεμένη λεχέεσσι γοήσεται, ἀλλὰ Σκάμανδρος{l]
[l [n}21.125{]}οἴσει δινήεις εἴσω ἁλὸς εὐρέα κόλπον·{l]
[l [n}21.126{]}θρῴσκων τις κατὰ κῦμα μέλαιναν φρῖχʼ ὑπαΐξει{l]
[l [n}21.127{]}ἰχθύς, ὅς κε φάγῃσι Λυκάονος ἀργέτα δημόν.{l]
[l [n}21.128{]}φθείρεσθʼ εἰς ὅ κεν ἄστυ κιχείομεν Ἰλίου ἱρῆς{l]
[l [n}21.129{]}ὑμεῖς μὲν φεύγοντες, ἐγὼ δʼ ὄπιθεν κεραΐζων.{l]
[l [n}21.130{]}οὐδʼ ὑμῖν ποταμός περ ἐΰρροος ἀργυροδίνης{l]
[l [n}21.131{]}ἀρκέσει, ᾧ δὴ δηθὰ πολέας ἱερεύετε ταύρους,{l]
[l [n}21.132{]}ζωοὺς δʼ ἐν δίνῃσι καθίετε μώνυχας ἵππους.{l]
[l [n}21.133{]}ἀλλὰ καὶ ὧς ὀλέεσθε κακὸν μόρον, εἰς ὅ κε πάντες{l]
[l [n}21.134{]}τίσετε Πατρόκλοιο φόνον καὶ λοιγὸν Ἀχαιῶν,{l]
[l [n}21.135{]}οὓς ἐπὶ νηυσὶ θοῇσιν ἐπέφνετε νόσφιν ἐμεῖο.{l]{q]{para]
[para}[l [n}21.136{]}ὣς ἄρʼ ἔφη, ποταμὸς δὲ χολώσατο κηρόθι μᾶλλον,{l]
[l [n}21.137{]}ὅρμηνεν δʼ ἀνὰ θυμὸν ὅπως παύσειε πόνοιο{l]
[l [n}21.138{]}δῖον Ἀχιλλῆα, Τρώεσσι δὲ λοιγὸν ἀλάλκοι.{l]
[l [n}21.139{]}τόφρα δὲ Πηλέος υἱὸς ἔχων δολιχόσκιον ἔγχος{l]
[l [n}21.140{]}Ἀστεροπαίῳ ἐπᾶλτο κατακτάμεναι μενεαίνων{l]
[l [n}21.141{]}υἱέϊ Πηλεγόνος· τὸν δʼ Ἀξιὸς εὐρυρέεθρος{l]
[l [n}21.142{]}γείνατο καὶ Περίβοια Ἀκεσσαμενοῖο θυγατρῶν{l]
[l [n}21.143{]}πρεσβυτάτη· τῇ γάρ ῥα μίγη ποταμὸς βαθυδίνης.{l]
[l [n}21.144{]}τῷ ῥʼ Ἀχιλεὺς ἐπόρουσεν, ὃ δʼ ἀντίος ἐκ ποταμοῖο{l]
[l [n}21.145{]}ἔστη ἔχων δύο δοῦρε· μένος δέ οἱ ἐν φρεσὶ θῆκε{l]
[l [n}21.146{]}Ξάνθος, ἐπεὶ κεχόλωτο δαϊκταμένων αἰζηῶν,{l]
[l [n}21.147{]}τοὺς Ἀχιλεὺς ἐδάϊζε κατὰ ῥόον οὐδʼ ἐλέαιρεν.{l]
[l [n}21.148{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}21.149{]}τὸν πρότερος προσέειπε ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}21.150{]}τίς πόθεν εἰς ἀνδρῶν ὅ μευ ἔτλης ἀντίος ἐλθεῖν;{l]
[l [n}21.151{]}δυστήνων δέ τε παῖδες ἐμῷ μένει ἀντιόωσι.{l]{q]{para]
[para}[l [n}21.152{]}τὸν δʼ αὖ Πηλεγόνος προσεφώνεε φαίδιμος υἱός·{l]
[q}[l [n}21.153{]}Πηλεΐδη μεγάθυμε τί ἦ γενεὴν ἐρεείνεις;{l]
[l [n}21.154{]}εἴμʼ ἐκ Παιονίης ἐριβώλου τηλόθʼ ἐούσης{l]
[l [n}21.155{]}Παίονας ἄνδρας ἄγων δολιχεγχέας· ἥδε δέ μοι νῦν{l]
[l [n}21.156{]}ἠὼς ἑνδεκάτη ὅτε Ἴλιον εἰλήλουθα.{l]
[l [n}21.157{]}αὐτὰρ ἐμοὶ γενεὴ ἐξ Ἀξιοῦ εὐρὺ ῥέοντος{l]
[l [n}21.158{]}Ἀξιοῦ, ὃς κάλλιστον ὕδωρ ἐπὶ γαῖαν ἵησιν,{l]
[l [n}21.159{]}ὃς τέκε Πηλεγόνα κλυτὸν ἔγχεϊ· τὸν δʼ ἐμέ φασι{l]
[l [n}21.160{]}γείνασθαι· νῦν αὖτε μαχώμεθα φαίδιμʼ Ἀχιλλεῦ.{l]{q]{para]
[para}[l [n}21.161{]}ὣς φάτʼ ἀπειλήσας, ὃ δʼ ἀνέσχετο δῖος Ἀχιλλεὺς{l]
[l [n}21.162{]}Πηλιάδα μελίην· ὃ δʼ ἁμαρτῇ δούρασιν ἀμφὶς{l]
[l [n}21.163{]}ἥρως Ἀστεροπαῖος, ἐπεὶ περιδέξιος ἦεν.{l]
[l [n}21.164{]}καί ῥʼ ἑτέρῳ μὲν δουρὶ σάκος βάλεν, οὐδὲ διὰ πρὸ{l]
[l [n}21.165{]}ῥῆξε σάκος· χρυσὸς γὰρ ἐρύκακε δῶρα θεοῖο·{l]
[l [n}21.166{]}τῷ δʼ ἑτέρῳ μιν πῆχυν ἐπιγράβδην βάλε χειρὸς{l]
[l [n}21.167{]}δεξιτερῆς, σύτο δʼ αἷμα κελαινεφές· ἣ δʼ ὑπὲρ αὐτοῦ{l]
[l [n}21.168{]}γαίῃ ἐνεστήρικτο λιλαιομένη χροὸς ἆσαι.{l]
[l [n}21.169{]}δεύτερος αὖτʼ Ἀχιλεὺς μελίην ἰθυπτίωνα{l]
[l [n}21.170{]}Ἀστεροπαίῳ ἐφῆκε κατακτάμεναι μενεαίνων.{l]
[l [n}21.171{]}καὶ τοῦ μέν ῥʼ ἀφάμαρτεν, ὃ δʼ ὑψηλὴν βάλεν ὄχθην,{l]
[l [n}21.172{]}μεσσοπαγὲς δʼ ἄρʼ ἔθηκε κατʼ ὄχθης μείλινον ἔγχος.{l]
[l [n}21.173{]}Πηλεΐδης δʼ ἄορ ὀξὺ ἐρυσσάμενος παρὰ μηροῦ{l]
[l [n}21.174{]}ἆλτʼ ἐπί οἱ μεμαώς· ὃ δʼ ἄρα μελίην Ἀχιλῆος{l]
[l [n}21.175{]}οὐ δύνατʼ ἐκ κρημνοῖο ἐρύσσαι χειρὶ παχείῃ.{l]
[l [n}21.176{]}τρὶς μέν μιν πελέμιξεν ἐρύσσασθαι μενεαίνων,{l]
[l [n}21.177{]}τρὶς δὲ μεθῆκε βίης· τὸ δὲ τέτρατον ἤθελε θυμῷ{l]
[l [n}21.178{]}ἆξαι ἐπιγνάμψας δόρυ μείλινον Αἰακίδαο,{l]
[l [n}21.179{]}ἀλλὰ πρὶν Ἀχιλεὺς σχεδὸν ἄορι θυμὸν ἀπηύρα.{l]
[l [n}21.180{]}γαστέρα γάρ μιν τύψε παρʼ ὀμφαλόν, ἐκ δʼ ἄρα πᾶσαι{l]
[l [n}21.181{]}χύντο χαμαὶ χολάδες· τὸν δὲ σκότος ὄσσε κάλυψεν{l]
[l [n}21.182{]}ἀσθμαίνοντʼ· Ἀχιλεὺς δʼ ἄρʼ ἐνὶ στήθεσσιν ὀρούσας{l]
[l [n}21.183{]}τεύχεά τʼ ἐξενάριξε καὶ εὐχόμενος ἔπος ηὔδα·{l]
[q}[l [n}21.184{]}κεῖσʼ οὕτως· χαλεπόν τοι ἐρισθενέος Κρονίωνος{l]
[l [n}21.185{]}παισὶν ἐριζέμεναι ποταμοῖό περ ἐκγεγαῶτι.{l]
[l [n}21.186{]}φῆσθα σὺ μὲν ποταμοῦ γένος ἔμμεναι εὐρὺ ῥέοντος,{l]
[l [n}21.187{]}αὐτὰρ ἐγὼ γενεὴν μεγάλου Διὸς εὔχομαι εἶναι.{l]
[l [n}21.188{]}τίκτέ μʼ ἀνὴρ πολλοῖσιν ἀνάσσων Μυρμιδόνεσσι{l]
[l [n}21.189{]}Πηλεὺς Αἰακίδης· ὃ δʼ ἄρʼ Αἰακὸς ἐκ Διὸς ἦεν.{l]
[l [n}21.190{]}τὼ κρείσσων μὲν Ζεὺς ποταμῶν ἁλιμυρηέντων,{l]
[l [n}21.191{]}κρείσσων αὖτε Διὸς γενεὴ ποταμοῖο τέτυκται.{l]
[l [n}21.192{]}καὶ γὰρ σοὶ ποταμός γε πάρα μέγας, εἰ δύναταί τι{l]
[l [n}21.193{]}χραισμεῖν· ἀλλʼ οὐκ ἔστι Διὶ Κρονίωνι μάχεσθαι,{l]
[l [n}21.194{]}τῷ οὐδὲ κρείων Ἀχελώϊος ἰσοφαρίζει,{l]
[l [n}21.195{]}οὐδὲ βαθυρρείταο μέγα σθένος Ὠκεανοῖο,{l]
[l [n}21.196{]}ἐξ οὗ περ πάντες ποταμοὶ καὶ πᾶσα θάλασσα{l]
[l [n}21.197{]}καὶ πᾶσαι κρῆναι καὶ φρείατα μακρὰ νάουσιν·{l]
[l [n}21.198{]}ἀλλὰ καὶ ὃς δείδοικε Διὸς μεγάλοιο κεραυνὸν{l]
[l [n}21.199{]}δεινήν τε βροντήν, ὅτʼ ἀπʼ οὐρανόθεν σμαραγήσῃ.{l]{q]{para]
[para}[l [n}21.200{]}ἦ ῥα, καὶ ἐκ κρημνοῖο ἐρύσσατο χάλκεον ἔγχος,{l]
[l [n}21.201{]}τὸν δὲ κατʼ αὐτόθι λεῖπεν, ἐπεὶ φίλον ἦτορ ἀπηύρα,{l]
[l [n}21.202{]}κείμενον ἐν ψαμάθοισι, δίαινε δέ μιν μέλαν ὕδωρ.{l]
[l [n}21.203{]}τὸν μὲν ἄρʼ ἐγχέλυές τε καὶ ἰχθύες ἀμφεπένοντο{l]
[l [n}21.204{]}δημὸν ἐρεπτόμενοι ἐπινεφρίδιον κείροντες·{l]
[l [n}21.205{]}αὐτὰρ ὃ βῆ ῥʼ ἰέναι μετὰ Παίονας ἱπποκορυστάς,{l]
[l [n}21.206{]}οἵ ῥʼ ἔτι πὰρ ποταμὸν πεφοβήατο δινήεντα,{l]
[l [n}21.207{]}ὡς εἶδον τὸν ἄριστον ἐνὶ κρατερῇ ὑσμίνῃ{l]
[l [n}21.208{]}χέρσʼ ὕπο Πηλεΐδαο καὶ ἄορι ἶφι δαμέντα.{l]
[l [n}21.209{]}ἔνθʼ ἕλε Θερσίλοχόν τε Μύδωνά τε Ἀστύπυλόν τε{l]
[l [n}21.210{]}Μνῆσόν τε Θρασίον τε καὶ Αἴνιον ἠδʼ Ὀφελέστην·{l]
[l [n}21.211{]}καί νύ κʼ ἔτι πλέονας κτάνε Παίονας ὠκὺς Ἀχιλλεύς,{l]
[l [n}21.212{]}εἰ μὴ χωσάμενος προσέφη ποταμὸς βαθυδίνης{l]
[l [n}21.213{]}ἀνέρι εἰσάμενος, βαθέης δʼ ἐκ φθέγξατο δίνης·{l]
[q}[l [n}21.214{]}ὦ Ἀχιλεῦ, περὶ μὲν κρατέεις, περὶ δʼ αἴσυλα ῥέζεις{l]
[l [n}21.215{]}ἀνδρῶν· αἰεὶ γάρ τοι ἀμύνουσιν θεοὶ αὐτοί.{l]
[l [n}21.216{]}εἴ τοι Τρῶας ἔδωκε Κρόνου παῖς πάντας ὀλέσσαι,{l]
[l [n}21.217{]}ἐξ ἐμέθεν γʼ ἐλάσας πεδίον κάτα μέρμερα ῥέζε·{l]
[l [n}21.218{]}πλήθει γὰρ δή μοι νεκύων ἐρατεινὰ ῥέεθρα,{l]
[l [n}21.219{]}οὐδέ τί πῃ δύναμαι προχέειν ῥόον εἰς ἅλα δῖαν{l]
[l [n}21.220{]}στεινόμενος νεκύεσσι, σὺ δὲ κτείνεις ἀϊδήλως.{l]
[l [n}21.221{]}ἀλλʼ ἄγε δὴ καὶ ἔασον· ἄγη μʼ ἔχει ὄρχαμε λαῶν.{l]{q]{para]
[para}[l [n}21.222{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}21.223{]}ἔσται ταῦτα Σκάμανδρε διοτρεφές, ὡς σὺ κελεύεις.{l]
[l [n}21.224{]}Τρῶας δʼ οὐ πρὶν λήξω ὑπερφιάλους ἐναρίζων,{l]
[l [n}21.225{]}πρὶν ἔλσαι κατὰ ἄστυ καὶ Ἕκτορι πειρηθῆναι{l]
[l [n}21.226{]}ἀντιβίην, ἤ κέν με δαμάσσεται, ἦ κεν ἐγὼ τόν.{l]{q]{para]
[para}[l [n}21.227{]}ὣς εἰπὼν Τρώεσσιν ἐπέσσυτο δαίμονι ἶσος·{l]
[l [n}21.228{]}καὶ τότʼ Ἀπόλλωνα προσέφη ποταμὸς βαθυδίνης·{l]
[q}[l [n}21.229{]}ὢ πόποι ἀργυρότοξε Διὸς τέκος οὐ σύ γε βουλὰς{l]
[l [n}21.230{]}εἰρύσαο Κρονίωνος, ὅ τοι μάλα πόλλʼ ἐπέτελλε{l]
[l [n}21.231{]}Τρωσὶ παρεστάμεναι καὶ ἀμύνειν, εἰς ὅ κεν ἔλθῃ{l]
[l [n}21.232{]}δείελος ὀψὲ δύων, σκιάσῃ δʼ ἐρίβωλον ἄρουραν.{l]{q]{para]
[para}[l [n}21.233{]}ἦ, καὶ Ἀχιλλεὺς μὲν δουρικλυτὸς ἔνθορε μέσσῳ{l]
[l [n}21.234{]}κρημνοῦ ἀπαΐξας· ὃ δʼ ἐπέσσυτο οἴδματι θύων,{l]
[l [n}21.235{]}πάντα δʼ ὄρινε ῥέεθρα κυκώμενος, ὦσε δὲ νεκροὺς{l]
[l [n}21.236{]}πολλούς, οἵ ῥα κατʼ αὐτὸν ἅλις ἔσαν, οὓς κτάνʼ Ἀχιλλεύς{l]
[l [n}21.237{]}τοὺς ἔκβαλλε θύραζε μεμυκὼς ἠΰτε ταῦρος{l]
[l [n}21.238{]}χέρσον δέ· ζωοὺς δὲ σάω κατὰ καλὰ ῥέεθρα,{l]
[l [n}21.239{]}κρύπτων ἐν δίνῃσι βαθείῃσιν μεγάλῃσι.{l]
[l [n}21.240{]}δεινὸν δʼ ἀμφʼ Ἀχιλῆα κυκώμενον ἵστατο κῦμα,{l]
[l [n}21.241{]}ὤθει δʼ ἐν σάκεϊ πίπτων ῥόος· οὐδὲ πόδεσσιν{l]
[l [n}21.242{]}εἶχε στηρίξασθαι· ὃ δὲ πτελέην ἕλε χερσὶν{l]
[l [n}21.243{]}εὐφυέα μεγάλην· ἣ δʼ ἐκ ῥιζῶν ἐριποῦσα{l]
[l [n}21.244{]}κρημνὸν ἅπαντα διῶσεν, ἐπέσχε δὲ καλὰ ῥέεθρα{l]
[l [n}21.245{]}ὄζοισιν πυκινοῖσι, γεφύρωσεν δέ μιν αὐτὸν{l]
[l [n}21.246{]}εἴσω πᾶσʼ ἐριποῦσʼ· ὃ δʼ ἄρʼ ἐκ δίνης ἀνορούσας{l]
[l [n}21.247{]}ἤϊξεν πεδίοιο ποσὶ κραιπνοῖσι πέτεσθαι{l]
[l [n}21.248{]}δείσας· οὐδέ τʼ ἔληγε θεὸς μέγας, ὦρτο δʼ ἐπʼ αὐτῷ{l]
[l [n}21.249{]}ἀκροκελαινιόων, ἵνα μιν παύσειε πόνοιο{l]
[l [n}21.250{]}δῖον Ἀχιλλῆα, Τρώεσσι δὲ λοιγὸν ἀλάλκοι.{l]
[l [n}21.251{]}Πηλεΐδης δʼ ἀπόρουσεν ὅσον τʼ ἐπὶ δουρὸς ἐρωή,{l]
[l [n}21.252{]}αἰετοῦ οἴματʼ ἔχων μέλανος τοῦ θηρητῆρος,{l]
[l [n}21.253{]}ὅς θʼ ἅμα κάρτιστός τε καὶ ὤκιστος πετεηνῶν·{l]
[l [n}21.254{]}τῷ ἐϊκὼς ἤϊξεν, ἐπὶ στήθεσσι δὲ χαλκὸς{l]
[l [n}21.255{]}σμερδαλέον κονάβιζεν· ὕπαιθα δὲ τοῖο λιασθεὶς{l]
[l [n}21.256{]}φεῦγʼ, ὃ δʼ ὄπισθε ῥέων ἕπετο μεγάλῳ ὀρυμαγδῷ.{l]
[l [n}21.257{]}ὡς δʼ ὅτʼ ἀνὴρ ὀχετηγὸς ἀπὸ κρήνης μελανύδρου{l]
[l [n}21.258{]}ἂμ φυτὰ καὶ κήπους ὕδατι ῥόον ἡγεμονεύῃ{l]
[l [n}21.259{]}χερσὶ μάκελλαν ἔχων, ἀμάρης ἐξ ἔχματα βάλλων·{l]
[l [n}21.260{]}τοῦ μέν τε προρέοντος ὑπὸ ψηφῖδες ἅπασαι{l]
[l [n}21.261{]}ὀχλεῦνται· τὸ δέ τʼ ὦκα κατειβόμενον κελαρύζει{l]
[l [n}21.262{]}χώρῳ ἔνι προαλεῖ, φθάνει δέ τε καὶ τὸν ἄγοντα·{l]
[l [n}21.263{]}ὣς αἰεὶ Ἀχιλῆα κιχήσατο κῦμα ῥόοιο{l]
[l [n}21.264{]}καὶ λαιψηρὸν ἐόντα· θεοὶ δέ τε φέρτεροι ἀνδρῶν.{l]
[l [n}21.265{]}ὁσσάκι δʼ ὁρμήσειε ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}21.266{]}στῆναι ἐναντίβιον καὶ γνώμεναι εἴ μιν ἅπαντες{l]
[l [n}21.267{]}ἀθάνατοι φοβέουσι, τοὶ οὐρανὸν εὐρὺν ἔχουσι,{l]
[l [n}21.268{]}τοσσάκι μιν μέγα κῦμα διιπετέος ποταμοῖο{l]
[l [n}21.269{]}πλάζʼ ὤμους καθύπερθεν· ὃ δʼ ὑψόσε ποσσὶν ἐπήδα{l]
[l [n}21.270{]}θυμῷ ἀνιάζων· ποταμὸς δʼ ὑπὸ γούνατʼ ἐδάμνα{l]
[l [n}21.271{]}λάβρος ὕπαιθα ῥέων, κονίην δʼ ὑπέρεπτε ποδοῖιν.{l]
[l [n}21.272{]}Πηλεΐδης δʼ ᾤμωξεν ἰδὼν εἰς οὐρανὸν εὐρύν·{l]
[q}[l [n}21.273{]}Ζεῦ πάτερ ὡς οὔ τίς με θεῶν ἐλεεινὸν ὑπέστη{l]
[l [n}21.274{]}ἐκ ποταμοῖο σαῶσαι· ἔπειτα δὲ καί τι πάθοιμι.{l]
[l [n}21.275{]}ἄλλος δʼ οὔ τις μοι τόσον αἴτιος Οὐρανιώνων,{l]
[l [n}21.276{]}ἀλλὰ φίλη μήτηρ, ἥ με ψεύδεσσιν ἔθελγεν·{l]
[l [n}21.277{]}ἥ μʼ ἔφατο Τρώων ὑπὸ τείχεϊ θωρηκτάων{l]
[l [n}21.278{]}λαιψηροῖς ὀλέεσθαι Ἀπόλλωνος βελέεσσιν.{l]
[l [n}21.279{]}ὥς μʼ ὄφελʼ Ἕκτωρ κτεῖναι ὃς ἐνθάδε γʼ ἔτραφʼ ἄριστος·{l]
[l [n}21.280{]}τώ κʼ ἀγαθὸς μὲν ἔπεφνʼ, ἀγαθὸν δέ κεν ἐξενάριξε·{l]
[l [n}21.281{]}νῦν δέ με λευγαλέῳ θανάτῳ εἵμαρτο ἁλῶναι{l]
[l [n}21.282{]}ἐρχθέντʼ ἐν μεγάλῳ ποταμῷ ὡς παῖδα συφορβόν,{l]
[l [n}21.283{]}ὅν ῥά τʼ ἔναυλος ἀποέρσῃ χειμῶνι περῶντα.{l]{q]{para]
[para}[l [n}21.284{]}ὣς φάτο, τῷ δὲ μάλʼ ὦκα Ποσειδάων καὶ Ἀθήνη{l]
[l [n}21.285{]}στήτην ἐγγὺς ἰόντε, δέμας δʼ ἄνδρεσσιν ἐΐκτην,{l]
[l [n}21.286{]}χειρὶ δὲ χεῖρα λαβόντες ἐπιστώσαντʼ ἐπέεσσι.{l]
[l [n}21.287{]}τοῖσι δὲ μύθων ἦρχε Ποσειδάων ἐνοσίχθων·{l]
[q}[l [n}21.288{]}Πηλεΐδη μήτʼ ἄρ τι λίην τρέε μήτέ τι τάρβει·{l]
[l [n}21.289{]}τοίω γάρ τοι νῶϊ θεῶν ἐπιταρρόθω εἰμὲν{l]
[l [n}21.290{]}Ζηνὸς ἐπαινήσαντος ἐγὼ καὶ Παλλὰς Ἀθήνη·{l]
[l [n}21.291{]}ὡς οὔ τοι ποταμῷ γε δαμήμεναι αἴσιμόν ἐστιν,{l]
[l [n}21.292{]}ἀλλʼ ὅδε μὲν τάχα λωφήσει, σὺ δὲ εἴσεαι αὐτός·{l]
[l [n}21.293{]}αὐτάρ τοι πυκινῶς ὑποθησόμεθʼ αἴ κε πίθηαι·{l]
[l [n}21.294{]}μὴ πρὶν παύειν χεῖρας ὁμοιΐου πολέμοιο{l]
[l [n}21.295{]}πρὶν κατὰ Ἰλιόφι κλυτὰ τείχεα λαὸν ἐέλσαι{l]
[l [n}21.296{]}Τρωϊκόν, ὅς κε φύγῃσι· σὺ δʼ Ἕκτορι θυμὸν ἀπούρας{l]
[l [n}21.297{]}ἂψ ἐπὶ νῆας ἴμεν· δίδομεν δέ τοι εὖχος ἀρέσθαι.{l]{q]{para]
[para}[l [n}21.298{]}τὼ μὲν ἄρʼ ὣς εἰπόντε μετʼ ἀθανάτους ἀπεβήτην·{l]
[l [n}21.299{]}αὐτὰρ ὃ βῆ, μέγα γάρ ῥα θεῶν ὄτρυνεν ἐφετμή,{l]
[l [n}21.300{]}ἐς πεδίον· τὸ δὲ πᾶν πλῆθʼ ὕδατος ἐκχυμένοιο,{l]
[l [n}21.301{]}πολλὰ δὲ τεύχεα καλὰ δαὶ κταμένων αἰζηῶν{l]
[l [n}21.302{]}πλῶον καὶ νέκυες· τοῦ δʼ ὑψόσε γούνατʼ ἐπήδα{l]
[l [n}21.303{]}πρὸς ῥόον ἀΐσσοντος ἀνʼ ἰθύν, οὐδέ μιν ἴσχεν{l]
[l [n}21.304{]}εὐρὺ ῥέων ποταμός· μέγα γὰρ σθένος ἔμβαλʼ Ἀθήνη.{l]
[l [n}21.305{]}οὐδὲ Σκάμανδρος ἔληγε τὸ ὃν μένος, ἀλλʼ ἔτι μᾶλλον{l]
[l [n}21.306{]}χώετο Πηλεΐωνι, κόρυσσε δὲ κῦμα ῥόοιο{l]
[l [n}21.307{]}ὑψόσʼ ἀειρόμενος, Σιμόεντι δὲ κέκλετʼ ἀΰσας·{l]
[q}[l [n}21.308{]}φίλε κασίγνητε σθένος ἀνέρος ἀμφότεροί περ{l]
[l [n}21.309{]}σχῶμεν, ἐπεὶ τάχα ἄστυ μέγα Πριάμοιο ἄνακτος{l]
[l [n}21.310{]}ἐκπέρσει, Τρῶες δὲ κατὰ μόθον οὐ μενέουσιν.{l]
[l [n}21.311{]}ἀλλʼ ἐπάμυνε τάχιστα, καὶ ἐμπίπληθι ῥέεθρα{l]
[l [n}21.312{]}ὕδατος ἐκ πηγέων, πάντας δʼ ὀρόθυνον ἐναύλους,{l]
[l [n}21.313{]}ἵστη δὲ μέγα κῦμα, πολὺν δʼ ὀρυμαγδὸν ὄρινε{l]
[l [n}21.314{]}φιτρῶν καὶ λάων, ἵνα παύσομεν ἄγριον ἄνδρα{l]
[l [n}21.315{]}ὃς δὴ νῦν κρατέει, μέμονεν δʼ ὅ γε ἶσα θεοῖσι.{l]
[l [n}21.316{]}φημὶ γὰρ οὔτε βίην χραισμησέμεν οὔτέ τι εἶδος{l]
[l [n}21.317{]}οὔτε τὰ τεύχεα καλά, τά που μάλα νειόθι λίμνης{l]
[l [n}21.318{]}κείσεθʼ ὑπʼ ἰλύος κεκαλυμμένα· κὰδ δέ μιν αὐτὸν{l]
[l [n}21.319{]}εἰλύσω ψαμάθοισιν ἅλις χέραδος περιχεύας{l]
[l [n}21.320{]}μυρίον, οὐδέ οἱ ὀστέʼ ἐπιστήσονται Ἀχαιοὶ{l]
[l [n}21.321{]}ἀλλέξαι· τόσσην οἱ ἄσιν καθύπερθε καλύψω.{l]
[l [n}21.322{]}αὐτοῦ οἱ καὶ σῆμα τετεύξεται, οὐδέ τί μιν χρεὼ{l]
[l [n}21.323{]}ἔσται τυμβοχόης, ὅτε μιν θάπτωσιν Ἀχαιοί.{l]{q]{para]
[para}[l [n}21.324{]}ἦ, καὶ ἐπῶρτʼ Ἀχιλῆϊ κυκώμενος ὑψόσε θύων{l]
[l [n}21.325{]}μορμύρων ἀφρῷ τε καὶ αἵματι καὶ νεκύεσσι.{l]
[l [n}21.326{]}πορφύρεον δʼ ἄρα κῦμα διιπετέος ποταμοῖο{l]
[l [n}21.327{]}ἵστατʼ ἀειρόμενον, κατὰ δʼ ᾕρεε Πηλεΐωνα·{l]
[l [n}21.328{]}Ἥρη δὲ μέγʼ ἄϋσε περιδείσασʼ Ἀχιλῆϊ{l]
[l [n}21.329{]}μή μιν ἀποέρσειε μέγας ποταμὸς βαθυδίνης,{l]
[l [n}21.330{]}αὐτίκα δʼ Ἥφαιστον προσεφώνεεν ὃν φίλον υἱόν·{l]
[q}[l [n}21.331{]}ὄρσεο κυλλοπόδιον ἐμὸν τέκος· ἄντα σέθεν γὰρ{l]
[l [n}21.332{]}Ξάνθον δινήεντα μάχῃ ἠΐσκομεν εἶναι·{l]
[l [n}21.333{]}ἀλλʼ ἐπάμυνε τάχιστα, πιφαύσκεο δὲ φλόγα πολλήν.{l]
[l [n}21.334{]}αὐτὰρ ἐγὼ Ζεφύροιο καὶ ἀργεστᾶο Νότοιο{l]
[l [n}21.335{]}εἴσομαι ἐξ ἁλόθεν χαλεπὴν ὄρσουσα θύελλαν,{l]
[l [n}21.336{]}ἥ κεν ἀπὸ Τρώων κεφαλὰς καὶ τεύχεα κήαι{l]
[l [n}21.337{]}φλέγμα κακὸν φορέουσα· σὺ δὲ Ξάνθοιο παρʼ ὄχθας{l]
[l [n}21.338{]}δένδρεα καῖʼ, ἐν δʼ αὐτὸν ἵει πυρί· μὴ δέ σε πάμπαν{l]
[l [n}21.339{]}μειλιχίοις ἐπέεσσιν ἀποτρεπέτω καὶ ἀρειῇ·{l]
[l [n}21.340{]}μὴ δὲ πρὶν ἀπόπαυε τεὸν μένος, ἀλλʼ ὁπότʼ ἂν δὴ{l]
[l [n}21.341{]}φθέγξομʼ ἐγὼν ἰάχουσα, τότε σχεῖν ἀκάματον πῦρ.{l]{q]{para]
[para}[l [n}21.342{]}ὣς ἔφαθʼ, Ἥφαιστος δὲ τιτύσκετο θεσπιδαὲς πῦρ.{l]
[l [n}21.343{]}πρῶτα μὲν ἐν πεδίῳ πῦρ δαίετο, καῖε δὲ νεκροὺς{l]
[l [n}21.344{]}πολλούς, οἵ ῥα κατʼ αὐτὸν ἅλις ἔσαν, οὓς κτάνʼ Ἀχιλλεύς·{l]
[l [n}21.345{]}πᾶν δʼ ἐξηράνθη πεδίον, σχέτο δʼ ἀγλαὸν ὕδωρ.{l]
[l [n}21.346{]}ὡς δʼ ὅτʼ ὀπωρινὸς Βορέης νεοαρδέʼ ἀλωὴν{l]
[l [n}21.347{]}αἶψʼ ἀγξηράνῃ· χαίρει δέ μιν ὅς τις ἐθείρῃ·{l]
[l [n}21.348{]}ὣς ἐξηράνθη πεδίον πᾶν, κὰδ δʼ ἄρα νεκροὺς{l]
[l [n}21.349{]}κῆεν· ὃ δʼ ἐς ποταμὸν τρέψε φλόγα παμφανόωσαν.{l]
[l [n}21.350{]}καίοντο πτελέαι τε καὶ ἰτέαι ἠδὲ μυρῖκαι,{l]
[l [n}21.351{]}καίετο δὲ λωτός τε ἰδὲ θρύον ἠδὲ κύπειρον,{l]
[l [n}21.352{]}τὰ περὶ καλὰ ῥέεθρα ἅλις ποταμοῖο πεφύκει·{l]
[l [n}21.353{]}τείροντʼ ἐγχέλυές τε καὶ ἰχθύες οἳ κατὰ δίνας,{l]
[l [n}21.354{]}οἳ κατὰ καλὰ ῥέεθρα κυβίστων ἔνθα καὶ ἔνθα{l]
[l [n}21.355{]}πνοιῇ τειρόμενοι πολυμήτιος Ἡφαίστοιο.{l]
[l [n}21.356{]}καίετο δʼ ἲς ποταμοῖο ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζεν·{l]
[q}[l [n}21.357{]}Ἥφαιστʼ, οὔ τις σοί γε θεῶν δύνατʼ ἀντιφερίζειν,{l]
[l [n}21.358{]}οὐδʼ ἂν ἐγὼ σοί γʼ ὧδε πυρὶ φλεγέθοντι μαχοίμην.{l]
[l [n}21.359{]}λῆγʼ ἔριδος, Τρῶας δὲ καὶ αὐτίκα δῖος Ἀχιλλεὺς{l]
[l [n}21.360{]}ἄστεος ἐξελάσειε· τί μοι ἔριδος καὶ ἀρωγῆς;{l]{q]{para]
[para}[l [n}21.361{]}φῆ πυρὶ καιόμενος, ἀνὰ δʼ ἔφλυε καλὰ ῥέεθρα.{l]
[l [n}21.362{]}ὡς δὲ λέβης ζεῖ ἔνδον ἐπειγόμενος πυρὶ πολλῷ{l]
[l [n}21.363{]}κνίσην μελδόμενος ἁπαλοτρεφέος σιάλοιο{l]
[l [n}21.364{]}πάντοθεν ἀμβολάδην, ὑπὸ δὲ ξύλα κάγκανα κεῖται,{l]
[l [n}21.365{]}ὣς τοῦ καλὰ ῥέεθρα πυρὶ φλέγετο, ζέε δʼ ὕδωρ·{l]
[l [n}21.366{]}οὐδʼ ἔθελε προρέειν, ἀλλʼ ἴσχετο· τεῖρε δʼ ἀϋτμὴ{l]
[l [n}21.367{]}Ἡφαίστοιο βίηφι πολύφρονος. αὐτὰρ ὅ γʼ Ἥρην{l]
[l [n}21.368{]}πολλὰ λισσόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}21.369{]}Ἥρη τίπτε σὸς υἱὸς ἐμὸν ῥόον ἔχραε κήδειν{l]
[l [n}21.370{]}ἐξ ἄλλων; οὐ μέν τοι ἐγὼ τόσον αἴτιός εἰμι{l]
[l [n}21.371{]}ὅσσον οἱ ἄλλοι πάντες, ὅσοι Τρώεσσιν ἀρωγοί.{l]
[l [n}21.372{]}ἀλλʼ ἤτοι μὲν ἐγὼν ἀποπαύσομαι εἰ σὺ κελεύεις,{l]
[l [n}21.373{]}παυέσθω δὲ καὶ οὗτος· ἐγὼ δʼ ἐπὶ καὶ τόδʼ ὀμοῦμαι,{l]
[l [n}21.374{]}μή ποτʼ ἐπὶ Τρώεσσιν ἀλεξήσειν κακὸν ἦμαρ,{l]
[l [n}21.375{]}μὴ δʼ ὁπότʼ ἂν Τροίη μαλερῷ πυρὶ πᾶσα δάηται{l]
[l [n}21.376{]}καιομένη, καίωσι δʼ ἀρήϊοι υἷες Ἀχαιῶν.{l]{q]{para]
[para}[l [n}21.377{]}αὐτὰρ ἐπεὶ τό γʼ ἄκουσε θεὰ λευκώλενος Ἥρη,{l]
[l [n}21.378{]}αὐτίκʼ ἄρʼ Ἥφαιστον προσεφώνεεν ὃν φίλον υἱόν·{l]
[q}[l [n}21.379{]}Ἥφαιστε σχέο τέκνον ἀγακλεές· οὐ γὰρ ἔοικεν{l]
[l [n}21.380{]}ἀθάνατον θεὸν ὧδε βροτῶν ἕνεκα στυφελίζειν.{l]{q]{para]
[para}[l [n}21.381{]}ὣς ἔφαθʼ, Ἥφαιστος δὲ κατέσβεσε θεσπιδαὲς πῦρ,{l]
[l [n}21.382{]}ἄψορρον δʼ ἄρα κῦμα κατέσσυτο καλὰ ῥέεθρα.{l]{para]
[para}[l [n}21.383{]}αὐτὰρ ἐπεὶ Ξάνθοιο δάμη μένος, οἳ μὲν ἔπειτα{l]
[l [n}21.384{]}παυσάσθην, Ἥρη γὰρ ἐρύκακε χωομένη περ·{l]
[l [n}21.385{]}ἐν δʼ ἄλλοισι θεοῖσιν ἔρις πέσε βεβριθυῖα{l]
[l [n}21.386{]}ἀργαλέη, δίχα δέ σφιν ἐνὶ φρεσὶ θυμὸς ἄητο·{l]
[l [n}21.387{]}σὺν δʼ ἔπεσον μεγάλῳ πατάγῳ, βράχε δʼ εὐρεῖα χθών,{l]
[l [n}21.388{]}ἀμφὶ δὲ σάλπιγξεν μέγας οὐρανός. ἄϊε δὲ Ζεὺς{l]
[l [n}21.389{]}ἥμενος Οὐλύμπῳ· ἐγέλασσε δέ οἱ φίλον ἦτορ{l]
[l [n}21.390{]}γηθοσύνῃ, ὅθʼ ὁρᾶτο θεοὺς ἔριδι ξυνιόντας.{l]
[l [n}21.391{]}ἔνθʼ οἵ γʼ οὐκέτι δηρὸν ἀφέστασαν· ἦρχε γὰρ Ἄρης{l]
[l [n}21.392{]}ῥινοτόρος, καὶ πρῶτος Ἀθηναίῃ ἐπόρουσε{l]
[l [n}21.393{]}χάλκεον ἔγχος ἔχων, καὶ ὀνείδειον φάτο μῦθον·{l]
[q}[l [n}21.394{]}τίπτʼ αὖτʼ ὦ κυνάμυια θεοὺς ἔριδι ξυνελαύνεις{l]
[l [n}21.395{]}θάρσος ἄητον ἔχουσα, μέγας δέ σε θυμὸς ἀνῆκεν;{l]
[l [n}21.396{]}ἦ οὐ μέμνῃ ὅτε Τυδεΐδην Διομήδεʼ ἀνῆκας{l]
[l [n}21.397{]}οὐτάμεναι, αὐτὴ δὲ πανόψιον ἔγχος ἑλοῦσα{l]
[l [n}21.398{]}ἰθὺς ἐμεῦ ὦσας, διὰ δὲ χρόα καλὸν ἔδαψας;{l]
[l [n}21.399{]}τώ σʼ αὖ νῦν ὀΐω ἀποτισέμεν ὅσσα ἔοργας.{l]{q]{para]
[para}[l [n}21.400{]}ὣς εἰπὼν οὔτησε κατʼ αἰγίδα θυσσανόεσσαν{l]
[l [n}21.401{]}σμερδαλέην, ἣν οὐδὲ Διὸς δάμνησι κεραυνός·{l]
[l [n}21.402{]}τῇ μιν Ἄρης οὔτησε μιαιφόνος ἔγχεϊ μακρῷ.{l]
[l [n}21.403{]}ἣ δʼ ἀναχασσαμένη λίθον εἵλετο χειρὶ παχείῃ{l]
[l [n}21.404{]}κείμενον ἐν πεδίῳ μέλανα τρηχύν τε μέγαν τε,{l]
[l [n}21.405{]}τόν ῥʼ ἄνδρες πρότεροι θέσαν ἔμμεναι οὖρον ἀρούρης·{l]
[l [n}21.406{]}τῷ βάλε θοῦρον Ἄρηα κατʼ αὐχένα, λῦσε δὲ γυῖα.{l]
[l [n}21.407{]}ἑπτὰ δʼ ἐπέσχε πέλεθρα πεσών, ἐκόνισε δὲ χαίτας,{l]
[l [n}21.408{]}τεύχεά τʼ ἀμφαράβησε· γέλασσε δὲ Παλλὰς Ἀθήνη,{l]
[l [n}21.409{]}καί οἱ ἐπευχομένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}21.410{]}νηπύτιʼ οὐδέ νύ πώ περ ἐπεφράσω ὅσσον ἀρείων{l]
[l [n}21.411{]}εὔχομʼ ἐγὼν ἔμεναι, ὅτι μοι μένος ἰσοφαρίζεις.{l]
[l [n}21.412{]}οὕτω κεν τῆς μητρὸς ἐρινύας ἐξαποτίνοις,{l]
[l [n}21.413{]}ἥ τοι χωομένη κακὰ μήδεται οὕνεκʼ Ἀχαιοὺς{l]
[l [n}21.414{]}κάλλιπες, αὐτὰρ Τρωσὶν ὑπερφιάλοισιν ἀμύνεις.{l]{q]{para]
[para}[l [n}21.415{]}ὣς ἄρα φωνήσασα πάλιν τρέπεν ὄσσε φαεινώ·{l]
[l [n}21.416{]}τὸν δʼ ἄγε χειρὸς ἑλοῦσα Διὸς θυγάτηρ Ἀφροδίτη{l]
[l [n}21.417{]}πυκνὰ μάλα στενάχοντα· μόγις δʼ ἐσαγείρετο θυμόν.{l]
[l [n}21.418{]}τὴν δʼ ὡς οὖν ἐνόησε θεὰ λευκώλενος Ἥρη,{l]
[l [n}21.419{]}αὐτίκʼ Ἀθηναίην ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}21.420{]}ὢ πόποι αἰγιόχοιο Διὸς τέκος Ἀτρυτώνη{l]
[l [n}21.421{]}καὶ δʼ αὖθʼ ἡ κυνάμυια ἄγει βροτολοιγὸν Ἄρηα{l]
[l [n}21.422{]}δηΐου ἐκ πολέμοιο κατὰ κλόνον· ἀλλὰ μέτελθε.{l]{q]{para]
[para}[l [n}21.423{]}ὣς φάτʼ, Ἀθηναίη δὲ μετέσσυτο, χαῖρε δὲ θυμῷ,{l]
[l [n}21.424{]}καί ῥʼ ἐπιεισαμένη πρὸς στήθεα χειρὶ παχείῃ{l]
[l [n}21.425{]}ἤλασε· τῆς δʼ αὐτοῦ λύτο γούνατα καὶ φίλον ἦτορ.{l]
[l [n}21.426{]}τὼ μὲν ἄρʼ ἄμφω κεῖντο ἐπὶ χθονὶ πουλυβοτείρῃ,{l]
[l [n}21.427{]}ἣ δʼ ἄρʼ ἐπευχομένη ἔπεα πτερόεντʼ ἀγόρευε·{l]
[q}[l [n}21.428{]}τοιοῦτοι νῦν πάντες ὅσοι Τρώεσσιν ἀρωγοὶ{l]
[l [n}21.429{]}εἶεν, ὅτʼ Ἀργείοισι μαχοίατο θωρηκτῇσιν,{l]
[l [n}21.430{]}ὧδέ τε θαρσαλέοι καὶ τλήμονες, ὡς Ἀφροδίτη{l]
[l [n}21.431{]}ἦλθεν Ἄρῃ ἐπίκουρος ἐμῷ μένει ἀντιόωσα·{l]
[l [n}21.432{]}τώ κεν δὴ πάλαι ἄμμες ἐπαυσάμεθα πτολέμοιο{l]
[l [n}21.433{]}Ἰλίου ἐκπέρσαντες ἐϋκτίμενον πτολίεθρον.{l]{q]{para]
[para}[l [n}21.434{]}ὣς φάτο, μείδησεν δὲ θεὰ λευκώλενος Ἥρη.{l]
[l [n}21.435{]}αὐτὰρ Ἀπόλλωνα προσέφη κρείων ἐνοσίχθων·{l]
[q}[l [n}21.436{]}Φοῖβε τί ἢ δὴ νῶϊ διέσταμεν; οὐδὲ ἔοικεν{l]
[l [n}21.437{]}ἀρξάντων ἑτέρων· τὸ μὲν αἴσχιον αἴ κʼ ἀμαχητὶ{l]
[l [n}21.438{]}ἴομεν Οὔλυμπον δὲ Διὸς ποτὶ χαλκοβατὲς δῶ.{l]
[l [n}21.439{]}ἄρχε· σὺ γὰρ γενεῆφι νεώτερος· οὐ γὰρ ἔμοιγε{l]
[l [n}21.440{]}καλόν, ἐπεὶ πρότερος γενόμην καὶ πλείονα οἶδα.{l]
[l [n}21.441{]}νηπύτιʼ ὡς ἄνοον κραδίην ἔχες· οὐδέ νυ τῶν περ{l]
[l [n}21.442{]}μέμνηαι ὅσα δὴ πάθομεν κακὰ Ἴλιον ἀμφὶ{l]
[l [n}21.443{]}μοῦνοι νῶϊ θεῶν, ὅτʼ ἀγήνορι Λαομέδοντι{l]
[l [n}21.444{]}πὰρ Διὸς ἐλθόντες θητεύσαμεν εἰς ἐνιαυτὸν{l]
[l [n}21.445{]}μισθῷ ἔπι ῥητῷ· ὃ δὲ σημαίνων ἐπέτελλεν.{l]
[l [n}21.446{]}ἤτοι ἐγὼ Τρώεσσι πόλιν πέρι τεῖχος ἔδειμα{l]
[l [n}21.447{]}εὐρύ τε καὶ μάλα καλόν, ἵνʼ ἄρρηκτος πόλις εἴη·{l]
[l [n}21.448{]}Φοῖβε σὺ δʼ εἰλίποδας ἕλικας βοῦς βουκολέεσκες{l]
[l [n}21.449{]}Ἴδης ἐν κνημοῖσι πολυπτύχου ὑληέσσης.{l]
[l [n}21.450{]}ἀλλʼ ὅτε δὴ μισθοῖο τέλος πολυγηθέες ὧραι{l]
[l [n}21.451{]}ἐξέφερον, τότε νῶϊ βιήσατο μισθὸν ἅπαντα{l]
[l [n}21.452{]}Λαομέδων ἔκπαγλος, ἀπειλήσας δʼ ἀπέπεμπε.{l]
[l [n}21.453{]}σὺν μὲν ὅ γʼ ἠπείλησε πόδας καὶ χεῖρας ὕπερθε{l]
[l [n}21.454{]}δήσειν, καὶ περάαν νήσων ἔπι τηλεδαπάων·{l]
[l [n}21.455{]}στεῦτο δʼ ὅ γʼ ἀμφοτέρων ἀπολεψέμεν οὔατα χαλκῷ.{l]
[l [n}21.456{]}νῶϊ δὲ ἄψορροι κίομεν κεκοτηότι θυμῷ{l]
[l [n}21.457{]}μισθοῦ χωόμενοι, τὸν ὑποστὰς οὐκ ἐτέλεσσε.{l]
[l [n}21.458{]}τοῦ δὴ νῦν λαοῖσι φέρεις χάριν, οὐδὲ μεθʼ ἡμέων{l]
[l [n}21.459{]}πειρᾷ ὥς κε Τρῶες ὑπερφίαλοι ἀπόλωνται{l]
[l [n}21.460{]}πρόχνυ κακῶς σὺν παισὶ καὶ αἰδοίῃς ἀλόχοισι{l]{q]{para]
[para}[l [n}21.461{]}τὸν δʼ αὖτε προσέειπεν ἄναξ ἑκάεργος Ἀπόλλων·{l]
[q}[l [n}21.462{]}ἐννοσίγαιʼ οὐκ ἄν με σαόφρονα μυθήσαιο{l]
[l [n}21.463{]}ἔμμεναι, εἰ δὴ σοί γε βροτῶν ἕνεκα πτολεμίξω{l]
[l [n}21.464{]}δειλῶν, οἳ φύλλοισιν ἐοικότες ἄλλοτε μέν τε{l]
[l [n}21.465{]}ζαφλεγέες τελέθουσιν ἀρούρης καρπὸν ἔδοντες,{l]
[l [n}21.466{]}ἄλλοτε δὲ φθινύθουσιν ἀκήριοι. ἀλλὰ τάχιστα{l]
[l [n}21.467{]}παυώμεσθα μάχης· οἳ δʼ αὐτοὶ δηριαάσθων.{l]{q]{para]
[para}[l [n}21.468{]}ὣς ἄρα φωνήσας πάλιν ἐτράπετʼ· αἴδετο γάρ ῥα{l]
[l [n}21.469{]}πατροκασιγνήτοιο μιγήμεναι ἐν παλάμῃσι.{l]
[l [n}21.470{]}τὸν δὲ κασιγνήτη μάλα νείκεσε πότνια θηρῶν{l]
[l [n}21.471{]}Ἄρτεμις ἀγροτέρη, καὶ ὀνείδειον φάτο μῦθον·{l]
[q}[l [n}21.472{]}φεύγεις δὴ ἑκάεργε, Ποσειδάωνι δὲ νίκην{l]
[l [n}21.473{]}πᾶσαν ἐπέτρεψας, μέλεον δέ οἱ εὖχος ἔδωκας·{l]
[l [n}21.474{]}νηπύτιε τί νυ τόξον ἔχεις ἀνεμώλιον αὔτως;{l]
[l [n}21.475{]}μή σευ νῦν ἔτι πατρὸς ἐνὶ μεγάροισιν ἀκούσω{l]
[l [n}21.476{]}εὐχομένου, ὡς τὸ πρὶν ἐν ἀθανάτοισι θεοῖσιν,{l]
[l [n}21.477{]}ἄντα Ποσειδάωνος ἐναντίβιον πολεμίζειν.{l]{q]{para]
[para}[l [n}21.478{]}ὣς φάτο, τὴν δʼ οὔ τι προσέφη ἑκάεργος Ἀπόλλων,{l]
[l [n}21.479{]}ἀλλὰ χολωσαμένη Διὸς αἰδοίη παράκοιτις{l]
[l [n}21.480{]}νείκεσεν ἰοχέαιραν ὀνειδείοις ἐπέεσσι·{l]
[q}[l [n}21.481{]}πῶς δὲ σὺ νῦν μέμονας κύον ἀδεὲς ἀντίʼ ἐμεῖο{l]
[l [n}21.482{]}στήσεσθαι; χαλεπή τοι ἐγὼ μένος ἀντιφέρεσθαι{l]
[l [n}21.483{]}τοξοφόρῳ περ ἐούσῃ, ἐπεὶ σὲ λέοντα γυναιξὶ{l]
[l [n}21.484{]}Ζεὺς θῆκεν, καὶ ἔδωκε κατακτάμεν ἥν κʼ ἐθέλῃσθα.{l]
[l [n}21.485{]}ἤτοι βέλτερόν ἐστι κατʼ οὔρεα θῆρας ἐναίρειν{l]
[l [n}21.486{]}ἀγροτέρας τʼ ἐλάφους ἢ κρείσσοσιν ἶφι μάχεσθαι.{l]
[l [n}21.487{]}εἰ δʼ ἐθέλεις πολέμοιο δαήμεναι, ὄφρʼ ἐῢ εἰδῇς{l]
[l [n}21.488{]}ὅσσον φερτέρη εἴμʼ, ὅτι μοι μένος ἀντιφερίζεις.{l]{q]{para]
[para}[l [n}21.489{]}ἦ ῥα, καὶ ἀμφοτέρας ἐπὶ καρπῷ χεῖρας ἔμαρπτε{l]
[l [n}21.490{]}σκαιῇ, δεξιτερῇ δʼ ἄρʼ ἀπʼ ὤμων αἴνυτο τόξα,{l]
[l [n}21.491{]}αὐτοῖσιν δʼ ἄρʼ ἔθεινε παρʼ οὔατα μειδιόωσα{l]
[l [n}21.492{]}ἐντροπαλιζομένην· ταχέες δʼ ἔκπιπτον ὀϊστοί.{l]
[l [n}21.493{]}δακρυόεσσα δʼ ὕπαιθα θεὰ φύγεν ὥς τε πέλεια,{l]
[l [n}21.494{]}ἥ ῥά θʼ ὑπʼ ἴρηκος κοίλην εἰσέπτατο πέτρην{l]
[l [n}21.495{]}χηραμόν· οὐδʼ ἄρα τῇ γε ἁλώμεναι αἴσιμον ἦεν·{l]
[l [n}21.496{]}ὣς ἣ δακρυόεσσα φύγεν, λίπε δʼ αὐτόθι τόξα.{l]
[l [n}21.497{]}Λητὼ δὲ προσέειπε διάκτορος ἀργεϊφόντης·{l]
[q}[l [n}21.498{]}Λητοῖ ἐγὼ δέ τοι οὔ τι μαχήσομαι· ἀργαλέον δὲ{l]
[l [n}21.499{]}πληκτίζεσθʼ ἀλόχοισι Διὸς νεφεληγερέταο·{l]
[l [n}21.500{]}ἀλλὰ μάλα πρόφρασσα μετʼ ἀθανάτοισι θεοῖσιν{l]
[l [n}21.501{]}εὔχεσθαι ἐμὲ νικῆσαι κρατερῆφι βίηφιν.{l]{q]{para]
[para}[l [n}21.502{]}ὣς ἄρʼ ἔφη, Λητὼ δὲ συναίνυτο καμπύλα τόξα{l]
[l [n}21.503{]}πεπτεῶτʼ ἄλλυδις ἄλλα μετὰ στροφάλιγγι κονίης.{l]
[l [n}21.504{]}ἣ μὲν τόξα λαβοῦσα πάλιν κίε θυγατέρος ἧς·{l]
[l [n}21.505{]}ἣ δʼ ἄρʼ Ὄλυμπον ἵκανε Διὸς ποτὶ χαλκοβατὲς δῶ,{l]
[l [n}21.506{]}δακρυόεσσα δὲ πατρὸς ἐφέζετο γούνασι κούρη,{l]
[l [n}21.507{]}ἀμφὶ δʼ ἄρʼ ἀμβρόσιος ἑανὸς τρέμε· τὴν δὲ προτὶ οἷ{l]
[l [n}21.508{]}εἷλε πατὴρ Κρονίδης, καὶ ἀνείρετο ἡδὺ γελάσσας·{l]
[q}[l [n}21.509{]}τίς νύ σε τοιάδʼ ἔρεξε φίλον τέκος Οὐρανιώνων{l]
[l [n}21.510{]}μαψιδίως, ὡς εἴ τι κακὸν ῥέζουσαν ἐνωπῇ;{l]{q]{para]
[para}[l [n}21.511{]}τὸν δʼ αὖτε προσέειπεν ἐϋστέφανος κελαδεινή·{l]
[q}[l [n}21.512{]}σή μʼ ἄλοχος στυφέλιξε πάτερ λευκώλενος Ἥρη,{l]
[l [n}21.513{]}ἐξ ἧς ἀθανάτοισιν ἔρις καὶ νεῖκος ἐφῆπται.{l]{q]{para]
[para}[l [n}21.514{]}ὣς οἳ μὲν τοιαῦτα πρὸς ἀλλήλους ἀγόρευον·{l]
[q}[l [n}21.515{]}αὐτὰρ Ἀπόλλων Φοῖβος ἐδύσετο Ἴλιον ἱρήν·{l]
[l [n}21.516{]}μέμβλετο γάρ οἱ τεῖχος ἐϋδμήτοιο πόληος{l]
[l [n}21.517{]}μὴ Δαναοὶ πέρσειαν ὑπὲρ μόρον ἤματι κείνῳ.{l]
[l [n}21.518{]}οἳ δʼ ἄλλοι πρὸς Ὄλυμπον ἴσαν θεοὶ αἰὲν ἐόντες,{l]
[l [n}21.519{]}οἳ μὲν χωόμενοι, οἳ δὲ μέγα κυδιόωντες·{l]
[l [n}21.520{]}κὰδ δʼ ἷζον παρὰ πατρὶ κελαινεφεῖ· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}21.521{]}Τρῶας ὁμῶς αὐτούς τʼ ὄλεκεν καὶ μώνυχας ἵππους.{l]
[l [n}21.522{]}ὡς δʼ ὅτε καπνὸς ἰὼν εἰς οὐρανὸν εὐρὺν ἵκηται{l]
[l [n}21.523{]}ἄστεος αἰθομένοιο, θεῶν δέ ἑ μῆνις ἀνῆκε,{l]
[l [n}21.524{]}πᾶσι δʼ ἔθηκε πόνον, πολλοῖσι δὲ κήδεʼ ἐφῆκεν,{l]
[l [n}21.525{]}ὣς Ἀχιλεὺς Τρώεσσι πόνον καὶ κήδεʼ ἔθηκεν.{l]
[para}[l [n}21.526{]}ἑστήκει δʼ ὃ γέρων Πρίαμος θείου ἐπὶ πύργου,{l]
[l [n}21.527{]}ἐς δʼ ἐνόησʼ Ἀχιλῆα πελώριον· αὐτὰρ ὑπʼ αὐτοῦ{l]
[l [n}21.528{]}Τρῶες ἄφαρ κλονέοντο πεφυζότες, οὐδέ τις ἀλκὴ{l]
[l [n}21.529{]}γίγνεθʼ· ὃ δʼ οἰμώξας ἀπὸ πύργου βαῖνε χαμᾶζε{l]
[l [n}21.530{]}ὀτρύνων παρὰ τεῖχος ἀγακλειτοὺς πυλαωρούς·{l]
[q}[l [n}21.531{]}πεπταμένας ἐν χερσὶ πύλας ἔχετʼ εἰς ὅ κε λαοὶ{l]
[l [n}21.532{]}ἔλθωσι προτὶ ἄστυ πεφυζότες· ἦ γὰρ Ἀχιλλεὺς{l]
[l [n}21.533{]}ἐγγὺς ὅδε κλονέων· νῦν οἴω λοίγιʼ ἔσεσθαι.{l]
[l [n}21.534{]}αὐτὰρ ἐπεί κʼ ἐς τεῖχος ἀναπνεύσωσιν ἀλέντες,{l]
[l [n}21.535{]}αὖτις ἐπανθέμεναι σανίδας πυκινῶς ἀραρυίας·{l]
[l [n}21.536{]}δείδια γὰρ μὴ οὖλος ἀνὴρ ἐς τεῖχος ἅληται.{l]{q]{q]{para]
[para}[l [n}21.537{]}ὣς ἔφαθʼ, οἳ δʼ ἄνεσάν τε πύλας καὶ ἀπῶσαν ὀχῆας·{l]
[l [n}21.538{]}αἳ δὲ πετασθεῖσαι τεῦξαν φάος· αὐτὰρ Ἀπόλλων{l]
[l [n}21.539{]}ἀντίος ἐξέθορε Τρώων ἵνα λοιγὸν ἀλάλκοι.{l]
[l [n}21.540{]}οἳ δʼ ἰθὺς πόλιος καὶ τείχεος ὑψηλοῖο{l]
[l [n}21.541{]}δίψῃ καρχαλέοι κεκονιμένοι ἐκ πεδίοιο{l]
[l [n}21.542{]}φεῦγον· ὃ δὲ σφεδανὸν ἔφεπʼ ἔγχεϊ, λύσσα δέ οἱ κῆρ{l]
[l [n}21.543{]}αἰὲν ἔχε κρατερή, μενέαινε δὲ κῦδος ἀρέσθαι.{l]{para]
[para}[l [n}21.544{]}ἔνθά κεν ὑψίπυλον Τροίην ἕλον υἷες Ἀχαιῶν,{l]
[l [n}21.545{]}εἰ μὴ Ἀπόλλων Φοῖβος Ἀγήνορα δῖον ἀνῆκε{l]
[l [n}21.546{]}φῶτʼ Ἀντήνορος υἱὸν ἀμύμονά τε κρατερόν τε.{l]
[l [n}21.547{]}ἐν μέν οἱ κραδίῃ θάρσος βάλε, πὰρ δέ οἱ αὐτὸς{l]
[l [n}21.548{]}ἔστη, ὅπως θανάτοιο βαρείας χεῖρας ἀλάλκοι{l]
[l [n}21.549{]}φηγῷ κεκλιμένος· κεκάλυπτο δʼ ἄρʼ ἠέρι πολλῇ.{l]
[l [n}21.550{]}αὐτὰρ ὅ γʼ ὡς ἐνόησεν Ἀχιλλῆα πτολίπορθον{l]
[l [n}21.551{]}ἔστη, πολλὰ δέ οἱ κραδίη πόρφυρε μένοντι·{l]
[l [n}21.552{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}21.553{]}ὤ μοι ἐγών· εἰ μέν κεν ὑπὸ κρατεροῦ Ἀχιλῆος{l]
[l [n}21.554{]}φεύγω, τῇ περ οἱ ἄλλοι ἀτυζόμενοι κλονέονται,{l]
[l [n}21.555{]}αἱρήσει με καὶ ὧς, καὶ ἀνάλκιδα δειροτομήσει.{l]
[l [n}21.556{]}εἰ δʼ ἂν ἐγὼ τούτους μὲν ὑποκλονέεσθαι ἐάσω{l]
[l [n}21.557{]}Πηλεΐδῃ Ἀχιλῆϊ, ποσὶν δʼ ἀπὸ τείχεος ἄλλῃ{l]
[l [n}21.558{]}φεύγω πρὸς πεδίον Ἰλήϊον, ὄφρʼ ἂν ἵκωμαι{l]
[l [n}21.559{]}Ἴδης τε κνημοὺς κατά τε ῥωπήϊα δύω·{l]
[l [n}21.560{]}ἑσπέριος δʼ ἂν ἔπειτα λοεσσάμενος ποταμοῖο{l]
[l [n}21.561{]}ἱδρῶ ἀποψυχθεὶς προτὶ Ἴλιον ἀπονεοίμην·{l]
[l [n}21.562{]}ἀλλὰ τί ἤ μοι ταῦτα φίλος διελέξατο θυμός;{l]
[l [n}21.563{]}μή μʼ ἀπαειρόμενον πόλιος πεδίον δὲ νοήσῃ{l]
[l [n}21.564{]}καί με μεταΐξας μάρψῃ ταχέεσσι πόδεσσιν.{l]
[l [n}21.565{]}οὐκέτʼ ἔπειτʼ ἔσται θάνατον καὶ κῆρας ἀλύξαι·{l]
[l [n}21.566{]}λίην γὰρ κρατερὸς περὶ πάντων ἔστʼ ἀνθρώπων.{l]
[l [n}21.567{]}εἰ δέ κέ οἱ προπάροιθε πόλεος κατεναντίον ἔλθω·{l]
[l [n}21.568{]}καὶ γάρ θην τούτῳ τρωτὸς χρὼς ὀξέϊ χαλκῷ,{l]
[l [n}21.569{]}ἐν δὲ ἴα ψυχή, θνητὸν δέ ἕ φασʼ ἄνθρωποι{l]
[l [n}21.570{]}ἔμμεναι· αὐτάρ οἱ Κρονίδης Ζεὺς κῦδος ὀπάζει.{l]{q]{para]
[para}[l [n}21.571{]}ὣς εἰπὼν Ἀχιλῆα ἀλεὶς μένεν, ἐν δέ οἱ ἦτορ{l]
[l [n}21.572{]}ἄλκιμον ὁρμᾶτο πτολεμίζειν ἠδὲ μάχεσθαι.{l]
[l [n}21.573{]}ἠΰτε πάρδαλις εἶσι βαθείης ἐκ ξυλόχοιο{l]
[l [n}21.574{]}ἀνδρὸς θηρητῆρος ἐναντίον, οὐδέ τι θυμῷ{l]
[l [n}21.575{]}ταρβεῖ οὐδὲ φοβεῖται, ἐπεί κεν ὑλαγμὸν ἀκούσῃ·{l]
[l [n}21.576{]}εἴ περ γὰρ φθάμενός μιν ἢ οὐτάσῃ ἠὲ βάλῃσιν,{l]
[l [n}21.577{]}ἀλλά τε καὶ περὶ δουρὶ πεπαρμένη οὐκ ἀπολήγει{l]
[l [n}21.578{]}ἀλκῆς, πρίν γʼ ἠὲ ξυμβλήμεναι ἠὲ δαμῆναι·{l]
[l [n}21.579{]}ὣς Ἀντήνορος υἱὸς ἀγαυοῦ δῖος Ἀγήνωρ{l]
[l [n}21.580{]}οὐκ ἔθελεν φεύγειν, πρὶν πειρήσαιτʼ Ἀχιλῆος.{l]
[l [n}21.581{]}ἀλλʼ ὅ γʼ ἄρʼ ἀσπίδα μὲν πρόσθʼ ἔσχετο πάντοσʼ ἐΐσην,{l]
[l [n}21.582{]}ἐγχείῃ δʼ αὐτοῖο τιτύσκετο, καὶ μέγʼ ἀΰτει·{l]
[q}[l [n}21.583{]}ἦ δή που μάλʼ ἔολπας ἐνὶ φρεσὶ φαίδιμʼ Ἀχιλλεῦ{l]
[l [n}21.584{]}ἤματι τῷδε πόλιν πέρσειν Τρώων ἀγερώχων{l]
[l [n}21.585{]}νηπύτιʼ· ἦ τʼ ἔτι πολλὰ τετεύξεται ἄλγεʼ ἐπʼ αὐτῇ.{l]
[l [n}21.586{]}ἐν γάρ οἱ πολέες τε καὶ ἄλκιμοι ἀνέρες εἰμέν,{l]
[l [n}21.587{]}οἳ καὶ πρόσθε φίλων τοκέων ἀλόχων τε καὶ υἱῶν{l]
[l [n}21.588{]}Ἴλιον εἰρυόμεσθα· σὺ δʼ ἐνθάδε πότμον ἐφέψεις{l]
[l [n}21.589{]}ὧδʼ ἔκπαγλος ἐὼν καὶ θαρσαλέος πολεμιστής.{l]{q]{para]
[para}[l [n}21.590{]}ἦ ῥα, καὶ ὀξὺν ἄκοντα βαρείης χειρὸς ἀφῆκε,{l]
[l [n}21.591{]}καί ῥʼ ἔβαλε κνήμην ὑπὸ γούνατος οὐδʼ ἀφάμαρτεν.{l]
[l [n}21.592{]}ἀμφὶ δέ οἱ κνημὶς νεοτεύκτου κασσιτέροιο{l]
[l [n}21.593{]}σμερδαλέον κονάβησε· πάλιν δʼ ἀπὸ χαλκὸς ὄρουσε{l]
[l [n}21.594{]}βλημένου, οὐδʼ ἐπέρησε, θεοῦ δʼ ἠρύκακε δῶρα.{l]
[l [n}21.595{]}Πηλεΐδης δʼ ὁρμήσατʼ Ἀγήνορος ἀντιθέοιο{l]
[l [n}21.596{]}δεύτερος· οὐδʼ ἔτʼ ἔασεν Ἀπόλλων κῦδος ἀρέσθαι,{l]
[l [n}21.597{]}ἀλλά μιν ἐξήρπαξε, κάλυψε δʼ ἄρʼ ἠέρι πολλῇ,{l]
[l [n}21.598{]}ἡσύχιον δʼ ἄρα μιν πολέμου ἔκπεμπε νέεσθαι.{l]
[l [n}21.599{]}αὐτὰρ ὃ Πηλεΐωνα δόλῳ ἀποέργαθε λαοῦ·{l]
[l [n}21.600{]}αὐτῷ γὰρ ἑκάεργος Ἀγήνορι πάντα ἐοικὼς{l]
[l [n}21.601{]}ἔστη πρόσθε ποδῶν, ὃ δʼ ἐπέσσυτο ποσσὶ διώκειν·{l]
[l [n}21.602{]}εἷος ὃ τὸν πεδίοιο διώκετο πυροφόροιο{l]
[l [n}21.603{]}τρέψας πὰρ ποταμὸν βαθυδινήεντα Σκάμανδρον{l]
[l [n}21.604{]}τυτθὸν ὑπεκπροθέοντα· δόλῳ δʼ ἄρʼ ἔθελγεν Ἀπόλλων{l]
[l [n}21.605{]}ὡς αἰεὶ ἔλποιτο κιχήσεσθαι ποσὶν οἷσι·{l]
[l [n}21.606{]}τόφρʼ ἄλλοι Τρῶες πεφοβημένοι ἦλθον ὁμίλῳ{l]
[l [n}21.607{]}ἀσπάσιοι προτὶ ἄστυ, πόλις δʼ ἔμπλητο ἀλέντων.{l]
[l [n}21.608{]}οὐδʼ ἄρα τοί γʼ ἔτλαν πόλιος καὶ τείχεος ἐκτὸς{l]
[l [n}21.609{]}μεῖναι ἔτʼ ἀλλήλους, καὶ γνώμεναι ὅς τε πεφεύγοι{l]
[l [n}21.610{]}ὅς τʼ ἔθανʼ ἐν πολέμῳ· ἀλλʼ ἐσσυμένως ἐσέχυντο{l]
[l [n}21.611{]}ἐς πόλιν, ὅν τινα τῶν γε πόδες καὶ γοῦνα σαώσαι.{l]{para]
{book]
[book [n}22{]}[l [n}22.1{]}ὣς οἳ μὲν κατὰ ἄστυ πεφυζότες ἠΰτε νεβροὶ{l]
[l [n}22.2{]}ἱδρῶ ἀπεψύχοντο πίον τʼ ἀκέοντό τε δίψαν{l]
[l [n}22.3{]}κεκλιμένοι καλῇσιν ἐπάλξεσιν· αὐτὰρ Ἀχαιοὶ{l]
[l [n}22.4{]}τείχεος ἆσσον ἴσαν σάκεʼ ὤμοισι κλίναντες.{l]
[l [n}22.5{]}Ἕκτορα δʼ αὐτοῦ μεῖναι ὀλοιὴ μοῖρα πέδησεν{l]
[l [n}22.6{]}Ἰλίου προπάροιθε πυλάων τε Σκαιάων.{l]
[l [n}22.7{]}αὐτὰρ Πηλείωνα προσηύδα Φοῖβος Ἀπόλλων·{l]
[q}[l [n}22.8{]}τίπτέ με Πηλέος υἱὲ ποσὶν ταχέεσσι διώκεις{l]
[l [n}22.9{]}αὐτὸς θνητὸς ἐὼν θεὸν ἄμβροτον; οὐδέ νύ πώ με{l]
[l [n}22.10{]}ἔγνως ὡς θεός εἰμι, σὺ δʼ ἀσπερχὲς μενεαίνεις.{l]
[l [n}22.11{]}ἦ νύ τοι οὔ τι μέλει Τρώων πόνος, οὓς ἐφόβησας,{l]
[l [n}22.12{]}οἳ δή τοι εἰς ἄστυ ἄλεν, σὺ δὲ δεῦρο λιάσθης.{l]
[l [n}22.13{]}οὐ μέν με κτενέεις, ἐπεὶ οὔ τοι μόρσιμός εἰμι.{l]{q]
[para}[l [n}22.14{]}τὸν δὲ μέγʼ ὀχθήσας προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}22.15{]}ἔβλαψάς μʼ ἑκάεργε θεῶν ὀλοώτατε πάντων{l]
[l [n}22.16{]}ἐνθάδε νῦν τρέψας ἀπὸ τείχεος· ἦ κʼ ἔτι πολλοὶ{l]
[l [n}22.17{]}γαῖαν ὀδὰξ εἷλον πρὶν Ἴλιον εἰσαφικέσθαι.{l]
[l [n}22.18{]}νῦν δʼ ἐμὲ μὲν μέγα κῦδος ἀφείλεο, τοὺς δὲ σάωσας{l]
[l [n}22.19{]}ῥηϊδίως, ἐπεὶ οὔ τι τίσιν γʼ ἔδεισας ὀπίσσω.{l]
[l [n}22.20{]}ἦ σʼ ἂν τισαίμην, εἴ μοι δύναμίς γε παρείη.{l]{q]{para]
[para}[l [n}22.21{]}ὣς εἰπὼν προτὶ ἄστυ μέγα φρονέων ἐβεβήκει,{l]
[l [n}22.22{]}σευάμενος ὥς θʼ ἵππος ἀεθλοφόρος σὺν ὄχεσφιν,{l]
[l [n}22.23{]}ὅς ῥά τε ῥεῖα θέῃσι τιταινόμενος πεδίοιο·{l]
[l [n}22.24{]}ὣς Ἀχιλεὺς λαιψηρὰ πόδας καὶ γούνατʼ ἐνώμα.{l]{para]
[para}[l [n}22.25{]}τὸν δʼ ὃ γέρων Πρίαμος πρῶτος ἴδεν ὀφθαλμοῖσι{l]
[l [n}22.26{]}παμφαίνονθʼ ὥς τʼ ἀστέρʼ ἐπεσσύμενον πεδίοιο,{l]
[l [n}22.27{]}ὅς ῥά τʼ ὀπώρης εἶσιν, ἀρίζηλοι δέ οἱ αὐγαὶ{l]
[l [n}22.28{]}φαίνονται πολλοῖσι μετʼ ἀστράσι νυκτὸς ἀμολγῷ,{l]
[l [n}22.29{]}ὅν τε κύνʼ Ὠρίωνος ἐπίκλησιν καλέουσι.{l]
[l [n}22.30{]}λαμπρότατος μὲν ὅ γʼ ἐστί, κακὸν δέ τε σῆμα τέτυκται,{l]
[l [n}22.31{]}καί τε φέρει πολλὸν πυρετὸν δειλοῖσι βροτοῖσιν·{l]
[l [n}22.32{]}ὣς τοῦ χαλκὸς ἔλαμπε περὶ στήθεσσι θέοντος.{l]
[l [n}22.33{]}ᾤμωξεν δʼ ὃ γέρων, κεφαλὴν δʼ ὅ γε κόψατο χερσὶν{l]
[l [n}22.34{]}ὑψόσʼ ἀνασχόμενος, μέγα δʼ οἰμώξας ἐγεγώνει{l]
[l [n}22.35{]}λισσόμενος φίλον υἱόν· ὃ δὲ προπάροιθε πυλάων{l]
[l [n}22.36{]}ἑστήκει ἄμοτον μεμαὼς Ἀχιλῆϊ μάχεσθαι·{l]
[l [n}22.37{]}τὸν δʼ ὃ γέρων ἐλεεινὰ προσηύδα χεῖρας ὀρεγνύς·{l]
[q}
[para}[l [n}22.38{]}Ἕκτορ μή μοι μίμνε φίλον τέκος ἀνέρα τοῦτον{l]
[l [n}22.39{]}οἶος ἄνευθʼ ἄλλων, ἵνα μὴ τάχα πότμον ἐπίσπῃς{l]
[l [n}22.40{]}Πηλεΐωνι δαμείς, ἐπεὶ ἦ πολὺ φέρτερός ἐστι{l]
[l [n}22.41{]}σχέτλιος· αἴθε θεοῖσι φίλος τοσσόνδε γένοιτο{l]
[l [n}22.42{]}ὅσσον ἐμοί· τάχα κέν ἑ κύνες καὶ γῦπες ἔδοιεν{l]
[l [n}22.43{]}κείμενον· ἦ κέ μοι αἰνὸν ἀπὸ πραπίδων ἄχος ἔλθοι·{l]
[l [n}22.44{]}ὅς μʼ υἱῶν πολλῶν τε καὶ ἐσθλῶν εὖνιν ἔθηκε{l]
[l [n}22.45{]}κτείνων καὶ περνὰς νήσων ἔπι τηλεδαπάων.{l]
[l [n}22.46{]}καὶ γὰρ νῦν δύο παῖδε Λυκάονα καὶ Πολύδωρον{l]
[l [n}22.47{]}οὐ δύναμαι ἰδέειν Τρώων εἰς ἄστυ ἀλέντων,{l]
[l [n}22.48{]}τούς μοι Λαοθόη τέκετο κρείουσα γυναικῶν.{l]
[l [n}22.49{]}ἀλλʼ εἰ μὲν ζώουσι μετὰ στρατῷ, ἦ τʼ ἂν ἔπειτα{l]
[l [n}22.50{]}χαλκοῦ τε χρυσοῦ τʼ ἀπολυσόμεθʼ, ἔστι γὰρ ἔνδον·{l]
[l [n}22.51{]}πολλὰ γὰρ ὤπασε παιδὶ γέρων ὀνομάκλυτος Ἄλτης.{l]
[l [n}22.52{]}εἰ δʼ ἤδη τεθνᾶσι καὶ εἰν Ἀΐδαο δόμοισιν,{l]
[l [n}22.53{]}ἄλγος ἐμῷ θυμῷ καὶ μητέρι τοὶ τεκόμεσθα·{l]
[l [n}22.54{]}λαοῖσιν δʼ ἄλλοισι μινυνθαδιώτερον ἄλγος{l]
[l [n}22.55{]}ἔσσεται, ἢν μὴ καὶ σὺ θάνῃς Ἀχιλῆϊ δαμασθείς.{l]
[l [n}22.56{]}ἀλλʼ εἰσέρχεο τεῖχος ἐμὸν τέκος, ὄφρα σαώσῃς{l]
[l [n}22.57{]}Τρῶας καὶ Τρῳάς, μὴ δὲ μέγα κῦδος ὀρέξῃς{l]
[l [n}22.58{]}Πηλεΐδῃ, αὐτὸς δὲ φίλης αἰῶνος ἀμερθῇς.{l]
[l [n}22.59{]}πρὸς δʼ ἐμὲ τὸν δύστηνον ἔτι φρονέοντʼ ἐλέησον{l]
[l [n}22.60{]}δύσμορον, ὅν ῥα πατὴρ Κρονίδης ἐπὶ γήραος οὐδῷ{l]
[l [n}22.61{]}αἴσῃ ἐν ἀργαλέῃ φθίσει κακὰ πόλλʼ ἐπιδόντα{l]
[l [n}22.62{]}υἷάς τʼ ὀλλυμένους ἑλκηθείσας τε θύγατρας,{l]
[l [n}22.63{]}καὶ θαλάμους κεραϊζομένους, καὶ νήπια τέκνα{l]
[l [n}22.64{]}βαλλόμενα προτὶ γαίῃ ἐν αἰνῇ δηϊοτῆτι,{l]
[l [n}22.65{]}ἑλκομένας τε νυοὺς ὀλοῇς ὑπὸ χερσὶν Ἀχαιῶν.{l]
[l [n}22.66{]}αὐτὸν δʼ ἂν πύματόν με κύνες πρώτῃσι θύρῃσιν{l]
[l [n}22.67{]}ὠμησταὶ ἐρύουσιν, ἐπεί κέ τις ὀξέϊ χαλκῷ{l]
[l [n}22.68{]}τύψας ἠὲ βαλὼν ῥεθέων ἐκ θυμὸν ἕληται,{l]
[l [n}22.69{]}οὓς τρέφον ἐν μεγάροισι τραπεζῆας θυραωρούς,{l]
[l [n}22.70{]}οἵ κʼ ἐμὸν αἷμα πιόντες ἀλύσσοντες περὶ θυμῷ{l]
[l [n}22.71{]}κείσοντʼ ἐν προθύροισι. νέῳ δέ τε πάντʼ ἐπέοικεν{l]
[l [n}22.72{]}ἄρηϊ κταμένῳ δεδαϊγμένῳ ὀξέϊ χαλκῷ{l]
[l [n}22.73{]}κεῖσθαι· πάντα δὲ καλὰ θανόντι περ ὅττι φανήῃ·{l]
[l [n}22.74{]}ἀλλʼ ὅτε δὴ πολιόν τε κάρη πολιόν τε γένειον{l]
[l [n}22.75{]}αἰδῶ τʼ αἰσχύνωσι κύνες κταμένοιο γέροντος,{l]
[l [n}22.76{]}τοῦτο δὴ οἴκτιστον πέλεται δειλοῖσι βροτοῖσιν.{l]{q]{para]
[para}[l [n}22.77{]}ἦ ῥʼ ὃ γέρων, πολιὰς δʼ ἄρʼ ἀνὰ τρίχας ἕλκετο χερσὶ{l]
[l [n}22.78{]}τίλλων ἐκ κεφαλῆς· οὐδʼ Ἕκτορι θυμὸν ἔπειθε.{l]
[l [n}22.79{]}μήτηρ δʼ αὖθʼ ἑτέρωθεν ὀδύρετο δάκρυ χέουσα{l]
[l [n}22.80{]}κόλπον ἀνιεμένη, ἑτέρηφι δὲ μαζὸν ἀνέσχε·{l]
[l [n}22.81{]}καί μιν δάκρυ χέουσʼ ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}22.82{]}Ἕκτορ τέκνον ἐμὸν τάδε τʼ αἴδεο καί μʼ ἐλέησον{l]
[l [n}22.83{]}αὐτήν, εἴ ποτέ τοι λαθικηδέα μαζὸν ἐπέσχον·{l]
[l [n}22.84{]}τῶν μνῆσαι φίλε τέκνον ἄμυνε δὲ δήϊον ἄνδρα{l]
[l [n}22.85{]}τείχεος ἐντὸς ἐών, μὴ δὲ πρόμος ἵστασο τούτῳ{l]
[l [n}22.86{]}σχέτλιος· εἴ περ γάρ σε κατακτάνῃ, οὔ σʼ ἔτʼ ἔγωγε{l]
[l [n}22.87{]}κλαύσομαι ἐν λεχέεσσι φίλον θάλος, ὃν τέκον αὐτή,{l]
[l [n}22.88{]}οὐδʼ ἄλοχος πολύδωρος· ἄνευθε δέ σε μέγα νῶϊν{l]
[l [n}22.89{]}Ἀργείων παρὰ νηυσὶ κύνες ταχέες κατέδονται.{l]{q]{para]
[para}[l [n}22.90{]}ὣς τώ γε κλαίοντε προσαυδήτην φίλον υἱὸν{l]
[l [n}22.91{]}πολλὰ λισσομένω· οὐδʼ Ἕκτορι θυμὸν ἔπειθον,{l]
[l [n}22.92{]}ἀλλʼ ὅ γε μίμνʼ Ἀχιλῆα πελώριον ἆσσον ἰόντα.{l]
[l [n}22.93{]}ὡς δὲ δράκων ἐπὶ χειῇ ὀρέστερος ἄνδρα μένῃσι{l]
[l [n}22.94{]}βεβρωκὼς κακὰ φάρμακʼ, ἔδυ δέ τέ μιν χόλος αἰνός,{l]
[l [n}22.95{]}σμερδαλέον δὲ δέδορκεν ἑλισσόμενος περὶ χειῇ·{l]
[l [n}22.96{]}ὣς Ἕκτωρ ἄσβεστον ἔχων μένος οὐχ ὑπεχώρει{l]
[l [n}22.97{]}πύργῳ ἔπι προὔχοντι φαεινὴν ἀσπίδʼ ἐρείσας·{l]
[l [n}22.98{]}ὀχθήσας δʼ ἄρα εἶπε πρὸς ὃν μεγαλήτορα θυμόν·{l]
[q}[l [n}22.99{]}ὤ μοι ἐγών, εἰ μέν κε πύλας καὶ τείχεα δύω,{l]
[l [n}22.100{]}Πουλυδάμας μοι πρῶτος ἐλεγχείην ἀναθήσει,{l]
[l [n}22.101{]}ὅς μʼ ἐκέλευε Τρωσὶ ποτὶ πτόλιν ἡγήσασθαι{l]
[l [n}22.102{]}νύχθʼ ὕπο τήνδʼ ὀλοὴν ὅτε τʼ ὤρετο δῖος Ἀχιλλεύς.{l]
[l [n}22.103{]}ἀλλʼ ἐγὼ οὐ πιθόμην· ἦ τʼ ἂν πολὺ κέρδιον ἦεν.{l]
[l [n}22.104{]}νῦν δʼ ἐπεὶ ὤλεσα λαὸν ἀτασθαλίῃσιν ἐμῇσιν,{l]
[l [n}22.105{]}αἰδέομαι Τρῶας καὶ Τρῳάδας ἑλκεσιπέπλους,{l]
[l [n}22.106{]}μή ποτέ τις εἴπῃσι κακώτερος ἄλλος ἐμεῖο·{l]
[q}[l [n}22.107{]}Ἕκτωρ ἧφι βίηφι πιθήσας ὤλεσε λαόν.{l]{q][l [n}22.108{]}ὣς ἐρέουσιν· ἐμοὶ δὲ τότʼ ἂν πολὺ κέρδιον εἴη{l]
[l [n}22.109{]}ἄντην ἢ Ἀχιλῆα κατακτείναντα νέεσθαι,{l]
[l [n}22.110{]}ἠέ κεν αὐτῷ ὀλέσθαι ἐϋκλειῶς πρὸ πόληος.{l]
[l [n}22.111{]}εἰ δέ κεν ἀσπίδα μὲν καταθείομαι ὀμφαλόεσσαν{l]
[l [n}22.112{]}καὶ κόρυθα βριαρήν, δόρυ δὲ πρὸς τεῖχος ἐρείσας{l]
[l [n}22.113{]}αὐτὸς ἰὼν Ἀχιλῆος ἀμύμονος ἀντίος ἔλθω{l]
[l [n}22.114{]}καί οἱ ὑπόσχωμαι Ἑλένην καὶ κτήμαθʼ ἅμʼ αὐτῇ,{l]
[l [n}22.115{]}πάντα μάλʼ ὅσσά τʼ Ἀλέξανδρος κοίλῃς ἐνὶ νηυσὶν{l]
[l [n}22.116{]}ἠγάγετο Τροίηνδʼ, ἥ τʼ ἔπλετο νείκεος ἀρχή,{l]
[l [n}22.117{]}δωσέμεν Ἀτρεΐδῃσιν ἄγειν, ἅμα δʼ ἀμφὶς Ἀχαιοῖς{l]
[l [n}22.118{]}ἄλλʼ ἀποδάσσεσθαι ὅσα τε πτόλις ἥδε κέκευθε·{l]
[l [n}22.119{]}Τρωσὶν δʼ αὖ μετόπισθε γερούσιον ὅρκον ἕλωμαι{l]
[l [n}22.120{]}μή τι κατακρύψειν, ἀλλʼ ἄνδιχα πάντα δάσασθαι{l]
[l [n}22.121{]}κτῆσιν ὅσην πτολίεθρον ἐπήρατον ἐντὸς ἐέργει·{l]
[l [n}22.122{]}ἀλλὰ τί ἤ μοι ταῦτα φίλος διελέξατο θυμός;{l]
[l [n}22.123{]}μή μιν ἐγὼ μὲν ἵκωμαι ἰών, ὃ δέ μʼ οὐκ ἐλεήσει{l]
[l [n}22.124{]}οὐδέ τί μʼ αἰδέσεται, κτενέει δέ με γυμνὸν ἐόντα{l]
[l [n}22.125{]}αὔτως ὥς τε γυναῖκα, ἐπεί κʼ ἀπὸ τεύχεα δύω.{l]
[l [n}22.126{]}οὐ μέν πως νῦν ἔστιν ἀπὸ δρυὸς οὐδʼ ἀπὸ πέτρης{l]
[l [n}22.127{]}τῷ ὀαριζέμεναι, ἅ τε παρθένος ἠΐθεός τε{l]
[l [n}22.128{]}παρθένος ἠΐθεός τʼ ὀαρίζετον ἀλλήλοιιν.{l]
[l [n}22.129{]}βέλτερον αὖτʼ ἔριδι ξυνελαυνέμεν ὅττι τάχιστα·{l]
[l [n}22.130{]}εἴδομεν ὁπποτέρῳ κεν Ὀλύμπιος εὖχος ὀρέξῃ.{l]{q]{para]
[para}[l [n}22.131{]}ὣς ὅρμαινε μένων, ὃ δέ οἱ σχεδὸν ἦλθεν Ἀχιλλεὺς{l]
[l [n}22.132{]}ἶσος Ἐνυαλίῳ κορυθάϊκι πτολεμιστῇ{l]
[l [n}22.133{]}σείων Πηλιάδα μελίην κατὰ δεξιὸν ὦμον{l]
[l [n}22.134{]}δεινήν· ἀμφὶ δὲ χαλκὸς ἐλάμπετο εἴκελος αὐγῇ{l]
[l [n}22.135{]}ἢ πυρὸς αἰθομένου ἢ ἠελίου ἀνιόντος.{l]
[l [n}22.136{]}Ἕκτορα δʼ, ὡς ἐνόησεν, ἕλε τρόμος· οὐδʼ ἄρʼ ἔτʼ ἔτλη{l]
[l [n}22.137{]}αὖθι μένειν, ὀπίσω δὲ πύλας λίπε, βῆ δὲ φοβηθείς·{l]
[l [n}22.138{]}Πηλεΐδης δʼ ἐπόρουσε ποσὶ κραιπνοῖσι πεποιθώς.{l]
[l [n}22.139{]}ἠΰτε κίρκος ὄρεσφιν ἐλαφρότατος πετεηνῶν{l]
[l [n}22.140{]}ῥηϊδίως οἴμησε μετὰ τρήρωνα πέλειαν,{l]
[l [n}22.141{]}ἣ δέ θʼ ὕπαιθα φοβεῖται, ὃ δʼ ἐγγύθεν ὀξὺ λεληκὼς{l]
[l [n}22.142{]}ταρφέʼ ἐπαΐσσει, ἑλέειν τέ ἑ θυμὸς ἀνώγει·{l]
[l [n}22.143{]}ὣς ἄρʼ ὅ γʼ ἐμμεμαὼς ἰθὺς πέτετο, τρέσε δʼ Ἕκτωρ{l]
[l [n}22.144{]}τεῖχος ὕπο Τρώων, λαιψηρὰ δὲ γούνατʼ ἐνώμα.{l]
[l [n}22.145{]}οἳ δὲ παρὰ σκοπιὴν καὶ ἐρινεὸν ἠνεμόεντα{l]
[l [n}22.146{]}τείχεος αἰὲν ὑπʼ ἐκ κατʼ ἀμαξιτὸν ἐσσεύοντο,{l]
[l [n}22.147{]}κρουνὼ δʼ ἵκανον καλλιρρόω· ἔνθα δὲ πηγαὶ{l]
[l [n}22.148{]}δοιαὶ ἀναΐσσουσι Σκαμάνδρου δινήεντος.{l]
[l [n}22.149{]}ἣ μὲν γάρ θʼ ὕδατι λιαρῷ ῥέει, ἀμφὶ δὲ καπνὸς{l]
[l [n}22.150{]}γίγνεται ἐξ αὐτῆς ὡς εἰ πυρὸς αἰθομένοιο·{l]
[l [n}22.151{]}ἣ δʼ ἑτέρη θέρεϊ προρέει ἐϊκυῖα χαλάζῃ,{l]
[l [n}22.152{]}ἢ χιόνι ψυχρῇ ἢ ἐξ ὕδατος κρυστάλλῳ.{l]
[l [n}22.153{]}ἔνθα δʼ ἐπʼ αὐτάων πλυνοὶ εὐρέες ἐγγὺς ἔασι{l]
[l [n}22.154{]}καλοὶ λαΐνεοι, ὅθι εἵματα σιγαλόεντα{l]
[l [n}22.155{]}πλύνεσκον Τρώων ἄλοχοι καλαί τε θύγατρες{l]
[l [n}22.156{]}τὸ πρὶν ἐπʼ εἰρήνης πρὶν ἐλθεῖν υἷας Ἀχαιῶν.{l]
[l [n}22.157{]}τῇ ῥα παραδραμέτην φεύγων ὃ δʼ ὄπισθε διώκων·{l]
[l [n}22.158{]}πρόσθε μὲν ἐσθλὸς ἔφευγε, δίωκε δέ μιν μέγʼ ἀμείνων{l]
[l [n}22.159{]}καρπαλίμως, ἐπεὶ οὐχ ἱερήϊον οὐδὲ βοείην{l]
[l [n}22.160{]}ἀρνύσθην, ἅ τε ποσσὶν ἀέθλια γίγνεται ἀνδρῶν,{l]
[l [n}22.161{]}ἀλλὰ περὶ ψυχῆς θέον Ἕκτορος ἱπποδάμοιο.{l]
[l [n}22.162{]}ὡς δʼ ὅτʼ ἀεθλοφόροι περὶ τέρματα μώνυχες ἵπποι{l]
[l [n}22.163{]}ῥίμφα μάλα τρωχῶσι· τὸ δὲ μέγα κεῖται ἄεθλον{l]
[l [n}22.164{]}ἢ τρίπος ἠὲ γυνὴ ἀνδρὸς κατατεθνηῶτος·{l]
[l [n}22.165{]}ὣς τὼ τρὶς Πριάμοιο πόλιν πέρι δινηθήτην{l]
[l [n}22.166{]}καρπαλίμοισι πόδεσσι· θεοὶ δʼ ἐς πάντες ὁρῶντο·{l]
[l [n}22.167{]}τοῖσι δὲ μύθων ἦρχε πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[q}[l [n}22.168{]}ὢ πόποι ἦ φίλον ἄνδρα διωκόμενον περὶ τεῖχος{l]
[l [n}22.169{]}ὀφθαλμοῖσιν ὁρῶμαι· ἐμὸν δʼ ὀλοφύρεται ἦτορ{l]
[l [n}22.170{]}Ἕκτορος, ὅς μοι πολλὰ βοῶν ἐπὶ μηρίʼ ἔκηεν{l]
[l [n}22.171{]}Ἴδης ἐν κορυφῇσι πολυπτύχου, ἄλλοτε δʼ αὖτε{l]
[l [n}22.172{]}ἐν πόλει ἀκροτάτῃ· νῦν αὖτέ ἑ δῖος Ἀχιλλεὺς{l]
[l [n}22.173{]}ἄστυ πέρι Πριάμοιο ποσὶν ταχέεσσι διώκει.{l]
[l [n}22.174{]}ἀλλʼ ἄγετε φράζεσθε θεοὶ καὶ μητιάασθε{l]
[l [n}22.175{]}ἠέ μιν ἐκ θανάτοιο σαώσομεν, ἦέ μιν ἤδη{l]
[l [n}22.176{]}Πηλεΐδῃ Ἀχιλῆϊ δαμάσσομεν ἐσθλὸν ἐόντα.{l]{q]{para]
[para}[l [n}22.177{]}τὸν δʼ αὖτε προσέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}22.178{]}ὦ πάτερ ἀργικέραυνε κελαινεφὲς οἷον ἔειπες·{l]
[l [n}22.179{]}ἄνδρα θνητὸν ἐόντα πάλαι πεπρωμένον αἴσῃ{l]
[l [n}22.180{]}ἂψ ἐθέλεις θανάτοιο δυσηχέος ἐξαναλῦσαι;{l]
[l [n}22.181{]}ἔρδʼ· ἀτὰρ οὔ τοι πάντες ἐπαινέομεν θεοὶ ἄλλοι.{l]{q]{para]
[para}[l [n}22.182{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}22.183{]}θάρσει Τριτογένεια φίλον τέκος· οὔ νύ τι θυμῷ{l]
[l [n}22.184{]}πρόφρονι μυθέομαι, ἐθέλω δέ τοι ἤπιος εἶναι·{l]
[l [n}22.185{]}ἔρξον ὅπῃ δή τοι νόος ἔπλετο, μὴ δʼ ἔτʼ ἐρώει.{l]{q]{para]
[para}[l [n}22.186{]}ὣς εἰπὼν ὄτρυνε πάρος μεμαυῖαν Ἀθήνην·{l]
[l [n}22.187{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων ἀΐξασα.{l]{para]
[para}[l [n}22.188{]}Ἕκτορα δʼ ἀσπερχὲς κλονέων ἔφεπʼ ὠκὺς Ἀχιλλεύς.{l]
[l [n}22.189{]}ὡς δʼ ὅτε νεβρὸν ὄρεσφι κύων ἐλάφοιο δίηται{l]
[l [n}22.190{]}ὄρσας ἐξ εὐνῆς διά τʼ ἄγκεα καὶ διὰ βήσσας·{l]
[l [n}22.191{]}τὸν δʼ εἴ πέρ τε λάθῃσι καταπτήξας ὑπὸ θάμνῳ,{l]
[l [n}22.192{]}ἀλλά τʼ ἀνιχνεύων θέει ἔμπεδον ὄφρά κεν εὕρῃ·{l]
[l [n}22.193{]}ὣς Ἕκτωρ οὐ λῆθε ποδώκεα Πηλεΐωνα.{l]
[l [n}22.194{]}ὁσσάκι δʼ ὁρμήσειε πυλάων Δαρδανιάων{l]
[l [n}22.195{]}ἀντίον ἀΐξασθαι ἐϋδμήτους ὑπὸ πύργους,{l]
[l [n}22.196{]}εἴ πως οἷ καθύπερθεν ἀλάλκοιεν βελέεσσι,{l]
[l [n}22.197{]}τοσσάκι μιν προπάροιθεν ἀποστρέψασκε παραφθὰς{l]
[l [n}22.198{]}πρὸς πεδίον· αὐτὸς δὲ ποτὶ πτόλιος πέτετʼ αἰεί.{l]
[l [n}22.199{]}ὡς δʼ ἐν ὀνείρῳ οὐ δύναται φεύγοντα διώκειν·{l]
[l [n}22.200{]}οὔτʼ ἄρʼ ὃ τὸν δύναται ὑποφεύγειν οὔθʼ ὃ διώκειν·{l]
[l [n}22.201{]}ὣς ὃ τὸν οὐ δύνατο μάρψαι ποσίν, οὐδʼ ὃς ἀλύξαι.{l]
[l [n}22.202{]}πῶς δέ κεν Ἕκτωρ κῆρας ὑπεξέφυγεν θανάτοιο,{l]
[l [n}22.203{]}εἰ μή οἱ πύματόν τε καὶ ὕστατον ἤντετʼ Ἀπόλλων{l]
[l [n}22.204{]}ἐγγύθεν, ὅς οἱ ἐπῶρσε μένος λαιψηρά τε γοῦνα;{l]
[l [n}22.205{]}λαοῖσιν δʼ ἀνένευε καρήατι δῖος Ἀχιλλεύς,{l]
[l [n}22.206{]}οὐδʼ ἔα ἱέμεναι ἐπὶ Ἕκτορι πικρὰ βέλεμνα,{l]
[l [n}22.207{]}μή τις κῦδος ἄροιτο βαλών, ὃ δὲ δεύτερος ἔλθοι.{l]
[l [n}22.208{]}ἀλλʼ ὅτε δὴ τὸ τέταρτον ἐπὶ κρουνοὺς ἀφίκοντο,{l]
[l [n}22.209{]}καὶ τότε δὴ χρύσεια πατὴρ ἐτίταινε τάλαντα,{l]
[l [n}22.210{]}ἐν δʼ ἐτίθει δύο κῆρε τανηλεγέος θανάτοιο,{l]
[l [n}22.211{]}τὴν μὲν Ἀχιλλῆος, τὴν δʼ Ἕκτορος ἱπποδάμοιο,{l]
[l [n}22.212{]}ἕλκε δὲ μέσσα λαβών· ῥέπε δʼ Ἕκτορος αἴσιμον ἦμαρ,{l]
[l [n}22.213{]}ᾤχετο δʼ εἰς Ἀΐδαο, λίπεν δέ ἑ Φοῖβος Ἀπόλλων.{l]
[l [n}22.214{]}Πηλεΐωνα δʼ ἵκανε θεὰ γλαυκῶπις Ἀθήνη,{l]
[l [n}22.215{]}ἀγχοῦ δʼ ἱσταμένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}22.216{]}νῦν δὴ νῶι ἔολπα Διῒ φίλε φαίδιμʼ Ἀχιλλεῦ{l]
[l [n}22.217{]}οἴσεσθαι μέγα κῦδος Ἀχαιοῖσι προτὶ νῆας{l]
[l [n}22.218{]}Ἕκτορα δῃώσαντε μάχης ἄατόν περ ἐόντα.{l]
[l [n}22.219{]}οὔ οἱ νῦν ἔτι γʼ ἔστι πεφυγμένον ἄμμε γενέσθαι,{l]
[l [n}22.220{]}οὐδʼ εἴ κεν μάλα πολλὰ πάθοι ἑκάεργος Ἀπόλλων{l]
[l [n}22.221{]}προπροκυλινδόμενος πατρὸς Διὸς αἰγιόχοιο.{l]
[l [n}22.222{]}ἀλλὰ σὺ μὲν νῦν στῆθι καὶ ἄμπνυε, τόνδε δʼ ἐγώ τοι{l]
[l [n}22.223{]}οἰχομένη πεπιθήσω ἐναντίβιον μαχέσασθαι.{l]{q]{para]
[para}[l [n}22.224{]}ὣς φάτʼ Ἀθηναίη, ὃ δʼ ἐπείθετο, χαῖρε δὲ θυμῷ,{l]
[l [n}22.225{]}στῆ δʼ ἄρʼ ἐπὶ μελίης χαλκογλώχινος ἐρεισθείς.{l]
[l [n}22.226{]}ἣ δʼ ἄρα τὸν μὲν ἔλειπε, κιχήσατο δʼ Ἕκτορα δῖον{l]
[l [n}22.227{]}Δηϊφόβῳ ἐϊκυῖα δέμας καὶ ἀτειρέα φωνήν·{l]
[l [n}22.228{]}ἀγχοῦ δʼ ἱσταμένη ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}22.229{]}ἠθεῖʼ ἦ μάλα δή σε βιάζεται ὠκὺς Ἀχιλλεὺς{l]
[l [n}22.230{]}ἄστυ πέρι Πριάμοιο ποσὶν ταχέεσσι διώκων·{l]
[l [n}22.231{]}ἀλλʼ ἄγε δὴ στέωμεν καὶ ἀλεξώμεσθα μένοντες.{l]{q]{para]
[para}[l [n}22.232{]}τὴν δʼ αὖτε προσέειπε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}22.233{]}Δηΐφοβʼ ἦ μέν μοι τὸ πάρος πολὺ φίλτατος ἦσθα{l]
[l [n}22.234{]}γνωτῶν οὓς Ἑκάβη ἠδὲ Πρίαμος τέκε παῖδας·{l]
[l [n}22.235{]}νῦν δʼ ἔτι καὶ μᾶλλον νοέω φρεσὶ τιμήσασθαι,{l]
[l [n}22.236{]}ὃς ἔτλης ἐμεῦ εἵνεκʼ, ἐπεὶ ἴδες ὀφθαλμοῖσι,{l]
[l [n}22.237{]}τείχεος ἐξελθεῖν, ἄλλοι δʼ ἔντοσθε μένουσι.{l]{q]{para]
[para}[l [n}22.238{]}τὸν δʼ αὖτε προσέειπε θεὰ γλαυκῶπις Ἀθήνη·{l]
[q}[l [n}22.239{]}ἠθεῖʼ ἦ μὲν πολλὰ πατὴρ καὶ πότνια μήτηρ{l]
[l [n}22.240{]}λίσσονθʼ ἑξείης γουνούμενοι, ἀμφὶ δʼ ἑταῖροι,{l]
[l [n}22.241{]}αὖθι μένειν· τοῖον γὰρ ὑποτρομέουσιν ἅπαντες·{l]
[l [n}22.242{]}ἀλλʼ ἐμὸς ἔνδοθι θυμὸς ἐτείρετο πένθεϊ λυγρῷ.{l]
[l [n}22.243{]}νῦν δʼ ἰθὺς μεμαῶτε μαχώμεθα, μὴ δέ τι δούρων{l]
[l [n}22.244{]}ἔστω φειδωλή, ἵνα εἴδομεν εἴ κεν Ἀχιλλεὺς{l]
[l [n}22.245{]}νῶϊ κατακτείνας ἔναρα βροτόεντα φέρηται{l]
[l [n}22.246{]}νῆας ἔπι γλαφυράς, ἦ κεν σῷ δουρὶ δαμήῃ.{l]{q]{para]
[para}[l [n}22.247{]}ὣς φαμένη καὶ κερδοσύνῃ ἡγήσατʼ Ἀθήνη·{l]
[l [n}22.248{]}οἳ δʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}22.249{]}τὸν πρότερος προσέειπε μέγας κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}22.250{]}οὔ σʼ ἔτι Πηλέος υἱὲ φοβήσομαι, ὡς τὸ πάρος περ{l]
[l [n}22.251{]}τρὶς περὶ ἄστυ μέγα Πριάμου δίον, οὐδέ ποτʼ ἔτλην{l]
[l [n}22.252{]}μεῖναι ἐπερχόμενον· νῦν αὖτέ με θυμὸς ἀνῆκε{l]
[l [n}22.253{]}στήμεναι ἀντία σεῖο· ἕλοιμί κεν ἤ κεν ἁλοίην.{l]
[l [n}22.254{]}ἀλλʼ ἄγε δεῦρο θεοὺς ἐπιδώμεθα· τοὶ γὰρ ἄριστοι{l]
[l [n}22.255{]}μάρτυροι ἔσσονται καὶ ἐπίσκοποι ἁρμονιάων·{l]
[l [n}22.256{]}οὐ γὰρ ἐγώ σʼ ἔκπαγλον ἀεικιῶ, αἴ κεν ἐμοὶ Ζεὺς{l]
[l [n}22.257{]}δώῃ καμμονίην, σὴν δὲ ψυχὴν ἀφέλωμαι·{l]
[l [n}22.258{]}ἀλλʼ ἐπεὶ ἄρ κέ σε συλήσω κλυτὰ τεύχεʼ Ἀχιλλεῦ{l]
[l [n}22.259{]}νεκρὸν Ἀχαιοῖσιν δώσω πάλιν· ὣς δὲ σὺ ῥέζειν.{l]{q]{para]
[para}[l [n}22.260{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}22.261{]}Ἕκτορ μή μοι ἄλαστε συνημοσύνας ἀγόρευε·{l]
[l [n}22.262{]}ὡς οὐκ ἔστι λέουσι καὶ ἀνδράσιν ὅρκια πιστά,{l]
[l [n}22.263{]}οὐδὲ λύκοι τε καὶ ἄρνες ὁμόφρονα θυμὸν ἔχουσιν,{l]
[l [n}22.264{]}ἀλλὰ κακὰ φρονέουσι διαμπερὲς ἀλλήλοισιν,{l]
[l [n}22.265{]}ὣς οὐκ ἔστʼ ἐμὲ καὶ σὲ φιλήμεναι, οὐδέ τι νῶϊν{l]
[l [n}22.266{]}ὅρκια ἔσσονται, πρίν γʼ ἢ ἕτερόν γε πεσόντα{l]
[l [n}22.267{]}αἵματος ἆσαι Ἄρηα ταλαύρινον πολεμιστήν.{l]
[l [n}22.268{]}παντοίης ἀρετῆς μιμνήσκεο· νῦν σε μάλα χρὴ{l]
[l [n}22.269{]}αἰχμητήν τʼ ἔμεναι καὶ θαρσαλέον πολεμιστήν.{l]
[l [n}22.270{]}οὔ τοι ἔτʼ ἔσθʼ ὑπάλυξις, ἄφαρ δέ σε Παλλὰς Ἀθήνη{l]
[l [n}22.271{]}ἔγχει ἐμῷ δαμάᾳ· νῦν δʼ ἀθρόα πάντʼ ἀποτίσεις{l]
[l [n}22.272{]}κήδεʼ ἐμῶν ἑτάρων οὓς ἔκτανες ἔγχεϊ θύων.{l]{q]{para]
[para}[l [n}22.273{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος·{l]
[l [n}22.274{]}καὶ τὸ μὲν ἄντα ἰδὼν ἠλεύατο φαίδιμος Ἕκτωρ·{l]
[l [n}22.275{]}ἕζετο γὰρ προϊδών, τὸ δʼ ὑπέρπτατο χάλκεον ἔγχος,{l]
[l [n}22.276{]}ἐν γαίῃ δʼ ἐπάγη· ἀνὰ δʼ ἥρπασε Παλλὰς Ἀθήνη,{l]
[l [n}22.277{]}ἂψ δʼ Ἀχιλῆϊ δίδου, λάθε δʼ Ἕκτορα ποιμένα λαῶν.{l]
[l [n}22.278{]}Ἕκτωρ δὲ προσέειπεν ἀμύμονα Πηλεΐωνα·{l]
[q}[l [n}22.279{]}ἤμβροτες, οὐδʼ ἄρα πώ τι θεοῖς ἐπιείκελʼ Ἀχιλλεῦ{l]
[l [n}22.280{]}ἐκ Διὸς ἠείδης τὸν ἐμὸν μόρον, ἦ τοι ἔφης γε·{l]
[l [n}22.281{]}ἀλλά τις ἀρτιεπὴς καὶ ἐπίκλοπος ἔπλεο μύθων,{l]
[l [n}22.282{]}ὄφρά σʼ ὑποδείσας μένεος ἀλκῆς τε λάθωμαι.{l]
[l [n}22.283{]}οὐ μέν μοι φεύγοντι μεταφρένῳ ἐν δόρυ πήξεις,{l]
[l [n}22.284{]}ἀλλʼ ἰθὺς μεμαῶτι διὰ στήθεσφιν ἔλασσον{l]
[l [n}22.285{]}εἴ τοι ἔδωκε θεός· νῦν αὖτʼ ἐμὸν ἔγχος ἄλευαι{l]
[l [n}22.286{]}χάλκεον· ὡς δή μιν σῷ ἐν χροῒ πᾶν κομίσαιο.{l]
[l [n}22.287{]}καί κεν ἐλαφρότερος πόλεμος Τρώεσσι γένοιτο{l]
[l [n}22.288{]}σεῖο καταφθιμένοιο· σὺ γάρ σφισι πῆμα μέγιστον.{l]{q]{para]
[para}[l [n}22.289{]}ἦ ῥα, καὶ ἀμπεπαλὼν προΐει δολιχόσκιον ἔγχος,{l]
[l [n}22.290{]}καὶ βάλε Πηλεΐδαο μέσον σάκος οὐδʼ ἀφάμαρτε·{l]
[l [n}22.291{]}τῆλε δʼ ἀπεπλάγχθη σάκεος δόρυ· χώσατο δʼ Ἕκτωρ{l]
[l [n}22.292{]}ὅττί ῥά οἱ βέλος ὠκὺ ἐτώσιον ἔκφυγε χειρός,{l]
[l [n}22.293{]}στῆ δὲ κατηφήσας, οὐδʼ ἄλλʼ ἔχε μείλινον ἔγχος.{l]
[l [n}22.294{]}Δηΐφοβον δʼ ἐκάλει λευκάσπιδα μακρὸν ἀΰσας·{l]
[l [n}22.295{]}ᾔτεέ μιν δόρυ μακρόν· ὃ δʼ οὔ τί οἱ ἐγγύθεν ἦεν.{l]
[l [n}22.296{]}Ἕκτωρ δʼ ἔγνω ᾗσιν ἐνὶ φρεσὶ φώνησέν τε·{l]
[q}[l [n}22.297{]}ὢ πόποι ἦ μάλα δή με θεοὶ θάνατόνδε κάλεσσαν·{l]
[l [n}22.298{]}Δηΐφοβον γὰρ ἔγωγʼ ἐφάμην ἥρωα παρεῖναι·{l]
[l [n}22.299{]}ἀλλʼ ὃ μὲν ἐν τείχει, ἐμὲ δʼ ἐξαπάτησεν Ἀθήνη.{l]
[l [n}22.300{]}νῦν δὲ δὴ ἐγγύθι μοι θάνατος κακός, οὐδʼ ἔτʼ ἄνευθεν,{l]
[l [n}22.301{]}οὐδʼ ἀλέη· ἦ γάρ ῥα πάλαι τό γε φίλτερον ἦεν{l]
[l [n}22.302{]}Ζηνί τε καὶ Διὸς υἷι ἑκηβόλῳ, οἵ με πάρος γε{l]
[l [n}22.303{]}πρόφρονες εἰρύατο· νῦν αὖτέ με μοῖρα κιχάνει.{l]
[l [n}22.304{]}μὴ μὰν ἀσπουδί γε καὶ ἀκλειῶς ἀπολοίμην,{l]
[l [n}22.305{]}ἀλλὰ μέγα ῥέξας τι καὶ ἐσσομένοισι πυθέσθαι.{l]{q]{para]
[para}[l [n}22.306{]}ὣς ἄρα φωνήσας εἰρύσσατο φάσγανον ὀξύ,{l]
[l [n}22.307{]}τό οἱ ὑπὸ λαπάρην τέτατο μέγα τε στιβαρόν τε,{l]
[l [n}22.308{]}οἴμησεν δὲ ἀλεὶς ὥς τʼ αἰετὸς ὑψιπετήεις,{l]
[l [n}22.309{]}ὅς τʼ εἶσιν πεδίον δὲ διὰ νεφέων ἐρεβεννῶν{l]
[l [n}22.310{]}ἁρπάξων ἢ ἄρνʼ ἀμαλὴν ἤ πτῶκα λαγωόν·{l]
[l [n}22.311{]}ὣς Ἕκτωρ οἴμησε τινάσσων φάσγανον ὀξύ.{l]
[l [n}22.312{]}ὁρμήθη δʼ Ἀχιλεύς, μένεος δʼ ἐμπλήσατο θυμὸν{l]
[l [n}22.313{]}ἀγρίου, πρόσθεν δὲ σάκος στέρνοιο κάλυψε{l]
[l [n}22.314{]}καλὸν δαιδάλεον, κόρυθι δʼ ἐπένευε φαεινῇ{l]
[l [n}22.315{]}τετραφάλῳ· καλαὶ δὲ περισσείοντο ἔθειραι{l]
[l [n}22.316{]}χρύσεαι, ἃς Ἥφαιστος ἵει λόφον ἀμφὶ θαμειάς.{l]
[l [n}22.317{]}οἷος δʼ ἀστὴρ εἶσι μετʼ ἀστράσι νυκτὸς ἀμολγῷ{l]
[l [n}22.318{]}ἕσπερος, ὃς κάλλιστος ἐν οὐρανῷ ἵσταται ἀστήρ,{l]
[l [n}22.319{]}ὣς αἰχμῆς ἀπέλαμπʼ εὐήκεος, ἣν ἄρʼ Ἀχιλλεὺς{l]
[l [n}22.320{]}πάλλεν δεξιτερῇ φρονέων κακὸν Ἕκτορι δίῳ,{l]
[l [n}22.321{]}εἰσορόων χρόα καλόν, ὅπῃ εἴξειε μάλιστα.{l]
[l [n}22.322{]}τοῦ δὲ καὶ ἄλλο τόσον μὲν ἔχε χρόα χάλκεα τεύχεα,{l]
[l [n}22.323{]}καλά, τὰ Πατρόκλοιο βίην ἐνάριξε κατακτάς·{l]
[l [n}22.324{]}φαίνετο δʼ ᾗ κληῗδες ἀπʼ ὤμων αὐχένʼ ἔχουσι,{l]
[l [n}22.325{]}λαυκανίην, ἵνα τε ψυχῆς ὤκιστος ὄλεθρος·{l]
[l [n}22.326{]}τῇ ῥʼ ἐπὶ οἷ μεμαῶτʼ ἔλασʼ ἔγχεϊ δῖος Ἀχιλλεύς,{l]
[l [n}22.327{]}ἀντικρὺ δʼ ἁπαλοῖο διʼ αὐχένος ἤλυθʼ ἀκωκή·{l]
[l [n}22.328{]}οὐδʼ ἄρʼ ἀπʼ ἀσφάραγον μελίη τάμε χαλκοβάρεια,{l]
[l [n}22.329{]}ὄφρά τί μιν προτιείποι ἀμειβόμενος ἐπέεσσιν.{l]
[l [n}22.330{]}ἤριπε δʼ ἐν κονίῃς· ὃ δʼ ἐπεύξατο δῖος Ἀχιλλεύς·{l]
[q}[l [n}22.331{]}Ἕκτορ ἀτάρ που ἔφης Πατροκλῆʼ ἐξεναρίζων{l]
[l [n}22.332{]}σῶς ἔσσεσθʼ, ἐμὲ δʼ οὐδὲν ὀπίζεο νόσφιν ἐόντα,{l]
[l [n}22.333{]}νήπιε· τοῖο δʼ ἄνευθεν ἀοσσητὴρ μέγʼ ἀμείνων{l]
[l [n}22.334{]}νηυσὶν ἔπι γλαφυρῇσιν ἐγὼ μετόπισθε λελείμμην,{l]
[l [n}22.335{]}ὅς τοι γούνατʼ ἔλυσα· σὲ μὲν κύνες ἠδʼ οἰωνοὶ{l]
[l [n}22.336{]}ἑλκήσουσʼ ἀϊκῶς, τὸν δὲ κτεριοῦσιν Ἀχαιοί.{l]{q]{para]
[para}[l [n}22.337{]}τὸν δʼ ὀλιγοδρανέων προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}22.338{]}λίσσομʼ ὑπὲρ ψυχῆς καὶ γούνων σῶν τε τοκήων,{l]
[l [n}22.339{]}μή με ἔα παρὰ νηυσὶ κύνας καταδάψαι Ἀχαιῶν,{l]
[l [n}22.340{]}ἀλλὰ σὺ μὲν χαλκόν τε ἅλις χρυσόν τε δέδεξο,{l]
[l [n}22.341{]}δῶρα τά τοι δώσουσι πατὴρ καὶ πότνια μήτηρ,{l]
[l [n}22.342{]}σῶμα δὲ οἴκαδʼ ἐμὸν δόμεναι πάλιν, ὄφρα πυρός με{l]
[l [n}22.343{]}Τρῶες καὶ Τρώων ἄλοχοι λελάχωσι θανόντα.{l]{q]{para]
[para}[l [n}22.344{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πόδας ὠκὺς Ἀχιλλεὺς·{l]
[q}[l [n}22.345{]}μή με κύον γούνων γουνάζεο μὴ δὲ τοκήων·{l]
[l [n}22.346{]}αἲ γάρ πως αὐτόν με μένος καὶ θυμὸς ἀνήη{l]
[l [n}22.347{]}ὤμʼ ἀποταμνόμενον κρέα ἔδμεναι, οἷα ἔοργας,{l]
[l [n}22.348{]}ὡς οὐκ ἔσθʼ ὃς σῆς γε κύνας κεφαλῆς ἀπαλάλκοι,{l]
[l [n}22.349{]}οὐδʼ εἴ κεν δεκάκις τε καὶ εἰκοσινήριτʼ ἄποινα{l]
[l [n}22.350{]}στήσωσʼ ἐνθάδʼ ἄγοντες, ὑπόσχωνται δὲ καὶ ἄλλα,{l]
[l [n}22.351{]}οὐδʼ εἴ κέν σʼ αὐτὸν χρυσῷ ἐρύσασθαι ἀνώγοι{l]
[l [n}22.352{]}Δαρδανίδης Πρίαμος· οὐδʼ ὧς σέ γε πότνια μήτηρ{l]
[l [n}22.353{]}ἐνθεμένη λεχέεσσι γοήσεται ὃν τέκεν αὐτή,{l]
[l [n}22.354{]}ἀλλὰ κύνες τε καὶ οἰωνοὶ κατὰ πάντα δάσονται.{l]{q]{para]
[para}[l [n}22.355{]}τὸν δὲ καταθνῄσκων προσέφη κορυθαίολος Ἕκτωρ·{l]
[q}[l [n}22.356{]}ἦ σʼ εὖ γιγνώσκων προτιόσσομαι, οὐδʼ ἄρʼ ἔμελλον{l]
[l [n}22.357{]}πείσειν· ἦ γὰρ σοί γε σιδήρεος ἐν φρεσὶ θυμός.{l]
[l [n}22.358{]}φράζεο νῦν, μή τοί τι θεῶν μήνιμα γένωμαι{l]
[l [n}22.359{]}ἤματι τῷ ὅτε κέν σε Πάρις καὶ Φοῖβος Ἀπόλλων{l]
[l [n}22.360{]}ἐσθλὸν ἐόντʼ ὀλέσωσιν ἐνὶ Σκαιῇσι πύλῃσιν.{l]{q]{para]
[para}[l [n}22.361{]}ὣς ἄρα μιν εἰπόντα τέλος θανάτοιο κάλυψε,{l]
[l [n}22.362{]}ψυχὴ δʼ ἐκ ῥεθέων πταμένη Ἄϊδος δὲ βεβήκει{l]
[l [n}22.363{]}ὃν πότμον γοόωσα λιποῦσʼ ἀνδροτῆτα καὶ ἥβην.{l]
[l [n}22.364{]}τὸν καὶ τεθνηῶτα προσηύδα δῖος Ἀχιλλεύς·{l]
[q}[l [n}22.365{]}τέθναθι· κῆρα δʼ ἐγὼ τότε δέξομαι ὁππότε κεν δὴ{l]
[l [n}22.366{]}Ζεὺς ἐθέλῃ τελέσαι ἠδʼ ἀθάνατοι θεοὶ ἄλλοι.{l]{q]{para]
[para}[l [n}22.367{]}ἦ ῥα, καὶ ἐκ νεκροῖο ἐρύσσατο χάλκεον ἔγχος,{l]
[l [n}22.368{]}καὶ τό γʼ ἄνευθεν ἔθηχʼ, ὃ δʼ ἀπʼ ὤμων τεύχεʼ ἐσύλα{l]
[l [n}22.369{]}αἱματόεντʼ· ἄλλοι δὲ περίδραμον υἷες Ἀχαιῶν,{l]
[l [n}22.370{]}οἳ καὶ θηήσαντο φυὴν καὶ εἶδος ἀγητὸν{l]
[l [n}22.371{]}Ἕκτορος· οὐδʼ ἄρα οἵ τις ἀνουτητί γε παρέστη.{l]
[l [n}22.372{]}ὧδε δέ τις εἴπεσκεν ἰδὼν ἐς πλησίον ἄλλον·{l]
[q}[l [n}22.373{]}ὢ πόποι, ἦ μάλα δὴ μαλακώτερος ἀμφαφάασθαι{l]
[l [n}22.374{]}Ἕκτωρ ἢ ὅτε νῆας ἐνέπρησεν πυρὶ κηλέῳ.{l]{q]{para]
[para}[l [n}22.375{]}ὣς ἄρα τις εἴπεσκε καὶ οὐτήσασκε παραστάς.{l]
[l [n}22.376{]}τὸν δʼ ἐπεὶ ἐξενάριξε ποδάρκης δῖος Ἀχιλλεύς,{l]
[l [n}22.377{]}στὰς ἐν Ἀχαιοῖσιν ἔπεα πτερόεντʼ ἀγόρευεν·{l]
[q}[l [n}22.378{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}22.379{]}ἐπεὶ δὴ τόνδʼ ἄνδρα θεοὶ δαμάσασθαι ἔδωκαν,{l]
[l [n}22.380{]}ὃς κακὰ πόλλʼ ἔρρεξεν ὅσʼ οὐ σύμπαντες οἱ ἄλλοι,{l]
[l [n}22.381{]}εἰ δʼ ἄγετʼ ἀμφὶ πόλιν σὺν τεύχεσι πειρηθῶμεν,{l]
[l [n}22.382{]}ὄφρά κʼ ἔτι γνῶμεν Τρώων νόον ὅν τινʼ ἔχουσιν,{l]
[l [n}22.383{]}ἢ καταλείψουσιν πόλιν ἄκρην τοῦδε πεσόντος,{l]
[l [n}22.384{]}ἦε μένειν μεμάασι καὶ Ἕκτορος οὐκέτʼ ἐόντος.{l]
[l [n}22.385{]}ἀλλὰ τί ἤ μοι ταῦτα φίλος διελέξατο θυμός;{l]
[l [n}22.386{]}κεῖται πὰρ νήεσσι νέκυς ἄκλαυτος ἄθαπτος{l]
[l [n}22.387{]}Πάτροκλος· τοῦ δʼ οὐκ ἐπιλήσομαι, ὄφρʼ ἂν ἔγωγε{l]
[l [n}22.388{]}ζωοῖσιν μετέω καί μοι φίλα γούνατʼ ὀρώρῃ·{l]
[l [n}22.389{]}εἰ δὲ θανόντων περ καταλήθοντʼ εἰν Ἀΐδαο{l]
[l [n}22.390{]}αὐτὰρ ἐγὼ καὶ κεῖθι φίλου μεμνήσομʼ ἑταίρου.{l]
[l [n}22.391{]}νῦν δʼ ἄγʼ ἀείδοντες παιήονα κοῦροι Ἀχαιῶν{l]
[l [n}22.392{]}νηυσὶν ἔπι γλαφυρῇσι νεώμεθα, τόνδε δʼ ἄγωμεν.{l]
[l [n}22.393{]}ἠράμεθα μέγα κῦδος· ἐπέφνομεν Ἕκτορα δῖον,{l]
[l [n}22.394{]}ᾧ Τρῶες κατὰ ἄστυ θεῷ ὣς εὐχετόωντο.{l]{q]{para]
[para}[l [n}22.395{]}ἦ ῥα, καὶ Ἕκτορα δῖον ἀεικέα μήδετο ἔργα.{l]
[l [n}22.396{]}ἀμφοτέρων μετόπισθε ποδῶν τέτρηνε τένοντε{l]
[l [n}22.397{]}ἐς σφυρὸν ἐκ πτέρνης, βοέους δʼ ἐξῆπτεν ἱμάντας,{l]
[l [n}22.398{]}ἐκ δίφροιο δʼ ἔδησε, κάρη δʼ ἕλκεσθαι ἔασεν·{l]
[l [n}22.399{]}ἐς δίφρον δʼ ἀναβὰς ἀνά τε κλυτὰ τεύχεʼ ἀείρας{l]
[l [n}22.400{]}μάστιξέν ῥʼ ἐλάαν, τὼ δʼ οὐκ ἀέκοντε πετέσθην.{l]
[l [n}22.401{]}τοῦ δʼ ἦν ἑλκομένοιο κονίσαλος, ἀμφὶ δὲ χαῖται{l]
[l [n}22.402{]}κυάνεαι πίτναντο, κάρη δʼ ἅπαν ἐν κονίῃσι{l]
[l [n}22.403{]}κεῖτο πάρος χαρίεν· τότε δὲ Ζεὺς δυσμενέεσσι{l]
[l [n}22.404{]}δῶκεν ἀεικίσσασθαι ἑῇ ἐν πατρίδι γαίῃ.{l]{para]
[para}[l [n}22.405{]}ὣς τοῦ μὲν κεκόνιτο κάρη ἅπαν· ἣ δέ νυ μήτηρ{l]
[l [n}22.406{]}τίλλε κόμην, ἀπὸ δὲ λιπαρὴν ἔρριψε καλύπτρην{l]
[l [n}22.407{]}τηλόσε, κώκυσεν δὲ μάλα μέγα παῖδʼ ἐσιδοῦσα·{l]
[l [n}22.408{]}ᾤμωξεν δʼ ἐλεεινὰ πατὴρ φίλος, ἀμφὶ δὲ λαοὶ{l]
[l [n}22.409{]}κωκυτῷ τʼ εἴχοντο καὶ οἰμωγῇ κατὰ ἄστυ.{l]
[l [n}22.410{]}τῷ δὲ μάλιστʼ ἄρʼ ἔην ἐναλίγκιον ὡς εἰ ἅπασα{l]
[l [n}22.411{]}Ἴλιος ὀφρυόεσσα πυρὶ σμύχοιτο κατʼ ἄκρης.{l]
[l [n}22.412{]}λαοὶ μέν ῥα γέροντα μόγις ἔχον ἀσχαλόωντα{l]
[l [n}22.413{]}ἐξελθεῖν μεμαῶτα πυλάων Δαρδανιάων.{l]
[l [n}22.414{]}πάντας δʼ ἐλλιτάνευε κυλινδόμενος κατὰ κόπρον,{l]
[l [n}22.415{]}ἐξονομακλήδην ὀνομάζων ἄνδρα ἕκαστον·{l]
[q}[l [n}22.416{]}σχέσθε φίλοι, καί μʼ οἶον ἐάσατε κηδόμενοί περ{l]
[l [n}22.417{]}ἐξελθόντα πόληος ἱκέσθʼ ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}22.418{]}λίσσωμʼ ἀνέρα τοῦτον ἀτάσθαλον ὀβριμοεργόν,{l]
[l [n}22.419{]}ἤν πως ἡλικίην αἰδέσσεται ἠδʼ ἐλεήσῃ{l]
[l [n}22.420{]}γῆρας· καὶ δέ νυ τῷ γε πατὴρ τοιόσδε τέτυκται{l]
[l [n}22.421{]}Πηλεύς, ὅς μιν ἔτικτε καὶ ἔτρεφε πῆμα γενέσθαι{l]
[l [n}22.422{]}Τρωσί· μάλιστα δʼ ἐμοὶ περὶ πάντων ἄλγεʼ ἔθηκε.{l]
[l [n}22.423{]}τόσσους γάρ μοι παῖδας ἀπέκτανε τηλεθάοντας·{l]
[l [n}22.424{]}τῶν πάντων οὐ τόσσον ὀδύρομαι ἀχνύμενός περ{l]
[l [n}22.425{]}ὡς ἑνός, οὗ μʼ ἄχος ὀξὺ κατοίσεται Ἄϊδος εἴσω,{l]
[l [n}22.426{]}Ἕκτορος· ὡς ὄφελεν θανέειν ἐν χερσὶν ἐμῇσι·{l]
[l [n}22.427{]}τώ κε κορεσσάμεθα κλαίοντέ τε μυρομένω τε{l]
[l [n}22.428{]}μήτηρ θʼ, ἥ μιν ἔτικτε δυσάμμορος, ἠδʼ ἐγὼ αὐτός.{l]{q]{para]
[para}[l [n}22.429{]}ὣς ἔφατο κλαίων, ἐπὶ δὲ στενάχοντο πολῖται·{l]
[l [n}22.430{]}Τρῳῇσιν δʼ Ἑκάβη ἁδινοῦ ἐξῆρχε γόοιο·{l]
[q}[l [n}22.431{]}τέκνον ἐγὼ δειλή· τί νυ βείομαι αἰνὰ παθοῦσα{l]
[l [n}22.432{]}σεῦ ἀποτεθνηῶτος; ὅ μοι νύκτάς τε καὶ ἦμαρ{l]
[l [n}22.433{]}εὐχωλὴ κατὰ ἄστυ πελέσκεο, πᾶσί τʼ ὄνειαρ{l]
[l [n}22.434{]}Τρωσί τε καὶ Τρῳῇσι κατὰ πτόλιν, οἵ σε θεὸν ὣς{l]
[l [n}22.435{]}δειδέχατʼ· ἦ γὰρ καί σφι μάλα μέγα κῦδος ἔησθα{l]
[l [n}22.436{]}ζωὸς ἐών· νῦν αὖ θάνατος καὶ μοῖρα κιχάνει.{l]{q]{para]
[para}[l [n}22.437{]}ὣς ἔφατο κλαίουσʼ, ἄλοχος δʼ οὔ πώ τι πέπυστο{l]
[l [n}22.438{]}Ἕκτορος· οὐ γάρ οἵ τις ἐτήτυμος ἄγγελος ἐλθὼν{l]
[l [n}22.439{]}ἤγγειλʼ ὅττί ῥά οἱ πόσις ἔκτοθι μίμνε πυλάων,{l]
[l [n}22.440{]}ἀλλʼ ἥ γʼ ἱστὸν ὕφαινε μυχῷ δόμου ὑψηλοῖο{l]
[l [n}22.441{]}δίπλακα πορφυρέην, ἐν δὲ θρόνα ποικίλʼ ἔπασσε.{l]
[l [n}22.442{]}κέκλετο δʼ ἀμφιπόλοισιν ἐϋπλοκάμοις κατὰ δῶμα{l]
[l [n}22.443{]}ἀμφὶ πυρὶ στῆσαι τρίποδα μέγαν, ὄφρα πέλοιτο{l]
[l [n}22.444{]}Ἕκτορι θερμὰ λοετρὰ μάχης ἐκ νοστήσαντι{l]
[l [n}22.445{]}νηπίη, οὐδʼ ἐνόησεν ὅ μιν μάλα τῆλε λοετρῶν{l]
[l [n}22.446{]}χερσὶν Ἀχιλλῆος δάμασε γλαυκῶπις Ἀθήνη.{l]
[l [n}22.447{]}κωκυτοῦ δʼ ἤκουσε καὶ οἰμωγῆς ἀπὸ πύργου·{l]
[l [n}22.448{]}τῆς δʼ ἐλελίχθη γυῖα, χαμαὶ δέ οἱ ἔκπεσε κερκίς·{l]
[l [n}22.449{]}ἣ δʼ αὖτις δμῳῇσιν ἐϋπλοκάμοισι μετηύδα·{l]
[q}[l [n}22.450{]}δεῦτε δύω μοι ἕπεσθον, ἴδωμʼ ὅτινʼ ἔργα τέτυκται.{l]
[l [n}22.451{]}αἰδοίης ἑκυρῆς ὀπὸς ἔκλυον, ἐν δʼ ἐμοὶ αὐτῇ{l]
[l [n}22.452{]}στήθεσι πάλλεται ἦτορ ἀνὰ στόμα, νέρθε δὲ γοῦνα{l]
[l [n}22.453{]}πήγνυται· ἐγγὺς δή τι κακὸν Πριάμοιο τέκεσσιν.{l]
[l [n}22.454{]}αἲ γὰρ ἀπʼ οὔατος εἴη ἐμεῦ ἔπος· ἀλλὰ μάλʼ αἰνῶς{l]
[l [n}22.455{]}δείδω μὴ δή μοι θρασὺν Ἕκτορα δῖος Ἀχιλλεὺς{l]
[l [n}22.456{]}μοῦνον ἀποτμήξας πόλιος πεδίον δὲ δίηται,{l]
[l [n}22.457{]}καὶ δή μιν καταπαύσῃ ἀγηνορίης ἀλεγεινῆς{l]
[l [n}22.458{]}ἥ μιν ἔχεσκʼ, ἐπεὶ οὔ ποτʼ ἐνὶ πληθυῖ μένεν ἀνδρῶν,{l]
[l [n}22.459{]}ἀλλὰ πολὺ προθέεσκε, τὸ ὃν μένος οὐδενὶ εἴκων.{l]{q]{para]
[para}[l [n}22.460{]}ὣς φαμένη μεγάροιο διέσσυτο μαινάδι ἴση{l]
[l [n}22.461{]}παλλομένη κραδίην· ἅμα δʼ ἀμφίπολοι κίον αὐτῇ{l]
[l [n}22.462{]}αὐτὰρ ἐπεὶ πύργόν τε καὶ ἀνδρῶν ἷξεν ὅμιλον{l]
[l [n}22.463{]}ἔστη παπτήνασʼ ἐπὶ τείχεϊ, τὸν δὲ νόησεν{l]
[l [n}22.464{]}ἑλκόμενον πρόσθεν πόλιος· ταχέες δέ μιν ἵπποι{l]
[l [n}22.465{]}ἕλκον ἀκηδέστως κοίλας ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}22.466{]}τὴν δὲ κατʼ ὀφθαλμῶν ἐρεβεννὴ νὺξ ἐκάλυψεν,{l]
[l [n}22.467{]}ἤριπε δʼ ἐξοπίσω, ἀπὸ δὲ ψυχὴν ἐκάπυσσε.{l]
[l [n}22.468{]}τῆλε δʼ ἀπὸ κρατὸς βάλε δέσματα σιγαλόεντα,{l]
[l [n}22.469{]}ἄμπυκα κεκρύφαλόν τε ἰδὲ πλεκτὴν ἀναδέσμην{l]
[l [n}22.470{]}κρήδεμνόν θʼ, ὅ ῥά οἱ δῶκε χρυσῆ Ἀφροδίτη{l]
[l [n}22.471{]}ἤματι τῷ ὅτε μιν κορυθαίολος ἠγάγεθʼ Ἕκτωρ{l]
[l [n}22.472{]}ἐκ δόμου Ἠετίωνος, ἐπεὶ πόρε μυρία ἕδνα.{l]
[l [n}22.473{]}ἀμφὶ δέ μιν γαλόῳ τε καὶ εἰνατέρες ἅλις ἔσταν,{l]
[l [n}22.474{]}αἵ ἑ μετὰ σφίσιν εἶχον ἀτυζομένην ἀπολέσθαι.{l]
[l [n}22.475{]}ἣ δʼ ἐπεὶ οὖν ἔμπνυτο καὶ ἐς φρένα θυμὸς ἀγέρθη{l]
[l [n}22.476{]}ἀμβλήδην γοόωσα μετὰ Τρῳῇσιν ἔειπεν·{l]
[q}[l [n}22.477{]}Ἕκτορ ἐγὼ δύστηνος· ἰῇ ἄρα γεινόμεθʼ αἴσῃ{l]
[l [n}22.478{]}ἀμφότεροι, σὺ μὲν ἐν Τροίῃ Πριάμου κατὰ δῶμα,{l]
[l [n}22.479{]}αὐτὰρ ἐγὼ Θήβῃσιν ὑπὸ Πλάκῳ ὑληέσσῃ{l]
[l [n}22.480{]}ἐν δόμῳ Ἠετίωνος, ὅ μʼ ἔτρεφε τυτθὸν ἐοῦσαν{l]
[l [n}22.481{]}δύσμορος αἰνόμορον· ὡς μὴ ὤφελλε τεκέσθαι.{l]
[l [n}22.482{]}νῦν δὲ σὺ μὲν Ἀΐδαο δόμους ὑπὸ κεύθεσι γαίης{l]
[l [n}22.483{]}ἔρχεαι, αὐτὰρ ἐμὲ στυγερῷ ἐνὶ πένθεϊ λείπεις{l]
[l [n}22.484{]}χήρην ἐν μεγάροισι· πάϊς δʼ ἔτι νήπιος αὔτως,{l]
[l [n}22.485{]}ὃν τέκομεν σύ τʼ ἐγώ τε δυσάμμοροι· οὔτε σὺ τούτῳ{l]
[l [n}22.486{]}ἔσσεαι Ἕκτορ ὄνειαρ ἐπεὶ θάνες, οὔτε σοὶ οὗτος.{l]
[l [n}22.487{]}ἤν περ γὰρ πόλεμόν γε φύγῃ πολύδακρυν Ἀχαιῶν,{l]
[l [n}22.488{]}αἰεί τοι τούτῳ γε πόνος καὶ κήδεʼ ὀπίσσω{l]
[l [n}22.489{]}ἔσσοντʼ· ἄλλοι γάρ οἱ ἀπουρίσσουσιν ἀρούρας.{l]
[l [n}22.490{]}ἦμαρ δʼ ὀρφανικὸν παναφήλικα παῖδα τίθησι·{l]
[l [n}22.491{]}πάντα δʼ ὑπεμνήμυκε, δεδάκρυνται δὲ παρειαί,{l]
[l [n}22.492{]}δευόμενος δέ τʼ ἄνεισι πάϊς ἐς πατρὸς ἑταίρους,{l]
[l [n}22.493{]}ἄλλον μὲν χλαίνης ἐρύων, ἄλλον δὲ χιτῶνος·{l]
[l [n}22.494{]}τῶν δʼ ἐλεησάντων κοτύλην τις τυτθὸν ἐπέσχε·{l]
[l [n}22.495{]}χείλεα μέν τʼ ἐδίηνʼ, ὑπερῴην δʼ οὐκ ἐδίηνε.{l]
[l [n}22.496{]}τὸν δὲ καὶ ἀμφιθαλὴς ἐκ δαιτύος ἐστυφέλιξε{l]
[l [n}22.497{]}χερσὶν πεπλήγων καὶ ὀνειδείοισιν ἐνίσσων·{l]
[q}[l [n}22.498{]}ἔρρʼ οὕτως· οὐ σός γε πατὴρ μεταδαίνυται ἡμῖν.{l]{q][l [n}22.499{]}δακρυόεις δέ τʼ ἄνεισι πάϊς ἐς μητέρα χήρην{l]
[l [n}22.500{]}Ἀστυάναξ, ὃς πρὶν μὲν ἑοῦ ἐπὶ γούνασι πατρὸς{l]
[l [n}22.501{]}μυελὸν οἶον ἔδεσκε καὶ οἰῶν πίονα δημόν·{l]
[l [n}22.502{]}αὐτὰρ ὅθʼ ὕπνος ἕλοι, παύσαιτό τε νηπιαχεύων,{l]
[l [n}22.503{]}εὕδεσκʼ ἐν λέκτροισιν ἐν ἀγκαλίδεσσι τιθήνης{l]
[l [n}22.504{]}εὐνῇ ἔνι μαλακῇ θαλέων ἐμπλησάμενος κῆρ·{l]
[l [n}22.505{]}νῦν δʼ ἂν πολλὰ πάθῃσι φίλου ἀπὸ πατρὸς ἁμαρτὼν{l]
[l [n}22.506{]}Ἀστυάναξ, ὃν Τρῶες ἐπίκλησιν καλέουσιν·{l]
[l [n}22.507{]}οἶος γάρ σφιν ἔρυσο πύλας καὶ τείχεα μακρά.{l]
[l [n}22.508{]}νῦν δὲ σὲ μὲν παρὰ νηυσὶ κορωνίσι νόσφι τοκήων{l]
[l [n}22.509{]}αἰόλαι εὐλαὶ ἔδονται, ἐπεί κε κύνες κορέσωνται{l]
[l [n}22.510{]}γυμνόν· ἀτάρ τοι εἵματʼ ἐνὶ μεγάροισι κέονται{l]
[l [n}22.511{]}λεπτά τε καὶ χαρίεντα τετυγμένα χερσὶ γυναικῶν.{l]
[l [n}22.512{]}ἀλλʼ ἤτοι τάδε πάντα καταφλέξω πυρὶ κηλέῳ{l]
[l [n}22.513{]}οὐδὲν σοί γʼ ὄφελος, ἐπεὶ οὐκ ἐγκείσεαι αὐτοῖς,{l]
[l [n}22.514{]}ἀλλὰ πρὸς Τρώων καὶ Τρωϊάδων κλέος εἶναι.{l]{q]{para]
[para}[l [n}22.515{]}ὣς ἔφατο κλαίουσʼ, ἐπὶ δὲ στενάχοντο γυναῖκες.{l]{para]
{book]
[book [n}23{]}[l [n}23.1{]}ὣς οἳ μὲν στενάχοντο κατὰ πτόλιν· αὐτὰρ Ἀχαιοὶ{l]
[l [n}23.2{]}ἐπεὶ δὴ νῆάς τε καὶ Ἑλλήσποντον ἵκοντο,{l]
[l [n}23.3{]}οἳ μὲν ἄρʼ ἐσκίδναντο ἑὴν ἐπὶ νῆα ἕκαστος,{l]
[l [n}23.4{]}Μυρμιδόνας δʼ οὐκ εἴα ἀποσκίδνασθαι Ἀχιλλεύς,{l]
[l [n}23.5{]}ἀλλʼ ὅ γε οἷς ἑτάροισι φιλοπτολέμοισι μετηύδα·{l]
[q}[l [n}23.6{]}Μυρμιδόνες ταχύπωλοι ἐμοὶ ἐρίηρες ἑταῖροι{l]
[l [n}23.7{]}μὴ δή πω ὑπʼ ὄχεσφι λυώμεθα μώνυχας ἵππους,{l]
[l [n}23.8{]}ἀλλʼ αὐτοῖς ἵπποισι καὶ ἅρμασιν ἆσσον ἰόντες{l]
[l [n}23.9{]}Πάτροκλον κλαίωμεν· ὃ γὰρ γέρας ἐστὶ θανόντων.{l]
[l [n}23.10{]}αὐτὰρ ἐπεί κʼ ὀλοοῖο τεταρπώμεσθα γόοιο,{l]
[l [n}23.11{]}ἵππους λυσάμενοι δορπήσομεν ἐνθάδε πάντες.{l]{q]
[para}[l [n}23.12{]}ὣς ἔφαθʼ, οἳ δʼ ᾤμωξαν ἀολλέες, ἦρχε δʼ Ἀχιλλεύς.{l]
[l [n}23.13{]}οἳ δὲ τρὶς περὶ νεκρὸν ἐΰτριχας ἤλασαν ἵππους{l]
[l [n}23.14{]}μυρόμενοι· μετὰ δέ σφι Θέτις γόου ἵμερον ὦρσε.{l]
[l [n}23.15{]}δεύοντο ψάμαθοι, δεύοντο δὲ τεύχεα φωτῶν{l]
[l [n}23.16{]}δάκρυσι· τοῖον γὰρ πόθεον μήστωρα φόβοιο.{l]
[l [n}23.17{]}τοῖσι δὲ Πηλεΐδης ἁδινοῦ ἐξῆρχε γόοιο{l]
[l [n}23.18{]}χεῖρας ἐπʼ ἀνδροφόνους θέμενος στήθεσσιν ἑταίρου·{l]
[q}[l [n}23.19{]}χαῖρέ μοι ὦ Πάτροκλε καὶ εἰν Ἀΐδαο δόμοισι·{l]
[l [n}23.20{]}πάντα γὰρ ἤδη τοι τελέω τὰ πάροιθεν ὑπέστην{l]
[l [n}23.21{]}Ἕκτορα δεῦρʼ ἐρύσας δώσειν κυσὶν ὠμὰ δάσασθαι,{l]
[l [n}23.22{]}δώδεκα δὲ προπάροιθε πυρῆς ἀποδειροτομήσειν{l]
[l [n}23.23{]}Τρώων ἀγλαὰ τέκνα σέθεν κταμένοιο χολωθείς.{l]{q]{para]
[para}[l [n}23.24{]}ἦ ῥα καὶ Ἕκτορα δῖον ἀεικέα μήδετο ἔργα{l]
[l [n}23.25{]}πρηνέα πὰρ λεχέεσσι Μενοιτιάδαο τανύσσας{l]
[l [n}23.26{]}ἐν κονίῃς· οἳ δʼ ἔντεʼ ἀφωπλίζοντο ἕκαστος{l]
[l [n}23.27{]}χάλκεα μαρμαίροντα, λύον δʼ ὑψηχέας ἵππους,{l]
[l [n}23.28{]}κὰδ δʼ ἷζον παρὰ νηῒ ποδώκεος Αἰακίδαο{l]
[l [n}23.29{]}μυρίοι· αὐτὰρ ὃ τοῖσι τάφον μενοεικέα δαίνυ.{l]
[l [n}23.30{]}πολλοὶ μὲν βόες ἀργοὶ ὀρέχθεον ἀμφὶ σιδήρῳ{l]
[l [n}23.31{]}σφαζόμενοι, πολλοὶ δʼ ὄϊες καὶ μηκάδες αἶγες·{l]
[l [n}23.32{]}πολλοὶ δʼ ἀργιόδοντες ὕες θαλέθοντες ἀλοιφῇ{l]
[l [n}23.33{]}εὑόμενοι τανύοντο διὰ φλογὸς Ἡφαίστοιο·{l]
[l [n}23.34{]}πάντῃ δʼ ἀμφὶ νέκυν κοτυλήρυτον ἔρρεεν αἷμα.{l]{para]
[para}[l [n}23.35{]}αὐτὰρ τόν γε ἄνακτα ποδώκεα Πηλεΐωνα{l]
[l [n}23.36{]}εἰς Ἀγαμέμνονα δῖον ἄγον βασιλῆες Ἀχαιῶν{l]
[l [n}23.37{]}σπουδῇ παρπεπιθόντες ἑταίρου χωόμενον κῆρ.{l]
[l [n}23.38{]}οἳ δʼ ὅτε δὴ κλισίην Ἀγαμέμνονος ἷξον ἰόντες,{l]
[l [n}23.39{]}αὐτίκα κηρύκεσσι λιγυφθόγγοισι κέλευσαν{l]
[l [n}23.40{]}ἀμφὶ πυρὶ στῆσαι τρίποδα μέγαν, εἰ πεπίθοιεν{l]
[l [n}23.41{]}Πηλεΐδην λούσασθαι ἄπο βρότον αἱματόεντα.{l]
[l [n}23.42{]}αὐτὰρ ὅ γʼ ἠρνεῖτο στερεῶς, ἐπὶ δʼ ὅρκον ὄμοσσεν·{l]
[q}[l [n}23.43{]}οὐ μὰ Ζῆνʼ, ὅς τίς τε θεῶν ὕπατος καὶ ἄριστος,{l]
[l [n}23.44{]}οὐ θέμις ἐστὶ λοετρὰ καρήατος ἆσσον ἱκέσθαι{l]
[l [n}23.45{]}πρίν γʼ ἐνὶ Πάτροκλον θέμεναι πυρὶ σῆμά τε χεῦαι{l]
[l [n}23.46{]}κείρασθαί τε κόμην, ἐπεὶ οὔ μʼ ἔτι δεύτερον ὧδε{l]
[l [n}23.47{]}ἵξετʼ ἄχος κραδίην ὄφρα ζωοῖσι μετείω.{l]
[l [n}23.48{]}ἀλλʼ ἤτοι νῦν μὲν στυγερῇ πειθώμεθα δαιτί·{l]
[l [n}23.49{]}ἠῶθεν δʼ ὄτρυνον ἄναξ ἀνδρῶν Ἀγάμεμνον{l]
[l [n}23.50{]}ὕλην τʼ ἀξέμεναι παρά τε σχεῖν ὅσσʼ ἐπιεικὲς{l]
[l [n}23.51{]}νεκρὸν ἔχοντα νέεσθαι ὑπὸ ζόφον ἠερόεντα,{l]
[l [n}23.52{]}ὄφρʼ ἤτοι τοῦτον μὲν ἐπιφλέγῃ ἀκάματον πῦρ{l]
[l [n}23.53{]}θᾶσσον ἀπʼ ὀφθαλμῶν, λαοὶ δʼ ἐπὶ ἔργα τράπωνται.{l]{q]{para]
[para}[l [n}23.54{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο.{l]
[l [n}23.55{]}ἐσσυμένως δʼ ἄρα δόρπον ἐφοπλίσσαντες ἕκαστοι{l]
[l [n}23.56{]}δαίνυντʼ, οὐδέ τι θυμὸς ἐδεύετο δαιτὸς ἐΐσης.{l]
[l [n}23.57{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}23.58{]}οἳ μὲν κακκείοντες ἔβαν κλισίην δὲ ἕκαστος,{l]
[l [n}23.59{]}Πηλεΐδης δʼ ἐπὶ θινὶ πολυφλοίσβοιο θαλάσσης{l]
[l [n}23.60{]}κεῖτο βαρὺ στενάχων πολέσιν μετὰ Μυρμιδόνεσσιν{l]
[l [n}23.61{]}ἐν καθαρῷ, ὅθι κύματʼ ἐπʼ ἠϊόνος κλύζεσκον·{l]
[l [n}23.62{]}εὖτε τὸν ὕπνος ἔμαρπτε λύων μελεδήματα θυμοῦ{l]
[l [n}23.63{]}νήδυμος ἀμφιχυθείς· μάλα γὰρ κάμε φαίδιμα γυῖα{l]
[l [n}23.64{]}Ἕκτορʼ ἐπαΐσσων προτὶ Ἴλιον ἠνεμόεσσαν·{l]
[l [n}23.65{]}ἦλθε δʼ ἐπὶ ψυχὴ Πατροκλῆος δειλοῖο{l]
[l [n}23.66{]}πάντʼ αὐτῷ μέγεθός τε καὶ ὄμματα κάλʼ ἐϊκυῖα{l]
[l [n}23.67{]}καὶ φωνήν, καὶ τοῖα περὶ χροῒ εἵματα ἕστο·{l]
[l [n}23.68{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς καί μιν πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}23.69{]}εὕδεις, αὐτὰρ ἐμεῖο λελασμένος ἔπλευ Ἀχιλλεῦ.{l]
[l [n}23.70{]}οὐ μέν μευ ζώοντος ἀκήδεις, ἀλλὰ θανόντος·{l]
[l [n}23.71{]}θάπτέ με ὅττι τάχιστα πύλας Ἀΐδαο περήσω.{l]
[l [n}23.72{]}τῆλέ με εἴργουσι ψυχαὶ εἴδωλα καμόντων,{l]
[l [n}23.73{]}οὐδέ μέ πω μίσγεσθαι ὑπὲρ ποταμοῖο ἐῶσιν,{l]
[l [n}23.74{]}ἀλλʼ αὔτως ἀλάλημαι ἀνʼ εὐρυπυλὲς Ἄϊδος δῶ.{l]
[l [n}23.75{]}καί μοι δὸς τὴν χεῖρʼ· ὀλοφύρομαι, οὐ γὰρ ἔτʼ αὖτις{l]
[l [n}23.76{]}νίσομαι ἐξ Ἀΐδαο, ἐπήν με πυρὸς λελάχητε.{l]
[l [n}23.77{]}οὐ μὲν γὰρ ζωοί γε φίλων ἀπάνευθεν ἑταίρων{l]
[l [n}23.78{]}βουλὰς ἑζόμενοι βουλεύσομεν, ἀλλʼ ἐμὲ μὲν κὴρ{l]
[l [n}23.79{]}ἀμφέχανε στυγερή, ἥ περ λάχε γιγνόμενόν περ·{l]
[l [n}23.80{]}καὶ δὲ σοὶ αὐτῷ μοῖρα, θεοῖς ἐπιείκελʼ Ἀχιλλεῦ,{l]
[l [n}23.81{]}τείχει ὕπο Τρώων εὐηφενέων ἀπολέσθαι.{l]
[l [n}23.82{]}ἄλλο δέ τοι ἐρέω καὶ ἐφήσομαι αἴ κε πίθηαι·{l]
[l [n}23.83{]}μὴ ἐμὰ σῶν ἀπάνευθε τιθήμεναι ὀστέʼ Ἀχιλλεῦ,{l]
[l [n}23.84{]}ἀλλʼ ὁμοῦ ὡς ἐτράφημεν ἐν ὑμετέροισι δόμοισιν,{l]
[l [n}23.85{]}εὖτέ με τυτθὸν ἐόντα Μενοίτιος ἐξ Ὀπόεντος{l]
[l [n}23.86{]}ἤγαγεν ὑμέτερόνδʼ ἀνδροκτασίης ὕπο λυγρῆς,{l]
[l [n}23.87{]}ἤματι τῷ ὅτε παῖδα κατέκτανον Ἀμφιδάμαντος{l]
[l [n}23.88{]}νήπιος οὐκ ἐθέλων ἀμφʼ ἀστραγάλοισι χολωθείς·{l]
[l [n}23.89{]}ἔνθά με δεξάμενος ἐν δώμασιν ἱππότα Πηλεὺς{l]
[l [n}23.90{]}ἔτραφέ τʼ ἐνδυκέως καὶ σὸν θεράποντʼ ὀνόμηνεν·{l]
[l [n}23.91{]}ὣς δὲ καὶ ὀστέα νῶϊν ὁμὴ σορὸς ἀμφικαλύπτοι{l]
[l [n}23.92{]}χρύσεος ἀμφιφορεύς, τόν τοι πόρε πότνια μήτηρ.{l]{q]{para]
[para}[l [n}23.93{]}τὸν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}23.94{]}τίπτέ μοι ἠθείη κεφαλὴ δεῦρʼ εἰλήλουθας{l]
[l [n}23.95{]}καί μοι ταῦτα ἕκαστʼ ἐπιτέλλεαι; αὐτὰρ ἐγώ τοι{l]
[l [n}23.96{]}πάντα μάλʼ ἐκτελέω καὶ πείσομαι ὡς σὺ κελεύεις.{l]
[l [n}23.97{]}ἀλλά μοι ἆσσον στῆθι· μίνυνθά περ ἀμφιβαλόντε{l]
[l [n}23.98{]}ἀλλήλους ὀλοοῖο τεταρπώμεσθα γόοιο.{l]{q]{para]
[para}[l [n}23.99{]}ὣς ἄρα φωνήσας ὠρέξατο χερσὶ φίλῃσιν{l]
[l [n}23.100{]}οὐδʼ ἔλαβε· ψυχὴ δὲ κατὰ χθονὸς ἠΰτε καπνὸς{l]
[l [n}23.101{]}ᾤχετο τετριγυῖα· ταφὼν δʼ ἀνόρουσεν Ἀχιλλεὺς{l]
[l [n}23.102{]}χερσί τε συμπλατάγησεν, ἔπος δʼ ὀλοφυδνὸν ἔειπεν·{l]
[q}[l [n}23.103{]}ὢ πόποι ἦ ῥά τίς ἐστι καὶ εἰν Ἀΐδαο δόμοισι{l]
[l [n}23.104{]}ψυχὴ καὶ εἴδωλον, ἀτὰρ φρένες οὐκ ἔνι πάμπαν·{l]
[l [n}23.105{]}παννυχίη γάρ μοι Πατροκλῆος δειλοῖο{l]
[l [n}23.106{]}ψυχὴ ἐφεστήκει γοόωσά τε μυρομένη τε,{l]
[l [n}23.107{]}καί μοι ἕκαστʼ ἐπέτελλεν, ἔϊκτο δὲ θέσκελον αὐτῷ.{l]{q]{para]
[para}[l [n}23.108{]}ὣς φάτο, τοῖσι δὲ πᾶσιν ὑφʼ ἵμερον ὦρσε γόοιο·{l]
[l [n}23.109{]}μυρομένοισι δὲ τοῖσι φάνη ῥοδοδάκτυλος Ἠὼς{l]
[l [n}23.110{]}ἀμφὶ νέκυν ἐλεεινόν. ἀτὰρ κρείων Ἀγαμέμνων{l]
[l [n}23.111{]}οὐρῆάς τʼ ὄτρυνε καὶ ἀνέρας ἀξέμεν ὕλην{l]
[l [n}23.112{]}πάντοθεν ἐκ κλισιῶν· ἐπὶ δʼ ἀνὴρ ἐσθλὸς ὀρώρει{l]
[l [n}23.113{]}Μηριόνης θεράπων ἀγαπήνορος Ἰδομενῆος.{l]
[l [n}23.114{]}οἳ δʼ ἴσαν ὑλοτόμους πελέκεας ἐν χερσὶν ἔχοντες{l]
[l [n}23.115{]}σειράς τʼ εὐπλέκτους· πρὸ δʼ ἄρʼ οὐρῆες κίον αὐτῶν.{l]
[l [n}23.116{]}πολλὰ δʼ ἄναντα κάταντα πάραντά τε δόχμιά τʼ ἦλθον·{l]
[l [n}23.117{]}ἀλλʼ ὅτε δὴ κνημοὺς προσέβαν πολυπίδακος Ἴδης,{l]
[l [n}23.118{]}αὐτίκʼ ἄρα δρῦς ὑψικόμους ταναήκεϊ χαλκῷ{l]
[l [n}23.119{]}τάμνον ἐπειγόμενοι· ταὶ δὲ μεγάλα κτυπέουσαι{l]
[l [n}23.120{]}πῖπτον· τὰς μὲν ἔπειτα διαπλήσσοντες Ἀχαιοὶ{l]
[l [n}23.121{]}ἔκδεον ἡμιόνων· ταὶ δὲ χθόνα ποσσὶ δατεῦντο{l]
[l [n}23.122{]}ἐλδόμεναι πεδίοιο διὰ ῥωπήϊα πυκνά.{l]
[l [n}23.123{]}πάντες δʼ ὑλοτόμοι φιτροὺς φέρον· ὡς γὰρ ἀνώγει{l]
[l [n}23.124{]}Μηριόνης θεράπων ἀγαπήνορος Ἰδομενῆος.{l]
[l [n}23.125{]}κὰδ δʼ ἄρʼ ἐπʼ ἀκτῆς βάλλον ἐπισχερώ, ἔνθʼ ἄρʼ Ἀχιλλεὺς{l]
[l [n}23.126{]}φράσσατο Πατρόκλῳ μέγα ἠρίον ἠδὲ οἷ αὐτῷ.{l]{para]
[para}[l [n}23.127{]}αὐτὰρ ἐπεὶ πάντῃ παρακάββαλον ἄσπετον ὕλην{l]
[l [n}23.128{]}ἥατʼ ἄρʼ αὖθι μένοντες ἀολλέες. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}23.129{]}αὐτίκα Μυρμιδόνεσσι φιλοπτολέμοισι κέλευσε{l]
[l [n}23.130{]}χαλκὸν ζώννυσθαι, ζεῦξαι δʼ ὑπʼ ὄχεσφιν ἕκαστον{l]
[l [n}23.131{]}ἵππους· οἳ δʼ ὄρνυντο καὶ ἐν τεύχεσσιν ἔδυνον,{l]
[l [n}23.132{]}ἂν δʼ ἔβαν ἐν δίφροισι παραιβάται ἡνίοχοί τε,{l]
[l [n}23.133{]}πρόσθε μὲν ἱππῆες, μετὰ δὲ νέφος εἵπετο πεζῶν{l]
[l [n}23.134{]}μυρίοι· ἐν δὲ μέσοισι φέρον Πάτροκλον ἑταῖροι.{l]
[l [n}23.135{]}θριξὶ δὲ πάντα νέκυν καταείνυσαν, ἃς ἐπέβαλλον{l]
[l [n}23.136{]}κειρόμενοι· ὄπιθεν δὲ κάρη ἔχε δῖος Ἀχιλλεὺς{l]
[l [n}23.137{]}ἀχνύμενος· ἕταρον γὰρ ἀμύμονα πέμπʼ Ἄϊδος δέ.{l]{para]
[para}[l [n}23.138{]}οἳ δʼ ὅτε χῶρον ἵκανον ὅθί σφισι πέφραδʼ Ἀχιλλεὺς{l]
[l [n}23.139{]}κάτθεσαν, αἶψα δέ οἱ μενοεικέα νήεον ὕλην.{l]
[l [n}23.140{]}ἔνθʼ αὖτʼ ἄλλʼ ἐνόησε ποδάρκης δῖος Ἀχιλλεύς·{l]
[l [n}23.141{]}στὰς ἀπάνευθε πυρῆς ξανθὴν ἀπεκείρατο χαίτην,{l]
[l [n}23.142{]}τήν ῥα Σπερχειῷ ποταμῷ τρέφε τηλεθόωσαν·{l]
[l [n}23.143{]}ὀχθήσας δʼ ἄρα εἶπεν ἰδὼν ἐπὶ οἴνοπα πόντον·{l]
[q}[l [n}23.144{]}Σπερχείʼ ἄλλως σοί γε πατὴρ ἠρήσατο Πηλεὺς{l]
[l [n}23.145{]}κεῖσέ με νοστήσαντα φίλην ἐς πατρίδα γαῖαν{l]
[l [n}23.146{]}σοί τε κόμην κερέειν ῥέξειν θʼ ἱερὴν ἑκατόμβην,{l]
[l [n}23.147{]}πεντήκοντα δʼ ἔνορχα παρʼ αὐτόθι μῆλʼ ἱερεύσειν{l]
[l [n}23.148{]}ἐς πηγάς, ὅθι τοι τέμενος βωμός τε θυήεις.{l]
[l [n}23.149{]}ὣς ἠρᾶθʼ ὃ γέρων, σὺ δέ οἱ νόον οὐκ ἐτέλεσσας.{l]
[l [n}23.150{]}νῦν δʼ ἐπεὶ οὐ νέομαί γε φίλην ἐς πατρίδα γαῖαν{l]
[l [n}23.151{]}Πατρόκλῳ ἥρωϊ κόμην ὀπάσαιμι φέρεσθαι.{l]{q]{para]
[para}[l [n}23.152{]}ὣς εἰπὼν ἐν χερσὶ κόμην ἑτάροιο φίλοιο{l]
[l [n}23.153{]}θῆκεν, τοῖσι δὲ πᾶσιν ὑφʼ ἵμερον ὦρσε γόοιο.{l]
[l [n}23.154{]}καί νύ κʼ ὀδυρομένοισιν ἔδυ φάος ἠελίοιο{l]
[l [n}23.155{]}εἰ μὴ Ἀχιλλεὺς αἶψʼ Ἀγαμέμνονι εἶπε παραστάς·{l]
[q}[l [n}23.156{]}Ἀτρεΐδη, σοὶ γάρ τε μάλιστά γε λαὸς Ἀχαιῶν{l]
[l [n}23.157{]}πείσονται μύθοισι, γόοιο μὲν ἔστι καὶ ἆσαι,{l]
[l [n}23.158{]}νῦν δʼ ἀπὸ πυρκαϊῆς σκέδασον καὶ δεῖπνον ἄνωχθι{l]
[l [n}23.159{]}ὅπλεσθαι· τάδε δʼ ἀμφὶ πονησόμεθʼ οἷσι μάλιστα{l]
[l [n}23.160{]}κήδεός ἐστι νέκυς· παρὰ δʼ οἵ τʼ ἀγοὶ ἄμμι μενόντων.{l]{q]{para]
[para}[l [n}23.161{]}αὐτὰρ ἐπεὶ τό γʼ ἄκουσεν ἄναξ ἀνδρῶν Ἀγαμέμνων,{l]
[l [n}23.162{]}αὐτίκα λαὸν μὲν σκέδασεν κατὰ νῆας ἐΐσας,{l]
[l [n}23.163{]}κηδεμόνες δὲ παρʼ αὖθι μένον καὶ νήεον ὕλην,{l]
[l [n}23.164{]}ποίησαν δὲ πυρὴν ἑκατόμπεδον ἔνθα καὶ ἔνθα,{l]
[l [n}23.165{]}ἐν δὲ πυρῇ ὑπάτῃ νεκρὸν θέσαν ἀχνύμενοι κῆρ.{l]
[l [n}23.166{]}πολλὰ δὲ ἴφια μῆλα καὶ εἰλίποδας ἕλικας βοῦς{l]
[l [n}23.167{]}πρόσθε πυρῆς ἔδερόν τε καὶ ἄμφεπον· ἐκ δʼ ἄρα πάντων{l]
[l [n}23.168{]}δημὸν ἑλὼν ἐκάλυψε νέκυν μεγάθυμος Ἀχιλλεὺς{l]
[l [n}23.169{]}ἐς πόδας ἐκ κεφαλῆς, περὶ δὲ δρατὰ σώματα νήει.{l]
[l [n}23.170{]}ἐν δʼ ἐτίθει μέλιτος καὶ ἀλείφατος ἀμφιφορῆας{l]
[l [n}23.171{]}πρὸς λέχεα κλίνων· πίσυρας δʼ ἐριαύχενας ἵππους{l]
[l [n}23.172{]}ἐσσυμένως ἐνέβαλλε πυρῇ μεγάλα στεναχίζων.{l]
[l [n}23.173{]}ἐννέα τῷ γε ἄνακτι τραπεζῆες κύνες ἦσαν,{l]
[l [n}23.174{]}καὶ μὲν τῶν ἐνέβαλλε πυρῇ δύο δειροτομήσας,{l]
[l [n}23.175{]}δώδεκα δὲ Τρώων μεγαθύμων υἱέας ἐσθλοὺς{l]
[l [n}23.176{]}χαλκῷ δηϊόων· κακὰ δὲ φρεσὶ μήδετο ἔργα·{l]
[l [n}23.177{]}ἐν δὲ πυρὸς μένος ἧκε σιδήρεον ὄφρα νέμοιτο.{l]
[l [n}23.178{]}ᾤμωξέν τʼ ἄρʼ ἔπειτα, φίλον δʼ ὀνόμηνεν ἑταῖρον·{l]
[q}[l [n}23.179{]}χαῖρέ μοι ὦ Πάτροκλε καὶ εἰν Ἀΐδαο δόμοισι·{l]
[l [n}23.180{]}πάντα γὰρ ἤδη τοι τελέω τὰ πάροιθεν ὑπέστην,{l]
[l [n}23.181{]}δώδεκα μὲν Τρώων μεγαθύμων υἱέας ἐσθλοὺς{l]
[l [n}23.182{]}τοὺς ἅμα σοὶ πάντας πῦρ ἐσθίει· Ἕκτορα δʼ οὔ τι{l]
[l [n}23.183{]}δώσω Πριαμίδην πυρὶ δαπτέμεν, ἀλλὰ κύνεσσιν.{l]{q]{para]
[para}[l [n}23.184{]}ὣς φάτʼ ἀπειλήσας· τὸν δʼ οὐ κύνες ἀμφεπένοντο,{l]
[l [n}23.185{]}ἀλλὰ κύνας μὲν ἄλαλκε Διὸς θυγάτηρ Ἀφροδίτη{l]
[l [n}23.186{]}ἤματα καὶ νύκτας, ῥοδόεντι δὲ χρῖεν ἐλαίῳ{l]
[l [n}23.187{]}ἀμβροσίῳ, ἵνα μή μιν ἀποδρύφοι ἑλκυστάζων.{l]
[l [n}23.188{]}τῷ δʼ ἐπὶ κυάνεον νέφος ἤγαγε Φοῖβος Ἀπόλλων{l]
[l [n}23.189{]}οὐρανόθεν πεδίον δέ, κάλυψε δὲ χῶρον ἅπαντα{l]
[l [n}23.190{]}ὅσσον ἐπεῖχε νέκυς, μὴ πρὶν μένος ἠελίοιο{l]
[l [n}23.191{]}σκήλειʼ ἀμφὶ περὶ χρόα ἴνεσιν ἠδὲ μέλεσσιν.{l]{para]
[para}[l [n}23.192{]}οὐδὲ πυρὴ Πατρόκλου ἐκαίετο τεθνηῶτος·{l]
[l [n}23.193{]}ἔνθʼ αὖτʼ ἀλλʼ ἐνόησε ποδάρκης δῖος Ἀχιλλεύς·{l]
[l [n}23.194{]}στὰς ἀπάνευθε πυρῆς δοιοῖς ἠρᾶτʼ ἀνέμοισι{l]
[l [n}23.195{]}Βορέῃ καὶ Ζεφύρῳ, καὶ ὑπίσχετο ἱερὰ καλά·{l]
[l [n}23.196{]}πολλὰ δὲ καὶ σπένδων χρυσέῳ δέπαϊ λιτάνευεν{l]
[l [n}23.197{]}ἐλθέμεν, ὄφρα τάχιστα πυρὶ φλεγεθοίατο νεκροί,{l]
[l [n}23.198{]}ὕλη τε σεύαιτο καήμεναι. ὦκα δὲ Ἶρις{l]
[l [n}23.199{]}ἀράων ἀΐουσα μετάγγελος ἦλθʼ ἀνέμοισιν.{l]
[l [n}23.200{]}οἳ μὲν ἄρα Ζεφύροιο δυσαέος ἀθρόοι ἔνδον{l]
[l [n}23.201{]}εἰλαπίνην δαίνυντο· θέουσα δὲ Ἶρις ἐπέστη{l]
[l [n}23.202{]}βηλῷ ἔπι λιθέῳ· τοὶ δʼ ὡς ἴδον ὀφθαλμοῖσι{l]
[l [n}23.203{]}πάντες ἀνήϊξαν, κάλεόν τέ μιν εἰς ἓ ἕκαστος·{l]
[l [n}23.204{]}ἣ δʼ αὖθʼ ἕζεσθαι μὲν ἀνήνατο, εἶπε δὲ μῦθον·{l]
[q}[l [n}23.205{]}οὐχ ἕδος· εἶμι γὰρ αὖτις ἐπʼ Ὠκεανοῖο ῥέεθρα{l]
[l [n}23.206{]}Αἰθιόπων ἐς γαῖαν, ὅθι ῥέζουσʼ ἑκατόμβας{l]
[l [n}23.207{]}ἀθανάτοις, ἵνα δὴ καὶ ἐγὼ μεταδαίσομαι ἱρῶν.{l]
[l [n}23.208{]}ἀλλʼ Ἀχιλεὺς Βορέην ἠδὲ Ζέφυρον κελαδεινὸν{l]
[l [n}23.209{]}ἐλθεῖν ἀρᾶται, καὶ ὑπίσχεται ἱερὰ καλά,{l]
[l [n}23.210{]}ὄφρα πυρὴν ὄρσητε καήμεναι, ᾗ ἔνι κεῖται{l]
[l [n}23.211{]}Πάτροκλος, τὸν πάντες ἀναστενάχουσιν Ἀχαιοί.{l]{q]{para]
[para}[l [n}23.212{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπεβήσετο, τοὶ δʼ ὀρέοντο{l]
[l [n}23.213{]}ἠχῇ θεσπεσίῃ νέφεα κλονέοντε πάροιθεν.{l]
[l [n}23.214{]}αἶψα δὲ πόντον ἵκανον ἀήμεναι, ὦρτο δὲ κῦμα{l]
[l [n}23.215{]}πνοιῇ ὕπο λιγυρῇ· Τροίην δʼ ἐρίβωλον ἱκέσθην,{l]
[l [n}23.216{]}ἐν δὲ πυρῇ πεσέτην, μέγα δʼ ἴαχε θεσπιδαὲς πῦρ.{l]
[l [n}23.217{]}παννύχιοι δʼ ἄρα τοί γε πυρῆς ἄμυδις φλόγʼ ἔβαλλον{l]
[l [n}23.218{]}φυσῶντες λιγέως· ὃ δὲ πάννυχος ὠκὺς Ἀχιλλεὺς{l]
[l [n}23.219{]}χρυσέου ἐκ κρητῆρος ἑλὼν δέπας ἀμφικύπελλον{l]
[l [n}23.220{]}οἶνον ἀφυσσόμενος χαμάδις χέε, δεῦε δὲ γαῖαν{l]
[l [n}23.221{]}ψυχὴν κικλήσκων Πατροκλῆος δειλοῖο.{l]
[l [n}23.222{]}ὡς δὲ πατὴρ οὗ παιδὸς ὀδύρεται ὀστέα καίων{l]
[l [n}23.223{]}νυμφίου, ὅς τε θανὼν δειλοὺς ἀκάχησε τοκῆας,{l]
[l [n}23.224{]}ὣς Ἀχιλεὺς ἑτάροιο ὀδύρετο ὀστέα καίων,{l]
[l [n}23.225{]}ἑρπύζων παρὰ πυρκαϊὴν ἁδινὰ στεναχίζων.{l]{para]
[para}[l [n}23.226{]}ἦμος δʼ ἑωσφόρος εἶσι φόως ἐρέων ἐπὶ γαῖαν,{l]
[l [n}23.227{]}ὅν τε μέτα κροκόπεπλος ὑπεὶρ ἅλα κίδναται ἠώς,{l]
[l [n}23.228{]}τῆμος πυρκαϊὴ ἐμαραίνετο, παύσατο δὲ φλόξ.{l]
[l [n}23.229{]}οἳ δʼ ἄνεμοι πάλιν αὖτις ἔβαν οἶκον δὲ νέεσθαι{l]
[l [n}23.230{]}Θρηΐκιον κατὰ πόντον· ὃ δʼ ἔστενεν οἴδματι θύων.{l]
[l [n}23.231{]}Πηλεΐδης δʼ ἀπὸ πυρκαϊῆς ἑτέρωσε λιασθεὶς{l]
[l [n}23.232{]}κλίνθη κεκμηώς, ἐπὶ δὲ γλυκὺς ὕπνος ὄρουσεν·{l]
[l [n}23.233{]}οἳ δʼ ἀμφʼ Ἀτρεΐωνα ἀολλέες ἠγερέθοντο·{l]
[l [n}23.234{]}τῶν μιν ἐπερχομένων ὅμαδος καὶ δοῦπος ἔγειρεν,{l]
[l [n}23.235{]}ἕζετο δʼ ὀρθωθεὶς καί σφεας πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}23.236{]}Ἀτρεΐδη τε καὶ ἄλλοι ἀριστῆες Παναχαιῶν,{l]
[l [n}23.237{]}πρῶτον μὲν κατὰ πυρκαϊὴν σβέσατʼ αἴθοπι οἴνῳ{l]
[l [n}23.238{]}πᾶσαν, ὁπόσσον ἐπέσχε πυρὸς μένος· αὐτὰρ ἔπειτα{l]
[l [n}23.239{]}ὀστέα Πατρόκλοιο Μενοιτιάδαο λέγωμεν{l]
[l [n}23.240{]}εὖ διαγιγνώσκοντες· ἀριφραδέα δὲ τέτυκται·{l]
[l [n}23.241{]}ἐν μέσσῃ γὰρ ἔκειτο πυρῇ, τοὶ δʼ ἄλλοι ἄνευθεν{l]
[l [n}23.242{]}ἐσχατιῇ καίοντʼ ἐπιμὶξ ἵπποι τε καὶ ἄνδρες.{l]
[l [n}23.243{]}καὶ τὰ μὲν ἐν χρυσέῃ φιάλῃ καὶ δίπλακι δημῷ{l]
[l [n}23.244{]}θείομεν, εἰς ὅ κεν αὐτὸς ἐγὼν Ἄϊδι κεύθωμαι.{l]
[l [n}23.245{]}τύμβον δʼ οὐ μάλα πολλὸν ἐγὼ πονέεσθαι ἄνωγα,{l]
[l [n}23.246{]}ἀλλʼ ἐπιεικέα τοῖον· ἔπειτα δὲ καὶ τὸν Ἀχαιοὶ{l]
[l [n}23.247{]}εὐρύν θʼ ὑψηλόν τε τιθήμεναι, οἵ κεν ἐμεῖο{l]
[l [n}23.248{]}δεύτεροι ἐν νήεσσι πολυκλήϊσι λίπησθε.{l]{q]{para]
[para}[l [n}23.249{]}ὣς ἔφαθʼ, οἳ δʼ ἐπίθοντο ποδώκεϊ Πηλεΐωνι.{l]
[l [n}23.250{]}πρῶτον μὲν κατὰ πυρκαϊὴν σβέσαν αἴθοπι οἴνῳ{l]
[l [n}23.251{]}ὅσσον ἐπὶ φλὸξ ἦλθε, βαθεῖα δὲ κάππεσε τέφρη·{l]
[l [n}23.252{]}κλαίοντες δʼ ἑτάροιο ἐνηέος ὀστέα λευκὰ{l]
[l [n}23.253{]}ἄλλεγον ἐς χρυσέην φιάλην καὶ δίπλακα δημόν,{l]
[l [n}23.254{]}ἐν κλισίῃσι δὲ θέντες ἑανῷ λιτὶ κάλυψαν·{l]
[l [n}23.255{]}τορνώσαντο δὲ σῆμα θεμείλιά τε προβάλοντο{l]
[l [n}23.256{]}ἀμφὶ πυρήν· εἶθαρ δὲ χυτὴν ἐπὶ γαῖαν ἔχευαν,{l]
[l [n}23.257{]}χεύαντες δὲ τὸ σῆμα πάλιν κίον. αὐτὰρ Ἀχιλλεὺς{l]
[l [n}23.258{]}αὐτοῦ λαὸν ἔρυκε καὶ ἵζανεν εὐρὺν ἀγῶνα,{l]
[l [n}23.259{]}νηῶν δʼ ἔκφερʼ ἄεθλα λέβητάς τε τρίποδάς τε{l]
[l [n}23.260{]}ἵππους θʼ ἡμιόνους τε βοῶν τʼ ἴφθιμα κάρηνα,{l]
[l [n}23.261{]}ἠδὲ γυναῖκας ἐϋζώνους πολιόν τε σίδηρον.{l]{para]
[para}[l [n}23.262{]}ἱππεῦσιν μὲν πρῶτα ποδώκεσιν ἀγλάʼ ἄεθλα{l]
[l [n}23.263{]}θῆκε γυναῖκα ἄγεσθαι ἀμύμονα ἔργα ἰδυῖαν{l]
[l [n}23.264{]}καὶ τρίποδʼ ὠτώεντα δυωκαιεικοσίμετρον{l]
[l [n}23.265{]}τῷ πρώτῳ· ἀτὰρ αὖ τῷ δευτέρῳ ἵππον ἔθηκεν{l]
[l [n}23.266{]}ἑξέτεʼ ἀδμήτην βρέφος ἡμίονον κυέουσαν·{l]
[l [n}23.267{]}αὐτὰρ τῷ τριτάτῳ ἄπυρον κατέθηκε λέβητα{l]
[l [n}23.268{]}καλὸν τέσσαρα μέτρα κεχανδότα λευκὸν ἔτʼ αὔτως·{l]
[l [n}23.269{]}τῷ δὲ τετάρτῳ θῆκε δύω χρυσοῖο τάλαντα,{l]
[l [n}23.270{]}πέμπτῳ δʼ ἀμφίθετον φιάλην ἀπύρωτον ἔθηκε.{l]
[l [n}23.271{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.272{]}Ἀτρεΐδη τε καὶ ἄλλοι ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}23.273{]}ἱππῆας τάδʼ ἄεθλα δεδεγμένα κεῖτʼ ἐν ἀγῶνι.{l]
[l [n}23.274{]}εἰ μὲν νῦν ἐπὶ ἄλλῳ ἀεθλεύοιμεν Ἀχαιοὶ{l]
[l [n}23.275{]}ἦ τʼ ἂν ἐγὼ τὰ πρῶτα λαβὼν κλισίην δὲ φεροίμην.{l]
[l [n}23.276{]}ἴστε γὰρ ὅσσον ἐμοὶ ἀρετῇ περιβάλλετον ἵπποι·{l]
[l [n}23.277{]}ἀθάνατοί τε γάρ εἰσι, Ποσειδάων δὲ πόρʼ αὐτοὺς{l]
[l [n}23.278{]}πατρὶ ἐμῷ Πηλῆϊ, ὃ δʼ αὖτʼ ἐμοὶ ἐγγυάλιξεν.{l]
[l [n}23.279{]}ἀλλʼ ἤτοι μὲν ἐγὼ μενέω καὶ μώνυχες ἵπποι·{l]
[l [n}23.280{]}τοίου γὰρ κλέος ἐσθλὸν ἀπώλεσαν ἡνιόχοιο{l]
[l [n}23.281{]}ἠπίου, ὅς σφωϊν μάλα πολλάκις ὑγρὸν ἔλαιον{l]
[l [n}23.282{]}χαιτάων κατέχευε λοέσσας ὕδατι λευκῷ.{l]
[l [n}23.283{]}τὸν τώ γʼ ἑσταότες πενθείετον, οὔδεϊ δέ σφι{l]
[l [n}23.284{]}χαῖται ἐρηρέδαται, τὼ δʼ ἕστατον ἀχνυμένω κῆρ.{l]
[l [n}23.285{]}ἄλλοι δὲ στέλλεσθε κατὰ στρατόν, ὅς τις Ἀχαιῶν{l]
[l [n}23.286{]}ἵπποισίν τε πέποιθε καὶ ἅρμασι κολλητοῖσιν.{l]{q]{para]
[para}[l [n}23.287{]}ὣς φάτο Πηλεΐδης, ταχέες δʼ ἱππῆες ἄγερθεν.{l]
[l [n}23.288{]}ὦρτο πολὺ πρῶτος μὲν ἄναξ ἀνδρῶν Εὔμηλος{l]
[l [n}23.289{]}Ἀδμήτου φίλος υἱός, ὃς ἱπποσύνῃ ἐκέκαστο·{l]
[l [n}23.290{]}τῷ δʼ ἐπὶ Τυδεΐδης ὦρτο κρατερὸς Διομήδης,{l]
[l [n}23.291{]}ἵππους δὲ Τρῳοὺς ὕπαγε ζυγόν, οὕς ποτʼ ἀπηύρα{l]
[l [n}23.292{]}Αἰνείαν, ἀτὰρ αὐτὸν ὑπεξεσάωσεν Ἀπόλλων.{l]
[l [n}23.293{]}τῷ δʼ ἄρʼ ἐπʼ Ἀτρεΐδης ὦρτο ξανθὸς Μενέλαος{l]
[l [n}23.294{]}διογενής, ὑπὸ δὲ ζυγὸν ἤγαγεν ὠκέας ἵππους{l]
[l [n}23.295{]}Αἴθην τὴν Ἀγαμεμνονέην τὸν ἑόν τε Πόδαργον·{l]
[l [n}23.296{]}τὴν Ἀγαμέμνονι δῶκʼ Ἀγχισιάδης Ἐχέπωλος{l]
[l [n}23.297{]}δῶρʼ, ἵνα μή οἱ ἕποιθʼ ὑπὸ Ἴλιον ἠνεμόεσσαν,{l]
[l [n}23.298{]}ἀλλʼ αὐτοῦ τέρποιτο μένων· μέγα γάρ οἱ ἔδωκε{l]
[l [n}23.299{]}Ζεὺς ἄφενος, ναῖεν δʼ ὅ γʼ ἐν εὐρυχόρῳ Σικυῶνι·{l]
[l [n}23.300{]}τὴν ὅ γʼ ὑπὸ ζυγὸν ἦγε μέγα δρόμου ἰσχανόωσαν.{l]
[l [n}23.301{]}Ἀντίλοχος δὲ τέταρτος ἐΰτριχας ὁπλίσαθʼ ἵππους,{l]
[l [n}23.302{]}Νέστορος ἀγλαὸς υἱὸς ὑπερθύμοιο ἄνακτος{l]
[l [n}23.303{]}τοῦ Νηληϊάδαο· Πυλοιγενέες δέ οἱ ἵπποι{l]
[l [n}23.304{]}ὠκύποδες φέρον ἅρμα· πατὴρ δέ οἱ ἄγχι παραστὰς{l]
[l [n}23.305{]}μυθεῖτʼ εἰς ἀγαθὰ φρονέων νοέοντι καὶ αὐτῷ·{l]
[q}[l [n}23.306{]}Ἀντίλοχʼ ἤτοι μέν σε νέον περ ἐόντʼ ἐφίλησαν{l]
[l [n}23.307{]}Ζεύς τε Ποσειδάων τε, καὶ ἱπποσύνας ἐδίδαξαν{l]
[l [n}23.308{]}παντοίας· τὼ καί σε διδασκέμεν οὔ τι μάλα χρεώ·{l]
[l [n}23.309{]}οἶσθα γὰρ εὖ περὶ τέρμαθʼ ἑλισσέμεν· ἀλλά τοι ἵπποι{l]
[l [n}23.310{]}βάρδιστοι θείειν· τώ τʼ οἴω λοίγιʼ ἔσεσθαι.{l]
[l [n}23.311{]}τῶν δʼ ἵπποι μὲν ἔασιν ἀφάρτεροι, οὐδὲ μὲν αὐτοὶ{l]
[l [n}23.312{]}πλείονα ἴσασιν σέθεν αὐτοῦ μητίσασθαι.{l]
[l [n}23.313{]}ἀλλʼ ἄγε δὴ σὺ φίλος μῆτιν ἐμβάλλεο θυμῷ{l]
[l [n}23.314{]}παντοίην, ἵνα μή σε παρεκπροφύγῃσιν ἄεθλα.{l]
[l [n}23.315{]}μήτι τοι δρυτόμος μέγʼ ἀμείνων ἠὲ βίηφι·{l]
[l [n}23.316{]}μήτι δʼ αὖτε κυβερνήτης ἐνὶ οἴνοπι πόντῳ{l]
[l [n}23.317{]}νῆα θοὴν ἰθύνει ἐρεχθομένην ἀνέμοισι·{l]
[l [n}23.318{]}μήτι δʼ ἡνίοχος περιγίγνεται ἡνιόχοιο.{l]
[l [n}23.319{]}ἀλλʼ ὃς μέν θʼ ἵπποισι καὶ ἅρμασιν οἷσι πεποιθὼς{l]
[l [n}23.320{]}ἀφραδέως ἐπὶ πολλὸν ἑλίσσεται ἔνθα καὶ ἔνθα,{l]
[l [n}23.321{]}ἵπποι δὲ πλανόωνται ἀνὰ δρόμον, οὐδὲ κατίσχει·{l]
[l [n}23.322{]}ὃς δέ κε κέρδεα εἰδῇ ἐλαύνων ἥσσονας ἵππους,{l]
[l [n}23.323{]}αἰεὶ τέρμʼ ὁρόων στρέφει ἐγγύθεν, οὐδέ ἑ λήθει{l]
[l [n}23.324{]}ὅππως τὸ πρῶτον τανύσῃ βοέοισιν ἱμᾶσιν,{l]
[l [n}23.325{]}ἀλλʼ ἔχει ἀσφαλέως καὶ τὸν προὔχοντα δοκεύει.{l]
[l [n}23.326{]}σῆμα δέ τοι ἐρέω μάλʼ ἀριφραδές, οὐδέ σε λήσει.{l]
[l [n}23.327{]}ἕστηκε ξύλον αὖον ὅσον τʼ ὄργυιʼ ὑπὲρ αἴης{l]
[l [n}23.328{]}ἢ δρυὸς ἢ πεύκης· τὸ μὲν οὐ καταπύθεται ὄμβρῳ,{l]
[l [n}23.329{]}λᾶε δὲ τοῦ ἑκάτερθεν ἐρηρέδαται δύο λευκὼ{l]
[l [n}23.330{]}ἐν ξυνοχῇσιν ὁδοῦ, λεῖος δʼ ἱππόδρομος ἀμφὶς{l]
[l [n}23.331{]}ἤ τευ σῆμα βροτοῖο πάλαι κατατεθνηῶτος,{l]
[l [n}23.332{]}ἢ τό γε νύσσα τέτυκτο ἐπὶ προτέρων ἀνθρώπων,{l]
[l [n}23.333{]}καὶ νῦν τέρματʼ ἔθηκε ποδάρκης δῖος Ἀχιλλεύς.{l]
[l [n}23.334{]}τῷ σὺ μάλʼ ἐγχρίμψας ἐλάαν σχεδὸν ἅρμα καὶ ἵππους,{l]
[l [n}23.335{]}αὐτὸς δὲ κλινθῆναι ἐϋπλέκτῳ ἐνὶ δίφρῳ{l]
[l [n}23.336{]}ἦκʼ ἐπʼ ἀριστερὰ τοῖιν· ἀτὰρ τὸν δεξιὸν ἵππον{l]
[l [n}23.337{]}κένσαι ὁμοκλήσας, εἶξαί τέ οἱ ἡνία χερσίν.{l]
[l [n}23.338{]}ἐν νύσσῃ δέ τοι ἵππος ἀριστερὸς ἐγχριμφθήτω,{l]
[l [n}23.339{]}ὡς ἄν τοι πλήμνη γε δοάσσεται ἄκρον ἱκέσθαι{l]
[l [n}23.340{]}κύκλου ποιητοῖο· λίθου δʼ ἀλέασθαι ἐπαυρεῖν,{l]
[l [n}23.341{]}μή πως ἵππους τε τρώσῃς κατά θʼ ἅρματα ἄξῃς·{l]
[l [n}23.342{]}χάρμα δὲ τοῖς ἄλλοισιν, ἐλεγχείη δὲ σοὶ αὐτῷ{l]
[l [n}23.343{]}ἔσσεται· ἀλλὰ φίλος φρονέων πεφυλαγμένος εἶναι.{l]
[l [n}23.344{]}εἰ γάρ κʼ ἐν νύσσῃ γε παρεξελάσῃσθα διώκων,{l]
[l [n}23.345{]}οὐκ ἔσθʼ ὅς κέ σʼ ἕλῃσι μετάλμενος οὐδὲ παρέλθῃ,{l]
[l [n}23.346{]}οὐδʼ εἴ κεν μετόπισθεν Ἀρίονα δῖον ἐλαύνοι{l]
[l [n}23.347{]}Ἀδρήστου ταχὺν ἵππον, ὃς ἐκ θεόφιν γένος ἦεν,{l]
[l [n}23.348{]}ἢ τοὺς Λαομέδοντος, οἳ ἐνθάδε γʼ ἔτραφεν ἐσθλοί.{l]{q]{para]
[para}[l [n}23.349{]}ὣς εἰπὼν Νέστωρ Νηλήϊος ἂψ ἐνὶ χώρῃ{l]
[l [n}23.350{]}ἕζετʼ, ἐπεὶ ᾧ παιδὶ ἑκάστου πείρατʼ ἔειπε.{l]{para]
[para}[l [n}23.351{]}Μηριόνης δʼ ἄρα πέμπτος ἐΰτριχας ὁπλίσαθʼ ἵππους.{l]
[l [n}23.352{]}ἂν δʼ ἔβαν ἐς δίφρους, ἐν δὲ κλήρους ἐβάλοντο·{l]
[l [n}23.353{]}πάλλʼ Ἀχιλεύς, ἐκ δὲ κλῆρος θόρε Νεστορίδαο{l]
[l [n}23.354{]}Ἀντιλόχου· μετὰ τὸν δʼ ἔλαχε κρείων Εὔμηλος·{l]
[l [n}23.355{]}τῷ δʼ ἄρʼ ἐπʼ Ἀτρεΐδης δουρὶ κλειτὸς Μενέλαος,{l]
[l [n}23.356{]}τῷ δʼ ἐπὶ Μηριόνης λάχʼ ἐλαυνέμεν· ὕστατος αὖτε{l]
[l [n}23.357{]}Τυδεΐδης ὄχʼ ἄριστος ἐὼν λάχʼ ἐλαυνέμεν ἵππους.{l]
[l [n}23.358{]}στὰν δὲ μεταστοιχί, σήμηνε δὲ τέρματʼ Ἀχιλλεὺς{l]
[l [n}23.359{]}τηλόθεν ἐν λείῳ πεδίῳ· παρὰ δὲ σκοπὸν εἷσεν{l]
[l [n}23.360{]}ἀντίθεον Φοίνικα ὀπάονα πατρὸς ἑοῖο,{l]
[l [n}23.361{]}ὡς μεμνέῳτο δρόμους καὶ ἀληθείην ἀποείποι.{l]{para]
[para}[l [n}23.362{]}οἳ δʼ ἅμα πάντες ἐφʼ ἵπποιιν μάστιγας ἄειραν,{l]
[l [n}23.363{]}πέπληγόν θʼ ἱμᾶσιν, ὁμόκλησάν τʼ ἐπέεσσιν{l]
[l [n}23.364{]}ἐσσυμένως· οἳ δʼ ὦκα διέπρησσον πεδίοιο{l]
[l [n}23.365{]}νόσφι νεῶν ταχέως· ὑπὸ δὲ στέρνοισι κονίη{l]
[l [n}23.366{]}ἵστατʼ ἀειρομένη ὥς τε νέφος ἠὲ θύελλα,{l]
[l [n}23.367{]}χαῖται δʼ ἐρρώοντο μετὰ πνοιῇς ἀνέμοιο.{l]
[l [n}23.368{]}ἅρματα δʼ ἄλλοτε μὲν χθονὶ πίλνατο πουλυβοτείρῃ,{l]
[l [n}23.369{]}ἄλλοτε δʼ ἀΐξασκε μετήορα· τοὶ δʼ ἐλατῆρες{l]
[l [n}23.370{]}ἕστασαν ἐν δίφροισι, πάτασσε δὲ θυμὸς ἑκάστου{l]
[l [n}23.371{]}νίκης ἱεμένων· κέκλοντο δὲ οἷσιν ἕκαστος{l]
[l [n}23.372{]}ἵπποις, οἳ δʼ ἐπέτοντο κονίοντες πεδίοιο.{l]{para]
[para}[l [n}23.373{]}ἀλλʼ ὅτε δὴ πύματον τέλεον δρόμον ὠκέες ἵπποι{l]
[l [n}23.374{]}ἂψ ἐφʼ ἁλὸς πολιῆς, τότε δὴ ἀρετή γε ἑκάστου{l]
[l [n}23.375{]}φαίνετʼ, ἄφαρ δʼ ἵπποισι τάθη δρόμος· ὦκα δʼ ἔπειτα{l]
[l [n}23.376{]}αἳ Φηρητιάδαο ποδώκεες ἔκφερον ἵπποι.{l]
[l [n}23.377{]}τὰς δὲ μετʼ ἐξέφερον Διομήδεος ἄρσενες ἵπποι{l]
[l [n}23.378{]}Τρώϊοι, οὐδέ τι πολλὸν ἄνευθʼ ἔσαν, ἀλλὰ μάλʼ ἐγγύς·{l]
[l [n}23.379{]}αἰεὶ γὰρ δίφρου ἐπιβησομένοισιν ἐΐκτην,{l]
[l [n}23.380{]}πνοιῇ δʼ Εὐμήλοιο μετάφρενον εὐρέε τʼ ὤμω{l]
[l [n}23.381{]}θέρμετʼ· ἐπʼ αὐτῷ γὰρ κεφαλὰς καταθέντε πετέσθην.{l]
[l [n}23.382{]}καί νύ κεν ἢ παρέλασσʼ ἢ ἀμφήριστον ἔθηκεν,{l]
[l [n}23.383{]}εἰ μὴ Τυδέος υἷϊ κοτέσσατο Φοῖβος Ἀπόλλων,{l]
[l [n}23.384{]}ὅς ῥά οἱ ἐκ χειρῶν ἔβαλεν μάστιγα φαεινήν.{l]
[l [n}23.385{]}τοῖο δʼ ἀπʼ ὀφθαλμῶν χύτο δάκρυα χωομένοιο,{l]
[l [n}23.386{]}οὕνεκα τὰς μὲν ὅρα ἔτι καὶ πολὺ μᾶλλον ἰούσας,{l]
[l [n}23.387{]}οἳ δέ οἱ ἐβλάφθησαν ἄνευ κέντροιο θέοντες.{l]
[l [n}23.388{]}οὐδʼ ἄρʼ Ἀθηναίην ἐλεφηράμενος λάθʼ Ἀπόλλων{l]
[l [n}23.389{]}Τυδεΐδην, μάλα δʼ ὦκα μετέσσυτο ποιμένα λαῶν,{l]
[l [n}23.390{]}δῶκε δέ οἱ μάστιγα, μένος δʼ ἵπποισιν ἐνῆκεν·{l]
[l [n}23.391{]}ἣ δὲ μετʼ Ἀδμήτου υἱὸν κοτέουσʼ ἐβεβήκει,{l]
[l [n}23.392{]}ἵππειον δέ οἱ ἦξε θεὰ ζυγόν· αἳ δέ οἱ ἵπποι{l]
[l [n}23.393{]}ἀμφὶς ὁδοῦ δραμέτην, ῥυμὸς δʼ ἐπὶ γαῖαν ἐλύσθη.{l]
[l [n}23.394{]}αὐτὸς δʼ ἐκ δίφροιο παρὰ τροχὸν ἐξεκυλίσθη,{l]
[l [n}23.395{]}ἀγκῶνάς τε περιδρύφθη στόμα τε ῥῖνάς τε,{l]
[l [n}23.396{]}θρυλίχθη δὲ μέτωπον ἐπʼ ὀφρύσι· τὼ δέ οἱ ὄσσε{l]
[l [n}23.397{]}δακρυόφι πλῆσθεν, θαλερὴ δέ οἱ ἔσχετο φωνή.{l]
[l [n}23.398{]}Τυδεΐδης δὲ παρατρέψας ἔχε μώνυχας ἵππους,{l]
[l [n}23.399{]}πολλὸν τῶν ἄλλων ἐξάλμενος· ἐν γὰρ Ἀθήνη{l]
[l [n}23.400{]}ἵπποις ἧκε μένος καὶ ἐπʼ αὐτῷ κῦδος ἔθηκε.{l]
[l [n}23.401{]}τῷ δʼ ἄρʼ ἐπʼ Ἀτρεΐδης εἶχε ξανθὸς Μενέλαος.{l]
[l [n}23.402{]}Ἀντίλοχος δʼ ἵπποισιν ἐκέκλετο πατρὸς ἑοῖο·{l]
[q}[l [n}23.403{]}ἔμβητον καὶ σφῶϊ· τιταίνετον ὅττι τάχιστα.{l]
[l [n}23.404{]}ἤτοι μὲν κείνοισιν ἐριζέμεν οὔ τι κελεύω{l]
[l [n}23.405{]}Τυδεΐδεω ἵπποισι δαΐφρονος, οἷσιν Ἀθήνη{l]
[l [n}23.406{]}νῦν ὤρεξε τάχος καὶ ἐπʼ αὐτῷ κῦδος ἔθηκεν·{l]
[l [n}23.407{]}ἵππους δʼ Ἀτρεΐδαο κιχάνετε, μὴ δὲ λίπησθον,{l]
[l [n}23.408{]}καρπαλίμως, μὴ σφῶϊν ἐλεγχείην καταχεύῃ{l]
[l [n}23.409{]}Αἴθη θῆλυς ἐοῦσα· τί ἢ λείπεσθε φέριστοι;{l]
[l [n}23.410{]}ὧδε γὰρ ἐξερέω, καὶ μὴν τετελεσμένον ἔσται·{l]
[l [n}23.411{]}οὐ σφῶϊν κομιδὴ παρὰ Νέστορι ποιμένι λαῶν{l]
[l [n}23.412{]}ἔσσεται, αὐτίκα δʼ ὔμμε κατακτενεῖ ὀξέϊ χαλκῷ,{l]
[l [n}23.413{]}αἴ κʼ ἀποκηδήσαντε φερώμεθα χεῖρον ἄεθλον.{l]
[l [n}23.414{]}ἀλλʼ ἐφομαρτεῖτον καὶ σπεύδετον ὅττι τάχιστα·{l]
[l [n}23.415{]}ταῦτα δʼ ἐγὼν αὐτὸς τεχνήσομαι ἠδὲ νοήσω{l]
[l [n}23.416{]}στεινωπῷ ἐν ὁδῷ παραδύμεναι, οὐδέ με λήσει.{l]{q]{para]
[para}[l [n}23.417{]}ὣς ἔφαθʼ, οἳ δὲ ἄνακτος ὑποδείσαντες ὁμοκλὴν{l]
[l [n}23.418{]}μᾶλλον ἐπιδραμέτην ὀλίγον χρόνον· αἶψα δʼ ἔπειτα{l]
[l [n}23.419{]}στεῖνος ὁδοῦ κοίλης ἴδεν Ἀντίλοχος μενεχάρμης.{l]
[l [n}23.420{]}ῥωχμὸς ἔην γαίης, ᾗ χειμέριον ἀλὲν ὕδωρ{l]
[l [n}23.421{]}ἐξέρρηξεν ὁδοῖο, βάθυνε δὲ χῶρον ἅπαντα·{l]
[l [n}23.422{]}τῇ ῥʼ εἶχεν Μενέλαος ἁματροχιὰς ἀλεείνων.{l]
[l [n}23.423{]}Ἀντίλοχος δὲ παρατρέψας ἔχε μώνυχας ἵππους{l]
[l [n}23.424{]}ἐκτὸς ὁδοῦ, ὀλίγον δὲ παρακλίνας ἐδίωκεν.{l]
[l [n}23.425{]}Ἀτρεΐδης δʼ ἔδεισε καὶ Ἀντιλόχῳ ἐγεγώνει·{l]
[q}[l [n}23.426{]}Ἀντίλοχʼ ἀφραδέως ἱππάζεαι, ἀλλʼ ἄνεχʼ ἵππους·{l]
[l [n}23.427{]}στεινωπὸς γὰρ ὁδός, τάχα δʼ εὐρυτέρη παρελάσσαι·{l]
[l [n}23.428{]}μή πως ἀμφοτέρους δηλήσεαι ἅρματι κύρσας.{l]{q]{para]
[para}[l [n}23.429{]}ὣς ἔφατʼ, Ἀντίλοχος δʼ ἔτι καὶ πολὺ μᾶλλον ἔλαυνε{l]
[l [n}23.430{]}κέντρῳ ἐπισπέρχων ὡς οὐκ ἀΐοντι ἐοικώς.{l]
[l [n}23.431{]}ὅσσα δὲ δίσκου οὖρα κατωμαδίοιο πέλονται,{l]
[l [n}23.432{]}ὅν τʼ αἰζηὸς ἀφῆκεν ἀνὴρ πειρώμενος ἥβης,{l]
[l [n}23.433{]}τόσσον ἐπιδραμέτην· αἳ δʼ ἠρώησαν ὀπίσσω{l]
[l [n}23.434{]}Ἀτρεΐδεω· αὐτὸς γὰρ ἑκὼν μεθέηκεν ἐλαύνειν{l]
[l [n}23.435{]}μή πως συγκύρσειαν ὁδῷ ἔνι μώνυχες ἵπποι,{l]
[l [n}23.436{]}δίφρους τʼ ἀνστρέψειαν ἐϋπλεκέας, κατὰ δʼ αὐτοὶ{l]
[l [n}23.437{]}ἐν κονίῃσι πέσοιεν ἐπειγόμενοι περὶ νίκης.{l]
[l [n}23.438{]}τὸν καὶ νεικείων προσέφη ξανθὸς Μενέλαος·{l]
[q}[l [n}23.439{]}Ἀντίλοχʼ οὔ τις σεῖο βροτῶν ὀλοώτερος ἄλλος·{l]
[l [n}23.440{]}ἔρρʼ, ἐπεὶ οὔ σʼ ἔτυμόν γε φάμεν πεπνῦσθαι Ἀχαιοί.{l]
[l [n}23.441{]}ἀλλʼ οὐ μὰν οὐδʼ ὧς ἄτερ ὅρκου οἴσῃ ἄεθλον.{l]{q]{para]
[para}[l [n}23.442{]}ὣς εἰπὼν ἵπποισιν ἐκέκλετο φώνησέν τε·{l]
[q}[l [n}23.443{]}μή μοι ἐρύκεσθον μὴ δʼ ἕστατον ἀχνυμένω κῆρ.{l]
[l [n}23.444{]}φθήσονται τούτοισι πόδες καὶ γοῦνα καμόντα{l]
[l [n}23.445{]}ἢ ὑμῖν· ἄμφω γὰρ ἀτέμβονται νεότητος.{l]{q]{para]
[para}[l [n}23.446{]}ὣς ἔφαθʼ, οἳ δὲ ἄνακτος ὑποδείσαντες ὁμοκλὴν{l]
[l [n}23.447{]}μᾶλλον ἐπιδραμέτην, τάχα δέ σφισιν ἄγχι γένοντο.{l]{para]
[para}[l [n}23.448{]}Ἀργεῖοι δʼ ἐν ἀγῶνι καθήμενοι εἰσορόωντο{l]
[l [n}23.449{]}ἵππους· τοὶ δὲ πέτοντο κονίοντες πεδίοιο.{l]
[l [n}23.450{]}πρῶτος δʼ Ἰδομενεὺς Κρητῶν ἀγὸς ἐφράσαθʼ ἵππους·{l]
[l [n}23.451{]}ἧστο γὰρ ἐκτὸς ἀγῶνος ὑπέρτατος ἐν περιωπῇ·{l]
[l [n}23.452{]}τοῖο δʼ ἄνευθεν ἐόντος ὁμοκλητῆρος ἀκούσας{l]
[l [n}23.453{]}ἔγνω, φράσσατο δʼ ἵππον ἀριπρεπέα προὔχοντα,{l]
[l [n}23.454{]}ὃς τὸ μὲν ἄλλο τόσον φοῖνιξ ἦν, ἐν δὲ μετώπῳ{l]
[l [n}23.455{]}λευκὸν σῆμα τέτυκτο περίτροχον ἠΰτε μήνη.{l]
[l [n}23.456{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.457{]}ὦ φίλοι Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}23.458{]}οἶος ἐγὼν ἵππους αὐγάζομαι ἦε καὶ ὑμεῖς;{l]
[l [n}23.459{]}ἄλλοι μοι δοκέουσι παροίτεροι ἔμμεναι ἵπποι,{l]
[l [n}23.460{]}ἄλλος δʼ ἡνίοχος ἰνδάλλεται· αἳ δέ που αὐτοῦ{l]
[l [n}23.461{]}ἔβλαβεν ἐν πεδίῳ, αἳ κεῖσέ γε φέρτεραι ἦσαν·{l]
[l [n}23.462{]}ἤτοι γὰρ τὰς πρῶτα ἴδον περὶ τέρμα βαλούσας,{l]
[l [n}23.463{]}νῦν δʼ οὔ πῃ δύναμαι ἰδέειν· πάντῃ δέ μοι ὄσσε{l]
[l [n}23.464{]}Τρωϊκὸν ἂμ πεδίον παπταίνετον εἰσορόωντι·{l]
[l [n}23.465{]}ἦε τὸν ἡνίοχον φύγον ἡνία, οὐδὲ δυνάσθη{l]
[l [n}23.466{]}εὖ σχεθέειν περὶ τέρμα καὶ οὐκ ἐτύχησεν ἑλίξας·{l]
[l [n}23.467{]}ἔνθά μιν ἐκπεσέειν ὀΐω σύν θʼ ἅρματα ἆξαι,{l]
[l [n}23.468{]}αἳ δʼ ἐξηρώησαν, ἐπεὶ μένος ἔλλαβε θυμόν.{l]
[l [n}23.469{]}ἀλλὰ ἴδεσθε καὶ ὔμμες ἀνασταδόν· οὐ γὰρ ἔγωγε{l]
[l [n}23.470{]}εὖ διαγιγνώσκω· δοκέει δέ μοι ἔμμεναι ἀνὴρ{l]
[l [n}23.471{]}Αἰτωλὸς γενεήν, μετὰ δʼ Ἀργείοισιν ἀνάσσει{l]
[l [n}23.472{]}Τυδέος ἱπποδάμου υἱὸς κρατερὸς Διομήδης.{l]{q]{para]
[para}[l [n}23.473{]}τὸν δʼ αἰσχρῶς ἐνένιπεν Ὀϊλῆος ταχὺς Αἴας·{l]
[q}[l [n}23.474{]}Ἰδομενεῦ τί πάρος λαβρεύεαι; αἳ δέ τʼ ἄνευθεν{l]
[l [n}23.475{]}ἵπποι ἀερσίποδες πολέος πεδίοιο δίενται.{l]
[l [n}23.476{]}οὔτε νεώτατός ἐσσι μετʼ Ἀργείοισι τοσοῦτον,{l]
[l [n}23.477{]}οὔτέ τοι ὀξύτατον κεφαλῆς ἐκδέρκεται ὄσσε·{l]
[l [n}23.478{]}ἀλλʼ αἰεὶ μύθοις λαβρεύεαι· οὐδέ τί σε χρὴ{l]
[l [n}23.479{]}λαβραγόρην ἔμεναι· πάρα γὰρ καὶ ἀμείνονες ἄλλοι.{l]
[l [n}23.480{]}ἵπποι δʼ αὐταὶ ἔασι παροίτεραι, αἳ τὸ πάρος περ,{l]
[l [n}23.481{]}Εὐμήλου, ἐν δʼ αὐτὸς ἔχων εὔληρα βέβηκε.{l]{q]{para]
[para}[l [n}23.482{]}τὸν δὲ χολωσάμενος Κρητῶν ἀγὸς ἀντίον ηὔδα·{l]
[q}[l [n}23.483{]}Αἶαν νεῖκος ἄριστε κακοφραδὲς ἄλλά τε πάντα{l]
[l [n}23.484{]}δεύεαι Ἀργείων, ὅτι τοι νόος ἐστὶν ἀπηνής.{l]
[l [n}23.485{]}δεῦρό νυν ἢ τρίποδος περιδώμεθον ἠὲ λέβητος,{l]
[l [n}23.486{]}ἴστορα δʼ Ἀτρεΐδην Ἀγαμέμνονα θείομεν ἄμφω,{l]
[l [n}23.487{]}ὁππότεραι πρόσθʼ ἵπποι, ἵνα γνώῃς ἀποτίνων.{l]{q]{para]
[para}[l [n}23.488{]}ὣς ἔφατʼ, ὄρνυτο δʼ αὐτίκʼ Ὀϊλῆος ταχὺς Αἴας{l]
[l [n}23.489{]}χωόμενος χαλεποῖσιν ἀμείψασθαι ἐπέεσσι·{l]
[l [n}23.490{]}καί νύ κε δὴ προτέρω ἔτʼ ἔρις γένετʼ ἀμφοτέροισιν,{l]
[l [n}23.491{]}εἰ μὴ Ἀχιλλεὺς αὐτὸς ἀνίστατο καὶ φάτο μῦθον·{l]
[q}[l [n}23.492{]}μηκέτι νῦν χαλεποῖσιν ἀμείβεσθον ἐπέεσσιν{l]
[l [n}23.493{]}Αἶαν Ἰδομενεῦ τε κακοῖς, ἐπεὶ οὐδὲ ἔοικε.{l]
[l [n}23.494{]}καὶ δʼ ἄλλῳ νεμεσᾶτον ὅτις τοιαῦτά γε ῥέζοι.{l]
[l [n}23.495{]}ἀλλʼ ὑμεῖς ἐν ἀγῶνι καθήμενοι εἰσοράασθε{l]
[l [n}23.496{]}ἵππους· οἳ δὲ τάχʼ αὐτοὶ ἐπειγόμενοι περὶ νίκης{l]
[l [n}23.497{]}ἐνθάδʼ ἐλεύσονται· τότε δὲ γνώσεσθε ἕκαστος{l]
[l [n}23.498{]}ἵππους Ἀργείων, οἳ δεύτεροι οἵ τε πάροιθεν.{l]{q]{para]
[para}[l [n}23.499{]}ὣς φάτο, Τυδεΐδης δὲ μάλα σχεδὸν ἦλθε διώκων,{l]
[l [n}23.500{]}μάστι δʼ αἰὲν ἔλαυνε κατωμαδόν· οἳ δέ οἱ ἵπποι{l]
[l [n}23.501{]}ὑψόσʼ ἀειρέσθην ῥίμφα πρήσσοντε κέλευθον.{l]
[l [n}23.502{]}αἰεὶ δʼ ἡνίοχον κονίης ῥαθάμιγγες ἔβαλλον,{l]
[l [n}23.503{]}ἅρματα δὲ χρυσῷ πεπυκασμένα κασσιτέρῳ τε{l]
[l [n}23.504{]}ἵπποις ὠκυπόδεσσιν ἐπέτρεχον· οὐδέ τι πολλὴ{l]
[l [n}23.505{]}γίγνετʼ ἐπισσώτρων ἁρματροχιὴ κατόπισθεν{l]
[l [n}23.506{]}ἐν λεπτῇ κονίῃ· τὼ δὲ σπεύδοντε πετέσθην.{l]
[l [n}23.507{]}στῆ δὲ μέσῳ ἐν ἀγῶνι, πολὺς δʼ ἀνεκήκιεν ἱδρὼς{l]
[l [n}23.508{]}ἵππων ἔκ τε λόφων καὶ ἀπὸ στέρνοιο χαμᾶζε.{l]
[l [n}23.509{]}αὐτὸς δʼ ἐκ δίφροιο χαμαὶ θόρε παμφανόωντος,{l]
[l [n}23.510{]}κλῖνε δʼ ἄρα μάστιγα ποτὶ ζυγόν· οὐδὲ μάτησεν{l]
[l [n}23.511{]}ἴφθιμος Σθένελος, ἀλλʼ ἐσσυμένως λάβʼ ἄεθλον,{l]
[l [n}23.512{]}δῶκε δʼ ἄγειν ἑτάροισιν ὑπερθύμοισι γυναῖκα{l]
[l [n}23.513{]}καὶ τρίποδʼ ὠτώεντα φέρειν· ὃ δʼ ἔλυεν ὑφʼ ἵππους.{l]{para]
[para}[l [n}23.514{]}τῷ δʼ ἄρʼ ἐπʼ Ἀντίλοχος Νηλήϊος ἤλασεν ἵππους{l]
[l [n}23.515{]}κέρδεσιν, οὔ τι τάχει γε, παραφθάμενος Μενέλαον·{l]
[l [n}23.516{]}ἀλλὰ καὶ ὧς Μενέλαος ἔχʼ ἐγγύθεν ὠκέας ἵππους.{l]
[l [n}23.517{]}ὅσσον δὲ τροχοῦ ἵππος ἀφίσταται, ὅς ῥα ἄνακτα{l]
[l [n}23.518{]}ἕλκῃσιν πεδίοιο τιταινόμενος σὺν ὄχεσφι·{l]
[l [n}23.519{]}τοῦ μέν τε ψαύουσιν ἐπισσώτρου τρίχες ἄκραι{l]
[l [n}23.520{]}οὐραῖαι· ὃ δέ τʼ ἄγχι μάλα τρέχει, οὐδέ τι πολλὴ{l]
[l [n}23.521{]}χώρη μεσσηγὺς πολέος πεδίοιο θέοντος·{l]
[l [n}23.522{]}τόσσον δὴ Μενέλαος ἀμύμονος Ἀντιλόχοιο{l]
[l [n}23.523{]}λείπετʼ· ἀτὰρ τὰ πρῶτα καὶ ἐς δίσκουρα λέλειπτο,{l]
[l [n}23.524{]}ἀλλά μιν αἶψα κίχανεν· ὀφέλλετο γὰρ μένος ἠῢ{l]
[l [n}23.525{]}ἵππου τῆς Ἀγαμεμνονέης καλλίτριχος Αἴθης·{l]
[l [n}23.526{]}εἰ δέ κʼ ἔτι προτέρω γένετο δρόμος ἀμφοτέροισι,{l]
[l [n}23.527{]}τώ κέν μιν παρέλασσʼ οὐδʼ ἀμφήριστον ἔθηκεν.{l]
[l [n}23.528{]}αὐτὰρ Μηριόνης θεράπων ἐῢς Ἰδομενῆος{l]
[l [n}23.529{]}λείπετʼ ἀγακλῆος Μενελάου δουρὸς ἐρωήν·{l]
[l [n}23.530{]}βάρδιστοι μὲν γάρ οἱ ἔσαν καλλίτριχες ἵπποι,{l]
[l [n}23.531{]}ἤκιστος δʼ ἦν αὐτὸς ἐλαυνέμεν ἅρμʼ ἐν ἀγῶνι.{l]
[l [n}23.532{]}υἱὸς δʼ Ἀδμήτοιο πανύστατος ἤλυθεν ἄλλων{l]
[l [n}23.533{]}ἕλκων ἅρματα καλὰ ἐλαύνων πρόσσοθεν ἵππους.{l]
[l [n}23.534{]}τὸν δὲ ἰδὼν ᾤκτειρε ποδάρκης δῖος Ἀχιλλεύς,{l]
[l [n}23.535{]}στὰς δʼ ἄρʼ ἐν Ἀργείοις ἔπεα πτερόεντʼ ἀγόρευε·{l]
[q}[l [n}23.536{]}λοῖσθος ἀνὴρ ὤριστος ἐλαύνει μώνυχας ἵππους·{l]
[l [n}23.537{]}ἀλλʼ ἄγε δή οἱ δῶμεν ἀέθλιον ὡς ἐπιεικὲς{l]
[l [n}23.538{]}δεύτερʼ· ἀτὰρ τὰ πρῶτα φερέσθω Τυδέος υἱός.{l]{q]{para]
[para}[l [n}23.539{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπῄνεον ὡς ἐκέλευε.{l]
[l [n}23.540{]}καί νύ κέ οἱ πόρεν ἵππον, ἐπῄνησαν γὰρ Ἀχαιοί,{l]
[l [n}23.541{]}εἰ μὴ ἄρʼ Ἀντίλοχος μεγαθύμου Νέστορος υἱὸς{l]
[l [n}23.542{]}Πηλεΐδην Ἀχιλῆα δίκῃ ἠμείψατʼ ἀναστάς·{l]
[q}[l [n}23.543{]}ὦ Ἀχιλεῦ μάλα τοι κεχολώσομαι αἴ κε τελέσσῃς{l]
[l [n}23.544{]}τοῦτο ἔπος· μέλλεις γὰρ ἀφαιρήσεσθαι ἄεθλον{l]
[l [n}23.545{]}τὰ φρονέων ὅτι οἱ βλάβεν ἅρματα καὶ ταχέʼ ἵππω{l]
[l [n}23.546{]}αὐτός τʼ ἐσθλὸς ἐών· ἀλλʼ ὤφελεν ἀθανάτοισιν{l]
[l [n}23.547{]}εὔχεσθαι· τό κεν οὔ τι πανύστατος ἦλθε διώκων.{l]
[l [n}23.548{]}εἰ δέ μιν οἰκτίρεις καί τοι φίλος ἔπλετο θυμῷ{l]
[l [n}23.549{]}ἔστί τοι ἐν κλισίῃ χρυσὸς πολύς, ἔστι δὲ χαλκὸς{l]
[l [n}23.550{]}καὶ πρόβατʼ, εἰσὶ δέ τοι δμῳαὶ καὶ μώνυχες ἵπποι·{l]
[l [n}23.551{]}τῶν οἱ ἔπειτʼ ἀνελὼν δόμεναι καὶ μεῖζον ἄεθλον{l]
[l [n}23.552{]}ἠὲ καὶ αὐτίκα νῦν, ἵνα σʼ αἰνήσωσιν Ἀχαιοί.{l]
[l [n}23.553{]}τὴν δʼ ἐγὼ οὐ δώσω· περὶ δʼ αὐτῆς πειρηθήτω{l]
[l [n}23.554{]}ἀνδρῶν ὅς κʼ ἐθέλῃσιν ἐμοὶ χείρεσσι μάχεσθαι.{l]{q]{para]
[para}[l [n}23.555{]}ὣς φάτο, μείδησεν δὲ ποδάρκης δῖος Ἀχιλλεὺς{l]
[l [n}23.556{]}χαίρων Ἀντιλόχῳ, ὅτι οἱ φίλος ἦεν ἑταῖρος·{l]
[l [n}23.557{]}καί μιν ἀμειβόμενος ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}23.558{]}Ἀντίλοχʼ, εἰ μὲν δή με κελεύεις οἴκοθεν ἄλλο{l]
[l [n}23.559{]}Εὐμήλῳ ἐπιδοῦναι, ἐγὼ δέ κε καὶ τὸ τελέσσω.{l]
[l [n}23.560{]}δώσω οἱ θώρηκα, τὸν Ἀστεροπαῖον ἀπηύρων{l]
[l [n}23.561{]}χάλκεον, ᾧ πέρι χεῦμα φαεινοῦ κασσιτέροιο{l]
[l [n}23.562{]}ἀμφιδεδίνηται· πολέος δέ οἱ ἄξιος ἔσται.{l]{q]{para]
[para}[l [n}23.563{]}ἦ ῥα, καὶ Αὐτομέδοντι φίλῳ ἐκέλευσεν ἑταίρῳ{l]
[l [n}23.564{]}οἰσέμεναι κλισίηθεν· ὃ δʼ ᾤχετο καί οἱ ἔνεικεν,{l]
[l [n}23.565{]}Εὐμήλῳ δʼ ἐν χερσὶ τίθει· ὃ δὲ δέξατο χαίρων.{l]{para]
[para}[l [n}23.566{]}τοῖσι δὲ καὶ Μενέλαος ἀνίστατο θυμὸν ἀχεύων{l]
[l [n}23.567{]}Ἀντιλόχῳ ἄμοτον κεχολωμένος· ἐν δʼ ἄρα κῆρυξ{l]
[l [n}23.568{]}χειρὶ σκῆπτρον ἔθηκε, σιωπῆσαί τε κέλευσεν{l]
[l [n}23.569{]}Ἀργείους· ὃ δʼ ἔπειτα μετηύδα ἰσόθεος φώς·{l]
[q}[l [n}23.570{]}Ἀντίλοχε πρόσθεν πεπνυμένε ποῖον ἔρεξας.{l]
[l [n}23.571{]}ᾔσχυνας μὲν ἐμὴν ἀρετήν, βλάψας δέ μοι ἵππους{l]
[l [n}23.572{]}τοὺς σοὺς πρόσθε βαλών, οἵ τοι πολὺ χείρονες ἦσαν.{l]
[l [n}23.573{]}ἀλλʼ ἄγετʼ Ἀργείων ἡγήτορες ἠδὲ μέδοντες{l]
[l [n}23.574{]}ἐς μέσον ἀμφοτέροισι δικάσσατε, μὴ δʼ ἐπʼ ἀρωγῇ,{l]
[l [n}23.575{]}μή ποτέ τις εἴπῃσιν Ἀχαιῶν χαλκοχιτώνων·{l]
[q}[l [n}23.576{]}Ἀντίλοχον ψεύδεσσι βιησάμενος Μενέλαος{l]
[l [n}23.577{]}οἴχεται ἵππον ἄγων, ὅτι οἱ πολὺ χείρονες ἦσαν{l]
[l [n}23.578{]}ἵπποι, αὐτὸς δὲ κρείσσων ἀρετῇ τε βίῃ τε.{l]{q][l [n}23.579{]}εἰ δʼ ἄγʼ ἐγὼν αὐτὸς δικάσω, καί μʼ οὔ τινά φημι{l]
[l [n}23.580{]}ἄλλον ἐπιπλήξειν Δαναῶν· ἰθεῖα γὰρ ἔσται.{l]
[l [n}23.581{]}Ἀντίλοχʼ εἰ δʼ ἄγε δεῦρο διοτρεφές, ἣ θέμις ἐστί,{l]
[l [n}23.582{]}στὰς ἵππων προπάροιθε καὶ ἅρματος, αὐτὰρ ἱμάσθλην{l]
[l [n}23.583{]}χερσὶν ἔχε ῥαδινήν, ᾗ περ τὸ πρόσθεν ἔλαυνες,{l]
[l [n}23.584{]}ἵππων ἁψάμενος γαιήοχον ἐννοσίγαιον{l]
[l [n}23.585{]}ὄμνυθι μὴ μὲν ἑκὼν τὸ ἐμὸν δόλῳ ἅρμα πεδῆσαι.{l]{q]{para]
[para}[l [n}23.586{]}τὸν δʼ αὖτʼ Ἀντίλοχος πεπνυμένος ἀντίον ηὔδα·{l]
[q}[l [n}23.587{]}ἄνσχεο νῦν· πολλὸν γὰρ ἔγωγε νεώτερός εἰμι{l]
[l [n}23.588{]}σεῖο ἄναξ Μενέλαε, σὺ δὲ πρότερος καὶ ἀρείων.{l]
[l [n}23.589{]}οἶσθʼ οἷαι νέου ἀνδρὸς ὑπερβασίαι τελέθουσι·{l]
[l [n}23.590{]}κραιπνότερος μὲν γάρ τε νόος, λεπτὴ δέ τε μῆτις.{l]
[l [n}23.591{]}τώ τοι ἐπιτλήτω κραδίη· ἵππον δέ τοι αὐτὸς{l]
[l [n}23.592{]}δώσω, τὴν ἀρόμην. εἰ καί νύ κεν οἴκοθεν ἄλλο{l]
[l [n}23.593{]}μεῖζον ἐπαιτήσειας, ἄφαρ κέ τοι αὐτίκα δοῦναι{l]
[l [n}23.594{]}βουλοίμην ἢ σοί γε διοτρεφὲς ἤματα πάντα{l]
[l [n}23.595{]}ἐκ θυμοῦ πεσέειν καὶ δαίμοσιν εἶναι ἀλιτρός.{l]{q]{para]
[para}[l [n}23.596{]}ἦ ῥα καὶ ἵππον ἄγων μεγαθύμου Νέστορος υἱὸς{l]
[l [n}23.597{]}ἐν χείρεσσι τίθει Μενελάου· τοῖο δὲ θυμὸς{l]
[l [n}23.598{]}ἰάνθη ὡς εἴ τε περὶ σταχύεσσιν ἐέρση{l]
[l [n}23.599{]}ληΐου ἀλδήσκοντος, ὅτε φρίσσουσιν ἄρουραι·{l]
[l [n}23.600{]}ὣς ἄρα σοὶ Μενέλαε μετὰ φρεσὶ θυμὸς ἰάνθη.{l]
[l [n}23.601{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}23.602{]}Ἀντίλοχε νῦν μέν τοι ἐγὼν ὑποείξομαι αὐτὸς{l]
[l [n}23.603{]}χωόμενος, ἐπεὶ οὔ τι παρήορος οὐδʼ ἀεσίφρων{l]
[l [n}23.604{]}ἦσθα πάρος· νῦν αὖτε νόον νίκησε νεοίη.{l]
[l [n}23.605{]}δεύτερον αὖτʼ ἀλέασθαι ἀμείνονας ἠπεροπεύειν.{l]
[l [n}23.606{]}οὐ γάρ κέν με τάχʼ ἄλλος ἀνὴρ παρέπεισεν Ἀχαιῶν.{l]
[l [n}23.607{]}ἀλλὰ σὺ γὰρ δὴ πολλὰ πάθες καὶ πολλὰ μόγησας{l]
[l [n}23.608{]}σός τε πατὴρ ἀγαθὸς καὶ ἀδελφεὸς εἵνεκʼ ἐμεῖο·{l]
[l [n}23.609{]}τώ τοι λισσομένῳ ἐπιπείσομαι, ἠδὲ καὶ ἵππον{l]
[l [n}23.610{]}δώσω ἐμήν περ ἐοῦσαν, ἵνα γνώωσι καὶ οἵδε{l]
[l [n}23.611{]}ὡς ἐμὸς οὔ ποτε θυμὸς ὑπερφίαλος καὶ ἀπηνής.{l]{q]{para]
[para}[l [n}23.612{]}ἦ ῥα, καὶ Ἀντιλόχοιο Νοήμονι δῶκεν ἑταίρῳ{l]
[l [n}23.613{]}ἵππον ἄγειν· ὃ δʼ ἔπειτα λέβηθʼ ἕλε παμφανόωντα.{l]
[l [n}23.614{]}Μηριόνης δʼ ἀνάειρε δύω χρυσοῖο τάλαντα{l]
[l [n}23.615{]}τέτρατος, ὡς ἔλασεν. πέμπτον δʼ ὑπελείπετʼ ἄεθλον,{l]
[l [n}23.616{]}ἀμφίθετος φιάλη· τὴν Νέστορι δῶκεν Ἀχιλλεὺς{l]
[l [n}23.617{]}Ἀργείων ἀνʼ ἀγῶνα φέρων, καὶ ἔειπε παραστάς·{l]
[q}[l [n}23.618{]}τῆ νῦν, καὶ σοὶ τοῦτο γέρον κειμήλιον ἔστω{l]
[l [n}23.619{]}Πατρόκλοιο τάφου μνῆμʼ ἔμμεναι· οὐ γὰρ ἔτʼ αὐτὸν{l]
[l [n}23.620{]}ὄψῃ ἐν Ἀργείοισι· δίδωμι δέ τοι τόδʼ ἄεθλον{l]
[l [n}23.621{]}αὔτως· οὐ γὰρ πύξ γε μαχήσεαι, οὐδὲ παλαίσεις,{l]
[l [n}23.622{]}οὐδʼ ἔτʼ ἀκοντιστὺν ἐσδύσεαι, οὐδὲ πόδεσσι{l]
[l [n}23.623{]}θεύσεαι· ἤδη γὰρ χαλεπὸν κατὰ γῆρας ἐπείγει.{l]{q]{para]
[para}[l [n}23.624{]}ὣς εἰπὼν ἐν χερσὶ τίθει· ὃ δʼ ἐδέξατο χαίρων,{l]
[l [n}23.625{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}23.626{]}ναὶ δὴ ταῦτά γε πάντα τέκος κατὰ μοῖραν ἔειπες·{l]
[l [n}23.627{]}οὐ γὰρ ἔτʼ ἔμπεδα γυῖα φίλος πόδες, οὐδέ τι χεῖρες{l]
[l [n}23.628{]}ὤμων ἀμφοτέρωθεν ἐπαΐσσονται ἐλαφραί.{l]
[l [n}23.629{]}εἴθʼ ὣς ἡβώοιμι βίη τέ μοι ἔμπεδος εἴη{l]
[l [n}23.630{]}ὡς ὁπότε κρείοντʼ Ἀμαρυγκέα θάπτον Ἐπειοὶ{l]
[l [n}23.631{]}Βουπρασίῳ, παῖδες δʼ ἔθεσαν βασιλῆος ἄεθλα·{l]
[l [n}23.632{]}ἔνθʼ οὔ τίς μοι ὁμοῖος ἀνὴρ γένετʼ, οὔτʼ ἄρʼ Ἐπειῶν{l]
[l [n}23.633{]}οὔτʼ αὐτῶν Πυλίων οὔτʼ Αἰτωλῶν μεγαθύμων.{l]
[l [n}23.634{]}πὺξ μὲν ἐνίκησα Κλυτομήδεα Ἤνοπος υἱόν,{l]
[l [n}23.635{]}Ἀγκαῖον δὲ πάλῃ Πλευρώνιον, ὅς μοι ἀνέστη·{l]
[l [n}23.636{]}Ἴφικλον δὲ πόδεσσι παρέδραμον ἐσθλὸν ἐόντα,{l]
[l [n}23.637{]}δουρὶ δʼ ὑπειρέβαλον Φυλῆά τε καὶ Πολύδωρον.{l]
[l [n}23.638{]}οἴοισίν μʼ ἵπποισι παρήλασαν Ἀκτορίωνε{l]
[l [n}23.639{]}πλήθει πρόσθε βαλόντες ἀγασσάμενοι περὶ νίκης,{l]
[l [n}23.640{]}οὕνεκα δὴ τὰ μέγιστα παρʼ αὐτόθι λείπετʼ ἄεθλα.{l]
[l [n}23.641{]}οἳ δʼ ἄρʼ ἔσαν δίδυμοι· ὃ μὲν ἔμπεδον ἡνιόχευεν,{l]
[l [n}23.642{]}ἔμπεδον ἡνιόχευʼ, ὃ δʼ ἄρα μάστιγι κέλευεν.{l]
[l [n}23.643{]}ὥς ποτʼ ἔον· νῦν αὖτε νεώτεροι ἀντιοώντων{l]
[l [n}23.644{]}ἔργων τοιούτων· ἐμὲ δὲ χρὴ γήραϊ λυγρῷ{l]
[l [n}23.645{]}πείθεσθαι, τότε δʼ αὖτε μετέπρεπον ἡρώεσσιν.{l]
[l [n}23.646{]}ἀλλʼ ἴθι καὶ σὸν ἑταῖρον ἀέθλοισι κτερέϊζε.{l]
[l [n}23.647{]}τοῦτο δʼ ἐγὼ πρόφρων δέχομαι, χαίρει δέ μοι ἦτορ,{l]
[l [n}23.648{]}ὥς μευ ἀεὶ μέμνησαι ἐνηέος, οὐδέ σε λήθω,{l]
[l [n}23.649{]}τιμῆς ἧς τέ μʼ ἔοικε τετιμῆσθαι μετʼ Ἀχαιοῖς.{l]
[l [n}23.650{]}σοὶ δὲ θεοὶ τῶνδʼ ἀντὶ χάριν μενοεικέα δοῖεν.{l]{q]{para]
[para}[l [n}23.651{]}ὣς φάτο, Πηλεΐδης δὲ πολὺν καθʼ ὅμιλον Ἀχαιῶν{l]
[l [n}23.652{]}ᾤχετʼ, ἐπεὶ πάντʼ αἶνον ἐπέκλυε Νηλεΐδαο.{l]
[l [n}23.653{]}αὐτὰρ ὃ πυγμαχίης ἀλεγεινῆς θῆκεν ἄεθλα·{l]
[l [n}23.654{]}ἡμίονον ταλαεργὸν ἄγων κατέδησʼ ἐν ἀγῶνι{l]
[l [n}23.655{]}ἑξέτεʼ ἀδμήτην, ἥ τʼ ἀλγίστη δαμάσασθαι·{l]
[l [n}23.656{]}τῷ δʼ ἄρα νικηθέντι τίθει δέπας ἀμφικύπελλον.{l]
[l [n}23.657{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.658{]}Ἀτρεΐδη τε καὶ ἄλλοι ἐϋκνήμιδες Ἀχαιοὶ{l]
[l [n}23.659{]}ἄνδρε δύω περὶ τῶνδε κελεύομεν, ὥ περ ἀρίστω,{l]
[l [n}23.660{]}πὺξ μάλʼ ἀνασχομένω πεπληγέμεν· ᾧ δέ κʼ Ἀπόλλων{l]
[l [n}23.661{]}δώῃ καμμονίην, γνώωσι δὲ πάντες Ἀχαιοί,{l]
[l [n}23.662{]}ἡμίονον ταλαεργὸν ἄγων κλισίην δὲ νεέσθω·{l]
[l [n}23.663{]}αὐτὰρ ὃ νικηθεὶς δέπας οἴσεται ἀμφικύπελλον.{l]{q]{para]
[para}[l [n}23.664{]}ὣς ἔφατʼ, ὄρνυτο δʼ αὐτίκʼ ἀνὴρ ἠΰς τε μέγας τε{l]
[l [n}23.665{]}εἰδὼς πυγμαχίης υἱὸς Πανοπῆος Ἐπειός,{l]
[l [n}23.666{]}ἅψατο δʼ ἡμιόνου ταλαεργοῦ φώνησέν τε·{l]
[q}[l [n}23.667{]}ἆσσον ἴτω ὅς τις δέπας οἴσεται ἀμφικύπελλον·{l]
[l [n}23.668{]}ἡμίονον δʼ οὔ φημί τινʼ ἀξέμεν ἄλλον Ἀχαιῶν{l]
[l [n}23.669{]}πυγμῇ νικήσαντʼ, ἐπεὶ εὔχομαι εἶναι ἄριστος.{l]
[l [n}23.670{]}ἦ οὐχ ἅλις ὅττι μάχης ἐπιδεύομαι; οὐδʼ ἄρα πως ἦν{l]
[l [n}23.671{]}ἐν πάντεσσʼ ἔργοισι δαήμονα φῶτα γενέσθαι.{l]
[l [n}23.672{]}ὧδε γὰρ ἐξερέω, τὸ δὲ καὶ τετελεσμένον ἔσται·{l]
[l [n}23.673{]}ἀντικρὺ χρόα τε ῥήξω σύν τʼ ὀστέʼ ἀράξω.{l]
[l [n}23.674{]}κηδεμόνες δέ οἱ ἐνθάδʼ ἀολλέες αὖθι μενόντων,{l]
[l [n}23.675{]}οἵ κέ μιν ἐξοίσουσιν ἐμῇς ὑπὸ χερσὶ δαμέντα.{l]{q]{para]
[para}[l [n}23.676{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἀκὴν ἐγένοντο σιωπῇ.{l]
[l [n}23.677{]}Εὐρύαλος δέ οἱ οἶος ἀνίστατο ἰσόθεος φὼς{l]
[l [n}23.678{]}Μηκιστῆος υἱὸς Ταλαϊονίδαο ἄνακτος,{l]
[l [n}23.679{]}ὅς ποτε Θήβας δʼ ἦλθε δεδουπότος Οἰδιπόδαο{l]
[l [n}23.680{]}ἐς τάφον· ἔνθα δὲ πάντας ἐνίκα Καδμείωνας.{l]
[l [n}23.681{]}τὸν μὲν Τυδεΐδης δουρὶ κλυτὸς ἀμφεπονεῖτο{l]
[l [n}23.682{]}θαρσύνων ἔπεσιν, μέγα δʼ αὐτῷ βούλετο νίκην.{l]
[l [n}23.683{]}ζῶμα δέ οἱ πρῶτον παρακάββαλεν, αὐτὰρ ἔπειτα{l]
[l [n}23.684{]}δῶκεν ἱμάντας ἐϋτμήτους βοὸς ἀγραύλοιο.{l]
[l [n}23.685{]}τὼ δὲ ζωσαμένω βήτην ἐς μέσσον ἀγῶνα,{l]
[l [n}23.686{]}ἄντα δʼ ἀνασχομένω χερσὶ στιβαρῇσιν ἅμʼ ἄμφω{l]
[l [n}23.687{]}σύν ῥʼ ἔπεσον, σὺν δέ σφι βαρεῖαι χεῖρες ἔμιχθεν.{l]
[l [n}23.688{]}δεινὸς δὲ χρόμαδος γενύων γένετʼ, ἔρρεε δʼ ἱδρὼς{l]
[l [n}23.689{]}πάντοθεν ἐκ μελέων· ἐπὶ δʼ ὄρνυτο δῖος Ἐπειός,{l]
[l [n}23.690{]}κόψε δὲ παπτήναντα παρήϊον· οὐδʼ ἄρʼ ἔτι δὴν{l]
[l [n}23.691{]}ἑστήκειν· αὐτοῦ γὰρ ὑπήριπε φαίδιμα γυῖα.{l]
[l [n}23.692{]}ὡς δʼ ὅθʼ ὑπὸ φρικὸς Βορέω ἀναπάλλεται ἰχθὺς{l]
[l [n}23.693{]}θίνʼ ἐν φυκιόεντι, μέλαν δέ ἑ κῦμα κάλυψεν,{l]
[l [n}23.694{]}ὣς πληγεὶς ἀνέπαλτʼ· αὐτὰρ μεγάθυμος Ἐπειὸς{l]
[l [n}23.695{]}χερσὶ λαβὼν ὤρθωσε· φίλοι δʼ ἀμφέσταν ἑταῖροι,{l]
[l [n}23.696{]}οἵ μιν ἄγον διʼ ἀγῶνος ἐφελκομένοισι πόδεσσιν{l]
[l [n}23.697{]}αἷμα παχὺ πτύοντα κάρη βάλλονθʼ ἑτέρωσε·{l]
[l [n}23.698{]}κὰδ δʼ ἀλλοφρονέοντα μετὰ σφίσιν εἷσαν ἄγοντες,{l]
[l [n}23.699{]}αὐτοὶ δʼ οἰχόμενοι κόμισαν δέπας ἀμφικύπελλον.{l]{para]
[para}[l [n}23.700{]}Πηλεΐδης δʼ αἶψʼ ἄλλα κατὰ τρίτα θῆκεν ἄεθλα{l]
[l [n}23.701{]}δεικνύμενος Δαναοῖσι παλαισμοσύνης ἀλεγεινῆς,{l]
[l [n}23.702{]}τῷ μὲν νικήσαντι μέγαν τρίποδʼ ἐμπυριβήτην,{l]
[l [n}23.703{]}τὸν δὲ δυωδεκάβοιον ἐνὶ σφίσι τῖον Ἀχαιοί·{l]
[l [n}23.704{]}ἀνδρὶ δὲ νικηθέντι γυναῖκʼ ἐς μέσσον ἔθηκε,{l]
[l [n}23.705{]}πολλὰ δʼ ἐπίστατο ἔργα, τίον δέ ἑ τεσσαράβοιον.{l]
[l [n}23.706{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.707{]}ὄρνυσθʼ οἳ καὶ τούτου ἀέθλου πειρήσεσθον.{l]{q][l [n}23.708{]}ὣς ἔφατʼ, ὦρτο δʼ ἔπειτα μέγας Τελαμώνιος Αἴας,{l]
[l [n}23.709{]}ἂν δʼ Ὀδυσεὺς πολύμητις ἀνίστατο κέρδεα εἰδώς.{l]
[l [n}23.710{]}ζωσαμένω δʼ ἄρα τώ γε βάτην ἐς μέσσον ἀγῶνα,{l]
[l [n}23.711{]}ἀγκὰς δʼ ἀλλήλων λαβέτην χερσὶ στιβαρῇσιν{l]
[l [n}23.712{]}ὡς ὅτʼ ἀμείβοντες, τούς τε κλυτὸς ἤραρε τέκτων{l]
[l [n}23.713{]}δώματος ὑψηλοῖο βίας ἀνέμων ἀλεείνων.{l]
[l [n}23.714{]}τετρίγει δʼ ἄρα νῶτα θρασειάων ἀπὸ χειρῶν{l]
[l [n}23.715{]}ἑλκόμενα στερεῶς· κατὰ δὲ νότιος ῥέεν ἱδρώς,{l]
[l [n}23.716{]}πυκναὶ δὲ σμώδιγγες ἀνὰ πλευράς τε καὶ ὤμους{l]
[l [n}23.717{]}αἵματι φοινικόεσσαι ἀνέδραμον· οἳ δὲ μάλʼ αἰεὶ{l]
[l [n}23.718{]}νίκης ἱέσθην τρίποδος πέρι ποιητοῖο·{l]
[l [n}23.719{]}οὔτʼ Ὀδυσεὺς δύνατο σφῆλαι οὔδει τε πελάσσαι,{l]
[l [n}23.720{]}οὔτʼ Αἴας δύνατο, κρατερὴ δʼ ἔχεν ἲς Ὀδυσῆος.{l]
[l [n}23.721{]}ἀλλʼ ὅτε δή ῥʼ ἀνίαζον ἐϋκνήμιδας Ἀχαιούς,{l]
[l [n}23.722{]}δὴ τότε μιν προσέειπε μέγας Τελαμώνιος Αἴας·{l]
[q}[l [n}23.723{]}διογενὲς Λαερτιάδη πολυμήχανʼ Ὀδυσσεῦ{l]
[l [n}23.724{]}ἤ μʼ ἀνάειρʼ, ἢ ἐγὼ σέ· τὰ δʼ αὖ Διὶ πάντα μελήσει.{l]{q]{para]
[para}[l [n}23.725{]}ὣς εἰπὼν ἀνάειρε· δόλου δʼ οὐ λήθετʼ Ὀδυσσεύς·{l]
[l [n}23.726{]}κόψʼ ὄπιθεν κώληπα τυχών, ὑπέλυσε δὲ γυῖα,{l]
[l [n}23.727{]}κὰδ δʼ ἔβαλʼ ἐξοπίσω· ἐπὶ δὲ στήθεσσιν Ὀδυσσεὺς{l]
[l [n}23.728{]}κάππεσε· λαοὶ δʼ αὖ θηεῦντό τε θάμβησάν τε.{l]
[l [n}23.729{]}δεύτερος αὖτʼ ἀνάειρε πολύτλας δῖος Ὀδυσσεύς,{l]
[l [n}23.730{]}κίνησεν δʼ ἄρα τυτθὸν ἀπὸ χθονός, οὐδʼ ἔτʼ ἄειρεν,{l]
[l [n}23.731{]}ἐν δὲ γόνυ γνάμψεν· ἐπὶ δὲ χθονὶ κάππεσον ἄμφω{l]
[l [n}23.732{]}πλησίοι ἀλλήλοισι, μιάνθησαν δὲ κονίῃ.{l]
[l [n}23.733{]}καί νύ κε τὸ τρίτον αὖτις ἀναΐξαντʼ ἐπάλαιον,{l]
[l [n}23.734{]}εἰ μὴ Ἀχιλλεὺς αὐτὸς ἀνίστατο καὶ κατέρυκε·{l]
[q}[l [n}23.735{]}μηκέτʼ ἐρείδεσθον, μὴ δὲ τρίβεσθε κακοῖσι·{l]
[l [n}23.736{]}νίκη δʼ ἀμφοτέροισιν· ἀέθλια δʼ ἶσʼ ἀνελόντες{l]
[l [n}23.737{]}ἔρχεσθʼ, ὄφρα καὶ ἄλλοι ἀεθλεύωσιν Ἀχαιοί.{l]{q]{para]
[para}[l [n}23.738{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα τοῦ μάλα μὲν κλύον ἠδὲ πίθοντο,{l]
[l [n}23.739{]}καί ῥʼ ἀπομορξαμένω κονίην δύσαντο χιτῶνας.{l]{para]
[para}[l [n}23.740{]}Πηλεΐδης δʼ αἶψʼ ἄλλα τίθει ταχυτῆτος ἄεθλα{l]
[l [n}23.741{]}ἀργύρεον κρητῆρα τετυγμένον· ἓξ δʼ ἄρα μέτρα{l]
[l [n}23.742{]}χάνδανεν, αὐτὰρ κάλλει ἐνίκα πᾶσαν ἐπʼ αἶαν{l]
[l [n}23.743{]}πολλόν, ἐπεὶ Σιδόνες πολυδαίδαλοι εὖ ἤσκησαν,{l]
[l [n}23.744{]}Φοίνικες δʼ ἄγον ἄνδρες ἐπʼ ἠεροειδέα πόντον,{l]
[l [n}23.745{]}στῆσαν δʼ ἐν λιμένεσσι, Θόαντι δὲ δῶρον ἔδωκαν·{l]
[l [n}23.746{]}υἷος δὲ Πριάμοιο Λυκάονος ὦνον ἔδωκε{l]
[l [n}23.747{]}Πατρόκλῳ ἥρωϊ Ἰησονίδης Εὔνηος.{l]
[l [n}23.748{]}καὶ τὸν Ἀχιλλεὺς θῆκεν ἄεθλον οὗ ἑτάροιο,{l]
[l [n}23.749{]}ὅς τις ἐλαφρότατος ποσσὶ κραιπνοῖσι πέλοιτο·{l]
[l [n}23.750{]}δευτέρῳ αὖ βοῦν θῆκε μέγαν καὶ πίονα δημῷ,{l]
[l [n}23.751{]}ἡμιτάλαντον δὲ χρυσοῦ λοισθήϊʼ ἔθηκε.{l]
[l [n}23.752{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.753{]}ὄρνυσθʼ οἳ καὶ τούτου ἀέθλου πειρήσεσθε.{l]{q][l [n}23.754{]}ὣς ἔφατʼ, ὄρνυτο δʼ αὐτίκʼ Ὀϊλῆος ταχὺς Αἴας,{l]
[l [n}23.755{]}ἂν δʼ Ὀδυσεὺς πολύμητις, ἔπειτα δὲ Νέστορος υἱὸς{l]
[l [n}23.756{]}Ἀντίλοχος· ὃ γὰρ αὖτε νέους ποσὶ πάντας ἐνίκα.{l]
[l [n}23.757{]}στὰν δὲ μεταστοιχί· σήμηνε δὲ τέρματʼ Ἀχιλλεύς.{l]
[l [n}23.758{]}τοῖσι δʼ ἀπὸ νύσσης τέτατο δρόμος· ὦκα δʼ ἔπειτα{l]
[l [n}23.759{]}ἔκφερʼ Ὀϊλιάδης· ἐπὶ δʼ ὄρνυτο δῖος Ὀδυσσεὺς{l]
[l [n}23.760{]}ἄγχι μάλʼ, ὡς ὅτε τίς τε γυναικὸς ἐϋζώνοιο{l]
[l [n}23.761{]}στήθεός ἐστι κανών, ὅν τʼ εὖ μάλα χερσὶ τανύσσῃ{l]
[l [n}23.762{]}πηνίον ἐξέλκουσα παρὲκ μίτον, ἀγχόθι δʼ ἴσχει{l]
[l [n}23.763{]}στήθεος· ὣς Ὀδυσεὺς θέεν ἐγγύθεν, αὐτὰρ ὄπισθεν{l]
[l [n}23.764{]}ἴχνια τύπτε πόδεσσι πάρος κόνιν ἀμφιχυθῆναι·{l]
[l [n}23.765{]}κὰδ δʼ ἄρα οἱ κεφαλῆς χέʼ ἀϋτμένα δῖος Ὀδυσσεὺς{l]
[l [n}23.766{]}αἰεὶ ῥίμφα θέων· ἴαχον δʼ ἐπὶ πάντες Ἀχαιοὶ{l]
[l [n}23.767{]}νίκης ἱεμένῳ, μάλα δὲ σπεύδοντι κέλευον.{l]
[l [n}23.768{]}ἀλλʼ ὅτε δὴ πύματον τέλεον δρόμον, αὐτίκʼ Ὀδυσσεὺς{l]
[l [n}23.769{]}εὔχετʼ Ἀθηναίῃ γλαυκώπιδι ὃν κατὰ θυμόν·{l]
[q}[l [n}23.770{]}κλῦθι θεά, ἀγαθή μοι ἐπίρροθος ἐλθὲ ποδοῖιν.{l]{q][l [n}23.771{]}ὣς ἔφατʼ εὐχόμενος· τοῦ δʼ ἔκλυε Παλλὰς Ἀθήνη,{l]
[l [n}23.772{]}γυῖα δʼ ἔθηκεν ἐλαφρά, πόδας καὶ χεῖρας ὕπερθεν.{l]
[l [n}23.773{]}ἀλλʼ ὅτε δὴ τάχʼ ἔμελλον ἐπαΐξασθαι ἄεθλον,{l]
[l [n}23.774{]}ἔνθʼ Αἴας μὲν ὄλισθε θέων, βλάψεν γὰρ Ἀθήνη,{l]
[l [n}23.775{]}τῇ ῥα βοῶν κέχυτʼ ὄνθος ἀποκταμένων ἐριμύκων,{l]
[l [n}23.776{]}οὓς ἐπὶ Πατρόκλῳ πέφνεν πόδας ὠκὺς Ἀχιλλεύς·{l]
[l [n}23.777{]}ἐν δʼ ὄνθου βοέου πλῆτο στόμα τε ῥῖνάς τε·{l]
[l [n}23.778{]}κρητῆρʼ αὖτʼ ἀνάειρε πολύτλας δῖος Ὀδυσσεύς,{l]
[l [n}23.779{]}ὡς ἦλθε φθάμενος· ὃ δὲ βοῦν ἕλε φαίδιμος Αἴας.{l]
[l [n}23.780{]}στῆ δὲ κέρας μετὰ χερσὶν ἔχων βοὸς ἀγραύλοιο{l]
[l [n}23.781{]}ὄνθον ἀποπτύων, μετὰ δʼ Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.782{]}ὢ πόποι ἦ μʼ ἔβλαψε θεὰ πόδας, ἣ τὸ πάρος περ{l]
[l [n}23.783{]}μήτηρ ὣς Ὀδυσῆϊ παρίσταται ἠδʼ ἐπαρήγει.{l]{q]{para]
[para}[l [n}23.784{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πάντες ἐπʼ αὐτῷ ἡδὺ γέλασσαν.{l]
[l [n}23.785{]}Ἀντίλοχος δʼ ἄρα δὴ λοισθήϊον ἔκφερʼ ἄεθλον{l]
[l [n}23.786{]}μειδιόων, καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.787{]}εἰδόσιν ὔμμʼ ἐρέω πᾶσιν φίλοι, ὡς ἔτι καὶ νῦν{l]
[l [n}23.788{]}ἀθάνατοι τιμῶσι παλαιοτέρους ἀνθρώπους.{l]
[l [n}23.789{]}Αἴας μὲν γὰρ ἐμεῖʼ ὀλίγον προγενέστερός ἐστιν,{l]
[l [n}23.790{]}οὗτος δὲ προτέρης γενεῆς προτέρων τʼ ἀνθρώπων·{l]
[l [n}23.791{]}ὠμογέροντα δέ μίν φασʼ ἔμμεναι· ἀργαλέον δὲ{l]
[l [n}23.792{]}ποσσὶν ἐριδήσασθαι Ἀχαιοῖς, εἰ μὴ Ἀχιλλεῖ.{l]{q]{para]
[para}[l [n}23.793{]}ὣς φάτο, κύδηνεν δὲ ποδώκεα Πηλεΐωνα.{l]
[l [n}23.794{]}τὸν δʼ Ἀχιλεὺς μύθοισιν ἀμειβόμενος προσέειπεν·{l]
[q}[l [n}23.795{]}Ἀντίλοχʼ οὐ μέν τοι μέλεος εἰρήσεται αἶνος,{l]
[l [n}23.796{]}ἀλλά τοι ἡμιτάλαντον ἐγὼ χρυσοῦ ἐπιθήσω.{l]{q]{para]
[para}[l [n}23.797{]}ὣς εἰπὼν ἐν χερσὶ τίθει, ὃ δʼ ἐδέξατο χαίρων.{l]
[l [n}23.798{]}αὐτὰρ Πηλεΐδης κατὰ μὲν δολιχόσκιον ἔγχος{l]
[l [n}23.799{]}θῆκʼ ἐς ἀγῶνα φέρων, κατὰ δʼ ἀσπίδα καὶ τρυφάλειαν{l]
[l [n}23.800{]}τεύχεα Σαρπήδοντος, ἅ μιν Πάτροκλος ἀπηύρα.{l]
[l [n}23.801{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.802{]}ἄνδρε δύω περὶ τῶνδε κελεύομεν, ὥ περ ἀρίστω,{l]
[l [n}23.803{]}τεύχεα ἑσσαμένω ταμεσίχροα χαλκὸν ἑλόντε{l]
[l [n}23.804{]}ἀλλήλων προπάροιθεν ὁμίλου πειρηθῆναι.{l]
[l [n}23.805{]}ὁππότερός κε φθῇσιν ὀρεξάμενος χρόα καλόν,{l]
[l [n}23.806{]}ψαύσῃ δʼ ἐνδίνων διά τʼ ἔντεα καὶ μέλαν αἷμα,{l]
[l [n}23.807{]}τῷ μὲν ἐγὼ δώσω τόδε φάσγανον ἀργυρόηλον{l]
[l [n}23.808{]}καλὸν Θρηΐκιον, τὸ μὲν Ἀστεροπαῖον ἀπηύρων·{l]
[l [n}23.809{]}τεύχεα δʼ ἀμφότεροι ξυνήϊα ταῦτα φερέσθων·{l]
[l [n}23.810{]}καί σφιν δαῖτʼ ἀγαθὴν παραθήσομεν ἐν κλισίῃσιν.{l]{q]{para]
[para}[l [n}23.811{]}ὣς ἔφατʼ, ὦρτο δʼ ἔπειτα μέγας Τελαμώνιος Αἴας,{l]
[l [n}23.812{]}ἂν δʼ ἄρα Τυδεΐδης ὦρτο, κρατερὸς Διομήδης.{l]
[l [n}23.813{]}οἳ δʼ ἐπεὶ οὖν ἑκάτερθεν ὁμίλου θωρήχθησαν,{l]
[l [n}23.814{]}ἐς μέσον ἀμφοτέρω συνίτην μεμαῶτε μάχεσθαι{l]
[l [n}23.815{]}δεινὸν δερκομένω· θάμβος δʼ ἔχε πάντας Ἀχαιούς.{l]
[l [n}23.816{]}ἀλλʼ ὅτε δὴ σχεδὸν ἦσαν ἐπʼ ἀλλήλοισιν ἰόντες,{l]
[l [n}23.817{]}τρὶς μὲν ἐπήϊξαν, τρὶς δὲ σχεδὸν ὁρμήθησαν.{l]
[l [n}23.818{]}ἔνθʼ Αἴας μὲν ἔπειτα κατʼ ἀσπίδα πάντοσʼ ἐΐσην{l]
[l [n}23.819{]}νύξʼ, οὐδὲ χρόʼ ἵκανεν· ἔρυτο γὰρ ἔνδοθι θώρηξ·{l]
[l [n}23.820{]}Τυδεΐδης δʼ ἄρʼ ἔπειτα ὑπὲρ σάκεος μεγάλοιο{l]
[l [n}23.821{]}αἰὲν ἐπʼ αὐχένι κῦρε φαεινοῦ δουρὸς ἀκωκῇ.{l]
[l [n}23.822{]}καὶ τότε δή ῥʼ Αἴαντι περιδείσαντες Ἀχαιοὶ{l]
[l [n}23.823{]}παυσαμένους ἐκέλευσαν ἀέθλια ἶσʼ ἀνελέσθαι.{l]
[l [n}23.824{]}αὐτὰρ Τυδεΐδῃ δῶκεν μέγα φάσγανον ἥρως{l]
[l [n}23.825{]}σὺν κολεῷ τε φέρων καὶ ἐϋτμήτῳ τελαμῶνι.{l]{para]
[para}[l [n}23.826{]}αὐτὰρ Πηλεΐδης θῆκεν σόλον αὐτοχόωνον{l]
[l [n}23.827{]}ὃν πρὶν μὲν ῥίπτασκε μέγα σθένος Ἠετίωνος·{l]
[l [n}23.828{]}ἀλλʼ ἤτοι τὸν ἔπεφνε ποδάρκης δῖος Ἀχιλλεύς,{l]
[l [n}23.829{]}τὸν δʼ ἄγετʼ ἐν νήεσσι σὺν ἄλλοισι κτεάτεσσι.{l]
[l [n}23.830{]}στῆ δʼ ὀρθὸς καὶ μῦθον ἐν Ἀργείοισιν ἔειπεν·{l]
[q}[l [n}23.831{]}ὄρνυσθʼ οἳ καὶ τούτου ἀέθλου πειρήσεσθε.{l]
[l [n}23.832{]}εἴ οἱ καὶ μάλα πολλὸν ἀπόπροθι πίονες ἀγροί,{l]
[l [n}23.833{]}ἕξει μιν καὶ πέντε περιπλομένους ἐνιαυτοὺς{l]
[l [n}23.834{]}χρεώμενος· οὐ μὲν γάρ οἱ ἀτεμβόμενός γε σιδήρου{l]
[l [n}23.835{]}ποιμὴν οὐδʼ ἀροτὴρ εἶσʼ ἐς πόλιν, ἀλλὰ παρέξει.{l]{q]{para]
[para}[l [n}23.836{]}ὣς ἔφατʼ, ὦρτο δʼ ἔπειτα μενεπτόλεμος Πολυποίτης,{l]
[l [n}23.837{]}ἂν δὲ Λεοντῆος κρατερὸν μένος ἀντιθέοιο,{l]
[l [n}23.838{]}ἂν δʼ Αἴας Τελαμωνιάδης καὶ δῖος Ἐπειός.{l]
[l [n}23.839{]}ἑξείης δʼ ἵσταντο, σόλον δʼ ἕλε δῖος Ἐπειός,{l]
[l [n}23.840{]}ἧκε δὲ δινήσας· γέλασαν δʼ ἐπὶ πάντες Ἀχαιοί.{l]
[l [n}23.841{]}δεύτερος αὖτʼ ἀφέηκε Λεοντεὺς ὄζος Ἄρηος·{l]
[l [n}23.842{]}τὸ τρίτον αὖτʼ ἔρριψε μέγας Τελαμώνιος Αἴας{l]
[l [n}23.843{]}χειρὸς ἄπο στιβαρῆς, καὶ ὑπέρβαλε σήματα πάντων.{l]
[l [n}23.844{]}ἀλλʼ ὅτε δὴ σόλον εἷλε μενεπτόλεμος Πολυποίτης,{l]
[l [n}23.845{]}ὅσσόν τίς τʼ ἔρριψε καλαύροπα βουκόλος ἀνήρ,{l]
[l [n}23.846{]}ἣ δέ θʼ ἑλισσομένη πέτεται διὰ βοῦς ἀγελαίας,{l]
[l [n}23.847{]}τόσσον παντὸς ἀγῶνος ὑπέρβαλε· τοὶ δὲ βόησαν.{l]
[l [n}23.848{]}ἀνστάντες δʼ ἕταροι Πολυποίταο κρατεροῖο{l]
[l [n}23.849{]}νῆας ἔπι γλαφυρὰς ἔφερον βασιλῆος ἄεθλον.{l]{para]
[para}[l [n}23.850{]}αὐτὰρ ὃ τοξευτῇσι τίθει ἰόεντα σίδηρον,{l]
[l [n}23.851{]}κὰδ δʼ ἐτίθει δέκα μὲν πελέκεας, δέκα δʼ ἡμιπέλεκκα,{l]
[l [n}23.852{]}ἱστὸν δʼ ἔστησεν νηὸς κυανοπρῴροιο{l]
[l [n}23.853{]}τηλοῦ ἐπὶ ψαμάθοις, ἐκ δὲ τρήρωνα πέλειαν{l]
[l [n}23.854{]}λεπτῇ μηρίνθῳ δῆσεν ποδός, ἧς ἄρʼ ἀνώγει{l]
[l [n}23.855{]}τοξεύειν· ὃς μέν κε βάλῃ τρήρωνα πέλειαν,{l]
[l [n}23.856{]}πάντας ἀειράμενος πελέκεας οἶκον δὲ φερέσθω·{l]
[l [n}23.857{]}ὃς δέ κε μηρίνθοιο τύχῃ ὄρνιθος ἁμαρτών,{l]
[l [n}23.858{]}ἥσσων γὰρ δὴ κεῖνος, ὃ δʼ οἴσεται ἡμιπέλεκκα.{l]{para]
[para}[l [n}23.859{]}ὣς ἔφατʼ, ὦρτο δʼ ἔπειτα βίη Τεύκροιο ἄνακτος,{l]
[l [n}23.860{]}ἂν δʼ ἄρα Μηριόνης θεράπων ἐῢς Ἰδομενῆος.{l]
[l [n}23.861{]}κλήρους δʼ ἐν κυνέῃ χαλκήρεϊ πάλλον ἑλόντες,{l]
[l [n}23.862{]}Τεῦκρος δὲ πρῶτος κλήρῳ λάχεν· αὐτίκα δʼ ἰὸν{l]
[l [n}23.863{]}ἧκεν ἐπικρατέως, οὐδʼ ἠπείλησεν ἄνακτι{l]
[l [n}23.864{]}ἀρνῶν πρωτογόνων ῥέξειν κλειτὴν ἑκατόμβην.{l]
[l [n}23.865{]}ὄρνιθος μὲν ἅμαρτε· μέγηρε γάρ οἱ τό γʼ Ἀπόλλων·{l]
[l [n}23.866{]}αὐτὰρ ὃ μήρινθον βάλε πὰρ πόδα, τῇ δέδετʼ ὄρνις·{l]
[l [n}23.867{]}ἀντικρὺ δʼ ἀπὸ μήρινθον τάμε πικρὸς ὀϊστός.{l]
[l [n}23.868{]}ἣ μὲν ἔπειτʼ ἤϊξε πρὸς οὐρανόν, ἣ δὲ παρείθη{l]
[l [n}23.869{]}μήρινθος ποτὶ γαῖαν· ἀτὰρ κελάδησαν Ἀχαιοί.{l]
[l [n}23.870{]}σπερχόμενος δʼ ἄρα Μηριόνης ἐξείρυσε χειρὸς{l]
[l [n}23.871{]}τόξον· ἀτὰρ δὴ ὀϊστὸν ἔχεν πάλαι, ὡς ἴθυνεν.{l]
[l [n}23.872{]}αὐτίκα δʼ ἠπείλησεν ἑκηβόλῳ Ἀπόλλωνι{l]
[l [n}23.873{]}ἀρνῶν πρωτογόνων ῥέξειν κλειτὴν ἑκατόμβην.{l]
[l [n}23.874{]}ὕψι δʼ ὑπὸ νεφέων εἶδε τρήρωνα πέλειαν·{l]
[l [n}23.875{]}τῇ ῥʼ ὅ γε δινεύουσαν ὑπὸ πτέρυγος βάλε μέσσην,{l]
[l [n}23.876{]}ἀντικρὺ δὲ διῆλθε βέλος· τὸ μὲν ἂψ ἐπὶ γαίῃ{l]
[l [n}23.877{]}πρόσθεν Μηριόναο πάγη ποδός· αὐτὰρ ἣ ὄρνις{l]
[l [n}23.878{]}ἱστῷ ἐφεζομένη νηὸς κυανοπρῴροιο{l]
[l [n}23.879{]}αὐχένʼ ἀπεκρέμασεν, σὺν δὲ πτερὰ πυκνὰ λίασθεν.{l]
[l [n}23.880{]}ὠκὺς δʼ ἐκ μελέων θυμὸς πτάτο, τῆλε δʼ ἀπʼ αὐτοῦ{l]
[l [n}23.881{]}κάππεσε· λαοὶ δʼ αὖ θηεῦντό τε θάμβησάν τε.{l]
[l [n}23.882{]}ἂν δʼ ἄρα Μηριόνης πελέκεας δέκα πάντας ἄειρε,{l]
[l [n}23.883{]}Τεῦκρος δʼ ἡμιπέλεκκα φέρεν κοίλας ἐπὶ νῆας.{l]{para]
[para}[l [n}23.884{]}αὐτὰρ Πηλεΐδης κατὰ μὲν δολιχόσκιον ἔγχος,{l]
[l [n}23.885{]}κὰδ δὲ λέβητʼ ἄπυρον βοὸς ἄξιον ἀνθεμόεντα{l]
[l [n}23.886{]}θῆκʼ ἐς ἀγῶνα φέρων· καί ῥʼ ἥμονες ἄνδρες ἀνέσταν·{l]
[l [n}23.887{]}ἂν μὲν ἄρʼ Ἀτρεΐδης εὐρὺ κρείων Ἀγαμέμνων,{l]
[l [n}23.888{]}ἂν δʼ ἄρα Μηριόνης, θεράπων ἐῢς Ἰδομενῆος.{l]
[l [n}23.889{]}τοῖσι δὲ καὶ μετέειπε ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}23.890{]}Ἀτρεΐδη· ἴδμεν γὰρ ὅσον προβέβηκας ἁπάντων{l]
[l [n}23.891{]}ἠδʼ ὅσσον δυνάμει τε καὶ ἥμασιν ἔπλευ ἄριστος·{l]
[l [n}23.892{]}ἀλλὰ σὺ μὲν τόδʼ ἄεθλον ἔχων κοίλας ἐπὶ νῆας{l]
[l [n}23.893{]}ἔρχευ, ἀτὰρ δόρυ Μηριόνῃ ἥρωϊ πόρωμεν,{l]
[l [n}23.894{]}εἰ σύ γε σῷ θυμῷ ἐθέλοις· κέλομαι γὰρ ἔγωγε.{l]{q]{para]
[para}[l [n}23.895{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησεν ἄναξ ἀνδρῶν Ἀγαμέμνων·{l]
[l [n}23.896{]}δῶκε δὲ Μηριόνῃ δόρυ χάλκεον· αὐτὰρ ὅ γʼ ἥρως{l]
[l [n}23.897{]}Ταλθυβίῳ κήρυκι δίδου περικαλλὲς ἄεθλον.{l]{para]
{book]
[book [n}24{]}[l [n}24.1{]}λῦτο δʼ ἀγών, λαοὶ δὲ θοὰς ἐπὶ νῆας ἕκαστοι{l]
[l [n}24.2{]}ἐσκίδναντʼ ἰέναι. τοὶ μὲν δόρποιο μέδοντο{l]
[l [n}24.3{]}ὕπνου τε γλυκεροῦ ταρπήμεναι· αὐτὰρ Ἀχιλλεὺς{l]
[l [n}24.4{]}κλαῖε φίλου ἑτάρου μεμνημένος, οὐδέ μιν ὕπνος{l]
[l [n}24.5{]}ᾕρει πανδαμάτωρ, ἀλλʼ ἐστρέφετʼ ἔνθα καὶ ἔνθα{l]
[l [n}24.6{]}Πατρόκλου ποθέων ἀνδροτῆτά τε καὶ μένος ἠΰ,{l]
[l [n}24.7{]}ἠδʼ ὁπόσα τολύπευσε σὺν αὐτῷ καὶ πάθεν ἄλγεα{l]
[l [n}24.8{]}ἀνδρῶν τε πτολέμους ἀλεγεινά τε κύματα πείρων·{l]
[l [n}24.9{]}τῶν μιμνησκόμενος θαλερὸν κατὰ δάκρυον εἶβεν,{l]
[l [n}24.10{]}ἄλλοτʼ ἐπὶ πλευρὰς κατακείμενος, ἄλλοτε δʼ αὖτε{l]
[l [n}24.11{]}ὕπτιος, ἄλλοτε δὲ πρηνής· τοτὲ δʼ ὀρθὸς ἀναστὰς{l]
[l [n}24.12{]}δινεύεσκʼ ἀλύων παρὰ θῖνʼ ἁλός· οὐδέ μιν ἠὼς{l]
[l [n}24.13{]}φαινομένη λήθεσκεν ὑπεὶρ ἅλα τʼ ἠϊόνας τε.{l]
[l [n}24.14{]}ἀλλʼ ὅ γʼ ἐπεὶ ζεύξειεν ὑφʼ ἅρμασιν ὠκέας ἵππους,{l]
[l [n}24.15{]}Ἕκτορα δʼ ἕλκεσθαι δησάσκετο δίφρου ὄπισθεν,{l]
[l [n}24.16{]}τρὶς δʼ ἐρύσας περὶ σῆμα Μενοιτιάδαο θανόντος{l]
[l [n}24.17{]}αὖτις ἐνὶ κλισίῃ παυέσκετο, τὸν δέ τʼ ἔασκεν{l]
[l [n}24.18{]}ἐν κόνι ἐκτανύσας προπρηνέα· τοῖο δʼ Ἀπόλλων{l]
[l [n}24.19{]}πᾶσαν ἀεικείην ἄπεχε χροῒ φῶτʼ ἐλεαίρων{l]
[l [n}24.20{]}καὶ τεθνηότα περ· περὶ δʼ αἰγίδι πάντα κάλυπτε{l]
[l [n}24.21{]}χρυσείῃ, ἵνα μή μιν ἀποδρύφοι ἑλκυστάζων.{l]
[para}[l [n}24.22{]}ὣς ὃ μὲν Ἕκτορα δῖον ἀείκιζεν μενεαίνων·{l]
[l [n}24.23{]}τὸν δʼ ἐλεαίρεσκον μάκαρες θεοὶ εἰσορόωντες,{l]
[l [n}24.24{]}κλέψαι δʼ ὀτρύνεσκον ἐΰσκοπον ἀργεϊφόντην.{l]
[l [n}24.25{]}ἔνθʼ ἄλλοις μὲν πᾶσιν ἑήνδανεν, οὐδέ ποθʼ Ἥρῃ{l]
[l [n}24.26{]}οὐδὲ Ποσειδάωνʼ οὐδὲ γλαυκώπιδι κούρῃ,{l]
[l [n}24.27{]}ἀλλʼ ἔχον ὥς σφιν πρῶτον ἀπήχθετο Ἴλιος ἱρὴ{l]
[l [n}24.28{]}καὶ Πρίαμος καὶ λαὸς Ἀλεξάνδρου ἕνεκʼ ἄτης,{l]
[l [n}24.29{]}ὃς νείκεσσε θεὰς ὅτε οἱ μέσσαυλον ἵκοντο,{l]
[l [n}24.30{]}τὴν δʼ ᾔνησʼ ἥ οἱ πόρε μαχλοσύνην ἀλεγεινήν.{l]
[l [n}24.31{]}ἀλλʼ ὅτε δή ῥʼ ἐκ τοῖο δυωδεκάτη γένετʼ ἠώς,{l]
[l [n}24.32{]}καὶ τότʼ ἄρʼ ἀθανάτοισι μετηύδα Φοῖβος Ἀπόλλων·{l]
[q}[l [n}24.33{]}σχέτλιοί ἐστε θεοί, δηλήμονες· οὔ νύ ποθʼ ὑμῖν{l]
[l [n}24.34{]}Ἕκτωρ μηρίʼ ἔκηε βοῶν αἰγῶν τε τελείων;{l]
[l [n}24.35{]}τὸν νῦν οὐκ ἔτλητε νέκυν περ ἐόντα σαῶσαι{l]
[l [n}24.36{]}ᾗ τʼ ἀλόχῳ ἰδέειν καὶ μητέρι καὶ τέκεϊ ᾧ{l]
[l [n}24.37{]}καὶ πατέρι Πριάμῳ λαοῖσί τε, τοί κέ μιν ὦκα{l]
[l [n}24.38{]}ἐν πυρὶ κήαιεν καὶ ἐπὶ κτέρεα κτερίσαιεν.{l]
[l [n}24.39{]}ἀλλʼ ὀλοῷ Ἀχιλῆϊ θεοὶ βούλεσθʼ ἐπαρήγειν,{l]
[l [n}24.40{]}ᾧ οὔτʼ ἂρ φρένες εἰσὶν ἐναίσιμοι οὔτε νόημα{l]
[l [n}24.41{]}γναμπτὸν ἐνὶ στήθεσσι, λέων δʼ ὣς ἄγρια οἶδεν,{l]
[l [n}24.42{]}ὅς τʼ ἐπεὶ ἂρ μεγάλῃ τε βίῃ καὶ ἀγήνορι θυμῷ{l]
[l [n}24.43{]}εἴξας εἶσʼ ἐπὶ μῆλα βροτῶν ἵνα δαῖτα λάβῃσιν·{l]
[l [n}24.44{]}ὣς Ἀχιλεὺς ἔλεον μὲν ἀπώλεσεν, οὐδέ οἱ αἰδὼς{l]
[l [n}24.45{]}γίγνεται, ἥ τʼ ἄνδρας μέγα σίνεται ἠδʼ ὀνίνησι.{l]
[l [n}24.46{]}μέλλει μέν πού τις καὶ φίλτερον ἄλλον ὀλέσσαι{l]
[l [n}24.47{]}ἠὲ κασίγνητον ὁμογάστριον ἠὲ καὶ υἱόν·{l]
[l [n}24.48{]}ἀλλʼ ἤτοι κλαύσας καὶ ὀδυράμενος μεθέηκε·{l]
[l [n}24.49{]}τλητὸν γὰρ Μοῖραι θυμὸν θέσαν ἀνθρώποισιν.{l]
[l [n}24.50{]}αὐτὰρ ὅ γʼ Ἕκτορα δῖον, ἐπεὶ φίλον ἦτορ ἀπηύρα,{l]
[l [n}24.51{]}ἵππων ἐξάπτων περὶ σῆμʼ ἑτάροιο φίλοιο{l]
[l [n}24.52{]}ἕλκει· οὐ μήν οἱ τό γε κάλλιον οὐδέ τʼ ἄμεινον.{l]
[l [n}24.53{]}μὴ ἀγαθῷ περ ἐόντι νεμεσσηθέωμέν οἱ ἡμεῖς·{l]
[l [n}24.54{]}κωφὴν γὰρ δὴ γαῖαν ἀεικίζει μενεαίνων.{l]{q]{para]
[para}[l [n}24.55{]}τὸν δὲ χολωσαμένη προσέφη λευκώλενος Ἥρη·{l]
[q}[l [n}24.56{]}εἴη κεν καὶ τοῦτο τεὸν ἔπος ἀργυρότοξε{l]
[l [n}24.57{]}εἰ δὴ ὁμὴν Ἀχιλῆϊ καὶ Ἕκτορι θήσετε τιμήν.{l]
[l [n}24.58{]}Ἕκτωρ μὲν θνητός τε γυναῖκά τε θήσατο μαζόν·{l]
[l [n}24.59{]}αὐτὰρ Ἀχιλλεύς ἐστι θεᾶς γόνος, ἣν ἐγὼ αὐτὴ{l]
[l [n}24.60{]}θρέψά τε καὶ ἀτίτηλα καὶ ἀνδρὶ πόρον παράκοιτιν{l]
[l [n}24.61{]}Πηλέϊ, ὃς περὶ κῆρι φίλος γένετʼ ἀθανάτοισι.{l]
[l [n}24.62{]}πάντες δʼ ἀντιάασθε θεοὶ γάμου· ἐν δὲ σὺ τοῖσι{l]
[l [n}24.63{]}δαίνυʼ ἔχων φόρμιγγα κακῶν ἕταρʼ, αἰὲν ἄπιστε.{l]{q]{para]
[para}[l [n}24.64{]}τὴν δʼ ἀπαμειβόμενος προσέφη νεφεληγερέτα Ζεύς·{l]
[q}[l [n}24.65{]}Ἥρη μὴ δὴ πάμπαν ἀποσκύδμαινε θεοῖσιν·{l]
[l [n}24.66{]}οὐ μὲν γὰρ τιμή γε μίʼ ἔσσεται· ἀλλὰ καὶ Ἕκτωρ{l]
[l [n}24.67{]}φίλτατος ἔσκε θεοῖσι βροτῶν οἳ ἐν Ἰλίῳ εἰσίν·{l]
[l [n}24.68{]}ὣς γὰρ ἔμοιγʼ, ἐπεὶ οὔ τι φίλων ἡμάρτανε δώρων.{l]
[l [n}24.69{]}οὐ γάρ μοί ποτε βωμὸς ἐδεύετο δαιτὸς ἐΐσης{l]
[l [n}24.70{]}λοιβῆς τε κνίσης τε· τὸ γὰρ λάχομεν γέρας ἡμεῖς.{l]
[l [n}24.71{]}ἀλλʼ ἤτοι κλέψαι μὲν ἐάσομεν, οὐδέ πῃ ἔστι,{l]
[l [n}24.72{]}λάθρῃ Ἀχιλλῆος θρασὺν Ἕκτορα· ἦ γάρ οἱ αἰεὶ{l]
[l [n}24.73{]}μήτηρ παρμέμβλωκεν ὁμῶς νύκτάς τε καὶ ἦμαρ.{l]
[l [n}24.74{]}ἀλλʼ εἴ τις καλέσειε θεῶν Θέτιν ἆσσον ἐμεῖο,{l]
[l [n}24.75{]}ὄφρά τί οἱ εἴπω πυκινὸν ἔπος, ὥς κεν Ἀχιλλεὺς{l]
[l [n}24.76{]}δώρων ἐκ Πριάμοιο λάχῃ ἀπό θʼ Ἕκτορα λύσῃ.{l]{q]{para]
[para}[l [n}24.77{]}ὣς ἔφατʼ, ὦρτο δὲ Ἶρις ἀελλόπος ἀγγελέουσα,{l]
[l [n}24.78{]}μεσσηγὺς δὲ Σάμου τε καὶ Ἴμβρου παιπαλοέσσης{l]
[l [n}24.79{]}ἔνθορε μείλανι πόντῳ· ἐπεστονάχησε δὲ λίμνη.{l]
[l [n}24.80{]}ἣ δὲ μολυβδαίνῃ ἰκέλη ἐς βυσσὸν ὄρουσεν,{l]
[l [n}24.81{]}ἥ τε κατʼ ἀγραύλοιο βοὸς κέρας ἐμβεβαυῖα{l]
[l [n}24.82{]}ἔρχεται ὠμηστῇσιν ἐπʼ ἰχθύσι κῆρα φέρουσα.{l]
[l [n}24.83{]}εὗρε δʼ ἐνὶ σπῆϊ γλαφυρῷ Θέτιν, ἀμφὶ δʼ ἄρʼ ἄλλαι{l]
[l [n}24.84{]}εἵαθʼ ὁμηγερέες ἅλιαι θεαί· ἣ δʼ ἐνὶ μέσσῃς{l]
[l [n}24.85{]}κλαῖε μόρον οὗ παιδὸς ἀμύμονος, ὅς οἱ ἔμελλε{l]
[l [n}24.86{]}φθίσεσθʼ ἐν Τροίῃ ἐριβώλακι τηλόθι πάτρης.{l]
[l [n}24.87{]}ἀγχοῦ δʼ ἱσταμένη προσέφη πόδας ὠκέα Ἶρις·{l]
[q}[l [n}24.88{]}ὄρσο Θέτι· καλέει Ζεὺς ἄφθιτα μήδεα εἰδώς.{l]{q][l [n}24.89{]}τὴν δʼ ἠμείβετʼ ἔπειτα θεὰ Θέτις ἀργυρόπεζα·{l]
[q}[l [n}24.90{]}τίπτέ με κεῖνος ἄνωγε μέγας θεός; αἰδέομαι δὲ{l]
[l [n}24.91{]}μίσγεσθʼ ἀθανάτοισιν, ἔχω δʼ ἄχεʼ ἄκριτα θυμῷ.{l]
[l [n}24.92{]}εἶμι μέν, οὐδʼ ἅλιον ἔπος ἔσσεται ὅττί κεν εἴπῃ.{l]{q]{para]
[para}[l [n}24.93{]}ὣς ἄρα φωνήσασα κάλυμμʼ ἕλε δῖα θεάων{l]
[l [n}24.94{]}κυάνεον, τοῦ δʼ οὔ τι μελάντερον ἔπλετο ἔσθος.{l]
[l [n}24.95{]}βῆ δʼ ἰέναι, πρόσθεν δὲ ποδήνεμος ὠκέα Ἶρις{l]
[l [n}24.96{]}ἡγεῖτʼ· ἀμφὶ δʼ ἄρα σφι λιάζετο κῦμα θαλάσσης.{l]
[l [n}24.97{]}ἀκτὴν δʼ ἐξαναβᾶσαι ἐς οὐρανὸν ἀϊχθήτην,{l]
[l [n}24.98{]}εὗρον δʼ εὐρύοπα Κρονίδην, περὶ δʼ ἄλλοι ἅπαντες{l]
[l [n}24.99{]}εἵαθʼ ὁμηγερέες μάκαρες θεοὶ αἰὲν ἐόντες.{l]
[l [n}24.100{]}ἣ δʼ ἄρα πὰρ Διὶ πατρὶ καθέζετο, εἶξε δʼ Ἀθήνη.{l]
[l [n}24.101{]}Ἥρη δὲ χρύσεον καλὸν δέπας ἐν χερὶ θῆκε{l]
[l [n}24.102{]}καί ῥʼ εὔφρηνʼ ἐπέεσσι· Θέτις δʼ ὤρεξε πιοῦσα.{l]
[l [n}24.103{]}τοῖσι δὲ μύθων ἦρχε πατὴρ ἀνδρῶν τε θεῶν τε·{l]
[q}[l [n}24.104{]}ἤλυθες Οὔλυμπον δὲ θεὰ Θέτι κηδομένη περ,{l]
[l [n}24.105{]}πένθος ἄλαστον ἔχουσα μετὰ φρεσίν· οἶδα καὶ αὐτός·{l]
[l [n}24.106{]}ἀλλὰ καὶ ὧς ἐρέω τοῦ σʼ εἵνεκα δεῦρο κάλεσσα.{l]
[l [n}24.107{]}ἐννῆμαρ δὴ νεῖκος ἐν ἀθανάτοισιν ὄρωρεν{l]
[l [n}24.108{]}Ἕκτορος ἀμφὶ νέκυι καὶ Ἀχιλλῆϊ πτολιπόρθῳ·{l]
[l [n}24.109{]}κλέψαι δʼ ὀτρύνουσιν ἐΰσκοπον ἀργεϊφόντην·{l]
[l [n}24.110{]}αὐτὰρ ἐγὼ τόδε κῦδος Ἀχιλλῆϊ προτιάπτω{l]
[l [n}24.111{]}αἰδῶ καὶ φιλότητα τεὴν μετόπισθε φυλάσσων.{l]
[l [n}24.112{]}αἶψα μάλʼ ἐς στρατὸν ἐλθὲ καὶ υἱέϊ σῷ ἐπίτειλον·{l]
[l [n}24.113{]}σκύζεσθαί οἱ εἰπὲ θεούς, ἐμὲ δʼ ἔξοχα πάντων{l]
[l [n}24.114{]}ἀθανάτων κεχολῶσθαι, ὅτι φρεσὶ μαινομένῃσιν{l]
[l [n}24.115{]}Ἕκτορʼ ἔχει παρὰ νηυσὶ κορωνίσιν οὐδʼ ἀπέλυσεν,{l]
[l [n}24.116{]}αἴ κέν πως ἐμέ τε δείσῃ ἀπό θʼ Ἕκτορα λύσῃ.{l]
[l [n}24.117{]}αὐτὰρ ἐγὼ Πριάμῳ μεγαλήτορι Ἶριν ἐφήσω{l]
[l [n}24.118{]}λύσασθαι φίλον υἱὸν ἰόντʼ ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}24.119{]}δῶρα δʼ Ἀχιλλῆϊ φερέμεν, τά κε θυμὸν ἰήνῃ.{l]{q]{para]
[para}[l [n}24.120{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε θεὰ Θέτις ἀργυρόπεζα,{l]
[l [n}24.121{]}βῆ δὲ κατʼ Οὐλύμποιο καρήνων ἀΐξασα,{l]
[l [n}24.122{]}ἷξεν δʼ ἐς κλισίην οὗ υἱέος· ἔνθʼ ἄρα τόν γε{l]
[l [n}24.123{]}εὗρʼ ἁδινὰ στενάχοντα· φίλοι δʼ ἀμφʼ αὐτὸν ἑταῖροι{l]
[l [n}24.124{]}ἐσσυμένως ἐπένοντο καὶ ἐντύνοντο ἄριστον·{l]
[l [n}24.125{]}τοῖσι δʼ ὄϊς λάσιος μέγας ἐν κλισίῃ ἱέρευτο.{l]
[l [n}24.126{]}ἣ δὲ μάλʼ ἄγχʼ αὐτοῖο καθέζετο πότνια μήτηρ,{l]
[l [n}24.127{]}χειρί τέ μιν κατέρεξεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}24.128{]}τέκνον ἐμὸν τέο μέχρις ὀδυρόμενος καὶ ἀχεύων{l]
[l [n}24.129{]}σὴν ἔδεαι κραδίην μεμνημένος οὔτέ τι σίτου{l]
[l [n}24.130{]}οὔτʼ εὐνῆς; ἀγαθὸν δὲ γυναικί περ ἐν φιλότητι{l]
[l [n}24.131{]}μίσγεσθʼ· οὐ γάρ μοι δηρὸν βέῃ, ἀλλά τοι ἤδη{l]
[l [n}24.132{]}ἄγχι παρέστηκεν θάνατος καὶ μοῖρα κραταιή.{l]
[l [n}24.133{]}ἀλλʼ ἐμέθεν ξύνες ὦκα, Διὸς δέ τοι ἄγγελός εἰμι·{l]
[l [n}24.134{]}σκύζεσθαι σοί φησι θεούς, ἑὲ δʼ ἔξοχα πάντων{l]
[l [n}24.135{]}ἀθανάτων κεχολῶσθαι, ὅτι φρεσὶ μαινομένῃσιν{l]
[l [n}24.136{]}Ἕκτορʼ ἔχεις παρὰ νηυσὶ κορωνίσιν οὐδʼ ἀπέλυσας.{l]
[l [n}24.137{]}ἀλλʼ ἄγε δὴ λῦσον, νεκροῖο δὲ δέξαι ἄποινα.{l]{q]{para]
[para}[l [n}24.138{]}τὴν δʼ ἀπαμειβόμενος προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}24.139{]}τῇδʼ εἴη· ὃς ἄποινα φέροι καὶ νεκρὸν ἄγοιτο,{l]
[l [n}24.140{]}εἰ δὴ πρόφρονι θυμῷ Ὀλύμπιος αὐτὸς ἀνώγει.{l]{q]{para]
[para}[l [n}24.141{]}ὣς οἵ γʼ ἐν νηῶν ἀγύρει μήτηρ τε καὶ υἱὸς{l]
[l [n}24.142{]}πολλὰ πρὸς ἀλλήλους ἔπεα πτερόεντʼ ἀγόρευον.{l]
[l [n}24.143{]}Ἶριν δʼ ὄτρυνε Κρονίδης εἰς Ἴλιον ἱρήν·{l]
[q}[l [n}24.144{]}βάσκʼ ἴθι Ἶρι ταχεῖα λιποῦσʼ ἕδος Οὐλύμποιο{l]
[l [n}24.145{]}ἄγγειλον Πριάμῳ μεγαλήτορι Ἴλιον εἴσω{l]
[l [n}24.146{]}λύσασθαι φίλον υἱὸν ἰόντʼ ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}24.147{]}δῶρα δʼ Ἀχιλλῆϊ φερέμεν τά κε θυμὸν ἰήνῃ{l]
[l [n}24.148{]}οἶον, μὴ δέ τις ἄλλος ἅμα Τρώων ἴτω ἀνήρ.{l]
[l [n}24.149{]}κῆρύξ τίς οἱ ἕποιτο γεραίτερος, ὅς κʼ ἰθύνοι{l]
[l [n}24.150{]}ἡμιόνους καὶ ἄμαξαν ἐΰτροχον, ἠδὲ καὶ αὖτις{l]
[l [n}24.151{]}νεκρὸν ἄγοι προτὶ ἄστυ, τὸν ἔκτανε δῖος Ἀχιλλεύς.{l]
[l [n}24.152{]}μὴ δέ τί οἱ θάνατος μελέτω φρεσὶ μὴ δέ τι τάρβος·{l]
[l [n}24.153{]}τοῖον γάρ οἱ πομπὸν ὀπάσσομεν ἀργεϊφόντην,{l]
[l [n}24.154{]}ὃς ἄξει εἷός κεν ἄγων Ἀχιλῆϊ πελάσσῃ.{l]
[l [n}24.155{]}αὐτὰρ ἐπὴν ἀγάγῃσιν ἔσω κλισίην Ἀχιλῆος,{l]
[l [n}24.156{]}οὔτʼ αὐτὸς κτενέει ἀπό τʼ ἄλλους πάντας ἐρύξει·{l]
[l [n}24.157{]}οὔτε γάρ ἐστʼ ἄφρων οὔτʼ ἄσκοπος οὔτʼ ἀλιτήμων,{l]
[l [n}24.158{]}ἀλλὰ μάλʼ ἐνδυκέως ἱκέτεω πεφιδήσεται ἀνδρός.{l]{q]{para]
[para}[l [n}24.159{]}ὣς ἔφατʼ, ὦρτο δὲ Ἶρις ἀελλόπος ἀγγελέουσα.{l]
[l [n}24.160{]}ἷξεν δʼ ἐς Πριάμοιο, κίχεν δʼ ἐνοπήν τε γόον τε.{l]
[l [n}24.161{]}παῖδες μὲν πατέρʼ ἀμφὶ καθήμενοι ἔνδοθεν αὐλῆς{l]
[l [n}24.162{]}δάκρυσιν εἵματʼ ἔφυρον, ὃ δʼ ἐν μέσσοισι γεραιὸς{l]
[l [n}24.163{]}ἐντυπὰς ἐν χλαίνῃ κεκαλυμμένος· ἀμφὶ δὲ πολλὴ{l]
[l [n}24.164{]}κόπρος ἔην κεφαλῇ τε καὶ αὐχένι τοῖο γέροντος{l]
[l [n}24.165{]}τήν ῥα κυλινδόμενος καταμήσατο χερσὶν ἑῇσι.{l]
[l [n}24.166{]}θυγατέρες δʼ ἀνὰ δώματʼ ἰδὲ νυοὶ ὠδύροντο{l]
[l [n}24.167{]}τῶν μιμνησκόμεναι οἳ δὴ πολέες τε καὶ ἐσθλοὶ{l]
[l [n}24.168{]}χερσὶν ὑπʼ Ἀργείων κέατο ψυχὰς ὀλέσαντες.{l]
[l [n}24.169{]}στῆ δὲ παρὰ Πρίαμον Διὸς ἄγγελος, ἠδὲ προσηύδα{l]
[l [n}24.170{]}τυτθὸν φθεγξαμένη· τὸν δὲ τρόμος ἔλλαβε γυῖα·{l]
[q}[l [n}24.171{]}θάρσει Δαρδανίδη Πρίαμε φρεσί, μὴ δέ τι τάρβει·{l]
[l [n}24.172{]}οὐ μὲν γάρ τοι ἐγὼ κακὸν ὀσσομένη τόδʼ ἱκάνω{l]
[l [n}24.173{]}ἀλλʼ ἀγαθὰ φρονέουσα· Διὸς δέ τοι ἄγγελός εἰμι,{l]
[l [n}24.174{]}ὅς σευ ἄνευθεν ἐὼν μέγα κήδεται ἠδʼ ἐλεαίρει.{l]
[l [n}24.175{]}λύσασθαί σʼ ἐκέλευσεν Ὀλύμπιος Ἕκτορα δῖον,{l]
[l [n}24.176{]}δῶρα δʼ Ἀχιλλῆϊ φερέμεν τά κε θυμὸν ἰήνῃ{l]
[l [n}24.177{]}οἶον, μὴ δέ τις ἄλλος ἅμα Τρώων ἴτω ἀνήρ.{l]
[l [n}24.178{]}κῆρύξ τίς τοι ἕποιτο γεραίτερος, ὅς κʼ ἰθύνοι{l]
[l [n}24.179{]}ἡμιόνους καὶ ἄμαξαν ἐΰτροχον, ἠδὲ καὶ αὖτις{l]
[l [n}24.180{]}νεκρὸν ἄγοι προτὶ ἄστυ, τὸν ἔκτανε δῖος Ἀχιλλεύς.{l]
[l [n}24.181{]}μὴ δέ τί τοι θάνατος μελέτω φρεσὶ μηδέ τι τάρβος·{l]
[l [n}24.182{]}τοῖος γάρ τοι πομπὸς ἅμʼ ἕψεται ἀργεϊφόντης,{l]
[l [n}24.183{]}ὅς σʼ ἄξει εἷός κεν ἄγων Ἀχιλῆϊ πελάσσῃ.{l]
[l [n}24.184{]}αὐτὰρ ἐπὴν ἀγάγῃσιν ἔσω κλισίην Ἀχιλῆος,{l]
[l [n}24.185{]}οὔτʼ αὐτὸς κτενέει ἀπό τʼ ἄλλους πάντας ἐρύξει·{l]
[l [n}24.186{]}οὔτε γάρ ἔστʼ ἄφρων οὔτʼ ἄσκοπος οὔτʼ ἀλιτήμων,{l]
[l [n}24.187{]}ἀλλὰ μάλʼ ἐνδυκέως ἱκέτεω πεφιδήσεται ἀνδρός.{l]{q]{para]
[para}[l [n}24.188{]}ἣ μὲν ἄρʼ ὣς εἰποῦσʼ ἀπέβη πόδας ὠκέα Ἶρις,{l]
[l [n}24.189{]}αὐτὰρ ὅ γʼ υἷας ἄμαξαν ἐΰτροχον ἡμιονείην{l]
[l [n}24.190{]}ὁπλίσαι ἠνώγει, πείρινθα δὲ δῆσαι ἐπʼ αὐτῆς.{l]
[l [n}24.191{]}αὐτὸς δʼ ἐς θάλαμον κατεβήσετο κηώεντα{l]
[l [n}24.192{]}κέδρινον ὑψόροφον, ὃς γλήνεα πολλὰ κεχάνδει·{l]
[l [n}24.193{]}ἐς δʼ ἄλοχον Ἑκάβην ἐκαλέσσατο φώνησέν τε·{l]
[q}[l [n}24.194{]}δαιμονίη Διόθεν μοι Ὀλύμπιος ἄγγελος ἦλθε{l]
[l [n}24.195{]}λύσασθαι φίλον υἱὸν ἰόντʼ ἐπὶ νῆας Ἀχαιῶν,{l]
[l [n}24.196{]}δῶρα δʼ Ἀχιλλῆϊ φερέμεν τά κε θυμὸν ἰήνῃ.{l]
[l [n}24.197{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ τί τοι φρεσὶν εἴδεται εἶναι;{l]
[l [n}24.198{]}αἰνῶς γάρ μʼ αὐτόν γε μένος καὶ θυμὸς ἄνωγε{l]
[l [n}24.199{]}κεῖσʼ ἰέναι ἐπὶ νῆας ἔσω στρατὸν εὐρὺν Ἀχαιῶν.{l]{q]{para]
[para}[l [n}24.200{]}ὣς φάτο, κώκυσεν δὲ γυνὴ καὶ ἀμείβετο μύθῳ·{l]
[q}[l [n}24.201{]}ὤ μοι πῇ δή τοι φρένες οἴχονθʼ, ᾗς τὸ πάρος περ{l]
[l [n}24.202{]}ἔκλεʼ ἐπʼ ἀνθρώπους ξείνους ἠδʼ οἷσιν ἀνάσσεις;{l]
[l [n}24.203{]}πῶς ἐθέλεις ἐπὶ νῆας Ἀχαιῶν ἐλθέμεν οἶος{l]
[l [n}24.204{]}ἀνδρὸς ἐς ὀφθαλμοὺς ὅς τοι πολέας τε καὶ ἐσθλοὺς{l]
[l [n}24.205{]}υἱέας ἐξενάριξε· σιδήρειόν νύ τοι ἦτορ.{l]
[l [n}24.206{]}εἰ γάρ σʼ αἱρήσει καὶ ἐσόψεται ὀφθαλμοῖσιν{l]
[l [n}24.207{]}ὠμηστὴς καὶ ἄπιστος ἀνὴρ ὅ γε οὔ σʼ ἐλεήσει,{l]
[l [n}24.208{]}οὐδέ τί σʼ αἰδέσεται. νῦν δὲ κλαίωμεν ἄνευθεν{l]
[l [n}24.209{]}ἥμενοι ἐν μεγάρῳ· τῷ δʼ ὥς ποθι Μοῖρα κραταιὴ{l]
[l [n}24.210{]}γιγνομένῳ ἐπένησε λίνῳ, ὅτε μιν τέκον αὐτή,{l]
[l [n}24.211{]}ἀργίποδας κύνας ἆσαι ἑῶν ἀπάνευθε τοκήων{l]
[l [n}24.212{]}ἀνδρὶ πάρα κρατερῷ, τοῦ ἐγὼ μέσον ἧπαρ ἔχοιμι{l]
[l [n}24.213{]}ἐσθέμεναι προσφῦσα· τότʼ ἄντιτα ἔργα γένοιτο{l]
[l [n}24.214{]}παιδὸς ἐμοῦ, ἐπεὶ οὔ ἑ κακιζόμενόν γε κατέκτα,{l]
[l [n}24.215{]}ἀλλὰ πρὸ Τρώων καὶ Τρωϊάδων βαθυκόλπων{l]
[l [n}24.216{]}ἑσταότʼ οὔτε φόβου μεμνημένον οὔτʼ ἀλεωρῆς.{l]{q]{para]
[para}[l [n}24.217{]}τὴν δʼ αὖτε προσέειπε γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.218{]}μή μʼ ἐθέλοντʼ ἰέναι κατερύκανε, μὴ δέ μοι αὐτὴ{l]
[l [n}24.219{]}ὄρνις ἐνὶ μεγάροισι κακὸς πέλευ· οὐδέ με πείσεις.{l]
[l [n}24.220{]}εἰ μὲν γάρ τίς μʼ ἄλλος ἐπιχθονίων ἐκέλευεν,{l]
[l [n}24.221{]}ἢ οἳ μάντιές εἰσι θυοσκόοι ἢ ἱερῆες,{l]
[l [n}24.222{]}ψεῦδός κεν φαῖμεν καὶ νοσφιζοίμεθα μᾶλλον·{l]
[l [n}24.223{]}νῦν δʼ, αὐτὸς γὰρ ἄκουσα θεοῦ καὶ ἐσέδρακον ἄντην,{l]
[l [n}24.224{]}εἶμι καὶ οὐχ ἅλιον ἔπος ἔσσεται. εἰ δέ μοι αἶσα{l]
[l [n}24.225{]}τεθνάμεναι παρὰ νηυσὶν Ἀχαιῶν χαλκοχιτώνων{l]
[l [n}24.226{]}βούλομαι· αὐτίκα γάρ με κατακτείνειεν Ἀχιλλεὺς{l]
[l [n}24.227{]}ἀγκὰς ἑλόντʼ ἐμὸν υἱόν, ἐπὴν γόου ἐξ ἔρον εἵην.{l]{q]{para]
[para}[l [n}24.228{]}ἦ καὶ φωριαμῶν ἐπιθήματα κάλʼ ἀνέῳγεν·{l]
[l [n}24.229{]}ἔνθεν δώδεκα μὲν περικαλλέας ἔξελε πέπλους,{l]
[l [n}24.230{]}δώδεκα δʼ ἁπλοΐδας χλαίνας, τόσσους δὲ τάπητας,{l]
[l [n}24.231{]}τόσσα δὲ φάρεα λευκά, τόσους δʼ ἐπὶ τοῖσι χιτῶνας.{l]
[l [n}24.232{]}χρυσοῦ δὲ στήσας ἔφερεν δέκα πάντα τάλαντα,{l]
[l [n}24.233{]}ἐκ δὲ δύʼ αἴθωνας τρίποδας, πίσυρας δὲ λέβητας,{l]
[l [n}24.234{]}ἐκ δὲ δέπας περικαλλές, ὅ οἱ Θρῇκες πόρον ἄνδρες{l]
[l [n}24.235{]}ἐξεσίην ἐλθόντι μέγα κτέρας· οὐδέ νυ τοῦ περ{l]
[l [n}24.236{]}φείσατʼ ἐνὶ μεγάροις ὃ γέρων, περὶ δʼ ἤθελε θυμῷ{l]
[l [n}24.237{]}λύσασθαι φίλον υἱόν. ὃ δὲ Τρῶας μὲν ἅπαντας{l]
[l [n}24.238{]}αἰθούσης ἀπέεργεν ἔπεσσʼ αἰσχροῖσιν ἐνίσσων·{l]
[q}[l [n}24.239{]}ἔρρετε λωβητῆρες ἐλεγχέες· οὔ νυ καὶ ὑμῖν{l]
[l [n}24.240{]}οἴκοι ἔνεστι γόος, ὅτι μʼ ἤλθετε κηδήσοντες;{l]
[l [n}24.241{]}ἦ ὀνόσασθʼ ὅτι μοι Κρονίδης Ζεὺς ἄλγεʼ ἔδωκε{l]
[l [n}24.242{]}παῖδʼ ὀλέσαι τὸν ἄριστον; ἀτὰρ γνώσεσθε καὶ ὔμμες·{l]
[l [n}24.243{]}ῥηΐτεροι γὰρ μᾶλλον Ἀχαιοῖσιν δὴ ἔσεσθε{l]
[l [n}24.244{]}κείνου τεθνηῶτος ἐναιρέμεν. αὐτὰρ ἔγωγε{l]
[l [n}24.245{]}πρὶν ἀλαπαζομένην τε πόλιν κεραϊζομένην τε{l]
[l [n}24.246{]}ὀφθαλμοῖσιν ἰδεῖν βαίην δόμον Ἄϊδος εἴσω.{l]{q]{para]
[para}[l [n}24.247{]}ἦ καὶ σκηπανίῳ δίεπʼ ἀνέρας· οἳ δʼ ἴσαν ἔξω{l]
[l [n}24.248{]}σπερχομένοιο γέροντος· ὃ δʼ υἱάσιν οἷσιν ὁμόκλα{l]
[l [n}24.249{]}νεικείων Ἕλενόν τε Πάριν τʼ Ἀγάθωνά τε δῖον{l]
[l [n}24.250{]}Πάμμονά τʼ Ἀντίφονόν τε βοὴν ἀγαθόν τε Πολίτην{l]
[l [n}24.251{]}Δηΐφοβόν τε καὶ Ἱππόθοον καὶ δῖον Ἀγαυόν·{l]
[l [n}24.252{]}ἐννέα τοῖς ὃ γεραιὸς ὁμοκλήσας ἐκέλευε·{l]
[q}[l [n}24.253{]}σπεύσατέ μοι κακὰ τέκνα κατηφόνες· αἴθʼ ἅμα πάντες{l]
[l [n}24.254{]}Ἕκτορος ὠφέλετʼ ἀντὶ θοῇς ἐπὶ νηυσὶ πεφάσθαι.{l]
[l [n}24.255{]}ὤ μοι ἐγὼ πανάποτμος, ἐπεὶ τέκον υἷας ἀρίστους{l]
[l [n}24.256{]}Τροίῃ ἐν εὐρείῃ, τῶν δʼ οὔ τινά φημι λελεῖφθαι,{l]
[l [n}24.257{]}Μήστορά τʼ ἀντίθεον καὶ Τρωΐλον ἱππιοχάρμην{l]
[l [n}24.258{]}Ἕκτορά θʼ, ὃς θεὸς ἔσκε μετʼ ἀνδράσιν, οὐδὲ ἐῴκει{l]
[l [n}24.259{]}ἀνδρός γε θνητοῦ πάϊς ἔμμεναι ἀλλὰ θεοῖο.{l]
[l [n}24.260{]}τοὺς μὲν ἀπώλεσʼ Ἄρης, τὰ δʼ ἐλέγχεα πάντα λέλειπται{l]
[l [n}24.261{]}ψεῦσταί τʼ ὀρχησταί τε χοροιτυπίῃσιν ἄριστοι{l]
[l [n}24.262{]}ἀρνῶν ἠδʼ ἐρίφων ἐπιδήμιοι ἁρπακτῆρες.{l]
[l [n}24.263{]}οὐκ ἂν δή μοι ἄμαξαν ἐφοπλίσσαιτε τάχιστα,{l]
[l [n}24.264{]}ταῦτά τε πάντʼ ἐπιθεῖτε, ἵνα πρήσσωμεν ὁδοῖο;{l]{q]{para]
[para}[l [n}24.265{]}ὣς ἔφαθʼ, οἳ δʼ ἄρα πατρὸς ὑποδείσαντες ὁμοκλὴν{l]
[l [n}24.266{]}ἐκ μὲν ἄμαξαν ἄειραν ἐΰτροχον ἡμιονείην{l]
[l [n}24.267{]}καλὴν πρωτοπαγέα, πείρινθα δὲ δῆσαν ἐπʼ αὐτῆς,{l]
[l [n}24.268{]}κὰδ δʼ ἀπὸ πασσαλόφι ζυγὸν ᾕρεον ἡμιόνειον{l]
[l [n}24.269{]}πύξινον ὀμφαλόεν εὖ οἰήκεσσιν ἀρηρός·{l]
[l [n}24.270{]}ἐκ δʼ ἔφερον ζυγόδεσμον ἅμα ζυγῷ ἐννεάπηχυ.{l]
[l [n}24.271{]}καὶ τὸ μὲν εὖ κατέθηκαν ἐϋξέστῳ ἐπὶ ῥυμῷ{l]
[l [n}24.272{]}πέζῃ ἔπι πρώτῃ, ἐπὶ δὲ κρίκον ἕστορι βάλλον,{l]
[l [n}24.273{]}τρὶς δʼ ἑκάτερθεν ἔδησαν ἐπʼ ὀμφαλόν, αὐτὰρ ἔπειτα{l]
[l [n}24.274{]}ἑξείης κατέδησαν, ὑπὸ γλωχῖνα δʼ ἔκαμψαν.{l]
[l [n}24.275{]}ἐκ θαλάμου δὲ φέροντες ἐϋξέστης ἐπʼ ἀπήνης{l]
[l [n}24.276{]}νήεον Ἑκτορέης κεφαλῆς ἀπερείσιʼ ἄποινα,{l]
[l [n}24.277{]}ζεῦξαν δʼ ἡμιόνους κρατερώνυχας ἐντεσιεργούς,{l]
[l [n}24.278{]}τούς ῥά ποτε Πριάμῳ Μυσοὶ δόσαν ἀγλαὰ δῶρα.{l]
[l [n}24.279{]}ἵππους δὲ Πριάμῳ ὕπαγον ζυγόν, οὓς ὃ γεραιὸς{l]
[l [n}24.280{]}αὐτὸς ἔχων ἀτίταλλεν ἐϋξέστῃ ἐπὶ φάτνῃ.{l]{para]
[para}[l [n}24.281{]}τὼ μὲν ζευγνύσθην ἐν δώμασιν ὑψηλοῖσι{l]
[l [n}24.282{]}κῆρυξ καὶ Πρίαμος πυκινὰ φρεσὶ μήδεʼ ἔχοντες·{l]
[l [n}24.283{]}ἀγχίμολον δέ σφʼ ἦλθʼ Ἑκάβη τετιηότι θυμῷ{l]
[l [n}24.284{]}οἶνον ἔχουσʼ ἐν χειρὶ μελίφρονα δεξιτερῆφι{l]
[l [n}24.285{]}χρυσέῳ ἐν δέπαϊ, ὄφρα λείψαντε κιοίτην·{l]
[l [n}24.286{]}στῆ δʼ ἵππων προπάροιθεν ἔπος τʼ ἔφατʼ ἔκ τʼ ὀνόμαζε·{l]
[q}[l [n}24.287{]}τῆ σπεῖσον Διὶ πατρί, καὶ εὔχεο οἴκαδʼ ἱκέσθαι{l]
[l [n}24.288{]}ἂψ ἐκ δυσμενέων ἀνδρῶν, ἐπεὶ ἂρ σέ γε θυμὸς{l]
[l [n}24.289{]}ὀτρύνει ἐπὶ νῆας ἐμεῖο μὲν οὐκ ἐθελούσης.{l]
[l [n}24.290{]}ἀλλʼ εὔχεο σύ γʼ ἔπειτα κελαινεφέϊ Κρονίωνι{l]
[l [n}24.291{]}Ἰδαίῳ, ὅς τε Τροίην κατὰ πᾶσαν ὁρᾶται,{l]
[l [n}24.292{]}αἴτει δʼ οἰωνὸν ταχὺν ἄγγελον, ὅς τέ οἱ αὐτῷ{l]
[l [n}24.293{]}φίλτατος οἰωνῶν, καί εὑ κράτος ἐστὶ μέγιστον,{l]
[l [n}24.294{]}δεξιόν, ὄφρά μιν αὐτὸς ἐν ὀφθαλμοῖσι νοήσας{l]
[l [n}24.295{]}τῷ πίσυνος ἐπὶ νῆας ἴῃς Δαναῶν ταχυπώλων.{l]
[l [n}24.296{]}εἰ δέ τοι οὐ δώσει ἑὸν ἄγγελον εὐρύοπα Ζεύς,{l]
[l [n}24.297{]}οὐκ ἂν ἔγωγέ σʼ ἔπειτα ἐποτρύνουσα κελοίμην{l]
[l [n}24.298{]}νῆας ἐπʼ Ἀργείων ἰέναι μάλα περ μεμαῶτα.{l]{q]{para]
[para}[l [n}24.299{]}τὴν δʼ ἀπαμειβόμενος προσέφη Πρίαμος θεοειδής·{l]
[q}[l [n}24.300{]}ὦ γύναι οὐ μέν τοι τόδʼ ἐφιεμένῃ ἀπιθήσω.{l]
[l [n}24.301{]}ἐσθλὸν γὰρ Διὶ χεῖρας ἀνασχέμεν αἴ κʼ ἐλεήσῃ.{l]{q]{para]
[para}[l [n}24.302{]}ἦ ῥα καὶ ἀμφίπολον ταμίην ὄτρυνʼ ὃ γεραιὸς{l]
[l [n}24.303{]}χερσὶν ὕδωρ ἐπιχεῦαι ἀκήρατον· ἣ δὲ παρέστη{l]
[l [n}24.304{]}χέρνιβον ἀμφίπολος πρόχοόν θʼ ἅμα χερσὶν ἔχουσα.{l]
[l [n}24.305{]}νιψάμενος δὲ κύπελλον ἐδέξατο ἧς ἀλόχοιο·{l]
[l [n}24.306{]}εὔχετʼ ἔπειτα στὰς μέσῳ ἕρκεϊ, λεῖβε δὲ οἶνον{l]
[l [n}24.307{]}οὐρανὸν εἰσανιδών, καὶ φωνήσας ἔπος ηὔδα·{l]
[q}[l [n}24.308{]}Ζεῦ πάτερ Ἴδηθεν μεδέων κύδιστε μέγιστε{l]
[l [n}24.309{]}δός μʼ ἐς Ἀχιλλῆος φίλον ἐλθεῖν ἠδʼ ἐλεεινόν,{l]
[l [n}24.310{]}πέμψον δʼ οἰωνὸν ταχὺν ἄγγελον, ὅς τε σοὶ αὐτῷ{l]
[l [n}24.311{]}φίλτατος οἰωνῶν, καί εὑ κράτος ἐστὶ μέγιστον,{l]
[l [n}24.312{]}δεξιόν, ὄφρά μιν αὐτὸς ἐν ὀφθαλμοῖσι νοήσας{l]
[l [n}24.313{]}τῷ πίσυνος ἐπὶ νῆας ἴω Δαναῶν ταχυπώλων.{l]{q]{para]
[para}[l [n}24.314{]}ὣς ἔφατʼ εὐχόμενος, τοῦ δʼ ἔκλυε μητίετα Ζεὺς{l]
[l [n}24.315{]}αὐτίκα δʼ αἰετὸν ἧκε τελειότατον πετεηνῶν{l]
[l [n}24.316{]}μόρφνον θηρητῆρʼ ὃν καὶ περκνὸν καλέουσιν.{l]
[l [n}24.317{]}ὅσση δʼ ὑψορόφοιο θύρη θαλάμοιο τέτυκται{l]
[l [n}24.318{]}ἀνέρος ἀφνειοῖο ἐῢ κληῗσʼ ἀραρυῖα,{l]
[l [n}24.319{]}τόσσʼ ἄρα τοῦ ἑκάτερθεν ἔσαν πτερά· εἴσατο δέ σφι{l]
[l [n}24.320{]}δεξιὸς ἀΐξας διὰ ἄστεος· οἳ δὲ ἰδόντες{l]
[l [n}24.321{]}γήθησαν, καὶ πᾶσιν ἐνὶ φρεσὶ θυμὸς ἰάνθη.{l]{para]
[para}[l [n}24.322{]}σπερχόμενος δʼ ὃ γεραιὸς ἑοῦ ἐπεβήσετο δίφρου,{l]
[l [n}24.323{]}ἐκ δʼ ἔλασε προθύροιο καὶ αἰθούσης ἐριδούπου.{l]
[l [n}24.324{]}πρόσθε μὲν ἡμίονοι ἕλκον τετράκυκλον ἀπήνην,{l]
[l [n}24.325{]}τὰς Ἰδαῖος ἔλαυνε δαΐφρων· αὐτὰρ ὄπισθεν{l]
[l [n}24.326{]}ἵπποι, τοὺς ὃ γέρων ἐφέπων μάστιγι κέλευε{l]
[l [n}24.327{]}καρπαλίμως κατὰ ἄστυ· φίλοι δʼ ἅμα πάντες ἕποντο{l]
[l [n}24.328{]}πόλλʼ ὀλοφυρόμενοι ὡς εἰ θάνατον δὲ κιόντα.{l]
[l [n}24.329{]}οἳ δʼ ἐπεὶ οὖν πόλιος κατέβαν, πεδίον δʼ ἀφίκοντο,{l]
[l [n}24.330{]}οἳ μὲν ἄρʼ ἄψορροι προτὶ Ἴλιον ἀπονέοντο{l]
[l [n}24.331{]}παῖδες καὶ γαμβροί, τὼ δʼ οὐ λάθον εὐρύοπα Ζῆν{l]
[l [n}24.332{]}ἐς πεδίον προφανέντε· ἰδὼν δʼ ἐλέησε γέροντα,{l]
[l [n}24.333{]}αἶψα δʼ ἄρʼ Ἑρμείαν υἱὸν φίλον ἀντίον ηὔδα·{l]
[q}[l [n}24.334{]}Ἑρμεία, σοὶ γάρ τε μάλιστά γε φίλτατόν ἐστιν{l]
[l [n}24.335{]}ἀνδρὶ ἑταιρίσσαι, καί τʼ ἔκλυες ᾧ κʼ ἐθέλῃσθα,{l]
[l [n}24.336{]}βάσκʼ ἴθι καὶ Πρίαμον κοίλας ἐπὶ νῆας Ἀχαιῶν{l]
[l [n}24.337{]}ὣς ἄγαγʼ, ὡς μήτʼ ἄρ τις ἴδῃ μήτʼ ἄρ τε νοήσῃ{l]
[l [n}24.338{]}τῶν ἄλλων Δαναῶν, πρὶν Πηλεΐωνα δʼ ἱκέσθαι.{l]{q]{para]
[para}[l [n}24.339{]}ὣς ἔφατʼ, οὐδʼ ἀπίθησε διάκτορος ἀργεϊφόντης.{l]
[l [n}24.340{]}αὐτίκʼ ἔπειθʼ ὑπὸ ποσσὶν ἐδήσατο καλὰ πέδιλα{l]
[l [n}24.341{]}ἀμβρόσια χρύσεια, τά μιν φέρον ἠμὲν ἐφʼ ὑγρὴν{l]
[l [n}24.342{]}ἠδʼ ἐπʼ ἀπείρονα γαῖαν ἅμα πνοιῇς ἀνέμοιο·{l]
[l [n}24.343{]}εἵλετο δὲ ῥάβδον, τῇ τʼ ἀνδρῶν ὄμματα θέλγει{l]
[l [n}24.344{]}ὧν ἐθέλει, τοὺς δʼ αὖτε καὶ ὑπνώοντας ἐγείρει·{l]
[l [n}24.345{]}τὴν μετὰ χερσὶν ἔχων πέτετο κρατὺς ἀργεϊφόντης.{l]
[l [n}24.346{]}αἶψα δʼ ἄρα Τροίην τε καὶ Ἑλλήσποντον ἵκανε,{l]
[l [n}24.347{]}βῆ δʼ ἰέναι κούρῳ αἰσυμνητῆρι ἐοικὼς{l]
[l [n}24.348{]}πρῶτον ὑπηνήτῃ, τοῦ περ χαριεστάτη ἥβη.{l]{para]
[para}[l [n}24.349{]}οἳ δʼ ἐπεὶ οὖν μέγα σῆμα παρὲξ Ἴλοιο ἔλασσαν,{l]
[l [n}24.350{]}στῆσαν ἄρʼ ἡμιόνους τε καὶ ἵππους ὄφρα πίοιεν{l]
[l [n}24.351{]}ἐν ποταμῷ· δὴ γὰρ καὶ ἐπὶ κνέφας ἤλυθε γαῖαν.{l]
[l [n}24.352{]}τὸν δʼ ἐξ ἀγχιμόλοιο ἰδὼν ἐφράσσατο κῆρυξ{l]
[l [n}24.353{]}Ἑρμείαν, ποτὶ δὲ Πρίαμον φάτο φώνησέν τε·{l]
[q}[l [n}24.354{]}φράζεο Δαρδανίδη· φραδέος νόου ἔργα τέτυκται.{l]
[l [n}24.355{]}ἄνδρʼ ὁρόω, τάχα δʼ ἄμμε διαρραίσεσθαι ὀΐω.{l]
[l [n}24.356{]}ἀλλʼ ἄγε δὴ φεύγωμεν ἐφʼ ἵππων, ἤ μιν ἔπειτα{l]
[l [n}24.357{]}γούνων ἁψάμενοι λιτανεύσομεν αἴ κʼ ἐλεήσῃ.{l]{q]{para]
[para}[l [n}24.358{]}ὣς φάτο, σὺν δὲ γέροντι νόος χύτο, δείδιε δʼ αἰνῶς,{l]
[l [n}24.359{]}ὀρθαὶ δὲ τρίχες ἔσταν ἐνὶ γναμπτοῖσι μέλεσσι,{l]
[l [n}24.360{]}στῆ δὲ ταφών· αὐτὸς δʼ ἐριούνιος ἐγγύθεν ἐλθὼν{l]
[l [n}24.361{]}χεῖρα γέροντος ἑλὼν ἐξείρετο καὶ προσέειπε·{l]
[q}[l [n}24.362{]}πῇ πάτερ ὧδʼ ἵππους τε καὶ ἡμιόνους ἰθύνεις{l]
[l [n}24.363{]}νύκτα διʼ ἀμβροσίην, ὅτε θʼ εὕδουσι βροτοὶ ἄλλοι;{l]
[l [n}24.364{]}οὐδὲ σύ γʼ ἔδεισας μένεα πνείοντας Ἀχαιούς,{l]
[l [n}24.365{]}οἵ τοι δυσμενέες καὶ ἀνάρσιοι ἐγγὺς ἔασι;{l]
[l [n}24.366{]}τῶν εἴ τίς σε ἴδοιτο θοὴν διὰ νύκτα μέλαιναν{l]
[l [n}24.367{]}τοσσάδʼ ὀνείατʼ ἄγοντα, τίς ἂν δή τοι νόος εἴη;{l]
[l [n}24.368{]}οὔτʼ αὐτὸς νέος ἐσσί, γέρων δέ τοι οὗτος ὀπηδεῖ,{l]
[l [n}24.369{]}ἄνδρʼ ἀπαμύνασθαι, ὅτε τις πρότερος χαλεπήνῃ.{l]
[l [n}24.370{]}ἀλλʼ ἐγὼ οὐδέν σε ῥέξω κακά, καὶ δέ κεν ἄλλον{l]
[l [n}24.371{]}σεῦ ἀπαλεξήσαιμι· φίλῳ δέ σε πατρὶ ἐΐσκω.{l]{q]{para]
[para}[l [n}24.372{]}τὸν δʼ ἠμείβετʼ ἔπειτα γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.373{]}οὕτω πῃ τάδε γʼ ἐστὶ φίλον τέκος ὡς ἀγορεύεις.{l]
[l [n}24.374{]}ἀλλʼ ἔτι τις καὶ ἐμεῖο θεῶν ὑπερέσχεθε χεῖρα,{l]
[l [n}24.375{]}ὅς μοι τοιόνδʼ ἧκεν ὁδοιπόρον ἀντιβολῆσαι{l]
[l [n}24.376{]}αἴσιον, οἷος δὴ σὺ δέμας καὶ εἶδος ἀγητός,{l]
[l [n}24.377{]}πέπνυσαί τε νόῳ, μακάρων δʼ ἔξεσσι τοκήων.{l]{q]{para]
[para}[l [n}24.378{]}τὸν δʼ αὖτε προσέειπε διάκτορος ἀργεϊφόντης·{l]
[q}[l [n}24.379{]}ναὶ δὴ ταῦτά γε πάντα γέρον κατὰ μοῖραν ἔειπες.{l]
[l [n}24.380{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ καὶ ἀτρεκέως κατάλεξον,{l]
[l [n}24.381{]}ἠέ πῃ ἐκπέμπεις κειμήλια πολλὰ καὶ ἐσθλὰ{l]
[l [n}24.382{]}ἄνδρας ἐς ἀλλοδαποὺς ἵνα περ τάδε τοι σόα μίμνῃ,{l]
[l [n}24.383{]}ἦ ἤδη πάντες καταλείπετε Ἴλιον ἱρὴν{l]
[l [n}24.384{]}δειδιότες· τοῖος γὰρ ἀνὴρ ὤριστος ὄλωλε{l]
[l [n}24.385{]}σὸς πάϊς· οὐ μὲν γάρ τι μάχης ἐπιδεύετʼ Ἀχαιῶν.{l]{q]{para]
[para}[l [n}24.386{]}τὸν δʼ ἠμείβετʼ ἔπειτα γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.387{]}τίς δὲ σύ ἐσσι φέριστε τέων δʼ ἔξεσσι τοκήων;{l]
[l [n}24.388{]}ὥς μοι καλὰ τὸν οἶτον ἀπότμου παιδὸς ἔνισπες.{l]{q]{para]
[para}[l [n}24.389{]}τὸν δʼ αὖτε προσέειπε διάκτορος ἀργεϊφόντης·{l]
[q}[l [n}24.390{]}πειρᾷ ἐμεῖο γεραιὲ καὶ εἴρεαι Ἕκτορα δῖον.{l]
[l [n}24.391{]}τὸν μὲν ἐγὼ μάλα πολλὰ μάχῃ ἔνι κυδιανείρῃ{l]
[l [n}24.392{]}ὀφθαλμοῖσιν ὄπωπα, καὶ εὖτʼ ἐπὶ νηυσὶν ἐλάσσας{l]
[l [n}24.393{]}Ἀργείους κτείνεσκε δαΐζων ὀξέϊ χαλκῷ·{l]
[l [n}24.394{]}ἡμεῖς δʼ ἑσταότες θαυμάζομεν· οὐ γὰρ Ἀχιλλεὺς{l]
[l [n}24.395{]}εἴα μάρνασθαι κεχολωμένος Ἀτρεΐωνι.{l]
[l [n}24.396{]}τοῦ γὰρ ἐγὼ θεράπων, μία δʼ ἤγαγε νηῦς εὐεργής·{l]
[l [n}24.397{]}Μυρμιδόνων δʼ ἔξειμι, πατὴρ δέ μοί ἐστι Πολύκτωρ.{l]
[l [n}24.398{]}ἀφνειὸς μὲν ὅ γʼ ἐστί, γέρων δὲ δὴ ὡς σύ περ ὧδε,{l]
[l [n}24.399{]}ἓξ δέ οἱ υἷες ἔασιν, ἐγὼ δέ οἱ ἕβδομός εἰμι·{l]
[l [n}24.400{]}τῶν μέτα παλλόμενος κλήρῳ λάχον ἐνθάδʼ ἕπεσθαι.{l]
[l [n}24.401{]}νῦν δʼ ἦλθον πεδίον δʼ ἀπὸ νηῶν· ἠῶθεν γὰρ{l]
[l [n}24.402{]}θήσονται περὶ ἄστυ μάχην ἑλίκωπες Ἀχαιοί.{l]
[l [n}24.403{]}ἀσχαλόωσι γὰρ οἵδε καθήμενοι, οὐδὲ δύνανται{l]
[l [n}24.404{]}ἴσχειν ἐσσυμένους πολέμου βασιλῆες Ἀχαιῶν.{l]{q]{para]
[para}[l [n}24.405{]}τὸν δʼ ἠμείβετʼ ἔπειτα γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.406{]}εἰ μὲν δὴ θεράπων Πηληϊάδεω Ἀχιλῆος{l]
[l [n}24.407{]}εἴς, ἄγε δή μοι πᾶσαν ἀληθείην κατάλεξον,{l]
[l [n}24.408{]}ἢ ἔτι πὰρ νήεσσιν ἐμὸς πάϊς, ἦέ μιν ἤδη{l]
[l [n}24.409{]}ᾗσι κυσὶν μελεϊστὶ ταμὼν προύθηκεν Ἀχιλλεύς.{l]{q]{para]
[para}[l [n}24.410{]}τὸν δʼ αὖτε προσέειπε διάκτορος ἀργεϊφόντης·{l]
[q}[l [n}24.411{]}ὦ γέρον οὔ πω τόν γε κύνες φάγον οὐδʼ οἰωνοί,{l]
[l [n}24.412{]}ἀλλʼ ἔτι κεῖνος κεῖται Ἀχιλλῆος παρὰ νηῒ{l]
[l [n}24.413{]}αὔτως ἐν κλισίῃσι· δυωδεκάτη δέ οἱ ἠὼς{l]
[l [n}24.414{]}κειμένῳ, οὐδέ τί οἱ χρὼς σήπεται, οὐδέ μιν εὐλαὶ{l]
[l [n}24.415{]}ἔσθουσʼ, αἵ ῥά τε φῶτας ἀρηϊφάτους κατέδουσιν.{l]
[l [n}24.416{]}ἦ μέν μιν περὶ σῆμα ἑοῦ ἑτάροιο φίλοιο{l]
[l [n}24.417{]}ἕλκει ἀκηδέστως ἠὼς ὅτε δῖα φανήῃ,{l]
[l [n}24.418{]}οὐδέ μιν αἰσχύνει· θηοῖό κεν αὐτὸς ἐπελθὼν{l]
[l [n}24.419{]}οἷον ἐερσήεις κεῖται, περὶ δʼ αἷμα νένιπται,{l]
[l [n}24.420{]}οὐδέ ποθι μιαρός· σὺν δʼ ἕλκεα πάντα μέμυκεν{l]
[l [n}24.421{]}ὅσσʼ ἐτύπη· πολέες γὰρ ἐν αὐτῷ χαλκὸν ἔλασσαν.{l]
[l [n}24.422{]}ὥς τοι κήδονται μάκαρες θεοὶ υἷος ἑῆος{l]
[l [n}24.423{]}καὶ νέκυός περ ἐόντος, ἐπεί σφι φίλος περὶ κῆρι.{l]{q]{para]
[para}[l [n}24.424{]}ὣς φάτο, γήθησεν δʼ ὃ γέρων, καὶ ἀμείβετο μύθῳ·{l]
[q}[l [n}24.425{]}ὦ τέκος, ἦ ῥʼ ἀγαθὸν καὶ ἐναίσιμα δῶρα διδοῦναι{l]
[l [n}24.426{]}ἀθανάτοις, ἐπεὶ οὔ ποτʼ ἐμὸς πάϊς, εἴ ποτʼ ἔην γε,{l]
[l [n}24.427{]}λήθετʼ ἐνὶ μεγάροισι θεῶν οἳ Ὄλυμπον ἔχουσι·{l]
[l [n}24.428{]}τώ οἱ ἀπεμνήσαντο καὶ ἐν θανάτοιό περ αἴσῃ.{l]
[l [n}24.429{]}ἀλλʼ ἄγε δὴ τόδε δέξαι ἐμεῦ πάρα καλὸν ἄλεισον,{l]
[l [n}24.430{]}αὐτόν τε ῥῦσαι, πέμψον δέ με σύν γε θεοῖσιν,{l]
[l [n}24.431{]}ὄφρά κεν ἐς κλισίην Πηληϊάδεω ἀφίκωμαι.{l]{q]{para]
[para}[l [n}24.432{]}τὸν δʼ αὖτε προσέειπε διάκτορος ἀργεϊφόντης·{l]
[q}[l [n}24.433{]}πειρᾷ ἐμεῖο γεραιὲ νεωτέρου, οὐδέ με πείσεις,{l]
[l [n}24.434{]}ὅς με κέλῃ σέο δῶρα παρὲξ Ἀχιλῆα δέχεσθαι.{l]
[l [n}24.435{]}τὸν μὲν ἐγὼ δείδοικα καὶ αἰδέομαι περὶ κῆρι{l]
[l [n}24.436{]}συλεύειν, μή μοί τι κακὸν μετόπισθε γένηται.{l]
[l [n}24.437{]}σοὶ δʼ ἂν ἐγὼ πομπὸς καί κε κλυτὸν Ἄργος ἱκοίμην,{l]
[l [n}24.438{]}ἐνδυκέως ἐν νηῒ θοῇ ἢ πεζὸς ὁμαρτέων·{l]
[l [n}24.439{]}οὐκ ἄν τίς τοι πομπὸν ὀνοσσάμενος μαχέσαιτο.{l]{q]{para]
[para}[l [n}24.440{]}ἦ καὶ ἀναΐξας ἐριούνιος ἅρμα καὶ ἵππους{l]
[l [n}24.441{]}καρπαλίμως μάστιγα καὶ ἡνία λάζετο χερσίν,{l]
[l [n}24.442{]}ἐν δʼ ἔπνευσʼ ἵπποισι καὶ ἡμιόνοις μένος ἠΰ.{l]
[l [n}24.443{]}ἀλλʼ ὅτε δὴ πύργους τε νεῶν καὶ τάφρον ἵκοντο,{l]
[l [n}24.444{]}οἳ δὲ νέον περὶ δόρπα φυλακτῆρες πονέοντο,{l]
[l [n}24.445{]}τοῖσι δʼ ἐφʼ ὕπνον ἔχευε διάκτορος ἀργεϊφόντης{l]
[l [n}24.446{]}πᾶσιν, ἄφαρ δʼ ὤϊξε πύλας καὶ ἀπῶσεν ὀχῆας,{l]
[l [n}24.447{]}ἐς δʼ ἄγαγε Πρίαμόν τε καὶ ἀγλαὰ δῶρʼ ἐπʼ ἀπήνης.{l]
[l [n}24.448{]}ἀλλʼ ὅτε δὴ κλισίην Πηληϊάδεω ἀφίκοντο{l]
[l [n}24.449{]}ὑψηλήν, τὴν Μυρμιδόνες ποίησαν ἄνακτι{l]
[l [n}24.450{]}δοῦρʼ ἐλάτης κέρσαντες· ἀτὰρ καθύπερθεν ἔρεψαν{l]
[l [n}24.451{]}λαχνήεντʼ ὄροφον λειμωνόθεν ἀμήσαντες·{l]
[l [n}24.452{]}ἀμφὶ δέ οἱ μεγάλην αὐλὴν ποίησαν ἄνακτι{l]
[l [n}24.453{]}σταυροῖσιν πυκινοῖσι· θύρην δʼ ἔχε μοῦνος ἐπιβλὴς{l]
[l [n}24.454{]}εἰλάτινος, τὸν τρεῖς μὲν ἐπιρρήσσεσκον Ἀχαιοί,{l]
[l [n}24.455{]}τρεῖς δʼ ἀναοίγεσκον μεγάλην κληῗδα θυράων{l]
[l [n}24.456{]}τῶν ἄλλων· Ἀχιλεὺς δʼ ἄρʼ ἐπιρρήσσεσκε καὶ οἶος·{l]
[l [n}24.457{]}δή ῥα τόθʼ Ἑρμείας ἐριούνιος ᾦξε γέροντι,{l]
[l [n}24.458{]}ἐς δʼ ἄγαγε κλυτὰ δῶρα ποδώκεϊ Πηλεΐωνι,{l]
[l [n}24.459{]}ἐξ ἵππων δʼ ἀπέβαινεν ἐπὶ χθόνα φώνησέν τε·{l]
[q}[l [n}24.460{]}ὦ γέρον ἤτοι ἐγὼ θεὸς ἄμβροτος εἰλήλουθα{l]
[l [n}24.461{]}Ἑρμείας· σοὶ γάρ με πατὴρ ἅμα πομπὸν ὄπασσεν.{l]
[l [n}24.462{]}ἀλλʼ ἤτοι μὲν ἐγὼ πάλιν εἴσομαι, οὐδʼ Ἀχιλῆος{l]
[l [n}24.463{]}ὀφθαλμοὺς εἴσειμι· νεμεσσητὸν δέ κεν εἴη{l]
[l [n}24.464{]}ἀθάνατον θεὸν ὧδε βροτοὺς ἀγαπαζέμεν ἄντην·{l]
[l [n}24.465{]}τύνη δʼ εἰσελθὼν λαβὲ γούνατα Πηλεΐωνος,{l]
[l [n}24.466{]}καί μιν ὑπὲρ πατρὸς καὶ μητέρος ἠϋκόμοιο{l]
[l [n}24.467{]}λίσσεο καὶ τέκεος, ἵνα οἱ σὺν θυμὸν ὀρίνῃς.{l]{q]{para]
[para}[l [n}24.468{]}ὣς ἄρα φωνήσας ἀπέβη πρὸς μακρὸν Ὄλυμπον{l]
[l [n}24.469{]}Ἑρμείας· Πρίαμος δʼ ἐξ ἵππων ἆλτο χαμᾶζε,{l]
[l [n}24.470{]}Ἰδαῖον δὲ κατʼ αὖθι λίπεν· ὃ δὲ μίμνεν ἐρύκων{l]
[l [n}24.471{]}ἵππους ἡμιόνους τε· γέρων δʼ ἰθὺς κίεν οἴκου,{l]
[l [n}24.472{]}τῇ ῥʼ Ἀχιλεὺς ἵζεσκε Διῒ φίλος· ἐν δέ μιν αὐτὸν{l]
[l [n}24.473{]}εὗρʼ, ἕταροι δʼ ἀπάνευθε καθήατο· τὼ δὲ δύʼ οἴω{l]
[l [n}24.474{]}ἥρως Αὐτομέδων τε καὶ Ἄλκιμος ὄζος Ἄρηος{l]
[l [n}24.475{]}ποίπνυον παρεόντε· νέον δʼ ἀπέληγεν ἐδωδῆς{l]
[l [n}24.476{]}ἔσθων καὶ πίνων· ἔτι καὶ παρέκειτο τράπεζα.{l]
[l [n}24.477{]}τοὺς δʼ ἔλαθʼ εἰσελθὼν Πρίαμος μέγας, ἄγχι δʼ ἄρα στὰς{l]
[l [n}24.478{]}χερσὶν Ἀχιλλῆος λάβε γούνατα καὶ κύσε χεῖρας{l]
[l [n}24.479{]}δεινὰς ἀνδροφόνους, αἵ οἱ πολέας κτάνον υἷας.{l]
[l [n}24.480{]}ὡς δʼ ὅτʼ ἂν ἄνδρʼ ἄτη πυκινὴ λάβῃ, ὅς τʼ ἐνὶ πάτρῃ{l]
[l [n}24.481{]}φῶτα κατακτείνας ἄλλων ἐξίκετο δῆμον{l]
[l [n}24.482{]}ἀνδρὸς ἐς ἀφνειοῦ, θάμβος δʼ ἔχει εἰσορόωντας,{l]
[l [n}24.483{]}ὣς Ἀχιλεὺς θάμβησεν ἰδὼν Πρίαμον θεοειδέα·{l]
[l [n}24.484{]}θάμβησαν δὲ καὶ ἄλλοι, ἐς ἀλλήλους δὲ ἴδοντο.{l]
[l [n}24.485{]}τὸν καὶ λισσόμενος Πρίαμος πρὸς μῦθον ἔειπε·{l]
[q}[l [n}24.486{]}μνῆσαι πατρὸς σοῖο θεοῖς ἐπιείκελʼ Ἀχιλλεῦ,{l]
[l [n}24.487{]}τηλίκου ὥς περ ἐγών, ὀλοῷ ἐπὶ γήραος οὐδῷ·{l]
[l [n}24.488{]}καὶ μέν που κεῖνον περιναιέται ἀμφὶς ἐόντες{l]
[l [n}24.489{]}τείρουσʼ, οὐδέ τίς ἐστιν ἀρὴν καὶ λοιγὸν ἀμῦναι.{l]
[l [n}24.490{]}ἀλλʼ ἤτοι κεῖνός γε σέθεν ζώοντος ἀκούων{l]
[l [n}24.491{]}χαίρει τʼ ἐν θυμῷ, ἐπί τʼ ἔλπεται ἤματα πάντα{l]
[l [n}24.492{]}ὄψεσθαι φίλον υἱὸν ἀπὸ Τροίηθεν ἰόντα·{l]
[l [n}24.493{]}αὐτὰρ ἐγὼ πανάποτμος, ἐπεὶ τέκον υἷας ἀρίστους{l]
[l [n}24.494{]}Τροίῃ ἐν εὐρείῃ, τῶν δʼ οὔ τινά φημι λελεῖφθαι.{l]
[l [n}24.495{]}πεντήκοντά μοι ἦσαν ὅτʼ ἤλυθον υἷες Ἀχαιῶν·{l]
[l [n}24.496{]}ἐννεακαίδεκα μέν μοι ἰῆς ἐκ νηδύος ἦσαν,{l]
[l [n}24.497{]}τοὺς δʼ ἄλλους μοι ἔτικτον ἐνὶ μεγάροισι γυναῖκες.{l]
[l [n}24.498{]}τῶν μὲν πολλῶν θοῦρος Ἄρης ὑπὸ γούνατʼ ἔλυσεν·{l]
[l [n}24.499{]}ὃς δέ μοι οἶος ἔην, εἴρυτο δὲ ἄστυ καὶ αὐτούς,{l]
[l [n}24.500{]}τὸν σὺ πρῴην κτεῖνας ἀμυνόμενον περὶ πάτρης{l]
[l [n}24.501{]}Ἕκτορα· τοῦ νῦν εἵνεχʼ ἱκάνω νῆας Ἀχαιῶν{l]
[l [n}24.502{]}λυσόμενος παρὰ σεῖο, φέρω δʼ ἀπερείσιʼ ἄποινα.{l]
[l [n}24.503{]}ἀλλʼ αἰδεῖο θεοὺς Ἀχιλεῦ, αὐτόν τʼ ἐλέησον{l]
[l [n}24.504{]}μνησάμενος σοῦ πατρός· ἐγὼ δʼ ἐλεεινότερός περ,{l]
[l [n}24.505{]}ἔτλην δʼ οἷʼ οὔ πώ τις ἐπιχθόνιος βροτὸς ἄλλος,{l]
[l [n}24.506{]}ἀνδρὸς παιδοφόνοιο ποτὶ στόμα χεῖρʼ ὀρέγεσθαι.{l]{q]{para]
[para}[l [n}24.507{]}ὣς φάτο, τῷ δʼ ἄρα πατρὸς ὑφʼ ἵμερον ὦρσε γόοιο·{l]
[l [n}24.508{]}ἁψάμενος δʼ ἄρα χειρὸς ἀπώσατο ἦκα γέροντα.{l]
[l [n}24.509{]}τὼ δὲ μνησαμένω ὃ μὲν Ἕκτορος ἀνδροφόνοιο{l]
[l [n}24.510{]}κλαῖʼ ἁδινὰ προπάροιθε ποδῶν Ἀχιλῆος ἐλυσθείς,{l]
[l [n}24.511{]}αὐτὰρ Ἀχιλλεὺς κλαῖεν ἑὸν πατέρʼ, ἄλλοτε δʼ αὖτε{l]
[l [n}24.512{]}Πάτροκλον· τῶν δὲ στοναχὴ κατὰ δώματʼ ὀρώρει.{l]
[l [n}24.513{]}αὐτὰρ ἐπεί ῥα γόοιο τετάρπετο δῖος Ἀχιλλεύς,{l]
[l [n}24.514{]}καί οἱ ἀπὸ πραπίδων ἦλθʼ ἵμερος ἠδʼ ἀπὸ γυίων,{l]
[l [n}24.515{]}αὐτίκʼ ἀπὸ θρόνου ὦρτο, γέροντα δὲ χειρὸς ἀνίστη{l]
[l [n}24.516{]}οἰκτίρων πολιόν τε κάρη πολιόν τε γένειον,{l]
[l [n}24.517{]}καί μιν φωνήσας ἔπεα πτερόεντα προσηύδα·{l]
[q}[l [n}24.518{]}ἆ δείλʼ, ἦ δὴ πολλὰ κάκʼ ἄνσχεο σὸν κατὰ θυμόν.{l]
[l [n}24.519{]}πῶς ἔτλης ἐπὶ νῆας Ἀχαιῶν ἐλθέμεν οἶος{l]
[l [n}24.520{]}ἀνδρὸς ἐς ὀφθαλμοὺς ὅς τοι πολέας τε καὶ ἐσθλοὺς{l]
[l [n}24.521{]}υἱέας ἐξενάριξα; σιδήρειόν νύ τοι ἦτορ.{l]
[l [n}24.522{]}ἀλλʼ ἄγε δὴ κατʼ ἄρʼ ἕζευ ἐπὶ θρόνου, ἄλγεα δʼ ἔμπης{l]
[l [n}24.523{]}ἐν θυμῷ κατακεῖσθαι ἐάσομεν ἀχνύμενοί περ·{l]
[l [n}24.524{]}οὐ γάρ τις πρῆξις πέλεται κρυεροῖο γόοιο·{l]
[l [n}24.525{]}ὡς γὰρ ἐπεκλώσαντο θεοὶ δειλοῖσι βροτοῖσι{l]
[l [n}24.526{]}ζώειν ἀχνυμένοις· αὐτοὶ δέ τʼ ἀκηδέες εἰσί.{l]
[l [n}24.527{]}δοιοὶ γάρ τε πίθοι κατακείαται ἐν Διὸς οὔδει{l]
[l [n}24.528{]}δώρων οἷα δίδωσι κακῶν, ἕτερος δὲ ἑάων·{l]
[l [n}24.529{]}ᾧ μέν κʼ ἀμμίξας δώῃ Ζεὺς τερπικέραυνος,{l]
[l [n}24.530{]}ἄλλοτε μέν τε κακῷ ὅ γε κύρεται, ἄλλοτε δʼ ἐσθλῷ·{l]
[l [n}24.531{]}ᾧ δέ κε τῶν λυγρῶν δώῃ, λωβητὸν ἔθηκε,{l]
[l [n}24.532{]}καί ἑ κακὴ βούβρωστις ἐπὶ χθόνα δῖαν ἐλαύνει,{l]
[l [n}24.533{]}φοιτᾷ δʼ οὔτε θεοῖσι τετιμένος οὔτε βροτοῖσιν.{l]
[l [n}24.534{]}ὣς μὲν καὶ Πηλῆϊ θεοὶ δόσαν ἀγλαὰ δῶρα{l]
[l [n}24.535{]}ἐκ γενετῆς· πάντας γὰρ ἐπʼ ἀνθρώπους ἐκέκαστο{l]
[l [n}24.536{]}ὄλβῳ τε πλούτῳ τε, ἄνασσε δὲ Μυρμιδόνεσσι,{l]
[l [n}24.537{]}καί οἱ θνητῷ ἐόντι θεὰν ποίησαν ἄκοιτιν.{l]
[l [n}24.538{]}ἀλλʼ ἐπὶ καὶ τῷ θῆκε θεὸς κακόν, ὅττί οἱ οὔ τι{l]
[l [n}24.539{]}παίδων ἐν μεγάροισι γονὴ γένετο κρειόντων,{l]
[l [n}24.540{]}ἀλλʼ ἕνα παῖδα τέκεν παναώριον· οὐδέ νυ τόν γε{l]
[l [n}24.541{]}γηράσκοντα κομίζω, ἐπεὶ μάλα τηλόθι πάτρης{l]
[l [n}24.542{]}ἧμαι ἐνὶ Τροίῃ, σέ τε κήδων ἠδὲ σὰ τέκνα.{l]
[l [n}24.543{]}καὶ σὲ γέρον τὸ πρὶν μὲν ἀκούομεν ὄλβιον εἶναι·{l]
[l [n}24.544{]}ὅσσον Λέσβος ἄνω Μάκαρος ἕδος ἐντὸς ἐέργει{l]
[l [n}24.545{]}καὶ Φρυγίη καθύπερθε καὶ Ἑλλήσποντος ἀπείρων,{l]
[l [n}24.546{]}τῶν σε γέρον πλούτῳ τε καὶ υἱάσι φασὶ κεκάσθαι.{l]
[l [n}24.547{]}αὐτὰρ ἐπεί τοι πῆμα τόδʼ ἤγαγον Οὐρανίωνες{l]
[l [n}24.548{]}αἰεί τοι περὶ ἄστυ μάχαι τʼ ἀνδροκτασίαι τε.{l]
[l [n}24.549{]}ἄνσχεο, μὴ δʼ ἀλίαστον ὀδύρεο σὸν κατὰ θυμόν·{l]
[l [n}24.550{]}οὐ γάρ τι πρήξεις ἀκαχήμενος υἷος ἑῆος,{l]
[l [n}24.551{]}οὐδέ μιν ἀνστήσεις, πρὶν καὶ κακὸν ἄλλο πάθῃσθα.{l]{q]{para]
[para}[l [n}24.552{]}τὸν δʼ ἠμείβετʼ ἔπειτα γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.553{]}μή πω μʼ ἐς θρόνον ἵζε διοτρεφὲς ὄφρά κεν Ἕκτωρ{l]
[l [n}24.554{]}κεῖται ἐνὶ κλισίῃσιν ἀκηδής, ἀλλὰ τάχιστα{l]
[l [n}24.555{]}λῦσον ἵνʼ ὀφθαλμοῖσιν ἴδω· σὺ δὲ δέξαι ἄποινα{l]
[l [n}24.556{]}πολλά, τά τοι φέρομεν· σὺ δὲ τῶνδʼ ἀπόναιο, καὶ ἔλθοις{l]
[l [n}24.557{]}σὴν ἐς πατρίδα γαῖαν, ἐπεί με πρῶτον ἔασας{l]
[l [n}24.558{]}αὐτόν τε ζώειν καὶ ὁρᾶν φάος ἠελίοιο.{l]{q]{para]
[para}[l [n}24.559{]}τὸν δʼ ἄρʼ ὑπόδρα ἰδὼν προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}24.560{]}μηκέτι νῦν μʼ ἐρέθιζε γέρον· νοέω δὲ καὶ αὐτὸς{l]
[l [n}24.561{]}Ἕκτορά τοι λῦσαι, Διόθεν δέ μοι ἄγγελος ἦλθε{l]
[l [n}24.562{]}μήτηρ, ἥ μʼ ἔτεκεν, θυγάτηρ ἁλίοιο γέροντος.{l]
[l [n}24.563{]}καὶ δέ σε γιγνώσκω Πρίαμε φρεσίν, οὐδέ με λήθεις,{l]
[l [n}24.564{]}ὅττι θεῶν τίς σʼ ἦγε θοὰς ἐπὶ νῆας Ἀχαιῶν.{l]
[l [n}24.565{]}οὐ γάρ κε τλαίη βροτὸς ἐλθέμεν, οὐδὲ μάλʼ ἡβῶν,{l]
[l [n}24.566{]}ἐς στρατόν· οὐδὲ γὰρ ἂν φυλάκους λάθοι, οὐδέ κʼ ὀχῆα{l]
[l [n}24.567{]}ῥεῖα μετοχλίσσειε θυράων ἡμετεράων.{l]
[l [n}24.568{]}τὼ νῦν μή μοι μᾶλλον ἐν ἄλγεσι θυμὸν ὀρίνῃς,{l]
[l [n}24.569{]}μή σε γέρον οὐδʼ αὐτὸν ἐνὶ κλισίῃσιν ἐάσω{l]
[l [n}24.570{]}καὶ ἱκέτην περ ἐόντα, Διὸς δʼ ἀλίτωμαι ἐφετμάς.{l]{q]{para]
[para}[l [n}24.571{]}ὣς ἔφατʼ, ἔδεισεν δʼ ὃ γέρων καὶ ἐπείθετο μύθῳ.{l]
[l [n}24.572{]}Πηλεΐδης δʼ οἴκοιο λέων ὣς ἆλτο θύραζε{l]
[l [n}24.573{]}οὐκ οἶος, ἅμα τῷ γε δύω θεράποντες ἕποντο{l]
[l [n}24.574{]}ἥρως Αὐτομέδων ἠδʼ Ἄλκιμος, οὕς ῥα μάλιστα{l]
[l [n}24.575{]}τῖʼ Ἀχιλεὺς ἑτάρων μετὰ Πάτροκλόν γε θανόντα,{l]
[l [n}24.576{]}οἳ τόθʼ ὑπὸ ζυγόφιν λύον ἵππους ἡμιόνους τε,{l]
[l [n}24.577{]}ἐς δʼ ἄγαγον κήρυκα καλήτορα τοῖο γέροντος,{l]
[l [n}24.578{]}κὰδ δʼ ἐπὶ δίφρου εἷσαν· ἐϋξέστου δʼ ἀπʼ ἀπήνης{l]
[l [n}24.579{]}ᾕρεον Ἑκτορέης κεφαλῆς ἀπερείσιʼ ἄποινα.{l]
[l [n}24.580{]}κὰδ δʼ ἔλιπον δύο φάρεʼ ἐΰννητόν τε χιτῶνα,{l]
[l [n}24.581{]}ὄφρα νέκυν πυκάσας δοίη οἶκον δὲ φέρεσθαι.{l]
[l [n}24.582{]}δμῳὰς δʼ ἐκκαλέσας λοῦσαι κέλετʼ ἀμφί τʼ ἀλεῖψαι{l]
[l [n}24.583{]}νόσφιν ἀειράσας, ὡς μὴ Πρίαμος ἴδοι υἱόν,{l]
[l [n}24.584{]}μὴ ὃ μὲν ἀχνυμένῃ κραδίῃ χόλον οὐκ ἐρύσαιτο{l]
[l [n}24.585{]}παῖδα ἰδών, Ἀχιλῆϊ δʼ ὀρινθείη φίλον ἦτορ,{l]
[l [n}24.586{]}καί ἑ κατακτείνειε, Διὸς δʼ ἀλίτηται ἐφετμάς.{l]
[l [n}24.587{]}τὸν δʼ ἐπεὶ οὖν δμῳαὶ λοῦσαν καὶ χρῖσαν ἐλαίῳ,{l]
[l [n}24.588{]}ἀμφὶ δέ μιν φᾶρος καλὸν βάλον ἠδὲ χιτῶνα,{l]
[l [n}24.589{]}αὐτὸς τόν γʼ Ἀχιλεὺς λεχέων ἐπέθηκεν ἀείρας,{l]
[l [n}24.590{]}σὺν δʼ ἕταροι ἤειραν ἐϋξέστην ἐπʼ ἀπήνην.{l]
[l [n}24.591{]}ᾤμωξέν τʼ ἄρʼ ἔπειτα, φίλον δʼ ὀνόμηνεν ἑταῖρον·{l]
[q}[l [n}24.592{]}μή μοι Πάτροκλε σκυδμαινέμεν, αἴ κε πύθηαι{l]
[l [n}24.593{]}εἰν Ἄϊδός περ ἐὼν ὅτι Ἕκτορα δῖον ἔλυσα{l]
[l [n}24.594{]}πατρὶ φίλῳ, ἐπεὶ οὔ μοι ἀεικέα δῶκεν ἄποινα.{l]
[l [n}24.595{]}σοὶ δʼ αὖ ἐγὼ καὶ τῶνδʼ ἀποδάσσομαι ὅσσʼ ἐπέοικεν.{l]{q]{para]
[para}[l [n}24.596{]}ἦ ῥα, καὶ ἐς κλισίην πάλιν ἤϊε δῖος Ἀχιλλεύς,{l]
[l [n}24.597{]}ἕζετο δʼ ἐν κλισμῷ πολυδαιδάλῳ ἔνθεν ἀνέστη{l]
[l [n}24.598{]}τοίχου τοῦ ἑτέρου, ποτὶ δὲ Πρίαμον φάτο μῦθον·{l]
[q}[l [n}24.599{]}υἱὸς μὲν δή τοι λέλυται γέρον ὡς ἐκέλευες,{l]
[l [n}24.600{]}κεῖται δʼ ἐν λεχέεσσʼ· ἅμα δʼ ἠοῖ φαινομένηφιν{l]
[l [n}24.601{]}ὄψεαι αὐτὸς ἄγων· νῦν δὲ μνησώμεθα δόρπου.{l]
[l [n}24.602{]}καὶ γάρ τʼ ἠΰκομος Νιόβη ἐμνήσατο σίτου,{l]
[l [n}24.603{]}τῇ περ δώδεκα παῖδες ἐνὶ μεγάροισιν ὄλοντο{l]
[l [n}24.604{]}ἓξ μὲν θυγατέρες, ἓξ δʼ υἱέες ἡβώοντες.{l]
[l [n}24.605{]}τοὺς μὲν Ἀπόλλων πέφνεν ἀπʼ ἀργυρέοιο βιοῖο{l]
[l [n}24.606{]}χωόμενος Νιόβῃ, τὰς δʼ Ἄρτεμις ἰοχέαιρα,{l]
[l [n}24.607{]}οὕνεκʼ ἄρα Λητοῖ ἰσάσκετο καλλιπαρῄῳ·{l]
[l [n}24.608{]}φῆ δοιὼ τεκέειν, ἣ δʼ αὐτὴ γείνατο πολλούς·{l]
[l [n}24.609{]}τὼ δʼ ἄρα καὶ δοιώ περ ἐόντʼ ἀπὸ πάντας ὄλεσσαν.{l]
[l [n}24.610{]}οἳ μὲν ἄρʼ ἐννῆμαρ κέατʼ ἐν φόνῳ, οὐδέ τις ἦεν{l]
[l [n}24.611{]}κατθάψαι, λαοὺς δὲ λίθους ποίησε Κρονίων·{l]
[l [n}24.612{]}τοὺς δʼ ἄρα τῇ δεκάτῃ θάψαν θεοὶ Οὐρανίωνες.{l]
[l [n}24.613{]}ἣ δʼ ἄρα σίτου μνήσατʼ, ἐπεὶ κάμε δάκρυ χέουσα.{l]
[l [n}24.614{]}νῦν δέ που ἐν πέτρῃσιν ἐν οὔρεσιν οἰοπόλοισιν{l]
[l [n}24.615{]}ἐν Σιπύλῳ, ὅθι φασὶ θεάων ἔμμεναι εὐνὰς{l]
[l [n}24.616{]}νυμφάων, αἵ τʼ ἀμφʼ Ἀχελώϊον ἐρρώσαντο,{l]
[l [n}24.617{]}ἔνθα λίθος περ ἐοῦσα θεῶν ἐκ κήδεα πέσσει.{l]
[l [n}24.618{]}ἀλλʼ ἄγε δὴ καὶ νῶϊ μεδώμεθα δῖε γεραιὲ{l]
[l [n}24.619{]}σίτου· ἔπειτά κεν αὖτε φίλον παῖδα κλαίοισθα{l]
[l [n}24.620{]}Ἴλιον εἰσαγαγών· πολυδάκρυτος δέ τοι ἔσται.{l]{q]{para]
[para}[l [n}24.621{]}ἦ καὶ ἀναΐξας ὄϊν ἄργυφον ὠκὺς Ἀχιλλεὺς{l]
[l [n}24.622{]}σφάξʼ· ἕταροι δʼ ἔδερόν τε καὶ ἄμφεπον εὖ κατὰ κόσμον,{l]
[l [n}24.623{]}μίστυλλόν τʼ ἄρʼ ἐπισταμένως πεῖράν τʼ ὀβελοῖσιν,{l]
[l [n}24.624{]}ὄπτησάν τε περιφραδέως, ἐρύσαντό τε πάντα.{l]
[l [n}24.625{]}Αὐτομέδων δʼ ἄρα σῖτον ἑλὼν ἐπένειμε τραπέζῃ{l]
[l [n}24.626{]}καλοῖς ἐν κανέοισιν· ἀτὰρ κρέα νεῖμεν Ἀχιλλεύς.{l]
[l [n}24.627{]}οἳ δʼ ἐπʼ ὀνείαθʼ ἑτοῖμα προκείμενα χεῖρας ἴαλλον.{l]
[l [n}24.628{]}αὐτὰρ ἐπεὶ πόσιος καὶ ἐδητύος ἐξ ἔρον ἕντο,{l]
[l [n}24.629{]}ἤτοι Δαρδανίδης Πρίαμος θαύμαζʼ Ἀχιλῆα{l]
[l [n}24.630{]}ὅσσος ἔην οἷός τε· θεοῖσι γὰρ ἄντα ἐῴκει·{l]
[l [n}24.631{]}αὐτὰρ ὃ Δαρδανίδην Πρίαμον θαύμαζεν Ἀχιλλεὺς{l]
[l [n}24.632{]}εἰσορόων ὄψίν τʼ ἀγαθὴν καὶ μῦθον ἀκούων.{l]
[l [n}24.633{]}αὐτὰρ ἐπεὶ τάρπησαν ἐς ἀλλήλους ὁρόωντες,{l]
[l [n}24.634{]}τὸν πρότερος προσέειπε γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.635{]}λέξον νῦν με τάχιστα διοτρεφές, ὄφρα καὶ ἤδη{l]
[l [n}24.636{]}ὕπνῳ ὕπο γλυκερῷ ταρπώμεθα κοιμηθέντες·{l]
[l [n}24.637{]}οὐ γάρ πω μύσαν ὄσσε ὑπὸ βλεφάροισιν ἐμοῖσιν{l]
[l [n}24.638{]}ἐξ οὗ σῇς ὑπὸ χερσὶν ἐμὸς πάϊς ὤλεσε θυμόν,{l]
[l [n}24.639{]}ἀλλʼ αἰεὶ στενάχω καὶ κήδεα μυρία πέσσω{l]
[l [n}24.640{]}αὐλῆς ἐν χόρτοισι κυλινδόμενος κατὰ κόπρον.{l]
[l [n}24.641{]}νῦν δὴ καὶ σίτου πασάμην καὶ αἴθοπα οἶνον{l]
[l [n}24.642{]}λαυκανίης καθέηκα· πάρος γε μὲν οὔ τι πεπάσμην.{l]{q]{para]
[para}[l [n}24.643{]}ἦ ῥʼ, Ἀχιλεὺς δʼ ἑτάροισιν ἰδὲ δμῳῇσι κέλευσε{l]
[l [n}24.644{]}δέμνιʼ ὑπʼ αἰθούσῃ θέμεναι καὶ ῥήγεα καλὰ{l]
[l [n}24.645{]}πορφύρεʼ ἐμβαλέειν, στορέσαι τʼ ἐφύπερθε τάπητας,{l]
[l [n}24.646{]}χλαίνας τʼ ἐνθέμεναι οὔλας καθύπερθεν ἕσασθαι.{l]
[l [n}24.647{]}αἳ δʼ ἴσαν ἐκ μεγάροιο δάος μετὰ χερσὶν ἔχουσαι,{l]
[l [n}24.648{]}αἶψα δʼ ἄρα στόρεσαν δοιὼ λέχεʼ ἐγκονέουσαι.{l]
[l [n}24.649{]}τὸν δʼ ἐπικερτομέων προσέφη πόδας ὠκὺς Ἀχιλλεύς·{l]
[q}[l [n}24.650{]}ἐκτὸς μὲν δὴ λέξο γέρον φίλε, μή τις Ἀχαιῶν{l]
[l [n}24.651{]}ἐνθάδʼ ἐπέλθῃσιν βουληφόρος, οἵ τέ μοι αἰεὶ{l]
[l [n}24.652{]}βουλὰς βουλεύουσι παρήμενοι, ἣ θέμις ἐστί·{l]
[l [n}24.653{]}τῶν εἴ τίς σε ἴδοιτο θοὴν διὰ νύκτα μέλαιναν,{l]
[l [n}24.654{]}αὐτίκʼ ἂν ἐξείποι Ἀγαμέμνονι ποιμένι λαῶν,{l]
[l [n}24.655{]}καί κεν ἀνάβλησις λύσιος νεκροῖο γένηται.{l]
[l [n}24.656{]}ἀλλʼ ἄγε μοι τόδε εἰπὲ καὶ ἀτρεκέως κατάλεξον,{l]
[l [n}24.657{]}ποσσῆμαρ μέμονας κτερεϊζέμεν Ἕκτορα δῖον,{l]
[l [n}24.658{]}ὄφρα τέως αὐτός τε μένω καὶ λαὸν ἐρύκω.{l]{q]{para]
[para}[l [n}24.659{]}τὸν δʼ ἠμείβετʼ ἔπειτα γέρων Πρίαμος θεοειδής·{l]
[q}[l [n}24.660{]}εἰ μὲν δή μʼ ἐθέλεις τελέσαι τάφον Ἕκτορι δίῳ,{l]
[l [n}24.661{]}ὧδέ κέ μοι ῥέζων Ἀχιλεῦ κεχαρισμένα θείης.{l]
[l [n}24.662{]}οἶσθα γὰρ ὡς κατὰ ἄστυ ἐέλμεθα, τηλόθι δʼ ὕλη{l]
[l [n}24.663{]}ἀξέμεν ἐξ ὄρεος, μάλα δὲ Τρῶες δεδίασιν.{l]
[l [n}24.664{]}ἐννῆμαρ μέν κʼ αὐτὸν ἐνὶ μεγάροις γοάοιμεν,{l]
[l [n}24.665{]}τῇ δεκάτῃ δέ κε θάπτοιμεν δαινῦτό τε λαός,{l]
[l [n}24.666{]}ἑνδεκάτῃ δέ κε τύμβον ἐπʼ αὐτῷ ποιήσαιμεν,{l]
[l [n}24.667{]}τῇ δὲ δυωδεκάτῃ πολεμίξομεν εἴ περ ἀνάγκη.{l]{q]{para]
[para}[l [n}24.668{]}τὸν δʼ αὖτε προσέειπε ποδάρκης δῖος Ἀχιλλεύς·{l]
[q}[l [n}24.669{]}ἔσται τοι καὶ ταῦτα γέρον Πρίαμʼ ὡς σὺ κελεύεις·{l]
[l [n}24.670{]}σχήσω γὰρ πόλεμον τόσσον χρόνον ὅσσον ἄνωγας.{l]{q]{para]
[para}[l [n}24.671{]}ὣς ἄρα φωνήσας ἐπὶ καρπῷ χεῖρα γέροντος{l]
[l [n}24.672{]}ἔλλαβε δεξιτερήν, μή πως δείσειʼ ἐνὶ θυμῷ.{l]
[l [n}24.673{]}οἳ μὲν ἄρʼ ἐν προδόμῳ δόμου αὐτόθι κοιμήσαντο{l]
[l [n}24.674{]}κῆρυξ καὶ Πρίαμος πυκινὰ φρεσὶ μήδεʼ ἔχοντες,{l]
[l [n}24.675{]}αὐτὰρ Ἀχιλλεὺς εὗδε μυχῷ κλισίης ἐϋπήκτου·{l]
[l [n}24.676{]}τῷ δὲ Βρισηῒς παρελέξατο καλλιπάρῃος.{l]{para]
[para}[l [n}24.677{]}ἄλλοι μέν ῥα θεοί τε καὶ ἀνέρες ἱπποκορυσταὶ{l]
[l [n}24.678{]}εὗδον παννύχιοι μαλακῷ δεδμημένοι ὕπνῳ·{l]
[l [n}24.679{]}ἀλλʼ οὐχ Ἑρμείαν ἐριούνιον ὕπνος ἔμαρπτεν{l]
[l [n}24.680{]}ὁρμαίνοντʼ ἀνὰ θυμὸν ὅπως Πρίαμον βασιλῆα{l]
[l [n}24.681{]}νηῶν ἐκπέμψειε λαθὼν ἱεροὺς πυλαωρούς.{l]
[l [n}24.682{]}στῆ δʼ ἄρʼ ὑπὲρ κεφαλῆς καί μιν πρὸς μῦθον ἔειπεν·{l]
[q}[l [n}24.683{]}ὦ γέρον οὔ νύ τι σοί γε μέλει κακόν, οἷον ἔθʼ εὕδεις{l]
[l [n}24.684{]}ἀνδράσιν ἐν δηΐοισιν, ἐπεί σʼ εἴασεν Ἀχιλλεύς.{l]
[l [n}24.685{]}καὶ νῦν μὲν φίλον υἱὸν ἐλύσαο, πολλὰ δʼ ἔδωκας·{l]
[l [n}24.686{]}σεῖο δέ κε ζωοῦ καὶ τρὶς τόσα δοῖεν ἄποινα{l]
[l [n}24.687{]}παῖδες τοὶ μετόπισθε λελειμμένοι, αἴ κʼ Ἀγαμέμνων{l]
[l [n}24.688{]}γνώῃ σʼ Ἀτρεΐδης, γνώωσι δὲ πάντες Ἀχαιοί.{l]{q]{para]
[para}[l [n}24.689{]}ὣς ἔφατʼ, ἔδεισεν δʼ ὃ γέρων, κήρυκα δʼ ἀνίστη.{l]
[l [n}24.690{]}τοῖσιν δʼ Ἑρμείας ζεῦξʼ ἵππους ἡμιόνους τε,{l]
[l [n}24.691{]}ῥίμφα δʼ ἄρʼ αὐτὸς ἔλαυνε κατὰ στρατόν, οὐδέ τις ἔγνω.{l]{para]
[para}[l [n}24.692{]}ἀλλʼ ὅτε δὴ πόρον ἷξον ἐϋρρεῖος ποταμοῖο{l]
[l [n}24.693{]}Ξάνθου δινήεντος, ὃν ἀθάνατος τέκετο Ζεύς,{l]
[l [n}24.694{]}Ἑρμείας μὲν ἔπειτʼ ἀπέβη πρὸς μακρὸν Ὄλυμπον,{l]
[l [n}24.695{]}Ἠὼς δὲ κροκόπεπλος ἐκίδνατο πᾶσαν ἐπʼ αἶαν,{l]
[l [n}24.696{]}οἳ δʼ εἰς ἄστυ ἔλων οἰμωγῇ τε στοναχῇ τε{l]
[l [n}24.697{]}ἵππους, ἡμίονοι δὲ νέκυν φέρον. οὐδέ τις ἄλλος{l]
[l [n}24.698{]}ἔγνω πρόσθʼ ἀνδρῶν καλλιζώνων τε γυναικῶν,{l]
[l [n}24.699{]}ἀλλʼ ἄρα Κασσάνδρη ἰκέλη χρυσῇ Ἀφροδίτῃ{l]
[l [n}24.700{]}Πέργαμον εἰσαναβᾶσα φίλον πατέρʼ εἰσενόησεν{l]
[l [n}24.701{]}ἑσταότʼ ἐν δίφρῳ, κήρυκά τε ἀστυβοώτην·{l]
[l [n}24.702{]}τὸν δʼ ἄρʼ ἐφʼ ἡμιόνων ἴδε κείμενον ἐν λεχέεσσι·{l]
[l [n}24.703{]}κώκυσέν τʼ ἄρʼ ἔπειτα γέγωνέ τε πᾶν κατὰ ἄστυ·{l]
[q}[l [n}24.704{]}ὄψεσθε Τρῶες καὶ Τρῳάδες Ἕκτορʼ ἰόντες,{l]
[l [n}24.705{]}εἴ ποτε καὶ ζώοντι μάχης ἐκνοστήσαντι{l]
[l [n}24.706{]}χαίρετʼ, ἐπεὶ μέγα χάρμα πόλει τʼ ἦν παντί τε δήμῳ.{l]{q]{para]
[para}[l [n}24.707{]}ὣς ἔφατʼ, οὐδέ τις αὐτόθʼ ἐνὶ πτόλεϊ λίπετʼ ἀνὴρ{l]
[l [n}24.708{]}οὐδὲ γυνή· πάντας γὰρ ἀάσχετον ἵκετο πένθος·{l]
[l [n}24.709{]}ἀγχοῦ δὲ ξύμβληντο πυλάων νεκρὸν ἄγοντι.{l]
[l [n}24.710{]}πρῶται τόν γʼ ἄλοχός τε φίλη καὶ πότνια μήτηρ{l]
[l [n}24.711{]}τιλλέσθην ἐπʼ ἄμαξαν ἐΰτροχον ἀΐξασαι{l]
[l [n}24.712{]}ἁπτόμεναι κεφαλῆς· κλαίων δʼ ἀμφίσταθʼ ὅμιλος.{l]
[l [n}24.713{]}καί νύ κε δὴ πρόπαν ἦμαρ ἐς ἠέλιον καταδύντα{l]
[l [n}24.714{]}Ἕκτορα δάκρυ χέοντες ὀδύροντο πρὸ πυλάων,{l]
[l [n}24.715{]}εἰ μὴ ἄρʼ ἐκ δίφροιο γέρων λαοῖσι μετηύδα·{l]
[q}[l [n}24.716{]}εἴξατέ μοι οὐρεῦσι διελθέμεν· αὐτὰρ ἔπειτα{l]
[l [n}24.717{]}ἄσεσθε κλαυθμοῖο, ἐπὴν ἀγάγωμι δόμον δέ.{l]{q]{para]
[para}[l [n}24.718{]}ὣς ἔφαθʼ, οἳ δὲ διέστησαν καὶ εἶξαν ἀπήνῃ.{l]
[l [n}24.719{]}οἳ δʼ ἐπεὶ εἰσάγαγον κλυτὰ δώματα, τὸν μὲν ἔπειτα{l]
[l [n}24.720{]}τρητοῖς ἐν λεχέεσσι θέσαν, παρὰ δʼ εἷσαν ἀοιδοὺς{l]
[l [n}24.721{]}θρήνων ἐξάρχους, οἵ τε στονόεσσαν ἀοιδὴν{l]
[l [n}24.722{]}οἳ μὲν ἄρʼ ἐθρήνεον, ἐπὶ δὲ στενάχοντο γυναῖκες.{l]
[l [n}24.723{]}τῇσιν δʼ Ἀνδρομάχη λευκώλενος ἦρχε γόοιο{l]
[l [n}24.724{]}Ἕκτορος ἀνδροφόνοιο κάρη μετὰ χερσὶν ἔχουσα·{l]
[q}[l [n}24.725{]}ἆνερ ἀπʼ αἰῶνος νέος ὤλεο, κὰδ δέ με χήρην{l]
[l [n}24.726{]}λείπεις ἐν μεγάροισι· πάϊς δʼ ἔτι νήπιος αὔτως{l]
[l [n}24.727{]}ὃν τέκομεν σύ τʼ ἐγώ τε δυσάμμοροι, οὐδέ μιν οἴω{l]
[l [n}24.728{]}ἥβην ἵξεσθαι· πρὶν γὰρ πόλις ἥδε κατʼ ἄκρης{l]
[l [n}24.729{]}πέρσεται· ἦ γὰρ ὄλωλας ἐπίσκοπος, ὅς τέ μιν αὐτὴν{l]
[l [n}24.730{]}ῥύσκευ, ἔχες δʼ ἀλόχους κεδνὰς καὶ νήπια τέκνα,{l]
[l [n}24.731{]}αἳ δή τοι τάχα νηυσὶν ὀχήσονται γλαφυρῇσι,{l]
[l [n}24.732{]}καὶ μὲν ἐγὼ μετὰ τῇσι· σὺ δʼ αὖ τέκος ἢ ἐμοὶ αὐτῇ{l]
[l [n}24.733{]}ἕψεαι, ἔνθά κεν ἔργα ἀεικέα ἐργάζοιο{l]
[l [n}24.734{]}ἀθλεύων πρὸ ἄνακτος ἀμειλίχου, ἤ τις Ἀχαιῶν{l]
[l [n}24.735{]}ῥίψει χειρὸς ἑλὼν ἀπὸ πύργου λυγρὸν ὄλεθρον{l]
[l [n}24.736{]}χωόμενος, ᾧ δή που ἀδελφεὸν ἔκτανεν Ἕκτωρ{l]
[l [n}24.737{]}ἢ πατέρʼ ἠὲ καὶ υἱόν, ἐπεὶ μάλα πολλοὶ Ἀχαιῶν{l]
[l [n}24.738{]}Ἕκτορος ἐν παλάμῃσιν ὀδὰξ ἕλον ἄσπετον οὖδας.{l]
[l [n}24.739{]}οὐ γὰρ μείλιχος ἔσκε πατὴρ τεὸς ἐν δαῒ λυγρῇ·{l]
[l [n}24.740{]}τὼ καί μιν λαοὶ μὲν ὀδύρονται κατὰ ἄστυ,{l]
[l [n}24.741{]}ἀρητὸν δὲ τοκεῦσι γόον καὶ πένθος ἔθηκας{l]
[l [n}24.742{]}Ἕκτορ· ἐμοὶ δὲ μάλιστα λελείψεται ἄλγεα λυγρά.{l]
[l [n}24.743{]}οὐ γάρ μοι θνῄσκων λεχέων ἐκ χεῖρας ὄρεξας,{l]
[l [n}24.744{]}οὐδέ τί μοι εἶπες πυκινὸν ἔπος, οὗ τέ κεν αἰεὶ{l]
[l [n}24.745{]}μεμνῄμην νύκτάς τε καὶ ἤματα δάκρυ χέουσα.{l]{q]{para]
[para}[l [n}24.746{]}ὣς ἔφατο κλαίουσʼ, ἐπὶ δὲ στενάχοντο γυναῖκες.{l]
[l [n}24.747{]}τῇσιν δʼ αὖθʼ Ἑκάβη ἁδινοῦ ἐξῆρχε γόοιο·{l]
[q}[l [n}24.748{]}Ἕκτορ ἐμῷ θυμῷ πάντων πολὺ φίλτατε παίδων,{l]
[l [n}24.749{]}ἦ μέν μοι ζωός περ ἐὼν φίλος ἦσθα θεοῖσιν·{l]
[l [n}24.750{]}οἳ δʼ ἄρα σεῦ κήδοντο καὶ ἐν θανάτοιό περ αἴσῃ.{l]
[l [n}24.751{]}ἄλλους μὲν γὰρ παῖδας ἐμοὺς πόδας ὠκὺς Ἀχιλλεὺς{l]
[l [n}24.752{]}πέρνασχʼ ὅν τινʼ ἕλεσκε πέρην ἁλὸς ἀτρυγέτοιο,{l]
[l [n}24.753{]}ἐς Σάμον ἔς τʼ Ἴμβρον καὶ Λῆμνον ἀμιχθαλόεσσαν·{l]
[l [n}24.754{]}σεῦ δʼ ἐπεὶ ἐξέλετο ψυχὴν ταναήκεϊ χαλκῷ,{l]
[l [n}24.755{]}πολλὰ ῥυστάζεσκεν ἑοῦ περὶ σῆμʼ ἑτάροιο{l]
[l [n}24.756{]}Πατρόκλου, τὸν ἔπεφνες· ἀνέστησεν δέ μιν οὐδʼ ὧς.{l]
[l [n}24.757{]}νῦν δέ μοι ἑρσήεις καὶ πρόσφατος ἐν μεγάροισι{l]
[l [n}24.758{]}κεῖσαι, τῷ ἴκελος ὅν τʼ ἀργυρότοξος Ἀπόλλων{l]
[l [n}24.759{]}οἷς ἀγανοῖσι βέλεσσιν ἐποιχόμενος κατέπεφνεν.{l]{q]{para]
[para}[l [n}24.760{]}ὣς ἔφατο κλαίουσα, γόον δʼ ἀλίαστον ὄρινε.{l]
[l [n}24.761{]}τῇσι δʼ ἔπειθʼ Ἑλένη τριτάτη ἐξῆρχε γόοιο·{l]
[q}[l [n}24.762{]}Ἕκτορ ἐμῷ θυμῷ δαέρων πολὺ φίλτατε πάντων,{l]
[l [n}24.763{]}ἦ μέν μοι πόσις ἐστὶν Ἀλέξανδρος θεοειδής,{l]
[l [n}24.764{]}ὅς μʼ ἄγαγε Τροίηνδʼ· ὡς πρὶν ὤφελλον ὀλέσθαι.{l]
[l [n}24.765{]}ἤδη γὰρ νῦν μοι τόδε εἰκοστὸν ἔτος ἐστὶν{l]
[l [n}24.766{]}ἐξ οὗ κεῖθεν ἔβην καὶ ἐμῆς ἀπελήλυθα πάτρης·{l]
[l [n}24.767{]}ἀλλʼ οὔ πω σεῦ ἄκουσα κακὸν ἔπος οὐδʼ ἀσύφηλον·{l]
[l [n}24.768{]}ἀλλʼ εἴ τίς με καὶ ἄλλος ἐνὶ μεγάροισιν ἐνίπτοι{l]
[l [n}24.769{]}δαέρων ἢ γαλόων ἢ εἰνατέρων εὐπέπλων,{l]
[l [n}24.770{]}ἢ ἑκυρή, ἑκυρὸς δὲ πατὴρ ὣς ἤπιος αἰεί,{l]
[l [n}24.771{]}ἀλλὰ σὺ τὸν ἐπέεσσι παραιφάμενος κατέρυκες{l]
[l [n}24.772{]}σῇ τʼ ἀγανοφροσύνῃ καὶ σοῖς ἀγανοῖς ἐπέεσσι.{l]
[l [n}24.773{]}τὼ σέ θʼ ἅμα κλαίω καὶ ἔμʼ ἄμμορον ἀχνυμένη κῆρ·{l]
[l [n}24.774{]}οὐ γάρ τίς μοι ἔτʼ ἄλλος ἐνὶ Τροίῃ εὐρείῃ{l]
[l [n}24.775{]}ἤπιος οὐδὲ φίλος, πάντες δέ με πεφρίκασιν.{l]{q]{para]
[para}[l [n}24.776{]}ὣς ἔφατο κλαίουσʼ, ἐπὶ δʼ ἔστενε δῆμος ἀπείρων.{l]
[l [n}24.777{]}λαοῖσιν δʼ ὃ γέρων Πρίαμος μετὰ μῦθον ἔειπεν·{l]
[q}[l [n}24.778{]}ἄξετε νῦν Τρῶες ξύλα ἄστυ δέ, μὴ δέ τι θυμῷ{l]
[l [n}24.779{]}δείσητʼ Ἀργείων πυκινὸν λόχον· ἦ γὰρ Ἀχιλλεὺς{l]
[l [n}24.780{]}πέμπων μʼ ὧδʼ ἐπέτελλε μελαινάων ἀπὸ νηῶν{l]
[l [n}24.781{]}μὴ πρὶν πημανέειν πρὶν δωδεκάτη μόλῃ ἠώς.{l]{q]{para]
[para}[l [n}24.782{]}ὣς ἔφαθʼ, οἳ δʼ ὑπʼ ἀμάξῃσιν βόας ἡμιόνους τε{l]
[l [n}24.783{]}ζεύγνυσαν, αἶψα δʼ ἔπειτα πρὸ ἄστεος ἠγερέθοντο.{l]
[l [n}24.784{]}ἐννῆμαρ μὲν τοί γε ἀγίνεον ἄσπετον ὕλην·{l]
[l [n}24.785{]}ἀλλʼ ὅτε δὴ δεκάτη ἐφάνη φαεσίμβροτος ἠώς,{l]
[l [n}24.786{]}καὶ τότʼ ἄρʼ ἐξέφερον θρασὺν Ἕκτορα δάκρυ χέοντες,{l]
[l [n}24.787{]}ἐν δὲ πυρῇ ὑπάτῃ νεκρὸν θέσαν, ἐν δʼ ἔβαλον πῦρ.{l]{para]
[para}[l [n}24.788{]}ἦμος δʼ ἠριγένεια φάνη ῥοδοδάκτυλος Ἠώς,{l]
[l [n}24.789{]}τῆμος ἄρʼ ἀμφὶ πυρὴν κλυτοῦ Ἕκτορος ἔγρετο λαός.{l]
[l [n}24.790{]}αὐτὰρ ἐπεί ῥʼ ἤγερθεν ὁμηγερέες τʼ ἐγένοντο{l]
[l [n}24.791{]}πρῶτον μὲν κατὰ πυρκαϊὴν σβέσαν αἴθοπι οἴνῳ{l]
[l [n}24.792{]}πᾶσαν, ὁπόσσον ἐπέσχε πυρὸς μένος· αὐτὰρ ἔπειτα{l]
[l [n}24.793{]}ὀστέα λευκὰ λέγοντο κασίγνητοί θʼ ἕταροί τε{l]
[l [n}24.794{]}μυρόμενοι, θαλερὸν δὲ κατείβετο δάκρυ παρειῶν.{l]
[l [n}24.795{]}καὶ τά γε χρυσείην ἐς λάρνακα θῆκαν ἑλόντες{l]
[l [n}24.796{]}πορφυρέοις πέπλοισι καλύψαντες μαλακοῖσιν.{l]
[l [n}24.797{]}αἶψα δʼ ἄρʼ ἐς κοίλην κάπετον θέσαν, αὐτὰρ ὕπερθε{l]
[l [n}24.798{]}πυκνοῖσιν λάεσσι κατεστόρεσαν μεγάλοισι·{l]
[l [n}24.799{]}ῥίμφα δὲ σῆμʼ ἔχεαν, περὶ δὲ σκοποὶ ἥατο πάντῃ,{l]
[l [n}24.800{]}μὴ πρὶν ἐφορμηθεῖεν ἐϋκνήμιδες Ἀχαιοί.{l]
[l [n}24.801{]}χεύαντες δὲ τὸ σῆμα πάλιν κίον· αὐτὰρ ἔπειτα{l]
[l [n}24.802{]}εὖ συναγειρόμενοι δαίνυντʼ ἐρικυδέα δαῖτα{l]
[l [n}24.803{]}δώμασιν ἐν Πριάμοιο διοτρεφέος βασιλῆος.{l]{para]
[para}[l [n}24.804{]}ὣς οἵ γʼ ἀμφίεπον τάφον Ἕκτορος ἱπποδάμοιο.{l]{para]
